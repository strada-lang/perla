# Perla Parser - Builds AST from token stream
#
# Recursive descent parser for Perl 5 syntax.
# Returns a program AST node containing statements and sub definitions.

use Perla::AST;
use Perla::Lexer;

package Perla::Parser;

func reset_modules() void {
    # no-op - state is now in parser context
}

# --- Debug helper: writes to stderr when PERLA_DEBUG=1. Compile-time
#     counterpart to the runtime perla_debug_mode() hooks in perla_stash.c. ---
func _dbg(str $msg) void {
    if (core::getenv("PERLA_DEBUG") eq "1") {
        __C__ {
            char *__m = strada_to_str(msg);
            fprintf(stderr, "[perla] %s\n", __m);
            free(__m);
        }
    }
}

func add_lib_path(str $path) void {
    # no-op - called from Perla.strada, but paths are now set on parser
}

# These work on the parser context directly
func _get_lib_paths_from(scalar $p) scalar {
    return $p->{"lib_paths"};
}

func _is_module_loaded_in(scalar $p, str $module) int {
    my scalar $loaded = $p->{"loaded_modules"};
    if (!defined($loaded)) { return 0; }
    my str $val = "" . $loaded->{$module};
    if (length($val) > 0 && $val ne "0") { return 1; }
    return 0;
}

func _mark_module_loaded_in(scalar $p, str $module) void {
    if (!defined($p->{"loaded_modules"})) {
        $p->{"loaded_modules"} = {};
    }
    $p->{"loaded_modules"}->{$module} = 1;
}

func parse(array @tokens) scalar {
    return parse_with_paths(@tokens, []);
}

func parse_with_filename(array @tokens, str $filename) scalar {
    return parse_with_file_context(@tokens, [], {}, $filename);
}

func parse_with_file_context(array @tokens, scalar $init_lib_paths, scalar $loaded_mods, str $filename) scalar {
    return parse_with_file_context_paths(@tokens, $init_lib_paths, $loaded_mods, {}, $filename);
}

# Same as parse_with_file_context, but takes an explicit loaded_paths
# hash for path-based dedup across recursive parses.
func parse_with_file_context_paths(array @tokens, scalar $init_lib_paths, scalar $loaded_mods, scalar $loaded_paths, str $filename) scalar {
    my hash %parser = ();
    $parser{"tokens"} = \@tokens;
    $parser{"pos"} = 0;
    $parser{"len"} = scalar(@tokens);
    $parser{"pkg"} = "main";
    $parser{"lib_paths"} = $init_lib_paths;
    $parser{"loaded_modules"} = $loaded_mods;
    # At the very start of a TOP-LEVEL --precompile-deps run (no ancestor in
    # PERLA_BUILDING_LIST), clear any .buildfail markers left by a previous
    # build so this run retries every module from scratch — essential after a
    # compiler fix. Guarded by PERLA_MARKERS_CLEARED so the many nested
    # in-process parses don't re-clear; spawned children have a non-empty
    # PERLA_BUILDING_LIST so they never clear (and thus keep the cache warm
    # across the build).
    if (core::getenv("PERLA_PRECOMPILE_DEPS") eq "1"
        && core::getenv("PERLA_BUILDING_LIST") eq ""
        && core::getenv("PERLA_MARKERS_CLEARED") ne "1") {
        core::setenv("PERLA_MARKERS_CLEARED", "1");
        if (defined($init_lib_paths)) {
            my int $__mci = 0;
            while ($__mci < scalar(@{$init_lib_paths})) {
                my str $__mcp = $init_lib_paths->[$__mci];
                if (length($__mcp) > 0) {
                    core::qx("find " . $__mcp . " -name '*.pm.buildfail' -delete 2>/dev/null");
                }
                $__mci = $__mci + 1;
            }
        }
    }
    # Path-based dedup: seed with the current file so a sibling `use X`
    # that happens to resolve to this same file (via a lib_path
    # collision) doesn't re-parse it under a different module name and
    # duplicate every sub it defines. See the matching check in
    # _load_module.
    if (!defined($loaded_paths)) { $loaded_paths = {}; }
    $parser{"loaded_paths"} = $loaded_paths;
    if (length($filename) > 0) {
        $parser{"loaded_paths"}->{$filename} = 1;
    }
    $parser{"filename"} = $filename;
    $parser{"current_sub"} = "";

    my scalar $prog = Perla::AST::node(Perla::AST::N_PROGRAM());
    $prog->{"stmts"} = [];
    $prog->{"package"} = "main";
    $prog->{"lib_paths"} = $init_lib_paths;
    # Propagate source filename to the AST root so codegen can use it
    # for caller(), die location messages, and __FILE__.
    if (length($filename) > 0) { $prog->{"filename"} = $filename; }
    $parser{"prog"} = $prog;

    while (!_at_end(\%parser)) {
        # DATA_SECTION is a pseudo-token emitted by the lexer after
        # `__DATA__` — capture the raw post-marker content on the AST
        # root and stop parsing. CodeGen opens it as the DATA filehandle.
        if (_peek_type(\%parser) eq "DATA_SECTION") {
            $prog->{"data_section"} = _peek_val(\%parser);
            _advance(\%parser);
            last;
        }
        my scalar $stmt = undef;
        try {
            $stmt = _parse_stmt(\%parser);
        } catch ($e) {
            # Parse error - skip to next semicolon or brace to recover
            my str $fn = "" . $parser{"filename"};
            my str $pkg = "" . $parser{"pkg"};
            my str $next_tok = _at_end(\%parser) ? "EOF" : _peek_val(\%parser);
            say(STDERR, "[parse error] " . $fn . " pkg=" . $pkg . " near '" . $next_tok . "': " . $e);
            while (!_at_end(\%parser)) {
                my str $skip_type = _peek_type(\%parser);
                if ($skip_type eq "SEMI" || $skip_type eq "SUB" || $skip_type eq "PACKAGE") { last; }
                _advance(\%parser);
            }
            _match(\%parser, "SEMI");
        }
        if (defined($stmt)) {
            push(@{$prog->{"stmts"}}, $stmt);
        }
    }

    # Expose the Perl -V @INC cache on the AST so CodeGen can seed the
    # runtime require search paths from it (along with user-declared
    # lib_paths from `use lib`). Ensure it's populated even when the
    # main program's compile-time `use` calls all resolved through
    # direct lib_paths - binaries may still `require X` at runtime
    # against the parent Perl install's @INC.
    if (!defined($parser{"inc_roots"})) {
        my scalar $inc_cache = [];
        my str $perl_binary = core::getenv("PERLA_PERL");
        if (length($perl_binary) == 0) { $perl_binary = "perl"; }
        my str $inc_cmd = $perl_binary . " -e 'print join(\":\", grep { !/^\\./ && -d $_ } @INC)' 2>/dev/null";
        my str $inc_out = trim(core::qx($inc_cmd));
        if (length($inc_out) > 0) {
            my array @inc_roots = split(":", $inc_out);
            my int $ri = 0;
            while ($ri < scalar(@inc_roots)) {
                my str $rp = trim($inc_roots[$ri]);
                if (length($rp) > 0) { push(@{$inc_cache}, $rp); }
                $ri++;
            }
        }
        $parser{"inc_roots"} = $inc_cache;
    }
    $prog->{"inc_roots"} = $parser{"inc_roots"};

    return $prog;
}

func parse_with_paths(array @tokens, scalar $init_lib_paths) scalar {
    return parse_with_context(@tokens, $init_lib_paths, {});
}

func parse_with_context(array @tokens, scalar $init_lib_paths, scalar $loaded_mods) scalar {
    my hash %parser = ();
    $parser{"tokens"} = \@tokens;
    $parser{"pos"} = 0;
    $parser{"len"} = scalar(@tokens);
    $parser{"pkg"} = "main";
    $parser{"lib_paths"} = $init_lib_paths;
    $parser{"loaded_modules"} = $loaded_mods;
    $parser{"filename"} = "";
    $parser{"current_sub"} = "";

    my scalar $prog = Perla::AST::node(Perla::AST::N_PROGRAM());
    $prog->{"stmts"} = [];
    $prog->{"package"} = "main";
    $prog->{"lib_paths"} = $init_lib_paths;
    $parser{"prog"} = $prog;

    while (!_at_end(\%parser)) {
        my scalar $stmt = undef;
        try {
            $stmt = _parse_stmt(\%parser);
        } catch ($e) {
            # Parse error - skip to next semicolon/sub/package to recover.
            # Matches parse_with_file_context. Without this, a fatal parse
            # error inside a transitively-loaded module can abort the whole
            # main compilation.
            my str $pkg = "" . $parser{"pkg"};
            my str $next_tok = _at_end(\%parser) ? "EOF" : _peek_val(\%parser);
            say(STDERR, "[parse error] pkg=" . $pkg . " near '" . $next_tok . "': " . $e);
            while (!_at_end(\%parser)) {
                my str $skip_type = _peek_type(\%parser);
                if ($skip_type eq "SEMI" || $skip_type eq "SUB" || $skip_type eq "PACKAGE") { last; }
                _advance(\%parser);
            }
            _match(\%parser, "SEMI");
        }
        if (defined($stmt)) {
            push(@{$prog->{"stmts"}}, $stmt);
        }
    }

    return $prog;
}

# --- Token access ---
func _cur(scalar $p) scalar { return $p->{"tokens"}->[$p->{"pos"}]; }
func _at_end(scalar $p) int { return $p->{"pos"} >= $p->{"len"} || _cur($p)->{"type"} eq "EOF"; }
func _peek_type(scalar $p) str { return _cur($p)->{"type"}; }
func _peek_val(scalar $p) str { return _cur($p)->{"value"}; }
func _advance(scalar $p) scalar { my scalar $t = _cur($p); $p->{"pos"} = $p->{"pos"} + 1; return $t; }
func _expect(scalar $p, str $type) scalar {
    my scalar $t = _cur($p);
    if ($t->{"type"} ne $type) {
        my str $fn = "" . $p->{"filename"};
        my str $at = "";
        if (length($fn) > 0) {
            $at = " at " . $fn;
        }
        die("syntax error" . $at . " line " . $t->{"line"} . ": expected " . $type . ", got " . $t->{"type"} . " '" . $t->{"value"} . "'");
    }
    return _advance($p);
}

func _match(scalar $p, str $type) int {
    if (_peek_type($p) eq $type) { _advance($p); return 1; }
    return 0;
}

func _match_val(scalar $p, str $type, str $val) int {
    if (_peek_type($p) eq $type && _peek_val($p) eq $val) { _advance($p); return 1; }
    return 0;
}

# --- Statement parsing ---
func _parse_stmt(scalar $p) scalar {
    my str $type = _peek_type($p);
    my str $val = _peek_val($p);

    if ($type eq "SEMI") { _advance($p); return undef; }

    # Lexer-captured `format NAME = ... .` block. Value carries
    # "NAME\x01BODY" so unpack both halves here.
    if ($type eq "FORMAT_DEFN") {
        my str $raw = "" . $val;
        my int $sep = index($raw, "\x01");
        my str $fmt_name = "STDOUT";
        my str $fmt_body = $raw;
        if ($sep >= 0) {
            $fmt_name = substr($raw, 0, $sep);
            $fmt_body = substr($raw, $sep + 1, length($raw) - $sep - 1);
        }
        _advance($p);
        my scalar $fn = Perla::AST::node(Perla::AST::N_FORMAT());
        $fn->{"name"} = $fmt_name;
        $fn->{"body"} = $fmt_body;
        return $fn;
    }

    # `write [FILEHANDLE];` — emit using current format. Bare `write`
    # uses the selected output handle (typically STDOUT).
    if ($type eq "IDENT" && $val eq "write" && $p->{"pos"} + 1 < $p->{"len"}) {
        my scalar $next_w = $p->{"tokens"}->[$p->{"pos"} + 1];
        my str $nt = $next_w->{"type"};
        if ($nt eq "SEMI" || $nt eq "IDENT" || $nt eq "SCALAR_VAR" || $nt eq "RBRACE" || $nt eq "RPAREN") {
            _advance($p);  # consume `write`
            my scalar $wn = Perla::AST::node(Perla::AST::N_WRITE());
            $wn->{"handle"} = "STDOUT";
            # `write FH;` — bareword filehandle.
            if (_peek_type($p) eq "IDENT" && _peek_val($p) ne "write") {
                my str $maybe_fh = "" . _peek_val($p);
                # Heuristic: identifier in all caps is a filehandle.
                my int $is_fh = 1;
                my int $ci = 0;
                while ($ci < length($maybe_fh)) {
                    my str $cc = substr($maybe_fh, $ci, 1);
                    if (!(($cc ge "A" && $cc le "Z") || ($cc ge "0" && $cc le "9") || $cc eq "_")) { $is_fh = 0; last; }
                    $ci = $ci + 1;
                }
                if ($is_fh == 1) {
                    _advance($p);
                    $wn->{"handle"} = $maybe_fh;
                }
            }
            # `write $fh;` — scalar variable holding a filehandle. Parse
            # as an expression and stash it on the node so codegen can
            # call perla_write_format_to_fh(\$fh, current_fmt) at runtime.
            elsif (_peek_type($p) eq "SCALAR_VAR") {
                $wn->{"fh_expr"} = _parse_expr($p);
            }
            return $wn;
        }
    }

    # Label: IDENT followed by : then a loop statement
    if ($type eq "IDENT" && $p->{"pos"} + 1 < $p->{"len"}) {
        my scalar $next_tok = $p->{"tokens"}->[$p->{"pos"} + 1];
        if ($next_tok->{"type"} eq "OP" && $next_tok->{"value"} eq ":") {
            # Check if it looks like a label (followed by while/for/foreach/until/do)
            my str $label_name = $val;
            my int $save = $p->{"pos"};
            _advance($p);  # consume IDENT
            _advance($p);  # consume :
            my str $next_type = _peek_type($p);
            if ($next_type eq "WHILE" || $next_type eq "UNTIL" || $next_type eq "FOR" || $next_type eq "FOREACH" || $next_type eq "DO") {
                my scalar $loop = _parse_stmt($p);
                if (defined($loop)) {
                    $loop->{"label"} = $label_name;
                }
                return $loop;
            }
            # Labeled bare block: `LABEL: { ... }`. Perl allows `last LABEL`
            # to jump to the block's exit. Attach the label to the N_BLOCK so
            # CodeGen can emit matching labels for `last`/`redo`.
            if ($next_type eq "LBRACE") {
                my scalar $block = _parse_block($p);
                if (defined($block)) {
                    $block->{"label"} = $label_name;
                }
                return $block;
            }
            # Free-standing label: `LABEL: statement` — used as a goto
            # target. Emit a label statement, which codegen turns into
            # a C label, and continue parsing the following statement
            # at the same nesting level (the parser loop picks it up).
            my scalar $lnode = Perla::AST::node(Perla::AST::N_LABEL_STMT());
            $lnode->{"label"} = $label_name;
            return $lnode;
        }
    }

    if ($type eq "C_BLOCK") {
        my scalar $tok = _advance($p);
        my scalar $node = Perla::AST::node(Perla::AST::N_C_BLOCK());
        $node->{"code"} = $tok->{"value"};
        return $node;
    }
    if ($type eq "STRADA_BLOCK") {
        my scalar $tok = _advance($p);
        my scalar $node = Perla::AST::node(Perla::AST::N_STRADA_BLOCK());
        $node->{"code"} = $tok->{"value"};
        return $node;
    }
    if ($type eq "MY") {
        # `my sub foo { ... }` — Perl 5.18+ lexical subs. Without
        # proper lexical scoping (which would require per-block sub
        # tables), treat as a normal sub declaration: the sub becomes
        # callable in the enclosing package. Captures are imperfect
        # (won't see outer my-vars below the declaration scope) but
        # the common case of "internal helper sub" works correctly.
        my int $__my_next = $p->{"pos"} + 1;
        if ($__my_next < $p->{"len"}
            && $p->{"tokens"}->[$__my_next]->{"type"} eq "SUB") {
            _advance($p);  # consume MY
            return _parse_sub($p);
        }
        return _parse_my($p);
    }
    # state $var - context-sensitive (state is also a valid sub name)
    if ($type eq "IDENT" && $val eq "state") {
        my int $next_pos = $p->{"pos"} + 1;
        if ($next_pos < $p->{"len"}) {
            my str $nt = $p->{"tokens"}->[$next_pos]->{"type"};
            if ($nt eq "SCALAR_VAR" || $nt eq "ARRAY_VAR" || $nt eq "HASH_VAR") {
                return _parse_state($p);
            }
        }
    }
    if ($type eq "OUR") {
        # `our sub foo { ... }` — exports a sub to the enclosing package
        # (and aliases it as a lexical). Without a real lexical-sub
        # implementation, treat as a plain sub declaration so the name
        # becomes callable. Same shape as the `my sub` fix above.
        my int $__our_next = $p->{"pos"} + 1;
        if ($__our_next < $p->{"len"}
            && $p->{"tokens"}->[$__our_next]->{"type"} eq "SUB") {
            _advance($p);  # consume OUR
            return _parse_sub($p);
        }
        return _parse_our($p);
    }
    if ($type eq "LOCAL") { return _parse_local($p); }
    if ($type eq "END_MARKER" || $type eq "DATA_MARKER") {
        # __END__ / __DATA__ - stop parsing this file
        $p->{"pos"} = $p->{"len"};  # jump to end
        return undef;
    }
    if ($type eq "SUB") {
        # `sub { ... }->()` / `sub { ... }(args)` at statement start is an
        # immediately-invoked anonymous sub, not a sub definition. The
        # statement-level path discards the trailing `->()`. Detect the
        # pattern by scanning past the matching `}` and checking for
        # ARROW or LPAREN — those indicate an expression. Bare
        # `sub { ... };` (anon sub literal with no call) is meaningless,
        # so the only reason to fall to _parse_sub is when the next char
        # after the body is SEMI/EOF (or some pre-LBRACE token like an
        # IDENT name or attribute, which means it's a sub-definition).
        my int $is_anon_call = 0;
        my int $sn = $p->{"pos"} + 1;  # past SUB token
        if ($sn < $p->{"len"} && $p->{"tokens"}->[$sn]->{"type"} eq "LBRACE") {
            # Walk past the balanced { ... } to find the next token.
            my int $depth = 1;
            my int $scan = $sn + 1;
            while ($scan < $p->{"len"} && $depth > 0) {
                my str $stt = $p->{"tokens"}->[$scan]->{"type"};
                if ($stt eq "LBRACE") { $depth = $depth + 1; }
                elsif ($stt eq "RBRACE") { $depth = $depth - 1; }
                $scan = $scan + 1;
            }
            if ($depth == 0 && $scan < $p->{"len"}) {
                my str $after = $p->{"tokens"}->[$scan]->{"type"};
                if ($after eq "ARROW" || $after eq "LPAREN") {
                    $is_anon_call = 1;
                }
            }
        }
        if ($is_anon_call == 1) {
            my scalar $expr = _parse_expr($p);
            _match($p, "SEMI");
            return $expr;
        }
        return _parse_sub($p);
    }
    if ($type eq "IF") { return _parse_if($p); }
    if ($type eq "UNLESS") { return _parse_unless($p); }
    if ($type eq "WHILE") { return _parse_while($p); }
    if ($type eq "UNTIL") { return _parse_until($p); }
    if ($type eq "FOR" || $type eq "FOREACH") { return _parse_for($p); }
    if ($type eq "RETURN") { return _parse_return($p); }
    # goto &EXPR - Perl's tail-call functional goto. Replaces the current
    # call frame with a call to EXPR so that `caller` in EXPR reports the
    # frame that invoked the current sub, not the current sub itself. Used
    # in Mo::Inline's `sub { ...; goto &$i }` wrapper around the captured
    # original `import` sub: without real goto semantics, `caller` inside
    # the captured sub reports the wrapper's package, not the caller's.
    #
    # `&first`  - reference the sub named first (don't invoke it here)
    # `&$ref`   - dereference code ref in $ref
    # Codegen turns either form into a perla_call_code(target, perla_at_)
    # after popping the current call frame.
    if ($type eq "IDENT" && _peek_val($p) eq "goto") {
        my int $save_pos = $p->{"pos"};
        _advance($p);
        if (_peek_type($p) eq "OP" && _peek_val($p) eq "&") {
            _advance($p);  # consume '&'
            my scalar $target = undef;
            if (_peek_type($p) eq "IDENT") {
                # goto &funcname - turn into \&funcname so codegen produces
                # a code ref, not an invocation of funcname.
                my scalar $call = Perla::AST::node(Perla::AST::N_CALL());
                $call->{"name"} = _advance($p)->{"value"};
                $call->{"args"} = [];
                while (_peek_type($p) eq "PKG_SEP") {
                    _advance($p);
                    if (_peek_type($p) eq "IDENT" || _peek_type($p) eq "PACKAGE") {
                        $call->{"name"} = $call->{"name"} . "::" . _advance($p)->{"value"};
                    }
                }
                my scalar $ref = Perla::AST::node(Perla::AST::N_REF());
                $ref->{"operand"} = $call;
                $target = $ref;
            } else {
                # goto &$ref / goto &{EXPR} - parse as expression (the
                # scalar or braced expression yields the code ref directly).
                if (_peek_type($p) eq "LBRACE") {
                    # `goto &{EXPR}` — code dereference with a block. The
                    # general _parse_expr from here sees `{...}` and parses
                    # it as an anonymous-hash constructor (the `&` was
                    # already consumed above), so the generated C built a
                    # hash ref and tried to dispatch IT. Match the
                    # expression-level `&{EXPR}` handler (parser line ~5642):
                    # build an N_GLOB_ACCESS with is_code_deref=1 so codegen
                    # emits the dynamic stash lookup + dispatch.
                    _advance($p);  # consume {
                    my scalar $expr = _parse_expr($p);
                    _expect($p, "RBRACE");
                    my scalar $glob = Perla::AST::node(Perla::AST::N_GLOB_ACCESS());
                    $glob->{"name"} = "";
                    $glob->{"expr"} = $expr;
                    $glob->{"is_code_deref"} = 1;
                    $target = $glob;
                } else {
                    $target = _parse_expr($p);
                }
            }
            my scalar $node = Perla::AST::node(Perla::AST::N_GOTO_SUB());
            $node->{"target"} = $target;
            # Postfix if/unless - without this, `goto &SUB if COND;` falls
            # through to the outer statement parser, which misreads the
            # `if` as a fresh prefix-if and errors with
            # "expected LPAREN got …" on the condition's first token.
            # (Seen in MRO/Compat.pm line 156:
            # `goto &Class::C3::import if $_[1] eq 'c3';` - a parse
            # failure there cascaded the remainder of the sub body into
            # module-init top level, causing __set_mro to run at load
            # time with undef args and die.)
            if (_peek_type($p) eq "IF") {
                _advance($p);
                my scalar $cond = _parse_expr($p);
                my scalar $wrap = Perla::AST::node(Perla::AST::N_POSTFIX_IF());
                $wrap->{"body"} = $node;
                $wrap->{"cond"} = $cond;
                _match($p, "SEMI");
                return $wrap;
            }
            if (_peek_type($p) eq "UNLESS") {
                _advance($p);
                my scalar $cond = _parse_expr($p);
                my scalar $wrap = Perla::AST::node(Perla::AST::N_POSTFIX_UNLESS());
                $wrap->{"body"} = $node;
                $wrap->{"cond"} = $cond;
                _match($p, "SEMI");
                return $wrap;
            }
            _match($p, "SEMI");
            return $node;
        }
        # `goto EXPR` where EXPR yields a code ref: `goto \&Pkg::sub`
        # (backslash-amp ref expression) and `goto $cref` (scalar holding a
        # code ref). Perl treats a goto to a code value as a tail call,
        # identical to `goto &$cref`. Without this, the `&`-only branch above
        # misses these forms, `goto` falls through to a discarded expression,
        # and the wrapping sub returns undef. Real-world: Types::Standard's
        # `goto \&Type::Library::add_type` (every core type built this way) and
        # Type::Tiny's `goto \&overload::OVERLOAD`.
        # LPAREN handles the parenthesized statement form `goto($cref)` /
        # `goto(\&sub)` as a proper tail-call (N_GOTO_SUB: pop frame + return
        # the call). Without it these fall through to a plain `goto(...)`
        # N_CALL, which for the tail-recursion idiom (`goto(\&self)`) recurses
        # instead of replacing the frame → unbounded growth / hang. (Genuine
        # EXPRESSION-context goto, e.g. a ternary branch, still lands in
        # _gen_call's goto handler and yields the coderef-call's value.)
        my str $g_pt = _peek_type($p);
        if ($g_pt eq "BACKSLASH" || $g_pt eq "SCALAR_VAR" || $g_pt eq "LPAREN") {
            my scalar $target = _parse_expr($p);
            my scalar $node = Perla::AST::node(Perla::AST::N_GOTO_SUB());
            $node->{"target"} = $target;
            if (_peek_type($p) eq "IF") {
                _advance($p);
                my scalar $cond = _parse_expr($p);
                my scalar $wrap = Perla::AST::node(Perla::AST::N_POSTFIX_IF());
                $wrap->{"body"} = $node;
                $wrap->{"cond"} = $cond;
                _match($p, "SEMI");
                return $wrap;
            }
            if (_peek_type($p) eq "UNLESS") {
                _advance($p);
                my scalar $cond = _parse_expr($p);
                my scalar $wrap = Perla::AST::node(Perla::AST::N_POSTFIX_UNLESS());
                $wrap->{"body"} = $node;
                $wrap->{"cond"} = $cond;
                _match($p, "SEMI");
                return $wrap;
            }
            _match($p, "SEMI");
            return $node;
        }
        # `goto LABEL` (bareword label-jump form).
        if (_peek_type($p) eq "IDENT" && _peek_val($p) ne "if" && _peek_val($p) ne "unless") {
            my str $label_name = _advance($p)->{"value"};
            my scalar $gnode = Perla::AST::node(Perla::AST::N_GOTO_LABEL());
            $gnode->{"label"} = $label_name;
            # Postfix if/unless.
            if (_peek_type($p) eq "IF") {
                _advance($p);
                my scalar $cond = _parse_expr($p);
                _match($p, "SEMI");
                my scalar $pif = Perla::AST::node(Perla::AST::N_POSTFIX_IF());
                $pif->{"expr"} = $gnode;
                $pif->{"cond"} = $cond;
                return $pif;
            }
            if (_peek_type($p) eq "UNLESS") {
                _advance($p);
                my scalar $cond = _parse_expr($p);
                _match($p, "SEMI");
                my scalar $pif = Perla::AST::node(Perla::AST::N_POSTFIX_UNLESS());
                $pif->{"expr"} = $gnode;
                $pif->{"cond"} = $cond;
                return $pif;
            }
            _match($p, "SEMI");
            return $gnode;
        }
        # Not goto LABEL — put the token back and fall through
        $p->{"pos"} = $save_pos;
    }
    if ($type eq "LAST" || $type eq "NEXT" || $type eq "REDO") {
        _advance($p);
        my int $node_type = Perla::AST::N_LAST();
        if ($type eq "NEXT") { $node_type = Perla::AST::N_NEXT(); }
        if ($type eq "REDO") { $node_type = Perla::AST::N_REDO(); }
        my scalar $ctrl = Perla::AST::node($node_type);
        # Check for label: last LABEL
        if (_peek_type($p) eq "IDENT" && _peek_val($p) ne "if" && _peek_val($p) ne "unless") {
            $ctrl->{"label"} = _advance($p)->{"value"};
        }
        # Check for postfix if/unless
        if (_peek_type($p) eq "IF") {
            _advance($p);
            my scalar $cond = _parse_expr($p);
            _match($p, "SEMI");
            my scalar $pif = Perla::AST::node(Perla::AST::N_POSTFIX_IF());
            $pif->{"expr"} = $ctrl;
            $pif->{"cond"} = $cond;
            return $pif;
        }
        if (_peek_type($p) eq "UNLESS") {
            _advance($p);
            my scalar $cond = _parse_expr($p);
            _match($p, "SEMI");
            my scalar $pif = Perla::AST::node(Perla::AST::N_POSTFIX_UNLESS());
            $pif->{"expr"} = $ctrl;
            $pif->{"cond"} = $cond;
            return $pif;
        }
        _match($p, "SEMI");
        return $ctrl;
    }
    if ($type eq "DO") { return _parse_do($p); }
    if ($type eq "GIVEN") { return _parse_given($p); }
    if ($type eq "PACKAGE") { return _parse_package($p); }
    if ($type eq "USE") { return _parse_use($p); }
    if ($type eq "NO") { return _parse_no($p); }
    if ($type eq "REQUIRE") { return _parse_require_stmt($p); }
    if ($type eq "BEGIN") { return _parse_begin($p); }
    if ($type eq "END") { return _parse_end($p); }

    # Bare block: { ... } at statement level (not anon hash)
    # Bare `{ ... }` at statement level is a block (loop-once
    # construct). Real Perl always treats this as a block — only in
    # expression position can `{...}` be a hash literal. The previous
    # whitelist of "keywords that must start a block" missed bare-op
    # statements like `{ ++$i; ... redo ...}` (Carp.pm:long_error_loc),
    # which then got parsed as a hash literal whose keys were the
    # statements — producing infinite recursion at runtime when
    # `redo` was emitted as a hash-construction expression.
    if ($type eq "LBRACE") {
        # Perl heuristic: when `{` at statement level immediately
        # contains a `KEY =>` pair, it's an anon-hash expression
        # statement, not a code block. `map { { x => 1 } } @list` etc.
        # depend on this so the inner block yields a hashref, not the
        # comma-list of key/value pairs.
        #
        # We scan forward at brace-depth 0 (relative to this `{`) until
        # we hit a `=>` (anon-hash), or a `;`/closing `}` (code block).
        # This catches forms like `{ %$_, key => val }` where the first
        # content token is a sigil/spread, not an IDENT key.
        my int $sp = $p->{"pos"} + 1;
        my int $is_anon_hash = 0;
        my int $depth = 0;
        my int $slen = $p->{"len"};
        while ($sp < $slen) {
            my str $st = $p->{"tokens"}->[$sp]->{"type"};
            if ($st eq "LBRACE" || $st eq "LPAREN" || $st eq "LBRACKET") {
                $depth = $depth + 1;
            } elsif ($st eq "RBRACE" || $st eq "RPAREN" || $st eq "RBRACKET") {
                if ($depth == 0) { last; }
                $depth = $depth - 1;
            } elsif ($depth == 0) {
                if ($st eq "FAT_ARROW") {
                    $is_anon_hash = 1;
                    last;
                }
                if ($st eq "SEMI") { last; }
            }
            $sp = $sp + 1;
        }
        if ($is_anon_hash == 1) {
            # Parse as expression — _parse_expr's LBRACE handler will
            # build an N_ANON_HASH node.
            my scalar $h_expr = _parse_expr($p);
            _match($p, "SEMI");
            return $h_expr;
        }
        my scalar $block = _parse_block($p);
        return $block;
    }

    # Expression statement (with optional postfix modifiers)
    my scalar $expr = _parse_expr($p);

    # Top-level comma / fat-arrow: `A, B, C [for LIST]` or `$k => $v`.
    # Perl's `,` (and `=>`) in list/void context keeps both sides. At
    # statement level we want all sub-expressions to run - required for
    # idioms like Mo::Inline's
    # `eval"no Mo::$_", &{$M.$_.::e}($P,\%e,\%o,\@_) for @_;`.
    # Generating an N_ANON_ARRAY (flat list) rather than N_BLOCK makes
    # the value available to containers expecting a list - critical for
    # `map { $_ => 1 } @list`, where the block's last expression is the
    # list (key, 1) and map flattens arrays into its output. Without
    # this, `=>` was dropped entirely and the block returned just `1`
    # per iteration, so `my %h = map { $_ => 1 } qw(a b c)` built
    # `(1 => undef)` instead of `(a => 1, b => 1, c => 1)`. Array eval
    # runs every element in order, so side-effect sequences still work.
    if (_peek_type($p) eq "COMMA" || _peek_type($p) eq "FAT_ARROW") {
        my scalar $seq = Perla::AST::node(Perla::AST::N_ANON_ARRAY());
        $seq->{"elems"} = [];
        $seq->{"is_ref"} = 0;
        push(@{$seq->{"elems"}}, $expr);
        while (_peek_type($p) eq "COMMA" || _peek_type($p) eq "FAT_ARROW") {
            _advance($p);
            my str $pt = _peek_type($p);
            if ($pt eq "SEMI" || $pt eq "IF" || $pt eq "UNLESS" ||
                $pt eq "WHILE" || $pt eq "UNTIL" || $pt eq "FOR" ||
                $pt eq "FOREACH" || $pt eq "EOF" || $pt eq "RBRACE") { last; }
            push(@{$seq->{"elems"}}, _parse_expr($p));
        }
        $expr = $seq;
    }

    # Postfix if/unless/while/until/for
    if (_peek_type($p) eq "IF") {
        _advance($p);
        my scalar $cond = _parse_expr($p);
        _match($p, "SEMI");
        my scalar $node = Perla::AST::node(Perla::AST::N_POSTFIX_IF());
        $node->{"expr"} = $expr;
        $node->{"cond"} = $cond;
        return $node;
    }
    if (_peek_type($p) eq "UNLESS") {
        _advance($p);
        my scalar $cond = _parse_expr($p);
        _match($p, "SEMI");
        my scalar $node = Perla::AST::node(Perla::AST::N_POSTFIX_UNLESS());
        $node->{"expr"} = $expr;
        $node->{"cond"} = $cond;
        return $node;
    }
    if (_peek_type($p) eq "WHILE") {
        _advance($p);
        my scalar $cond = _parse_expr($p);
        _match($p, "SEMI");
        my scalar $node = Perla::AST::node(Perla::AST::N_POSTFIX_WHILE());
        $node->{"expr"} = $expr;
        # `STMT while (<$fh>)` — same readline-into-$_ rewrite as the
        # prefix form. Without this the body's $_ stayed at its prior
        # value (or empty) while the loop count was still driven by
        # the readline returning truthy lines.
        if (defined($cond) && $cond->{"type"} == Perla::AST::N_READLINE()) {
            my scalar $under_pw = Perla::AST::node_with(Perla::AST::N_SCALAR_VAR(), "name", "_");
            my scalar $assign_pw = Perla::AST::node(Perla::AST::N_ASSIGN());
            $assign_pw->{"target"} = $under_pw;
            $assign_pw->{"value"} = $cond;
            $assign_pw->{"op"} = "=";
            my scalar $def_pw = Perla::AST::node(Perla::AST::N_CALL());
            $def_pw->{"name"} = "defined";
            $def_pw->{"args"} = [$assign_pw];
            $cond = $def_pw;
        }
        $node->{"cond"} = $cond;
        return $node;
    }
    if (_peek_type($p) eq "UNTIL") {
        _advance($p);
        my scalar $cond = _parse_expr($p);
        _match($p, "SEMI");
        my scalar $node = Perla::AST::node(Perla::AST::N_POSTFIX_UNTIL());
        $node->{"expr"} = $expr;
        $node->{"cond"} = $cond;
        return $node;
    }
    if (_peek_type($p) eq "FOREACH" || _peek_type($p) eq "FOR") {
        _advance($p);
        my scalar $list = _parse_expr($p);
        # `EXPR for @a, @b;` — comma-separated list flattens both arrays
        # into the iteration. _parse_expr stops at the first comma, so
        # without this loop the postfix-for only iterated over @a and
        # silently dropped @b.
        if (_peek_type($p) eq "COMMA" || _peek_type($p) eq "FAT_ARROW") {
            my scalar $ll = Perla::AST::node(Perla::AST::N_ANON_ARRAY());
            $ll->{"elems"} = [$list];
            $ll->{"is_ref"} = 0;
            while (_peek_type($p) eq "COMMA" || _peek_type($p) eq "FAT_ARROW") {
                _advance($p);
                if (_peek_type($p) eq "SEMI" || _peek_type($p) eq "RPAREN" || _at_end($p)) { last; }
                push(@{$ll->{"elems"}}, _parse_expr($p));
            }
            $list = $ll;
        }
        _match($p, "SEMI");
        my scalar $node = Perla::AST::node(Perla::AST::N_POSTFIX_FOR());
        $node->{"expr"} = $expr;
        $node->{"list"} = $list;
        return $node;
    }

    _match($p, "SEMI");
    return $expr;
}

# --- my/our/local ---
# Sub-expression form of `my` declaration: parses `my $x = EXPR` without
# consuming the trailing `;` or any statement modifier (those bind to the
# enclosing statement, not the inner `my`). Used in places like the RHS of
# `${$ref} = my $m = expr` or `if (my $z = expr)`.
func _parse_my_expr(scalar $p) scalar {
    my scalar $my_tok = _advance($p);  # consume 'my'
    my scalar $node = Perla::AST::node(Perla::AST::N_MY());
    if (defined($my_tok->{"line"})) { $node->{"line"} = $my_tok->{"line"}; }
    _parse_var_decl($p, $node);
    return $node;
}

# `our @X = ...` in expression position (RHS of a chained assignment, e.g.
# `our @EXPORT = our @EXPORT_OK = qw(...)`). Mirrors _parse_my_expr — produces
# an N_OUR node (with its init) without consuming a trailing semicolon or
# low-prec word ops, so the enclosing assignment keeps parsing.
func _parse_our_expr(scalar $p) scalar {
    my scalar $our_tok = _advance($p);  # consume 'our'
    my scalar $node = Perla::AST::node(Perla::AST::N_OUR());
    if (defined($our_tok->{"line"})) { $node->{"line"} = $our_tok->{"line"}; }
    _parse_var_decl($p, $node);
    return $node;
}

# Consume a trailing chain of low-precedence word ops (and/or/xor) with $node
# as the initial left operand, returning the (possibly wrapped) expression. In
# Perl `and`/`or`/`xor` bind looser than `=`, so in `my $x = E and COND` (or
# `if (my $x = E and COND)`) they attach to the whole assignment, not its RHS.
# This mirrors the binop chain _parse_expr already builds for the non-`my`
# case, so condition sites that special-case a leading `my` (which bypass
# _parse_expr — see _parse_if / _parse_while) still consume the word ops.
func _wrap_low_prec_word_ops(scalar $p, scalar $node) scalar {
    my scalar $expr_node = $node;
    while (_peek_type($p) eq "OP" && (_peek_val($p) eq "or" || _peek_val($p) eq "and" || _peek_val($p) eq "xor")) {
        my str $lop = _advance($p)->{"value"};
        my scalar $lrhs = _parse_assign($p);
        my scalar $lbinop = Perla::AST::node(Perla::AST::N_BINOP());
        $lbinop->{"op"} = $lop;
        $lbinop->{"left"} = $expr_node;
        $lbinop->{"right"} = $lrhs;
        $expr_node = $lbinop;
    }
    return $expr_node;
}

func _parse_my(scalar $p) scalar {
    my scalar $my_tok = _advance($p);  # consume 'my'
    my scalar $node = Perla::AST::node(Perla::AST::N_MY());
    if (defined($my_tok->{"line"})) { $node->{"line"} = $my_tok->{"line"}; }
    _parse_var_decl($p, $node);
    # `my $x = 0 or die;` — low-prec word op binds AFTER assignment.
    my scalar $expr_node = _wrap_low_prec_word_ops($p, $node);
    # Check for postfix modifiers: my $x = expr if/unless/while/until/for COND;
    if (_peek_type($p) eq "IF") {
        _advance($p);
        my scalar $cond = _parse_expr($p);
        _match($p, "SEMI");
        my scalar $pif = Perla::AST::node(Perla::AST::N_POSTFIX_IF());
        $pif->{"expr"} = $expr_node;
        $pif->{"cond"} = $cond;
        return $pif;
    }
    if (_peek_type($p) eq "UNLESS") {
        _advance($p);
        my scalar $cond = _parse_expr($p);
        _match($p, "SEMI");
        my scalar $pif = Perla::AST::node(Perla::AST::N_POSTFIX_UNLESS());
        $pif->{"expr"} = $expr_node;
        $pif->{"cond"} = $cond;
        return $pif;
    }
    _match($p, "SEMI");
    return $expr_node;
}

func _parse_our(scalar $p) scalar {
    _advance($p);
    my scalar $node = Perla::AST::node(Perla::AST::N_OUR());
    _parse_var_decl($p, $node);
    # `our $x = 0 or die;` — mirror _parse_my low-prec word op wrap.
    my scalar $expr_node = _wrap_low_prec_word_ops($p, $node);
    # Postfix if/unless: `our $X = 0 unless defined $X;` (Template::Provider
    # and others). Without this, the UNLESS bubbles up to the statement loop,
    # which tries to parse it as the `unless (COND) { ... }` form and fails
    # with "expected LPAREN, got ...".
    if (_peek_type($p) eq "IF") {
        _advance($p);
        my scalar $cond = _parse_expr($p);
        _match($p, "SEMI");
        my scalar $pif = Perla::AST::node(Perla::AST::N_POSTFIX_IF());
        $pif->{"expr"} = $expr_node;
        $pif->{"cond"} = $cond;
        return $pif;
    }
    if (_peek_type($p) eq "UNLESS") {
        _advance($p);
        my scalar $cond = _parse_expr($p);
        _match($p, "SEMI");
        my scalar $pif = Perla::AST::node(Perla::AST::N_POSTFIX_UNLESS());
        $pif->{"expr"} = $expr_node;
        $pif->{"cond"} = $cond;
        return $pif;
    }
    _match($p, "SEMI");
    return $expr_node;
}

func _parse_state(scalar $p) scalar {
    _advance($p);  # consume 'state'
    my scalar $node = Perla::AST::node(Perla::AST::N_STATE());
    _parse_var_decl($p, $node);
    # `state $x = 0 or die;` — mirror _parse_my low-prec word op wrap.
    my scalar $expr_node = $node;
    while (_peek_type($p) eq "OP" && (_peek_val($p) eq "or" || _peek_val($p) eq "and" || _peek_val($p) eq "xor")) {
        my str $lop = _advance($p)->{"value"};
        my scalar $lrhs = _parse_assign($p);
        my scalar $lbinop = Perla::AST::node(Perla::AST::N_BINOP());
        $lbinop->{"op"} = $lop;
        $lbinop->{"left"} = $expr_node;
        $lbinop->{"right"} = $lrhs;
        $expr_node = $lbinop;
    }
    if (_peek_type($p) eq "IF") {
        _advance($p);
        my scalar $cond = _parse_expr($p);
        _match($p, "SEMI");
        my scalar $pif = Perla::AST::node(Perla::AST::N_POSTFIX_IF());
        $pif->{"expr"} = $expr_node;
        $pif->{"cond"} = $cond;
        return $pif;
    }
    if (_peek_type($p) eq "UNLESS") {
        _advance($p);
        my scalar $cond = _parse_expr($p);
        _match($p, "SEMI");
        my scalar $pif = Perla::AST::node(Perla::AST::N_POSTFIX_UNLESS());
        $pif->{"expr"} = $expr_node;
        $pif->{"cond"} = $cond;
        return $pif;
    }
    _match($p, "SEMI");
    return $expr_node;
}

func _parse_local(scalar $p) scalar {
    _advance($p);
    my scalar $node = Perla::AST::node(Perla::AST::N_LOCAL());
    # `local EXPR` — EXPR can be a simple variable or a complex lvalue
    # like `$obj->{key}` or `$arr[N]`. Use full expression parsing for
    # the latter; the codegen branches based on whether `var` (single
    # token) or `target` (AST) is set. Without this, `local $obj->{key}
    # = value` parsed `local $obj`, then the `->{key} = value` was left
    # as a separate (invalid) statement and the local silently no-op'd.
    # SAC's `local $self->{_nested_func_lhs} = $k` relies on this.
    my str $type = _peek_type($p);
    if ($type eq "LPAREN") {
        _parse_var_decl($p, $node);
    } else {
        my scalar $target = _parse_postfix($p);
        my int $tt = $target->{"type"};
        if ($tt == Perla::AST::N_SCALAR_VAR() || $tt == Perla::AST::N_ARRAY_VAR() || $tt == Perla::AST::N_HASH_VAR()) {
            # Simple var — keep `var` shape so existing local codegen handles it.
            my scalar $tok = Perla::AST::node($tt);
            $tok->{"value"} = $target->{"name"};
            $tok->{"type"} = ($tt == Perla::AST::N_SCALAR_VAR()) ? "SCALAR_VAR" : (($tt == Perla::AST::N_ARRAY_VAR()) ? "ARRAY_VAR" : "HASH_VAR");
            $node->{"var"} = $tok;
        } else {
            # Complex lvalue (hash/array element, deref) — store the AST.
            $node->{"target"} = $target;
        }
        if (_peek_type($p) eq "OP" && _peek_val($p) eq "=") {
            _advance($p);
            $node->{"init"} = _parse_expr($p);
        }
    }
    # Check for postfix if/unless
    if (_peek_type($p) eq "IF") {
        _advance($p);
        my scalar $cond = _parse_expr($p);
        _match($p, "SEMI");
        my scalar $pif = Perla::AST::node(Perla::AST::N_POSTFIX_IF());
        $pif->{"expr"} = $node;
        $pif->{"cond"} = $cond;
        return $pif;
    }
    if (_peek_type($p) eq "UNLESS") {
        _advance($p);
        my scalar $cond = _parse_expr($p);
        _match($p, "SEMI");
        my scalar $pif = Perla::AST::node(Perla::AST::N_POSTFIX_UNLESS());
        $pif->{"expr"} = $node;
        $pif->{"cond"} = $cond;
        return $pif;
    }
    _match($p, "SEMI");
    return $node;
}

func _parse_var_decl(scalar $p, scalar $node) void {
    my str $type = _peek_type($p);
    # my ($a, $b) = @_; pattern
    if ($type eq "LPAREN") {
        _advance($p);
        my array @vars = ();
        while (_peek_type($p) ne "RPAREN" && !_at_end($p)) {
            push(@vars, _advance($p));
            _match($p, "COMMA");
        }
        _expect($p, "RPAREN");
        $node->{"vars"} = \@vars;
    } else {
        # Single variable
        my scalar $var = _advance($p);
        $node->{"var"} = $var;
    }
    # Optional initializer. Parse at the `=` level (no low-prec or/and/xor)
    # so `my $r = 0 or 1` binds as `(my $r = 0) or 1` per Perl precedence.
    # The statement-level _parse_my (and our/state) handle trailing low-prec
    # word ops afterwards; the expression-level _parse_my_expr returns N_MY
    # so the outer _parse_low_or picks up `or` in expression context.
    if (_peek_type($p) eq "OP" && _peek_val($p) eq "=") {
        _advance($p);
        $node->{"init"} = _parse_assign($p);
    } elsif (_peek_type($p) eq "OP"
             && (_peek_val($p) eq "//=" || _peek_val($p) eq "||=")) {
        # `my $x //= EXPR` / `my $x ||= EXPR` — a just-declared $x is
        # always undef (falsy), so the compound-op LHS check always
        # picks EXPR. Equivalent to `my $x = EXPR`. Without this branch,
        # the //= / ||= tokens fell out of the declaration and became
        # orphan statements (EXPR floated free, $x stayed undef).
        _advance($p);
        $node->{"init"} = _parse_assign($p);
    }
}

# --- sub declaration ---
func _parse_sub(scalar $p) scalar {
    _advance($p);  # consume 'sub'
    my scalar $node = Perla::AST::node(Perla::AST::N_SUB());
    $node->{"package"} = $p->{"pkg"};

    # Name (optional for anon subs)
    # Accept IDENT, or any keyword/op token as sub name when followed by { or (
    my str $saved_sub = "" . $p->{"current_sub"};
    my str $ptype = _peek_type($p);
    my int $is_sub_name = 0;
    if ($ptype eq "IDENT") {
        $is_sub_name = 1;
    } elsif ($ptype ne "LBRACE" && $ptype ne "LPAREN" && $ptype ne "SEMI" && $ptype ne "EOF") {
        my int $next2 = $p->{"pos"} + 1;
        if ($next2 < $p->{"len"}) {
            my str $nt2 = $p->{"tokens"}->[$next2]->{"type"};
            if ($nt2 eq "LBRACE" || $nt2 eq "LPAREN" || $nt2 eq "SEMI" || ($nt2 eq "OP" && $p->{"tokens"}->[$next2]->{"value"} eq ":")) { $is_sub_name = 1; }
        }
    }
    if ($is_sub_name == 1) {
        $node->{"name"} = _advance($p)->{"value"};
        $p->{"current_sub"} = $p->{"pkg"} . "::" . $node->{"name"};
    } else {
        # Anonymous sub — clear current_sub so __SUB__ inside knows it
        # is not in a named-sub scope (otherwise it would resolve to the
        # outer named sub's coderef, which is wrong for nested anon).
        $p->{"current_sub"} = "";
    }

    # Prototype — record `()` empty-prototype subs specifically so the
    # nested-sub hoist can target HTTP::Status-style constant defs
    # (`sub HTTP_OK () { 200 }`) without hoisting Role::Tiny's
    # `sub _linear_isa($;$) { ... }` (which has a complex prototype
    # AND breaks bizowie when properly registered — see project memory).
    if (_peek_type($p) eq "LPAREN") {
        _advance($p);
        # Peek: empty parens?
        if (_peek_type($p) eq "RPAREN") {
            $node->{"empty_proto"} = 1;
        }
        # Detect Perl 5.20+ signatures: `sub name ($a, $b, $c = expr)`.
        # If the first token inside parens is a sigil-var, treat as a
        # signature; otherwise it's a prototype string and we skip tokens.
        # Distinguishing prototype-char tokens (lexer reads `$)`, `$(`,
        # `$>`, `$<` as SCALAR_VAR with name = the punctuation char) —
        # check that the var name starts with an identifier letter
        # before committing to the signature path. Without this, the
        # familiar prototype forms `sub foo ($) { }` and `sub foo (@) { }`
        # blow up as malformed signatures.
        my str $first_ty = _peek_type($p);
        my int $is_sig = 0;
        if ($first_ty eq "SCALAR_VAR" || $first_ty eq "ARRAY_VAR" || $first_ty eq "HASH_VAR") {
            my str $first_val = _peek_val($p);
            if (length($first_val) > 0) {
                my str $c0 = substr($first_val, 0, 1);
                if (($c0 ge "a" && $c0 le "z") || ($c0 ge "A" && $c0 le "Z") || $c0 eq "_") {
                    $is_sig = 1;
                }
            }
        }
        if ($is_sig == 1) {
            my array @sig_params = ();
            while (_peek_type($p) ne "RPAREN" && !_at_end($p)) {
                my scalar $sp = {};
                $sp->{"sigil"} = _peek_type($p);
                $sp->{"name"} = _advance($p)->{"value"};  # e.g. "$a", "@rest"
                # Optional default: `= EXPR`
                if (_peek_type($p) eq "OP" && _peek_val($p) eq "=") {
                    _advance($p);  # consume '='
                    # Parse default expression up to comma or RPAREN
                    $sp->{"default"} = _parse_ternary($p);
                }
                push(@sig_params, $sp);
                if (_peek_type($p) eq "COMMA" || (_peek_type($p) eq "OP" && _peek_val($p) eq ",")) {
                    _advance($p);
                } else {
                    last;
                }
            }
            $node->{"sig_params"} = \@sig_params;
            _expect($p, "RPAREN");
        } else {
            # Prototype: collect tokens until RPAREN as the prototype
            # string so prototype("PKG::name") at runtime can return it.
            # The lexer fuses `$)` into SCALAR_VAR ")" (Perl's effective
            # GID special var), so the canonical `($)` prototype produces
            # LPAREN + SCALAR_VAR(")") with NO trailing RPAREN. Bail out
            # of the collect loop when we see the body's LBRACE or end
            # of statement — perl's protos only contain `$@%&*\\;[]+`
            # chars, none of which can produce a `{`.
            my str $proto_str = "";
            # NOTE: SEMI (`;`) is a valid proto char (required/optional
            # separator: `sub f (\@;@)`). Don't bail on SEMI here — the
            # else-branch below appends ";" to proto_str. RPAREN/LBRACE
            # are the real proto terminators (and EOF for safety).
            while (_peek_type($p) ne "RPAREN"
                   && _peek_type($p) ne "LBRACE"
                   && !_at_end($p)) {
                my scalar $pt = _advance($p);
                my str $pv = "" . $pt->{"value"};
                if ($pt->{"type"} eq "SCALAR_VAR") {
                    # Fused-token case: lexer read `$)` as SCALAR_VAR(")").
                    # The `)` is the proto's CLOSING paren — emit just `$`
                    # for the proto and STOP (the loop's RPAREN-check
                    # didn't fire because the token was SCALAR_VAR).
                    $proto_str = $proto_str . "\$";
                    if ($pv eq ")") {
                        # Closing paren is implicit; nothing left to consume.
                        last;
                    }
                    # Otherwise (sig-char like `>`/`<`/`(` after `$`),
                    # include it verbatim.
                    if ($pv ne "") { $proto_str = $proto_str . $pv; }
                } elsif ($pt->{"type"} eq "ARRAY_VAR") {
                    $proto_str = $proto_str . "@";
                    if ($pv ne "") { $proto_str = $proto_str . $pv; }
                } elsif ($pt->{"type"} eq "HASH_VAR") {
                    $proto_str = $proto_str . "%";
                    if ($pv ne "") { $proto_str = $proto_str . $pv; }
                } else {
                    $proto_str = $proto_str . $pv;
                }
            }
            $node->{"prototype"} = $proto_str;
            # Only consume RPAREN if present (the `$)`-fused case skipped it).
            if (_peek_type($p) eq "RPAREN") {
                _advance($p);
            }
        }
    }

    # Attributes: sub name : Attr1 Attr2(args) Attr3 { ... }
    # Collected verbatim into $node->{"attrs"} as ("Attr1", "Attr2(args)", "Attr3")
    # so codegen can dispatch MODIFY_CODE_ATTRIBUTES and attributes::get
    # can return the list. Built-ins (:method, :lvalue, :prototype(...))
    # are recognized in codegen.
    if (_peek_type($p) eq "OP" && _peek_val($p) eq ":") {
        _advance($p);  # consume ':'
        my array @attrs = ();
        while (_peek_type($p) ne "LBRACE" && _peek_type($p) ne "SEMI" && !_at_end($p)) {
            # Attribute name token (IDENT/keyword).
            my str $aname = "" . _peek_val($p);
            _advance($p);
            # Optional argument list in parens — captured raw (paren-balanced).
            if (_peek_type($p) eq "LPAREN") {
                _advance($p);
                my str $body = "";
                my int $depth = 1;
                while ($depth > 0 && !_at_end($p)) {
                    my str $ty = _peek_type($p);
                    my str $vv = "" . _peek_val($p);
                    if ($ty eq "LPAREN") { $depth = $depth + 1; $body = $body . "("; _advance($p); }
                    elsif ($ty eq "RPAREN") {
                        $depth = $depth - 1;
                        if ($depth > 0) { $body = $body . ")"; }
                        _advance($p);
                    } else {
                        if (length($body) > 0) { $body = $body . " "; }
                        $body = $body . $vv;
                        _advance($p);
                    }
                }
                $aname = $aname . "(" . $body . ")";
            }
            # Skip a separating colon between attributes (`:Attr1 :Attr2` form).
            if (_peek_type($p) eq "OP" && _peek_val($p) eq ":") { _advance($p); }
            push(@attrs, $aname);
        }
        if (size(@attrs) > 0) { $node->{"attrs"} = \@attrs; }
    }

    # Forward declaration: sub name (proto); - no body, skip entirely
    if (_peek_type($p) eq "SEMI") {
        _advance($p);  # consume ;
        $p->{"current_sub"} = $saved_sub;
        # Return a use node (no-op) instead of a sub node to avoid duplicate defs
        return Perla::AST::node(Perla::AST::N_USE());
    }

    # Body
    $node->{"body"} = _parse_block($p);
    $p->{"current_sub"} = $saved_sub;
    return $node;
}

# --- Block { ... } ---
func _parse_block(scalar $p) scalar {
    _expect($p, "LBRACE");
    my scalar $block = Perla::AST::node(Perla::AST::N_BLOCK());
    $block->{"stmts"} = [];
    # Save package scope - `package X;` inside a block is lexically scoped,
    # so when the block closes we need to restore the outer package.
    my str $saved_pkg = "" . $p->{"pkg"};
    while (_peek_type($p) ne "RBRACE" && !_at_end($p)) {
        my scalar $stmt = _parse_stmt($p);
        if (defined($stmt)) {
            push(@{$block->{"stmts"}}, $stmt);
        }
    }
    _expect($p, "RBRACE");
    # If the block changed the package, append a synthetic package-restore
    # statement so subsequent code (and CodeGen's $cg->{"pkg"}) sees the outer
    # package again.
    if ($p->{"pkg"} ne $saved_pkg) {
        my scalar $restore = Perla::AST::node(Perla::AST::N_PACKAGE());
        $restore->{"name"} = $saved_pkg;
        # Mark as synthetic so codegen's implicit-return logic skips it
        # when finding the block's last expression. Without this,
        # `sub a { package Foo; sub { 42 }; }` saw the synthetic
        # restore as the last statement and returned undef instead of
        # the anon sub. Surfaced via Eval::Closure's sandbox-wrapped
        # `eval` that produces `package Sandbox_N; sub { ... };`.
        $restore->{"synthetic"} = 1;
        push(@{$block->{"stmts"}}, $restore);
        $p->{"pkg"} = $saved_pkg;
    }
    return $block;
}

# --- Control flow ---
func _parse_if(scalar $p) scalar {
    _advance($p);  # consume 'if'
    my scalar $node = Perla::AST::node(Perla::AST::N_IF());
    _expect($p, "LPAREN");
    # Support: if (my $var = expr) - declaration as condition. A trailing
    # low-prec `and`/`or`/`xor` binds looser than the `=`, so wrap the N_MY as
    # the LHS of that chain (`if (my $tp = E and $app)` => `(my $tp = E) and
    # $app`). _parse_my_expr alone stops at the word op and RPAREN then fails.
    if (_peek_type($p) eq "MY") {
        $node->{"cond"} = _wrap_low_prec_word_ops($p, _parse_my_expr($p));
    } else {
        $node->{"cond"} = _parse_expr($p);
    }
    _expect($p, "RPAREN");
    $node->{"then"} = _parse_block($p);
    if (_peek_type($p) eq "ELSIF") {
        $node->{"else"} = _parse_if($p);  # elsif chains as nested if
    } elsif (_peek_type($p) eq "ELSE") {
        _advance($p);
        $node->{"else"} = _parse_block($p);
    }
    return $node;
}

func _parse_unless(scalar $p) scalar {
    _advance($p);
    my scalar $node = Perla::AST::node(Perla::AST::N_UNLESS());
    _expect($p, "LPAREN");
    $node->{"cond"} = _parse_expr($p);
    _expect($p, "RPAREN");
    $node->{"body"} = _parse_block($p);
    if (_peek_type($p) eq "ELSE") {
        _advance($p);
        $node->{"else"} = _parse_block($p);
    }
    return $node;
}

func _parse_while(scalar $p) scalar {
    _advance($p);
    my scalar $node = Perla::AST::node(Perla::AST::N_WHILE());
    _expect($p, "LPAREN");
    # Handle: while (my $var = EXPR) - declare + assign + check defined
    if (_peek_type($p) eq "MY") {
        my scalar $my_node = _parse_my_expr($p);
        # `while (my $x = E and COND)` — the low-prec word op opts out of the
        # implicit defined() wrap; the condition is the plain boolean
        # `(my $x = E) and COND`, re-evaluated each iteration (var still
        # visible in the body — codegen handles N_MY nested in a binop cond).
        if (_peek_type($p) eq "OP" && (_peek_val($p) eq "or" || _peek_val($p) eq "and" || _peek_val($p) eq "xor")) {
            $node->{"cond"} = _wrap_low_prec_word_ops($p, $my_node);
            _expect($p, "RPAREN");
            $node->{"body"} = _parse_block($p);
            if (_peek_type($p) eq "IDENT" && _peek_val($p) eq "continue") {
                my int $save_cont_pos2 = $p->{"pos"};
                _advance($p);
                if (_peek_type($p) eq "LBRACE") {
                    $node->{"continue"} = _parse_block($p);
                } else {
                    $p->{"pos"} = $save_cont_pos2;
                }
            }
            return $node;
        }
        $node->{"init_my"} = $my_node;
        # The condition is: defined($var)
        if (defined($my_node->{"var"})) {
            my scalar $var_node = Perla::AST::node_with(Perla::AST::N_SCALAR_VAR(), "name", $my_node->{"var"}->{"value"});
            my scalar $def_node = Perla::AST::node(Perla::AST::N_CALL());
            $def_node->{"name"} = "defined";
            $def_node->{"args"} = [$var_node];
            $node->{"cond"} = $def_node;
        } else {
            $node->{"cond"} = Perla::AST::node_with(Perla::AST::N_INT_LIT(), "value", "1");
        }
    } else {
        $node->{"cond"} = _parse_expr($p);
        # Perl: `while (<$fh>)` → `while (defined($_ = <$fh>))`. The
        # diamond op in while-cond auto-assigns to \$_ and the loop
        # continues until EOF (undef). Without this, perla's while
        # condition sees the line/paragraph text directly, which is
        # truthy even for non-empty paragraphs but `chomp` etc. then
        # operate on a stale \$_ instead of the just-read value.
        if (defined($node->{"cond"}) && $node->{"cond"}->{"type"} == Perla::AST::N_READLINE()) {
            my scalar $under = Perla::AST::node_with(Perla::AST::N_SCALAR_VAR(), "name", "_");
            my scalar $assign = Perla::AST::node(Perla::AST::N_ASSIGN());
            $assign->{"target"} = $under;
            $assign->{"value"} = $node->{"cond"};
            $assign->{"op"} = "=";
            my scalar $def = Perla::AST::node(Perla::AST::N_CALL());
            $def->{"name"} = "defined";
            $def->{"args"} = [$assign];
            $node->{"cond"} = $def;
        }
    }
    _expect($p, "RPAREN");
    $node->{"body"} = _parse_block($p);
    # `while (...) { BODY } continue { CONT }` — the continue block
    # runs after every loop iteration (including ones ended via `next`)
    # and before the next condition test. Required for while-loops
    # whose iterator update lives in `continue { ... }` instead of the
    # body.
    if (_peek_type($p) eq "IDENT" && _peek_val($p) eq "continue") {
        my int $save_cont_pos = $p->{"pos"};
        _advance($p);
        if (_peek_type($p) eq "LBRACE") {
            $node->{"continue"} = _parse_block($p);
        } else {
            $p->{"pos"} = $save_cont_pos;
        }
    }
    return $node;
}

func _parse_until(scalar $p) scalar {
    _advance($p);
    my scalar $node = Perla::AST::node(Perla::AST::N_UNTIL());
    _expect($p, "LPAREN");
    $node->{"cond"} = _parse_expr($p);
    _expect($p, "RPAREN");
    $node->{"body"} = _parse_block($p);
    if (_peek_type($p) eq "IDENT" && _peek_val($p) eq "continue") {
        my int $save_cont_pos = $p->{"pos"};
        _advance($p);
        if (_peek_type($p) eq "LBRACE") {
            $node->{"continue"} = _parse_block($p);
        } else {
            $p->{"pos"} = $save_cont_pos;
        }
    }
    return $node;
}

func _parse_for(scalar $p) scalar {
    _advance($p);  # consume 'for' or 'foreach'
    # foreach my $x (@arr) { }
    if (_peek_type($p) eq "MY" || _peek_type($p) eq "SCALAR_VAR") {
        my scalar $node = Perla::AST::node(Perla::AST::N_FOREACH());
        if (_peek_type($p) eq "MY") {
            _advance($p);
            $node->{"my"} = 1;
        }
        $node->{"var"} = _advance($p);
        _expect($p, "LPAREN");
        # Parse list (could be single expr, range, or comma-separated)
        my scalar $first = _parse_expr($p);
        if (_peek_type($p) eq "COMMA") {
            # Comma-separated list: build anon array
            my scalar $list = Perla::AST::node(Perla::AST::N_ANON_ARRAY());
            $list->{"elems"} = [];
            push(@{$list->{"elems"}}, $first);
            while (_peek_type($p) eq "COMMA" || _peek_type($p) eq "FAT_ARROW") {
                _advance($p);
                if (_peek_type($p) eq "RPAREN") { last; }
                push(@{$list->{"elems"}}, _parse_expr($p));
            }
            $node->{"list"} = $list;
        } else {
            $node->{"list"} = $first;
        }
        _expect($p, "RPAREN");
        $node->{"body"} = _parse_block($p);
        if (_peek_type($p) eq "IDENT" && _peek_val($p) eq "continue") {
            my int $save_cont_pos = $p->{"pos"};
            _advance($p);
            if (_peek_type($p) eq "LBRACE") {
                $node->{"continue"} = _parse_block($p);
            } else {
                $p->{"pos"} = $save_cont_pos;
            }
        }
        return $node;
    }
    # foreach (EXPR) { } - implicit $_ loop
    # Distinguish from C-style for by checking if there's a ; before )
    if (_peek_type($p) eq "LPAREN") {
        # Peek ahead to see if this is foreach(@arr) or for(init;cond;step)
        my int $save_pos = $p->{"pos"};
        _advance($p); # consume (
        my int $depth = 1;
        my int $has_semi = 0;
        while ($p->{"pos"} < $p->{"len"} && $depth > 0) {
            my str $pt = _peek_type($p);
            if ($pt eq "LPAREN") { $depth++; }
            elsif ($pt eq "RPAREN") { $depth--; }
            elsif ($pt eq "SEMI" && $depth == 1) { $has_semi = 1; }
            if ($depth > 0) { _advance($p); }
        }
        $p->{"pos"} = $save_pos; # backtrack

        if ($has_semi == 0) {
            # foreach (EXPR, EXPR, ...) - implicit $_ loop. Real Perl
            # accepts a comma-separated list inside the parens (e.g.
            # `for (0,1) { ... }` from DBIx::Class::ResultSource); we
            # used to call _parse_expr once and bail on the comma.
            my scalar $node = Perla::AST::node(Perla::AST::N_FOREACH());
            $node->{"implicit_topic"} = 1;
            _expect($p, "LPAREN");
            my scalar $first = _parse_expr($p);
            if (_peek_type($p) eq "COMMA" || _peek_type($p) eq "FAT_ARROW") {
                my scalar $list = Perla::AST::node(Perla::AST::N_ANON_ARRAY());
                $list->{"elems"} = [];
                push(@{$list->{"elems"}}, $first);
                while (_peek_type($p) eq "COMMA" || _peek_type($p) eq "FAT_ARROW") {
                    _advance($p);
                    if (_peek_type($p) eq "RPAREN") { last; }
                    push(@{$list->{"elems"}}, _parse_expr($p));
                }
                $node->{"list"} = $list;
            } else {
                $node->{"list"} = $first;
            }
            _expect($p, "RPAREN");
            $node->{"body"} = _parse_block($p);
            if (_peek_type($p) eq "IDENT" && _peek_val($p) eq "continue") {
                my int $save_cont_pos = $p->{"pos"};
                _advance($p);
                if (_peek_type($p) eq "LBRACE") {
                    $node->{"continue"} = _parse_block($p);
                } else {
                    $p->{"pos"} = $save_cont_pos;
                }
            }
            return $node;
        }
    }

    # for (init; cond; step) { } - any of init/cond/step may be empty
    if (_peek_type($p) eq "LPAREN") {
        my scalar $node = Perla::AST::node(Perla::AST::N_FOR_C());
        _advance($p);
        # Init can be 'my $var = expr', plain expression, or empty
        if (_peek_type($p) eq "SEMI") {
            _advance($p);
        } elsif (_peek_type($p) eq "MY") {
            $node->{"init"} = _parse_my_expr($p);
            _expect($p, "SEMI");
        } else {
            $node->{"init"} = _parse_expr($p);
            _expect($p, "SEMI");
        }
        # Empty cond means always-true (like C)
        if (_peek_type($p) ne "SEMI") {
            $node->{"cond"} = _parse_expr($p);
        }
        _expect($p, "SEMI");
        # Empty step is allowed. Step may be a comma-separated list
        # (`$i++, $j--`) — collect into $node->{"steps"} so codegen can
        # emit each expression as its own C statement at the loop foot.
        if (_peek_type($p) ne "RPAREN") {
            my scalar $first_step = _parse_expr($p);
            if (_peek_type($p) eq "COMMA") {
                my array @sl = ($first_step);
                while (_peek_type($p) eq "COMMA") {
                    _advance($p);
                    if (_peek_type($p) eq "RPAREN") { last; }
                    push(@sl, _parse_expr($p));
                }
                $node->{"steps"} = \@sl;
            } else {
                $node->{"step"} = $first_step;
            }
        }
        _expect($p, "RPAREN");
        $node->{"body"} = _parse_block($p);
        return $node;
    }
    my str $fn = "" . $p->{"filename"};
    my str $at = "";
    if (length($fn) > 0) {
        $at = " at " . $fn;
    }
    die("syntax error" . $at . " line " . _cur($p)->{"line"} . ": unexpected token after for");
}

func _parse_return(scalar $p) scalar {
    _advance($p);
    my scalar $node = Perla::AST::node(Perla::AST::N_RETURN());
    if (_peek_type($p) ne "SEMI" && _peek_type($p) ne "RBRACE" &&
        _peek_type($p) ne "IF" && _peek_type($p) ne "UNLESS") {
        my scalar $first = _parse_expr($p);
        # `return E1, E2, E3` — without parens, the comma list operator
        # collects into one returned list. Previously only the first
        # expression was kept and the rest of the comma-chain was
        # silently absorbed by _match(SEMI), so a sub returning
        # `"a", "b", "c"` (no parens) only delivered "a" to the caller.
        if (_peek_type($p) eq "COMMA") {
            my array @elems = ($first);
            while (_peek_type($p) eq "COMMA") {
                _advance($p);
                if (_peek_type($p) eq "SEMI" || _peek_type($p) eq "RBRACE" ||
                    _peek_type($p) eq "IF" || _peek_type($p) eq "UNLESS") { last; }
                push(\@elems, _parse_expr($p));
            }
            my scalar $list_node = Perla::AST::node(Perla::AST::N_ANON_ARRAY());
            $list_node->{"elems"} = \@elems;
            $list_node->{"is_ref"} = 0;
            $node->{"value"} = $list_node;
        } else {
            $node->{"value"} = $first;
        }
    }
    # Check for postfix if/unless
    if (_peek_type($p) eq "IF") {
        _advance($p);
        my scalar $cond = _parse_expr($p);
        _match($p, "SEMI");
        my scalar $pif = Perla::AST::node(Perla::AST::N_POSTFIX_IF());
        $pif->{"expr"} = $node;
        $pif->{"cond"} = $cond;
        return $pif;
    }
    if (_peek_type($p) eq "UNLESS") {
        _advance($p);
        my scalar $cond = _parse_expr($p);
        _match($p, "SEMI");
        my scalar $pif = Perla::AST::node(Perla::AST::N_POSTFIX_UNLESS());
        $pif->{"expr"} = $node;
        $pif->{"cond"} = $cond;
        return $pif;
    }
    _match($p, "SEMI");
    return $node;
}

func _parse_do(scalar $p) scalar {
    _advance($p);  # consume 'do'
    if (_peek_type($p) eq "LBRACE") {
        my scalar $body = _parse_block($p);
        # Check for while/until after the block
        if (_peek_type($p) eq "WHILE") {
            _advance($p);
            _expect($p, "LPAREN");
            my scalar $cond = _parse_expr($p);
            _expect($p, "RPAREN");
            _match($p, "SEMI");
            my scalar $node = Perla::AST::node(Perla::AST::N_DO_WHILE());
            $node->{"body"} = $body;
            $node->{"cond"} = $cond;
            return $node;
        }
        if (_peek_type($p) eq "UNTIL") {
            _advance($p);
            _expect($p, "LPAREN");
            my scalar $cond = _parse_expr($p);
            _expect($p, "RPAREN");
            _match($p, "SEMI");
            my scalar $node = Perla::AST::node(Perla::AST::N_DO_WHILE());
            $node->{"body"} = $body;
            $node->{"cond"} = $cond;
            $node->{"negate"} = 1;
            return $node;
        }
        # Bare `do { BLOCK }` — also handle postfix statement modifiers
        # (`if`, `unless`, `while`, `until`, `for`, `foreach`). Perl
        # accepts `do { ... } for LIST;` and many CPAN modules
        # (Class::Accessor::Grouped, DBIx::Class internals) write that
        # form. Without these, the parser hits the FOR token next, calls
        # _parse_for which starts the prefix-for grammar and dies on
        # the first list expression that doesn't begin with `(`.
        if (_peek_type($p) eq "IF") {
            _advance($p);
            my scalar $cond = _parse_expr($p);
            _match($p, "SEMI");
            my scalar $pif = Perla::AST::node(Perla::AST::N_POSTFIX_IF());
            $pif->{"expr"} = $body;
            $pif->{"cond"} = $cond;
            return $pif;
        }
        if (_peek_type($p) eq "UNLESS") {
            _advance($p);
            my scalar $cond = _parse_expr($p);
            _match($p, "SEMI");
            my scalar $pif = Perla::AST::node(Perla::AST::N_POSTFIX_UNLESS());
            $pif->{"expr"} = $body;
            $pif->{"cond"} = $cond;
            return $pif;
        }
        if (_peek_type($p) eq "WHILE") {
            _advance($p);
            my scalar $cond = _parse_expr($p);
            _match($p, "SEMI");
            my scalar $pw = Perla::AST::node(Perla::AST::N_POSTFIX_WHILE());
            $pw->{"expr"} = $body;
            $pw->{"cond"} = $cond;
            return $pw;
        }
        if (_peek_type($p) eq "UNTIL") {
            _advance($p);
            my scalar $cond = _parse_expr($p);
            _match($p, "SEMI");
            my scalar $pw = Perla::AST::node(Perla::AST::N_POSTFIX_UNTIL());
            $pw->{"expr"} = $body;
            $pw->{"cond"} = $cond;
            return $pw;
        }
        if (_peek_type($p) eq "FOR" || _peek_type($p) eq "FOREACH") {
            _advance($p);
            my scalar $list = _parse_expr($p);
            _match($p, "SEMI");
            my scalar $pf = Perla::AST::node(Perla::AST::N_POSTFIX_FOR());
            $pf->{"expr"} = $body;
            $pf->{"list"} = $list;
            return $pf;
        }
        # Bare do { } block (no postfix modifier)
        _match($p, "SEMI");
        return $body;
    }
    # do "file" or do EXPR - at compile time, include the file's content
    if (_peek_type($p) eq "STRING") {
        my str $filename = _advance($p)->{"value"};
        _match($p, "SEMI");
        # Create a special node for do-file
        my scalar $node = Perla::AST::node(Perla::AST::N_SPECIAL_VAR());
        $node->{"value"} = "do_file:" . $filename;
        return $node;
    }
    # do "FILE-with-$var" — DQSTRING may contain interpolations that
    # must be resolved at runtime (e.g. `do "/tmp/job-$$.pl"`). Route
    # through N_DO_FILE_EXPR with an N_INTERP_STR path so codegen emits
    # an at-runtime slurp+eval.
    if (_peek_type($p) eq "DQSTRING") {
        my str $filename = _advance($p)->{"value"};
        _match($p, "SEMI");
        my scalar $istr = Perla::AST::node_with(Perla::AST::N_INTERP_STR(), "value", $filename);
        my scalar $df = Perla::AST::node(Perla::AST::N_DO_FILE_EXPR());
        $df->{"path"} = $istr;
        return $df;
    }
    # do EXPR - runtime, just eval the expression
    my scalar $expr = _parse_expr($p);
    _match($p, "SEMI");
    return $expr;
}

func _parse_given(scalar $p) scalar {
    _advance($p);  # consume 'given'
    _expect($p, "LPAREN");
    my scalar $topic = _parse_expr($p);
    _expect($p, "RPAREN");
    _expect($p, "LBRACE");

    # Parse when/default clauses
    my array @clauses = ();
    while (_peek_type($p) ne "RBRACE" && !_at_end($p)) {
        if (_peek_type($p) eq "WHEN") {
            _advance($p);
            _expect($p, "LPAREN");
            my scalar $match = _parse_expr($p);
            _expect($p, "RPAREN");
            my scalar $body = _parse_block($p);
            my hash %clause = ();
            $clause{"type"} = "when";
            $clause{"match"} = $match;
            $clause{"body"} = $body;
            push(@clauses, \%clause);
        } elsif (_peek_type($p) eq "DEFAULT") {
            _advance($p);
            my scalar $body = _parse_block($p);
            my hash %clause = ();
            $clause{"type"} = "default";
            $clause{"body"} = $body;
            push(@clauses, \%clause);
        } else {
            _advance($p);  # skip unexpected tokens
        }
    }
    _expect($p, "RBRACE");

    # Desugar given/when into if/elsif/else chain
    my scalar $result = undef;
    my int $i = scalar(@clauses) - 1;
    while ($i >= 0) {
        my scalar $clause = $clauses[$i];
        if ($clause->{"type"} eq "default") {
            $result = $clause->{"body"};
        } else {
            # when(EXPR) — simplified smartmatch. Detect common forms and
            # desugar to appropriate Perl-equivalent:
            #   /regex/        → $topic =~ /regex/
            #   [LIST]         → grep { $_ eq $topic } @{[LIST]}
            #   EXPR (numeric) → $topic == EXPR
            #   EXPR (string)  → $topic eq EXPR
            my scalar $if_node = Perla::AST::node(Perla::AST::N_IF());
            my scalar $cond;
            my scalar $m = $clause->{"match"};
            my int $mt = defined($m) ? $m->{"type"} : 0;
            if ($mt == Perla::AST::N_REGEX()) {
                # when (/pat/) — apply regex to $topic.
                $cond = Perla::AST::node(Perla::AST::N_BINOP());
                $cond->{"op"} = "=~";
                $cond->{"left"} = $topic;
                $cond->{"right"} = $m;
            } elsif ($mt == Perla::AST::N_ANON_ARRAY()) {
                # when ([a, b, c]) — membership test. Emit
                # `scalar(grep { $_ eq $topic } @{[a,b,c]})` via an
                # inline grep with the array as list.
                my scalar $grep_node = Perla::AST::node(Perla::AST::N_GREP());
                my scalar $cmp_node = Perla::AST::node(Perla::AST::N_BINOP());
                # Body: $_ eq $topic OR $_ == $topic depending on type;
                # use eq by default (works for both numeric and string
                # in Perl's smartmatch for scalar comparison).
                $cmp_node->{"op"} = "eq";
                my scalar $under_node = Perla::AST::node_with(Perla::AST::N_SCALAR_VAR(), "name", "_");
                $cmp_node->{"left"} = $under_node;
                $cmp_node->{"right"} = $topic;
                my scalar $body_node = Perla::AST::node(Perla::AST::N_BLOCK());
                $body_node->{"stmts"} = [$cmp_node];
                $grep_node->{"block"} = $body_node;
                # The list arg of grep should be the dereferenced anon array.
                # Simplest: just pass the elements as a flat list.
                $grep_node->{"list"} = $m;
                $cond = $grep_node;
            } elsif ($mt == Perla::AST::N_NUM_LIT() || $mt == Perla::AST::N_INT_LIT()) {
                # Numeric literal — use ==
                $cond = Perla::AST::node(Perla::AST::N_BINOP());
                $cond->{"op"} = "==";
                $cond->{"left"} = $topic;
                $cond->{"right"} = $m;
            } else {
                # Default: eq comparison
                $cond = Perla::AST::node(Perla::AST::N_BINOP());
                $cond->{"op"} = "eq";
                $cond->{"left"} = $topic;
                $cond->{"right"} = $m;
            }
            $if_node->{"cond"} = $cond;
            $if_node->{"then"} = $clause->{"body"};
            if (defined($result)) {
                $if_node->{"else"} = $result;
            }
            $result = $if_node;
        }
        $i--;
    }

    if (defined($result)) { return $result; }
    return Perla::AST::node(Perla::AST::N_UNDEF());
}

func _parse_package(scalar $p) scalar {
    _advance($p);
    my scalar $node = Perla::AST::node(Perla::AST::N_PACKAGE());
    # Read package name - may be multi-part (Foo::Bar::Baz)
    my str $pkg_name = _advance($p)->{"value"};
    while (_peek_type($p) eq "PKG_SEP") {
        _advance($p);
        if (_peek_type($p) eq "IDENT" || _peek_type($p) eq "PACKAGE") {
            $pkg_name = $pkg_name . "::" . _advance($p)->{"value"};
        }
    }
    $node->{"name"} = $pkg_name;
    $p->{"pkg"} = $pkg_name;
    _match($p, "SEMI");
    return $node;
}

func _parse_require_stmt(scalar $p) scalar {
    _advance($p);  # consume 'require'
    my scalar $node = Perla::AST::node(Perla::AST::N_REQUIRE());
    # require VERSION (5, 5.010, v5.10.1, etc.) - not a module load, perl version
    # check. Consume the number and emit a no-op USE node so the statement
    # has no runtime effect.
    if (_peek_type($p) eq "INT" || _peek_type($p) eq "NUM") {
        _advance($p);
        _match($p, "SEMI");
        return Perla::AST::node(Perla::AST::N_USE());
    }
    # require BAREWORD:  require Foo::Bar;  (module name)
    # require STRING:    require "path";    (runtime path)
    # require EXPR:      require $var;      (runtime expression)
    if (_peek_type($p) eq "IDENT" || _peek_type($p) eq "PACKAGE") {
        my str $mod = _advance($p)->{"value"};
        while (_peek_type($p) eq "PKG_SEP") {
            _advance($p);
            if (_peek_type($p) eq "IDENT" || _peek_type($p) eq "PACKAGE") {
                $mod = $mod . "::" . _advance($p)->{"value"};
            }
        }
        # Handle trailing version: require Foo 1.23; - ignore
        if (_peek_type($p) eq "INT" || _peek_type($p) eq "NUM") { _advance($p); }
        $node->{"module"} = $mod;
    } elsif (_peek_type($p) eq "STRING") {
        my str $s = _advance($p)->{"value"};
        # v-string: `require v5.20.0` — Lexer encodes vstrings as STRING
        # tokens whose value starts with a control byte (chr(<32)). These
        # are perl-version checks, not module loads. The chr(0) in the
        # value also breaks emission as a C string literal. Skip-as-noop.
        if (length($s) > 0 && ord(substr($s, 0, 1)) < 32) {
            _match($p, "SEMI");
            return Perla::AST::node(Perla::AST::N_USE());
        }
        # Convert path-style "Foo/Bar.pm" to module name Foo::Bar for the codegen
        if (length($s) > 3 && substr($s, length($s) - 3, 3) eq ".pm") {
            my str $mod = substr($s, 0, length($s) - 3);
            $mod = replace_all($mod, "/", "::");
            $node->{"module"} = $mod;
        } else {
            # Keep as-is; codegen will hand this to perla_require_module
            $node->{"expr"} = Perla::AST::node_with(Perla::AST::N_STR_LIT(), "value", $s);
        }
    } elsif (_peek_type($p) eq "DQSTRING") {
        # Double-quoted string - may contain $var interpolation
        # (e.g. `require "File/Spec/$module.pm"`). Keep the raw
        # DQSTRING value for detection of a literal .pm suffix, but
        # always build an N_INTERP_STR expression so codegen
        # interpolates at runtime. The resulting string is passed to
        # perla_require_module which handles both "Path/To.pm" and
        # "Module::Name" forms.
        my str $s = _advance($p)->{"value"};
        $node->{"expr"} = Perla::AST::node_with(Perla::AST::N_INTERP_STR(), "value", $s);
    } else {
        # require EXPR (scalar/var/computed) - runtime expr form
        $node->{"expr"} = _parse_expr($p);
    }
    # Postfix if/unless: `require DBI::PurePerl if $@ or ...;` (common guard
    # pattern in DBI.pm and elsewhere). Without this the IF bubbles up to the
    # statement loop, which then fails parsing the next tokens as a block
    # `if (COND) { ... }` form.
    if (_peek_type($p) eq "IF") {
        _advance($p);
        my scalar $cond = _parse_expr($p);
        _match($p, "SEMI");
        my scalar $pif = Perla::AST::node(Perla::AST::N_POSTFIX_IF());
        $pif->{"expr"} = $node;
        $pif->{"cond"} = $cond;
        return $pif;
    }
    if (_peek_type($p) eq "UNLESS") {
        _advance($p);
        my scalar $cond = _parse_expr($p);
        _match($p, "SEMI");
        my scalar $pif = Perla::AST::node(Perla::AST::N_POSTFIX_UNLESS());
        $pif->{"expr"} = $node;
        $pif->{"cond"} = $cond;
        return $pif;
    }
    _match($p, "SEMI");
    return $node;
}

func _parse_no(scalar $p) scalar {
    # `no MODULE [LIST];` — opposite of `use`. We treat most forms as a
    # no-op (consume to `;`) but mark a flag for `no integer;` so the
    # `use integer` codegen toggle can be reverted at file scope.
    _advance($p);  # consume NO
    my str $module = "";
    if (!_at_end($p)) {
        $module = _advance($p)->{"value"};
    }
    # Stop at RBRACE too: `{ no warnings }` (no trailing `;`) must not run away.
    while (_peek_type($p) ne "SEMI" && _peek_type($p) ne "RBRACE" && !_at_end($p)) { _advance($p); }
    _match($p, "SEMI");
    my scalar $node = Perla::AST::node(Perla::AST::N_USE());
    $node->{"module"} = $module;
    $node->{"is_no"} = 1;
    return $node;
}

func _parse_use(scalar $p) scalar {
    _advance($p);

    # Read the module name - may be multi-part (Foo::Bar::Baz)
    my str $module = _advance($p)->{"value"};

    # `use 5.006;` / `use v5.10;` / `use 5.042000;` - not a module load,
    # it's a Perl version check. Skip to end of statement and emit a
    # no-op N_USE node. Without this guard the codegen (which now
    # emits perla_require_module for every N_USE) tries to load
    # "5.006.pm" and dies with "Can't locate 5.006.pm in @INC".
    my str $__first = substr($module, 0, 1);
    # `use v5.10;` — the lexer encodes a v-string as its literal bytes
    # (chr(5).chr(10)), so the leading char is a control byte, not "v". The
    # literal-"v" check below would miss it and the codegen would then emit
    # perla_register_imported("\x05\x0a") — an unterminated C string literal
    # (the chr(10) is a raw newline). Detect the control-byte encoding (as the
    # require path does) and treat it as a version-check no-op.
    if (length($module) > 0 && ord($__first) < 32) {
        while (_peek_type($p) ne "SEMI" && _peek_type($p) ne "RBRACE" && !_at_end($p)) { _advance($p); }
        _match($p, "SEMI");
        return Perla::AST::node(Perla::AST::N_USE());
    }
    if ($__first eq "v" && length($module) > 1 && substr($module, 1, 1) ge "0" && substr($module, 1, 1) le "9") {
        while (_peek_type($p) ne "SEMI" && _peek_type($p) ne "RBRACE" && !_at_end($p)) { _advance($p); }
        _match($p, "SEMI");
        return Perla::AST::node(Perla::AST::N_USE());
    }
    if (length($module) > 0 && $__first ge "0" && $__first le "9") {
        while (_peek_type($p) ne "SEMI" && _peek_type($p) ne "RBRACE" && !_at_end($p)) { _advance($p); }
        _match($p, "SEMI");
        return Perla::AST::node(Perla::AST::N_USE());
    }

    # IO::Compress::* / IO::Uncompress::* / Compress::Zlib — provided natively
    # (libz/libbz2; one-shot verbs handled inline in the codegen, Compress::Zlib
    # functions registered in perla_init). Skip requiring the system .pm, whose
    # XS Compress::Raw::Zlib/Bzip2 dependency chain doesn't compile. Consume any
    # import list and declare the per-module $XxxError global so `... or die
    # $XxxError` passes strict.
    if ($module eq "IO::Compress::Gzip"       || $module eq "IO::Uncompress::Gunzip"
        || $module eq "IO::Compress::Deflate" || $module eq "IO::Uncompress::Inflate"
        || $module eq "IO::Compress::RawDeflate" || $module eq "IO::Uncompress::RawInflate"
        || $module eq "IO::Compress::Bzip2"   || $module eq "IO::Uncompress::Bunzip2"
        || $module eq "Compress::Zlib") {
        while (_peek_type($p) ne "SEMI" && _peek_type($p) ne "RBRACE" && !_at_end($p)) { _advance($p); }
        _match($p, "SEMI");
        my str $errname = "GzipError";
        if ($module eq "IO::Uncompress::Gunzip") { $errname = "GunzipError"; }
        elsif ($module eq "IO::Compress::Deflate") { $errname = "DeflateError"; }
        elsif ($module eq "IO::Uncompress::Inflate") { $errname = "InflateError"; }
        elsif ($module eq "IO::Compress::RawDeflate") { $errname = "RawDeflateError"; }
        elsif ($module eq "IO::Uncompress::RawInflate") { $errname = "RawInflateError"; }
        elsif ($module eq "IO::Compress::Bzip2") { $errname = "Bzip2Error"; }
        elsif ($module eq "IO::Uncompress::Bunzip2") { $errname = "Bunzip2Error"; }
        elsif ($module eq "Compress::Zlib") { $errname = "gzerrno"; }
        my scalar $node = Perla::AST::node(Perla::AST::N_OUR());
        my scalar $ev = {};
        $ev->{"value"} = $errname;
        $ev->{"type"} = "SCALAR_VAR";
        $node->{"var"} = $ev;
        return $node;
    }

    # use Math::BigInt — the class is provided natively (registered in
    # perla_init); skip the system .pm (which hangs the require chain). No
    # pragma flag: this is the explicit-object API, not literal promotion.
    if ($module eq "Math::BigInt") {
        while (_peek_type($p) ne "SEMI" && _peek_type($p) ne "RBRACE" && !_at_end($p)) { _advance($p); }
        _match($p, "SEMI");
        return Perla::AST::node(Perla::AST::N_USE());
    }

    # use bigint / use bignum — provided natively (arbitrary-precision integer
    # arithmetic, routed through perla_bigint_binop under a codegen flag). The
    # system bigint.pm pulls in Math::BigInt + Carp and hangs the require
    # chain, so skip it; emit an N_USE the codegen recognises to set the flag.
    if ($module eq "bigint" || $module eq "bignum") {
        while (_peek_type($p) ne "SEMI" && _peek_type($p) ne "RBRACE" && !_at_end($p)) { _advance($p); }
        _match($p, "SEMI");
        my scalar $node = Perla::AST::node(Perla::AST::N_USE());
        $node->{"module"} = "bigint";
        return $node;
    }

    # use constant NAME => VALUE;
    #
    # Compiles `use constant FOO => 1` to `sub FOO { 1 }` so callers
    # using the bareword form (`Pkg::FOO`, `&Pkg::FOO`, `FOO()`) get
    # the real value, not the literal "Pkg::FOO" string fallback that
    # the codegen emits for unknown 0-arg pkg-qualified calls. Earlier
    # versions emitted an `our $FOO = VALUE` which only made the scalar
    # variable form work; `HTTP::Status::RC_BAD_REQUEST` as referenced
    # by LWP::UserAgent ended up as the literal string instead of 400.
    if ($module eq "constant") {
        # Helper: build an N_SUB node `sub NAME { VALUE }`. The body is
        # a single-statement N_BLOCK whose value is VALUE; codegen
        # treats the last block expression as the implicit return.
        # use constant { KEY => VAL, ... } - hash-form multiple constants
        if (_peek_type($p) eq "LBRACE") {
            _advance($p);  # consume {
            my scalar $stmts_acc = [];
            while (_peek_type($p) ne "RBRACE" && !_at_end($p)) {
                my str $cname = _advance($p)->{"value"};
                if (_peek_type($p) eq "FAT_ARROW") { _advance($p); }
                my scalar $cval = _parse_assign($p);
                _match($p, "COMMA");
                my scalar $cnode = Perla::AST::node(Perla::AST::N_SUB());
                $cnode->{"package"} = $p->{"pkg"};
                $cnode->{"name"} = $cname;
                my scalar $cbody = Perla::AST::node(Perla::AST::N_BLOCK());
                $cbody->{"stmts"} = [$cval];
                $cnode->{"body"} = $cbody;
                push(@{$stmts_acc}, $cnode);
            }
            _match($p, "RBRACE");
            _match($p, "SEMI");
            # Return an N_BLOCK containing all the sub decls so they stay
            # in the same parse context (e.g. inside `{ package Foo; ... }`
            # so each ends up qualified to Foo). Previous implementation
            # pushed all but the first into $p->{prog}->{stmts}, which
            # promoted them to program scope and lost the enclosing
            # package context — only the first constant was installed in
            # the right stash; later ones got main::NAME.
            if (scalar(@{$stmts_acc}) == 0) {
                return Perla::AST::node(Perla::AST::N_USE());
            }
            if (scalar(@{$stmts_acc}) == 1) { return $stmts_acc->[0]; }
            my scalar $blk = Perla::AST::node(Perla::AST::N_BLOCK());
            $blk->{"stmts"} = $stmts_acc;
            return $blk;
        }
        # use constant NAME => VALUE - single constant
        my str $const_name = _advance($p)->{"value"};
        if (_peek_type($p) eq "FAT_ARROW") { _advance($p); }
        my scalar $const_val = _parse_expr($p);
        # A multi-element list value (`use constant DAYS => ('a','b','c')`)
        # is a list constant: Perl backs it with `@list`, so scalar context
        # yields the element COUNT. Flag the N_ANON_ARRAY so its codegen
        # opts into count-in-scalar (a single-element value keeps value
        # semantics — `(42)` is just 42).
        if (defined($const_val) && $const_val->{"type"} == Perla::AST::N_ANON_ARRAY()
            && (!defined($const_val->{"is_ref"}) || $const_val->{"is_ref"} == 0)
            && defined($const_val->{"elems"}) && scalar(@{$const_val->{"elems"}}) > 1) {
            $const_val->{"scalar_count"} = 1;
        }
        _match($p, "SEMI");
        my scalar $node = Perla::AST::node(Perla::AST::N_SUB());
        $node->{"package"} = $p->{"pkg"};
        $node->{"name"} = $const_name;
        my scalar $cbody = Perla::AST::node(Perla::AST::N_BLOCK());
        $cbody->{"stmts"} = [$const_val];
        $node->{"body"} = $cbody;
        return $node;
    }

    # use <pragma> - skip. ONLY real compile-time pragmas whose semantics
    # are about the parser / language itself (strict / warnings / feature /
    # utf8 / integer / bytes) and for which Perla has matching behavior
    # built in. Do NOT put runtime-behavior modules here (Exporter, Carp,
    # Config, POSIX, Fcntl, DynaLoader, etc.) - they need to actually load
    # so their real import / init runs.
    if ($module eq "strict" || $module eq "warnings" ||
        $module eq "warnings::register" ||
        $module eq "utf8" || $module eq "bytes" ||
        $module eq "feature" || $module eq "vars" ||
        $module eq "attributes" || $module eq "re" ||
        $module eq "autouse" || $module eq "subs" || $module eq "sigtrap" ||
        $module eq "sort" || $module eq "fields" || $module eq "if" ||
        $module eq "locale" ||
        $module eq "5" || $module eq "v5") {
        while (_peek_type($p) ne "SEMI" && _peek_type($p) ne "RBRACE" && !_at_end($p)) { _advance($p); }
        _match($p, "SEMI");
        # Preserve module="strict"/"utf8"/"bytes" on the N_USE node so
        # codegen can flip the relevant flags. Other pragmas stay as
        # bare N_USE.
        my scalar $__usen = Perla::AST::node(Perla::AST::N_USE());
        if ($module eq "strict" || $module eq "utf8" || $module eq "bytes"
            || $module eq "warnings") {
            $__usen->{"module"} = $module;
        }
        # `no warnings` (with $is_no set on the node) needs the module
        # too so the codegen can flip the flag off.
        return $__usen;
    }
    # `use mro 'c3'` / `use mro::c3` / `use mro` — capture the algo arg
    # (if any) into the N_USE node's `imports` field so the codegen can
    # call perla_set_mro with the right algorithm. Default to "dfs".
    # Wrap in a BEGIN block so the MRO setting takes effect before any
    # subsequent code runs — matching Perl's compile-time pragma
    # semantic (otherwise a later `use mro 'c3'` wouldn't influence
    # earlier method calls in the same file).
    if ($module eq "mro" || $module eq "mro::c3") {
        my array @mro_imps = ();
        while (_peek_type($p) ne "SEMI" && !_at_end($p)) {
            my scalar $tok = _advance($p);
            if ($tok->{"type"} eq "STRING" || $tok->{"type"} eq "DQSTRING") {
                push(@mro_imps, $tok->{"value"});
            }
        }
        _match($p, "SEMI");
        my scalar $mu = Perla::AST::node(Perla::AST::N_USE());
        $mu->{"module"} = $module;
        $mu->{"imports"} = \@mro_imps;
        # Capture the current package at parse time, since BEGIN-hoisting
        # loses the $cg->{"pkg"} context (codegen runs BEGIN blocks at
        # the top of main, where $cg->{"pkg"} is "main").
        $mu->{"mro_pkg"} = "" . $p->{"pkg"};
        # Wrap in BEGIN so it hoists to file-init time — matches Perl's
        # compile-time pragma semantic: an `use mro 'c3'` later in the
        # file influences method dispatch in earlier code.
        my scalar $bn = Perla::AST::node(Perla::AST::N_BEGIN());
        my scalar $bb = Perla::AST::node(Perla::AST::N_BLOCK());
        $bb->{"stmts"} = [$mu];
        $bn->{"body"} = $bb;
        return $bn;
    }

    # `use integer` - keep the module field set so codegen can flip the
    # use_integer flag and emit truncating division for `/`. DateTime::PP
    # relies on this to compute year/month/day correctly.
    if ($module eq "integer") {
        while (_peek_type($p) ne "SEMI" && _peek_type($p) ne "RBRACE" && !_at_end($p)) { _advance($p); }
        _match($p, "SEMI");
        my scalar $iu = Perla::AST::node(Perla::AST::N_USE());
        $iu->{"module"} = "integer";
        return $iu;
    }

    # use lib "path" - add library search path
    if ($module eq "lib") {
        if (_peek_type($p) eq "STRING" || _peek_type($p) eq "DQSTRING") {
            my str $path = _advance($p)->{"value"};
            push(@{$p->{"lib_paths"}}, $path);
        }
        _match($p, "SEMI");
        return Perla::AST::node(Perla::AST::N_USE());
    }

    # use parent 'Module' / use parent qw(Module1 Module2)
    # use base 'Module'
    # Accept `use parent -norequire, 'Module'` — the `-norequire`
    # arg tells real Perl to skip loading the module from disk
    # (we already do that), so just skip the token.
    if ($module eq "parent" || $module eq "base") {
        my array @parents = ();
        # Skip leading -norequire (parsed as OP "-" + IDENT "norequire"
        # or as a single IDENT depending on lexer; handle both).
        while (1) {
            my str $pt = _peek_type($p);
            my str $pv = _peek_val($p);
            if ($pt eq "OP" && $pv eq "-") {
                # Peek ahead to see if next is "norequire" ident
                _advance($p);  # consume '-'
                if (_peek_type($p) eq "IDENT" && _peek_val($p) eq "norequire") {
                    _advance($p);  # consume 'norequire'
                }
                if (_peek_type($p) eq "COMMA") { _advance($p); }
                next;
            }
            if ($pt eq "IDENT" && $pv eq "norequire") {
                _advance($p);
                if (_peek_type($p) eq "COMMA") { _advance($p); }
                next;
            }
            last;
        }
        if (_peek_type($p) eq "STRING" || _peek_type($p) eq "DQSTRING") {
            push(@parents, _advance($p)->{"value"});
        } elsif (_peek_type($p) eq "QW") {
            _advance($p);
            _expect($p, "LPAREN");
            while (_peek_type($p) ne "RPAREN" && !_at_end($p)) {
                push(@parents, _advance($p)->{"value"});
            }
            _expect($p, "RPAREN");
        }
        while (_peek_type($p) eq "COMMA" || _peek_type($p) eq "STRING" || _peek_type($p) eq "DQSTRING") {
            if (_peek_type($p) eq "COMMA") { _advance($p); next; }
            push(@parents, _advance($p)->{"value"});
        }
        _match($p, "SEMI");

        # Generate @ISA push for each parent, and load parent modules
        my scalar $prog_stmts = $p->{"prog"}->{"stmts"};
        my str $pkg = $p->{"pkg"};
        my int $pi = 0;
        while ($pi < scalar(@parents)) {
            my str $parent = $parents[$pi];
            # Load the parent module - push its stmts directly.
            # Force-build the parent: methods are needed via inheritance.
            _push_module_stmts_force($p, $prog_stmts, $parent);
            # Restore package context
            my scalar $restore = Perla::AST::node(Perla::AST::N_PACKAGE());
            $restore->{"name"} = $pkg;
            push(@{$prog_stmts}, $restore);
            # Generate: perla_isa_push(pkg, parent)
            my scalar $isa_node = Perla::AST::node(Perla::AST::N_USE());
            $isa_node->{"module"} = "__isa__";
            $isa_node->{"pkg"} = $pkg;
            $isa_node->{"parent"} = $parent;
            push(@{$prog_stmts}, $isa_node);
            $pi++;
        }
        return Perla::AST::node(Perla::AST::N_USE());
    }

    # Check for LoadModules-style dynamic module loader
    if ($module eq "Abe::LoadModules" || $module eq "LoadModules") {
        # Parse the (path => [...]) args to find directories
        my array @load_paths = ();
        while (_peek_type($p) ne "SEMI" && !_at_end($p)) {
            my scalar $tok = _advance($p);
            if ($tok->{"type"} eq "STRING" || $tok->{"type"} eq "DQSTRING") {
                my str $val = $tok->{"value"};
                # Check if this looks like a path
                if (index($val, "/") >= 0 || index($val, ".") == 0) {
                    push(@load_paths, $val);
                }
            }
        }
        _match($p, "SEMI");
        # If no valid absolute paths found, use the parser's lib_paths
        if (scalar(@load_paths) == 0 || (scalar(@load_paths) > 0 && index($load_paths[0], "/") != 0)) {
            @load_paths = @{$p->{"lib_paths"}};
        }
        # Load essential .pm files - focus on Abe/DB/ modules (database models)
        my scalar $prog_stmts = $p->{"prog"}->{"stmts"};
        my str $saved_pkg = $p->{"pkg"};
        my int $li = 0;
        while ($li < scalar(@load_paths)) {
            my str $dir = $load_paths[$li];
            # Inline depth-0 Abe/DB/*.pm and the Network/ subdir (26 files,
            # contains site_mapping/accounts/network_users tables Abe::App
            # requires during init). Deeper subdirs (533 files) would blow
            # the C compile budget; broader auto-load should use runtime
            # require+dlopen instead of AST inline.
            my array @pm_files = core::glob($dir . "/Abe/DB/*.pm");
            my array @pm_network = core::glob($dir . "/Abe/DB/Network/*.pm");
            my int $ni = 0;
            while ($ni < scalar(@pm_network)) {
                push(@pm_files, $pm_network[$ni]);
                $ni++;
            }
            my array @dbix_files = core::glob($dir . "/DBIx/Class/Bootstrap/*.pm");
            my int $di = 0;
            while ($di < scalar(@dbix_files)) {
                push(@pm_files, $dbix_files[$di]);
                $di++;
            }
            my int $fi = 0;
            while ($fi < scalar(@pm_files)) {
                my str $pm_file = $pm_files[$fi];
                my str $rel = $pm_file;
                if (index($rel, $dir) == 0) {
                    $rel = substr($rel, length($dir) + 1, length($rel) - length($dir) - 1);
                }
                if (index($rel, ".pm") >= 0) {
                    $rel = substr($rel, 0, length($rel) - 3);
                }
                my str $mod_name = replace_all($rel, "/", "::");
                _push_module_stmts($p, $prog_stmts, $mod_name);
                my scalar $restore2 = Perla::AST::node(Perla::AST::N_PACKAGE());
                $restore2->{"name"} = $saved_pkg;
                push(@{$prog_stmts}, $restore2);
                $fi++;
            }
            $li++;
        }
        return Perla::AST::node(Perla::AST::N_USE());
    }

    # use Module::Name - load the module file
    my scalar $prog_stmts = $p->{"prog"}->{"stmts"};
    my str $saved_pkg = $p->{"pkg"};
    $p->{"last_load_succeeded"} = 0;
    _push_module_stmts($p, $prog_stmts, $module);
    my int $loaded_at_compile = $p->{"last_load_succeeded"};

    # Always restore original package context after module inclusion
    # (the inlined module likely changed the package context)
    my scalar $restore = Perla::AST::node(Perla::AST::N_PACKAGE());
    $restore->{"name"} = $saved_pkg;
    push(@{$prog_stmts}, $restore);

    # Parse import args so we can emit Module->import(@args) at codegen.
    # Forms:
    #   use Module;            - import() with no extra args
    #   use Module ();         - explicit empty list: suppress import call
    #   use Module LIST;       - bare list, passed as import args
    #   use Module (A, B);     - parenthesized list
    #   use Module VERSION LIST; - Perl's version-check form; the
    #     VERSION is NOT an import arg. Skip a leading INT/NUM/v-string
    #     token here so `use Module::Runtime 0.012 ()` doesn't pass
    #     "0.012" as the import list (which would die in Exporter-style
    #     import functions).
    my array @import_args = ();
    my int $suppress_import = 0;
    my str $__ut = _peek_type($p);
    if ($__ut eq "INT" || $__ut eq "NUM") {
        _advance($p);
    }
    if (_peek_type($p) eq "LPAREN") {
        _advance($p);
        if (_peek_type($p) eq "RPAREN") {
            $suppress_import = 1;
        } else {
            while (_peek_type($p) ne "RPAREN" && !_at_end($p)) {
                push(@import_args, _parse_assign($p));
                if (_peek_type($p) eq "COMMA" || _peek_type($p) eq "FAT_ARROW") {
                    _advance($p);
                }
            }
        }
        _expect($p, "RPAREN");
    } else {
        # Stop at RBRACE too: a `use`/`no` can be the last statement in a
        # block with no trailing `;` (`{ package X; use warnings::register }`,
        # `{ use strict }`). Without the RBRACE guard the loop entered on the
        # `}`, _parse_assign consumed the block-closing brace, and the parse
        # ran away to EOF ("expected RBRACE, got EOF") — which broke
        # Path::Tiny and any module using that idiom.
        while (_peek_type($p) ne "SEMI" && _peek_type($p) ne "RBRACE" && !_at_end($p)) {
            push(@import_args, _parse_assign($p));
            if (_peek_type($p) eq "COMMA" || _peek_type($p) eq "FAT_ARROW") {
                _advance($p);
            } else {
                last;
            }
        }
    }
    _match($p, "SEMI");

    my scalar $node = Perla::AST::node(Perla::AST::N_USE());
    $node->{"module"} = $module;
    $node->{"import_args"} = \@import_args;
    $node->{"suppress_import"} = $suppress_import;
    $node->{"loaded_at_compile"} = $loaded_at_compile;
    return $node;
}

# Push module stmts directly into the program's stmt list
func _push_module_stmts(scalar $p, scalar $prog_stmts, str $module) void {
    my scalar $stmts = _load_module($p, $module);
    if (defined($stmts)) {
        my int $count = scalar(@{$stmts});
        my int $i = 0;
        while ($i < $count) {
            my scalar $s = $stmts->[$i];
            if (defined($s)) {
                push(@{$prog_stmts}, $s);
            }
            $i++;
        }
        # Caller (use-stmt parser) reads this to decide whether to emit
        # perla_mark_loaded. Marking %INC for a deferred module makes
        # runtime require short-circuit before it can actually load.
        $p->{"last_load_succeeded"} = 1;
    } else {
        $p->{"last_load_succeeded"} = 0;
    }
}

# Force-build variant: stash the parent name in a parser-level set
# so the next _load_module call expands its narrow auto-build
# heuristic to always include this module. Used by `use base/parent`
# so a parent class's methods are available via inheritance even
# when the parent has no `sub import` / `@EXPORT` to trigger the
# default heuristic. Without this, `use base 'Class::C3::Componentised'`
# would leave C3::Componentised's methods unregistered, making
# `$class->load_components(...)` (inherited via DBIx::Class chain)
# silently fail with "Can't locate object method".
func _push_module_stmts_force(scalar $p, scalar $prog_stmts, str $module) void {
    if (!defined($p->{"force_build_set"})) { $p->{"force_build_set"} = {}; }
    $p->{"force_build_set"}->{$module} = 1;
    _push_module_stmts($p, $prog_stmts, $module);
}

# Force-build the component modules named in a `load_components` /
# `load_own_components` call so their inherited methods are compiled and
# linked (see the call site in the ARROW method-call parser). Walks the
# argument AST (string literals, qw(...) lists, and [...] arrayrefs) and
# force-builds each component. A bare name gets the `DBIx::Class::` base
# (the overwhelmingly common Componentised user); a `+`-prefixed name is
# taken verbatim. Names whose .pm doesn't exist no-op in _load_module.
func _load_components_collect(scalar $p, scalar $prog_stmts, scalar $arg) void {
    if (!defined($arg)) { return; }
    my int $t = $arg->{"type"};
    if ($t == Perla::AST::N_STR_LIT()) {
        my str $c = "" . $arg->{"value"};
        if (length($c) == 0 || substr($c, 0, 1) eq "#") { return; }
        my str $full = $c;
        if (substr($c, 0, 1) eq "+") {
            $full = substr($c, 1, length($c) - 1);
        } else {
            $full = "DBIx::Class::" . $c;
        }
        my str $saved_pkg = $p->{"pkg"};
        _push_module_stmts_force($p, $prog_stmts, $full);
        $p->{"pkg"} = $saved_pkg;
        return;
    }
    if ($t == Perla::AST::N_QWORD() || $t == Perla::AST::N_ANON_ARRAY()) {
        if (defined($arg->{"elems"})) {
            my int $ei = 0;
            while ($ei < scalar(@{$arg->{"elems"}})) {
                _load_components_collect($p, $prog_stmts, $arg->{"elems"}->[$ei]);
                $ei = $ei + 1;
            }
        }
        return;
    }
}

func _load_components_deps(scalar $p, scalar $args) void {
    if (!defined($args)) { return; }
    my scalar $prog_stmts = $p->{"prog"}->{"stmts"};
    my int $ai = 0;
    while ($ai < scalar(@{$args})) {
        _load_components_collect($p, $prog_stmts, $args->[$ai]);
        $ai = $ai + 1;
    }
}

# Load a module file and return its AST statements
func _load_module(scalar $p, str $module) scalar {
    # Don't load the same module twice
    if (_is_module_loaded_in($p, $module) == 1) {
        _dbg("use " . $module . " -> already loaded (skip)");
        return undef;
    }
    _mark_module_loaded_in($p, $module);
    _dbg("use " . $module);

    # Convert Module::Name to Module/Name.pm
    my str $rel_path = "";
    my int $i = 0;
    my int $mlen = length($module);
    while ($i < $mlen) {
        my str $ch = substr($module, $i, 1);
        if ($ch eq ":" && $i + 1 < $mlen && substr($module, $i + 1, 1) eq ":") {
            $rel_path = $rel_path . "/";
            $i = $i + 2;
        } else {
            $rel_path = $rel_path . $ch;
            $i++;
        }
    }
    $rel_path = $rel_path . ".pm";


    # Search library paths. For "library tree" paths (site_perl/ or
    # under /opt/), we only use modules with a precompiled artifact
    # (.pm.o for static link, or .pm.so for dlopen under --shared) -
    # otherwise thousands of transitive .pm sources explode compile
    # time. Modules without any precompiled artifact fall through to
    # runtime require. For non-library-tree paths (typical project-
    # local `use lib`), parse .pm source as usual.
    #
    # With --precompile-deps (PERLA_PRECOMPILE_DEPS=1), any .pm in a
    # library tree that's missing BOTH artifacts gets compiled via
    # `perla -M` first (which builds both .pm.o and .pm.so in one
    # pass). If only one artifact is present we re-run `perla -M` to
    # rebuild the missing sibling. Idempotent: modules with both
    # artifacts are skipped.
    #
    # With --force-rebuild (PERLA_FORCE_REBUILD=1), `perla -M` is
    # always invoked regardless of whether the artifacts exist -
    # useful after changing the compiler or a module's source.
    #
    # Under --shared (PERLA_SHARED=1) the parser prefers .pm.so when
    # both artifacts are present, and CodeGen emits a dlopen+dlsym
    # call instead of linking the .o statically.
    my str $found_path = "";
    my scalar $paths = $p->{"lib_paths"};
    my int $lpi = 0;
    my int $precompile_deps = 0;
    my int $prefer_shared = 0;
    my int $force_rebuild = 0;
    if (core::getenv("PERLA_PRECOMPILE_DEPS") eq "1") { $precompile_deps = 1; }
    if (core::getenv("PERLA_SHARED") eq "1") { $prefer_shared = 1; }
    if (core::getenv("PERLA_FORCE_REBUILD") eq "1") { $force_rebuild = 1; }
    while ($lpi < scalar(@{$paths})) {
        my str $lib_path = $paths->[$lpi];
        my str $full = $lib_path . "/" . $rel_path;
        if (core::file_exists($full) == 1) {
            my int $is_tree = 0;
            if (index($lib_path, "site_perl") >= 0) { $is_tree = 1; }
            elsif (length($lib_path) >= 4 && substr($lib_path, 0, 4) eq "/opt") { $is_tree = 1; }
            # With --precompile-deps, treat ALL library paths as trees so
            # the auto-build path applies to project-local lib/ directories
            # (bizowie/lib has 2300+ .pm files; without this they'd all get
            # inlined into the consuming .pm.c, making Abe::App.pm.c 15MB).
            elsif ($precompile_deps == 1) { $is_tree = 1; }
            if ($is_tree == 1) {
                my str $ocand = $full . ".o";
                my str $socand = $full . ".so";
                my int $o_exists = core::file_exists($ocand);
                my int $so_exists = core::file_exists($socand);
                # Freshness check: discard stale artifacts older than the
                # .pm source OR older than the running perla binary.
                # Without this, edits to .pm produced no effect because
                # perla blindly used the prior-built .pm.o / .pm.so —
                # and runtime/codegen ABI changes (e.g. perla_caller
                # behavior) silently broke modules whose .pm.o was
                # baked in before the change. The auto-build path (below)
                # then rebuilds them on demand.
                if ($o_exists == 1 || $so_exists == 1) {
                    my int $ah_src_mtime = 0;
                    my int $ah_o_mtime = 0;
                    my int $ah_so_mtime = 0;
                    my int $ah_perla_mtime = 0;
                    __C__ {
                        struct stat __ah_st;
                        char *__ah_sp = strada_to_str(full);
                        if (stat(__ah_sp, &__ah_st) == 0) { strada_decref(ah_src_mtime); ah_src_mtime = STRADA_MAKE_TAGGED_INT((int64_t)__ah_st.st_mtime); }
                        free(__ah_sp);
                        char *__ah_op = strada_to_str(ocand);
                        if (stat(__ah_op, &__ah_st) == 0) { strada_decref(ah_o_mtime); ah_o_mtime = STRADA_MAKE_TAGGED_INT((int64_t)__ah_st.st_mtime); }
                        free(__ah_op);
                        char *__ah_sop = strada_to_str(socand);
                        if (stat(__ah_sop, &__ah_st) == 0) { strada_decref(ah_so_mtime); ah_so_mtime = STRADA_MAKE_TAGGED_INT((int64_t)__ah_st.st_mtime); }
                        free(__ah_sop);
                        char __ah_pp[2048];
                        ssize_t __ah_pn = readlink("/proc/self/exe", __ah_pp, sizeof(__ah_pp)-1);
                        if (__ah_pn > 0) {
                            __ah_pp[__ah_pn] = '\0';
                            if (stat(__ah_pp, &__ah_st) == 0) { strada_decref(ah_perla_mtime); ah_perla_mtime = STRADA_MAKE_TAGGED_INT((int64_t)__ah_st.st_mtime); }
                        }
                    }
                    if ($o_exists == 1 && $ah_o_mtime < $ah_src_mtime) {
                        _dbg("  " . $module . ": stale .pm.o (older than source) — ignoring");
                        $o_exists = 0;
                    }
                    if ($so_exists == 1 && $ah_so_mtime < $ah_src_mtime) {
                        _dbg("  " . $module . ": stale .pm.so (older than source) — ignoring");
                        $so_exists = 0;
                    }
                    if ($o_exists == 1 && $ah_perla_mtime > 0 && $ah_o_mtime < $ah_perla_mtime) {
                        _dbg("  " . $module . ": stale .pm.o (older than perla) — ignoring");
                        $o_exists = 0;
                    }
                    if ($so_exists == 1 && $ah_perla_mtime > 0 && $ah_so_mtime < $ah_perla_mtime) {
                        _dbg("  " . $module . ": stale .pm.so (older than perla) — ignoring");
                        $so_exists = 0;
                    }
                }
                # Force rebuild if requested (ignores existing artifacts).
                if ($force_rebuild == 1) {
                    my str $perla_bin = "";
                    __C__ {
                        char buf[2048];
                        ssize_t len = readlink("/proc/self/exe", buf, sizeof(buf)-1);
                        if (len > 0) {
                            buf[len] = '\0';
                            strada_decref(perla_bin);
                            perla_bin = strada_new_str(buf);
                        }
                    }
                    # Recursion guard: if $full is already being built by an
                    # ancestor (recorded in PERLA_BUILDING_LIST), treat as
                    # already-in-progress and skip the spawn. Prevents
                    # infinite fork-bomb on `use`-cycles like
                    # DateTime::Set ↔ DateTime::Span.
                    my str $__bl = core::getenv("PERLA_BUILDING_LIST");
                    my int $__cycle = 0;
                    if (length($__bl) > 0 && index(":" . $__bl . ":", ":" . $full . ":") >= 0) {
                        $__cycle = 1;
                    }
                    if (length($perla_bin) > 0 && $__cycle == 0) {
                        my str $__new_bl = length($__bl) > 0 ? ($__bl . ":" . $full) : $full;
                        # Pass the module name explicitly. Without this the
                        # child perla re-derives the name from the file path,
                        # which is brittle for relative paths that don't
                        # contain `/lib/`: `Shipment/FedEx.pm` falls through
                        # to basename-only and emits
                        # `perla_mod_init_FedEx` instead of the correct
                        # `perla_mod_init_Shipment_FedEx`, breaking the link.
                        # Build PERLA5LIB from parent's lib_paths so the
                        # child perla -M can resolve modules from the same
                        # @INC. Without this, `use YAML;` in Abe::App.pm
                        # doesn't find /opt/bzperl/... and the child emits
                        # "YAML: NOT FOUND at compile time" — the resulting
                        # .pm.deps misses YAML.pm.o, and at runtime YAML
                        # isn't loaded → use-import is skipped → Abe::App::Load
                        # is undefined → config() returns undef → DBI fail.
                        my str $__plib = "";
                        if (defined($p->{"lib_paths"})) {
                            my int $__lpi = 0;
                            my scalar $__lps = $p->{"lib_paths"};
                            while ($__lpi < scalar(@{$__lps})) {
                                if (length($__plib) > 0) { $__plib = $__plib . ":"; }
                                $__plib = $__plib . $__lps->[$__lpi];
                                $__lpi++;
                            }
                        }
                        my str $__plib_env = "";
                        if (length($__plib) > 0) { $__plib_env = "PERLA5LIB=" . $__plib . " "; }
                        # Propagate the dep-handling mode to the spawned child.
                        # Without PERLA_PRECOMPILE_DEPS the child ran a plain
                        # `perla -M`, treated project-local lib/ as a non-tree,
                        # and INLINED every transitive bizowie/OHPA module's
                        # source into its own .pm.c — so Abe::App.pm.c ballooned
                        # to 21MB (3722 inlined subs) and gcc couldn't compile
                        # it in time/memory. Propagating it makes every module
                        # in the recursion reference + auto-build its deps.
                        if ($precompile_deps == 1) { $__plib_env = $__plib_env . "PERLA_PRECOMPILE_DEPS=1 "; }
                        if ($prefer_shared == 1) { $__plib_env = $__plib_env . "PERLA_SHARED=1 "; }
                        my str $cmd = $__plib_env . "PERLA_MODULE_NAME=" . $module . " PERLA_BUILDING_LIST=" . $__new_bl . " " . $perla_bin . " -M " . $full . " 2>&1";
                        _dbg("    spawn: " . $cmd);
                        core::qx($cmd);
                        $o_exists = core::file_exists($ocand);
                        $so_exists = core::file_exists($socand);
                    }
                    if ($o_exists == 1 || $so_exists == 1) {
                        $found_path = $full;
                        last;
                    }
                }
                # If the preferred artifact (or either, when no
                # preference is forced) is already present, use it.
                if (($prefer_shared == 1 && $so_exists == 1) ||
                    ($prefer_shared == 0 && $o_exists == 1) ||
                    ($o_exists == 1) || ($so_exists == 1)) {
                    my str $which = "";
                    if ($prefer_shared == 1 && $so_exists == 1) { $which = ".pm.so (shared)"; }
                    elsif ($o_exists == 1) { $which = ".pm.o (static)"; }
                    else { $which = ".pm.so (shared)"; }
                    _dbg("  " . $module . ": cache HIT " . $full . " [" . $which . "]");
                    # If --precompile-deps is on and one side is
                    # missing, rebuild so both exist. But when
                    # PERLA_BUILD_PM_SO_ONLY=1 is in effect (set by
                    # perla_require_module's spawned child compiles),
                    # the .pm.o build is explicitly disabled — so
                    # missing .pm.o is expected and re-spawning to
                    # "rebuild it" wastes time without changing state.
                    # Without this guard, every cache-HIT on a .pm.so
                    # in the dep tree fires another perla -M that
                    # rebuilds .pm.so but doesn't produce .pm.o, then
                    # the next visit fires another spawn, ad infinitum.
                    # In the bizowie chain this turned a 30-min build
                    # into a 6-hour timeout with only 183 of ~2000+
                    # files built.
                    my int $so_only_env = (core::getenv("PERLA_BUILD_PM_SO_ONLY") eq "1") ? 1 : 0;
                    # Only re-spawn to build the artifact the CURRENT mode needs:
                    # static (default) needs .pm.o, --shared needs .pm.so.
                    # Previously a missing .pm.so ALWAYS triggered a rebuild
                    # (`|| $so_exists == 0`), even in static mode where .pm.o
                    # alone suffices — and since `perla -M` produces only .pm.o
                    # (never .pm.so), the .pm.so stayed missing and EVERY
                    # consumer re-ran the (slow, e.g. 2800-line Type::Tiny)
                    # build forever. That made the bizowie closure crawl. Gate
                    # each side on the mode that actually consumes it.
                    my int $o_missing_effective = ($prefer_shared == 0 && $o_exists == 0 && $so_only_env == 0) ? 1 : 0;
                    my int $so_missing_effective = ($prefer_shared == 1 && $so_exists == 0) ? 1 : 0;
                    if ($precompile_deps == 1 && ($o_missing_effective == 1 || $so_missing_effective == 1)) {
                        my str $perla_bin = "";
                        __C__ {
                            char buf[2048];
                            ssize_t len = readlink("/proc/self/exe", buf, sizeof(buf)-1);
                            if (len > 0) {
                                buf[len] = '\0';
                                strada_decref(perla_bin);
                                perla_bin = strada_new_str(buf);
                            }
                        }
                        my str $__bl = core::getenv("PERLA_BUILDING_LIST");
                        my int $__cycle = 0;
                        if (length($__bl) > 0 && index(":" . $__bl . ":", ":" . $full . ":") >= 0) {
                            $__cycle = 1;
                        }
                        if (length($perla_bin) > 0 && $__cycle == 0) {
                            my str $__new_bl = length($__bl) > 0 ? ($__bl . ":" . $full) : $full;
                            # Pass the module name explicitly. Without this the
                        # child perla re-derives the name from the file path,
                        # which is brittle for relative paths that don't
                        # contain `/lib/`: `Shipment/FedEx.pm` falls through
                        # to basename-only and emits
                        # `perla_mod_init_FedEx` instead of the correct
                        # `perla_mod_init_Shipment_FedEx`, breaking the link.
                        # Build PERLA5LIB from parent's lib_paths so the
                        # child perla -M can resolve modules from the same
                        # @INC. Without this, `use YAML;` in Abe::App.pm
                        # doesn't find /opt/bzperl/... and the child emits
                        # "YAML: NOT FOUND at compile time" — the resulting
                        # .pm.deps misses YAML.pm.o, and at runtime YAML
                        # isn't loaded → use-import is skipped → Abe::App::Load
                        # is undefined → config() returns undef → DBI fail.
                        my str $__plib = "";
                        if (defined($p->{"lib_paths"})) {
                            my int $__lpi = 0;
                            my scalar $__lps = $p->{"lib_paths"};
                            while ($__lpi < scalar(@{$__lps})) {
                                if (length($__plib) > 0) { $__plib = $__plib . ":"; }
                                $__plib = $__plib . $__lps->[$__lpi];
                                $__lpi++;
                            }
                        }
                        my str $__plib_env = "";
                        if (length($__plib) > 0) { $__plib_env = "PERLA5LIB=" . $__plib . " "; }
                        # Propagate the dep-handling mode to the spawned child.
                        # Without PERLA_PRECOMPILE_DEPS the child ran a plain
                        # `perla -M`, treated project-local lib/ as a non-tree,
                        # and INLINED every transitive bizowie/OHPA module's
                        # source into its own .pm.c — so Abe::App.pm.c ballooned
                        # to 21MB (3722 inlined subs) and gcc couldn't compile
                        # it in time/memory. Propagating it makes every module
                        # in the recursion reference + auto-build its deps.
                        if ($precompile_deps == 1) { $__plib_env = $__plib_env . "PERLA_PRECOMPILE_DEPS=1 "; }
                        if ($prefer_shared == 1) { $__plib_env = $__plib_env . "PERLA_SHARED=1 "; }
                        my str $cmd = $__plib_env . "PERLA_MODULE_NAME=" . $module . " PERLA_BUILDING_LIST=" . $__new_bl . " " . $perla_bin . " -M " . $full . " 2>&1";
                            _dbg("    spawn (precompile-deps sibling): " . $cmd);
                            core::qx($cmd);
                        }
                    }
                    $found_path = $full;
                    last;
                }
                # Decide whether to auto-build this .pm.o.
                # - With --precompile-deps: always build (recursive,
                #   includes the whole dep tree).
                # - Without: NARROW auto-build - only if the source
                #   looks like it has an `import` sub that installs
                #   @ISA. Those modules (Drogo::Dispatch,
                #   Class::Accessor::Fast, Exporter subclasses)
                #   silently break downstream method dispatch when
                #   their .pm.o isn't present, because
                #   perla_can(X, "import") returns NO and the
                #   compile-time dispatch to X::import skips.
                # - Modules without `sub import` (plain DBIx::Class
                #   subclasses, data modules, etc.) are left to
                #   runtime require - broad auto-build regressed
                #   larger apps by exposing compile-order bugs in
                #   DBIx::Class table-setup methods.
                # - Opt out entirely with PERLA_NO_AUTO_BUILD=1.
                my int $should_build = 0;
                if ($precompile_deps == 1) { $should_build = 1; }
                elsif (core::getenv("PERLA_NO_AUTO_BUILD") eq "1") { $should_build = 0; }
                elsif (defined($p->{"force_build_set"}) && exists($p->{"force_build_set"}->{$module})) {
                    # Caller is `use base/parent` — parent's methods
                    # are needed via inheritance. Force-build even if
                    # the source doesn't match the import-side heuristic.
                    $should_build = 1;
                }
                else {
                    # Quick source peek: look for `sub import` at
                    # BOL. Cheap one-time read per module. If the
                    # module installs @ISA in its import, we need
                    # .pm.o present so that import can run.
                    #
                    # Also catch the Mo::Inline pattern where import
                    # is installed via glob assignment like
                    # `*{$M.'import'}=sub{...}` (YAML::Mo, Mo, Mu,
                    # Moo::Tiny variants). The narrow `sub import`
                    # grep misses these because Mo::Inline generates
                    # a dense one-liner with no `sub import` token.
                    my str $src = core::slurp($full);
                    if (length($src) > 0) {
                        if (index($src, "\nsub import") >= 0
                            || index($src, "sub import\n") == 0
                            || index($src, "\nsub import\n") >= 0
                            || index($src, "\nsub import ") >= 0
                            || index($src, "\nsub import{") >= 0
                            || index($src, "\n*import =") >= 0
                            || index($src, "{\$M.import}") >= 0
                            || index($src, "{\$M.'import'}") >= 0
                            || index($src, "{\$M.\"import\"}") >= 0
                            || index($src, "\nour \@EXPORT") >= 0
                            || index($src, "\nuse YAML::Mo") >= 0
                            || index($src, "\nuse Mo ") >= 0
                            || index($src, "\nuse Mo;") >= 0
                            # XS modules: the .pm runs XSLoader::load or
                            # DynaLoader::bootstrap to register XS subs.
                            # Compiling + running the .pm (a) triggers
                            # the bootstrap via our XSLoader hook, and
                            # (b) sets @EXPORT / @EXPORT_OK so
                            # `use Foo qw(sym)` imports work.
                            || index($src, "XSLoader::load") >= 0
                            || index($src, "DynaLoader::bootstrap") >= 0
                            || index($src, "\nuse XSLoader") >= 0
                            || index($src, "\nuse DynaLoader") >= 0
                            || index($src, "\nbootstrap ") >= 0) {
                            $should_build = 1;
                        }
                    }
                }
                # Failure cache: a prior auto-build of this module already
                # failed (no .pm.o produced) and left a .buildfail marker. Don't
                # re-spawn `perla -M` — otherwise EVERY consumer of a failing
                # module re-attempts the same doomed build (O(consumers) wasted
                # compiles; this is what made a large closure crawl). Defer to
                # runtime require. The marker is cleared by the top-level
                # --precompile-deps run (see Parser init) so a fresh build — e.g.
                # after a compiler fix — retries from scratch.
                if ($should_build == 1 && core::file_exists($full . ".buildfail") == 1) {
                    _dbg("  " . $module . ": skip auto-build (cached prior failure) - runtime require");
                    $should_build = 0;
                }
                if ($should_build == 1) {
                    _dbg("  " . $module . ": cache MISS " . $full . " - auto-building via perla -M");
                    my str $perla_bin = "";
                    __C__ {
                        char buf[2048];
                        ssize_t len = readlink("/proc/self/exe", buf, sizeof(buf)-1);
                        if (len > 0) {
                            buf[len] = '\0';
                            strada_decref(perla_bin);
                            perla_bin = strada_new_str(buf);
                        }
                    }
                    my str $__bl = core::getenv("PERLA_BUILDING_LIST");
                    my int $__cycle = 0;
                    if (length($__bl) > 0 && index(":" . $__bl . ":", ":" . $full . ":") >= 0) {
                        $__cycle = 1;
                    }
                    if ($__cycle == 1) {
                        _dbg("  " . $module . ": build-cycle guard tripped (already building upstream)");
                    }
                    if (length($perla_bin) > 0 && $__cycle == 0) {
                        my str $__new_bl = length($__bl) > 0 ? ($__bl . ":" . $full) : $full;
                        # Pass the module name explicitly. Without this the
                        # child perla re-derives the name from the file path,
                        # which is brittle for relative paths that don't
                        # contain `/lib/`: `Shipment/FedEx.pm` falls through
                        # to basename-only and emits
                        # `perla_mod_init_FedEx` instead of the correct
                        # `perla_mod_init_Shipment_FedEx`, breaking the link.
                        # Build PERLA5LIB from parent's lib_paths so the
                        # child perla -M can resolve modules from the same
                        # @INC. Without this, `use YAML;` in Abe::App.pm
                        # doesn't find /opt/bzperl/... and the child emits
                        # "YAML: NOT FOUND at compile time" — the resulting
                        # .pm.deps misses YAML.pm.o, and at runtime YAML
                        # isn't loaded → use-import is skipped → Abe::App::Load
                        # is undefined → config() returns undef → DBI fail.
                        my str $__plib = "";
                        if (defined($p->{"lib_paths"})) {
                            my int $__lpi = 0;
                            my scalar $__lps = $p->{"lib_paths"};
                            while ($__lpi < scalar(@{$__lps})) {
                                if (length($__plib) > 0) { $__plib = $__plib . ":"; }
                                $__plib = $__plib . $__lps->[$__lpi];
                                $__lpi++;
                            }
                        }
                        my str $__plib_env = "";
                        if (length($__plib) > 0) { $__plib_env = "PERLA5LIB=" . $__plib . " "; }
                        # Propagate the dep-handling mode to the spawned child.
                        # Without PERLA_PRECOMPILE_DEPS the child ran a plain
                        # `perla -M`, treated project-local lib/ as a non-tree,
                        # and INLINED every transitive bizowie/OHPA module's
                        # source into its own .pm.c — so Abe::App.pm.c ballooned
                        # to 21MB (3722 inlined subs) and gcc couldn't compile
                        # it in time/memory. Propagating it makes every module
                        # in the recursion reference + auto-build its deps.
                        if ($precompile_deps == 1) { $__plib_env = $__plib_env . "PERLA_PRECOMPILE_DEPS=1 "; }
                        if ($prefer_shared == 1) { $__plib_env = $__plib_env . "PERLA_SHARED=1 "; }
                        my str $cmd = $__plib_env . "PERLA_MODULE_NAME=" . $module . " PERLA_BUILDING_LIST=" . $__new_bl . " " . $perla_bin . " -M " . $full . " 2>&1";
                        _dbg("    spawn: " . $cmd);
                        core::qx($cmd);
                        if (core::file_exists($ocand) == 1 || core::file_exists($socand) == 1) {
                            _dbg("  " . $module . ": auto-build OK");
                            $found_path = $full;
                            last;
                        }
                        _dbg("  " . $module . ": auto-build failed - falling through to runtime require");
                        # Record the failure so sibling consumers in this build
                        # don't re-attempt the same doomed `perla -M` (see the
                        # .buildfail check above).
                        core::spew($full . ".buildfail", "");
                    }
                } else {
                    _dbg("  " . $module . ": cache MISS " . $full . " (no auto-build - narrow heuristic skipped)");
                }
                # Still nothing - skip, let runtime require handle it.
            } else {
                _dbg("  " . $module . ": source " . $full . " (non-tree, will inline)");
                $found_path = $full;
                last;
            }
        }
        $lpi++;
    }

    # Also try relative to current directory
    if ($found_path eq "") {
        if (core::file_exists($rel_path) == 1) {
            _dbg("  " . $module . ": found ./" . $rel_path . " (cwd)");
            $found_path = $rel_path;
        }
    }

    # Fallback: look for a *precompiled* .pm.o in Perl's @INC roots (cached
    # from `perl -V` on first miss). This lets programs pick up modules
    # precompiled with `perla -M` without pulling every .pm source into the
    # main compile - which would trigger transitive source parses that slow
    # compilation by an order of magnitude or worse.
    if ($found_path eq "") {
        my scalar $inc_cache = $p->{"inc_roots"};
        if (!defined($inc_cache)) {
            $inc_cache = [];
            my str $perl_binary = core::getenv("PERLA_PERL");
            if (length($perl_binary) == 0) { $perl_binary = "perl"; }
            my str $inc_cmd = $perl_binary . " -e 'print join(\":\", grep { !/^\\./ && -d $_ } @INC)' 2>/dev/null";
            _dbg("  probing " . $perl_binary . " @INC for fallback");
            my str $inc_out = trim(core::qx($inc_cmd));
            if (length($inc_out) > 0) {
                my array @inc_roots = split(":", $inc_out);
                my int $ri = 0;
                while ($ri < scalar(@inc_roots)) {
                    my str $rp = trim($inc_roots[$ri]);
                    if (length($rp) > 0) {
                        push(@{$inc_cache}, $rp);
                        _dbg("    @INC: " . $rp);
                    }
                    $ri++;
                }
            }
            $p->{"inc_roots"} = $inc_cache;
        }

        # Skip XS modules - their .pm.o init expects DynaLoader to dlopen
        # auto/<path>/<base>.so, and that bootstrap isn't wired up in Perla
        # (manifests as `Can't load '/auto//.so'` at runtime and aborts the
        # program). Detect by looking for a sibling auto/.../base.so in any
        # @INC root.
        my str $base_no_pm = substr($rel_path, 0, length($rel_path) - 3);
        my int $last_slash = 0 - 1;
        my int $ci = 0;
        my int $bnplen = length($base_no_pm);
        while ($ci < $bnplen) {
            if (substr($base_no_pm, $ci, 1) eq "/") { $last_slash = $ci; }
            $ci++;
        }
        my str $basename = $base_no_pm;
        if ($last_slash >= 0) {
            $basename = substr($base_no_pm, $last_slash + 1, $bnplen - $last_slash - 1);
        }
        my int $has_xs = 0;
        my int $xi = 0;
        while ($xi < scalar(@{$inc_cache})) {
            my str $xs_path = $inc_cache->[$xi] . "/auto/" . $base_no_pm . "/" . $basename . ".so";
            if (core::file_exists($xs_path) == 1) { $has_xs = 1; last; }
            $xi++;
        }

        if ($has_xs == 1) {
            _dbg("  " . $module . ": XS module detected - skipping (runtime require will handle)");
        }
        if ($has_xs == 0) {
            my int $ri2 = 0;
            while ($ri2 < scalar(@{$inc_cache})) {
                my str $candidate = $inc_cache->[$ri2] . "/" . $rel_path;
                my str $ocand = $candidate . ".o";
                my str $socand = $candidate . ".so";
                my int $oc_o_exists = core::file_exists($ocand);
                my int $oc_so_exists = core::file_exists($socand);
                # Freshness check: discard stale artifact older than .pm
                # source (mirrored from the auto-build path; see comment
                # there). Without this, edits to .pm in @INC dirs were
                # silently ignored — the prior-built .o/.so kept running.
                if ($oc_o_exists == 1 || $oc_so_exists == 1) {
                    if (core::file_exists($candidate) == 1) {
                        my int $oi_src_mtime = 0;
                        my int $oi_o_mtime = 0;
                        my int $oi_so_mtime = 0;
                        __C__ {
                            struct stat __oi_st;
                            char *__oi_sp = strada_to_str(candidate);
                            if (stat(__oi_sp, &__oi_st) == 0) { strada_decref(oi_src_mtime); oi_src_mtime = STRADA_MAKE_TAGGED_INT((int64_t)__oi_st.st_mtime); }
                            free(__oi_sp);
                            char *__oi_op = strada_to_str(ocand);
                            if (stat(__oi_op, &__oi_st) == 0) { strada_decref(oi_o_mtime); oi_o_mtime = STRADA_MAKE_TAGGED_INT((int64_t)__oi_st.st_mtime); }
                            free(__oi_op);
                            char *__oi_sop = strada_to_str(socand);
                            if (stat(__oi_sop, &__oi_st) == 0) { strada_decref(oi_so_mtime); oi_so_mtime = STRADA_MAKE_TAGGED_INT((int64_t)__oi_st.st_mtime); }
                            free(__oi_sop);
                        }
                        if ($oc_o_exists == 1 && $oi_o_mtime < $oi_src_mtime) {
                            _dbg("  " . $module . ": stale .pm.o (@INC path) — ignoring");
                            $oc_o_exists = 0;
                        }
                        if ($oc_so_exists == 1 && $oi_so_mtime < $oi_src_mtime) {
                            _dbg("  " . $module . ": stale .pm.so (@INC path) — ignoring");
                            $oc_so_exists = 0;
                        }
                    }
                }
                if ($oc_o_exists == 1 || $oc_so_exists == 1) {
                    my str $which2 = "";
                    if ($oc_o_exists == 1) { $which2 = ".pm.o"; }
                    else { $which2 = ".pm.so"; }
                    _dbg("  " . $module . ": cache HIT @INC " . $candidate . " [" . $which2 . "]");
                    $found_path = $candidate;
                    last;
                }
                $ri2++;
            }
            # DO NOT fall back to parsing .pm source from inc_roots.
            # That's too slow on large perl installs (transitively
            # parses Moose, DBIx::Class, etc). Modules not found as a
            # precompiled artifact here fall through to runtime
            # `require`, which compiles-on-demand via perla -M.
            # To precompile, run: `perla -M /path/to/Module.pm`
        }
    }

    if ($found_path eq "") {
        _dbg("  " . $module . ": NOT FOUND at compile time (runtime require will retry)");
        return undef;
    }

    # Canonicalize to an absolute path. If $found_path came from a
    # relative lib_path entry (e.g. ".") or the cwd-rel fallback below,
    # the .pm.o reference we emit into PERLA_LINK_OBJECTS would be
    # relative too — and the cc step often runs from a different cwd
    # (build dirs, --keep flows), causing `ld: cannot find ./X.pm.o`.
    # realpath also normalises the path-dedup key on the next line so
    # `./foo/X.pm` and `/abs/foo/X.pm` are treated as the same module.
    my str $abs_found = "" . core::realpath($found_path);
    if (length($abs_found) > 0) { $found_path = $abs_found; }

    # Path-based dedup: two different Perl module names can resolve to
    # the same file on disk when a search-path collision happens - e.g.
    # `perla -M /path/lib/Abe/Template.pm` puts `/path/lib/Abe/` in the
    # lib_paths, and then a later `use Template` (Template::Toolkit)
    # inside a dep chain lands back on /path/lib/Abe/Template.pm (since
    # Abe/ + Template.pm is a real file on that path). The name-keyed
    # loaded_modules hash doesn't catch this because the two loads use
    # different module names. Catch it here: track resolved paths too.
    if (!defined($p->{"loaded_paths"})) { $p->{"loaded_paths"} = {}; }
    if (exists($p->{"loaded_paths"}->{$found_path})) {
        _dbg("  " . $module . ": resolved to already-loaded path " . $found_path . " (skip)");
        return undef;
    }
    $p->{"loaded_paths"}->{$found_path} = 1;

    # Check for precompiled artifacts (.pm.o for static link,
    # .pm.so for dlopen under --shared). If either exists, emit a
    # N_PRECOMPILED_MOD node carrying both paths plus a use_shared
    # flag; CodeGen decides between direct-call+link vs dlopen+dlsym.
    my str $o_path = $found_path . ".o";
    my str $so_path = $found_path . ".so";
    my int $o_exists = core::file_exists($o_path);
    my int $so_exists = core::file_exists($so_path);
    # Freshness check: a stale .pm.o/.pm.so older than the .pm source
    # silently masked source edits — perla blindly dlopen()'d the stale
    # artifact and ran old compiled code, so warn/print/sub-body changes
    # never took effect. Compare mtimes and discard the stale artifact
    # so the auto-build / inline path picks up the new source.
    if ($o_exists == 1 || $so_exists == 1) {
        my int $src_mtime = 0;
        my int $o_mtime = 0;
        my int $so_mtime = 0;
        __C__ {
            struct stat __st;
            char *__sp = strada_to_str(found_path);
            if (stat(__sp, &__st) == 0) { strada_decref(src_mtime); src_mtime = STRADA_MAKE_TAGGED_INT((int64_t)__st.st_mtime); }
            free(__sp);
            char *__op = strada_to_str(o_path);
            if (stat(__op, &__st) == 0) { strada_decref(o_mtime); o_mtime = STRADA_MAKE_TAGGED_INT((int64_t)__st.st_mtime); }
            free(__op);
            char *__sop = strada_to_str(so_path);
            if (stat(__sop, &__st) == 0) { strada_decref(so_mtime); so_mtime = STRADA_MAKE_TAGGED_INT((int64_t)__st.st_mtime); }
            free(__sop);
        }
        if ($o_exists == 1 && $o_mtime < $src_mtime) {
            _dbg("  " . $module . ": stale .pm.o (mtime " . $o_mtime . " < src " . $src_mtime . ") — ignoring");
            $o_exists = 0;
        }
        if ($so_exists == 1 && $so_mtime < $src_mtime) {
            _dbg("  " . $module . ": stale .pm.so (mtime " . $so_mtime . " < src " . $src_mtime . ") — ignoring");
            $so_exists = 0;
        }
    }
    if ($o_exists == 1 || $so_exists == 1) {
        my int $use_shared = 0;
        # Prefer .pm.so when --shared is set and it exists; otherwise
        # use .pm.o when present; fall back to .pm.so if it's the
        # only artifact.
        if (core::getenv("PERLA_SHARED") eq "1" && $so_exists == 1) {
            $use_shared = 1;
        } elsif ($o_exists == 0 && $so_exists == 1) {
            $use_shared = 1;
        }
        if ($use_shared == 1) {
            _dbg("  " . $module . ": emit precompiled (.pm.so dlopen) " . $so_path);
        } else {
            _dbg("  " . $module . ": emit precompiled (.pm.o static) " . $o_path);
        }
        my scalar $node = Perla::AST::node(Perla::AST::N_PRECOMPILED_MOD());
        $node->{"module"} = $module;
        $node->{"o_path"} = $o_path;
        $node->{"so_path"} = $so_path;
        $node->{"use_shared"} = $use_shared;
        $node->{"init_func"} = "perla_mod_init_" . replace_all($module, "::", "_");
        my array @result = ();
        push(@result, $node);
        return \@result;
    }
    _dbg("  " . $module . ": parsing source " . $found_path);

    # Read and parse the module
    my str $source = core::slurp($found_path);
    if (length($source) == 0) { return undef; }

    my array @tokens = Perla::Lexer::lex($source);
    # Parse module with inherited lib paths, loaded-modules, AND
    # loaded-paths tracking so dedup catches file-identity collisions
    # across the whole recursion (see comment above).
    my scalar $mod_ast = Perla::Parser::parse_with_file_context_paths(@tokens, $p->{"lib_paths"}, $p->{"loaded_modules"}, $p->{"loaded_paths"}, $found_path);
    if (!defined($mod_ast)) { return undef; }

    # Return the module's statements (excluding the trailing 1;)
    my scalar $stmts = $mod_ast->{"stmts"};
    my array @result = ();
    my int $si = 0;
    while ($si < scalar(@{$stmts})) {
        my scalar $s = $stmts->[$si];
        if (defined($s)) {
            # Skip bare "1" return value at end of module
            if ($s->{"type"} == Perla::AST::N_INT_LIT() && $s->{"value"} eq "1") {
                $si++;
                next;
            }
            push(@result, $s);
        }
        $si++;
    }

    return \@result;
}

func _parse_begin(scalar $p) scalar {
    # INIT / CHECK / UNITCHECK lex to the BEGIN token type but keep their
    # original keyword as the token value. Record the phase so codegen can run
    # them in Perl's order (BEGIN source-order, CHECK reverse, INIT source-order)
    # rather than all-as-BEGIN in source order.
    my scalar $kw = _advance($p);
    my scalar $node = Perla::AST::node(Perla::AST::N_BEGIN());
    my str $ph = "BEGIN";
    if (defined($kw) && defined($kw->{"value"})) {
        my str $kwv = "" . $kw->{"value"};
        if ($kwv eq "INIT" || $kwv eq "CHECK" || $kwv eq "UNITCHECK") { $ph = $kwv; }
    }
    $node->{"phase"} = $ph;
    $node->{"body"} = _parse_block($p);
    return $node;
}

func _parse_end(scalar $p) scalar {
    _advance($p);
    my scalar $node = Perla::AST::node(Perla::AST::N_END());
    $node->{"body"} = _parse_block($p);
    return $node;
}

# --- Expression parsing (operator precedence climbing) ---
# Perl's real precedence (low → high, just for the bottom of the stack):
#   and   or   xor   (lowest binary)
#   not
#   ,  =>
#   list operators (rightward)
#   = += -= *= /= %= .= //= ||= &&=   (assignment)
#   ?:   ternary
#   ..   ...
#   ||   //
#   &&
#   ...
# `and/or/xor` are LOWER than `=` / `||=`, not higher - so
# `$flag and $Q ||= expr` parses as `$flag and ($Q ||= expr)`. Having
# them at the same level as `&&`/`||` made the left side an assignment
# target and produced "Can't modify non-lvalue in ||= assignment" at
# compile time (Type::Tiny line 379 was the first observed hit).
func _parse_expr(scalar $p) scalar {
    return _parse_low_or($p);
}

func _parse_low_or(scalar $p) scalar {
    my scalar $left = _parse_low_and($p);
    while (_peek_type($p) eq "OP" && (_peek_val($p) eq "or" || _peek_val($p) eq "xor")) {
        my str $op = _advance($p)->{"value"};
        my scalar $right = _parse_low_and($p);
        my scalar $node = Perla::AST::node(Perla::AST::N_BINOP());
        $node->{"op"} = $op;
        $node->{"left"} = $left;
        $node->{"right"} = $right;
        $left = $node;
    }
    return $left;
}

func _parse_low_and(scalar $p) scalar {
    my scalar $left = _parse_assign($p);
    while (_peek_type($p) eq "OP" && _peek_val($p) eq "and") {
        _advance($p);
        my scalar $right = _parse_assign($p);
        my scalar $node = Perla::AST::node(Perla::AST::N_BINOP());
        $node->{"op"} = "and";
        $node->{"left"} = $left;
        $node->{"right"} = $right;
        $left = $node;
    }
    return $left;
}

func _parse_assign(scalar $p) scalar {
    my scalar $left = _parse_ternary($p);
    if (_peek_type($p) eq "OP") {
        my str $op = _peek_val($p);
        if ($op eq "=" || $op eq "+=" || $op eq "-=" || $op eq "*=" ||
            $op eq "/=" || $op eq ".=" || $op eq "%=" || $op eq "//=" ||
            $op eq "||=" || $op eq "&&=" || $op eq "**=" ||
            $op eq "|=" || $op eq "&=" || $op eq "^=" ||
            $op eq "<<=" || $op eq ">>=" || $op eq "x=") {
            _advance($p);
            my scalar $right = _parse_assign($p);  # Right-associative
            my scalar $node = Perla::AST::node(Perla::AST::N_ASSIGN());
            $node->{"target"} = $left;
            $node->{"op"} = $op;
            $node->{"value"} = $right;
            return $node;
        }
    }
    return $left;
}

func _parse_ternary(scalar $p) scalar {
    my scalar $left = _parse_range($p);
    if (_peek_type($p) eq "OP" && _peek_val($p) eq "?") {
        _advance($p);
        my scalar $then = _parse_assign($p);
        _expect($p, "OP");  # :
        my scalar $else = _parse_assign($p);
        my scalar $node = Perla::AST::node(Perla::AST::N_TERNARY());
        $node->{"cond"} = $left;
        $node->{"then"} = $then;
        $node->{"else"} = $else;
        return $node;
    }
    return $left;
}

# Range / flip-flop `..` and `...` — Perl precedence-3, just below `?:` and
# ABOVE `||`/`&&`/comparison/`=~`. So its operands run through the full
# or → and → compare → … → add chain (`$n == 3 .. $n == 6` is
# `($n == 3) .. ($n == 6)`, and `$l =~ /A/ .. $l =~ /B/` likewise). It used
# to live in _parse_concat with _parse_add operands — far too tight, so any
# `..` with a comparison/match/logical operand mis-parsed (the flip-flop and
# range both silently broke). Non-associative: no chaining (`1..5..9`).
func _parse_range(scalar $p) scalar {
    my scalar $left = _parse_or($p);
    if (_peek_type($p) eq "OP" && (_peek_val($p) eq ".." || _peek_val($p) eq "...")) {
        my str $dots = _peek_val($p);
        _advance($p);
        my scalar $right = _parse_or($p);
        my scalar $node = Perla::AST::node(Perla::AST::N_RANGE());
        $node->{"from"} = $left;
        $node->{"to"} = $right;
        # "..." is the three-dot flip-flop: in scalar context it does NOT
        # test the right operand on the same evaluation the left turned it on
        # (unlike ".."). Recorded for the codegen.
        if ($dots eq "...") { $node->{"is_3dot"} = 1; } else { $node->{"is_3dot"} = 0; }
        return $node;
    }
    return $left;
}

func _parse_or(scalar $p) scalar {
    my scalar $left = _parse_and($p);
    while (_peek_type($p) eq "OP" && (_peek_val($p) eq "||" || _peek_val($p) eq "//")) {
        my str $op = _advance($p)->{"value"};
        my scalar $right = _parse_and($p);
        my scalar $node = Perla::AST::node(Perla::AST::N_BINOP());
        $node->{"op"} = $op;
        $node->{"left"} = $left;
        $node->{"right"} = $right;
        $left = $node;
    }
    return $left;
}

func _parse_and(scalar $p) scalar {
    my scalar $left = _parse_not($p);
    while (_peek_type($p) eq "OP" && _peek_val($p) eq "&&") {
        _advance($p);
        my scalar $right = _parse_not($p);
        my scalar $node = Perla::AST::node(Perla::AST::N_BINOP());
        $node->{"op"} = "&&";
        $node->{"left"} = $left;
        $node->{"right"} = $right;
        $left = $node;
    }
    return $left;
}

func _parse_not(scalar $p) scalar {
    # Only `not` (low-precedence Perl word op) handled here. `!` (high-
    # precedence unary) is parsed in _parse_unary so it binds tighter
    # than + - * / etc., matching Perl: `!X + Y` → `(!X) + Y`. Without
    # that, `!!"0" + 0` returned "" instead of 0 (parsed as
    # `!(!("0" + 0))` = `!(!0)` = `!(1)` = "").
    if (_peek_type($p) eq "OP" && _peek_val($p) eq "not") {
        my str $op = _advance($p)->{"value"};
        my scalar $operand = _parse_not($p);
        my scalar $node = Perla::AST::node(Perla::AST::N_UNOP());
        $node->{"op"} = $op;
        $node->{"operand"} = $operand;
        return $node;
    }
    # my $var = expr as an expression (used in: $x and my $y = ..., if (my $z = ...))
    if (_peek_type($p) eq "MY") {
        return _wrap_binding_lvalue($p, _parse_my_expr($p));
    }
    # our $var = expr as an expression — chained `our @A = our @B = LIST`.
    if (_peek_type($p) eq "OUR") {
        return _wrap_binding_lvalue($p, _parse_our_expr($p));
    }
    return _parse_compare($p);
}

# Parse the right-hand side of a binding op (=~ / !~): a substitution / match /
# tr / regex literal, else a general concat-level expression (for comparison
# ops). Shared by _parse_compare and the my/our binding-lvalue path so both
# handle `s///`, `m//`, `tr///`, `/re/` identically.
func _parse_match_rhs(scalar $p) scalar {
    my scalar $right = undef;
    if (_peek_type($p) eq "SUBST_PAT") {
        my str $pat = _advance($p)->{"value"};
        my str $repl = "";
        my str $flags = "";
        if (_peek_type($p) eq "SUBST_REPL") { $repl = _advance($p)->{"value"}; }
        if (_peek_type($p) eq "SUBST_FLAGS") { $flags = _advance($p)->{"value"}; }
        $right = Perla::AST::node(Perla::AST::N_SUBST());
        $right->{"pattern"} = $pat;
        $right->{"replacement"} = $repl;
        $right->{"flags"} = $flags;
    } elsif (_peek_type($p) eq "MATCH_PAT") {
        my str $pat = _advance($p)->{"value"};
        my str $flags = "";
        if (_peek_type($p) eq "MATCH_FLAGS") { $flags = _advance($p)->{"value"}; }
        $right = Perla::AST::node(Perla::AST::N_REGEX());
        $right->{"pattern"} = $pat;
        $right->{"flags"} = $flags;
    } elsif (_peek_type($p) eq "TR_FROM") {
        my str $from = _advance($p)->{"value"};
        my str $to = "";
        my str $tr_flags = "";
        if (_peek_type($p) eq "TR_TO") { $to = _advance($p)->{"value"}; }
        if (_peek_type($p) eq "TR_FLAGS") { $tr_flags = _advance($p)->{"value"}; }
        $right = Perla::AST::node(Perla::AST::N_TR());
        $right->{"from"} = $from;
        $right->{"to"} = $to;
        $right->{"flags"} = $tr_flags;
    } elsif (_peek_type($p) eq "OP" && _peek_val($p) eq "/") {
        $right = _parse_regex($p);
    } elsif (_peek_type($p) eq "IDENT" && _peek_val($p) eq "s") {
        $right = _parse_subst($p);
    } else {
        $right = _parse_concat($p);
    }
    return $right;
}

# After parsing a `my`/`our` declaration in expression position, consume any
# trailing binding op so `( our $AUTOLOAD =~ /::(\w+)$/ )` and
# `( my $x =~ /re/ )` parse — the declaration is the lvalue, `=~`/`!~` binds to
# it. Without this, _parse_assign returned the N_MY/N_OUR node directly,
# bypassing _parse_compare's =~ handling, and the enclosing `)` failed with
# "expected RPAREN, got OP '=~'" (Type::Tiny's AUTOLOAD, line 1540).
func _wrap_binding_lvalue(scalar $p, scalar $left) scalar {
    while (_peek_type($p) eq "OP" && (_peek_val($p) eq "=~" || _peek_val($p) eq "!~")) {
        my str $op = _advance($p)->{"value"};
        my scalar $right = _parse_match_rhs($p);
        my scalar $node = Perla::AST::node(Perla::AST::N_BINOP());
        $node->{"op"} = $op;
        $node->{"left"} = $left;
        $node->{"right"} = $right;
        $left = $node;
    }
    return $left;
}

func _parse_compare(scalar $p) scalar {
    my scalar $left = _parse_bitwise($p);
    # Loop to chain =~ / !~ left-associatively:
    # `$s =~ s/X//r =~ s/Y//r` parses as `($s =~ s/X//r) =~ s/Y//r`.
    # Without the loop, only the first =~ was consumed; the second was
    # left to be parsed as a separate statement (with implicit $_ LHS),
    # so the second transform never applied to the first's result.
    while (_peek_type($p) eq "OP") {
        my str $op = _peek_val($p);
        if ($op eq "==" || $op eq "!=" || $op eq "<" || $op eq ">" ||
            $op eq "<=" || $op eq ">=" || $op eq "<=>" ||
            $op eq "eq" || $op eq "ne" || $op eq "lt" || $op eq "gt" ||
            $op eq "le" || $op eq "ge" || $op eq "cmp" ||
            $op eq "=~" || $op eq "!~" || $op eq "~~") {
            _advance($p);
            # After =~ or !~, parse regex/subst/tr/concat RHS (shared helper).
            my scalar $right = _parse_match_rhs($p);
            # Perl 5.32+ chained comparison: at the same precedence tier,
            # `A op1 B op2 C` means `(A op1 B) && (B op2 C)` with B
            # evaluated once. We build an N_CHAIN_CMP node that the
            # codegen materialises as a statement-expression with one
            # captured StradaValue per operand. Same tier:
            #   tier 1 — relational: <, >, <=, >=, lt, gt, le, ge
            #   tier 2 — equality:    ==, !=, <=>, eq, ne, cmp
            #   tier 3 — binding:     =~, !~, ~~  (left-assoc, no chaining)
            my int $cur_tier = 2;
            if ($op eq "<" || $op eq ">" || $op eq "<=" || $op eq ">="
                || $op eq "lt" || $op eq "gt" || $op eq "le" || $op eq "ge") {
                $cur_tier = 1;
            } elsif ($op eq "=~" || $op eq "!~" || $op eq "~~") {
                $cur_tier = 3;
            }
            my int $is_chain = 0;
            if (defined($left->{"type"}) && $left->{"type"} == Perla::AST::N_CHAIN_CMP()
                && defined($left->{"tier"}) && $left->{"tier"} == $cur_tier) {
                $is_chain = 1;
            } elsif (defined($left->{"type"}) && $left->{"type"} == Perla::AST::N_BINOP()
                     && defined($left->{"op"}) && $cur_tier >= 1 && $cur_tier <= 2) {
                # Was the previous op a comparison of the same tier? Only
                # then promote the BINOP to a CHAIN. `$prev_tier` MUST start
                # at a non-comparison sentinel (0): an arithmetic/concat LHS
                # (`$x + $y == 6`, `$x % $y == 0`) is an N_BINOP too, and a
                # default tier of 2 would mis-promote it into the equality
                # chain — evaluating `($x op $y` truthy) && ($y == RHS)`
                # instead of `($x op $y) == RHS`. (It happened to read
                # correctly only when the middle operand coincided with the
                # RHS, e.g. `4 - 2 == 2`.)
                my int $prev_tier = 0;
                my str $prev_op = $left->{"op"};
                if ($prev_op eq "<" || $prev_op eq ">" || $prev_op eq "<=" || $prev_op eq ">="
                    || $prev_op eq "lt" || $prev_op eq "gt" || $prev_op eq "le" || $prev_op eq "ge") {
                    $prev_tier = 1;
                } elsif ($prev_op eq "==" || $prev_op eq "!=" || $prev_op eq "<=>"
                    || $prev_op eq "eq" || $prev_op eq "ne" || $prev_op eq "cmp") {
                    $prev_tier = 2;
                } elsif ($prev_op eq "=~" || $prev_op eq "!~" || $prev_op eq "~~") {
                    $prev_tier = 3;
                }
                if ($prev_tier == $cur_tier) {
                    # Promote `(A op1 B)` binop into a CHAIN with two
                    # operands and one op, then we'll append below.
                    my scalar $cn = Perla::AST::node(Perla::AST::N_CHAIN_CMP());
                    $cn->{"operands"} = [$left->{"left"}, $left->{"right"}];
                    $cn->{"ops"} = [$prev_op];
                    $cn->{"tier"} = $prev_tier;
                    $left = $cn;
                    $is_chain = 1;
                }
            }
            if ($is_chain == 1) {
                push(@{$left->{"operands"}}, $right);
                push(@{$left->{"ops"}}, $op);
            } else {
                my scalar $node = Perla::AST::node(Perla::AST::N_BINOP());
                $node->{"op"} = $op;
                $node->{"left"} = $left;
                $node->{"right"} = $right;
                $left = $node;
            }
            next;
        }
        last;
    }
    return $left;
}

func _parse_bitwise(scalar $p) scalar {
    my scalar $left = _parse_concat($p);
    while (_peek_type($p) eq "OP" && (_peek_val($p) eq "&" || _peek_val($p) eq "|" || _peek_val($p) eq "^" || _peek_val($p) eq "<<" || _peek_val($p) eq ">>")) {
        my str $op = _advance($p)->{"value"};
        my scalar $right = _parse_concat($p);
        my scalar $node = Perla::AST::node(Perla::AST::N_BINOP());
        $node->{"op"} = $op;
        $node->{"left"} = $left;
        $node->{"right"} = $right;
        $left = $node;
    }
    return $left;
}

func _parse_concat(scalar $p) scalar {
    # Pass-through level. `.` (string concat) lives in _parse_add (Perl
    # precedence-18, with `+`/`-`), and `..`/`...` (range/flip-flop) moved up
    # to _parse_range (precedence-3, below `?:`). Nothing binds here now, but
    # the tier is kept so _parse_bitwise's call site stays stable.
    return _parse_add($p);
}

func _parse_add(scalar $p) scalar {
    my scalar $left = _parse_mul($p);
    while (_peek_type($p) eq "OP" && (_peek_val($p) eq "+" || _peek_val($p) eq "-" || _peek_val($p) eq ".")) {
        my scalar $op_tok = _advance($p);
        my str $op = $op_tok->{"value"};
        # `$x . bareword` — a bareword RHS of string-concat, NOT followed by
        # `(`/`->`/`::`, is a STRING in Perl (`$M.import` is `$M . "import"`,
        # i.e. "Mo::import"), not a 0-arg sub call. perla otherwise parsed it as
        # a call and resolved the name via cross-package walking — so `$M.import`
        # called a random `CGI::import` (whichever package last defined `import`)
        # with no invocant and died. This is exactly Mo's `*{$M.import}=sub{...}`
        # / `$P.ISA` metaprogramming idiom. Only treat as a string when the
        # IDENT isn't a call/method/qualified name.
        if ($op eq "." && _peek_type($p) eq "IDENT") {
            my str $nt2 = "";
            if ($p->{"pos"} + 1 < $p->{"len"}) { $nt2 = $p->{"tokens"}->[$p->{"pos"} + 1]->{"type"}; }
            if ($nt2 ne "LPAREN" && $nt2 ne "ARROW" && $nt2 ne "PKG_SEP" && $nt2 ne "FAT_ARROW") {
                my scalar $bw_tok = _advance($p);
                my scalar $bw_str = Perla::AST::node(Perla::AST::N_STR_LIT());
                $bw_str->{"value"} = $bw_tok->{"value"};
                my scalar $bnode = Perla::AST::node(Perla::AST::N_BINOP());
                $bnode->{"op"} = $op;
                $bnode->{"left"} = $left;
                $bnode->{"right"} = $bw_str;
                if (defined($op_tok->{"line"})) { $bnode->{"line"} = $op_tok->{"line"}; }
                $left = $bnode;
                next;
            }
        }
        my scalar $right = _parse_mul($p);
        my scalar $node = Perla::AST::node(Perla::AST::N_BINOP());
        $node->{"op"} = $op;
        $node->{"left"} = $left;
        $node->{"right"} = $right;
        # Record the operator token's line so codegen can attach it to
        # warnings (`Argument %s isn't numeric in %s at FILE line N`).
        if (defined($op_tok->{"line"})) { $node->{"line"} = $op_tok->{"line"}; }
        $left = $node;
    }
    return $left;
}

func _parse_mul(scalar $p) scalar {
    my scalar $left = _parse_unary($p);
    while (_peek_type($p) eq "OP" && (_peek_val($p) eq "*" || _peek_val($p) eq "/"
            || _peek_val($p) eq "%" || _peek_val($p) eq "x")) {
        my scalar $op_tok = _advance($p);
        my str $op = $op_tok->{"value"};
        my scalar $right = _parse_unary($p);
        my scalar $node = Perla::AST::node(Perla::AST::N_BINOP());
        $node->{"op"} = $op;
        $node->{"left"} = $left;
        $node->{"right"} = $right;
        if (defined($op_tok->{"line"})) { $node->{"line"} = $op_tok->{"line"}; }
        $left = $node;
    }
    return $left;
}

# `**` (exponentiation) is right-associative AND binds tighter than
# unary minus in Perl. So `2 ** 3 ** 2` is `2 ** (3 ** 2)` = 512, and
# `-2 ** 2` is `-(2 ** 2)` = -4. _parse_unary calls _parse_pow for its
# primary path so the `**` runs before the unary minus wraps the result.
func _parse_pow(scalar $p) scalar {
    my scalar $left = _parse_postfix($p);
    if (_peek_type($p) eq "OP" && _peek_val($p) eq "**") {
        _advance($p);
        my scalar $right = _parse_unary($p);  # right-recursive (allows -X on RHS)
        my scalar $node = Perla::AST::node(Perla::AST::N_BINOP());
        $node->{"op"} = "**";
        $node->{"left"} = $left;
        $node->{"right"} = $right;
        return $node;
    }
    return $left;
}

func _parse_unary(scalar $p) scalar {
    if (_peek_type($p) eq "OP") {
        my str $op = _peek_val($p);
        # File test operators: -e, -f, -d, -r, -w, -x, -s, -z
        if ($op eq "-" && $p->{"pos"} + 1 < $p->{"len"}) {
            my scalar $next = $p->{"tokens"}->[$p->{"pos"} + 1];
            # Auto-quote `-and`/`-or`/`-not`/`-xor` for hash-key /
            # comma-list positions. These tokenize as OP (Perl
            # word-operator) but in `{ -and => ... }` Perl treats them
            # as bareword strings. SAC's WHERE syntax relies on this:
            # `{ -and => [ ... ] }` is a top-level AND group.
            my int $is_word_op = 0;
            if ($next->{"type"} eq "OP") {
                my str $nv = "" . $next->{"value"};
                if ($nv eq "and" || $nv eq "or" || $nv eq "not" || $nv eq "xor") {
                    $is_word_op = 1;
                }
            }
            if ($is_word_op == 1) {
                my int $after_pos2 = $p->{"pos"} + 2;
                if ($after_pos2 < $p->{"len"}) {
                    my scalar $after2 = $p->{"tokens"}->[$after_pos2];
                    my str $atype2 = $after2->{"type"};
                    if ($atype2 eq "FAT_ARROW" || $atype2 eq "COMMA"
                        || $atype2 eq "RBRACE" || $atype2 eq "RBRACKET"
                        || $atype2 eq "RPAREN" || $atype2 eq "SEMI"
                        || $atype2 eq "EOF") {
                        my str $word = "" . $next->{"value"};
                        _advance($p);
                        _advance($p);
                        my scalar $node = Perla::AST::node(Perla::AST::N_STR_LIT());
                        $node->{"value"} = "-" . $word;
                        return $node;
                    }
                }
            }
            # Some file-test letters (`x`, `s`) also tokenize as OP elsewhere
            # in the lexer (string-repeat / substitution); accept both IDENT
            # and OP here. Without the OP branch, \`-x \$f\` failed to parse
            # — \`x\` came in as OP and the unary parser fell through.
            if ($next->{"type"} eq "IDENT" || $next->{"type"} eq "OP") {
                my str $letter = $next->{"value"};
                # Only the single-letter file-test names; \`-x\`-as-file-test
                # must be followed by a whitespace+operand (already parsed
                # as separate tokens) so we don't accidentally swallow
                # \`-x =\`, \`-x ->\` etc. that aren't file tests.
                my int $is_filetest = 0;
                if (length($letter) == 1) {
                    # Full Perl file-test letter set. Missing letters
                    # (notably `t`, `M`, `A`, `C`, `o`, `O`, `p`, `S`,
                    # `b`, `c`, `u`, `g`, `k`) used to fall through and
                    # parse as `-name(...)` (negated function call),
                    # so `-t $fh ? "y" : "n"` became `-t($fh ? ... : ...)`.
                    if ($letter eq "e" || $letter eq "f" || $letter eq "d" ||
                        $letter eq "r" || $letter eq "w" || $letter eq "x" ||
                        $letter eq "s" || $letter eq "z" || $letter eq "l" ||
                        $letter eq "T" || $letter eq "B" || $letter eq "t" ||
                        $letter eq "M" || $letter eq "A" || $letter eq "C" ||
                        $letter eq "o" || $letter eq "O" || $letter eq "p" ||
                        $letter eq "S" || $letter eq "b" || $letter eq "c" ||
                        $letter eq "u" || $letter eq "g" || $letter eq "k" ||
                        $letter eq "R" || $letter eq "W" || $letter eq "X") {
                        $is_filetest = 1;
                    }
                }
                if ($is_filetest == 1) {
                    _advance($p);  # consume -
                    _advance($p);  # consume letter
                    # File tests with no operand default to $_ (perl's
                    # named-unary-op convention). Detect by peeking: if the
                    # next token is a statement / list terminator OR a
                    # binary operator, plug $_ in as the operand instead of
                    # attempting to parse one. Without this, `-f && /\.pl$/`
                    # inside File::Find's callback (bare `-f` meaning -f $_)
                    # returned 0.
                    my str $ntype = _peek_type($p);
                    my int $defaults_to_underscore = 0;
                    if ($ntype eq "SEMI" || $ntype eq "COMMA" || $ntype eq "RPAREN"
                        || $ntype eq "RBRACE" || $ntype eq "RBRACKET" || $ntype eq "EOF"
                        || $ntype eq "AND" || $ntype eq "OR" || $ntype eq "QUESTION"
                        || $ntype eq "FAT_ARROW" || $ntype eq "COLON") {
                        $defaults_to_underscore = 1;
                    } elsif ($ntype eq "OP") {
                        # Check op value — terminators include `?`, `:`, `&&`,
                        # `||`, `//`, `..`, `cmp`, `eq`, `ne`, `lt`, etc.,
                        # but NOT unary `-`/`+`/`!`/`~`/`\` which can start a
                        # new operand.
                        my str $nval = "" . _peek_val($p);
                        if ($nval ne "-" && $nval ne "+" && $nval ne "!"
                            && $nval ne "~" && $nval ne "\\") {
                            $defaults_to_underscore = 1;
                        }
                    }
                    my scalar $operand;
                    if ($defaults_to_underscore == 1) {
                        $operand = Perla::AST::node_with(Perla::AST::N_SCALAR_VAR(), "name", "_");
                    } else {
                        # File tests are named-unary ops in Perl: they bind
                        # one TERM (postfix-level), not a full expression.
                        # `-t $fh ? "y" : "n"` must parse as `(-t $fh) ? ...`,
                        # not `-t ($fh ? ... : ...)`. _parse_unary recursed
                        # too deep and absorbed the ternary; _parse_postfix
                        # stops at postfix-level (primary + ->/[]/{}/. chain).
                        $operand = _parse_postfix($p);
                    }
                    my scalar $node = Perla::AST::node(Perla::AST::N_UNOP());
                    $node->{"op"} = "-" . $letter;
                    $node->{"operand"} = $operand;
                    return $node;
                }
                # Negative bareword auto-quoting: `-result_source` (where
                # result_source isn't a known sub call shape) becomes the
                # string "-result_source". Real Perl does this for hash
                # keys and `=>` LHS — DBIC's `-result_source => $rsrc`
                # construction relies on it. Skip if the next-next token
                # is `(` (sub call) or `::` (qualified name).
                my int $after_pos = $p->{"pos"} + 2;
                my int $skip = 0;
                if ($after_pos < $p->{"len"}) {
                    my scalar $after = $p->{"tokens"}->[$after_pos];
                    my str $atype = $after->{"type"};
                    my str $aval = "" . $after->{"value"};
                    if ($atype eq "LPAREN") { $skip = 1; }
                    if ($atype eq "OP" && ($aval eq "::" || $aval eq "->")) { $skip = 1; }
                    # Don't auto-quote inside arithmetic context — e.g.
                    # `5 - foo` should still be `5 - foo()`. Only auto-quote
                    # when the next-next token is `=>`, `,`, `}`, `]`, `)`,
                    # `;`, `||`, `or` — typical end-of-expr in hash/list
                    # contexts where Perl applies the rule.
                    my int $is_term_pos = 0;
                    if ($atype eq "FAT_ARROW" || $atype eq "COMMA"
                        || $atype eq "RBRACE" || $atype eq "RBRACKET"
                        || $atype eq "RPAREN" || $atype eq "SEMI"
                        || $atype eq "EOF") {
                        $is_term_pos = 1;
                    }
                    if ($is_term_pos == 0) { $skip = 1; }
                }
                if ($skip == 0) {
                    _advance($p);  # consume -
                    _advance($p);  # consume identifier
                    my scalar $node = Perla::AST::node(Perla::AST::N_STR_LIT());
                    $node->{"value"} = "-" . $letter;
                    return $node;
                }
            }
        }
        if ($op eq "-" || $op eq "+" || $op eq "~" || $op eq "!") {
            _advance($p);
            my scalar $operand = _parse_unary($p);
            my scalar $node = Perla::AST::node(Perla::AST::N_UNOP());
            $node->{"op"} = $op;
            $node->{"operand"} = $operand;
            return $node;
        }
    }
    if (_peek_type($p) eq "BACKSLASH") {
        _advance($p);
        # `\my $x` / `\my @arr` / `\my %h` — take a ref of a freshly-
        # declared lexical. The expression-form `_parse_my_expr` skips
        # the trailing-semicolon match that the statement-form
        # `_parse_my` does, so we can use it inline.
        if (_peek_type($p) eq "MY") {
            my scalar $my_node = _parse_my_expr($p);
            my scalar $node = Perla::AST::node(Perla::AST::N_REF());
            $node->{"operand"} = $my_node;
            return $node;
        }
        # Recurse into _parse_unary so a stacked `\\$x` (ref-to-ref)
        # picks up the inner backslash as another N_REF instead of
        # parsing the bare $x and dropping the inner ref. Without this,
        # `\\$x` compiled to `ref_create(undef)` + a useless $x stmt
        # (and `ref(\\$x)` returned "SCALAR" instead of "REF").
        my scalar $operand = _parse_unary($p);
        my scalar $node = Perla::AST::node(Perla::AST::N_REF());
        $node->{"operand"} = $operand;
        return $node;
    }
    return _parse_pow($p);
}

# Parse regex /pattern/flags after =~ or !~
func _parse_regex(scalar $p) scalar {
    _advance($p);  # consume opening /
    my str $pattern = "";
    # Collect tokens until we see / as an OP
    while (!_at_end($p)) {
        if (_peek_type($p) eq "OP" && _peek_val($p) eq "/") {
            _advance($p);  # consume closing /
            # Check for flags (i, g, m, s, x)
            my str $flags = "";
            while (!_at_end($p) && _peek_type($p) eq "IDENT") {
                my str $flag = _peek_val($p);
                if ($flag eq "i" || $flag eq "g" || $flag eq "m" || $flag eq "s" || $flag eq "x" || $flag eq "o" || $flag eq "e" || $flag eq "p") {
                    $flags = $flags . $flag;
                    _advance($p);
                } else {
                    last;
                }
            }
            my scalar $node = Perla::AST::node(Perla::AST::N_REGEX());
            $node->{"pattern"} = $pattern;
            $node->{"flags"} = $flags;
            return $node;
        }
        # Accumulate token value as pattern text
        my scalar $tok = _advance($p);
        $pattern = $pattern . $tok->{"value"};
    }
    # Unterminated regex - return what we have
    my scalar $node = Perla::AST::node(Perla::AST::N_REGEX());
    $node->{"pattern"} = $pattern;
    $node->{"flags"} = "";
    return $node;
}

# Parse s/pattern/replacement/flags
func _parse_subst(scalar $p) scalar {
    _advance($p);  # consume 's'
    # Expect /
    if (_peek_type($p) ne "OP" || _peek_val($p) ne "/") {
        return Perla::AST::node(Perla::AST::N_UNDEF());
    }
    _advance($p);  # consume opening /

    # Read pattern
    my str $pattern = "";
    my int $empty_replacement = 0;
    while (!_at_end($p)) {
        if (_peek_type($p) eq "OP" && _peek_val($p) eq "/") {
            _advance($p);  # consume middle /
            last;
        }
        # Handle // as empty replacement (middle + closing delimiter)
        if (_peek_type($p) eq "OP" && _peek_val($p) eq "//") {
            _advance($p);  # consume //
            $empty_replacement = 1;
            last;
        }
        my scalar $tok = _advance($p);
        $pattern = $pattern . $tok->{"value"};
    }

    # Read replacement (unless already consumed by //)
    my str $replacement = "";
    if ($empty_replacement == 0) {
        while (!_at_end($p)) {
            if (_peek_type($p) eq "OP" && _peek_val($p) eq "/") {
                _advance($p);  # consume closing /
                last;
            }
            # Handle // at end of replacement
            if (_peek_type($p) eq "OP" && _peek_val($p) eq "//") {
                _advance($p);
                last;
            }
            my scalar $tok = _advance($p);
            $replacement = $replacement . $tok->{"value"};
        }
    }

    # Read flags
    my str $flags = "";
    while (!_at_end($p) && _peek_type($p) eq "IDENT") {
        my str $f = _peek_val($p);
        if ($f eq "g" || $f eq "i" || $f eq "m" || $f eq "s" || $f eq "x" || $f eq "e" || $f eq "o" || $f eq "p") {
            $flags = $flags . $f;
            _advance($p);
        } else {
            last;
        }
    }

    my scalar $node = Perla::AST::node(Perla::AST::N_SUBST());
    $node->{"pattern"} = $pattern;
    $node->{"replacement"} = $replacement;
    $node->{"flags"} = $flags;
    return $node;
}

# Parse hash key - barewords become string literals
func _parse_hash_key(scalar $p) scalar {
    # If we see IDENT or keyword followed by }, treat as bareword string
    my str $kt = _peek_type($p);
    if ($kt eq "IDENT" || $kt eq "NEXT" || $kt eq "LAST" || $kt eq "FOR" || $kt eq "FOREACH" ||
        $kt eq "WHILE" || $kt eq "UNTIL" || $kt eq "IF" || $kt eq "UNLESS" || $kt eq "DO" ||
        $kt eq "MY" || $kt eq "OUR" || $kt eq "LOCAL" || $kt eq "RETURN" || $kt eq "SUB" ||
        $kt eq "PACKAGE" || $kt eq "USE" || $kt eq "BEGIN" || $kt eq "END" || $kt eq "GIVEN" ||
        $kt eq "WHEN" || $kt eq "DEFAULT" || $kt eq "REDO" ||
        $kt eq "SORT" || $kt eq "MAP" || $kt eq "GREP" || $kt eq "SPLIT" ||
        $kt eq "PUSH" || $kt eq "POP" || $kt eq "SHIFT" || $kt eq "UNDEF" ||
        $kt eq "DELETE" || $kt eq "EXISTS" || $kt eq "DEFINED" || $kt eq "EVAL" ||
        $kt eq "DIE" || $kt eq "PRINT" || $kt eq "SAY" || $kt eq "WARN" || $kt eq "CHOMP" ||
        $kt eq "ELSE" || $kt eq "ELSIF" ||
        # Perl built-ins that the lexer turns into special tokens but
        # that are still valid bareword hash keys when followed by `}`.
        # Without this, `$h->{keys}` lost the key (the parser tried to
        # parse `keys}` as a function call), broke push/delete/exists
        # autoviv chains in Amazon::S3 line 212 and similar idioms.
        $kt eq "KEYS" || $kt eq "VALUES" || $kt eq "EACH" ||
        $kt eq "LENGTH" || $kt eq "SCALAR" || $kt eq "REF" ||
        $kt eq "REVERSE" || $kt eq "JOIN" || $kt eq "SPRINTF" ||
        $kt eq "WANTARRAY" || $kt eq "CALLER") {
        my int $save_pos = $p->{"pos"};
        my scalar $tok = _advance($p);
        if (_peek_type($p) eq "RBRACE") {
            return Perla::AST::node_with(Perla::AST::N_STR_LIT(), "value", $tok->{"value"});
        }
        # Not a simple bareword - backtrack and parse as expression
        $p->{"pos"} = $save_pos;
    }
    # Handle `x` as bareword hash key (it's the repeat operator token).
    # Without the type guard, `\$h{\$x}` matched here because the lexer
    # tokenizes the SCALAR_VAR `\$x` with value "x" — and we'd then
    # advance past it, see `}`, and return literal key "x" instead of
    # looking up by the value of \$x.
    my str $kt_x = _peek_type($p);
    if (_peek_val($p) eq "x" && ($kt_x eq "IDENT" || $kt_x eq "OP")) {
        my int $save_pos = $p->{"pos"};
        my scalar $tok = _advance($p);
        if (_peek_type($p) eq "RBRACE") {
            return Perla::AST::node_with(Perla::AST::N_STR_LIT(), "value", "x");
        }
        $p->{"pos"} = $save_pos;
    }
    # Word-operator barewords as hash keys: eq, ne, lt, gt, le, ge, cmp,
    # and, or, xor, not. These all lex as type=OP, so the keyword loop
    # above misses them and the expression parser would treat them as
    # binary operators. Mirror the x handling.
    if ($kt_x eq "OP") {
        my str $opv = _peek_val($p);
        if ($opv eq "eq" || $opv eq "ne" || $opv eq "lt" || $opv eq "gt"
            || $opv eq "le" || $opv eq "ge" || $opv eq "cmp"
            || $opv eq "and" || $opv eq "or" || $opv eq "xor" || $opv eq "not") {
            my int $save_pos = $p->{"pos"};
            _advance($p);
            if (_peek_type($p) eq "RBRACE") {
                return Perla::AST::node_with(Perla::AST::N_STR_LIT(), "value", $opv);
            }
            $p->{"pos"} = $save_pos;
        }
    }
    my scalar $key = _parse_expr($p);
    # Multi-key hash subscript: $h{$a, $b} is Perl idiom for
    # $h{join($;, $a, $b)}. Default $; is "\x1C". Build a concat
    # chain with the runtime $; between each key expression so
    # `local $; = "|"` etc. work. Without this, the parser errors
    # at the comma with "expected RBRACE, got COMMA", and recovery
    # injects the remainder of the enclosing sub body into module
    # init. (Seen in File::Find.pm `$SLnkSeen{$DEV, $INO}++`.)
    if (_peek_type($p) eq "COMMA") {
        my scalar $concat = $key;
        while (_peek_type($p) eq "COMMA") {
            _advance($p);
            if (_peek_type($p) eq "RBRACE") { last; }
            # Append $; (runtime perla_subsep) then next expr.
            # N_SCALAR_VAR name=";" → perla_subsep at codegen time
            # (see the special-name handler in CodeGen.strada).
            my scalar $subsep_node = Perla::AST::node_with(
                Perla::AST::N_SCALAR_VAR(), "name", ";");
            my scalar $sep = Perla::AST::node(Perla::AST::N_BINOP());
            $sep->{"op"} = ".";
            $sep->{"left"} = $concat;
            $sep->{"right"} = $subsep_node;
            my scalar $next = _parse_expr($p);
            my scalar $join = Perla::AST::node(Perla::AST::N_BINOP());
            $join->{"op"} = ".";
            $join->{"left"} = $sep;
            $join->{"right"} = $next;
            $concat = $join;
        }
        return $concat;
    }
    return $key;
}

# Parse the LIST that follows a sort comparator (named sub or coderef),
# collecting a bare comma-separated list into a flat N_ANON_ARRAY exactly
# like the block form (`sort { } 3, 1, 2`) does. Without this, the no-paren
# comparator forms (`sort $cmp 3, 1, 2`, `sort byname 3, 1, 2`) parsed only
# the first element as the list and the rest leaked to the enclosing call.
func _parse_sort_list(scalar $p) scalar {
    my scalar $first_l = _parse_expr($p);
    if (_peek_type($p) ne "COMMA") { return $first_l; }
    my scalar $ll = Perla::AST::node(Perla::AST::N_ANON_ARRAY());
    $ll->{"elems"} = [$first_l];
    $ll->{"is_ref"} = 0;
    while (_peek_type($p) eq "COMMA") {
        _advance($p);
        # Trailing comma before a closing delimiter (incl. RBRACKET/RBRACE)
        # terminates the list — `[ sort @l, ]` must not _parse_expr the `]`.
        if (_peek_type($p) eq "RPAREN" || _peek_type($p) eq "RBRACKET"
            || _peek_type($p) eq "RBRACE" || _peek_type($p) eq "SEMI"
            || _at_end($p)) { last; }
        push(@{$ll->{"elems"}}, _parse_expr($p));
    }
    return $ll;
}

func _parse_postfix(scalar $p) scalar {
    my scalar $left = _parse_primary($p);

    while (1) {
        # ->method(), ->{key}, ->[idx]
        if (_peek_type($p) eq "ARROW") {
            _advance($p);
            # $ref->(args) - code reference call
            if (_peek_type($p) eq "LPAREN") {
                _advance($p);
                my scalar $node = Perla::AST::node(Perla::AST::N_CALL());
                $node->{"name"} = "__coderef__";
                $node->{"coderef"} = $left;
                $node->{"args"} = [];
                while (_peek_type($p) ne "RPAREN" && !_at_end($p)) {
                    push(@{$node->{"args"}}, _parse_assign($p));
                    if (_peek_type($p) eq "COMMA" || _peek_type($p) eq "FAT_ARROW") {
                        _advance($p);
                    }
                }
                _expect($p, "RPAREN");
                $left = $node;
            } elsif (_is_method_name_token($p) == 1) {
                # Check if method is a variable ($obj->$method) before consuming token
                my int $is_dynamic = 0;
                if (_peek_type($p) eq "SCALAR_VAR") { $is_dynamic = 1; }
                my str $method = _advance($p)->{"value"};
                if (substr($method, 0, 1) eq "$") {
                    $method = substr($method, 1, length($method) - 1);
                    $is_dynamic = 1;
                }
                my scalar $node = Perla::AST::node(Perla::AST::N_METHOD());
                $node->{"object"} = $left;
                $node->{"method"} = $method;
                if ($is_dynamic == 1) { $node->{"dynamic_method"} = 1; }
                $node->{"args"} = [];
                if (_peek_type($p) eq "LPAREN") {
                    _advance($p);
                    while (_peek_type($p) ne "RPAREN" && !_at_end($p)) {
                        push(@{$node->{"args"}}, _parse_assign($p));
                        if (_peek_type($p) eq "COMMA" || _peek_type($p) eq "FAT_ARROW") {
                            _advance($p);
                        }
                    }
                    _expect($p, "RPAREN");
                }
                # `$class->load_components(qw/A +Full::B/)` — DBIx::Class /
                # Class::C3::Componentised loads these component modules at
                # RUNTIME (via inject_base into @ISA), which the static dep
                # scan misses, so their inherited methods (`table`,
                # `has_column`, …) are never compiled/linked and dispatch dies
                # "Can't locate object method". Force-build each component like
                # `use base` does: bare names get the DBIx::Class:: base
                # (nonexistent files no-op in _load_module); `+`-prefixed names
                # are used verbatim.
                if ($method eq "load_components" || $method eq "load_own_components") {
                    _load_components_deps($p, $node->{"args"});
                }
                $left = $node;
            } elsif (_peek_type($p) eq "LBRACE") {
                _advance($p);
                my scalar $key = _parse_hash_key($p);
                _expect($p, "RBRACE");
                my scalar $node = Perla::AST::node(Perla::AST::N_ARROW_HASH());
                $node->{"object"} = $left;
                $node->{"key"} = $key;
                # Mark this as the explicit `->{key}` arrow form, mirroring
                # N_ARROW_ARRAY below. Without the flag, the codegen's
                # mangle-collision routing for `$X{k}` (no-arrow) leaks into
                # `$X->{k}` (explicit deref) when `@X` or `%X` also appears
                # in the file, so the scalar-deref read ends up at the wrong
                # C var (e.g. v_data__h instead of v_data).
                $node->{"is_explicit_arrow"} = 1;
                $left = $node;
            } elsif (_peek_type($p) eq "LBRACKET") {
                _advance($p);
                my scalar $idx = _parse_expr($p);
                _expect($p, "RBRACKET");
                my scalar $node = Perla::AST::node(Perla::AST::N_ARROW_ARRAY());
                $node->{"object"} = $left;
                $node->{"index"} = $idx;
                # Mark this as the explicit `->[idx]` arrow form. Without
                # this flag the codegen can't distinguish from the bare
                # `$arr[idx]` form (which reads from @arr) and would also
                # auto-route SCALAR_VAR derefs through the @-sigil C var,
                # so `$same->[0]` reads the wrong array when both `$same`
                # and `@same` exist. Required for SAC/DBIC's
                # `_resolve_bindattrs`'s `map { ... $_->[1] ... }` to
                # correctly deref the [col, val] tuple.
                $node->{"is_explicit_arrow"} = 1;
                $left = $node;
            } elsif (_peek_type($p) eq "POSTFIX_DEREF_ARRAY") {
                # `$ref->@*` — equivalent to `@{$ref}`.
                _advance($p);
                my scalar $node = Perla::AST::node(Perla::AST::N_DEREF_ARRAY());
                $node->{"ref"} = $left;
                $left = $node;
            } elsif (_peek_type($p) eq "POSTFIX_ASLICE_LB") {
                # `$ref->@[i, j, k]` — equivalent to `@{$ref}[i, j, k]`,
                # an array slice of the deref'd array.
                _advance($p);  # consume `@[`
                my scalar $slice = Perla::AST::node(Perla::AST::N_ARRAY_SLICE());
                my scalar $aref = Perla::AST::node(Perla::AST::N_DEREF_ARRAY());
                $aref->{"ref"} = $left;
                $slice->{"array"} = $aref;
                $slice->{"indices"} = [];
                while (_peek_type($p) ne "RBRACKET" && !_at_end($p)) {
                    push(@{$slice->{"indices"}}, _parse_assign($p));
                    if (_peek_type($p) eq "COMMA") { _advance($p); }
                }
                _expect($p, "RBRACKET");
                $left = $slice;
            } elsif (_peek_type($p) eq "POSTFIX_HSLICE_LB") {
                # `$ref->@{a, b}` — hash slice of the deref'd hash.
                _advance($p);  # consume `@{`
                my scalar $slice = Perla::AST::node(Perla::AST::N_HASH_SLICE());
                $slice->{"hash"} = $left;
                $slice->{"hash_is_ref"} = 1;
                $slice->{"keys_list"} = [];
                while (_peek_type($p) ne "RBRACE" && !_at_end($p)) {
                    push(@{$slice->{"keys_list"}}, _parse_assign($p));
                    if (_peek_type($p) eq "COMMA" || _peek_type($p) eq "FAT_ARROW") { _advance($p); }
                }
                _expect($p, "RBRACE");
                $left = $slice;
            } elsif (_peek_type($p) eq "POSTFIX_DEREF_HASH") {
                # `$ref->%*` — equivalent to `%{$ref}`.
                _advance($p);
                my scalar $node = Perla::AST::node(Perla::AST::N_DEREF_HASH());
                $node->{"ref"} = $left;
                $left = $node;
            } elsif (_peek_type($p) eq "POSTFIX_DEREF_SCALAR") {
                # `$ref->$*` — equivalent to `${$ref}`.
                _advance($p);
                my scalar $node = Perla::AST::node(Perla::AST::N_DEREF_SCALAR());
                $node->{"ref"} = $left;
                $left = $node;
            } elsif (_peek_type($p) eq "POSTFIX_DEREF_LASTIDX") {
                # `$ref->$#*` — last index of the deref'd array, i.e.
                # `$#{$ref}`. Lower to `scalar(@{$ref}) - 1` like the
                # braced `$#{ EXPR }` form does.
                _advance($p);
                my scalar $deref = Perla::AST::node(Perla::AST::N_DEREF_ARRAY());
                $deref->{"ref"} = $left;
                my scalar $size_call = Perla::AST::node(Perla::AST::N_CALL());
                $size_call->{"name"} = "scalar";
                $size_call->{"args"} = [$deref];
                my scalar $minus = Perla::AST::node(Perla::AST::N_BINOP());
                $minus->{"op"} = "-";
                $minus->{"left"} = $size_call;
                $minus->{"right"} = Perla::AST::node_with(Perla::AST::N_INT_LIT(), "value", "1");
                $left = $minus;
            } elsif (_peek_type($p) eq "DEREF_SCALAR_START") {
                # $obj->${ EXPR }( args ) - dynamic method dispatch via a
                # scalar reference. The braced EXPR evaluates to a scalar
                # ref whose deref is the method name. Seen in
                # DBIx::Class::Row.pm:883 and various metaprogramming idioms.
                # Lower to the same N_METHOD + dynamic_method form used by
                # $obj->$var, with the method-name expression captured
                # separately so codegen can strada_to_str it at runtime.
                _advance($p);  # consume ${
                my scalar $mexpr = _parse_expr($p);
                _expect($p, "RBRACE");
                # If the inner expression is a scalar ref (\EXPR), strip the
                # ref: $obj->${ \EXPR }(...) is equivalent to $obj->$name(...)
                # where $name = EXPR, because \EXPR creates a ref and ${...}
                # derefs it. Skipping the round-trip keeps codegen simple.
                if (defined($mexpr) && $mexpr->{"type"} == Perla::AST::N_REF()) {
                    $mexpr = $mexpr->{"operand"};
                }
                my scalar $node = Perla::AST::node(Perla::AST::N_METHOD());
                $node->{"object"} = $left;
                $node->{"method"} = "";
                $node->{"dynamic_method"} = 1;
                $node->{"method_expr"} = $mexpr;
                $node->{"args"} = [];
                if (_peek_type($p) eq "LPAREN") {
                    _advance($p);
                    while (_peek_type($p) ne "RPAREN" && !_at_end($p)) {
                        push(@{$node->{"args"}}, _parse_assign($p));
                        if (_peek_type($p) eq "COMMA" || _peek_type($p) eq "FAT_ARROW") {
                            _advance($p);
                        }
                    }
                    _expect($p, "RPAREN");
                }
                $left = $node;
            } else {
                last;
            }
        }
        # $hash{key} or $ref->{a}{b} (implied arrow between adjacent subscripts)
        # N_ARRAY_SLICE allowed too — `(LIST)[N]{key}` is a common idiom for
        # extracting a hashref from a list and immediately drilling into it.
        elsif (_peek_type($p) eq "LBRACE" && ($left->{"type"} == Perla::AST::N_SCALAR_VAR() || $left->{"type"} == Perla::AST::N_ARROW_HASH() || $left->{"type"} == Perla::AST::N_ARROW_ARRAY() || $left->{"type"} == Perla::AST::N_HASH_ELEM() || $left->{"type"} == Perla::AST::N_ARRAY_ELEM() || $left->{"type"} == Perla::AST::N_DEREF_ARRAY() || $left->{"type"} == Perla::AST::N_DEREF_SCALAR() || $left->{"type"} == Perla::AST::N_ARRAY_SLICE())) {
            # `@{EXPR}{KEYS}` is a hash slice in Perl (the `@` sigil on
            # the deref means "slice"), not single-element access. Force
            # N_HASH_SLICE for N_DEREF_ARRAY LHS so `@{$attrs}{qw(a b c)}`
            # returns a list of values (not undef from a non-existent
            # `{qw(a b c)}` arrow access). Surfaced via DBIC's
            # `_select_args` returning `('select', @{$attrs}{qw(from select where)}, $attrs, ...)`
            # — the slice was producing one undef instead of three values
            # so $ident reached the SQL maker as undef, and SAC died with
            # "no dispatch entry for UNDEF".
            if ($left->{"type"} == Perla::AST::N_DEREF_ARRAY()) {
                _advance($p);
                my scalar $node = Perla::AST::node(Perla::AST::N_HASH_SLICE());
                $node->{"hash"} = $left;
                $node->{"hash_is_ref"} = 1;
                $node->{"keys_list"} = [];
                while (_peek_type($p) ne "RBRACE" && !_at_end($p)) {
                    push(@{$node->{"keys_list"}}, _parse_assign($p));
                    if (_peek_type($p) eq "COMMA" || _peek_type($p) eq "FAT_ARROW") { _advance($p); }
                }
                _expect($p, "RBRACE");
                $left = $node;
            } elsif ($left->{"type"} == Perla::AST::N_SCALAR_VAR()) {
                # First subscript on a plain `$name` is a HASH ELEMENT of
                # `%name` (`$h{k}`), NOT an arrow deref of `$name`. The
                # primary parser builds N_HASH_ELEM for top-level `$h{k}`,
                # but expression contexts that reach this postfix loop (e.g.
                # `@{ $h{k} }`) were producing N_ARROW_HASH, so codegen treated
                # `$h` as a scalar hashref and strict 'vars' rejected it.
                _advance($p);
                my scalar $key = _parse_hash_key($p);
                _expect($p, "RBRACE");
                my scalar $node = Perla::AST::node(Perla::AST::N_HASH_ELEM());
                $node->{"hash"} = $left;
                $node->{"key"} = $key;
                $left = $node;
            } else {
                _advance($p);
                my scalar $key = _parse_hash_key($p);
                _expect($p, "RBRACE");
                # Chained access (`$h{a}{b}`, `$ref->{a}{b}`) — the second and
                # later subscripts are implied-arrow hash derefs.
                my scalar $node = Perla::AST::node(Perla::AST::N_ARROW_HASH());
                $node->{"object"} = $left;
                $node->{"key"} = $key;
                $left = $node;
            }
        }
        # $arr[idx] or $ref->{a}[0] (implied arrow) or @$ref[idx] or (expr)[idx] (list slice).
        # Also (EXPR =~ /pat/)[0] — regex match in list context returns
        # captures, and perla's parser used to bail with "expected RPAREN
        # got LBRACKET" because N_BINOP wasn't in the allowed-LHS list.
        # This blocked JSON::backportPP::value_to_json from parsing as a
        # sub (parsing died mid-body, so its body code was emitted at
        # module init level and the encode_error fired during JSON load).
        elsif (_peek_type($p) eq "LBRACKET" && ($left->{"type"} == Perla::AST::N_SCALAR_VAR() || $left->{"type"} == Perla::AST::N_ARROW_HASH() || $left->{"type"} == Perla::AST::N_ARROW_ARRAY() || $left->{"type"} == Perla::AST::N_HASH_ELEM() || $left->{"type"} == Perla::AST::N_ARRAY_ELEM() || $left->{"type"} == Perla::AST::N_CALL() || $left->{"type"} == Perla::AST::N_METHOD() || $left->{"type"} == Perla::AST::N_DEREF_ARRAY() || $left->{"type"} == Perla::AST::N_DEREF_SCALAR() || $left->{"type"} == Perla::AST::N_BINOP() || $left->{"type"} == Perla::AST::N_ANON_ARRAY() || $left->{"type"} == Perla::AST::N_ARRAY_VAR() || $left->{"type"} == Perla::AST::N_SORT() || $left->{"type"} == Perla::AST::N_MAP() || $left->{"type"} == Perla::AST::N_GREP() || $left->{"type"} == Perla::AST::N_ARRAY_SLICE())) {
            _advance($p);
            my scalar $idx = _parse_expr($p);
            # `@{EXPR}[INDICES]` is always a slice in Perl, even with one index
            # or a range. Also `@{EXPR}[$i..$#x]` (range) — perla used to fall
            # through to ARROW_ARRAY (single-element access) and lose all but
            # the last element of the range. Forcing N_ARRAY_SLICE for
            # N_DEREF_ARRAY LHS makes it behave like the dedicated `@arr[...]`
            # parse path. Surfaced via DBIC's
            # `for my $j (@{$attrs->{from}}[1..$#{$attrs->{from}}])` — only the
            # last join entry was iterated, so prefetch alias_map stayed empty.
            my int $force_slice = 0;
            if ($left->{"type"} == Perla::AST::N_DEREF_ARRAY()) { $force_slice = 1; }
            # `(LIST)[range]` or `(LIST)[qw(...)]` should be a list slice,
            # not a single-element access. Without this, `(gmtime)[0..5]`
            # collapsed `0..5` to a single index = strada_to_int(range) →
            # only one gmtime field came back, breaking
            # DateTime::from_epoch's
            #   @args{qw(second minute hour day month year)} = (gmtime($epoch))[0..5]
            # and producing year=1899 etc.
            if (defined($idx) && $idx->{"type"} == Perla::AST::N_RANGE()) { $force_slice = 1; }
            if (defined($idx) && $idx->{"type"} == Perla::AST::N_QWORD()) { $force_slice = 1; }
            if (defined($idx) && $idx->{"type"} == Perla::AST::N_ANON_ARRAY()) {
                my int $isref_a = 0;
                if (defined($idx->{"is_ref"})) { $isref_a = $idx->{"is_ref"}; }
                if ($isref_a == 0) { $force_slice = 1; }
            }
            # `(FUNC())[N]` and `($obj->method())[N]` are list slices in
            # Perl — the parens force list context on the inner expression
            # regardless of how many indices follow. Without this, perla
            # treated single-index forms as ARROW_ARRAY (element access)
            # and called the function in scalar context. Same logic
            # applies to list-context built-ins (sort/map/grep/split) and
            # reverse on a list.
            if ($left->{"type"} == Perla::AST::N_CALL()
                || $left->{"type"} == Perla::AST::N_METHOD()
                || $left->{"type"} == Perla::AST::N_SORT()
                || $left->{"type"} == Perla::AST::N_MAP()
                || $left->{"type"} == Perla::AST::N_GREP()) {
                $force_slice = 1;
            }
            if (_peek_type($p) eq "COMMA" || $force_slice == 1) {
                # List slice: (expr)[1,2] or $arr[1,2,3] or @{$ref}[1..3]
                my scalar $slice = Perla::AST::node(Perla::AST::N_ARRAY_SLICE());
                $slice->{"array"} = $left;
                $slice->{"indices"} = [$idx];
                while (_peek_type($p) eq "COMMA") {
                    _advance($p);
                    if (_peek_type($p) eq "RBRACKET") { last; }
                    push(@{$slice->{"indices"}}, _parse_expr($p));
                }
                _expect($p, "RBRACKET");
                $left = $slice;
            } else {
                _expect($p, "RBRACKET");
                # Treat as arrow array access (implied ->)
                my scalar $node = Perla::AST::node(Perla::AST::N_ARROW_ARRAY());
                $node->{"object"} = $left;
                $node->{"index"} = $idx;
                $left = $node;
            }
        }
        # Postfix ++ --
        elsif (_peek_type($p) eq "OP" && (_peek_val($p) eq "++" || _peek_val($p) eq "--")) {
            my str $op = _advance($p)->{"value"};
            my scalar $node = Perla::AST::node(Perla::AST::N_UNOP());
            $node->{"op"} = $op;
            $node->{"operand"} = $left;
            $node->{"postfix"} = 1;
            $left = $node;
        } else {
            last;
        }
    }
    return $left;
}

# --- Primary expressions ---
# Check if current token can be a method name after ->
# Any IDENT or keyword token (except structural tokens like LBRACE/SEMI) works
func _is_method_name_token(scalar $p) int {
    my str $t = _peek_type($p);
    if ($t eq "IDENT" || $t eq "SCALAR_VAR") { return 1; }
    # Reject structural tokens
    if ($t eq "LBRACE" || $t eq "LBRACKET" || $t eq "LPAREN" || $t eq "SEMI" ||
        $t eq "EOF" || $t eq "COMMA" || $t eq "RBRACE") { return 0; }
    # Accept keywords and operator words that are valid method/sub names
    if ($t eq "OP" && _peek_val($p) eq "x") { return 1; }
    if ($t eq "PRINT" || $t eq "SAY" || $t eq "PUSH" || $t eq "POP" ||
        $t eq "SHIFT" || $t eq "UNSHIFT" || $t eq "KEYS" || $t eq "VALUES" ||
        $t eq "EACH" || $t eq "SORT" || $t eq "MAP" || $t eq "GREP" ||
        $t eq "OPEN" || $t eq "CLOSE" || $t eq "CHOMP" || $t eq "CHOP" ||
        $t eq "DEFINED" || $t eq "DELETE" || $t eq "EXISTS" || $t eq "SPLICE" || $t eq "SPLIT" ||
        $t eq "DIE" || $t eq "WARN" || $t eq "EVAL" || $t eq "BLESS" ||
        $t eq "NEXT" || $t eq "LAST" || $t eq "REDO" || $t eq "RETURN" ||
        $t eq "REF_FUNC" || $t eq "WANTARRAY" || $t eq "CALLER" ||
        $t eq "MY" || $t eq "OUR" || $t eq "LOCAL" || $t eq "DO" ||
        $t eq "IF" || $t eq "UNLESS" || $t eq "WHILE" || $t eq "UNTIL" ||
        $t eq "FOR" || $t eq "FOREACH" || $t eq "SUB" ||
        $t eq "BEGIN" || $t eq "END" || $t eq "USE" || $t eq "NO" ||
        $t eq "REQUIRE" || $t eq "PACKAGE" || $t eq "UNDEF" ||
        $t eq "DEFAULT" || $t eq "GIVEN" || $t eq "WHEN") { return 1; }
    return 0;
}

func _is_keyword_before_fat_arrow(scalar $p) int {
    # Check if current token is a keyword and next token is =>
    my str $t = _peek_type($p);
    if ($t eq "IDENT" || $t eq "INT" || $t eq "NUM" || $t eq "STRING" || $t eq "DQSTRING") {
        return 0;
    }
    # Variables and dereferences are NOT auto-quoted by fat arrow - only
    # barewords and (legacy) keywords are. Excluding them fixes idioms like
    # `map { ($_ => undef) } @list`, which would otherwise turn every pair
    # into the literal string "_" => undef.
    if ($t eq "SCALAR_VAR" || $t eq "ARRAY_VAR" || $t eq "HASH_VAR" ||
        $t eq "SCALAR_DEREF" || $t eq "ARRAY_DEREF" || $t eq "HASH_DEREF" ||
        $t eq "LBRACE" || $t eq "LBRACKET" || $t eq "LPAREN" ||
        $t eq "BACKSLASH") {
        return 0;
    }
    # Check next token is =>
    my int $next_pos = $p->{"pos"} + 1;
    if ($next_pos < $p->{"len"}) {
        my scalar $next_tok = $p->{"tokens"}->[$next_pos];
        if ($next_tok->{"type"} eq "FAT_ARROW") {
            return 1;
        }
    }
    return 0;
}

func _parse_primary(scalar $p) scalar {
    my str $type = _peek_type($p);
    my str $val = _peek_val($p);

    # `local LVALUE` as an expression — e.g. `(local @{$h}{@k}, ...)` in
    # Role::Tiny's `apply_roles_to_package`. _parse_local consumes the
    # optional postfix-if/unless and a trailing SEMI, but at expression
    # context there's no SEMI; reuse the lvalue parsing path here so the
    # surrounding `,` / `)` doesn't trip the parser.
    if ($type eq "LOCAL") {
        _advance($p);
        my scalar $lnode = Perla::AST::node(Perla::AST::N_LOCAL());
        my scalar $ltarget = _parse_postfix($p);
        my int $ltt = $ltarget->{"type"};
        if ($ltt == Perla::AST::N_SCALAR_VAR() || $ltt == Perla::AST::N_ARRAY_VAR() || $ltt == Perla::AST::N_HASH_VAR()) {
            my scalar $ltok = Perla::AST::node($ltt);
            $ltok->{"value"} = $ltarget->{"name"};
            $ltok->{"type"} = ($ltt == Perla::AST::N_SCALAR_VAR()) ? "SCALAR_VAR" : (($ltt == Perla::AST::N_ARRAY_VAR()) ? "ARRAY_VAR" : "HASH_VAR");
            $lnode->{"var"} = $ltok;
        } else {
            $lnode->{"target"} = $ltarget;
        }
        if (_peek_type($p) eq "OP" && _peek_val($p) eq "=") {
            _advance($p);
            $lnode->{"init"} = _parse_assign($p);
        }
        return $lnode;
    }

    # Leading ::IDENT as bareword string (e.g. `$x . ::e` = `$x . "::e"`)
    # Under Perl's no-strict-subs semantics, a bareword beginning with :: is
    # a package-qualified name that stringifies literally. Used by Mo::Inline
    # tricks like `&{$M.$_.::e}($P,\%e,\%o,\@_)`.
    if ($type eq "OP" && $val eq ":"
        && $p->{"pos"} + 2 < $p->{"len"}
        && $p->{"tokens"}->[$p->{"pos"} + 1]->{"type"} eq "OP"
        && $p->{"tokens"}->[$p->{"pos"} + 1]->{"value"} eq ":"
        && $p->{"tokens"}->[$p->{"pos"} + 2]->{"type"} eq "IDENT") {
        _advance($p);  # consume first :
        _advance($p);  # consume second :
        my str $bname = _advance($p)->{"value"};
        my scalar $blit = Perla::AST::node(Perla::AST::N_STR_LIT());
        $blit->{"value"} = "::" . $bname;
        return $blit;
    }

    # Keywords used as hash keys before => (e.g., next => undef, for => 1)
    if (_is_keyword_before_fat_arrow($p) == 1) {
        _advance($p);
        return Perla::AST::node_with(Perla::AST::N_STR_LIT(), "value", $val);
    }

    # Standalone s/// (operates on $_): if (s/pat/repl/flags)
    if ($type eq "SUBST_PAT") {
        my str $pat = _advance($p)->{"value"};
        my str $repl = "";
        my str $flags = "";
        if (_peek_type($p) eq "SUBST_REPL") { $repl = _advance($p)->{"value"}; }
        if (_peek_type($p) eq "SUBST_FLAGS") { $flags = _advance($p)->{"value"}; }
        my scalar $subst = Perla::AST::node(Perla::AST::N_SUBST());
        $subst->{"pattern"} = $pat;
        $subst->{"replacement"} = $repl;
        $subst->{"flags"} = $flags;
        # Wrap as $_ =~ s///
        my scalar $dollar = Perla::AST::node(Perla::AST::N_SCALAR_VAR());
        $dollar->{"name"} = "_";
        my scalar $binop = Perla::AST::node(Perla::AST::N_BINOP());
        $binop->{"op"} = "=~";
        $binop->{"left"} = $dollar;
        $binop->{"right"} = $subst;
        return $binop;
    }

    # Standalone m/.../ (operates on $_): if (m/foo/) { ... }
    # Used in DBIx::Class::Relationship::BelongsTo's `for (keys %$cond)
    # { if (m/\./) { ... } }` and many CPAN modules' for-loop filters.
    if ($type eq "MATCH_PAT") {
        my str $pat = _advance($p)->{"value"};
        my str $flags = "";
        if (_peek_type($p) eq "MATCH_FLAGS") { $flags = _advance($p)->{"value"}; }
        my scalar $regex = Perla::AST::node(Perla::AST::N_REGEX());
        $regex->{"pattern"} = $pat;
        $regex->{"flags"} = $flags;
        # Wrap as $_ =~ /pat/flags
        my scalar $dollar = Perla::AST::node(Perla::AST::N_SCALAR_VAR());
        $dollar->{"name"} = "_";
        my scalar $binop = Perla::AST::node(Perla::AST::N_BINOP());
        $binop->{"op"} = "=~";
        $binop->{"left"} = $dollar;
        $binop->{"right"} = $regex;
        return $binop;
    }

    # qr/PATTERN/FLAGS — produces a compiled-regex value (rvalue, NOT an
    # implicit match against $_). Stored as a string of Perl's stringify
    # form `(?FLAGS:PATTERN)` so `=~ $stored_regex` later can extract.
    if ($type eq "QR_REGEX") {
        my str $qr_pat = _advance($p)->{"value"};
        my str $qr_flags = "";
        if (_peek_type($p) eq "QR_FLAGS") { $qr_flags = _advance($p)->{"value"}; }
        my scalar $qr_node = Perla::AST::node(Perla::AST::N_REGEX());
        $qr_node->{"pattern"} = $qr_pat;
        $qr_node->{"flags"} = $qr_flags;
        $qr_node->{"is_qr"} = 1;
        return $qr_node;
    }

    # Standalone tr/y (operates on $_)
    if ($type eq "TR_FROM") {
        my str $from = _advance($p)->{"value"};
        my str $to = "";
        my str $tr_flags = "";
        if (_peek_type($p) eq "TR_TO") { $to = _advance($p)->{"value"}; }
        if (_peek_type($p) eq "TR_FLAGS") { $tr_flags = _advance($p)->{"value"}; }
        my scalar $tr = Perla::AST::node(Perla::AST::N_TR());
        $tr->{"from"} = $from;
        $tr->{"to"} = $to;
        $tr->{"flags"} = $tr_flags;
        my scalar $dollar = Perla::AST::node(Perla::AST::N_SCALAR_VAR());
        $dollar->{"name"} = "_";
        my scalar $binop = Perla::AST::node(Perla::AST::N_BINOP());
        $binop->{"op"} = "=~";
        $binop->{"left"} = $dollar;
        $binop->{"right"} = $tr;
        return $binop;
    }

    # 'return' in expression context (e.g., $x || return 42)
    if ($type eq "RETURN") {
        _advance($p);
        my scalar $ret_node = Perla::AST::node(Perla::AST::N_RETURN());
        # Parse optional return value
        if (!_at_end($p) && _peek_type($p) ne "SEMICOLON" && _peek_type($p) ne "RPAREN" && _peek_type($p) ne "RBRACE") {
            $ret_node->{"value"} = _parse_expr($p);
        }
        return $ret_node;
    }

    # NEXT/LAST/REDO as primary expressions: needed for the very common
    #     EXPR or next;        # Clone::Choose backend loop
    #     EXPR or last;
    #     EXPR and last;
    # idiom. The statement-level handler at line 364 only fires when
    # NEXT/LAST/REDO is the *first* token of a statement; on the RHS of
    # `or`/`and` the expression parser called us here, and without this
    # branch the bareword would fall through to the IDENT path and end
    # up as N_UNDEF — silently turning the short-circuit into a no-op.
    # Optional label may follow (e.g. `or last OUTER`).
    if ($type eq "NEXT" || $type eq "LAST" || $type eq "REDO") {
        _advance($p);
        my int $ctrl_type = Perla::AST::N_LAST();
        if ($type eq "NEXT") { $ctrl_type = Perla::AST::N_NEXT(); }
        if ($type eq "REDO") { $ctrl_type = Perla::AST::N_REDO(); }
        my scalar $ctrl = Perla::AST::node($ctrl_type);
        if (_peek_type($p) eq "IDENT" && _peek_val($p) ne "if" && _peek_val($p) ne "unless") {
            $ctrl->{"label"} = _advance($p)->{"value"};
        }
        return $ctrl;
    }

    # do { BLOCK } as expression
    if ($type eq "DO") {
        _advance($p);
        if (_peek_type($p) eq "LBRACE") {
            my scalar $body = _parse_block($p);
            # Check for while/until
            if (_peek_type($p) eq "WHILE" || _peek_type($p) eq "UNTIL") {
                my int $negate = 0;
                if (_peek_type($p) eq "UNTIL") { $negate = 1; }
                _advance($p);
                _expect($p, "LPAREN");
                my scalar $cond = _parse_expr($p);
                _expect($p, "RPAREN");
                my scalar $dw = Perla::AST::node(Perla::AST::N_DO_WHILE());
                $dw->{"body"} = $body;
                $dw->{"cond"} = $cond;
                if ($negate == 1) { $dw->{"negate"} = 1; }
                return $dw;
            }
            return $body;  # N_BLOCK - _gen_expr handles it
        }
        # `do "FILE"` in expression context (e.g. `my $r = do "FILE"`).
        # Mirror `_parse_do`'s statement form: encode filename in a
        # N_SPECIAL_VAR with value="do_file:FILENAME". Without this,
        # the parser fell through to the literal-string branch and
        # `do "FILE"` was effectively a string literal "FILE".
        if (_peek_type($p) eq "STRING") {
            my str $filename = _advance($p)->{"value"};
            my scalar $df = Perla::AST::node(Perla::AST::N_SPECIAL_VAR());
            $df->{"value"} = "do_file:" . $filename;
            return $df;
        }
        # DQSTRING — may contain interpolations (e.g. `$$` PID).
        # Route through N_DO_FILE_EXPR so the path is resolved at
        # runtime.
        if (_peek_type($p) eq "DQSTRING") {
            my str $filename = _advance($p)->{"value"};
            my scalar $istr = Perla::AST::node_with(Perla::AST::N_INTERP_STR(), "value", $filename);
            my scalar $df = Perla::AST::node(Perla::AST::N_DO_FILE_EXPR());
            $df->{"path"} = $istr;
            return $df;
        }
        # `do $expr` — runtime filename. Mark with a special node so
        # codegen emits an at-runtime slurp+eval.
        if (_peek_type($p) eq "SCALAR_VAR" || _peek_type($p) eq "LBRACE") {
            my scalar $df = Perla::AST::node(Perla::AST::N_DO_FILE_EXPR());
            $df->{"path"} = _parse_unary($p);
            return $df;
        }
    }

    # Literals
    if ($type eq "INT") {
        _advance($p);
        return Perla::AST::node_with(Perla::AST::N_INT_LIT(), "value", $val);
    }
    if ($type eq "NUM") {
        _advance($p);
        return Perla::AST::node_with(Perla::AST::N_NUM_LIT(), "value", $val);
    }
    if ($type eq "STRING") {
        _advance($p);
        return Perla::AST::node_with(Perla::AST::N_STR_LIT(), "value", $val);
    }
    if ($type eq "DQSTRING") {
        _advance($p);
        return Perla::AST::node_with(Perla::AST::N_INTERP_STR(), "value", $val);
    }

    # Compile-time constants
    if ($type eq "LINE_CONST") {
        my scalar $tok = _advance($p);
        return Perla::AST::node_with(Perla::AST::N_INT_LIT(), "value", "" . $tok->{"line"});
    }
    if ($type eq "PACKAGE_CONST") {
        _advance($p);
        return Perla::AST::node_with(Perla::AST::N_STR_LIT(), "value", $p->{"pkg"});
    }
    if ($type eq "FILE_CONST") {
        _advance($p);
        my str $fn = "" . $p->{"filename"};
        if ($fn eq "") { $fn = "(eval)"; }
        return Perla::AST::node_with(Perla::AST::N_STR_LIT(), "value", $fn);
    }
    if ($type eq "SUB_CONST") {
        _advance($p);
        my str $subname = "" . $p->{"current_sub"};
        if ($subname eq "") {
            # Anonymous-sub context: emit a marker N_CALL with name
            # "__PERLA_CURRENT_SUB__" wrapped in N_REF. The codegen
            # for N_REF detects this marker and emits a CPOINTER to
            # the currently-emitting sub's C function — which is known
            # at codegen time even though the parser doesn't know it.
            # Enables self-recursion in anon subs:
            #   my $fib = sub { ... __SUB__->(\$n - 1) + __SUB__->(\$n - 2) };
            my scalar $call_a = Perla::AST::node(Perla::AST::N_CALL());
            $call_a->{"name"} = "__PERLA_CURRENT_SUB__";
            $call_a->{"args"} = [];
            my scalar $refn_a = Perla::AST::node(Perla::AST::N_REF());
            $refn_a->{"operand"} = $call_a;
            return $refn_a;
        }
        # Named-sub context: emit \&PKG::name so __SUB__->(...) calls
        # the current sub and ref(__SUB__) returns "CODE" and
        # __SUB__ == \&self compares true.
        my scalar $call = Perla::AST::node(Perla::AST::N_CALL());
        $call->{"name"} = $subname;
        $call->{"args"} = [];
        my scalar $refn = Perla::AST::node(Perla::AST::N_REF());
        $refn->{"operand"} = $call;
        return $refn;
    }

    # @{expr} - array dereference
    if ($type eq "DEREF_ARRAY_START") {
        _advance($p);
        my scalar $expr = _parse_expr($p);
        # Same as %{...}: tolerate trailing `;` since Perl treats the braces as a block.
        while (_peek_type($p) eq "SEMI") { _advance($p); }
        _expect($p, "RBRACE");
        my scalar $node = Perla::AST::node(Perla::AST::N_DEREF_ARRAY());
        $node->{"ref"} = $expr;
        return $node;
    }

    # ${expr} - scalar dereference (lexer does not currently emit this token
    # outside of ${ident}, but the handler is kept for future coordinated
    # lexer+parser changes).
    if ($type eq "DEREF_SCALAR_START") {
        _advance($p);
        my scalar $expr = _parse_expr($p);
        while (_peek_type($p) eq "SEMI") { _advance($p); }
        _expect($p, "RBRACE");
        my scalar $node = Perla::AST::node(Perla::AST::N_DEREF_SCALAR());
        $node->{"ref"} = $expr;
        return $node;
    }

    # %{expr} - hash dereference
    if ($type eq "DEREF_HASH_START") {
        _advance($p);
        my scalar $expr = _parse_expr($p);
        # Allow trailing `;` inside `%{ EXPR; }` — Perl treats the braces
        # as a block, so `%{ $h->{x} ||= ... ; }` is well-formed; perla
        # used to die at the semi (see DBIHacks::_resolve_aliastypes_from_select_args).
        while (_peek_type($p) eq "SEMI") { _advance($p); }
        _expect($p, "RBRACE");
        my scalar $node = Perla::AST::node(Perla::AST::N_DEREF_HASH());
        $node->{"ref"} = $expr;
        return $node;
    }
    # @$ref - array deref without braces
    if ($type eq "DEREF_ARRAY_SIGIL") {
        _advance($p);
        my scalar $expr = _parse_primary($p);
        # Check for hash slice: @$ref{keys}
        if (_peek_type($p) eq "LBRACE") {
            _advance($p);
            my scalar $node = Perla::AST::node(Perla::AST::N_HASH_SLICE());
            $node->{"hash"} = $expr;  # AST node (the ref to deref)
            $node->{"hash_is_ref"} = 1;
            $node->{"keys_list"} = [];
            while (_peek_type($p) ne "RBRACE" && !_at_end($p)) {
                push(@{$node->{"keys_list"}}, _parse_assign($p));
                if (_peek_type($p) eq "COMMA" || _peek_type($p) eq "FAT_ARROW") { _advance($p); }
            }
            _expect($p, "RBRACE");
            return $node;
        }
        my scalar $node = Perla::AST::node(Perla::AST::N_DEREF_ARRAY());
        $node->{"ref"} = $expr;
        return $node;
    }
    # %$ref - hash deref without braces
    if ($type eq "DEREF_HASH_SIGIL") {
        _advance($p);
        my scalar $expr = _parse_primary($p);
        # `%$ref{a, b}` — key-value hash slice via deref (5.20+).
        # Returns flat (k1, v1, k2, v2). Mirrors `%hash{a, b}`.
        if (_peek_type($p) eq "LBRACE") {
            _advance($p);
            my scalar $node = Perla::AST::node(Perla::AST::N_HASH_SLICE());
            $node->{"hash"} = $expr;
            $node->{"hash_is_ref"} = 1;
            $node->{"is_kv_slice"} = 1;
            $node->{"keys_list"} = [];
            while (_peek_type($p) ne "RBRACE" && !_at_end($p)) {
                push(@{$node->{"keys_list"}}, _parse_assign($p));
                if (_peek_type($p) eq "COMMA" || _peek_type($p) eq "FAT_ARROW") { _advance($p); }
            }
            _expect($p, "RBRACE");
            return $node;
        }
        my scalar $node = Perla::AST::node(Perla::AST::N_DEREF_HASH());
        $node->{"ref"} = $expr;
        return $node;
    }
    if ($type eq "UNDEF") {
        _advance($p);
        # `undef EXPR` is Perl's lvalue-clearing form — `undef $x` clears
        # the scalar to undef, `undef @arr` empties the array, `undef %h`
        # empties the hash. Bare `undef` (no arg) is just the undef value.
        # Detect a sigiled lvalue follower and rewrite as `EXPR = undef`.
        my str $next_t = _peek_type($p);
        # `undef &Pkg::name` / `undef &name` — Perl's "delete this sub
        # from the symbol table" form. After this, `defined(&Pkg::name)`
        # is false and the sub can't be called. The sub slot must be
        # cleared in the package stash.
        if ($next_t eq "OP" && _peek_val($p) eq "&") {
            _advance($p);  # consume '&'
            if (_peek_type($p) eq "IDENT") {
                my str $u_name = _advance($p)->{"value"};
                while (_peek_type($p) eq "PKG_SEP") {
                    _advance($p);
                    if (_peek_type($p) eq "IDENT" || _peek_type($p) eq "PACKAGE") {
                        $u_name = $u_name . "::" . _advance($p)->{"value"};
                    }
                }
                # Emit as N_CALL to a synthetic builtin that codegen handles.
                my scalar $undef_call = Perla::AST::node(Perla::AST::N_CALL());
                $undef_call->{"name"} = "__perla_undef_sub__";
                $undef_call->{"args"} = [];
                my scalar $name_lit = Perla::AST::node(Perla::AST::N_STR_LIT());
                $name_lit->{"value"} = $u_name;
                push(@{$undef_call->{"args"}}, $name_lit);
                return $undef_call;
            }
            # Fallback: `undef &{EXPR}` — not supported, treat as bare undef.
            return Perla::AST::node(Perla::AST::N_UNDEF());
        }
        if ($next_t eq "SCALAR_VAR" || $next_t eq "ARRAY_VAR" || $next_t eq "HASH_VAR") {
            my scalar $target = _parse_unary($p);
            my scalar $undef_val = Perla::AST::node(Perla::AST::N_UNDEF());
            # For @arr / %h, the equivalent is `@arr = ()` / `%h = ()`, not
            # `@arr = undef`. Use empty list to truly clear.
            my int $tt = $target->{"type"};
            if ($tt == Perla::AST::N_ARRAY_VAR() || $tt == Perla::AST::N_HASH_VAR()) {
                $undef_val = Perla::AST::node(Perla::AST::N_ANON_ARRAY());
                $undef_val->{"elems"} = [];
                $undef_val->{"is_ref"} = 0;
            }
            my scalar $assign = Perla::AST::node(Perla::AST::N_ASSIGN());
            $assign->{"op"} = "=";
            $assign->{"target"} = $target;
            $assign->{"value"} = $undef_val;
            return $assign;
        }
        # `undef()` and `undef(EXPR)` — Perl accepts the parens form too.
        # Consume the parens; if EXPR is present, treat as `undef EXPR`.
        if ($next_t eq "LPAREN") {
            _advance($p);  # consume LPAREN
            if (_peek_type($p) eq "RPAREN") {
                _advance($p);  # consume RPAREN — bare undef()
                return Perla::AST::node(Perla::AST::N_UNDEF());
            }
            # undef(EXPR) — parse inner, then expect RPAREN. Inner LVALUE
            # gets the clear-semantic rewrite as above.
            my scalar $target = _parse_expr($p);
            _match($p, "RPAREN");
            my int $tt2 = defined($target) ? $target->{"type"} : 0;
            if ($tt2 == Perla::AST::N_SCALAR_VAR()
                || $tt2 == Perla::AST::N_ARRAY_VAR()
                || $tt2 == Perla::AST::N_HASH_VAR()) {
                my scalar $undef_val = Perla::AST::node(Perla::AST::N_UNDEF());
                if ($tt2 == Perla::AST::N_ARRAY_VAR() || $tt2 == Perla::AST::N_HASH_VAR()) {
                    $undef_val = Perla::AST::node(Perla::AST::N_ANON_ARRAY());
                    $undef_val->{"elems"} = [];
                    $undef_val->{"is_ref"} = 0;
                }
                my scalar $assign = Perla::AST::node(Perla::AST::N_ASSIGN());
                $assign->{"op"} = "=";
                $assign->{"target"} = $target;
                $assign->{"value"} = $undef_val;
                return $assign;
            }
            # Non-lvalue undef(EXPR) — just return undef (EXPR evaluated
            # for side effects via comma-op wrap).
            my scalar $undef_node = Perla::AST::node(Perla::AST::N_UNDEF());
            return $undef_node;
        }
        return Perla::AST::node(Perla::AST::N_UNDEF());
    }

    # /regex/ literal
    if ($type eq "REGEX") {
        my str $pattern = _advance($p)->{"value"};
        my str $flags = "";
        if (_peek_type($p) eq "MATCH_FLAGS") {
            $flags = _advance($p)->{"value"};
        }
        my scalar $node = Perla::AST::node(Perla::AST::N_REGEX());
        $node->{"pattern"} = $pattern;
        $node->{"flags"} = $flags;
        return $node;
    }

    # `command` backtick
    if ($type eq "BACKTICK") {
        my str $cmd = _advance($p)->{"value"};
        return Perla::AST::node_with(Perla::AST::N_SPECIAL_VAR(), "value", "backtick:" . $cmd);
    }

    # <$fh> readline
    if ($type eq "READLINE") {
        my str $handle = _advance($p)->{"value"};
        my scalar $node = Perla::AST::node(Perla::AST::N_READLINE());
        $node->{"handle"} = $handle;
        return $node;
    }

    # $#array - last index
    if ($type eq "ARRAY_LAST_IDX") {
        my str $arr_name = _advance($p)->{"value"};
        return Perla::AST::node_with(Perla::AST::N_SPECIAL_VAR(), "value", "#" . $arr_name);
    }

    # $#{ EXPR } - last index of array ref expression
    if ($type eq "ARRAY_LAST_IDX_EXPR") {
        _advance($p);  # consume ARRAY_LAST_IDX_EXPR
        _expect($p, "LBRACE");
        my scalar $expr = _parse_expr($p);
        _expect($p, "RBRACE");
        # Create: scalar(@{ EXPR }) - 1
        my scalar $deref = Perla::AST::node(Perla::AST::N_DEREF_ARRAY());
        $deref->{"ref"} = $expr;
        my scalar $size_call = Perla::AST::node(Perla::AST::N_CALL());
        $size_call->{"name"} = "scalar";
        $size_call->{"args"} = [$deref];
        my scalar $minus = Perla::AST::node(Perla::AST::N_BINOP());
        $minus->{"op"} = "-";
        $minus->{"left"} = $size_call;
        $minus->{"right"} = Perla::AST::node_with(Perla::AST::N_INT_LIT(), "value", "1");
        return $minus;
    }

    # $#$ref - last index via scalar deref
    if ($type eq "ARRAY_LAST_IDX_DEREF") {
        _advance($p);  # consume ARRAY_LAST_IDX_DEREF
        my scalar $ref_expr = _parse_primary($p);
        # Create: scalar(@{ $ref }) - 1
        my scalar $deref = Perla::AST::node(Perla::AST::N_DEREF_ARRAY());
        $deref->{"ref"} = $ref_expr;
        my scalar $size_call = Perla::AST::node(Perla::AST::N_CALL());
        $size_call->{"name"} = "scalar";
        $size_call->{"args"} = [$deref];
        my scalar $minus = Perla::AST::node(Perla::AST::N_BINOP());
        $minus->{"op"} = "-";
        $minus->{"left"} = $size_call;
        $minus->{"right"} = Perla::AST::node_with(Perla::AST::N_INT_LIT(), "value", "1");
        return $minus;
    }

    # Variables
    if ($type eq "SCALAR_VAR") {
        _advance($p);
        # $$ref / $$$ref / $$$$ref / ... — the lexer leaves N-1 `$`s
        # at the start of val (the sigil consumed the first one). Each
        # remaining `$` is one deref level. The previous per-iteration
        # mutation of base_node->{name} only worked for ≤3 levels:
        # once base_node was wrapped in DEREF_SCALAR, later
        # `base_node->{name} = $inner` writes wrote to the wrapper
        # (unused field) and left the inner SCALAR_VAR's name stuck at
        # `$ref`. So `$$$$r3` looked up var `$r3` (doesn't exist) and
        # returned undef. Extract the base name in one pass, then wrap
        # the correct number of times.
        if (length($val) > 1 && substr($val, 0, 1) eq "$") {
            my str $base_name = $val;
            my int $deref_count = 0;
            while (length($base_name) > 0 && substr($base_name, 0, 1) eq "$") {
                $deref_count = $deref_count + 1;
                $base_name = substr($base_name, 1, length($base_name) - 1);
            }
            my scalar $base = Perla::AST::node_with(Perla::AST::N_SCALAR_VAR(), "name", $base_name);
            my int $wi = 0;
            while ($wi < $deref_count) {
                my scalar $wrap = Perla::AST::node(Perla::AST::N_DEREF_SCALAR());
                $wrap->{"ref"} = $base;
                $base = $wrap;
                $wi = $wi + 1;
            }
            return $base;
        }
        return Perla::AST::node_with(Perla::AST::N_SCALAR_VAR(), "name", $val);
    }
    if ($type eq "ARRAY_VAR") {
        _advance($p);
        # Array slice: @arr[1,3] or hash slice: @hash{"a","b"}
        if (_peek_type($p) eq "LBRACKET") {
            _advance($p);
            my scalar $node = Perla::AST::node(Perla::AST::N_ARRAY_SLICE());
            $node->{"array"} = $val;
            $node->{"indices"} = [];
            while (_peek_type($p) ne "RBRACKET" && !_at_end($p)) {
                push(@{$node->{"indices"}}, _parse_assign($p));
                if (_peek_type($p) eq "COMMA") { _advance($p); }
            }
            _expect($p, "RBRACKET");
            return $node;
        }
        if (_peek_type($p) eq "LBRACE") {
            _advance($p);
            my scalar $node = Perla::AST::node(Perla::AST::N_HASH_SLICE());
            $node->{"hash"} = $val;
            $node->{"keys_list"} = [];
            while (_peek_type($p) ne "RBRACE" && !_at_end($p)) {
                push(@{$node->{"keys_list"}}, _parse_assign($p));
                if (_peek_type($p) eq "COMMA" || _peek_type($p) eq "FAT_ARROW") { _advance($p); }
            }
            _expect($p, "RBRACE");
            return $node;
        }
        return Perla::AST::node_with(Perla::AST::N_ARRAY_VAR(), "name", $val);
    }
    if ($type eq "HASH_VAR") {
        _advance($p);
        # `%arr[1, 2]` — key-value array slice (Perl 5.20+).
        # Returns flat (idx1, val1, idx2, val2) for an array named
        # `arr`. Modeled via N_ARRAY_SLICE with is_kv_slice=1 so the
        # codegen pushes both index and value.
        if (_peek_type($p) eq "LBRACKET") {
            _advance($p);
            my scalar $node = Perla::AST::node(Perla::AST::N_ARRAY_SLICE());
            $node->{"array"} = $val;
            $node->{"is_kv_slice"} = 1;
            $node->{"indices"} = [];
            while (_peek_type($p) ne "RBRACKET" && !_at_end($p)) {
                push(@{$node->{"indices"}}, _parse_assign($p));
                if (_peek_type($p) eq "COMMA") { _advance($p); }
            }
            _expect($p, "RBRACKET");
            return $node;
        }
        # `%hash{a, b}` — key-value hash slice (Perl 5.20+).
        # Returns flat (key1, val1, key2, val2). Flagged on
        # N_HASH_SLICE so the codegen pushes both key and value.
        if (_peek_type($p) eq "LBRACE") {
            _advance($p);
            my scalar $node = Perla::AST::node(Perla::AST::N_HASH_SLICE());
            $node->{"hash"} = $val;
            $node->{"is_kv_slice"} = 1;
            $node->{"keys_list"} = [];
            while (_peek_type($p) ne "RBRACE" && !_at_end($p)) {
                push(@{$node->{"keys_list"}}, _parse_assign($p));
                if (_peek_type($p) eq "COMMA" || _peek_type($p) eq "FAT_ARROW") { _advance($p); }
            }
            _expect($p, "RBRACE");
            return $node;
        }
        return Perla::AST::node_with(Perla::AST::N_HASH_VAR(), "name", $val);
    }

    # Parenthesized expression / list
    if ($type eq "LPAREN") {
        _advance($p);
        # Empty list ()
        if (_peek_type($p) eq "RPAREN") {
            _advance($p);
            my scalar $empty = Perla::AST::node(Perla::AST::N_ANON_ARRAY());
            $empty->{"elems"} = [];
            return $empty;
        }
        my scalar $expr = _parse_expr($p);
        # Check for list: (a, b, c) or (a => 1, b => 2)
        if (_peek_type($p) eq "COMMA" || _peek_type($p) eq "FAT_ARROW") {
            my scalar $list = Perla::AST::node(Perla::AST::N_ANON_ARRAY());
            $list->{"elems"} = [];
            push(@{$list->{"elems"}}, $expr);
            while (_peek_type($p) eq "COMMA" || _peek_type($p) eq "FAT_ARROW") {
                _advance($p);  # consume , or =>
                if (_peek_type($p) eq "RPAREN") { last; }
                push(@{$list->{"elems"}}, _parse_assign($p));
            }
            _expect($p, "RPAREN");
            # `(a, b) x N` — multi-element list with `x` is list repeat.
            if (_peek_type($p) eq "OP" && _peek_val($p) eq "x") {
                $list->{"paren_list"} = 1;
            }
            return $list;
        }
        _expect($p, "RPAREN");
        # `(EXPR) x N` — paren-wrap signals list repetition. In Perl,
        # `($x) x 4` produces a 4-element list, while `$x x 4` is string
        # repeat. Wrap in N_ANON_ARRAY (non-ref) so `x` codegen can
        # detect and emit list-repeat semantics.
        if (_peek_type($p) eq "OP" && _peek_val($p) eq "x") {
            my scalar $list = Perla::AST::node(Perla::AST::N_ANON_ARRAY());
            $list->{"elems"} = [$expr];
            $list->{"paren_list"} = 1;
            return $list;
        }
        # `($var) = EXPR` — single-element parenthesized lvalue. Perl
        # treats the parens as forcing list-context assignment. Without
        # the wrap, `($name) = $text =~ /pat/` collapsed to
        # `$name = $text =~ /pat/` which is scalar-context match
        # returning the 1/0 boolean instead of capture values. Detect
        # by peek: the immediately-following token is `=` (and NOT
        # `==`/`=~`/etc.) and the inner EXPR is an lvalue-shaped node.
        if (_peek_type($p) eq "OP" && _peek_val($p) eq "=") {
            my int $et = $expr->{"type"};
            if ($et == Perla::AST::N_SCALAR_VAR() || $et == Perla::AST::N_ARRAY_VAR()
                || $et == Perla::AST::N_HASH_VAR() || $et == Perla::AST::N_HASH_ELEM()
                || $et == Perla::AST::N_ARRAY_ELEM() || $et == Perla::AST::N_ARROW_HASH()
                || $et == Perla::AST::N_ARROW_ARRAY() || $et == Perla::AST::N_DEREF_SCALAR()
                || $et == Perla::AST::N_MY()) {
                my scalar $list = Perla::AST::node(Perla::AST::N_ANON_ARRAY());
                $list->{"elems"} = [$expr];
                return $list;
            }
        }
        # `(EXPR)[N]` or `(EXPR)[a..b]` — paren-list followed by subscript
        # is a list slice in Perl. Forces list context on the inner so
        # `($s =~ /pat/)[0]` actually evaluates the regex in list context
        # and returns the capture, instead of evaluating in scalar context
        # and slicing the bool result. Wrap as a single-elem N_ANON_ARRAY
        # so the existing N_ARRAY_ELEM codegen for ANON_ARRAY arrays kicks
        # in (it pushes want_list=1 around the inner).
        if (_peek_type($p) eq "LBRACKET") {
            my scalar $list = Perla::AST::node(Perla::AST::N_ANON_ARRAY());
            $list->{"elems"} = [$expr];
            $list->{"paren_list"} = 1;
            return $list;
        }
        return $expr;
    }

    # Anonymous array ref [...]
    if ($type eq "LBRACKET") {
        _advance($p);
        my scalar $node = Perla::AST::node(Perla::AST::N_ANON_ARRAY());
        $node->{"elems"} = [];
        $node->{"is_ref"} = 1;  # [...] creates array REF, don't flatten in args
        while (_peek_type($p) ne "RBRACKET" && !_at_end($p)) {
            # Skip stray commas and fat arrows — Perl elides them in list
            # constructors and treats `=>` as a comma equivalent. Without
            # accepting FAT_ARROW here, `[a => 1]` parsed as `[a, <empty>, 1]`
            # (a 3-element array with a blank middle), so
            # `map { @$_ } [a=>1], [b=>2]` produced a 6-element list with
            # empty strings in slots 1, 3 and any hash built from those
            # pairs was wrong.
            while (_peek_type($p) eq "COMMA" || _peek_type($p) eq "FAT_ARROW") { _advance($p); }
            if (_peek_type($p) eq "RBRACKET" || _at_end($p)) { last; }
            push(@{$node->{"elems"}}, _parse_assign($p));
            if (_peek_type($p) eq "COMMA" || _peek_type($p) eq "FAT_ARROW") { _advance($p); }
        }
        _expect($p, "RBRACKET");
        return $node;
    }

    # Anonymous hash ref {...}
    if ($type eq "LBRACE") {
        _advance($p);
        my scalar $node = Perla::AST::node(Perla::AST::N_ANON_HASH());
        $node->{"pairs"} = [];
        while (_peek_type($p) ne "RBRACE" && !_at_end($p)) {
            # Skip stray commas — Perl elides empty list elements like
            # `{ a => 1, , b => 2 }`. Without this perla parses the bare
            # comma as an empty key, shifting subsequent pairs by one
            # slot.
            while (_peek_type($p) eq "COMMA") { _advance($p); }
            if (_peek_type($p) eq "RBRACE" || _at_end($p)) { last; }
            my scalar $key = _parse_assign($p);
            if (_peek_type($p) eq "FAT_ARROW") {
                _advance($p);
                my scalar $value = _parse_assign($p);
                push(@{$node->{"pairs"}}, $key);
                push(@{$node->{"pairs"}}, $value);
            } else {
                push(@{$node->{"pairs"}}, $key);
            }
            _match($p, "COMMA");
        }
        _expect($p, "RBRACE");
        return $node;
    }

    # Anonymous sub
    if ($type eq "SUB") {
        return _parse_sub($p);
    }

    # qw(word word word)
    if ($type eq "QW") {
        _advance($p);
        _expect($p, "LPAREN");
        my scalar $node = Perla::AST::node(Perla::AST::N_QWORD());
        $node->{"elems"} = [];
        while (_peek_type($p) ne "RPAREN" && !_at_end($p)) {
            my scalar $tok = _advance($p);
            push(@{$node->{"elems"}}, Perla::AST::node_with(Perla::AST::N_STR_LIT(), "value", $tok->{"value"}));
        }
        _expect($p, "RPAREN");
        return $node;
    }

    # map { BLOCK } LIST  or  map EXPR, LIST  (both also paren-wrapped)
    if ($type eq "MAP") {
        _advance($p);
        my scalar $node = Perla::AST::node(Perla::AST::N_MAP());
        # `map(EXPR, LIST)` - paren-wrapped call; see GREP note below.
        my int $__map_paren = 0;
        if (_peek_type($p) eq "LPAREN") {
            $__map_paren = 1;
            _advance($p);
        }
        if (_peek_type($p) eq "LBRACE") {
            $node->{"block"} = _parse_block($p);
        } else {
            # map EXPR, LIST - expression form
            my scalar $block = Perla::AST::node(Perla::AST::N_BLOCK());
            $block->{"stmts"} = [];
            push(@{$block->{"stmts"}}, _parse_expr($p));
            $node->{"block"} = $block;
            _expect($p, "COMMA");
        }
        # The LIST may be comma-separated literal items
        # (`map { ... } "a", "b"`). _parse_expr only reads up to the
        # next comma at this level, so collect any trailing comma items
        # into a flat N_ANON_ARRAY so codegen sees them all.
        my scalar $first_list = _parse_expr($p);
        if (_peek_type($p) eq "COMMA") {
            my scalar $list_node = Perla::AST::node(Perla::AST::N_ANON_ARRAY());
            $list_node->{"elems"} = [$first_list];
            $list_node->{"is_ref"} = 0;
            while (_peek_type($p) eq "COMMA") {
                _advance($p);
                # Stop on a trailing comma before a closing delimiter — incl.
                # RBRACKET/RBRACE, so `[ map {...} @l, ]` and `{ map {...} @l, }`
                # terminate instead of trying to _parse_expr the `]`/`}` and
                # running to EOF ("expected RBRACKET, got EOF"). Mirrors grep.
                if (_peek_type($p) eq "RPAREN" || _peek_type($p) eq "RBRACKET"
                    || _peek_type($p) eq "RBRACE" || _peek_type($p) eq "SEMI"
                    || _at_end($p)) { last; }
                push(@{$list_node->{"elems"}}, _parse_expr($p));
            }
            $node->{"list"} = $list_node;
        } else {
            $node->{"list"} = $first_list;
        }
        if ($__map_paren == 1) { _expect($p, "RPAREN"); }
        return $node;
    }

    # grep { BLOCK } LIST
    if ($type eq "GREP") {
        _advance($p);
        my scalar $node = Perla::AST::node(Perla::AST::N_GREP());
        # `grep(EXPR, LIST)` - paren-wrapped call form. Without this
        # branch, _parse_expr would consume `(EXPR, LIST)` as a single
        # parenthesized comma-expression, leaving no arg after the
        # comma, and the trailing `;` / statement modifier would then
        # fail with "expected COMMA, got …". MP.pm's
        # `@dirs = grep(length($_), splitdir(...)) unless …` was
        # hitting exactly this path.
        my int $__grep_paren = 0;
        if (_peek_type($p) eq "LPAREN") {
            $__grep_paren = 1;
            _advance($p);  # eat the `(`
        }
        if (_peek_type($p) eq "LBRACE") {
            $node->{"block"} = _parse_block($p);
        } else {
            # grep EXPR, @list - expression form (including grep /regex/, @list)
            my scalar $block = Perla::AST::node(Perla::AST::N_BLOCK());
            $block->{"stmts"} = [];
            push(@{$block->{"stmts"}}, _parse_expr($p));
            $node->{"block"} = $block;
            _expect($p, "COMMA");
        }
        # Parse list: could be multiple comma-separated expressions
        my scalar $first = _parse_expr($p);
        if (_peek_type($p) eq "COMMA") {
            # Multiple list elements → build an array
            # N_ANON_ARRAY uses "elems" key — match other call sites.
            # Earlier this used "elements" which codegen never read, so
            # the multi-element list was silently empty.
            my scalar $arr = Perla::AST::node(Perla::AST::N_ANON_ARRAY());
            $arr->{"elems"} = [];
            $arr->{"is_ref"} = 0;
            push(@{$arr->{"elems"}}, $first);
            while (_match($p, "COMMA")) {
                if (_peek_type($p) eq "RPAREN" || _peek_type($p) eq "RBRACE" ||
                    _peek_type($p) eq "RBRACKET" || _peek_type($p) eq "SEMI" ||
                    _at_end($p)) { last; }
                push(@{$arr->{"elems"}}, _parse_expr($p));
            }
            $node->{"list"} = $arr;
        } else {
            $node->{"list"} = $first;
        }
        if ($__grep_paren == 1) { _expect($p, "RPAREN"); }
        return $node;
    }

    # `require Foo::Bar` in expression context — DBI.pm uses
    # `(require File::Path and File::Path::mkpath(...))`. Route to the
    # statement parser; the trailing semicolon match there is non-fatal.
    if ($type eq "REQUIRE") {
        return _parse_require_stmt($p);
    }

    # Function call / bareword
    if ($type eq "IDENT" || $type eq "PRINT" || $type eq "SAY" || $type eq "DIE" ||
        $type eq "CHOMP" || $type eq "DEFINED" || $type eq "REF_FUNC" ||
        $type eq "PUSH" || $type eq "POP" || $type eq "SHIFT" || $type eq "UNSHIFT" ||
        $type eq "KEYS" || $type eq "VALUES" || $type eq "EXISTS" || $type eq "DELETE" ||
        $type eq "BLESS" || $type eq "OPEN" || $type eq "CLOSE" ||
        $type eq "SORT" || $type eq "MAP" || $type eq "GREP" ||
        $type eq "CALLER" || $type eq "WANTARRAY" || $type eq "EVAL" ||
        $type eq "SPLICE" || $type eq "SPLIT" || $type eq "EACH" || $type eq "CHOP" || $type eq "WARN") {
        # Capture the call's source line BEFORE advancing past the
        # IDENT token, so we can attach it to N_CALL nodes for
        # caller() / die location messages.
        my int $__call_line = _cur($p)->{"line"} + 0;
        my str $name = _advance($p)->{"value"};

        # `CORE::name` — Perl's explicit-builtin form. Used when the
        # current package overrides a built-in (`sub push {...}` then
        # \`CORE::push @arr, \$item\` to call the real one). Strip the
        # prefix so the subsequent IDENT-name dispatch (multi-arg
        # builtins, named-unary builtins, etc.) treats it as the bare
        # built-in. Without this, the lexer tokenised "CORE::push" as
        # a single IDENT — the parser fell through to the generic
        # 1-arg call branch which wrapped trailing args into an
        # anon-array, and \`CORE::push @{\$h->{items}}, \$v\` failed
        # to push in place.
        if (length($name) > 6 && substr($name, 0, 6) eq "CORE::") {
            $name = substr($name, 6, length($name) - 6);
        }

        # Bareword-on-left-of-fat-arrow autoquote: Perl treats `ref => X`
        # as `"ref" => X` (a key-value pair), not the function call
        # `ref(X)`. The lexer tokenises `ref` (and other builtins like
        # `keys`, `values`, etc.) as specialized tokens, so the parser
        # has to autoquote here. Without this, `{ ref => \$x }` parsed
        # as `{ ref(\$x => ...) }` and the key was missing.
        if (_peek_type($p) eq "FAT_ARROW") {
            return Perla::AST::node_with(Perla::AST::N_STR_LIT(), "value", $name);
        }

        # eval { BLOCK } - exception handling
        if ($name eq "eval" && _peek_type($p) eq "LBRACE") {
            my scalar $node = Perla::AST::node(Perla::AST::N_EVAL_BLOCK());
            $node->{"line"} = $__call_line;
            $node->{"body"} = _parse_block($p);
            return $node;
        }

        # ref $var - only consume one primary expression (not full ternary).
        # When followed by an operator (comparison, binary), use the no-arg
        # form — `ref eq 'ARRAY'` is `ref($_) eq 'ARRAY'`. Without this,
        # the parser tried to consume `eq` as a unary expression operand
        # and errored "expected RPAREN, got STRING 'ARRAY'" on common
        # `if (ref eq 'ARRAY')` idioms (used by deep-flatten and JSON-style
        # dispatch loops).
        if ($name eq "ref" && _peek_type($p) ne "LPAREN") {
            my scalar $node = Perla::AST::node(Perla::AST::N_CALL());
            $node->{"name"} = "ref";
            $node->{"args"} = [];
            my str $rnt = _peek_type($p);
            my int $no_arg = 0;
            if ($rnt eq "SEMI" || $rnt eq "RBRACE" || $rnt eq "RPAREN"
                || $rnt eq "COMMA" || $rnt eq "FAT_ARROW" || $rnt eq "OP"
                || $rnt eq "EQ_OP" || $rnt eq "QUESTION" || $rnt eq "COLON"
                || _at_end($p)) {
                $no_arg = 1;
            }
            if ($no_arg == 0) {
                push(@{$node->{"args"}}, _parse_unary($p));
            }
            return $node;
        }

        # sort { $a <=> $b } @list
        # Skip sort-keyword handling when followed by `=>` — bareword
        # hash-key auto-quote applies. e.g. `(sort => "desc")` is the
        # hash entry "sort" => "desc", not a sort call.
        if ($name eq "sort" && _peek_type($p) ne "FAT_ARROW") {
            if (_peek_type($p) eq "LBRACE") {
                my scalar $node = Perla::AST::node(Perla::AST::N_SORT());
                $node->{"block"} = _parse_block($p);
                # Collect comma-separated list elements (sort { } "a", "b")
                my scalar $first_l = _parse_expr($p);
                if (_peek_type($p) eq "COMMA") {
                    my scalar $ll = Perla::AST::node(Perla::AST::N_ANON_ARRAY());
                    $ll->{"elems"} = [$first_l];
                    $ll->{"is_ref"} = 0;
                    while (_peek_type($p) eq "COMMA") {
                        _advance($p);
                        if (_peek_type($p) eq "RPAREN" || _peek_type($p) eq "RBRACKET" || _peek_type($p) eq "RBRACE" || _peek_type($p) eq "SEMI" || _at_end($p)) { last; }
                        push(@{$ll->{"elems"}}, _parse_expr($p));
                    }
                    $node->{"list"} = $ll;
                } else {
                    $node->{"list"} = $first_l;
                }
                return $node;
            }
            # sort SUBNAME LIST or sort $coderef LIST — comparator is a
            # bareword sub name or scalar holding a code ref. Required by
            # JSON::backportPP::_sort which has
            #   defined $keysort ? (sort $keysort (keys %{$_[0]})) : ...
            # The parser hit "expected RPAREN got LPAREN" on the `(keys`
            # because it parsed `sort $keysort` as an expression but
            # didn't expect the LIST that followed.
            if (_peek_type($p) eq "SCALAR_VAR") {
                my int $save_pos = $p->{"pos"};
                my scalar $cmp = _parse_postfix($p);
                # If next token starts a list expression (LPAREN, IDENT,
                # ARRAY_VAR, etc.), this is sort SCALAR LIST. Otherwise
                # back up and let the no-block path handle it.
                my str $nt = _peek_type($p);
                # Accept the same list-starters as the named-comparator (IDENT)
                # branch below — notably QW/INT/NUM/STRING/keys/values/etc.
                # Without QW, `sort $cmp qw(...)` mis-parsed `$cmp` as the first
                # list element (so the coderef stringified into the output).
                if ($nt eq "LPAREN" || $nt eq "ARRAY_VAR" || $nt eq "SCALAR_VAR" ||
                    $nt eq "IDENT" || $nt eq "DEREF_HASH_START" || $nt eq "DEREF_ARRAY_START" ||
                    $nt eq "DEREF_ARRAY_SIGIL" || $nt eq "DEREF_HASH_SIGIL" ||
                    $nt eq "INT" || $nt eq "NUM" || $nt eq "STRING" || $nt eq "DQSTRING" || $nt eq "QW" ||
                    $nt eq "KEYS" || $nt eq "VALUES" || $nt eq "MAP" || $nt eq "GREP" ||
                    $nt eq "SORT" || $nt eq "REVERSE") {
                    my scalar $node = Perla::AST::node(Perla::AST::N_SORT());
                    $node->{"comparator_expr"} = $cmp;
                    $node->{"list"} = _parse_sort_list($p);
                    return $node;
                }
                # Not a sort SCALAR LIST form — restore and fall through.
                $p->{"pos"} = $save_pos;
            }
            # sort SUBNAME LIST — bareword comparator.
            # If the next IDENT is followed by a list-starter (LPAREN,
            # ARRAY_VAR, SCALAR_VAR, IDENT, INT, STRING), treat the
            # IDENT as the named comparator sub. EXCEPTION: when the
            # IDENT is a known Perl builtin name (`glob`, `reverse`, etc.)
            # followed by LPAREN, treat as expression list — `sort glob(...)`
            # is `sort EXPR`, not `sort SUBNAME LIST`.
            if (_peek_type($p) eq "IDENT") {
                my int $save_pos = $p->{"pos"};
                my int $next_pos = $p->{"pos"} + 1;
                my str $nnt = "";
                if ($next_pos < $p->{"len"}) {
                    $nnt = $p->{"tokens"}->[$next_pos]->{"type"};
                }
                if ($nnt eq "LPAREN" || $nnt eq "ARRAY_VAR" || $nnt eq "SCALAR_VAR" ||
                    $nnt eq "IDENT" || $nnt eq "INT" || $nnt eq "NUM" ||
                    $nnt eq "STRING" || $nnt eq "DQSTRING" || $nnt eq "DEREF_HASH_START" || $nnt eq "DEREF_ARRAY_START" ||
                    $nnt eq "DEREF_ARRAY_SIGIL" || $nnt eq "DEREF_HASH_SIGIL" ||
                    $nnt eq "QW" || $nnt eq "KEYS" || $nnt eq "VALUES" ||
                    $nnt eq "MAP" || $nnt eq "GREP" || $nnt eq "SORT" ||
                    $nnt eq "REVERSE") {
                    my str $cand_name = $p->{"tokens"}->[$p->{"pos"}]->{"value"};
                    # When followed by LPAREN, exclude known builtins that
                    # commonly appear as `sort BUILTIN(...)`.
                    my int $is_builtin = 0;
                    if ($nnt eq "LPAREN") {
                        if ($cand_name eq "glob" || $cand_name eq "reverse" ||
                            $cand_name eq "readdir" || $cand_name eq "caller" ||
                            $cand_name eq "localtime" || $cand_name eq "gmtime" ||
                            $cand_name eq "stat" || $cand_name eq "lstat" ||
                            $cand_name eq "unpack" || $cand_name eq "sprintf" ||
                            $cand_name eq "lc" || $cand_name eq "uc" ||
                            $cand_name eq "ucfirst" || $cand_name eq "lcfirst" ||
                            $cand_name eq "abs" || $cand_name eq "int" ||
                            $cand_name eq "sqrt" || $cand_name eq "sprintf" ||
                            $cand_name eq "wantarray" || $cand_name eq "defined" ||
                            $cand_name eq "ref" || $cand_name eq "exists" ||
                            $cand_name eq "delete" || $cand_name eq "scalar" ||
                            $cand_name eq "chr" || $cand_name eq "ord" ||
                            $cand_name eq "length" || $cand_name eq "index" ||
                            $cand_name eq "rindex" || $cand_name eq "substr" ||
                            $cand_name eq "hex" || $cand_name eq "oct") {
                            $is_builtin = 1;
                        }
                    }
                    if ($is_builtin == 0) {
                        my str $sub_name = _advance($p)->{"value"};
                        my scalar $node = Perla::AST::node(Perla::AST::N_SORT());
                        $node->{"cmp_sub"} = $sub_name;
                        $node->{"list"} = _parse_sort_list($p);
                        return $node;
                    }
                }
                $p->{"pos"} = $save_pos;
            }
            # sort(SUBNAME LIST) — bareword comparator inside parens.
            # Same disambiguation as the no-parens form: if the token after
            # LPAREN is IDENT followed by a list-starter, treat as named cmp.
            if (_peek_type($p) eq "LPAREN") {
                my int $save_pos = $p->{"pos"};
                _advance($p);  # consume LPAREN
                if (_peek_type($p) eq "IDENT") {
                    my int $next_pos = $p->{"pos"} + 1;
                    my str $nnt = "";
                    if ($next_pos < $p->{"len"}) {
                        $nnt = $p->{"tokens"}->[$next_pos]->{"type"};
                    }
                    if ($nnt eq "ARRAY_VAR" || $nnt eq "SCALAR_VAR" ||
                        $nnt eq "IDENT" || $nnt eq "INT" || $nnt eq "NUM" ||
                        $nnt eq "STRING" || $nnt eq "DEREF_HASH_START" || $nnt eq "DEREF_ARRAY_START") {
                        my str $sub_name = _advance($p)->{"value"};
                        my scalar $node = Perla::AST::node(Perla::AST::N_SORT());
                        $node->{"cmp_sub"} = $sub_name;
                        # Parse the list — comma-separated expressions up to RPAREN.
                        my scalar $first_l = _parse_expr($p);
                        if (_peek_type($p) eq "COMMA") {
                            my scalar $ll = Perla::AST::node(Perla::AST::N_ANON_ARRAY());
                            $ll->{"elems"} = [$first_l];
                            $ll->{"is_ref"} = 0;
                            while (_peek_type($p) eq "COMMA") {
                                _advance($p);
                                if (_peek_type($p) eq "RPAREN" || _at_end($p)) { last; }
                                push(@{$ll->{"elems"}}, _parse_expr($p));
                            }
                            $node->{"list"} = $ll;
                        } else {
                            $node->{"list"} = $first_l;
                        }
                        if (_peek_type($p) eq "RPAREN") { _advance($p); }
                        return $node;
                    }
                }
                # sort($coderef LIST) — scalar/coderef comparator inside
                # sort's immediate parens (mirrors the no-paren SCALAR_VAR
                # form). Without this, `sort($f 3,1,2)` took $f as the first
                # list element and stringified the coderef.
                if (_peek_type($p) eq "SCALAR_VAR") {
                    my int $cmp_save = $p->{"pos"};
                    my scalar $cmp = _parse_postfix($p);
                    my str $nt2 = _peek_type($p);
                    if ($nt2 eq "LPAREN" || $nt2 eq "ARRAY_VAR" || $nt2 eq "SCALAR_VAR" ||
                        $nt2 eq "IDENT" || $nt2 eq "INT" || $nt2 eq "NUM" ||
                        $nt2 eq "STRING" || $nt2 eq "DQSTRING" || $nt2 eq "QW" ||
                        $nt2 eq "DEREF_HASH_START" || $nt2 eq "DEREF_ARRAY_START" ||
                        $nt2 eq "DEREF_ARRAY_SIGIL" || $nt2 eq "DEREF_HASH_SIGIL" ||
                        $nt2 eq "KEYS" || $nt2 eq "VALUES" || $nt2 eq "MAP" ||
                        $nt2 eq "GREP" || $nt2 eq "SORT" || $nt2 eq "REVERSE") {
                        my scalar $node = Perla::AST::node(Perla::AST::N_SORT());
                        $node->{"comparator_expr"} = $cmp;
                        $node->{"list"} = _parse_sort_list($p);
                        if (_peek_type($p) eq "RPAREN") { _advance($p); }
                        return $node;
                    }
                    $p->{"pos"} = $cmp_save;
                }
                $p->{"pos"} = $save_pos;
            }
            # sort without block: default alphabetical sort. Collect
            # comma-list (sort "a", "b").
            if (_peek_type($p) ne "LPAREN") {
                my scalar $node = Perla::AST::node(Perla::AST::N_SORT());
                my scalar $first_l = _parse_expr($p);
                if (_peek_type($p) eq "COMMA") {
                    my scalar $ll = Perla::AST::node(Perla::AST::N_ANON_ARRAY());
                    $ll->{"elems"} = [$first_l];
                    $ll->{"is_ref"} = 0;
                    while (_peek_type($p) eq "COMMA") {
                        _advance($p);
                        if (_peek_type($p) eq "RPAREN" || _peek_type($p) eq "RBRACKET" || _peek_type($p) eq "RBRACE" || _peek_type($p) eq "SEMI" || _at_end($p)) { last; }
                        push(@{$ll->{"elems"}}, _parse_expr($p));
                    }
                    $node->{"list"} = $ll;
                } else {
                    $node->{"list"} = $first_l;
                }
                return $node;
            }
        }

        # IDENT { BLOCK } LIST - block-first calling convention (any, all, first, none, reduce, try, etc.)
        # `IDENT { BLOCK } LIST` is the block-first calling convention used
        # by map/grep/first/any/all/reduce/try etc. Restricted to a known
        # allowlist — other functions with prototypes like `(&@)` (e.g.
        # Context::Preserve's `preserve_context { … } replace => sub { … }`)
        # should compile as regular function calls with the block as a
        # coderef arg, not as grep-style filter iterations. Without the
        # allowlist, perla generated grep codegen for arbitrary user-defined
        # block-first functions, treating the block as a filter and the
        # arg-pairs as the list to iterate — DBIC's BlockRunner relied on
        # preserve_context for context-aware return; perla returned an
        # empty list so every dbh_do query never executed.
        my int $is_block_first = 0;
        if ($name eq "first" || $name eq "any" || $name eq "all" ||
            $name eq "none" || $name eq "notall" || $name eq "reduce" ||
            $name eq "try" || $name eq "catch" || $name eq "finally" ||
            $name eq "uniq" || $name eq "min" || $name eq "max" ||
            $name eq "minstr" || $name eq "maxstr" || $name eq "sum" || $name eq "sum0" ||
            $name eq "pairgrep" || $name eq "pairmap" || $name eq "pairfirst") {
            $is_block_first = 1;
        }
        if (_peek_type($p) eq "LBRACE" && $is_block_first == 1) {
            my scalar $node = Perla::AST::node(Perla::AST::N_GREP());
            $node->{"name"} = $name;
            $node->{"block"} = _parse_block($p);
            # `try { ... } catch (VAR)? { ... } finally { ... }` — the perl
            # 5.34 try/catch syntax. The historical block-first path only
            # accepted `catch { ... }` (with the error in $_), so `catch
            # ($e) { ... }` left $e unbound and the catch block ran with
            # an empty value. Walk a tail of catch/finally clauses
            # explicitly so the catch's variable name is captured as
            # `catch_var` for the codegen.
            if ($name eq "try" || $name eq "catch") {
                while (_peek_type($p) eq "IDENT"
                    && (_peek_val($p) eq "catch" || _peek_val($p) eq "finally")) {
                    my str $cl_name = _advance($p)->{"value"};
                    my scalar $cl_node = Perla::AST::node(Perla::AST::N_GREP());
                    $cl_node->{"name"} = $cl_name;
                    # Optional `(VAR)` between `catch` and `{`. perl
                    # accepts only a single scalar lexical for `catch`.
                    if ($cl_name eq "catch" && _peek_type($p) eq "LPAREN") {
                        _advance($p);
                        if (_peek_type($p) eq "SCALAR_VAR") {
                            $cl_node->{"catch_var"} = _advance($p)->{"value"};
                        }
                        _expect($p, "RPAREN");
                    }
                    # _parse_block expects LBRACE next; if missing, it
                    # errors with the usual "expected LBRACE" message.
                    $cl_node->{"block"} = _parse_block($p);
                    # Chain: try's list = catch's; catch's list = finally's.
                    my scalar $tail = $node;
                    while (defined($tail->{"list"})
                        && $tail->{"list"}->{"type"} == Perla::AST::N_GREP()
                        && (defined($tail->{"list"}->{"name"}))) {
                        $tail = $tail->{"list"};
                    }
                    $tail->{"list"} = $cl_node;
                }
                return $node;
            }
            # Parse list args after block (catch { }, finally { }, list elements)
            # Stop at expression terminators: ;  )  }  &&  ||  and  or  ?  :  ,
            my str $nt2 = _peek_type($p);
            my str $nv2 = _at_end($p) ? "" : _peek_val($p);
            if ($nt2 ne "SEMI" && $nt2 ne "RBRACE" && $nt2 ne "RPAREN" &&
                $nt2 ne "COMMA" && $nt2 ne "EOF" &&
                !($nt2 eq "OP" && ($nv2 eq "&&" || $nv2 eq "||" || $nv2 eq "?" ||
                  $nv2 eq ":" || $nv2 eq "!" || $nv2 eq "and" || $nv2 eq "or" ||
                  $nv2 eq ".")) && !_at_end($p)) {
                my scalar $first_l = _parse_expr($p);
                # Collect additional comma-separated args:
                # `reduce { ... } 10, 20, 30` — all three need to be in the
                # list, not just the first.
                # FAT_ARROW (`=>`) is fat comma in Perl — same as `,` in
                # list context. Without it, `pairmap { ... } a => 1, b => 2`
                # parsed only `"a"` as the list and dropped the rest into
                # a sibling statement.
                if (_peek_type($p) eq "COMMA" || _peek_type($p) eq "FAT_ARROW") {
                    my scalar $ll = Perla::AST::node(Perla::AST::N_ANON_ARRAY());
                    $ll->{"elems"} = [$first_l];
                    $ll->{"is_ref"} = 0;
                    while (_peek_type($p) eq "COMMA" || _peek_type($p) eq "FAT_ARROW") {
                        _advance($p);
                        if (_peek_type($p) eq "RPAREN" || _peek_type($p) eq "SEMI" || _at_end($p)) { last; }
                        push(@{$ll->{"elems"}}, _parse_expr($p));
                    }
                    $node->{"list"} = $ll;
                } else {
                    $node->{"list"} = $first_l;
                }
            }
            return $node;
        }
        # IDENT { BLOCK } LIST when IDENT isn't a known block-first builtin:
        # treat as a regular function call with the block converted to an
        # anonymous-sub coderef. Matches Perl's prototype-`(&@)` semantics.
        if (_peek_type($p) eq "LBRACE" && $name ne "sort" && $name ne "map" && $name ne "grep" && $name ne "bless" && $name ne "return" && $name ne "push" && $name ne "unshift" && $name ne "die" && $name ne "warn" && $name ne "print" && $name ne "say" && $name ne "printf" && $name ne "throw" && $name ne "exit") {
            my scalar $block = _parse_block($p);
            # Wrap the block as an anonymous sub — N_SUB with NO name field
            # set (name must be undef, not "") so the codegen's
            # `N_SUB && !defined(name)` branch fires and emits a closure
            # value instead of treating it as a (named) declaration.
            my scalar $anon = Perla::AST::node(Perla::AST::N_SUB());
            $anon->{"body"} = $block;
            $anon->{"params"} = [];
            my scalar $node = Perla::AST::node(Perla::AST::N_CALL());
            $node->{"name"} = $name;
            $node->{"args"} = [$anon];
            $node->{"line"} = $__call_line;
            # Parse remaining args. Perl's prototype semantics:
            #   `&`      — single-block sub. After the block, the call ends.
            #   `&@`     — block + list. List args follow with NO comma
            #              between the closing `}` and the first arg.
            #   `&;...`  — block + optional rest. Same — list args follow
            #              directly without a leading comma.
            # In all cases, a COMMA right after the `}` belongs to the
            # OUTER context (e.g., `print "x:", fn { ... }, "\n"` — the
            # comma + "\n" are print's args, not fn's). The previous
            # implementation eagerly slurped through commas, breaking
            # this idiom.
            my str $nt2 = _peek_type($p);
            my str $nv2 = _at_end($p) ? "" : _peek_val($p);
            # If the next token is COMMA, the function call is done —
            # the comma separates this call's result from a sibling
            # expression in the enclosing list.
            if ($nt2 ne "COMMA" && $nt2 ne "FAT_ARROW") {
                while ($nt2 ne "SEMI" && $nt2 ne "RBRACE" && $nt2 ne "RPAREN" &&
                       $nt2 ne "EOF" && !_at_end($p) &&
                       !($nt2 eq "OP" && ($nv2 eq "&&" || $nv2 eq "||" || $nv2 eq "?" ||
                         $nv2 eq ":" || $nv2 eq "!" || $nv2 eq "and" || $nv2 eq "or"))) {
                    if ($nt2 eq "COMMA" || $nt2 eq "FAT_ARROW") { _advance($p); }
                    else {
                        push(@{$node->{"args"}}, _parse_assign($p));
                    }
                    $nt2 = _peek_type($p);
                    $nv2 = _at_end($p) ? "" : _peek_val($p);
                }
            }
            return $node;
        }

        # Function call with parens
        if (_peek_type($p) eq "LPAREN") {
            _advance($p);
            my scalar $node = Perla::AST::node(Perla::AST::N_CALL());
            $node->{"name"} = $name;
            $node->{"args"} = [];
            $node->{"has_parens"} = 1;
            $node->{"line"} = $__call_line;
            while (_peek_type($p) ne "RPAREN" && !_at_end($p)) {
                push(@{$node->{"args"}}, _parse_assign($p));
                # Consume comma or fat arrow (=> acts like comma in arg lists)
                if (_peek_type($p) eq "COMMA" || _peek_type($p) eq "FAT_ARROW") {
                    _advance($p);
                }
            }
            _expect($p, "RPAREN");
            return $node;
        }

        # Bareword used as hash key (before =>)
        if (_peek_type($p) eq "FAT_ARROW") {
            return Perla::AST::node_with(Perla::AST::N_STR_LIT(), "value", $name);
        }

        # Indirect-object method call: `METHOD CLASSNAME(args...)` →
        # `CLASSNAME->METHOD(args)`. Perl supports this for any method
        # but most uses are `new ClassName(...)` (constructor invocation).
        # Locale::Country and many old CPAN modules use this idiom; without
        # this, `new Locale::Codes('country')` parses as
        # `new(Locale::Codes('country'))` — calling sub `new` in main with
        # the result of sub `Locale::Codes('country')` as arg, neither of
        # which exists.
        # We narrow to `new` (the canonical case) plus the existing
        # import/unimport handling. `new IDENT(...)` with IDENT being a
        # capitalized class name is the indirect form.
        if ($name eq "new" && _peek_type($p) eq "IDENT") {
            my str $next_val = _peek_val($p);
            # Class name must start with uppercase letter (Perl convention
            # for class names; this filters out `new $var` etc.).
            my int $first_ch = char_at($next_val, 0);
            if (length($next_val) > 0 && $first_ch >= 65 && $first_ch <= 90) {
                my int $save_pos2 = $p->{"pos"};
                my str $class_name = _advance($p)->{"value"};
                while (_peek_type($p) eq "PKG_SEP") {
                    _advance($p);
                    if (_peek_type($p) eq "IDENT" || _peek_type($p) eq "PACKAGE") {
                        $class_name = $class_name . "::" . _advance($p)->{"value"};
                    }
                }
                # After the class name we expect either ( args ) or
                # nothing (indirect-object with no args). `new Foo + 1`
                # would be ambiguous; we don't try to handle that here.
                my scalar $mnode = Perla::AST::node(Perla::AST::N_METHOD());
                my scalar $obj = Perla::AST::node(Perla::AST::N_STR_LIT());
                $obj->{"value"} = $class_name;
                $mnode->{"object"} = $obj;
                $mnode->{"method"} = "new";
                $mnode->{"args"} = [];
                if (_peek_type($p) eq "LPAREN") {
                    _advance($p);
                    while (_peek_type($p) ne "RPAREN" && !_at_end($p)) {
                        push(@{$mnode->{"args"}}, _parse_assign($p));
                        if (_peek_type($p) eq "COMMA") { _advance($p); }
                    }
                    _expect($p, "RPAREN");
                }
                return $mnode;
            }
        }
        # Indirect-object method call for `import`/`unimport`/`no`: the form
        #   import warnings;
        #   unimport strict;
        # is Perl's indirect-object syntax for CLASS->METHOD. Without this,
        # `import warnings;` parses as `import("warnings")` and, when it
        # appears inside a sub that IS the current package's import (e.g.,
        # Mo::Inline's installed import body), recurses into itself until
        # the stack overflows.
        # Only the narrow case (IDENT directly followed by a bareword IDENT
        # with no parens/paren args on `import`) is treated as indirect -
        # `import($foo)` and `import("x", "y")` remain normal function calls.
        if (($name eq "import" || $name eq "unimport") && _peek_type($p) eq "IDENT") {
            my str $class_name = _advance($p)->{"value"};
            # Handle further :: tokens for Foo::Bar::Baz class names.
            while (_peek_type($p) eq "PKG_SEP") {
                _advance($p);
                if (_peek_type($p) eq "IDENT" || _peek_type($p) eq "PACKAGE") {
                    $class_name = $class_name . "::" . _advance($p)->{"value"};
                }
            }
            my scalar $mnode = Perla::AST::node(Perla::AST::N_METHOD());
            my scalar $obj = Perla::AST::node(Perla::AST::N_STR_LIT());
            $obj->{"value"} = $class_name;
            $mnode->{"object"} = $obj;
            $mnode->{"method"} = $name;
            $mnode->{"args"} = [];
            # Additional args (rare): `import warnings 'qw(foo bar)';`
            while (_peek_type($p) ne "SEMI" && _peek_type($p) ne "RBRACE" && !_at_end($p)) {
                push(@{$mnode->{"args"}}, _parse_assign($p));
                if (_peek_type($p) eq "COMMA") { _advance($p); } else { last; }
            }
            return $mnode;
        }

        # Print/say with list args (no parens): print "hello\n"; or print $fh "text";
        if ($name eq "print" || $name eq "say" || $name eq "die" || $name eq "warn" || $name eq "printf") {
            my scalar $node = Perla::AST::node(Perla::AST::N_CALL());
            $node->{"name"} = $name;
            $node->{"args"} = [];
            $node->{"line"} = $__call_line;
            # Skip arg parsing entirely when the next token is a
            # statement-modifier keyword (if/unless/while/until/for/
            # foreach). `print for @arr` should be the bare `print;`
            # (prints $_) with a postfix-for; without this exclusion
            # the parser called _parse_assign on the FOR keyword and
            # produced an undef "first arg" that the codegen then
            # treated as the filehandle.
            if (_peek_type($p) ne "SEMI" && _peek_type($p) ne "RBRACE"
                && _peek_type($p) ne "IF" && _peek_type($p) ne "UNLESS"
                && _peek_type($p) ne "WHILE" && _peek_type($p) ne "UNTIL"
                && _peek_type($p) ne "FOR" && _peek_type($p) ne "FOREACH"
                && !_at_end($p)) {
                # Block-form filehandle: `print {$fh} LIST` or `print {*STDERR} LIST`.
                # The `{...}` is the filehandle expression, followed by LIST.
                # Without this, `print {$fh} "msg"` was parsed with $fh as a
                # standalone arg and the message disappeared (or worse, a
                # syntax error somewhere downstream).
                if (($name eq "print" || $name eq "say" || $name eq "printf")
                    && _peek_type($p) eq "LBRACE") {
                    # Save pos in case the `{` is actually an anon-hash arg
                    # (rare but possible). If the parsed expression looks
                    # like a hash literal (key => value pairs), bail out and
                    # treat as normal args.
                    my int $save_pos = $p->{"pos"};
                    _advance($p);  # consume `{`
                    my scalar $fh_expr = _parse_expr($p);
                    if (_peek_type($p) eq "RBRACE") {
                        _advance($p);
                        $node->{"fh"} = $fh_expr;
                        $node->{"args"} = [];
                        # Parse the LIST that follows
                        if (_peek_type($p) ne "SEMI" && _peek_type($p) ne "RBRACE"
                            && _peek_type($p) ne "COMMA" && !_at_end($p)) {
                            push(@{$node->{"args"}}, _parse_assign($p));
                            while (_match($p, "COMMA")) {
                                push(@{$node->{"args"}}, _parse_assign($p));
                            }
                        }
                        return $node;
                    }
                    # Mismatched/wrong shape — restore and fall through
                    $p->{"pos"} = $save_pos;
                }
                # Bareword-filehandle disambiguation for print/say:
                # `print STDERR "msg"` should parse as `print_fh(STDERR, "msg")`,
                # NOT `print(STDERR("msg"))`. Without this, _parse_assign sees
                # IDENT "STDERR" and treats it as a function call that greedily
                # consumes the message as its argument — Carp::carp output and
                # any module that prints to STDERR via the bareword form
                # silently disappears.
                # Detect bareword-FH: STDOUT/STDERR/STDIN by name, or any
                # other all-uppercase identifier (FH, FH2, LOG, OUT, etc).
                # Treating an arbitrary uppercase bareword as a FH only fires
                # when the next token starts an arg (not LPAREN/COMMA/SEMI),
                # so `TIME()` calls still work; only `print FH "msg"` form
                # is captured.
                my int $is_bw_fh = 0;
                if (($name eq "print" || $name eq "say" || $name eq "printf")
                    && _peek_type($p) eq "IDENT") {
                    my str $bwname = _peek_val($p);
                    if ($bwname eq "STDOUT" || $bwname eq "STDERR" || $bwname eq "STDIN") {
                        $is_bw_fh = 1;
                    } else {
                        # Heuristic: length >= 2, first char A-Z, rest A-Z/0-9/_
                        my int $bwlen = length($bwname);
                        if ($bwlen >= 2) {
                            my str $bw_first = substr($bwname, 0, 1);
                            if ($bw_first ge "A" && $bw_first le "Z") {
                                my int $bw_ok = 1;
                                my int $bw_i = 1;
                                while ($bw_i < $bwlen) {
                                    my str $bw_c = substr($bwname, $bw_i, 1);
                                    if (!(($bw_c ge "A" && $bw_c le "Z") || ($bw_c ge "0" && $bw_c le "9") || $bw_c eq "_")) {
                                        $bw_ok = 0;
                                        $bw_i = $bwlen;
                                    }
                                    $bw_i = $bw_i + 1;
                                }
                                if ($bw_ok == 1) { $is_bw_fh = 1; }
                            }
                        }
                    }
                }
                if ($is_bw_fh == 1) {
                    # Lookahead one token: next must be something that begins
                    # an arg (string, scalar var, etc), not a `(` (which would
                    # mean STDOUT(...) is intended as a real call).
                    my int $next_pos = $p->{"pos"} + 1;
                    my int $is_fh = 0;
                    if ($next_pos < $p->{"len"}) {
                        my str $nt = $p->{"tokens"}->[$next_pos]->{"type"};
                        # If next token is LPAREN, treat as a sub call.
                        # If next is COMMA/SEMI/RBRACE, the FH stands alone (rare).
                        # If next is ARROW, the bareword is a class name
                        # being method-called (`print M_A->new->greet`).
                        # Without the ARROW exclusion, `print M_A->new`
                        # parsed as `print_fh(M_A, ->new->...)` and stripped
                        # the class — perla then dispatched on the literal
                        # string "new" via the trailing chain. The package
                        # M_A matched the "FH-shaped bareword" heuristic
                        # because it's UPPER_UNDERSCORE.
                        # PKG_SEP (`::`) covers `print Foo::Bar->new(...)`.
                        if ($nt ne "LPAREN" && $nt ne "COMMA" && $nt ne "SEMI"
                            && $nt ne "RBRACE" && $nt ne "RPAREN" && $nt ne "EOF"
                            && $nt ne "ARROW" && $nt ne "PKG_SEP"
                            && $nt ne "FAT_ARROW" && $nt ne "OP") {
                            # OP exclusion handles `printf FORMAT . "\n",
                            # ...` — without it, FORMAT (an uppercase
                            # `use constant FORMAT => "..."`) matched the
                            # FH-shaped-bareword heuristic and ate the
                            # rest of the call. The next token is `.`
                            # (concat OP), which means FORMAT is being
                            # USED as a value in an expression, not as a
                            # filehandle.
                            $is_fh = 1;
                        }
                    }
                    if ($is_fh == 1) {
                        my str $fh_name = _advance($p)->{"value"};
                        # Mark on the node directly — codegen reads
                        # `fh_bareword` and emits `stderr`/`stdout`/`stdin`
                        # via fprintf, since v_STDERR etc. aren't defined
                        # symbols (they're externs nothing satisfies).
                        $node->{"fh_bareword"} = $fh_name;
                        push(@{$node->{"args"}}, _parse_assign($p));
                        while (_match($p, "COMMA")) {
                            push(@{$node->{"args"}}, _parse_assign($p));
                        }
                        return $node;
                    }
                }
                my scalar $first = _parse_assign($p);
                push(@{$node->{"args"}}, $first);
                # Check for filehandle pattern: print $fh EXPR (no comma after first arg).
                # Don't enter this branch for postfix statement modifiers
                # (IF/UNLESS/WHILE/UNTIL/FOR/FOREACH) — they belong to the
                # enclosing statement, not to print. Without this exclusion,
                # `print "x: $_\n" for (1..3);` parsed "x: $_\n" as a
                # filehandle and tried to read content starting at `for`,
                # silently dropping the loop and emitting nothing.
                # Also bail when the next token is a low-precedence boolean
                # OP (`and`/`or`/`xor`/`not`) — `print "x" and FOO` should
                # parse as `(print "x") and FOO`, not as filehandle "x"
                # followed by content FOO. Without this exclusion, the
                # filehandle-fallback consumed everything past the first
                # arg, the print silently produced bogus output, and the
                # original first string never printed. Surfaced via
                # `print "msg\n" and chomp;` patterns.
                my int $__bool_op = 0;
                if (_peek_type($p) eq "OP") {
                    my str $__pv = _peek_val($p);
                    if ($__pv eq "and" || $__pv eq "or" || $__pv eq "xor" || $__pv eq "not") {
                        $__bool_op = 1;
                    }
                }
                if (($name eq "print" || $name eq "say" || $name eq "printf") && _peek_type($p) ne "SEMI" && _peek_type($p) ne "COMMA" && _peek_type($p) ne "RBRACE"
                    && _peek_type($p) ne "IF" && _peek_type($p) ne "UNLESS"
                    && _peek_type($p) ne "WHILE" && _peek_type($p) ne "UNTIL"
                    && _peek_type($p) ne "FOR" && _peek_type($p) ne "FOREACH"
                    && $__bool_op == 0
                    && !_at_end($p)) {
                    # First arg was filehandle - mark it and parse content
                    $node->{"fh"} = $first;
                    $node->{"args"} = [];
                    push(@{$node->{"args"}}, _parse_assign($p));
                }
                while (_match($p, "COMMA")) {
                    push(@{$node->{"args"}}, _parse_assign($p));
                }
            }
            return $node;
        }

        # Named unary operators. Perl's precedence places these between the
        # binary `.` (additive/concat at level 7) and comparisons (`<` at
        # level 10), so `defined \$x and \$y` must parse as
        # `(defined \$x) and \$y`, not `defined (\$x and \$y)`. Using
        # _parse_assign as the argument parser was way too loose - it
        # greedily picked up and/or/= and produced garbage for common Perl
        # idioms like `_DRIVER`'s chain in File::HomeDir. _parse_concat
        # parses the right set of higher-precedence ops (.,  x, +, -, *, /)
        # without pulling in comparisons or low-prec boolean operators.
        if ($name eq "delete" || $name eq "exists" || $name eq "defined" ||
            $name eq "ref" || $name eq "reftype" || $name eq "blessed" ||
            $name eq "weaken" || $name eq "isweak" || $name eq "looks_like_number" ||
            $name eq "qsub" ||
            $name eq "chomp" || $name eq "chop" ||
            $name eq "pop" || $name eq "shift" || $name eq "each" ||
            $name eq "keys" || $name eq "values" || $name eq "scalar" ||
            $name eq "uc" || $name eq "lc" || $name eq "ucfirst" || $name eq "lcfirst" ||
            $name eq "length" || $name eq "chr" || $name eq "ord" || $name eq "abs" ||
            $name eq "caller" || $name eq "wantarray" ||
            $name eq "eval" ||
            $name eq "int" ||
            # Arithmetic named unaries
            $name eq "oct" || $name eq "hex" || $name eq "sqrt" ||
            $name eq "sin" || $name eq "cos" || $name eq "atan2" ||
            $name eq "log" || $name eq "exp" || $name eq "rand" || $name eq "srand" ||
            # I/O / system named unaries
            $name eq "close" || $name eq "closedir" || $name eq "eof" ||
            $name eq "fileno" || $name eq "readdir" || $name eq "readline" ||
            $name eq "readlink" || $name eq "rewinddir" || $name eq "telldir" ||
            $name eq "tell" || $name eq "tied" || $name eq "untie" ||
            $name eq "lstat" || $name eq "stat" ||
            $name eq "quotemeta" || $name eq "umask" || $name eq "alarm" ||
            $name eq "sleep" || $name eq "chdir" || $name eq "chroot" ||
            $name eq "rmdir" ||
            $name eq "glob" || $name eq "gmtime" || $name eq "localtime" ||
            # getpw*/getgr*/gethost*/getserv*/getproto* are named unaries
            $name eq "getpwnam" || $name eq "getpwuid" ||
            $name eq "getgrnam" || $name eq "getgrgid" ||
            $name eq "gethostbyname" || $name eq "gethostbyaddr" ||
            $name eq "getnetbyname" || $name eq "getnetbyaddr" ||
            $name eq "getprotobyname" || $name eq "getprotobynumber" ||
            $name eq "getservbyname" || $name eq "getservbyport") {
            if (_peek_type($p) ne "SEMI" && _peek_type($p) ne "RBRACE" &&
                _peek_type($p) ne "RPAREN" && _peek_type($p) ne "RBRACKET" &&
                _peek_type($p) ne "COMMA" &&
                _peek_type($p) ne "ARROW" &&
                # Statement-modifier keywords — `shift if @_`, `pop unless ...`,
                # `keys while ...` etc. should NOT swallow the modifier as
                # the named-unary arg. Without these, `\$self->{x} = shift if @_`
                # parsed as `\$self->{x} = shift(if @_)` and the if-modifier
                # was lost (setter ran unconditionally, getter calls clobbered
                # the slot).
                _peek_type($p) ne "IF" && _peek_type($p) ne "UNLESS" &&
                _peek_type($p) ne "WHILE" && _peek_type($p) ne "UNTIL" &&
                _peek_type($p) ne "FOR" && _peek_type($p) ne "FOREACH" &&
                # Don't swallow operators that can't start an operand.
                # Binary operators always need a left operand and can't
                # start a primary - seeing one after a named unary means
                # the named unary takes NO argument.
                # Missing this for `||`/`//`/`&&` caused `shift || 'default'`
                # (YAML::Mo's _new_error) to parse as `shift(|| 'default')`
                # and silently shift `strada_new_undef()` instead of @_,
                # producing an Error with undef code.
                !(_peek_type($p) eq "OP" && (_peek_val($p) eq "?" || _peek_val($p) eq ":"
                    || _peek_val($p) eq "." || _peek_val($p) eq "x"
                    || _peek_val($p) eq "||" || _peek_val($p) eq "&&" || _peek_val($p) eq "//"
                    || _peek_val($p) eq "==" || _peek_val($p) eq "!="
                    || _peek_val($p) eq "<" || _peek_val($p) eq ">"
                    || _peek_val($p) eq "<=" || _peek_val($p) eq ">=" || _peek_val($p) eq "<=>"
                    || _peek_val($p) eq "*" || _peek_val($p) eq "/" || _peek_val($p) eq "%"
                    || _peek_val($p) eq "|" || _peek_val($p) eq "^"
                    /* `&` is sub-call sigil when followed by IDENT/SCALAR_VAR/LBRACE,
                     * else bitwise-and. Required for `defined &SUB` to parse as
                     * `defined(&SUB)` rather than `(defined()) & (SUB())`. */
                    || (_peek_val($p) eq "&" && (
                        ($p->{"pos"} + 1 >= $p->{"len"})
                        || ($p->{"tokens"}->[$p->{"pos"} + 1]->{"type"} ne "IDENT"
                            && $p->{"tokens"}->[$p->{"pos"} + 1]->{"type"} ne "SCALAR_VAR"
                            && $p->{"tokens"}->[$p->{"pos"} + 1]->{"type"} ne "LBRACE")))
                    || _peek_val($p) eq "**" || _peek_val($p) eq "=~" || _peek_val($p) eq "!~"
                    # Low-precedence logical word ops — the Lexer tokenises
                    # `or`/`and`/`xor` as OP, not IDENT. Without these,
                    # `shift or DIE` swallowed `or DIE` as the shift arg and
                    # silently shifted from `strada_new_undef()`. YAML::Tiny's
                    # `my $file = shift or $class->_error("...")` saw an empty
                    # shift result, fired the _error unconditionally, and
                    # crashed Abe::App::init with "You did not specify a file
                    # name".
                    || _peek_val($p) eq "or" || _peek_val($p) eq "and" || _peek_val($p) eq "xor"
                    # Word comparison ops (cmp/eq/ne/lt/gt/le/ge) — same
                    # reason: tokenised as OP, must not be consumed as a
                    # named-unary argument.
                    || _peek_val($p) eq "cmp" || _peek_val($p) eq "eq" || _peek_val($p) eq "ne"
                    || _peek_val($p) eq "lt" || _peek_val($p) eq "gt"
                    || _peek_val($p) eq "le" || _peek_val($p) eq "ge")) &&
                !(_peek_type($p) eq "IDENT" && (_peek_val($p) eq "or" || _peek_val($p) eq "and"
                    || _peek_val($p) eq "xor" || _peek_val($p) eq "cmp" || _peek_val($p) eq "eq"
                    || _peek_val($p) eq "ne" || _peek_val($p) eq "lt" || _peek_val($p) eq "gt"
                    || _peek_val($p) eq "le" || _peek_val($p) eq "ge")) &&
                !_at_end($p)) {
                my scalar $node = Perla::AST::node(Perla::AST::N_CALL());
                $node->{"name"} = $name;
                $node->{"args"} = [];
                $node->{"line"} = $__call_line;
                push(@{$node->{"args"}}, _parse_concat($p));
                return $node;
            }
        }
        # Builtins that take multiple arguments without parens
        if ($name eq "push" || $name eq "unshift" ||
            $name eq "join" || $name eq "split" ||
            $name eq "bless" || $name eq "sprintf" ||
            $name eq "splice" || $name eq "open" ||
            $name eq "read" || $name eq "sysread" ||
            $name eq "seek" ||
            # No-parens forms: `opendir my $dh, $path` etc. — without
            # this, the multi-arg form silently parsed as a 1-arg call
            # (`opendir(my $dh)`) and the trailing path was dropped on
            # the floor. The filehandle came up undef, readdir returned
            # empty.
            $name eq "opendir" || $name eq "closedir" ||
            $name eq "rewinddir" || $name eq "telldir" ||
            $name eq "seekdir" ||
            # tie LVALUE, CLASS [, ARGS] — without this, `tie my $x,
            # 'Class'` parsed as `tie()` with $my-decl-and-class as a
            # separate expression, never actually tying the variable.
            # `untie $x` is a single-arg form but include it here so the
            # multi-arg path catches both.
            $name eq "tie" || $name eq "untie" ||
            # reverse LIST — without this, `reverse split /,/, "a,b,c"`
            # parsed the first split arg as reverse's only arg and
            # stranded the rest of split's args. As a multi-arg list
            # operator, the whole comma-list belongs to reverse, and
            # split's nested call eats `/,/, "a,b,c"` correctly.
            $name eq "reverse") {
            if (_peek_type($p) ne "SEMI" && _peek_type($p) ne "RBRACE" && !_at_end($p)) {
                my scalar $node = Perla::AST::node(Perla::AST::N_CALL());
                $node->{"name"} = $name;
                $node->{"args"} = [];
                $node->{"line"} = $__call_line;
                push(@{$node->{"args"}}, _parse_assign($p));
                # Accept both `,` and `=>` (fat-comma) as arg separators.
                # Perl parses `bless $self => $class` as `bless($self, $class)`
                # — without FAT_ARROW here we'd treat the `=>` as a comma
                # operator after `bless $self`, turning the call into a
                # 2-element list expression and freeing $self prematurely.
                while (_match($p, "COMMA") || _match($p, "FAT_ARROW")) {
                    # Trailing comma before RBRACE/RPAREN/SEMI/EOF is allowed
                    # in Perl ("the elephant operator" hooks). Without this
                    # check the parser tries _parse_assign on RBRACE and
                    # spirals into the enclosing block. Reproduces under
                    # `sprintf "fmt", $a, $b,\n}` — common in CPAN.
                    if (_peek_type($p) eq "RBRACE" || _peek_type($p) eq "RPAREN" ||
                        _peek_type($p) eq "RBRACKET" || _peek_type($p) eq "SEMI" ||
                        _at_end($p)) { last; }
                    push(@{$node->{"args"}}, _parse_assign($p));
                }
                return $node;
            }
        }

        # Bare identifier - if followed by variable tokens, treat as function call with args
        my scalar $node = Perla::AST::node(Perla::AST::N_CALL());
        $node->{"name"} = $name;
        $node->{"args"} = [];
        $node->{"line"} = $__call_line;
        my str $nt = _peek_type($p);
        if ($nt eq "SCALAR_VAR" || $nt eq "ARRAY_VAR" || $nt eq "HASH_VAR" ||
            $nt eq "STRING" || $nt eq "DQSTRING" || $nt eq "INT" || $nt eq "FLOAT" ||
            $nt eq "ARRAY_DEREF" ||
            $nt eq "SHIFT" || $nt eq "POP" || $nt eq "UNDEF" ||
            $nt eq "LBRACKET" || $nt eq "BACKSLASH" || $nt eq "IDENT" ||
            # Named list operators (map/grep/sort/reverse) can appear as args
            # to other named operators: `sum map { ... } @arr` is `sum(map(...))`.
            # Without these, `sum` was parsed as a 0-arg call and the map
            # expression became a dropped sibling statement.
            $nt eq "MAP" || $nt eq "GREP" || $nt eq "SORT" || $nt eq "REVERSE" ||
            # Anon sub as first arg: `take_sub sub { ... }` parses as
            # `take_sub(sub { ... })`. Without SUB here, the call captured
            # zero args and `sub { ... }` became a dropped sibling
            # expression. Mojo-/Catalyst-style DSLs (`get '/path' => sub
            # { ... }`, middleware push) hit this constantly.
            $nt eq "SUB" ||
            # `IDENT do { ... }` (do-block as expression first arg) and
            # `IDENT qw(...)` (word-list literal as first arg). Without
            # these, `f do { 1+2+3 }` parsed as `f()` plus the do-block
            # as a dropped sibling, and `f qw(a b c)` likewise.
            $nt eq "DO" || $nt eq "QW" ||
            # `IDENT my $x = ...` — Perl's named-unary path accepts a
            # my-decl as a value-producing expression. Without MY here,
            # `f my $x = "hi"` parsed as `f()` and the my-decl floated
            # off as a sibling. `defined my $x = …` works because
            # `defined` is in the named-unary list; this rescues
            # user-defined wrappers.
            $nt eq "MY") {
            push(@{$node->{"args"}}, _parse_assign($p));
            while (_peek_type($p) eq "COMMA" || _peek_type($p) eq "FAT_ARROW") {
                _advance($p);
                if (_peek_type($p) eq "RPAREN" || _peek_type($p) eq "SEMI") { last; }
                push(@{$node->{"args"}}, _parse_assign($p));
            }
        }
        return $node;
    }

    # Prefix ++ --
    if ($type eq "OP" && ($val eq "++" || $val eq "--")) {
        _advance($p);
        my scalar $operand = _parse_postfix($p);
        my scalar $node = Perla::AST::node(Perla::AST::N_UNOP());
        $node->{"op"} = $val;
        $node->{"operand"} = $operand;
        $node->{"prefix"} = 1;
        return $node;
    }

    # *Foo::bar or *{expr} - typeglob access
    if ($type eq "OP" && $val eq "*") {
        _advance($p);  # consume *
        # *{EXPR} - dynamic glob name from expression
        if (_peek_type($p) eq "LBRACE") {
            _advance($p);  # consume {
            my scalar $expr = _parse_expr($p);
            _match($p, "RBRACE");
            my scalar $node = Perla::AST::node(Perla::AST::N_GLOB_ACCESS());
            $node->{"name"} = "";
            $node->{"expr"} = $expr;
            # Optional trailing {SLOT} — typeglob slot access:
            # *{EXPR}{CODE}, *{EXPR}{SCALAR}, *{EXPR}{ARRAY}, *{EXPR}{HASH}
            if (_peek_type($p) eq "LBRACE") {
                _advance($p);
                if (_peek_type($p) eq "IDENT") {
                    $node->{"slot"} = _advance($p)->{"value"};
                }
                _match($p, "RBRACE");
            }
            return $node;
        }
        my str $glob_name = "";
        # Read the glob name: could be Foo::bar, or just bar.
        # Perl lets ANY identifier-shaped word be a glob name, including
        # builtin/reserved keywords (`*ref`, `*print`, `*die`, etc.) —
        # the lexer turns those into specific token types (REF_FUNC,
        # PRINT, DIE, ...) rather than plain IDENT, which previously
        # made `*ref = *orig` parse as `*` (name="") followed by a
        # separate `ref` call. Accept any token whose VALUE starts with
        # a letter or underscore (the identifier-shape check) so the
        # parse covers all built-in keyword names too.
        my str $__gn_pv = "" . _peek_val($p);
        my str $__gn_pt = _peek_type($p);
        my int $__gn_is_ident = 0;
        # The identifier-shape heuristic accepts keyword tokens (PRINT,
        # REF_FUNC, ...) as glob names — `*print`, `*ref`. But it must
        # NOT swallow a sigil variable: `*$fh` has a SCALAR_VAR next
        # whose VALUE ("fh") is identifier-shaped, yet it means a glob
        # DEREF of $fh, handled by the SCALAR_VAR elsif below. Exclude
        # sigil-var token types so they fall through to that branch.
        if (length($__gn_pv) > 0
            && $__gn_pt ne "SCALAR_VAR" && $__gn_pt ne "ARRAY_VAR"
            && $__gn_pt ne "HASH_VAR") {
            my str $__gn_c0 = substr($__gn_pv, 0, 1);
            if (($__gn_c0 >= "A" && $__gn_c0 <= "Z")
                || ($__gn_c0 >= "a" && $__gn_c0 <= "z")
                || $__gn_c0 eq "_") {
                $__gn_is_ident = 1;
            }
        }
        if (_peek_type($p) eq "IDENT" || _peek_type($p) eq "PACKAGE" || $__gn_is_ident == 1) {
            $glob_name = _advance($p)->{"value"};
            # Handle Foo::bar::baz
            while (_peek_type($p) eq "PKG_SEP") {
                _advance($p);
                my str $__gn2_pv = "" . _peek_val($p);
                my int $__gn2_id = 0;
                if (length($__gn2_pv) > 0) {
                    my str $__gn2_c0 = substr($__gn2_pv, 0, 1);
                    if (($__gn2_c0 >= "A" && $__gn2_c0 <= "Z")
                        || ($__gn2_c0 >= "a" && $__gn2_c0 <= "z")
                        || $__gn2_c0 eq "_") {
                        $__gn2_id = 1;
                    }
                }
                if (_peek_type($p) eq "IDENT" || $__gn2_id == 1) {
                    $glob_name = $glob_name . "::" . _advance($p)->{"value"};
                }
            }
        } elsif (_peek_type($p) eq "SCALAR_VAR") {
            # `*$fh` — glob-deref of the scalar $fh, NOT the named glob
            # `*fh`. For an open filehandle $fh is the handle itself;
            # `${*$fh}` then accesses the glob's SCALAR slot. Build the
            # expr (deref) form, mirroring `*{$fh}`, instead of treating
            # the var's NAME as a literal glob name (which dropped the
            # `$` and looked up a symbol-table glob that doesn't exist).
            my str $__gv_name = _advance($p)->{"value"};
            my scalar $__gv_expr = Perla::AST::node(Perla::AST::N_SCALAR_VAR());
            $__gv_expr->{"name"} = $__gv_name;
            my scalar $node = Perla::AST::node(Perla::AST::N_GLOB_ACCESS());
            $node->{"name"} = "";
            $node->{"expr"} = $__gv_expr;
            return $node;
        }
        my scalar $node = Perla::AST::node(Perla::AST::N_GLOB_ACCESS());
        $node->{"name"} = $glob_name;
        # Optional `*NAME{SLOT}` form — typeglob slot accessor.
        # CODE returns a code ref, SCALAR/ARRAY/HASH return refs to
        # the corresponding stash slots. IO returns the filehandle.
        if (_peek_type($p) eq "LBRACE") {
            my int $__sb_save = $p->{"pos"};
            _advance($p);
            if (_peek_type($p) eq "IDENT") {
                my str $__sb_slot = _peek_val($p);
                if ($__sb_slot eq "CODE" || $__sb_slot eq "SCALAR"
                    || $__sb_slot eq "ARRAY" || $__sb_slot eq "HASH"
                    || $__sb_slot eq "IO" || $__sb_slot eq "GLOB"
                    || $__sb_slot eq "NAME" || $__sb_slot eq "PACKAGE"
                    || $__sb_slot eq "FORMAT") {
                    _advance($p);  # consume slot name
                    if (_peek_type($p) eq "RBRACE") {
                        _advance($p);
                        $node->{"slot"} = $__sb_slot;
                        return $node;
                    }
                }
            }
            # Not a slot access — backtrack so a following `{...}`
            # subscript can be parsed by the postfix-chain loop above.
            $p->{"pos"} = $__sb_save;
        }
        return $node;
    }

    # &{EXPR} - code deref from expression, or &func(args)
    if ($type eq "OP" && $val eq "&") {
        _advance($p);  # consume &
        if (_peek_type($p) eq "LBRACE") {
            # &{EXPR} - dynamic code ref from string
            _advance($p);  # consume {
            my scalar $expr = _parse_expr($p);
            _expect($p, "RBRACE");
            # &{EXPR}(args) - call the code referenced by EXPR with args.
            # Build an N_CALL node with __coderef__ targeting a dynamic glob
            # lookup so the callee resolves at runtime.
            if (_peek_type($p) eq "LPAREN") {
                _advance($p);
                my scalar $glob = Perla::AST::node(Perla::AST::N_GLOB_ACCESS());
                $glob->{"name"} = "";
                $glob->{"expr"} = $expr;
                $glob->{"is_code_deref"} = 1;
                my scalar $call = Perla::AST::node(Perla::AST::N_CALL());
                $call->{"name"} = "__coderef__";
                $call->{"coderef"} = $glob;
                $call->{"args"} = [];
                while (_peek_type($p) ne "RPAREN" && !_at_end($p)) {
                    push(@{$call->{"args"}}, _parse_assign($p));
                    if (_peek_type($p) eq "COMMA" || _peek_type($p) eq "FAT_ARROW") { _advance($p); }
                }
                _expect($p, "RPAREN");
                return $call;
            }
            # `&{EXPR}` (no parens) — call the deref, passing caller's @_.
            # Same Perl rule as &\$sub bare-call. Without this, the
            # GLOB_ACCESS was returned as-is and used as a value (the
            # CODE ref itself, stringified to "CODE(0x...)").
            my scalar $glob = Perla::AST::node(Perla::AST::N_GLOB_ACCESS());
            $glob->{"name"} = "";
            $glob->{"expr"} = $expr;
            $glob->{"is_code_deref"} = 1;
            my scalar $call = Perla::AST::node(Perla::AST::N_CALL());
            $call->{"name"} = "__coderef__";
            $call->{"coderef"} = $glob;
            $call->{"args"} = [];
            $call->{"pass_caller_args"} = 1;
            return $call;
        }
        # &$sub or &$sub(args) - code ref call
        if (_peek_type($p) eq "SCALAR_VAR") {
            my scalar $var = _parse_primary($p);
            # Check for &$sub(args) - coderef call
            if (_peek_type($p) eq "LPAREN") {
                _advance($p);
                my scalar $call = Perla::AST::node(Perla::AST::N_CALL());
                $call->{"name"} = "__coderef__";
                $call->{"coderef"} = $var;
                $call->{"args"} = [];
                while (_peek_type($p) ne "RPAREN" && !_at_end($p)) {
                    push(@{$call->{"args"}}, _parse_assign($p));
                    if (_peek_type($p) eq "COMMA" || _peek_type($p) eq "FAT_ARROW") { _advance($p); }
                }
                _expect($p, "RPAREN");
                return $call;
            }
            # `&\$sub` (no parens) in Perl CALLS the sub passing the
            # caller's @_ through unchanged. The earlier code returned
            # the ref itself — `my \$r = &\$sub;` got the ref instead of
            # the call result. Build a __coderef__ call with the
            # pass_caller_args flag so the codegen forwards perla_at_
            # like the bare-&IDENT form does.
            my scalar $call = Perla::AST::node(Perla::AST::N_CALL());
            $call->{"name"} = "__coderef__";
            $call->{"coderef"} = $var;
            $call->{"args"} = [];
            $call->{"pass_caller_args"} = 1;
            return $call;
        }
        # Accept IDENT or builtin keyword tokens (PRINT, SAY, MY, etc.)
        # — `\&print` should give a CODE ref, not undef from the fallback.
        # Without this, the lexer's keyword-token classification (PRINT
        # for `print`, etc.) made `&print` fall through to the N_UNDEF
        # fallback at the bottom of _parse_primary, and `\&print`
        # returned a SCALAR ref to undef instead of CODE.
        my str $___tt = _peek_type($p);
        my int $___is_kw = 0;
        if ($___tt eq "PRINT" || $___tt eq "SAY" || $___tt eq "PRINTF"
            || $___tt eq "DIE" || $___tt eq "WARN" || $___tt eq "RETURN"
            || $___tt eq "PUSH" || $___tt eq "POP" || $___tt eq "SHIFT"
            || $___tt eq "UNSHIFT" || $___tt eq "MAP" || $___tt eq "GREP"
            || $___tt eq "SORT" || $___tt eq "SUB") {
            $___is_kw = 1;
        }
        # `\&eq` / `\&ne` / `\&cmp` / etc. — operator keywords (eq, ne,
        # lt, gt, le, ge, cmp, and, or, not, xor, x) are tokenized as
        # OP, but in the sub-name position after `&` they're just
        # identifiers. Without this the parser fell through and `\&eq`
        # ended up a SCALAR ref to undef — overload '==' => \\&eq
        # silently registered nothing.
        if ($___tt eq "OP" && $___is_kw == 0) {
            my str $___ov = _peek_val($p);
            if ($___ov eq "eq" || $___ov eq "ne" || $___ov eq "lt"
                || $___ov eq "gt" || $___ov eq "le" || $___ov eq "ge"
                || $___ov eq "cmp" || $___ov eq "and" || $___ov eq "or"
                || $___ov eq "not" || $___ov eq "xor" || $___ov eq "x") {
                $___is_kw = 1;
            }
        }
        if (_peek_type($p) eq "IDENT" || $___is_kw == 1) {
            my str $fname = _advance($p)->{"value"};
            my scalar $node = Perla::AST::node(Perla::AST::N_CALL());
            $node->{"name"} = $fname;
            $node->{"args"} = [];
            if (_peek_type($p) eq "LPAREN") {
                _advance($p);
                while (_peek_type($p) ne "RPAREN" && !_at_end($p)) {
                    push(@{$node->{"args"}}, _parse_assign($p));
                    if (_peek_type($p) eq "COMMA" || _peek_type($p) eq "FAT_ARROW") { _advance($p); }
                }
                _expect($p, "RPAREN");
            } else {
                # `&sub` (no parens, no args) — Perl semantics: pass the
                # caller's @_ THROUGH (the callee can shift() and modify
                # it). Hash::Merge's `_get_obj` and `_merge_hashes` rely
                # on this; without it, every Hash::Merge use ends up with
                # the merger object spilling into ($left, $right) and the
                # SELECT clause inherits the merger's behaviors hash.
                $node->{"pass_caller_args"} = 1;
            }
            return $node;
        }
    }

    # Fallback: skip and return undef literal
    _advance($p);
    return Perla::AST::node(Perla::AST::N_UNDEF());
}
