    }

    if ($type == Perla::AST::N_ARROW_ARRAY()) {
        my scalar $obj = $node->{"object"};
        my scalar $aaidx = $node->{"index"};
        # The parser uses N_ARROW_ARRAY for both `$arr[N]` (read from @arr,
        # implicit) and `$arr->[N]` (explicit deref of $arr scalar ref).
        # The two forms have different semantics — distinguished here by
        # the `is_explicit_arrow` flag set by the parser. Without this,
        # `$arr->[N]` was reading from @arr (wrong array when scalar holds
        # a different array ref), and `$_->[N]` was reading @_ (also wrong).
        my int $is_arrow = 0;
        if (defined($node->{"is_explicit_arrow"}) && $node->{"is_explicit_arrow"} == 1) { $is_arrow = 1; }
        # $_[N] (bare subscript on $_) means @_[N] — function argument access
        if ($is_arrow == 0 && $obj->{"type"} == Perla::AST::N_SCALAR_VAR() && $obj->{"name"} eq "_") {
            emit($cg, "({ StradaArray *__ae_av = strada_deref_array(perla_at_); ");
        } elsif ($is_arrow == 0 && $obj->{"type"} == Perla::AST::N_SCALAR_VAR() && $obj->{"name"} eq "-") {
            # `$-[N]` — regex match start offsets (@-).
            emit($cg, "({ StradaArray *__ae_av = strada_deref_array(strada_match_starts()); ");
        } elsif ($is_arrow == 0 && $obj->{"type"} == Perla::AST::N_SCALAR_VAR() && $obj->{"name"} eq "+") {
            # `$+[N]` — regex match end offsets (@+).
            emit($cg, "({ StradaArray *__ae_av = strada_deref_array(strada_match_ends()); ");
        } elsif ($is_arrow == 0 && $obj->{"type"} == Perla::AST::N_SCALAR_VAR() && index("" . ($obj->{"name"} // ""), "::") < 0) {
