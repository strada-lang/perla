                && defined($inner_hash->{"name"}) && length($inner_hash->{"name"}) > 0
                && index($inner_hash->{"name"}, "::") < 0 && $inner_hash->{"name"} ne "_"
                && exists($__perla_mangle_collisions{$inner_hash->{"name"}})) {
