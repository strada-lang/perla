                        # outer hash is itself a nested access so missing
                        # intermediates get autovivified to hashrefs.
                        my scalar $ma_outer;
                        my int $ma_outer_hash_ctx = 0;
                        if ($ma_it == Perla::AST::N_ARROW_HASH()) {
                            $ma_outer = $ma_inner->{"object"};
                            if (!defined($ma_inner->{"is_explicit_arrow"}) || $ma_inner->{"is_explicit_arrow"} != 1) {
                                $ma_outer_hash_ctx = 1;
                            }
                        } else {
                            $ma_outer = $ma_inner->{"hash"};
                            $ma_outer_hash_ctx = 1;
                        }
                        emit($cg, "({ StradaValue *__avh = ");
                        _gen_autoviv_outer_hash($cg, $ma_outer, $ma_outer_hash_ctx);
                        emit($cg, "; char *__avk = strada_to_str(");
                        gen_expr($cg, $ma_inner->{"key"});
                        emit($cg, "); StradaHash *__avhv = strada_deref_hash(__avh); ");
                        emit($cg, "StradaValue *__avs = __avhv ? strada_hash_get(__avhv, __avk) : NULL; ");
                        emit($cg, "if (!__avs || STRADA_IS_TAGGED_INT(__avs) || ");
                        emit($cg, "  __avs->type != STRADA_REF || !__avs->value.rv || ");
                        emit($cg, "  __avs->value.rv->type != STRADA_ARRAY) { ");
                        emit($cg, "  StradaValue *__newref = strada_new_ref_take(strada_new_array(), '@'); ");
                        emit($cg, "  if (__avhv) strada_hash_set_take(__avhv, __avk, __newref); ");
                        emit($cg, "  __avs = __newref; ");
                        emit($cg, "} StradaArray *__pa = strada_deref_array(__avs); ");
                        emit($cg, "free(__avk); ");
                        $ma_av = 1;
                    }
                }
                if ($ma_av == 0) {
                    emit($cg, "({ StradaArray *__pa = strada_deref_array(");
                    gen_expr($cg, $args->[0]);
                    emit($cg, "); ");
                }
                my int $pi = 1;
                while ($pi < $argc) {
                    my scalar $aelem = $args->[$pi];
                    my int $aet = $aelem->{"type"};
                    # `push @a, (1,2,3), (4,5)` parses each `(...)` arg
                    # as N_ANON_ARRAY without is_ref. Perl semantics: those
                    # are list groupings — flatten elements individually.
                    # Without this, each (...) got pushed as a single
                    # array-ref element (`ARRAY(0x..)` instead of 1,2,3).
                    if ($aet == Perla::AST::N_ANON_ARRAY()
                        && defined($aelem->{"elems"})
                        && (!defined($aelem->{"is_ref"}) || $aelem->{"is_ref"} == 0)) {
                        my scalar $sub_elems = $aelem->{"elems"};
                        my int $sei = 0;
                        while ($sei < scalar(@{$sub_elems})) {
                            my scalar $se = $sub_elems->[$sei];
                            my int $set = $se->{"type"};
                            if ($set == Perla::AST::N_ARRAY_VAR()
                                || $set == Perla::AST::N_DEREF_ARRAY()
                                || $set == Perla::AST::N_ARRAY_SLICE()
                                || $set == Perla::AST::N_HASH_SLICE()
                                || $set == Perla::AST::N_CALL()
                                || $set == Perla::AST::N_METHOD()
                                || $set == Perla::AST::N_GREP()
                                || $set == Perla::AST::N_MAP()
                                || $set == Perla::AST::N_SORT()
                                || $set == Perla::AST::N_RANGE()) {
                                emit($cg, "{ StradaValue *__fv = ");
                                gen_expr($cg, $se);
                                emit($cg, "; if (__fv && !STRADA_IS_TAGGED_INT(__fv) && __fv->type == STRADA_ARRAY) { ");
                                emit($cg, "StradaArray *__fa = __fv->value.av; ");
                                emit($cg, "size_t __fa_sz0 = __fa ? __fa->size : 0; size_t __fa_hd0 = __fa ? __fa->head : 0; ");
                                emit($cg, "for (size_t __fi = 0; __fi < __fa_sz0; __fi++) strada_array_push(__pa, __fa->elements[__fa_hd0 + __fi]); ");
                                emit($cg, "} else { strada_array_push(__pa, __fv); } } ");
                            } else {
                                emit($cg, "strada_array_push(__pa, ");
                                gen_expr($cg, $se);
                                emit($cg, "); ");
                            }
                            $sei = $sei + 1;
                        }
                    } elsif ($aet == Perla::AST::N_ARRAY_VAR()
                        || $aet == Perla::AST::N_DEREF_ARRAY()
                        || $aet == Perla::AST::N_ARRAY_SLICE()
                        || $aet == Perla::AST::N_HASH_SLICE()
                        || $aet == Perla::AST::N_CALL()
                        || $aet == Perla::AST::N_METHOD()
                        || $aet == Perla::AST::N_GREP()
                        || $aet == Perla::AST::N_MAP()
                        || $aet == Perla::AST::N_SORT()
                        || $aet == Perla::AST::N_RANGE()) {
                        # N_RANGE in list context produces a list (1..5 →
                        # 1,2,3,4,5). Without flattening, `push @a, 1..5`
                        # would push the range array as a single element.
                        emit($cg, "{ StradaValue *__fv = ");
                        gen_expr($cg, $aelem);
                        emit($cg, "; if (__fv && !STRADA_IS_TAGGED_INT(__fv) && __fv->type == STRADA_ARRAY) { ");
                        emit($cg, "StradaArray *__fa = __fv->value.av; ");
                        emit($cg, "size_t __fa_sz0 = __fa ? __fa->size : 0; size_t __fa_hd0 = __fa ? __fa->head : 0; ");
                        emit($cg, "for (size_t __fi = 0; __fi < __fa_sz0; __fi++) strada_array_push(__pa, __fa->elements[__fa_hd0 + __fi]); ");
                        emit($cg, "} else { strada_array_push(__pa, __fv); } } ");
                    } else {
                        emit($cg, "strada_array_push(__pa, ");
                        gen_expr($cg, $aelem);
                        emit($cg, "); ");
                    }
