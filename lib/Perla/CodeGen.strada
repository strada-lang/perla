        return;
    }
    # localtime($time) — 9-element list in list context, ctime-style
    # string ("Tue Nov 14 22:13:20 2023") in scalar context.
    if ($name eq "localtime") {
        emit($cg, "({ time_t __tt = ");
        if ($argc > 0) {
            emit($cg, "(time_t)strada_to_int(");
            gen_expr($cg, $args->[0]);
            emit($cg, ")");
        } else { emit($cg, "time(NULL)"); }
        emit($cg, "; struct tm *__tm = localtime(&__tt); StradaValue *__ltr; ");
        emit($cg, "if (__perla_want_list) { ");
        emit($cg, "StradaValue *__a = strada_new_array(); StradaArray *__av = strada_deref_array(__a); ");
        emit($cg, "strada_array_push(__av, STRADA_MAKE_TAGGED_INT(__tm->tm_sec)); ");
        emit($cg, "strada_array_push(__av, STRADA_MAKE_TAGGED_INT(__tm->tm_min)); ");
        emit($cg, "strada_array_push(__av, STRADA_MAKE_TAGGED_INT(__tm->tm_hour)); ");
        emit($cg, "strada_array_push(__av, STRADA_MAKE_TAGGED_INT(__tm->tm_mday)); ");
        emit($cg, "strada_array_push(__av, STRADA_MAKE_TAGGED_INT(__tm->tm_mon)); ");
        emit($cg, "strada_array_push(__av, STRADA_MAKE_TAGGED_INT(__tm->tm_year)); ");
        emit($cg, "strada_array_push(__av, STRADA_MAKE_TAGGED_INT(__tm->tm_wday)); ");
        emit($cg, "strada_array_push(__av, STRADA_MAKE_TAGGED_INT(__tm->tm_yday)); ");
        emit($cg, "strada_array_push(__av, STRADA_MAKE_TAGGED_INT(__tm->tm_isdst)); ");
        emit($cg, "__ltr = __a; ");
        emit($cg, "} else { char __ltb[64]; strftime(__ltb, sizeof(__ltb), \"%a %b %e %H:%M:%S %Y\", __tm); __ltr = strada_new_str(__ltb); } ");
        emit($cg, "__ltr; })");
        return;
    }
    # gmtime($time) — same as localtime but UTC. Context-aware:
    # 9-element list in list context, ctime-style string ("UTC")
    # in scalar context.
    if ($name eq "gmtime") {
        emit($cg, "({ time_t __tt = ");
        if ($argc > 0) {
            emit($cg, "(time_t)strada_to_int(");
            gen_expr($cg, $args->[0]);
            emit($cg, ")");
        } else { emit($cg, "time(NULL)"); }
        emit($cg, "; struct tm *__tm = gmtime(&__tt); StradaValue *__gtr; ");
        emit($cg, "if (!__perla_want_list) { char __gtb[64]; strftime(__gtb, sizeof(__gtb), \"%a %b %e %H:%M:%S %Y\", __tm); __gtr = strada_new_str(__gtb); } else { ");
        emit($cg, "StradaValue *__a = strada_new_array(); StradaArray *__av = strada_deref_array(__a); ");
        emit($cg, "strada_array_push(__av, STRADA_MAKE_TAGGED_INT(__tm->tm_sec)); ");
        emit($cg, "strada_array_push(__av, STRADA_MAKE_TAGGED_INT(__tm->tm_min)); ");
        emit($cg, "strada_array_push(__av, STRADA_MAKE_TAGGED_INT(__tm->tm_hour)); ");
        emit($cg, "strada_array_push(__av, STRADA_MAKE_TAGGED_INT(__tm->tm_mday)); ");
        emit($cg, "strada_array_push(__av, STRADA_MAKE_TAGGED_INT(__tm->tm_mon)); ");
        emit($cg, "strada_array_push(__av, STRADA_MAKE_TAGGED_INT(__tm->tm_year)); ");
        emit($cg, "strada_array_push(__av, STRADA_MAKE_TAGGED_INT(__tm->tm_wday)); ");
        emit($cg, "strada_array_push(__av, STRADA_MAKE_TAGGED_INT(__tm->tm_yday)); ");
        emit($cg, "strada_array_push(__av, STRADA_MAKE_TAGGED_INT(__tm->tm_isdst)); ");
        emit($cg, "__gtr = __a; } __gtr; })");
        return;
    }
    # POSIX::strftime(FORMAT, sec, min, hour, mday, mon, year[, wday, yday, isdst])
    # Args may arrive flattened (`strftime(\$fmt, \$s, \$m, ...)`) or via
    # a single list-returning call (`strftime(\$fmt, gmtime(\$t))`). Build
    # an args array in list context so both shapes work; pull tm fields
    # from the flattened array.
    if ($name eq "strftime" || $name eq "POSIX::strftime") {
        if ($argc >= 2) {
            emit($cg, "({ char __sfb[256]; struct tm __sftm = {0}; ");
            emit($cg, "char *__sff = strada_to_str(");
            gen_expr($cg, $args->[0]);
            emit($cg, "); ");
            emit($cg, "int __sav_wl_sft = __perla_want_list; __perla_want_list = 1; ");
            emit($cg, "StradaValue *__sfa = strada_new_array(); StradaArray *__sav = strada_deref_array(__sfa); ");
            my int $sfi = 1;
            while ($sfi < $argc) {
                emit($cg, "{ StradaValue *__sfe = ");
                gen_expr($cg, $args->[$sfi]);
                emit($cg, "; if (__sfe && !STRADA_IS_TAGGED_INT(__sfe) && __sfe->type == STRADA_ARRAY) { StradaArray *__sfx = __sfe->value.av; if (__sfx) for (size_t __sfj = 0; __sfj < __sfx->size; __sfj++) { StradaValue *__sfk = __sfx->elements[__sfx->head + __sfj]; if (__sfk) strada_incref(__sfk); strada_array_push(__sav, __sfk); } } else { if (__sfe) strada_incref(__sfe); strada_array_push(__sav, __sfe); } } ");
                $sfi++;
