                # @Pkg::H{k1, k2} = ... — write to HASH slot of stash glob.
                my str $hspn = "" . $hash_node_hs;
                my int $hsli = -1;
                my int $hssi = 0;
                while ($hssi < length($hspn) - 1) {
                    if (substr($hspn, $hssi, 2) eq "::") { $hsli = $hssi; }
                    $hssi = $hssi + 1;
