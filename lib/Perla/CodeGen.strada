        my int $route_simple_fallback = 0;
        my str $__sf_name = "";
        if ($is_arrow_h == 0 && $route_to_hash == 0 && $route_to_stash_h == 0
            && defined($aobj2) && $aobj2->{"type"} == Perla::AST::N_SCALAR_VAR()
            && defined($aobj2->{"name"}) && length($aobj2->{"name"}) > 0
            && index($aobj2->{"name"}, "::") < 0
            && $aobj2->{"name"} ne "_") {
