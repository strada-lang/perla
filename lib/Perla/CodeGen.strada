        while ($__crk_fi < length($__crk_file)) {
            my str $__crk_ch = substr($__crk_file, $__crk_fi, 1);
            if ($__crk_ch eq "\\") { $__crk_file_esc = $__crk_file_esc . "\\\\"; }
            elsif ($__crk_ch eq "\"") { $__crk_file_esc = $__crk_file_esc . "\\\""; }
            else { $__crk_file_esc = $__crk_file_esc . $__crk_ch; }
            $__crk_fi = $__crk_fi + 1;
        }
        emit($cg, "({ StradaValue *__dv = ");
        if ($argc > 1) {
            # Multi-arg croak/confess concatenates string args.
            # Perl: `croak "x", "y", "z"` produces "xyz" + location.
            # First arg is special — if it's a non-string ref (hashref/
            # arrayref/object), preserve it as $@ without concat. Only
            # do the concat-all when all args are stringy.
            emit($cg, "({ StradaValue *__cv = ");
            gen_expr($cg, $args->[0]);
            emit($cg, "; ");
            my int $cri = 1;
            while ($cri < $argc) {
                emit($cg, "{ StradaValue *__cv2 = ");
                gen_expr($cg, $args->[$cri]);
                emit($cg, "; StradaValue *__old = __cv; __cv = strada_concat_sv(__cv, __cv2); strada_decref(__old); strada_decref(__cv2); } ");
                $cri = $cri + 1;
            }
            emit($cg, "__cv; })");
        } elsif ($argc > 0) {
            gen_expr($cg, $args->[0]);
        } else {
            emit($cg, "strada_new_str(\"Died\")");
        }
        emit($cg, "; ");
        # Append " at <caller_file> line <caller_line>\n" regardless of
        # trailing newline — Perl's Carp::croak/confess always appends
        # location info (unlike `die`, which suppresses it for messages
        # ending in \n). Strip an existing trailing newline first so
        # the location lines up properly.
        emit($cg, "if (__dv && !STRADA_IS_TAGGED_INT(__dv) && __dv->type == STRADA_STR && __dv->value.pv) { ");
        emit($cg, "  size_t __dlen = strlen(__dv->value.pv); ");
        emit($cg, "  { ");
        emit($cg, "    const char *__cf = \"" . $__crk_file_esc . "\"; int __cl_ln = " . $__crk_line . "; ");
        emit($cg, "    char __dvbuf[1024]; size_t __dvcpy = __dlen < sizeof(__dvbuf) - 1 ? __dlen : sizeof(__dvbuf) - 1; ");
        emit($cg, "    memcpy(__dvbuf, __dv->value.pv, __dvcpy); __dvbuf[__dvcpy] = '\\0'; ");
        emit($cg, "    while (__dvcpy > 0 && (__dvbuf[__dvcpy - 1] == '\\n' || __dvbuf[__dvcpy - 1] == '\\r')) { __dvbuf[--__dvcpy] = '\\0'; } ");
        emit($cg, "    char __cbuf[2048]; snprintf(__cbuf, sizeof(__cbuf), \"%s at %s line %d.\\n\", __dvbuf, __cf, __cl_ln); ");
        # Both croak and confess append a stack-frame walk. Perl's CPAN
        # Carp::croak typically blames the immediate caller, Carp::confess
        # walks the whole chain — for our purposes they emit the same
        # call-chain text here. Without this loop, croak only included
        # the first "at FILE line N." line and no caller frames, so
        # `eval { sub a { croak "boom" } a(); }` lost the trace.
        # Each frame's line was set by perla_call_push from
        # perla_pending_call_line at entry — that IS the call-site
        # line. Use frame[ci].line/file directly, not frame[ci-1]
        # (which is the CALLER's entry, not the current frame's
        # call-site). Without this, confess showed "level_3() called
        # at line N" with N being where level_2 was called from
        # level_1, not where level_3 was called from level_2.
        emit($cg, "    for (int __ci = perla_call_depth - 1; __ci > 0; __ci--) { ");
        emit($cg, "      const char *__sp = perla_call_stack[__ci].package ?: \"main\"; ");
        emit($cg, "      const char *__sn = perla_call_stack[__ci].subname ?: \"?\"; ");
        emit($cg, "      const char *__sf = perla_call_stack[__ci].file ?: \"-\"; ");
        emit($cg, "      int __sl = perla_call_stack[__ci].line; ");
        emit($cg, "      if (strncmp(__sn, \"__perla_anon_\", 13) == 0) { __sn = \"__ANON__\"; } ");
        emit($cg, "      size_t __sblen = strlen(__cbuf); ");
        emit($cg, "      if (__sblen + 256 < sizeof(__cbuf)) { ");
        emit($cg, "        if (strcmp(__sn, \"(eval)\") == 0) { ");
        emit($cg, "          snprintf(__cbuf + __sblen, sizeof(__cbuf) - __sblen, \"\\teval {...} called at %s line %d\\n\", __sf, __sl); ");
        emit($cg, "        } else { ");
        emit($cg, "          snprintf(__cbuf + __sblen, sizeof(__cbuf) - __sblen, \"\\t%s::%s() called at %s line %d\\n\", __sp, __sn, __sf, __sl); ");
        emit($cg, "        } ");
        emit($cg, "      } ");
        emit($cg, "    } ");
        emit($cg, "    strada_decref(__dv); __dv = strada_new_str(__cbuf); ");
        emit($cg, "  } ");
        emit($cg, "} ");
        emit($cg, "if (perla_eval_error) strada_decref(perla_eval_error); ");
        # Transfer __dv ownership to perla_eval_error (no incref). See
        # the matching comment near the simple-die emit ~line 12937.
        emit($cg, "perla_eval_error = __dv; ");
        # Call $SIG{__DIE__} handler before unwinding — Perl fires it
        # for any die-flavored throw (die, croak, confess). Without
        # this, croak/confess didn't trigger user-installed __DIE__
        # handlers that die does. Mirrors the same emit in the `die`
        # branch above with re-entrancy guard via temp-swap.
        emit($cg, "{ StradaValue *__dh = (v_SIG && !STRADA_IS_TAGGED_INT(v_SIG) && v_SIG->type == STRADA_HASH) ? strada_hash_get(v_SIG->value.hv, \"__DIE__\") : NULL; ");
        emit($cg, "if (__dh && !STRADA_IS_TAGGED_INT(__dh) && (__dh->type == STRADA_CLOSURE || __dh->type == STRADA_CPOINTER)) { ");
        emit($cg, "  StradaValue *__da = strada_new_array(); strada_incref(__dv); strada_array_push(strada_deref_array(__da), __dv); ");
        emit($cg, "  StradaValue *__dhs = strada_hash_get(v_SIG->value.hv, \"__DIE__\"); if (__dhs) strada_incref(__dhs); strada_hash_delete(v_SIG->value.hv, \"__DIE__\"); ");
        emit($cg, "  StradaValue *__dr = perla_call_code(__dh, __da); if (__dr) strada_decref(__dr); strada_decref(__da); ");
        emit($cg, "  if (__dhs) { strada_hash_set_take(v_SIG->value.hv, \"__DIE__\", __dhs); } ");
        emit($cg, "} } ");
        emit($cg, "strada_die_sv(__dv); strada_new_undef(); })");
        return;
    }
    if ($name eq "carp" || $name eq "Carp::carp" || $name eq "cluck" || $name eq "Carp::cluck") {
        # Perl's Carp::carp/cluck call warn() under the hood — that
        # means $SIG{__WARN__} fires before stderr. Also append the
        # " at FILE line N" suffix (Carp always adds location info,
        # unlike `warn` which suppresses for messages ending in \n).
        my int $__crp_line = $node->{"line"} + 0;
        my str $__crp_file = "" . $cg->{"filename"};
        if (length($__crp_file) == 0) { $__crp_file = "-"; }
        my str $__crp_file_esc = "";
        my int $__crp_fi = 0;
        while ($__crp_fi < length($__crp_file)) {
            my str $__crp_ch = substr($__crp_file, $__crp_fi, 1);
            if ($__crp_ch eq "\\") { $__crp_file_esc = $__crp_file_esc . "\\\\"; }
            elsif ($__crp_ch eq "\"") { $__crp_file_esc = $__crp_file_esc . "\\\""; }
            else { $__crp_file_esc = $__crp_file_esc . $__crp_ch; }
            $__crp_fi = $__crp_fi + 1;
        }
        emit($cg, "({ char *__s = strada_to_str(");
        if ($argc > 0) {
            gen_expr($cg, $args->[0]);
        } else {
            emit($cg, "strada_new_str(\"Warning: something's wrong\")");
        }
        emit($cg, "); ");
        # Strip trailing newlines, append location suffix.
        emit($cg, "size_t __sl = __s ? strlen(__s) : 0; ");
        emit($cg, "while (__sl > 0 && (__s[__sl - 1] == '\\n' || __s[__sl - 1] == '\\r')) { __s[--__sl] = '\\0'; } ");
        emit($cg, "char __cmbuf[4096]; int __cmofs = snprintf(__cmbuf, sizeof(__cmbuf), \"%s at %s line %d.\\n\", __s ? __s : \"\", \"" . $__crp_file_esc . "\", " . $__crp_line . "); ");
        # Perl Carp::carp walks the call stack and appends a
        # "\tPKG::FUNC() called at FILE line LINE\n" line for each
        # outer frame. Mirror that here. The top of perla_call_stack
        # is the caller of carp (which is the sub-using-carp itself),
        # then its caller, etc. Skip the top frame because that's
        # already implied by the "at FILE line N" location above.
        emit($cg, "for (int __cmci = perla_call_depth - 1; __cmci > 0; __cmci--) { ");
        emit($cg, "  const char *__cmpkg = perla_call_stack[__cmci].package ? perla_call_stack[__cmci].package : \"main\"; ");
        emit($cg, "  const char *__cmsub = perla_call_stack[__cmci].subname ? perla_call_stack[__cmci].subname : \"?\"; ");
        emit($cg, "  const char *__cmfile = perla_call_stack[__cmci-1].file ? perla_call_stack[__cmci-1].file : \"-\"; ");
        emit($cg, "  int __cmln = perla_call_stack[__cmci].line; ");
        emit($cg, "  if (strncmp(__cmsub, \"__perla_anon_\", 13) == 0) { __cmsub = \"__ANON__\"; } ");
        emit($cg, "  if (__cmofs < (int)sizeof(__cmbuf)) { ");
        emit($cg, "    if (strcmp(__cmsub, \"(eval)\") == 0) { ");
        emit($cg, "      __cmofs += snprintf(__cmbuf + __cmofs, sizeof(__cmbuf) - __cmofs, \"\\teval {...} called at %s line %d\\n\", __cmfile, __cmln); ");
        emit($cg, "    } else { ");
        emit($cg, "      __cmofs += snprintf(__cmbuf + __cmofs, sizeof(__cmbuf) - __cmofs, \"\\t%s::%s() called at %s line %d\\n\", __cmpkg, __cmsub, __cmfile, __cmln); ");
        emit($cg, "    } ");
        emit($cg, "  } } ");
        emit($cg, "free(__s); ");
        # Route through $SIG{__WARN__} like `warn` does.
        emit($cg, "StradaValue *__wh = (v_SIG && !STRADA_IS_TAGGED_INT(v_SIG) && v_SIG->type == STRADA_HASH) ? strada_hash_get(v_SIG->value.hv, \"__WARN__\") : NULL; ");
        emit($cg, "if (__wh && !STRADA_IS_TAGGED_INT(__wh) && (__wh->type == STRADA_CLOSURE || __wh->type == STRADA_CPOINTER)) { ");
        emit($cg, "  StradaValue *__wa = strada_new_array(); strada_array_push(strada_deref_array(__wa), strada_new_str(__cmbuf)); ");
        emit($cg, "  StradaValue *__wr = perla_call_code(__wh, __wa); if (__wr) strada_decref(__wr); strada_decref(__wa); ");
        emit($cg, "} else { fputs(__cmbuf, stderr); } ");
        emit($cg, "strada_new_undef(); })");
        return;
    }

    # _definition_context is handled in _gen_push_args for proper list flattening

    # Devel::GlobalDestruction
    if ($name eq "in_global_destruction" || $name eq "Devel::GlobalDestruction::in_global_destruction") {
        emit($cg, "STRADA_MAKE_TAGGED_INT(0)");
        return;
    }

    # mro::get_pkg_gen - returns package generation number (stub: always 1)
    if ($name eq "mro::get_pkg_gen") {
        emit($cg, "STRADA_MAKE_TAGGED_INT(1)");
        return;
    }
    # Sub::Name::subname / Sub::Util::set_subname — name-a-sub writer.
    # Returns the 2nd arg (the coderef) as-is — set_subname only records
    # the name in a side-table; the coderef itself is unchanged. Kept
    # as a compile-time stub for the 2-arg form. The 1-arg reader form
    # (Sub::Util::subname) is handled at runtime via the stash binding
    # (perla_code_set("Sub::Util", "subname", perla_sub_util_subname)).
    if ($name eq "Sub::Name::subname" || $name eq "Sub::Util::set_subname") {
        if ($argc >= 2) {
            gen_expr($cg, $args->[1]);
        } else {
            emit($cg, "strada_new_undef()");
        }
        return;
    }
    # Sub::Util::set_prototype($proto, $coderef) — attach $proto to
    # $coderef and return $coderef. Calls runtime helper which mutates
    # the SV in place (promoting CPOINTER → CLOSURE when needed).
    if ($name eq "set_prototype" || $name eq "Sub::Util::set_prototype"
        || $name eq "Scalar::Util::set_prototype") {
        if ($argc >= 2) {
            emit($cg, "({ StradaValue *__sp_p = ");
            gen_expr($cg, $args->[0]);
            emit($cg, "; StradaValue *__sp_c = ");
            gen_expr($cg, $args->[1]);
            emit($cg, "; perla_sub_util_set_prototype_direct(__sp_p, __sp_c); ");
            if (expr_is_borrowed($args->[0]) == 0) {
                emit($cg, "if (__sp_p) strada_decref(__sp_p); ");
            }
            emit($cg, "if (__sp_c) strada_incref(__sp_c); __sp_c; })");
        } elsif ($argc == 1) {
            gen_expr($cg, $args->[0]);
        } else {
            emit($cg, "strada_new_undef()");
        }
        return;
    }
    # Module::Runtime::module_notional_filename
    if ($name eq "module_notional_filename" || $name eq "Module::Runtime::module_notional_filename") {
        if ($argc > 0) {
            emit($cg, "({ char *__mn = strada_to_str(");
            gen_expr($cg, $args->[0]);
            emit($cg, "); size_t __ml = strlen(__mn); char *__mf = malloc(__ml + 4); size_t __mi = 0; ");
            emit($cg, "for (size_t __i = 0; __i < __ml; __i++) { if (__mn[__i]==':'&&__mn[__i+1]==':') { __mf[__mi++]='/'; __i++; } else { __mf[__mi++]=__mn[__i]; } } ");
            emit($cg, "strcpy(__mf+__mi, \".pm\"); StradaValue *__r = strada_new_str(__mf); free(__mf); free(__mn); __r; })");
        } else {
            emit($cg, "strada_new_undef()");
        }
        return;
    }
    # Class::Load::is_class_loaded (stub: check if package stash exists)
    if ($name eq "is_class_loaded" || $name eq "Class::Load::is_class_loaded") {
        if ($argc > 0) {
            emit($cg, "({ char *__cn = strada_to_str(");
            gen_expr($cg, $args->[0]);
            emit($cg, "); int __cl = perla_stash_exists(__cn); free(__cn); STRADA_MAKE_TAGGED_INT(__cl); })");
        } else {
            emit($cg, "STRADA_MAKE_TAGGED_INT(0)");
        }
        return;
    }

    # throw_exception (Moose::Util and Class::MOP::Mixin)
    if ($name eq "throw_exception" || $name eq "Moose::Util::throw_exception") {
        emit($cg, "({ StradaValue *__te_args = strada_new_array(); StradaArray *__te_av = strada_deref_array(__te_args); ");
        my int $tai = 0;
        while ($tai < $argc) {
            emit($cg, "strada_array_push(__te_av, ");
            gen_expr($cg, $args->[$tai]);
            emit($cg, "); ");
            $tai++;
        }
        emit($cg, "perla_throw_exception(__te_args); strada_decref(__te_args); strada_new_undef(); })");
        return;
    }

    # require_module (Module::Runtime) — maps to perla_require_module
    if ($name eq "require_module" || $name eq "Module::Runtime::require_module") {
        if ($argc > 0) {
            emit($cg, "perla_require_module(");
            gen_expr($cg, $args->[0]);
            emit($cg, ")");
        } else {
            emit($cg, "strada_new_undef()");
        }
        return;
    }

    # use_module (Module::Runtime) — require + return class name
    if ($name eq "use_module" || $name eq "Module::Runtime::use_module") {
        if ($argc > 0) {
            emit($cg, "({ StradaValue *__um = ");
            gen_expr($cg, $args->[0]);
            emit($cg, "; perla_require_module(__um); __um; })");
        } else {
            emit($cg, "strada_new_undef()");
        }
        return;
    }

    # use_package_optimistically (Module::Runtime) — same as use_module but doesn't die on failure
    if ($name eq "use_package_optimistically" || $name eq "Module::Runtime::use_package_optimistically") {
        if ($argc > 0) {
            emit($cg, "({ StradaValue *__um = ");
            gen_expr($cg, $args->[0]);
            emit($cg, "; perla_require_module(__um); __um; })");
        } else {
            emit($cg, "strada_new_undef()");
        }
        return;
    }

    # Data::Dumper — built-in Dumper() function. Flatten @arr / %hash
    # args via _gen_push_args so `Dumper(@list)` emits $VAR1..$VAR_N
    # one per element (matches CPAN Data::Dumper). Previously each
    # arg was push'd as one element, so an array arg became a single
    # $VAR1 = [...] wrapping the whole list.
    if ($name eq "Dumper" || $name eq "Data::Dumper::Dumper") {
        emit($cg, "({ StradaValue *__da = strada_new_array(); StradaArray *__av = strada_deref_array(__da); ");
        _gen_push_args($cg, $args, $argc);
        emit($cg, "StradaValue *__dr = perla_dumper(__da); strada_decref(__da); __dr; })");
        return;
    }

    # `undef &Pkg::name` — Perl's "delete this sub from the symbol
    # table" form. Parser turns this into a synthetic call with the
    # qualified name as a string literal. Codegen clears the package
    # stash's CODE slot so `defined(&Pkg::name)` is false afterwards.
    if ($name eq "__perla_undef_sub__") {
        my str $us_full = "";
        if ($argc > 0 && defined($args->[0]) && $args->[0]->{"type"} == Perla::AST::N_STR_LIT()) {
            $us_full = "" . $args->[0]->{"value"};
        }
        my str $us_pkg = "" . $cg->{"pkg"};
        my str $us_short = $us_full;
        my int $us_sep = -1;
        my int $us_i = length($us_full) - 1;
        while ($us_i > 0) {
            if (substr($us_full, $us_i - 1, 2) eq "::") { $us_sep = $us_i - 1; last; }
            $us_i = $us_i - 1;
        }
        if ($us_sep >= 0) {
            $us_pkg = substr($us_full, 0, $us_sep);
            $us_short = substr($us_full, $us_sep + 2, length($us_full) - $us_sep - 2);
        }
        emit($cg, "({ perla_glob_store(perla_glob_get_or_create(perla_stash_get_or_create(\"" . $us_pkg . "\"), \"" . $us_short . "\"), 3, NULL); strada_new_undef(); })");
        return;
    }

    # defined
    if ($name eq "defined") {
        # Perl: `defined &SUB` checks whether SUB is defined in the
        # package stash WITHOUT calling it. The parser turns `&SUB` into
        # an N_CALL with pass_caller_args=1 which would otherwise call
        # the sub and check the return value. Detect the pattern and
        # route to a stash lookup instead. Required for Class::Load and
        # similar `defined &Pkg::method` checks.
        if ($argc > 0) {
            my scalar $arg0 = $args->[0];
            if (defined($arg0) && $arg0->{"type"} == Perla::AST::N_CALL()
                && defined($arg0->{"pass_caller_args"}) && $arg0->{"pass_caller_args"} == 1
                && defined($arg0->{"name"}) && length($arg0->{"name"}) > 0
                && $arg0->{"name"} ne "__coderef__") {
                my str $sn = $arg0->{"name"};
                my int $sep = -1;
                my int $si = length($sn) - 1;
                while ($si > 0) {
                    if (substr($sn, $si - 1, 2) eq "::") { $sep = $si - 1; last; }
                    $si--;
                }
                my str $spkg = ($sep >= 0) ? substr($sn, 0, $sep) : $cg->{"pkg"};
                my str $sshort = ($sep >= 0) ? substr($sn, $sep + 2, length($sn) - $sep - 2) : $sn;
                emit($cg, "(perla_code_get(\"" . $spkg . "\", \"" . $sshort . "\") ? STRADA_MAKE_TAGGED_INT(1) : strada_new_str(\"\"))");
                return;
            }
            # `defined &{EXPR}` — dynamic sub-by-name lookup. Parser
            # wraps as N_CALL with name="__coderef__" and coderef =
            # N_GLOB_ACCESS{is_code_deref=1, expr=EXPR}. Evaluate the
            # expr to a string at runtime, split on `::`, look up.
            # Also matches `defined &$var` where coderef is N_SCALAR_VAR
            # holding a name string — Memoize and similar introspect
            # via this pattern. Without this branch, the call falls
            # through to the default codegen which actually CALLS the
            # sub and checks its return — recursive subs that return
            # undef on entry then look "undefined" via this path.
            if (defined($arg0) && $arg0->{"type"} == Perla::AST::N_CALL()
                && defined($arg0->{"name"}) && $arg0->{"name"} eq "__coderef__"
                && defined($arg0->{"coderef"})) {
                my scalar $cref = $arg0->{"coderef"};
                my int $is_stringy = 0;
                my scalar $name_expr = undef;
                if (defined($cref->{"type"}) && $cref->{"type"} == Perla::AST::N_GLOB_ACCESS()
                    && defined($cref->{"is_code_deref"}) && $cref->{"is_code_deref"} == 1
                    && defined($cref->{"expr"})) {
                    $is_stringy = 1;
                    $name_expr = $cref->{"expr"};
                } elsif (defined($cref->{"type"}) && $cref->{"type"} == Perla::AST::N_SCALAR_VAR()) {
                    $is_stringy = 1;
                    $name_expr = $cref;
                }
                if ($is_stringy == 1) {
                    emit($cg, "({ char *__dn = strada_to_str(");
                    gen_expr($cg, $name_expr);
                    emit($cg, "); StradaValue *__dr; if (!__dn || !__dn[0]) { __dr = strada_new_str(\"\"); } ");
                    emit($cg, "else { const char *__dsep = NULL; for (const char *__dp = __dn; *__dp; __dp++) { if (__dp[0]==':' && __dp[1]==':') __dsep = __dp; } ");
                    emit($cg, "  StradaValue *__dfn; ");
                    emit($cg, "  if (__dsep) { size_t __dpl = (size_t)(__dsep - __dn); char __dpkg[256]; if (__dpl >= sizeof(__dpkg)) __dpl = sizeof(__dpkg)-1; memcpy(__dpkg, __dn, __dpl); __dpkg[__dpl] = 0; __dfn = perla_code_get(__dpkg, __dsep + 2); } ");
                    emit($cg, "  else { __dfn = perla_code_get(\"" . $cg->{"pkg"} . "\", __dn); if (!__dfn) __dfn = perla_code_get(\"main\", __dn); } ");
                    emit($cg, "  __dr = __dfn ? STRADA_MAKE_TAGGED_INT(1) : strada_new_str(\"\"); } ");
                    emit($cg, "free(__dn); __dr; })");
                    return;
                }
            }
        }
        # Perl: defined returns 1 for true, "" (empty string) for false.
        # defined() imposes scalar context on its arg — `defined sub()`
        # where sub does `return;` must give 0 (undef in scalar) even
        # when the surrounding expression is list context (e.g. inside
        # print args). Without saving/restoring __perla_want_list,
        # sub() ran in list context and returned strada_new_array()
        # (empty array) → strada_defined_bool(array) returned true.
        emit($cg, "({ int __sav_wl_def = __perla_want_list; __perla_want_list = 0; ");
        emit($cg, "StradaValue *__def_v = ");
        if ($argc > 0) { gen_expr($cg, $args->[0]); }
        else { emit($cg, "perla_dollar_underscore ? perla_dollar_underscore : strada_new_undef()"); }
        emit($cg, "; __perla_want_list = __sav_wl_def; ");
        emit($cg, "strada_defined_bool(__def_v) ? STRADA_MAKE_TAGGED_INT(1) : strada_new_str(\"\"); })");
        return;
    }

    # ref — returns Perl-compatible type string. ref imposes scalar
    # context on its arg; without `__perla_want_list = 0` save+restore,
    # `ref(returns_undef())` in print args ran in list context and got
    # an empty STRADA_ARRAY → reported "ARRAY" instead of "".
    if ($name eq "ref") {
        emit($cg, "({ int __sav_wl_ref = __perla_want_list; __perla_want_list = 0; ");
        emit($cg, "StradaValue *__rv = ");
        if ($argc > 0) { gen_expr($cg, $args->[0]); }
        else { emit($cg, "perla_dollar_underscore"); }
        emit($cg, "; __perla_want_list = __sav_wl_ref; const char *__rt = \"\"; ");
        emit($cg, "if (!__rv || STRADA_IS_TAGGED_INT(__rv)) __rt = \"\"; ");
        emit($cg, "else if (__rv->type == STRADA_REF && __rv->value.rv) { ");
        # For slot refs (perla's `\\$var` flavor that points at the C var
        # slot), follow the slot to read the actual referent. Without
        # this, ref() saw the slot address cast to StradaValue* and
        # always reported "SCALAR" — `ref(\\$arrayref)` returned SCALAR
        # instead of Perl's "REF".
        emit($cg, "  StradaValue *__rr; ");
        emit($cg, "  if (strada_is_slot_ref(__rv)) { StradaValue **__rs = (StradaValue**)__rv->value.ptr; __rr = __rs ? *__rs : NULL; } ");
        emit($cg, "  else { __rr = __rv->value.rv; } ");
        emit($cg, "  const char *__bp = (__rv->meta && __rv->meta->blessed_package) ? __rv->meta->blessed_package : NULL; ");
        emit($cg, "  if (__bp) __rt = __bp; ");
        emit($cg, "  else if (!__rr) __rt = \"SCALAR\"; ");
        emit($cg, "  else if (STRADA_IS_TAGGED_INT(__rr) || __rr->type == STRADA_INT || __rr->type == STRADA_NUM || __rr->type == STRADA_STR || __rr->type == STRADA_UNDEF) __rt = \"SCALAR\"; ");
        emit($cg, "  else if (__rr->type == STRADA_HASH) __rt = \"HASH\"; ");
        emit($cg, "  else if (__rr->type == STRADA_ARRAY) __rt = \"ARRAY\"; ");
        emit($cg, "  else if (__rr->type == STRADA_CLOSURE) __rt = \"CODE\"; ");
        emit($cg, "  else if (__rr->type == STRADA_REF) __rt = \"REF\"; ");
        emit($cg, "  else __rt = \"SCALAR\"; } ");
        emit($cg, "else if (__rv->type == STRADA_HASH) { ");
        emit($cg, "  const char *__bp = (__rv->meta && __rv->meta->blessed_package) ? __rv->meta->blessed_package : NULL; ");
        emit($cg, "  __rt = __bp ? __bp : \"HASH\"; } ");
        emit($cg, "else if (__rv->type == STRADA_ARRAY) { ");
        emit($cg, "  const char *__bp = (__rv->meta && __rv->meta->blessed_package) ? __rv->meta->blessed_package : NULL; ");
        emit($cg, "  __rt = __bp ? __bp : \"ARRAY\"; } ");
        emit($cg, "else if (__rv->type == STRADA_CLOSURE || __rv->type == STRADA_CPOINTER) { ");
        emit($cg, "  const char *__bp = (__rv->meta && __rv->meta->blessed_package) ? __rv->meta->blessed_package : NULL; ");
        emit($cg, "  __rt = __bp ? __bp : \"CODE\"; } ");
        # Non-ref types (STRADA_STR/INT/NUM) can carry blessed_package
        # too — used by qr// to mark its returned string as 'Regexp' so
        # `ref(qr/.../) eq "Regexp"` matches Perl's behavior. DBIC's
        # _Util::sigwarn_silencer relies on that check.
        emit($cg, "else if (__rv->meta && __rv->meta->blessed_package) __rt = __rv->meta->blessed_package; ");
        emit($cg, "else __rt = \"\"; ");
        emit($cg, "strada_new_str(__rt); })");
        return;
    }

    # shift
    if ($name eq "shift") {
        if ($argc > 0) {
            # Tied-aware: dispatch SHIFT on tied SV, else raw shift.
            # Force list-context around the arg so a DEREF_ARRAY in
            # scalar context isn't collapsed to its length.
            emit($cg, "({ int __sav_wl_sh = __perla_want_list; __perla_want_list = 1; StradaValue *__sh_sv = ");
            gen_expr($cg, $args->[0]);
            emit($cg, "; __perla_want_list = __sav_wl_sh; (__sh_sv && !STRADA_IS_TAGGED_INT(__sh_sv) && __sh_sv->meta && __sh_sv->meta->is_tied) ? strada_tied_array_shift(__sh_sv) : strada_array_shift(strada_deref_array(__sh_sv)); })");
        } else {
            # Bare shift = shift(@_) — @_ is never tied; raw call.
            emit($cg, "strada_array_shift(strada_deref_array(perla_at_))");
        }
        return;
    }

    # pop
    if ($name eq "pop") {
        if ($argc > 0) {
            # Tied-aware: dispatch POP on tied SV, else raw pop.
            # Force list-context (see shift).
            emit($cg, "({ int __sav_wl_po = __perla_want_list; __perla_want_list = 1; StradaValue *__po_sv = ");
            gen_expr($cg, $args->[0]);
            emit($cg, "; __perla_want_list = __sav_wl_po; (__po_sv && !STRADA_IS_TAGGED_INT(__po_sv) && __po_sv->meta && __po_sv->meta->is_tied) ? strada_tied_array_pop(__po_sv) : strada_array_pop(strada_deref_array(__po_sv)); })");
        } else {
            emit($cg, "strada_array_pop(strada_deref_array(perla_at_))");
        }
        return;
    }

    # push
    if ($name eq "push") {
        # Fast path: `push @arr, simple_val_1, ..., simple_val_N` where
        # every value-arg is a scalar (no array/hash flattening) and the
        # destination is a non-tied lexical array. Skip the __tp_args
        # wrapper array — emit one strada_array_push_take per arg
        # directly into the destination array. Tied-dispatch still
        # handled via a runtime meta check; the fast path applies only
        # when the meta indicates no tie.
        #
        # Win: bench_data's tight `push(@arr, $i*$i)` loop is the
        # canonical case — 50k iterations × (alloc args array + free)
        # collapses to 50k direct pushes.
        if ($argc >= 2 && defined($args->[0])
            && $args->[0]->{"type"} == Perla::AST::N_ARRAY_VAR()
            && defined($args->[0]->{"name"})
            && index($args->[0]->{"name"}, "::") < 0
            && $args->[0]->{"name"} ne "_") {
            my str $__tp_name = $args->[0]->{"name"};
            my str $__tp_cvar = c_var_a($__tp_name);
            # Detect "all simple value args" — every arg is something
            # that produces a single scalar (no array flatten, no
            # range, no anon-list, no call returning a list).
            my int $all_simple = 1;
            my int $__tspi = 1;
            while ($__tspi < $argc) {
                my int $tt = $args->[$__tspi]->{"type"};
                if ($tt == Perla::AST::N_ARRAY_VAR()
                    || $tt == Perla::AST::N_DEREF_ARRAY()
                    || $tt == Perla::AST::N_RANGE()
                    || $tt == Perla::AST::N_CALL()
                    || $tt == Perla::AST::N_METHOD()
                    || $tt == Perla::AST::N_ANON_ARRAY()
                    || $tt == Perla::AST::N_HASH_VAR()
                    || $tt == Perla::AST::N_DEREF_HASH()
                    || $tt == Perla::AST::N_ARRAY_SLICE()
                    || $tt == Perla::AST::N_HASH_SLICE()
                    || $tt == Perla::AST::N_MAP()
                    || $tt == Perla::AST::N_GREP()
                    || $tt == Perla::AST::N_SORT()) {
                    $all_simple = 0;
                    last;
                }
                $__tspi = $__tspi + 1;
            }
            if ($all_simple == 1) {
                # Inline N pushes: one stmt-expr that ends in the new
                # length. Tied-check at top; if untied (the hot case),
                # push each arg directly into the dest array.
                #
                # Evaluate arg expressions ONCE up front into __tp_v_N
                # locals — calling gen_expr twice on the same node
                # (once for the tied branch, once for the untied) is
                # only correct for pure expressions; anon-sub-as-expr
                # mutates the node (assigns a synthesized name) and
                # the second call falls into a fallback emit. Compute
                # once, dispatch by tied flag.
                emit($cg, "({ StradaValue *__tp_sv = " . $__tp_cvar . "; ");
                my int $sp_i = 1;
                while ($sp_i < $argc) {
                    emit($cg, "StradaValue *__tp_v_" . $sp_i . " = ");
                    gen_expr($cg, $args->[$sp_i]);
                    emit($cg, "; ");
                    $sp_i = $sp_i + 1;
                }
                emit($cg, "int64_t __tp_n; ");
                emit($cg, "if (__builtin_expect(__tp_sv && !STRADA_IS_TAGGED_INT(__tp_sv) && __tp_sv->meta && __tp_sv->meta->is_tied, 0)) { ");
                # Slow tied path — build args array, dispatch PUSH.
                emit($cg, "  StradaValue *__tp_args = strada_new_array(); StradaArray *__tp_av = strada_deref_array(__tp_args); ");
                $sp_i = 1;
                while ($sp_i < $argc) {
                    emit($cg, "  if (__tp_v_" . $sp_i . ") strada_incref(__tp_v_" . $sp_i . "); strada_array_push_take(__tp_av, __tp_v_" . $sp_i . "); ");
                    $sp_i = $sp_i + 1;
                }
                emit($cg, "  __tp_n = strada_tied_array_push(__tp_sv, __tp_args); ");
                emit($cg, "  strada_decref(__tp_args); ");
                emit($cg, "} else { ");
                # Fast path — direct push into the deref'd array.
                emit($cg, "  StradaArray *__tp_dav = strada_deref_array(__tp_sv); ");
                $sp_i = 1;
                while ($sp_i < $argc) {
                    emit($cg, "  if (__tp_v_" . $sp_i . ") strada_incref(__tp_v_" . $sp_i . "); strada_array_push_take(__tp_dav, __tp_v_" . $sp_i . "); ");
                    $sp_i = $sp_i + 1;
                }
                emit($cg, "  __tp_n = (int64_t)strada_array_length(__tp_dav); ");
                emit($cg, "} ");
                # Release the locals: owned expressions need decref to
                # balance gen_expr's +1; borrowed exprs are referenced
                # only via __tp_v_N here and need decref to balance the
                # push's incref. Either way: decref every __tp_v_N once.
                # (For borrowed exprs whose gen_expr didn't incref, the
                # push's incref + this decref are a wash.)
                $sp_i = 1;
                while ($sp_i < $argc) {
                    # Only decref owned exprs — borrowed exprs would underflow.
                    if (expr_is_borrowed($args->[$sp_i]) == 0) {
                        emit($cg, "if (__tp_v_" . $sp_i . ") strada_decref(__tp_v_" . $sp_i . "); ");
                    }
                    $sp_i = $sp_i + 1;
                }
                emit($cg, "STRADA_MAKE_TAGGED_INT(__tp_n); })");
                return;
            }
            # Statement-expression that ends in a tagged-int (the result
            # length). Build args array once; if tied, dispatch PUSH;
            # else push each element into the raw StradaArray.
            emit($cg, "({ StradaValue *__tp_sv = " . $__tp_cvar . "; ");
            emit($cg, "StradaValue *__tp_args = strada_new_array(); StradaArray *__tp_av = strada_deref_array(__tp_args); ");
            my int $__tpi = 1;
            while ($__tpi < $argc) {
                my scalar $__tp_arg = $args->[$__tpi];
                my int $__tp_at = $__tp_arg->{"type"};
                # `push @arr, (L1, L2, ...)` — the parens parse to a
                # non-ref N_ANON_ARRAY; perl semantics flatten it as
                # `push @arr, L1, L2, …`. Without this, the general path
                # gen_expr'd the ANON_ARRAY in (effectively scalar) push-arg
                # context and pushed its last element (or worse, an empty
                # placeholder when want_list was -1). Now we walk the elems
                # in-place and push each as its own item.
                if ($__tp_at == Perla::AST::N_ANON_ARRAY()
                    && (!defined($__tp_arg->{"is_ref"}) || $__tp_arg->{"is_ref"} == 0)
                    && defined($__tp_arg->{"elems"})) {
                    my scalar $__tp_elems = $__tp_arg->{"elems"};
                    my int $__tp_ne = scalar(@{$__tp_elems});
                    my int $__tp_ei = 0;
                    while ($__tp_ei < $__tp_ne) {
                        my scalar $__tp_el = $__tp_elems->[$__tp_ei];
                        my int $__tp_el_t = $__tp_el->{"type"};
                        # Inner element may itself need list-context for
                        # array/range/call expansion.
                        my int $__tp_el_is_call = ($__tp_el_t == Perla::AST::N_CALL()
                                                  || $__tp_el_t == Perla::AST::N_METHOD()) ? 1 : 0;
                        if ($__tp_el_t == Perla::AST::N_ARRAY_VAR()
                            || $__tp_el_t == Perla::AST::N_DEREF_ARRAY()
                            || $__tp_el_t == Perla::AST::N_RANGE()
                            || $__tp_el_is_call == 1) {
                            my int $__tp_el_owned = ($__tp_el_t == Perla::AST::N_RANGE()
                                                    || $__tp_el_is_call == 1) ? 1 : 0;
                            if ($__tp_el_is_call == 1) {
                                emit($cg, "{ int __tp_sav_wl = __perla_want_list; __perla_want_list = 1; StradaValue *__tp_v = ");
                                gen_expr($cg, $__tp_el);
                                emit($cg, "; __perla_want_list = __tp_sav_wl; ");
                            } else {
                                emit($cg, "{ StradaValue *__tp_v = ");
                                gen_expr($cg, $__tp_el);
                                emit($cg, "; ");
                            }
                            emit($cg, "if (__tp_v && !STRADA_IS_TAGGED_INT(__tp_v) && __tp_v->type == STRADA_ARRAY) { StradaArray *__tp_va = strada_deref_array(__tp_v); for (size_t __tpfi = 0; __tpfi < __tp_va->size; __tpfi++) { StradaValue *__tpe = __tp_va->elements[__tp_va->head + __tpfi]; if (__tpe) strada_incref(__tpe); strada_array_push_take(__tp_av, __tpe); } } else if (__tp_v) { strada_incref(__tp_v); strada_array_push_take(__tp_av, __tp_v); } ");
                            if ($__tp_el_owned == 1) {
                                emit($cg, "if (__tp_v) strada_decref(__tp_v); ");
                            }
                            emit($cg, "} ");
                        } else {
                            emit($cg, "{ StradaValue *__tp_v = ");
                            gen_expr($cg, $__tp_el);
                            emit($cg, "; if (__tp_v) strada_incref(__tp_v); strada_array_push_take(__tp_av, __tp_v); } ");
                        }
                        $__tp_ei = $__tp_ei + 1;
                    }
                    $__tpi = $__tpi + 1;
                    next;
                }
                # Force list context around sub/method calls so their
                # `return (a, b, c)` produces an array. Without this,
                # `push @arr, sub_returning_list()` saw the call in
                # whatever the outer context was (often scalar) and
                # the call returned just its last element.
                my int $__tp_is_call = ($__tp_at == Perla::AST::N_CALL()
                                       || $__tp_at == Perla::AST::N_METHOD()) ? 1 : 0;
                if ($__tp_at == Perla::AST::N_ARRAY_VAR()
                    || $__tp_at == Perla::AST::N_DEREF_ARRAY()
                    || $__tp_at == Perla::AST::N_RANGE()
                    || $__tp_is_call == 1) {
                    # ARRAY_VAR and DEREF_ARRAY produce borrowed pointers
                    # — the source still owns them. Decreffing __tp_v at
                    # loop end frees the source's container. RANGE and
                    # CALL produce owned values, must decref.
                    my int $__tp_owned = ($__tp_at == Perla::AST::N_RANGE()
                                          || $__tp_is_call == 1) ? 1 : 0;
                    if ($__tp_is_call == 1) {
                        emit($cg, "{ int __tp_sav_wl = __perla_want_list; __perla_want_list = 1; StradaValue *__tp_v = ");
                        gen_expr($cg, $__tp_arg);
                        emit($cg, "; __perla_want_list = __tp_sav_wl; ");
                    } else {
                        emit($cg, "{ StradaValue *__tp_v = ");
                        gen_expr($cg, $__tp_arg);
                        emit($cg, "; ");
                    }
                    emit($cg, "if (__tp_v && !STRADA_IS_TAGGED_INT(__tp_v) && __tp_v->type == STRADA_ARRAY) { StradaArray *__tp_va = strada_deref_array(__tp_v); for (size_t __tpfi = 0; __tpfi < __tp_va->size; __tpfi++) { StradaValue *__tpe = __tp_va->elements[__tp_va->head + __tpfi]; if (__tpe) strada_incref(__tpe); strada_array_push_take(__tp_av, __tpe); } } else if (__tp_v) { strada_incref(__tp_v); strada_array_push_take(__tp_av, __tp_v); } ");
                    if ($__tp_owned == 1) {
                        emit($cg, "if (__tp_v) strada_decref(__tp_v); ");
                    }
                    emit($cg, "} ");
                } else {
                    emit($cg, "{ StradaValue *__tp_v = ");
                    gen_expr($cg, $__tp_arg);
                    emit($cg, "; if (__tp_v) strada_incref(__tp_v); strada_array_push_take(__tp_av, __tp_v); } ");
                }
                $__tpi = $__tpi + 1;
            }
            emit($cg, "int64_t __tp_n; ");
            emit($cg, "if (__tp_sv && !STRADA_IS_TAGGED_INT(__tp_sv) && __tp_sv->meta && __tp_sv->meta->is_tied) { ");
            emit($cg, "  __tp_n = strada_tied_array_push(__tp_sv, __tp_args); ");
            emit($cg, "} else { ");
            emit($cg, "  StradaArray *__tp_dav = strada_deref_array(__tp_sv); ");
            emit($cg, "  StradaArray *__tp_pav = strada_deref_array(__tp_args); ");
            emit($cg, "  for (size_t __tp_si = 0; __tp_si < __tp_pav->size; __tp_si++) { StradaValue *__tpe = __tp_pav->elements[__tp_pav->head + __tp_si]; if (__tpe) strada_incref(__tpe); strada_array_push_take(__tp_dav, __tpe); } ");
            emit($cg, "  __tp_n = (int64_t)strada_array_length(__tp_dav); ");
            emit($cg, "} strada_decref(__tp_args); STRADA_MAKE_TAGGED_INT(__tp_n); })");
            return;
        }
        if ($argc >= 2) {
            # `push @arr, (LIST)` parses as `push @arr, ANON_ARRAY(elems=LIST)`
            # (without is_ref). Perl semantics: parens here are just list
            # grouping — flatten as if `push @arr, LIST` had been written.
            # Without this, `push @ret, (@r1, @r2)` stored the constructed
            # list as a single element. Surfaced via DBIC's
            # `_resolve_join`'s HASH branch (`push @ret, (@r1, @r2);`)
            # producing wrong join entries; prefetch queries had empty
            # alias_maps as a result.
            if ($argc == 2 && defined($args->[1])
                && $args->[1]->{"type"} == Perla::AST::N_ANON_ARRAY()
                && (!defined($args->[1]->{"is_ref"}) || $args->[1]->{"is_ref"} == 0)) {
                my scalar $elems = $args->[1]->{"elems"};
                my int $ne = defined($elems) ? scalar(@{$elems}) : 0;
                # `push @{$h->{key}}, A, B, C` — autovivify when
                # $h->{key} is undef so the multi-arg push lands in
                # a real array. Without this, `@{undef}` returns a
                # fresh transient array that isn't stored back, and
                # the pushes disappear. Mirrors the same autoviv we
                # do for the single-element push path below.
                my scalar $marr_arg = $args->[0];
                my int $marr_t = $marr_arg->{"type"};
                my int $did_av = 0;
                if ($marr_t == Perla::AST::N_DEREF_ARRAY() && defined($marr_arg->{"ref"})) {
                    my scalar $minner = $marr_arg->{"ref"};
                    my int $minner_t = $minner->{"type"};
                    if ($minner_t == Perla::AST::N_ARROW_HASH() || $minner_t == Perla::AST::N_HASH_ELEM()) {
                        # Walk the parent chain: if the outer hash is itself
                        # a nested hash access (e.g. `$multi{outer}{inner}`),
                        # autovivify intermediate hashrefs via
                        # `_gen_autoviv_hash` rather than a bare read. A
                        # bare read returns undef for missing intermediates
                        # and `strada_deref_hash(undef)` → NULL, which
                        # silently dropped the push.
                        my scalar $outer_node;
                        my int $outer_is_hash_ctx = 0;
                        if ($minner_t == Perla::AST::N_ARROW_HASH()) {
                            $outer_node = $minner->{"object"};
                            # `$h{k}` (no arrow) parses as N_ARROW_HASH with
                            # is_explicit_arrow unset — it's a hash-sigil
                            # access, so the OUTER variable name should bind
                            # to the %-storage (`v_X__h`) under name collision.
                            if (!defined($minner->{"is_explicit_arrow"}) || $minner->{"is_explicit_arrow"} != 1) {
                                $outer_is_hash_ctx = 1;
                            }
                        } else {
                            $outer_node = $minner->{"hash"};
                            $outer_is_hash_ctx = 1;
                        }
                        emit($cg, "({ StradaValue *__avh = ");
                        _gen_autoviv_outer_hash($cg, $outer_node, $outer_is_hash_ctx);
                        emit($cg, "; char *__avk = strada_to_str(");
                        gen_expr($cg, $minner->{"key"});
                        emit($cg, "); StradaHash *__avhv = strada_deref_hash(__avh); ");
                        emit($cg, "StradaValue *__avs = __avhv ? strada_hash_get(__avhv, __avk) : NULL; ");
                        emit($cg, "if (!__avs || STRADA_IS_TAGGED_INT(__avs) || ");
                        emit($cg, "  __avs->type != STRADA_REF || !__avs->value.rv || ");
                        emit($cg, "  __avs->value.rv->type != STRADA_ARRAY) { ");
                        emit($cg, "  StradaValue *__newref = strada_new_ref_take(strada_new_array(), '@'); ");
                        emit($cg, "  if (__avhv) strada_hash_set_take(__avhv, __avk, __newref); ");
                        emit($cg, "  __avs = __newref; ");
                        emit($cg, "} StradaArray *__pa = strada_deref_array(__avs); ");
                        emit($cg, "free(__avk); ");
                        $did_av = 1;
                    }
                }
                if ($did_av == 0) {
                    emit($cg, "({ StradaArray *__pa = strada_deref_array(");
                    gen_expr($cg, $args->[0]);
                    emit($cg, "); ");
                }
                my int $ei = 0;
                while ($ei < $ne) {
                    my scalar $el = $elems->[$ei];
                    my int $el_t = $el->{"type"};
                    # Each LIST element: if it's an array var, deref, slice,
                    # or anything that may yield a list (call/method/binop/
                    # ternary), flatten its contents; otherwise push as
                    # single value.
                    if ($el_t == Perla::AST::N_ARRAY_VAR()
                        || $el_t == Perla::AST::N_DEREF_ARRAY()
                        || $el_t == Perla::AST::N_ARRAY_SLICE()
                        || $el_t == Perla::AST::N_HASH_SLICE()
                        || $el_t == Perla::AST::N_CALL()
                        || $el_t == Perla::AST::N_METHOD()
                        || $el_t == Perla::AST::N_GREP()
                        || $el_t == Perla::AST::N_MAP()
                        || $el_t == Perla::AST::N_SORT()
                        || $el_t == Perla::AST::N_BINOP()
                        || $el_t == Perla::AST::N_TERNARY()) {
                        emit($cg, "{ StradaValue *__fv = ");
                        gen_expr($cg, $el);
                        emit($cg, "; if (__fv && !STRADA_IS_TAGGED_INT(__fv) && __fv->type == STRADA_ARRAY) { ");
                        emit($cg, "StradaArray *__fa = __fv->value.av; ");
                        # Snapshot __fa->size before the loop — `push @arr, @arr`
                        # has __fa == __pa, so growing __pa via push would extend
                        # the loop bound forever.
                        emit($cg, "size_t __fa_sz0 = __fa ? __fa->size : 0; ");
                        emit($cg, "size_t __fa_hd0 = __fa ? __fa->head : 0; ");
                        emit($cg, "for (size_t __fi = 0; __fi < __fa_sz0; __fi++) strada_array_push(__pa, __fa->elements[__fa_hd0 + __fi]); ");
                        emit($cg, "} else { strada_array_push(__pa, __fv); } } ");
                    } else {
                        emit($cg, "strada_array_push(__pa, ");
                        gen_expr($cg, $el);
                        emit($cg, "); ");
                    }
                    $ei++;
                }
                emit($cg, "STRADA_MAKE_TAGGED_INT((int64_t)(__pa ? __pa->size : 0)); })");
                return;
            }
            if ($argc == 2) {
                my scalar $push_val = $args->[1];
                my int $pv_type = $push_val->{"type"};
                # Flatten function/list-op call results (functions may return
                # arrays, and map/grep/sort always do). Without N_GREP/N_MAP/
                # N_SORT in the flatten set, `push @_, grep !/import/, @f`
                # stored the grep result as a SINGLE array element instead of
                # appending each element — YAML::Mo's sub_5 couldn't build
                # the `(builder, default)` arg list for sub_2, and the
                # wrapper chain never installed %o entries.
                # N_ARRAY_VAR / N_DEREF_ARRAY / *_SLICE: `push @results, @bind`
                # must flatten. Without this, push treats @bind as a single
                # array-ref element, defeating Perl semantics (`push @a, @b` is
                # equivalent to `push @a, $b[0], $b[1], ...`). Surfaced in
                # SAC's `_where_HASHREF` push of @bind from each clause —
                # bind list always ended up as zero placeholders even though
                # the per-call @bind had values.
                if ($pv_type == Perla::AST::N_CALL() || $pv_type == Perla::AST::N_METHOD()
                    || $pv_type == Perla::AST::N_GREP() || $pv_type == Perla::AST::N_MAP()
                    || $pv_type == Perla::AST::N_SORT()
                    || $pv_type == Perla::AST::N_ARRAY_VAR()
                    || $pv_type == Perla::AST::N_DEREF_ARRAY()
                    || $pv_type == Perla::AST::N_ARRAY_SLICE()
                    || $pv_type == Perla::AST::N_HASH_SLICE()
                    || $pv_type == Perla::AST::N_RANGE()
                    || $pv_type == Perla::AST::N_TERNARY()
                    || $pv_type == Perla::AST::N_QWORD()) {
                    # N_RANGE in list context flattens: `push @a, 1..5`
                    # pushes 5 elements, not one range-array.
                    # N_TERNARY can yield a list-returning branch:
                    # `push @r, cond ? fn(...) : $scalar` — the list
                    # branch should expand each element, not be pushed
                    # as one array. Without N_TERNARY here, recursive
                    # flatten patterns like `push @r, ref($_) eq 'ARRAY'
                    # ? flat_n(@$_) : $_` pushed the entire returned
                    # array as a single element.
                    # `push @{$h->{key}}, LIST` — autovivify the slot when
                    # undef so the push lands in a real array (Perl semantics).
                    # Required for SAC's
                    # `push @{$self->{where_bind}}, @bind` where `where_bind`
                    # starts undef and the slurp-into-array form would
                    # silently no-op via `strada_deref_array(undef) = NULL`.
                    my scalar $arr_arg_f = $args->[0];
                    my int $arr_t_f = $arr_arg_f->{"type"};
                    if ($arr_t_f == Perla::AST::N_DEREF_ARRAY() && defined($arr_arg_f->{"ref"})) {
                        my scalar $inner_f = $arr_arg_f->{"ref"};
                        my int $inner_t_f = $inner_f->{"type"};
                        if ($inner_t_f == Perla::AST::N_ARROW_HASH() || $inner_t_f == Perla::AST::N_HASH_ELEM()) {
                            my scalar $outer_f;
                            if ($inner_t_f == Perla::AST::N_ARROW_HASH()) {
                                $outer_f = $inner_f->{"object"};
                            } else {
                                $outer_f = $inner_f->{"hash"};
                            }
                            my int $outer_t_f = $outer_f->{"type"};
                            emit($cg, "({ StradaValue *__avh_f = ");
                            if ($outer_t_f == Perla::AST::N_HASH_ELEM() || $outer_t_f == Perla::AST::N_ARROW_HASH()) {
                                _gen_autoviv_hash($cg, $outer_f);
                            } else {
                                gen_expr($cg, $outer_f);
                            }
                            emit($cg, "; char *__avk_f = strada_to_str(");
                            gen_expr($cg, $inner_f->{"key"});
                            emit($cg, "); StradaHash *__avhv_f = strada_deref_hash(__avh_f); ");
                            emit($cg, "StradaValue *__avs_f = __avhv_f ? strada_hash_get(__avhv_f, __avk_f) : NULL; ");
                            emit($cg, "if (!__avs_f || STRADA_IS_TAGGED_INT(__avs_f) || ");
                            emit($cg, "  __avs_f->type != STRADA_REF || !__avs_f->value.rv || ");
                            emit($cg, "  __avs_f->value.rv->type != STRADA_ARRAY) { ");
                            emit($cg, "  StradaValue *__newref = strada_new_ref_take(strada_new_array(), '@'); ");
                            emit($cg, "  if (__avhv_f) strada_hash_set_take(__avhv_f, __avk_f, __newref); ");
                            emit($cg, "  __avs_f = __newref; ");
                            emit($cg, "} StradaArray *__pa = strada_deref_array(__avs_f); ");
                            emit($cg, "int __sav_wl = __perla_want_list; __perla_want_list = 1; StradaValue *__pv = ");
                            gen_expr($cg, $push_val);
                            emit($cg, "; __perla_want_list = __sav_wl; ");
                            emit($cg, "if (__pv && !STRADA_IS_TAGGED_INT(__pv) && __pv->type == STRADA_ARRAY) { ");
                            emit($cg, "StradaArray *__fa = __pv->value.av; ");
                            emit($cg, "size_t __fa_sz0 = __fa ? __fa->size : 0; size_t __fa_hd0 = __fa ? __fa->head : 0; ");
                            emit($cg, "for (size_t __fi = 0; __fi < __fa_sz0; __fi++) strada_array_push(__pa, __fa->elements[__fa_hd0 + __fi]); ");
                            emit($cg, "} else { strada_array_push(__pa, __pv); } ");
                            emit($cg, "free(__avk_f); STRADA_MAKE_TAGGED_INT((int64_t)(__pa ? __pa->size : 0)); })");
                            return;
                        }
                    }
                    # Set want_list=1 around the call so a `return (a,b,c)`
                    # callee returns the full list (not the scalar-context
                    # last element). Without this, `push @arr, $obj->fn()`
                    # only pushed the last element of fn's return list.
                    # __fa_sz0 snapshot prevents infinite loop on
                    # `push @arr, @arr` (the source and dest share storage).
                    emit($cg, "({ StradaArray *__pa = strada_deref_array(");
                    gen_expr($cg, $args->[0]);
                    emit($cg, "); int __sav_wl = __perla_want_list; __perla_want_list = 1; StradaValue *__pv = ");
                    gen_expr($cg, $push_val);
                    emit($cg, "; __perla_want_list = __sav_wl; if (__pv && !STRADA_IS_TAGGED_INT(__pv) && __pv->type == STRADA_ARRAY) { ");
                    emit($cg, "StradaArray *__fa = __pv->value.av; ");
                    emit($cg, "size_t __fa_sz0 = __fa ? __fa->size : 0; size_t __fa_hd0 = __fa ? __fa->head : 0; ");
                    emit($cg, "for (size_t __fi = 0; __fi < __fa_sz0; __fi++) strada_array_push(__pa, __fa->elements[__fa_hd0 + __fi]); ");
                    emit($cg, "} else { strada_array_push(__pa, __pv); } STRADA_MAKE_TAGGED_INT((int64_t)(__pa ? __pa->size : 0)); })");
                } else {
                    # `push @{$h->{key}}, X` — autovivify when $h->{key} is
                    # undef so the push lands in a real array (Perl semantics:
                    # `push @{undef_slot}, X` creates the slot). Without this,
                    # `strada_deref_array(undef)` returns NULL and the push
                    # silently no-ops. Surfaced via DBIC's
                    # `push @{$p->{-join_aliases}}, $alias` in
                    # `_resolve_prefetch`'s alias-map building.
                    my scalar $arr_arg = $args->[0];
                    my int $arr_t = $arr_arg->{"type"};
                    if ($arr_t == Perla::AST::N_DEREF_ARRAY() && defined($arr_arg->{"ref"})) {
                        my scalar $inner = $arr_arg->{"ref"};
                        my int $inner_t = $inner->{"type"};
                        if ($inner_t == Perla::AST::N_ARROW_HASH() || $inner_t == Perla::AST::N_HASH_ELEM()) {
                            my scalar $outer_s;
                            my int $outer_s_hash_ctx = 0;
                            if ($inner_t == Perla::AST::N_ARROW_HASH()) {
                                $outer_s = $inner->{"object"};
                                if (!defined($inner->{"is_explicit_arrow"}) || $inner->{"is_explicit_arrow"} != 1) {
                                    $outer_s_hash_ctx = 1;
                                }
                            } else {
                                $outer_s = $inner->{"hash"};
                                $outer_s_hash_ctx = 1;
                            }
                            emit($cg, "({ StradaValue *__avh = ");
                            _gen_autoviv_outer_hash($cg, $outer_s, $outer_s_hash_ctx);
                            emit($cg, "; char *__avk = strada_to_str(");
                            gen_expr($cg, $inner->{"key"});
                            emit($cg, "); StradaHash *__avhv = strada_deref_hash(__avh); ");
                            emit($cg, "StradaValue *__avs = __avhv ? strada_hash_get(__avhv, __avk) : NULL; ");
                            emit($cg, "if (!__avs || STRADA_IS_TAGGED_INT(__avs) || ");
                            emit($cg, "  __avs->type != STRADA_REF || !__avs->value.rv || ");
                            emit($cg, "  __avs->value.rv->type != STRADA_ARRAY) { ");
                            emit($cg, "  StradaValue *__newref = strada_new_ref_take(strada_new_array(), '@'); ");
                            emit($cg, "  if (__avhv) strada_hash_set_take(__avhv, __avk, __newref); ");
                            emit($cg, "  __avs = __newref; ");
                            emit($cg, "} ");
                            emit($cg, "StradaValue *__pv = ");
                            gen_expr($cg, $push_val);
                            emit($cg, "; StradaArray *__pa = strada_deref_array(__avs); strada_array_push(__pa, __pv); ");
                            emit($cg, "free(__avk); STRADA_MAKE_TAGGED_INT((int64_t)(__pa ? __pa->size : 0)); })");
                            return;
                        }
                        # `push @{$cols[$i]}, X` — autovivify the array
                        # element slot. Mirrors the hash branch above.
                        # Without this, transpose-style code like
                        # `push @{$cols[$i]}, $r->[$i]` silently no-ops
                        # because strada_deref_array(undef_slot) = NULL.
                        if ($inner_t == Perla::AST::N_ARROW_ARRAY() || $inner_t == Perla::AST::N_ARRAY_ELEM()) {
                            emit($cg, "({ StradaArray *__avha = strada_deref_array(");
                            # `push @{$_[N]}, X` parses with inner =
                            # N_ARROW_ARRAY{object=$_, is_explicit_arrow=0}
                            # — meaning `$_[N]` is element of @_, NOT a
                            # deref of scalar $_. Mirror the bare-subscript
                            # special-cases from the main N_ARROW_ARRAY
                            # codegen so the autoviv path agrees with the
                            # main read/write paths. Without these,
                            # `push @{$_[0]}, $val` deref'd
                            # perla_dollar_underscore and silently failed.
                            my scalar $__paa_obj;
                            my int $__paa_is_arrow = 0;
                            if ($inner_t == Perla::AST::N_ARROW_ARRAY()) {
                                $__paa_obj = $inner->{"object"};
                                if (defined($inner->{"is_explicit_arrow"}) && $inner->{"is_explicit_arrow"} == 1) { $__paa_is_arrow = 1; }
                            } else {
                                $__paa_obj = $inner->{"array"};
                            }
                            if ($__paa_is_arrow == 0
                                && defined($__paa_obj)
                                && $__paa_obj->{"type"} == Perla::AST::N_SCALAR_VAR()
                                && defined($__paa_obj->{"name"})
                                && $__paa_obj->{"name"} eq "_") {
                                emit($cg, "perla_at_");
                            } elsif ($__paa_is_arrow == 0
                                && defined($__paa_obj)
                                && $__paa_obj->{"type"} == Perla::AST::N_SCALAR_VAR()
                                && defined($__paa_obj->{"name"})
                                && index($__paa_obj->{"name"}, "::") < 0) {
                                emit($cg, c_var_a($__paa_obj->{"name"}));
                            } else {
                                if ($inner_t == Perla::AST::N_ARROW_ARRAY()) {
                                    gen_expr($cg, $inner->{"object"});
                                } else {
                                    gen_expr($cg, $inner->{"array"});
                                }
                            }
                            emit($cg, "); int __avi = (int)strada_to_int(");
                            gen_expr($cg, $inner->{"index"});
                            emit($cg, "); if (__avi < 0 && __avha) __avi += strada_array_length(__avha); ");
                            emit($cg, "StradaValue *__avs = __avha ? strada_array_get(__avha, __avi) : NULL; ");
                            emit($cg, "if (!__avs || STRADA_IS_TAGGED_INT(__avs) || ");
                            emit($cg, "  __avs->type != STRADA_REF || !__avs->value.rv || ");
                            emit($cg, "  __avs->value.rv->type != STRADA_ARRAY) { ");
                            emit($cg, "  StradaValue *__newref = strada_new_ref_take(strada_new_array(), '@'); ");
                            emit($cg, "  if (__avha) strada_array_set(__avha, __avi, __newref); ");
                            emit($cg, "  __avs = __newref; ");
                            emit($cg, "} ");
                            emit($cg, "StradaValue *__pv = ");
                            gen_expr($cg, $push_val);
                            emit($cg, "; StradaArray *__pa = strada_deref_array(__avs); strada_array_push(__pa, __pv); ");
                            emit($cg, "STRADA_MAKE_TAGGED_INT((int64_t)(__pa ? __pa->size : 0)); })");
                            return;
                        }
                    }
                    # Decref __pv if it was an owned temp (e.g. concat /
                    # literal); push increfs internally so owned values
                    # end with rc=2 (array + creator) and the creator's
                    # ref leaks. Borrowed values (variables) stay alive
                    # via their owning slot.
                    my int $pv_borrowed_2 = expr_is_borrowed($push_val);
                    emit($cg, "({ StradaValue *__pv = ");
                    gen_expr($cg, $push_val);
                    emit($cg, "; StradaArray *__pa = strada_deref_array(");
                    gen_expr($cg, $args->[0]);
                    emit($cg, "); strada_array_push(__pa, __pv); ");
                    if ($pv_borrowed_2 == 0) {
                        emit($cg, "if (__pv) strada_decref(__pv); ");
                    }
