            emit($cg, "if (__wh && !STRADA_IS_TAGGED_INT(__wh) && __wh->type == STRADA_CLOSURE) { ");
            emit($cg, "  StradaValue *__wa = strada_new_array(); strada_array_push(strada_deref_array(__wa), strada_new_str(\"Warning: something's wrong\\n\")); ");
            emit($cg, "  StradaValue *__wr = perla_call_code(__wh, __wa); if (__wr) strada_decref(__wr); strada_decref(__wa); ");
