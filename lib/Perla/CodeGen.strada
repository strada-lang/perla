        if ($__db_last_t == Perla::AST::N_FOREACH()
            || $__db_last_t == Perla::AST::N_FOR_C()
            || $__db_last_t == Perla::AST::N_WHILE()
            || $__db_last_t == Perla::AST::N_UNTIL()) {
