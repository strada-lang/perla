        emit($cg, "  char __wloc[512]; ");
        emit($cg, "  int __wllen = snprintf(__wloc, sizeof(__wloc), \" at %s line " . $warn_line . ".\\n\", __wfile); ");
        emit($cg, "  if (__wllen > 0) { ");
        emit($cg, "    if (__wblen + __wllen + 1 > __wbcap) { __wbcap = __wblen + __wllen + 1; __wbuf = realloc(__wbuf, __wbcap); } ");
        emit($cg, "    memcpy(__wbuf + __wblen, __wloc, __wllen); __wblen += __wllen; ");
        emit($cg, "  } ");
        emit($cg, "} ");
        emit($cg, "if (__wbuf) __wbuf[__wblen] = '\\0'; ");
        emit($cg, "StradaValue *__wh = (v_SIG && !STRADA_IS_TAGGED_INT(v_SIG) && v_SIG->type == STRADA_HASH) ? strada_hash_get(v_SIG->value.hv, \"__WARN__\") : NULL; ");
        emit($cg, "if (__wh && !STRADA_IS_TAGGED_INT(__wh) && (__wh->type == STRADA_CLOSURE || __wh->type == STRADA_CPOINTER)) { ");
        emit($cg, "  StradaValue *__wa = strada_new_array(); strada_array_push(strada_deref_array(__wa), strada_new_str_len(__wbuf ? __wbuf : \"\", __wblen)); ");
        emit($cg, "  StradaValue *__wr = perla_call_code(__wh, __wa); if (__wr) strada_decref(__wr); strada_decref(__wa); ");
