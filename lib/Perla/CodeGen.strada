            # write `$_[0]{$n} = $g->(@_)` as the last expression and have
            # the sub return the default value. Capture the RHS first and
            # yield it from the statement expression.
            emit($cg, "({ char *__k = strada_to_str(");
            gen_expr($cg, $target->{"key"});
            emit($cg, "); StradaValue *__hv_val = ");
            gen_expr($cg, $node->{"value"});
            emit($cg, "; strada_hv_store(");
