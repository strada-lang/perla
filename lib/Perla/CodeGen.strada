                    gen_expr($cg, $hkn);
                    emit($cg, "; __perla_want_list = __sav_wl_hsk; if (__hsk_arr && !STRADA_IS_TAGGED_INT(__hsk_arr) && __hsk_arr->type == STRADA_ARRAY) { ");
                    emit($cg, "  StradaArray *__hsk_av = __hsk_arr->value.av; ");
                    emit($cg, "  for (size_t __hsk_i = 0; __hsk_i < __hsk_av->size; __hsk_i++) { ");
                    emit($cg, "    strada_array_push(__hs_kav, __hsk_av->elements[__hsk_av->head + __hsk_i]); ");
                    emit($cg, "  } ");
                    emit($cg, "} else { strada_array_push(__hs_kav, __hsk_arr); } ");
                    emit($cg, "} ");
                } else {
                    emit($cg, "{ StradaValue *__hsk_v = ");
                    gen_expr($cg, $hkn);
                    emit($cg, "; strada_array_push(__hs_kav, __hsk_v); } ");
                }
                $hsi = $hsi + 1;
            }
            # Build a flat values array (RHS in list context)
            emit($cg, "int __sav_wl_hs = __perla_want_list; __perla_want_list = 1; ");
            emit($cg, "StradaValue *__hs_vals = ");
            gen_expr($cg, $node->{"value"});
            emit($cg, "; __perla_want_list = __sav_wl_hs; ");
            # Normalise __hs_vals into an array form
            emit($cg, "StradaValue *__hs_vfb = NULL; StradaArray *__hs_vav = NULL; ");
            emit($cg, "if (__hs_vals && !STRADA_IS_TAGGED_INT(__hs_vals) && __hs_vals->type == STRADA_ARRAY) { __hs_vav = __hs_vals->value.av; } ");
            emit($cg, "else { __hs_vfb = strada_new_array(); strada_array_push(strada_deref_array(__hs_vfb), __hs_vals); __hs_vav = strada_deref_array(__hs_vfb); } ");
            # Store each key/value pair
            emit($cg, "{ StradaHash *__hs_dh = strada_deref_hash(({ StradaValue *__dr = __hs_h; (!__dr || STRADA_IS_TAGGED_INT(__dr)) ? (__hs_h = strada_new_ref(strada_new_hash(), '%'))->value.rv : (__dr->type == STRADA_REF && __dr->value.rv) ? __dr->value.rv : __dr; })); ");
            emit($cg, "int __hs_klen = (int)strada_array_length(__hs_kav); ");
            emit($cg, "int __hs_vlen = __hs_vav ? (int)strada_array_length(__hs_vav) : 0; ");
            emit($cg, "for (int __hs_i = 0; __hs_i < __hs_klen; __hs_i++) { ");
            emit($cg, "char *__hs_k = strada_to_str(strada_array_get(__hs_kav, __hs_i)); ");
            emit($cg, "StradaValue *__hs_v = (__hs_i < __hs_vlen) ? strada_array_get(__hs_vav, __hs_i) : strada_new_undef(); ");
            emit($cg, "if (__hs_v) strada_incref(__hs_v); ");
            emit($cg, "if (__hs_dh) strada_hash_set_take(__hs_dh, __hs_k, __hs_v); ");
            emit($cg, "free(__hs_k); } } ");
