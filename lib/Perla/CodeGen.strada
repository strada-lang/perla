            emit($cg, "; strada_av_fetch_sv(__ae_sv_t, __ae_idx); })");
            return;
        } elsif ($is_arrow == 0 && $obj->{"type"} == Perla::AST::N_SCALAR_VAR() && index("" . ($obj->{"name"} // ""), "::") > 0) {
            # $Pkg::arr[N] — pkg-qualified scalar var indexed as @Pkg::arr.
            # The default _gen_expr emits perla_scalar_get which reads
            # SLOT_SCALAR (empty); route to perla_array_get for SLOT_ARRAY.
            my str $__pa_full = $obj->{"name"};
            my int $__pai = 0;
            my int $__pa_last = -1;
            while ($__pai < length($__pa_full) - 1) {
                if (substr($__pa_full, $__pai, 2) eq "::") { $__pa_last = $__pai; }
                $__pai = $__pai + 1;
            }
            my str $__pa_pkg = substr($__pa_full, 0, $__pa_last);
            my str $__pa_name = substr($__pa_full, $__pa_last + 2, length($__pa_full) - $__pa_last - 2);
            emit($cg, "({ StradaArray *__ae_av = strada_deref_array(perla_array_get(\"" . $__pa_pkg . "\", \"" . $__pa_name . "\")); ");
        } elsif ($is_arrow == 0
                 && ($obj->{"type"} == Perla::AST::N_ANON_ARRAY()
                     && (!defined($obj->{"is_ref"}) || $obj->{"is_ref"} != 1))) {
            # `(LIST)[N]` — paren-list followed by single index. The
            # anon-array codegen otherwise consults the surrounding
            # __perla_want_list (which is 0 inside `my \$x = ...`) and
            # collapses to the last element, so `(1, 2, 3, 4, 5)[2]`
            # returned undef (and broke
            # `my \$mid = (sort ...)[int(@arr/2)]` median-pattern code).
            # Force list context for the inner list.
            emit($cg, "({ StradaArray *__ae_av = strada_deref_array(({ int __sav_wl_sl = __perla_want_list; __perla_want_list = 1; StradaValue *__sl_av = ");
            gen_expr($cg, $obj);
            emit($cg, "; __perla_want_list = __sav_wl_sl; __sl_av; })); ");
        } else {
            # `$ref->[N]` — explicit arrow deref + element access. Apply
            # @{} overload before strada_deref_array so blessed refs that
            # overload @{} (Hash-Of-Array proxies, ARef wrappers, etc.)
            # resolve via the user's overload method, not the raw ref.
            # Without this, `$obj->[0]` on an @{}-overloaded object
            # silently returned undef. Track obj-ownership so we can
            # decref the source SV (mirrors the ARROW_HASH leak fix:
            # N_ARRAY_ELEM/CALL/etc. yield owned temps which would
            # otherwise leak one ref per `$arr[N]->[i]` access).
            my int $__aa_obj_owned = 0;
            if (defined($obj)) {
                my int $__aa_aot = $obj->{"type"};
                if ($__aa_aot == Perla::AST::N_ARRAY_ELEM()
                    || $__aa_aot == Perla::AST::N_HASH_ELEM()
                    || $__aa_aot == Perla::AST::N_ARROW_HASH()
                    || $__aa_aot == Perla::AST::N_ARROW_ARRAY()
                    || $__aa_aot == Perla::AST::N_CALL()
                    || $__aa_aot == Perla::AST::N_METHOD()) {
                    $__aa_obj_owned = 1;
                }
            }
            emit($cg, "({ StradaValue *__ae_obj = ");
            gen_expr($cg, $obj);
            emit($cg, "; StradaValue *__ae_ov = (__ae_obj && !STRADA_IS_TAGGED_INT(__ae_obj) && __ae_obj->type == STRADA_REF) ? perla_overload_deref(__ae_obj, \"\@{}\") : NULL; ");
            emit($cg, "StradaArray *__ae_av = strada_deref_array(__ae_ov ? __ae_ov : __ae_obj); ");
            # Stash flag for the trailing emit (after the fetch) below.
            $cg->{"__aa_obj_owned_pending"} = $__aa_obj_owned;
        }
        if (defined($aaidx) && $aaidx->{"type"} == Perla::AST::N_INT_LIT()) {
            emit($cg, "int __ae_idx = " . $aaidx->{"value"});
        } else {
            emit($cg, "int __ae_idx = (int)strada_to_int(");
            gen_expr($cg, $aaidx);
            emit($cg, ")");
        }
        # Let strada_array_get handle the negative-index adjustment so a
        # too-far-negative index (e.g. \$arr[-100] on a 5-elem array)
        # correctly returns undef rather than wrapping to a positive
        # in-range slot. The runtime checks idx<-size after adjustment.
        emit($cg, "; ");
        # Incref the fetched element. `strada_array_get` returns a BORROWED
        # ref; without this, repeated `my $x = $arr[$i]` reassignments
        # decref'd the borrowed and freed underlying elements after 2 visits.
        # If the `$ref->[N]` path captured an owned __ae_obj (via
        # __aa_obj_owned_pending), decref it after fetching — mirrors the
        # ARROW_HASH owned-object cleanup.
        emit($cg, "StradaValue *__ae_v = strada_array_get(__ae_av, __ae_idx); if (__ae_v) strada_incref(__ae_v); ");
        if (defined($cg->{"__aa_obj_owned_pending"}) && $cg->{"__aa_obj_owned_pending"} == 1) {
            emit($cg, "if (__ae_ov) strada_decref(__ae_ov); strada_decref(__ae_obj); ");
        }
        $cg->{"__aa_obj_owned_pending"} = 0;
        emit($cg, "__ae_v; })");
        return;
    }

    if ($type == Perla::AST::N_REF()) {
        my scalar $operand = $node->{"operand"};
        # \&{EXPR} — the glob access already returns a CPOINTER, don't double-wrap
        if (defined($operand) && $operand->{"type"} == Perla::AST::N_GLOB_ACCESS() && $operand->{"is_code_deref"} == 1) {
            gen_expr($cg, $operand);
            return;
        }
        # \&{EXPR} parses as N_REF wrapping N_CALL{name="__coderef__",
        # coderef=N_GLOB_ACCESS(...)} — the bare-deref-call form was
        # always wrapped in N_CALL by the parser. For \& context we
        # want a CPOINTER, not a call. Detect and emit the inner glob
        # access (which gives a CPOINTER). Concrete victim:
        # `my $orig = \&{"Foo::hi"}` returned undef; calling \$orig->()
        # then errored or returned empty.
        #
        # `\&$name` form: parser builds N_CALL with coderef=N_SCALAR_VAR
        # (since `&$name` is the no-parens coderef-call form). For the
        # `\&` ref context we want a CPOINTER for the sub *named by the
        # value of $name*. Look up the sub at runtime via perla_code_get
        # — same dispatch logic that perla_call_code uses for a string
        # value, but materialized as a value rather than invoked.
        if (defined($operand) && $operand->{"type"} == Perla::AST::N_CALL()
            && defined($operand->{"name"}) && $operand->{"name"} eq "__coderef__"
            && defined($operand->{"coderef"})) {
            my scalar $inner = $operand->{"coderef"};
            if ($inner->{"type"} == Perla::AST::N_GLOB_ACCESS() && $inner->{"is_code_deref"} == 1) {
                gen_expr($cg, $inner);
                return;
            }
            # `\&$NAME` / `\&{EXPR}` where the inner is anything other
            # than a static glob access: emit a runtime lookup mirroring
            # the dynamic N_GLOB_ACCESS path — accept CLOSURE/CPOINTER
            # passthrough, split on `::` for pkg::name, and convert
            # STRADA_STR (C function name from compiled subs) to CPOINTER
            # via dlsym so ref() returns "CODE".
            emit($cg, "({ StradaValue *__ge = ");
            gen_expr($cg, $inner);
            emit($cg, "; StradaValue *__gv = NULL; ");
            emit($cg, "if (__ge && !STRADA_IS_TAGGED_INT(__ge) && (__ge->type == STRADA_CLOSURE || __ge->type == STRADA_CPOINTER)) { __gv = __ge; strada_incref(__gv); } ");
            emit($cg, "else { char *__gn = strada_to_str(__ge); char *__ls = NULL; for (char *__p = __gn; *__p; __p++) if (__p[0]==':'&&__p[1]==':') __ls=__p; ");
            emit($cg, "char *__gpkg = \"" . $cg->{"pkg"} . "\"; char *__gshort = __gn; char *__gpb = NULL; ");
            emit($cg, "if (__ls) { __gpb = strndup(__gn, __ls-__gn); __gpkg = __gpb; __gshort = __ls+2; } ");
            emit($cg, "PerlGlob *__g = perla_glob_get(perla_stash_get_or_create(__gpkg), __gshort); ");
            emit($cg, "__gv = strada_new_undef(); ");
            emit($cg, "if (__g && __g->slots[PERLA_SLOT_CODE]) { ");
            emit($cg, "  StradaValue *__csv = __g->slots[PERLA_SLOT_CODE]; ");
            emit($cg, "  if (__csv && !STRADA_IS_TAGGED_INT(__csv) && (__csv->type == STRADA_CLOSURE || __csv->type == STRADA_CPOINTER)) { strada_decref(__gv); __gv = __csv; strada_incref(__gv); } ");
            emit($cg, "  else if (__csv && !STRADA_IS_TAGGED_INT(__csv) && __csv->type == STRADA_STR) { ");
            emit($cg, "    char *__fn = strada_to_str(__csv); void *__fp = dlsym(RTLD_DEFAULT, __fn); ");
            emit($cg, "    if (__fp) { strada_decref(__gv); __gv = strada_cpointer_new(__fp); } free(__fn); } } ");
            emit($cg, "if (__gpb) free(__gpb); free(__gn); } __gv; })");
            return;
        }
        # \*{EXPR} — Perl's typeglob-ref. Sub::Defer / Moo's _getglob does
        # `sub _getglob { \*{$_[0]} }` to capture a typeglob for later
        # `*{$glob} = $code` assignment. Without special-casing, perla
        # wraps the GLOB_ACCESS result (which is the code slot value) in
        # a ref — and then `*{$glob_ref} = $code` calls
        # perla_glob_assign_dynamic with that ref instead of the glob
        # name, so the install becomes a no-op. Surfaced via Moo's
        # `_install_coderef("$target::$name", $code)` failing silently:
        # `has` accessors (storage/wrap_txn/etc.) never made it into
        # DBIx::Class::Storage::BlockRunner's stash, breaking dbh_do.
        # Returning the underlying name string makes the subsequent
        # `*{$glob_ref} = $val` deref + perla_glob_assign_dynamic resolve
        # the name correctly.
        if (defined($operand) && $operand->{"type"} == Perla::AST::N_GLOB_ACCESS()
            && !defined($operand->{"slot"})) {
            my scalar $gexpr2 = $operand->{"expr"};
            if (defined($gexpr2)) {
                # Dynamic `\*{EXPR}` — keep the name-string form so
                # downstream *{...} deref + glob_assign_dynamic works.
                # Real GLOB-type modeling isn't needed for this path.
                gen_expr($cg, $gexpr2);
            } else {
                # Static `\*NAME` — bless the name-string as "GLOB"
                # so ref(\*FOO) returns "GLOB" matching Perl. The
                # underlying value is still STR (perla doesn't have
                # a dedicated SVt_PVGV); blessing only affects ref()
                # output. Downstream consumers that need the name
                # (perla_glob_assign_dynamic, *{$g} = ...) still get
                # the unblessed string via strada_to_str().
                emit($cg, "strada_bless(strada_new_str(\"" . $operand->{"name"} . "\"), \"GLOB\")");
            }
            return;
        }
        # \&func — create code reference (don't call the function)
        if (defined($operand) && $operand->{"type"} == Perla::AST::N_CALL() &&
            defined($operand->{"name"}) && (!defined($operand->{"args"}) || scalar(@{$operand->{"args"}}) == 0)) {
            # __SUB__ marker (parser emits this for __SUB__ in anon-sub
            # context — see Parser.strada SUB_CONST handler). Emit a
            # CPOINTER to the currently-emitting sub's C function.
            # $cg->{"current_sub_fname"} is set by gen_sub_def for
            # both named and anon subs.
            if ($operand->{"name"} eq "__PERLA_CURRENT_SUB__") {
                my str $__cs_fname = "";
                if (defined($cg->{"current_sub_fname"})) {
                    $__cs_fname = "" . $cg->{"current_sub_fname"};
                }
                if (length($__cs_fname) > 0) {
                    emit($cg, "strada_cpointer_new((void*)" . $__cs_fname . ")");
                } else {
                    # Outside any sub — undef coderef.
                    emit($cg, "perla_undef_coderef()");
                }
                return;
            }
            my str $resolved = Perla::CodeGen::Call::_resolve_sub($cg, $operand->{"name"});
            if (length($resolved) > 0) {
                emit($cg, "strada_cpointer_new((void*)" . sub_cname_q($resolved) . ")");
            } else {
                # Unresolved — try stash lookup at runtime
                my str $fn = $operand->{"name"};
                my int $dc = -1;
                my int $di = 0;
                while ($di < length($fn) - 1) {
                    if (substr($fn, $di, 2) eq "::") { $dc = $di; }
                    $di++;
                }
                if ($dc >= 0) {
                    my str $fpkg = substr($fn, 0, $dc);
                    my str $fsub = substr($fn, $dc + 2, length($fn) - $dc - 2);
                    emit($cg, "({ StradaValue *__cr = perla_code_get(\"" . $fpkg . "\", \"" . $fsub . "\"); __cr ? __cr : perla_undef_coderef_named(\"" . $fpkg . "::" . $fsub . "\"); })");
                } else {
                    emit($cg, "({ StradaValue *__cr = perla_code_get(\"" . $cg->{"pkg"} . "\", \"" . $fn . "\"); __cr ? __cr : perla_undef_coderef_named(\"" . $cg->{"pkg"} . "::" . $fn . "\"); })");
                }
            }
            return;
        }
        # `\$var` for plain scalar locals/file-scope vars: emit a slot
        # ref so writes through `$$ref = X` update the underlying
        # variable. Without this, `$$ref = X` writes into a heap copy
        # and the original `$var` (especially tagged ints) is unchanged.
        # Skip package-qualified names ($Pkg::X), special vars
        # ($_, $@, $1..), and anything not declared in the current scope.
        if (defined($operand) && $operand->{"type"} == Perla::AST::N_SCALAR_VAR()
            && defined($operand->{"name"}) && length($operand->{"name"}) > 0
            && index($operand->{"name"}, "::") < 0) {
            my str $__sr_name = $operand->{"name"};
            my int $__sr_special = 0;
            my str $__sr_ch0 = substr($__sr_name, 0, 1);
            # Special / capture vars get their own emit path; not a real C var.
            if ($__sr_ch0 ge "0" && $__sr_ch0 le "9") { $__sr_special = 1; }
            if ($__sr_name eq "_" || $__sr_name eq "@" || $__sr_name eq "!" ||
                $__sr_name eq "/" || $__sr_name eq "\\" || $__sr_name eq "," ||
                $__sr_name eq ";" || $__sr_name eq "&" || $__sr_name eq "+" ||
                $__sr_name eq "`" || $__sr_name eq "'" || $__sr_name eq "?" ||
                $__sr_name eq "|") { $__sr_special = 1; }
            my int $__sr_known = 0;
            if (defined($cg->{"local_vars"}) && exists($cg->{"local_vars"}->{$__sr_name})) { $__sr_known = 1; }
            if ($__sr_known == 0 && defined($cg->{"file_scope_vars"}) && exists($cg->{"file_scope_vars"}->{$__sr_name})) { $__sr_known = 1; }
            if ($__sr_known == 0 && defined($cg->{"our_vars"}) && exists($cg->{"our_vars"}->{$__sr_name})) { $__sr_known = 1; }
            # When the var is shadowed by an enclosing `for my $X` iter,
            # the slot ref would alias the SAME C local across iterations
            # (its address is fixed in the outer C scope). Fall through
            # to strada_ref_create which captures the current value as a
            # heap-allocated target per ref — gives each iteration its
            # own ref-target. Concrete victim: `for my $n (10,20,30)
            # { push @refs, \$n; }` produced three refs all pointing at
            # the LAST iter's v_n (30,30,30 instead of 10,20,30).
            my int $__sr_shadowed = 0;
            if ($__sr_known == 1 && defined($cg->{"my_lexicals"})) {
                my scalar $__sr_mxs = $cg->{"my_lexicals"};
                my int $__sr_mxi = 0;
                while ($__sr_mxi < scalar(@{$__sr_mxs})) {
                    my scalar $__sr_e = $__sr_mxs->[$__sr_mxi];
                    if (defined($__sr_e) && defined($__sr_e->{"name"})
                        && $__sr_e->{"name"} eq $__sr_name
                        && defined($__sr_e->{"from_foreach"})
                        && $__sr_e->{"from_foreach"} == 1) {
                        $__sr_shadowed = 1;
                        last;
                    }
                    $__sr_mxi = $__sr_mxi + 1;
                }
            }
            if ($__sr_special == 0 && $__sr_known == 1 && $__sr_shadowed == 0) {
                emit($cg, "strada_slot_ref_create(&" . c_var($__sr_name) . ")");
                return;
            }
            # `\$_` → slot ref to perla_dollar_underscore so ref() returns
            # SCALAR even when $_ has never been set. Without this,
            # gen_expr emits NULL and strada_ref_create(NULL) returned
            # bare undef, so `ref(\$_)` was "" instead of "SCALAR".
            if ($__sr_name eq "_") {
                emit($cg, "strada_slot_ref_create(&perla_dollar_underscore)");
                return;
            }
        }
        # `\$Pkg::name` — create a slot ref to the stash's SCALAR slot.
        # Without this, strada_ref_create(perla_scalar_get(...)) would
        # unbox tagged ints into fresh heap copies (see CLAUDE.md note),
        # so writes through the ref would update a copy and the stash
        # slot would never see them.
        if (defined($operand) && $operand->{"type"} == Perla::AST::N_SCALAR_VAR()
            && defined($operand->{"name"}) && index($operand->{"name"}, "::") > 0) {
            my str $__pqn = $operand->{"name"};
            my int $__srli = -1;
            my int $__srsi = 0;
            while ($__srsi < length($__pqn) - 1) {
                if (substr($__pqn, $__srsi, 2) eq "::") { $__srli = $__srsi; }
                $__srsi = $__srsi + 1;
            }
            my str $__srpkg = substr($__pqn, 0, $__srli);
            my str $__srnm = substr($__pqn, $__srli + 2, length($__pqn) - $__srli - 2);
            emit($cg, "strada_slot_ref_create(&perla_glob_get_or_create(perla_stash_get_or_create(\"" . $__srpkg . "\"), \"" . $__srnm . "\")->slots[PERLA_SLOT_SCALAR])");
            return;
        }
        # \$h->{k} / \$h{k} — create a ref to the hash entry's value
        # whose target is heap-boxed so writes through the ref reach
        # the hash. Hash entries can move on rehash, so we can't take
        # a slot ref to &entry->value safely; instead we ensure
        # entry->value is a heap StradaValue (boxing tagged ints) so
        # strada_ref_create captures a stable pointer. perla_scalar_deref_assign
        # mutates the target in-place — and since the hash entry holds
        # the same pointer, the update is visible via the hash.
        if (defined($operand)
            && ($operand->{"type"} == Perla::AST::N_HASH_ELEM()
                || $operand->{"type"} == Perla::AST::N_ARROW_HASH())) {
            my scalar $he_obj = ($operand->{"type"} == Perla::AST::N_HASH_ELEM())
                ? $operand->{"hash"} : $operand->{"object"};
            my scalar $he_key = $operand->{"key"};
            emit($cg, "({ StradaValue *__href_h = ");
            # Autoviv intermediate hashes for chains like \$h{a}{b}{c}.
            # Without this, fetching from an empty inner hash returns
            # undef and the boxing logic skips, leaving the ref pointing
            # at a throwaway undef.
            my int $he_inner_t = $he_obj->{"type"};
            if ($he_inner_t == Perla::AST::N_HASH_ELEM()
                || $he_inner_t == Perla::AST::N_ARROW_HASH()) {
                _gen_autoviv_hash($cg, $he_obj);
            } else {
                gen_expr($cg, $he_obj);
            }
            emit($cg, "; char *__href_k = strada_to_str(");
            gen_expr($cg, $he_key);
            emit($cg, "); StradaHash *__href_hv = strada_deref_hash(__href_h); ");
            emit($cg, "StradaValue *__href_v = __href_hv ? strada_hash_get(__href_hv, __href_k) : NULL; ");
            # Box: if absent, store new heap undef; if tagged int, replace
            # with heap STRADA_INT; otherwise use existing heap value.
            emit($cg, "if (__href_hv) { ");
            emit($cg, "  if (!__href_v) { __href_v = strada_new_undef(); strada_hash_set(__href_hv, __href_k, __href_v); strada_decref(__href_v); } ");
            emit($cg, "  else if (STRADA_IS_TAGGED_INT(__href_v)) { ");
            # Force a heap StradaValue (not tagged) so the ref captures a
            # stable pointer. strada_new_int(N) returns a tagged int for
            # small N which defeats the boxing — allocate a fresh undef
            # then overwrite it with the int value.
            emit($cg, "    StradaValue *__href_box = strada_new_undef(); ");
            emit($cg, "    strada_overwrite_in_place(__href_box, __href_v); ");
            emit($cg, "    strada_hash_set(__href_hv, __href_k, __href_box); ");
            emit($cg, "    strada_decref(__href_box); /* offset hash_set's incref */ ");
            emit($cg, "    __href_v = __href_box; ");
            emit($cg, "  } ");
            emit($cg, "} ");
            emit($cg, "free(__href_k); ");
            emit($cg, "__href_v ? strada_ref_create(__href_v) : strada_new_undef(); })");
            return;
        }
        # \$arr[i] / \$ref->[i] — create a slot ref to the array
        # element so writes through `$$ref = V` (and downstream uses like
        # `open(..., ">", \$arr[i])` that mutate via FH_MEMWRITE_REF)
        # land in the actual array slot, not a heap copy.
        # Autoviv to ensure the element exists before taking its address.
        if (defined($operand)
            && ($operand->{"type"} == Perla::AST::N_ARRAY_ELEM()
                || $operand->{"type"} == Perla::AST::N_ARROW_ARRAY())) {
            my scalar $ae_arr = ($operand->{"type"} == Perla::AST::N_ARRAY_ELEM())
                ? $operand->{"array"} : $operand->{"object"};
            emit($cg, "({ StradaArray *__sref_av = strada_deref_array(");
            # `\$_[N]` indexes @_ (perla_at_), NOT the scalar $_ — mirror the
            # read/writeback special-case. Without this, gen_expr emitted the
            # scalar $_ (perla_dollar_underscore), strada_deref_array(scalar)
            # was NULL, and `\$_[0]` yielded undef → ref(\$_[0]) was "" not
            # "SCALAR". Broke Specio::TypeChecks::is_Str (`ref(\$_[0]) eq
            # 'SCALAR'`), which rejected every value and blocked DateTime's
            # Specio type construction.
            if (defined($ae_arr) && $ae_arr->{"type"} == Perla::AST::N_SCALAR_VAR()
                && defined($ae_arr->{"name"}) && $ae_arr->{"name"} eq "_") {
                emit($cg, "perla_at_");
            } else {
                gen_expr($cg, $ae_arr);
            }
            emit($cg, "); int __sref_i = (int)strada_to_int(");
            gen_expr($cg, $operand->{"index"});
            emit($cg, "); StradaValue *__sref_r; ");
            emit($cg, "if (__sref_av) { ");
            emit($cg, "  if (__sref_i < 0) __sref_i += (int)__sref_av->size; ");
            emit($cg, "  while (__sref_i >= 0 && (size_t)__sref_i >= __sref_av->size) strada_array_push(__sref_av, strada_new_undef()); ");
            emit($cg, "  __sref_r = strada_slot_ref_create(&__sref_av->elements[__sref_av->head + __sref_i]); ");
            emit($cg, "} else { __sref_r = strada_new_undef(); } __sref_r; })");
            return;
        }
        # `\%{EXPR}` / `\@{EXPR}` — a ref to a hash/array deref must yield the
        # CONTAINER, not its scalar-context reduction. N_DEREF_HASH /
        # N_DEREF_ARRAY collapse to the key/element COUNT (a tagged int) when
        # __perla_want_list==0, so `\%{...}` in scalar context (e.g. `my $r =
        # \%{"Pkg::"}`) reffed the count → ref() was "SCALAR" not "HASH".
        # Force list context so the deref returns the hash/array. Concrete
        # victim: Role::Tiny::_getstash (`\%{"$_[0]::"}`) returned a scalar
        # ref to a number, so _all_subs found no subs → roles never applied →
        # Specio's `does` checks failed loading DateTime types.
        if (defined($operand)
            && ($operand->{"type"} == Perla::AST::N_DEREF_HASH()
                || $operand->{"type"} == Perla::AST::N_DEREF_ARRAY())) {
            emit($cg, "strada_ref_create(({ int __rdwl = __perla_want_list; __perla_want_list = 1; StradaValue *__rdv = ");
            gen_expr($cg, $operand);
            emit($cg, "; __perla_want_list = __rdwl; __rdv; }))");
            return;
        }
        emit($cg, "strada_ref_create(");
        gen_expr($cg, $operand);
        emit($cg, ")");
        return;
    }

    if ($type == Perla::AST::N_ANON_HASH()) {
        _gen_anon_hash($cg, $node);
        return;
    }

    if ($type == Perla::AST::N_ANON_ARRAY()) {
        _gen_anon_array($cg, $node);
        return;
    }

    # $$ref — scalar dereference. STRING form is a symbolic ref:
    # `${"Pkg::NAME"}` → look up the package's SLOT_SCALAR for NAME.
    # Class::Accessor::Grouped's set_inherited / get_inherited use
    # this to store class-data; without it DBIC's mk_classdata
    # accessors install but never persist their values.
    if ($type == Perla::AST::N_DEREF_SCALAR()) {
        # `${*$fh}` — the SCALAR slot of the glob $fh represents. perla
        # models a filehandle as its own SV; the slot lives on its meta.
        # File::Temp's `filename` is `return ${*$self}`. Detect a
        # glob-access inner (with expr — i.e. `*$fh` / `*{$fh}`) and read
        # the per-filehandle slot; non-filehandle exprs return undef
        # (matching the prior behavior — this path produced empty before).
        my scalar $__dsref = $node->{"ref"};
        if (defined($__dsref) && $__dsref->{"type"} == Perla::AST::N_GLOB_ACCESS()
            && defined($__dsref->{"expr"})) {
            emit($cg, "perla_fh_slot_get(");
            gen_expr($cg, $__dsref->{"expr"});
            emit($cg, ")");
            return;
        }
        my int $__ds_strict = 0;
        if (defined($cg->{"strict_refs"}) && $cg->{"strict_refs"} == 1) {
            $__ds_strict = 1;
        }
        emit($cg, "({ StradaValue *__dr = ");
        gen_expr($cg, $node->{"ref"});
        # Symbolic capture-var access: `\${\$i}` where \$i is a number
        # (or numeric string) should read \$N — perl's idiom for dynamic
        # capture lookup, e.g. iterating capture-table keys after a /g
        # match. Without this branch, `\${1}` returned undef because the
        # tagged-int short-circuit treated the int as "not a ref".
        # Strict refs doesn't gate this — \$N is not a symbolic package
        # ref, it's the regex capture global.
        emit($cg, "; (STRADA_IS_TAGGED_INT(__dr)) ? strada_capture_var((int)STRADA_TAGGED_INT_VAL(__dr)) : ");
        emit($cg, "(__dr && __dr->type == STRADA_STR && __dr->value.pv && __dr->value.pv[0] >= '0' && __dr->value.pv[0] <= '9') ? ({ int __cv_n = atoi(__dr->value.pv); char __cv_check[32]; snprintf(__cv_check, sizeof(__cv_check), \"%d\", __cv_n); (strcmp(__cv_check, __dr->value.pv) == 0) ? strada_capture_var(__cv_n) : perla_scalar_via_qname(__dr->value.pv); }) : ");
        emit($cg, "(!__dr) ? strada_new_undef() : ");
        # Slot ref: read through the C-variable pointer.
        emit($cg, "(__dr->type == STRADA_REF && strada_is_slot_ref(__dr)) ? ({ StradaValue **__slot = (StradaValue**)__dr->value.ptr; (__slot && *__slot) ? *__slot : strada_new_undef(); }) : ");
        emit($cg, "(__dr->type == STRADA_REF && __dr->value.rv) ? __dr->value.rv : ");
        # strict 'refs': turn the symbolic lookup into a runtime die.
        # Without strict refs, the string lookup via perla_scalar_via_qname
        # remains as the no-strict-refs symref idiom.
        if ($__ds_strict == 1) {
            emit($cg, "(__dr->type == STRADA_STR && __dr->value.pv) ? ({ char __sm[512]; snprintf(__sm, sizeof(__sm), \"Can't use string (\\\"%s\\\") as a SCALAR ref while \\\"strict refs\\\" in use\", __dr->value.pv); strada_die(__sm); strada_new_undef(); }) : ");
        } else {
            emit($cg, "(__dr->type == STRADA_STR && __dr->value.pv) ? perla_scalar_via_qname(__dr->value.pv) : ");
        }
        emit($cg, "__dr; })");
        return;
    }

    # @{expr} — array dereference (returns the array value).
    # If the expr is a STRING (Perl symbolic ref), look up the named
    # package global instead of treating the string as the contents.
    # Without that branch, code like `@{"Pkg::ISA"}` returned the
    # literal string "Pkg::ISA" wrapped as a one-element array — and
    # all the DBIC machinery that pokes at @{"$class\::ISA"} got
    # nothing.
    if ($type == Perla::AST::N_DEREF_ARRAY()) {
        # For blessed refs with `@{}` overload, the user sub returns the
        # array ref to deref. The wrapper from perla_call_code is leaked
        # by design — its rv is a borrowed view shared with whatever
        # the user sub returned (typically a long-lived ref like
        # `$_[0]->{arr}`), so decreffing the wrapper here could free
        # the underlying array if the user sub returns a temporary.
        my int $__da_strict = 0;
        if (defined($cg->{"strict_refs"}) && $cg->{"strict_refs"} == 1) {
            $__da_strict = 1;
        }
        # Force scalar context: `my \$n = @\$aref` should bind \$n to the
        # array LENGTH (Perl's scalar-context semantics) rather than
        # aliasing the array StradaValue. Without this, \$n stayed
        # linked to the array — push'ing later changed \$n's printed
        # value. Wrap the whole result in a __perla_want_list check.
        emit($cg, "({ StradaValue *__da_inner = ({ StradaValue *__dr = ");
        gen_expr($cg, $node->{"ref"});
        emit($cg, "; StradaValue *__dov = (__dr && !STRADA_IS_TAGGED_INT(__dr) && __dr->type == STRADA_REF) ? perla_overload_deref(__dr, \"\@{}\") : NULL; ");
        emit($cg, "if (__dov) { __dr = __dov; } ");
        emit($cg, "(!__dr || STRADA_IS_TAGGED_INT(__dr)) ? strada_new_array() : ");
        emit($cg, "(__dr->type == STRADA_REF && __dr->value.rv) ? __dr->value.rv : ");
        if ($__da_strict == 1) {
            emit($cg, "(__dr->type == STRADA_STR && __dr->value.pv) ? ({ char __sm[512]; snprintf(__sm, sizeof(__sm), \"Can't use string (\\\"%s\\\") as an ARRAY ref while \\\"strict refs\\\" in use\", __dr->value.pv); strada_die(__sm); strada_new_array(); }) : ");
        } else {
            emit($cg, "(__dr->type == STRADA_STR && __dr->value.pv) ? perla_array_via_qname(__dr->value.pv) : ");
        }
        emit($cg, "__dr; }); ");
        # Scalar-context: return the length as a tagged int (snapshot,
        # not aliased to the live array).
        emit($cg, "(__perla_want_list == 0 && __da_inner && !STRADA_IS_TAGGED_INT(__da_inner) && __da_inner->type == STRADA_ARRAY) ? STRADA_MAKE_TAGGED_INT((int64_t)strada_array_length(__da_inner->value.av)) : __da_inner; })");
        return;
    }

    # %{expr} — hash dereference (returns the hash value). Same
    # symbolic-ref handling as @{expr} above.
    if ($type == Perla::AST::N_DEREF_HASH()) {
        my int $__dh_strict = 0;
        if (defined($cg->{"strict_refs"}) && $cg->{"strict_refs"} == 1) {
            $__dh_strict = 1;
        }
        # Scalar-context %\$href: return number of keys as a tagged-int
        # snapshot (matches Perl 5.26+ where scalar(%h) is just keys count).
        emit($cg, "({ StradaValue *__dh_inner = ({ StradaValue *__dr = ");
        gen_expr($cg, $node->{"ref"});
        emit($cg, "; StradaValue *__dov = (__dr && !STRADA_IS_TAGGED_INT(__dr) && __dr->type == STRADA_REF) ? perla_overload_deref(__dr, \"\%{}\") : NULL; ");
        emit($cg, "if (__dov) { __dr = __dov; } ");
        emit($cg, "(!__dr || STRADA_IS_TAGGED_INT(__dr)) ? strada_new_hash() : ");
        emit($cg, "(__dr->type == STRADA_REF && __dr->value.rv) ? __dr->value.rv : ");
        if ($__dh_strict == 1) {
            emit($cg, "(__dr->type == STRADA_STR && __dr->value.pv) ? ({ char __sm[512]; snprintf(__sm, sizeof(__sm), \"Can't use string (\\\"%s\\\") as a HASH ref while \\\"strict refs\\\" in use\", __dr->value.pv); strada_die(__sm); strada_new_hash(); }) : ");
        } else {
            emit($cg, "(__dr->type == STRADA_STR && __dr->value.pv) ? perla_hash_via_qname(__dr->value.pv) : ");
        }
        emit($cg, "__dr; }); ");
        emit($cg, "(__perla_want_list == 0 && __dh_inner && !STRADA_IS_TAGGED_INT(__dh_inner) && __dh_inner->type == STRADA_HASH && __dh_inner->value.hv) ? STRADA_MAKE_TAGGED_INT((int64_t)__dh_inner->value.hv->num_entries) : __dh_inner; })");
        return;
    }

    if ($type == Perla::AST::N_TERNARY()) {
        # Wrap each branch in parens — if the branch is an assignment (e.g. the
        # idiom `cond ? $a = x : $b = y`), C's lower precedence for `=` would
        # otherwise parse `cond ? ... : lhs = rhs` as `(cond ? ... : lhs) = rhs`
        # and reject it as a non-lvalue.
        emit($cg, "(");
        _gen_cond($cg, $node->{"cond"});
        emit($cg, " ? (");
        gen_expr($cg, $node->{"then"});
        emit($cg, ") : (");
        gen_expr($cg, $node->{"else"});
        emit($cg, "))");
        return;
    }

    # qw(a b c) — array of strings
    if ($type == Perla::AST::N_QWORD()) {
        _gen_anon_array($cg, $node);
        return;
    }

    # map { BLOCK } LIST
    if ($type == Perla::AST::N_MAP()) {
        # `$_` inside the map block must update the GLOBAL
        # perla_dollar_underscore (not shadow it with a local). Otherwise
        # eval STRING run inside the block reads the outer/global $_,
        # which is stale. Sub::Quote::capture_unroll's
        # `qq{... ${\quotify $_} ...}` (which compiles to perla_eval_string
        # for the `${\EXPR}` interp slot) needs the loop's $_ visible to
        # the eval. Save/restore the previous global value across the
        # whole map so nested $_ users (eval, `print`, etc.) see the
        # right value during iteration.
        my int $ml_borrowed = expr_is_borrowed($node->{"list"});
        emit($cg, "({ StradaValue *__ma = strada_new_array(); StradaArray *__mav = strada_deref_array(__ma); ");
        emit($cg, "StradaValue *__map_prev_du = perla_dollar_underscore; ");
        emit($cg, "int __sav_wl_lu = __perla_want_list; __perla_want_list = 1; StradaValue *__ml = ");
        gen_expr($cg, $node->{"list"});
        emit($cg, "; __perla_want_list = __sav_wl_lu; ");
        # `map BLOCK %hash` iterates the hash's flattened key/value pairs.
        # strada_deref_array is NULL for a hash, so without this the hash fell
        # to the scalar-wrap below and was mapped once as a single hashref.
        emit($cg, "StradaValue *__ml_hf = perla_hash_kv_list(__ml); StradaValue *__ml_eff = __ml_hf ? __ml_hf : __ml; ");
        emit($cg, "StradaArray *__mla = strada_deref_array(__ml_eff); ");
        # Scalar-in-list-context: wrap as 1-element array. Mirrors grep fix.
        emit($cg, "StradaArray *__mla_tmp = NULL; if (!__mla && __ml) { __mla_tmp = strada_array_new(); strada_array_push(__mla_tmp, __ml); strada_incref(__ml); __mla = __mla_tmp; } ");
        emit($cg, "int __mlen = __mla ? strada_array_length(__mla) : 0; ");
        # Inside the block, force LIST context so list literals like `(a, b)`
        # produce N elements per iteration instead of just the last one.
        # Perl: `map BLOCK LIST` always evaluates BLOCK in list context.
        # Outer scalar context only affects how the *aggregate result* is
        # interpreted (count vs elements), not the per-iteration eval.
        emit($cg, "int __sav_wl_mb = __perla_want_list; __perla_want_list = 1; ");
        emit($cg, "for (int __mi = 0; __mi < __mlen; __mi++) { ");
        emit($cg, "StradaValue *__mi_orig = strada_array_get(__mla, __mi); ");
        emit($cg, "perla_dollar_underscore = __mi_orig; ");
        emit($cg, "StradaValue *__mr = ");
        # Generate the block's last expression
        _gen_map_block($cg, $node->{"block"});
        # Aliasing write-back: Perl aliases `$_` to each list element in
        # `map { ... } @arr`. If the block mutated `$_` (via `$_++`, `$_ =
        # X`, `$_++` etc.), copy the new value back into the source array
        # slot. perla_dollar_underscore may now point at a different
        # StradaValue than __mi_orig — detect that and write back.
        emit($cg, "; if (perla_dollar_underscore != __mi_orig) { ");
        emit($cg, "  if (perla_dollar_underscore) strada_incref(perla_dollar_underscore); ");
        emit($cg, "  if (__mla) strada_array_set(__mla, __mi, perla_dollar_underscore); ");
        emit($cg, "} ");
        # If the block result is an array (list return), flatten it into the output
        emit($cg, "if (__mr && !STRADA_IS_TAGGED_INT(__mr) && __mr->type == STRADA_ARRAY) { ");
        emit($cg, "StradaArray *__mra = strada_deref_array(__mr); ");
        emit($cg, "if (__mra) for (size_t __mri = 0; __mri < __mra->size; __mri++) strada_array_push(__mav, __mra->elements[__mri]); ");
        emit($cg, "} else { strada_array_push(__mav, __mr); } } ");
        emit($cg, "__perla_want_list = __sav_wl_mb; ");
        emit($cg, "perla_dollar_underscore = __map_prev_du; ");
        emit($cg, "if (__mla_tmp) strada_free_array(__mla_tmp); ");
        # Decref __ml if its source was owned (anon list literal,
        # range, call result). Borrowed forms (variables) skip.
        if ($ml_borrowed == 0) {
            emit($cg, "if (__ml) strada_decref(__ml); ");
        }
        # Free the temporary flattened hash kv-list, if one was built.
        emit($cg, "if (__ml_hf) strada_decref(__ml_hf); ");
        # In scalar context, map returns the count of elements in the
        # output list (Perl). Same fix as grep.
        emit($cg, "(__perla_want_list == 0) ? ({ int64_t __mc = (int64_t)(__mav ? __mav->size : 0); strada_decref(__ma); STRADA_MAKE_TAGGED_INT(__mc); }) : __ma; })");
        return;
    }

    # try { BLOCK } catch { BLOCK } finally { BLOCK } — Try::Tiny
    if ($type == Perla::AST::N_GREP() && $node->{"name"} eq "try") {
        # Use Strada's existing try/catch infrastructure (setjmp/longjmp)
        emit($cg, "({ StradaValue *__try_result = strada_new_undef(); ");
        # Save want_list; longjmp from die inside try bypasses inner per-statement
        # save/restore, so void-context (-1) would leak into catch and beyond.
        emit($cg, "int __try_sav_wl = __perla_want_list; ");
        emit($cg, "int __try_idx = strada_try_depth++; int __try_popped = 0; ");
        emit($cg, "strada_try_stack[__try_idx].active = 1; ");
        emit($cg, "if (setjmp(strada_try_stack[__try_idx].buf) == 0) { do { ");
        # Activate eval-block-expr semantics so `return EXPR` inside
        # the try body sets __try_result via a do-while + break.
        my int $__try_save_eb = 0;
        if (defined($cg->{"eval_block_expr_active"})) { $__try_save_eb = $cg->{"eval_block_expr_active"}; }
        my scalar $__try_save_rv = $cg->{"eval_block_result_var"};
        $cg->{"eval_block_expr_active"} = $__try_save_eb + 1;
        $cg->{"eval_block_result_var"} = "__try_result";
        # Try block — capture last expression as result
        my scalar $try_stmts = $node->{"block"}->{"stmts"};
        if (defined($try_stmts) && scalar(@{$try_stmts}) > 0) {
            my int $last_idx = scalar(@{$try_stmts}) - 1;
            my int $ti = 0;
            while ($ti < $last_idx) {
                Perla::CodeGen::Stmt::gen_stmt($cg, $try_stmts->[$ti]);
                $ti++;
            }
            # If last stmt is `return EXPR`, capture EXPR directly into
            # __try_result rather than running it through gen_expr_safe
            # (which doesn't know about N_RETURN).
            my scalar $tr_last = $try_stmts->[$last_idx];
            if (defined($tr_last) && $tr_last->{"type"} == Perla::AST::N_RETURN()) {
                if (defined($tr_last->{"value"})) {
                    emit($cg, "__try_result = ");
                    gen_expr($cg, $tr_last->{"value"});
                    emit($cg, "; if (__try_result) strada_incref(__try_result); ");
                }
            } elsif (defined($tr_last) && $tr_last->{"type"} == Perla::AST::N_IF()) {
                # try-body's value is the value of whichever if-branch ran
                # (Perl block-value-of-trailing-if-stmt semantics, same as
                # the catch handling below).
                Perla::CodeGen::Stmt::gen_if_capture_return($cg, $tr_last, "__try_result");
            } else {
                emit($cg, "__try_result = ");
                gen_expr_safe($cg, $tr_last);
                emit($cg, "; ");
            }
        }
        $cg->{"eval_block_expr_active"} = $__try_save_eb;
        $cg->{"eval_block_result_var"} = $__try_save_rv;
        emit($cg, " } while(0); ");
        emit($cg, " } else { ");
        # Restore want_list (see save above) — die's longjmp skipped inner restores.
        emit($cg, "__perla_want_list = __try_sav_wl; ");
        # Pop the inner try slot BEFORE running catch — so any die
        # inside catch propagates to the OUTER try (or terminates).
        # Without this, `die "X"` inside catch would longjmp back to
        # the same setjmp and re-enter the else, looping forever.
        emit($cg, "strada_try_stack[__try_idx].active = 0; strada_try_depth = __try_idx; __try_popped = 1; ");
        # Catch block — set $_ and v__ to the error, capture result
        my scalar $catch_node = $node->{"list"};
        my scalar $finally_node = undef;
        if (defined($catch_node) && $catch_node->{"type"} == Perla::AST::N_GREP()) {
            if ($catch_node->{"name"} eq "catch") {
                # Set $_ to the error message (v__, perla_dollar_underscore, and v_ for all codegen paths)
                emit($cg, "{ StradaValue *__saved_dollar = v__; ");
                # Prefer the actual exception value (blessed ref / hashref) over the stringified message
                emit($cg, "if (strada_exception_value) { v__ = strada_exception_value; strada_incref(v__); } ");
                emit($cg, "else { v__ = strada_exception_msg ? strada_new_str(strada_exception_msg) : strada_new_str(\"unknown error\"); } ");
                emit($cg, "if (getenv(\"PERLA_TRACE_CATCH\")) { char *__tc = strada_to_str(v__); fprintf(stderr, \"[catch-try] %s\\n\", __tc ? __tc : \"(empty)\"); free(__tc); } ");
                emit($cg, "StradaValue *perla_dollar_underscore = v__; ");
                emit($cg, "(void)perla_dollar_underscore; ");
                # Perl 5.34+ `catch (VAR)` — bind the exception value to
                # the named lexical so `catch ($e) { say $e }` sees the
                # error. Without this, $e stays undef and the catch body
                # runs with empty values. Save the caller's slot so we
                # restore on block exit (mirrors $_).
                if (defined($catch_node->{"catch_var"})) {
                    my str $cv_name = $catch_node->{"catch_var"};
                    my str $cv_c = c_var($cv_name);
                    emit($cg, "StradaValue *__cv_saved_" . safe_ident($cv_name) . " = " . $cv_c . "; ");
                    emit($cg, $cv_c . " = v__; strada_incref(" . $cv_c . "); ");
                }
                # Capture the last expression as __try_result
                my scalar $catch_stmts = undef;
                if (defined($catch_node->{"block"})) {
                    $catch_stmts = $catch_node->{"block"}->{"stmts"};
                } elsif (defined($catch_node->{"body"})) {
                    $catch_stmts = $catch_node->{"body"}->{"stmts"};
                }
                # Same eval-block-expr trick for the catch body so
                # `return EXPR` inside catch sets __try_result.
                emit($cg, "do { ");
                my int $__catch_save_eb = 0;
                if (defined($cg->{"eval_block_expr_active"})) { $__catch_save_eb = $cg->{"eval_block_expr_active"}; }
                my scalar $__catch_save_rv = $cg->{"eval_block_result_var"};
                $cg->{"eval_block_expr_active"} = $__catch_save_eb + 1;
                $cg->{"eval_block_result_var"} = "__try_result";
                if (defined($catch_stmts) && scalar(@{$catch_stmts}) > 0) {
                    my int $last_ci = scalar(@{$catch_stmts}) - 1;
                    my int $ci2 = 0;
                    while ($ci2 < $last_ci) {
                        Perla::CodeGen::Stmt::gen_stmt($cg, $catch_stmts->[$ci2]);
                        $ci2++;
                    }
                    # Last stmt: if it's a statement (if/while/for), just emit it;
                    # if it's an expression, capture as __try_result.
                    # If it's `return EXPR`, take EXPR directly.
                    my scalar $last_cs = $catch_stmts->[$last_ci];
                    my int $last_type = $last_cs->{"type"};
                    if ($last_type == Perla::AST::N_IF()) {
                        # Catch block ending with `if/elsif/else` should yield
                        # the value of whichever branch executes (matches Perl's
                        # treatment of an if-stmt as the last expression of a
                        # block). gen_if_capture_return walks branches and
                        # assigns each branch's last-expression to ret_var.
                        Perla::CodeGen::Stmt::gen_if_capture_return($cg, $last_cs, "__try_result");
                    } elsif ($last_type == Perla::AST::N_WHILE() ||
                        $last_type == Perla::AST::N_FOR_C() || $last_type == Perla::AST::N_FOREACH()) {
                        Perla::CodeGen::Stmt::gen_stmt($cg, $last_cs);
                    } elsif ($last_type == Perla::AST::N_RETURN()) {
                        if (defined($last_cs->{"value"})) {
                            emit($cg, "__try_result = ");
                            gen_expr($cg, $last_cs->{"value"});
                            emit($cg, "; if (__try_result) strada_incref(__try_result); ");
                        }
                    } else {
                        emit($cg, "__try_result = ");
                        gen_expr_safe($cg, $last_cs);
                        emit($cg, "; ");
                    }
                }
                $cg->{"eval_block_expr_active"} = $__catch_save_eb;
                $cg->{"eval_block_result_var"} = $__catch_save_rv;
                emit($cg, " } while(0); ");
                # Restore the catch-var slot first (in inverse order from
                # init above) before restoring v__.
                if (defined($catch_node->{"catch_var"})) {
                    my str $cv_name = $catch_node->{"catch_var"};
                    my str $cv_c = c_var($cv_name);
                    emit($cg, "if (" . $cv_c . ") strada_decref(" . $cv_c . "); ");
                    emit($cg, $cv_c . " = __cv_saved_" . safe_ident($cv_name) . "; ");
                }
                emit($cg, "strada_decref(v__); v__ = __saved_dollar; } ");
                # Check for finally node in catch's list
                if (defined($catch_node->{"list"})) {
                    my scalar $after_catch = $catch_node->{"list"};
                    if (defined($after_catch) && $after_catch->{"type"} == Perla::AST::N_GREP() && $after_catch->{"name"} eq "finally") {
                        $finally_node = $after_catch;
                    }
                }
            } elsif ($catch_node->{"name"} eq "finally") {
                # try { } finally { } — no catch block
                $finally_node = $catch_node;
            }
        }
        emit($cg, " } ");
        # Only pop if not already popped by the catch path.
        emit($cg, "if (!__try_popped) { strada_try_stack[__try_idx].active = 0; strada_try_depth = __try_idx; } ");
        # Finally block — always runs
        if (defined($finally_node)) {
            emit($cg, "{ ");
            if (defined($finally_node->{"block"})) {
                Perla::CodeGen::Stmt::gen_block_stmts($cg, $finally_node->{"block"});
            }
            emit($cg, " } ");
        }
        emit($cg, "__try_result; })");
        return;
    }

    # grep { BLOCK } LIST
    if ($type == Perla::AST::N_GREP()) {
        # `first`/`any`/`all`/`none`/`notall` { BLOCK } LIST — share the
        # IDENT-with-block parser path with grep, so they all arrive here.
        # Emit specialized iteration that short-circuits per the semantics
        # (return the matching element, or 0/1 boolean, etc.) instead of
        # collecting matches like grep. Required for SAC's special_op
        # dispatch and many CPAN modules that use List::Util predicates.
        my str $gname_full = "" . $node->{"name"};
        my str $gname = $gname_full;
        # Allow `List::Util::first { ... }` — extract the trailing segment.
        my int $g_li = -1;
        my int $g_si = 0;
        while ($g_si < length($gname_full) - 1) {
            if (substr($gname_full, $g_si, 2) eq "::") { $g_li = $g_si; }
            $g_si++;
        }
        if ($g_li >= 0) { $gname = substr($gname_full, $g_li + 2, length($gname_full) - $g_li - 2); }
        if ($gname eq "first") {
            emit($cg, "({ StradaValue *__fr = NULL; int __sav_wl_lu = __perla_want_list; __perla_want_list = 1; StradaValue *__gl = ");
            gen_expr($cg, $node->{"list"});
            emit($cg, "; __perla_want_list = __sav_wl_lu; StradaArray *__gla = strada_deref_array(__gl); ");
            emit($cg, "int __glen = __gla ? strada_array_length(__gla) : 0; ");
            emit($cg, "StradaValue *__gr_prev_du = perla_dollar_underscore; ");
            emit($cg, "for (int __gi = 0; __gi < __glen; __gi++) { ");
            emit($cg, "perla_dollar_underscore = strada_array_get(__gla, __gi); ");
            emit($cg, "if (perla_to_bool(");
            _gen_map_block($cg, $node->{"block"});
            emit($cg, ")) { __fr = perla_dollar_underscore; if (__fr) strada_incref(__fr); break; } } ");
            emit($cg, "perla_dollar_underscore = __gr_prev_du; ");
            emit($cg, "__fr ? __fr : strada_new_undef(); })");
            return;
        }
        if ($gname eq "any") {
            emit($cg, "({ int __any = 0; int __sav_wl_lu = __perla_want_list; __perla_want_list = 1; StradaValue *__gl = ");
            gen_expr($cg, $node->{"list"});
            emit($cg, "; __perla_want_list = __sav_wl_lu; StradaArray *__gla = strada_deref_array(__gl); ");
            emit($cg, "int __glen = __gla ? strada_array_length(__gla) : 0; ");
            emit($cg, "StradaValue *__gr_prev_du = perla_dollar_underscore; ");
            emit($cg, "for (int __gi = 0; __gi < __glen; __gi++) { ");
            emit($cg, "perla_dollar_underscore = strada_array_get(__gla, __gi); ");
            emit($cg, "if (perla_to_bool(");
            _gen_map_block($cg, $node->{"block"});
            emit($cg, ")) { __any = 1; break; } } ");
            emit($cg, "perla_dollar_underscore = __gr_prev_du; STRADA_MAKE_TAGGED_INT(__any); })");
            return;
        }
        if ($gname eq "all") {
            emit($cg, "({ int __all = 1; int __sav_wl_lu = __perla_want_list; __perla_want_list = 1; StradaValue *__gl = ");
            gen_expr($cg, $node->{"list"});
            emit($cg, "; __perla_want_list = __sav_wl_lu; StradaArray *__gla = strada_deref_array(__gl); ");
            emit($cg, "int __glen = __gla ? strada_array_length(__gla) : 0; ");
            emit($cg, "StradaValue *__gr_prev_du = perla_dollar_underscore; ");
            emit($cg, "for (int __gi = 0; __gi < __glen; __gi++) { ");
            emit($cg, "perla_dollar_underscore = strada_array_get(__gla, __gi); ");
            emit($cg, "if (!perla_to_bool(");
            _gen_map_block($cg, $node->{"block"});
            emit($cg, ")) { __all = 0; break; } } ");
            emit($cg, "perla_dollar_underscore = __gr_prev_du; STRADA_MAKE_TAGGED_INT(__all); })");
            return;
        }
        if ($gname eq "none" || $gname eq "notall") {
            # none { COND } LIST  — true if NO element matches
            #                     initial __np = 1, set 0 on first match.
            # notall { COND } LIST — true if NOT ALL match (at least one fails)
            #                     initial __np = 0, set 1 on first non-match.
            # Without this distinction perla's notall returned the opposite
            # of Perl's: `notall { $_ > 0 } -1, 1, 2` gave false.
            my int $is_notall = ($gname eq "notall") ? 1 : 0;
            my int $init_np = ($is_notall == 1) ? 0 : 1;
            my int $break_np = ($is_notall == 1) ? 1 : 0;
            emit($cg, "({ int __np = " . $init_np . "; int __sav_wl_lu = __perla_want_list; __perla_want_list = 1; StradaValue *__gl = ");
            gen_expr($cg, $node->{"list"});
            emit($cg, "; __perla_want_list = __sav_wl_lu; StradaArray *__gla = strada_deref_array(__gl); ");
            emit($cg, "int __glen = __gla ? strada_array_length(__gla) : 0; ");
            emit($cg, "StradaValue *__gr_prev_du = perla_dollar_underscore; ");
            emit($cg, "for (int __gi = 0; __gi < __glen; __gi++) { ");
            emit($cg, "perla_dollar_underscore = strada_array_get(__gla, __gi); ");
            if ($is_notall == 1) {
                emit($cg, "if (!perla_to_bool(");
            } else {
                emit($cg, "if (perla_to_bool(");
            }
            _gen_map_block($cg, $node->{"block"});
            emit($cg, ")) { __np = " . $break_np . "; break; } } ");
            emit($cg, "perla_dollar_underscore = __gr_prev_du; STRADA_MAKE_TAGGED_INT(__np); })");
            return;
        }
        # reduce { BLOCK } LIST — block uses \$a (accumulator) and \$b
        # (current). Returns final accumulator (or undef for empty list,
        # or the single element for a one-element list).
        if ($gname eq "reduce") {
            emit($cg, "({ int __sav_wl_rd = __perla_want_list; __perla_want_list = 1; StradaValue *__gl = ");
            gen_expr($cg, $node->{"list"});
            emit($cg, "; __perla_want_list = __sav_wl_rd; StradaArray *__gla = strada_deref_array(__gl); ");
            emit($cg, "StradaValue *__rd_fb = NULL; ");
            # If list arg is a scalar (e.g. \`reduce { ... } 42\`), wrap into a 1-elem array.
            emit($cg, "if (!__gla && __gl) { __rd_fb = strada_new_array(); strada_array_push(strada_deref_array(__rd_fb), __gl); __gla = strada_deref_array(__rd_fb); } ");
            emit($cg, "int __glen = __gla ? strada_array_length(__gla) : 0; ");
            emit($cg, "StradaValue *__rd_sa = v_a; StradaValue *__rd_sb = v_b; ");
            emit($cg, "StradaValue *__rd_acc = NULL; ");
            emit($cg, "if (__glen > 0) { __rd_acc = strada_array_get(__gla, 0); if (__rd_acc) strada_incref(__rd_acc); } ");
            emit($cg, "for (int __gi = 1; __gi < __glen; __gi++) { ");
            emit($cg, "v_a = __rd_acc; v_b = strada_array_get(__gla, __gi); ");
            emit($cg, "StradaValue *__rd_r = ");
            _gen_map_block($cg, $node->{"block"});
            emit($cg, "; if (__rd_acc) strada_decref(__rd_acc); __rd_acc = __rd_r; if (__rd_acc) strada_incref(__rd_acc); ");
            emit($cg, "} v_a = __rd_sa; v_b = __rd_sb; ");
            emit($cg, "if (__rd_fb) strada_decref(__rd_fb); ");
            emit($cg, "__rd_acc ? __rd_acc : strada_new_undef(); })");
            return;
        }
        # pairmap { BLOCK } LIST — bind $a=key, $b=value for each pair;
        # collect (flattened) results. pairgrep keeps the pairs whose
        # block returned true. Both use v_a/v_b like reduce.
        if ($gname eq "pairmap" || $gname eq "pairgrep") {
            my int $is_grep = ($gname eq "pairgrep") ? 1 : 0;
            emit($cg, "({ int __sav_wl_pm = __perla_want_list; __perla_want_list = 1; StradaValue *__gl = ");
            gen_expr($cg, $node->{"list"});
            emit($cg, "; __perla_want_list = __sav_wl_pm; StradaArray *__gla = strada_deref_array(__gl); ");
            emit($cg, "int __glen = __gla ? strada_array_length(__gla) : 0; ");
            emit($cg, "StradaValue *__pm_sa = v_a; StradaValue *__pm_sb = v_b; ");
            emit($cg, "StradaValue *__pm_out = strada_new_array(); StradaArray *__pm_oav = strada_deref_array(__pm_out); ");
            emit($cg, "for (int __gi = 0; __gi + 1 < __glen; __gi += 2) { ");
            emit($cg, "v_a = strada_array_get(__gla, __gi); ");
            emit($cg, "v_b = strada_array_get(__gla, __gi + 1); ");
            emit($cg, "StradaValue *__pm_r = ");
            _gen_map_block($cg, $node->{"block"});
            emit($cg, "; ");
            if ($is_grep == 1) {
                emit($cg, "int __pm_keep = perla_to_bool(__pm_r); ");
                emit($cg, "if (__pm_r) strada_decref(__pm_r); ");
                emit($cg, "if (__pm_keep) { ");
                emit($cg, "  StradaValue *__pm_k = v_a; if (__pm_k) strada_incref(__pm_k); strada_array_push_take(__pm_oav, __pm_k ? __pm_k : strada_new_undef()); ");
                emit($cg, "  StradaValue *__pm_v = v_b; if (__pm_v) strada_incref(__pm_v); strada_array_push_take(__pm_oav, __pm_v ? __pm_v : strada_new_undef()); ");
                emit($cg, "} ");
            } else {
                # pairmap: result can be a list — flatten arrays
                emit($cg, "if (__pm_r && !STRADA_IS_TAGGED_INT(__pm_r) && __pm_r->type == STRADA_ARRAY) { ");
                emit($cg, "  StradaArray *__pm_ra = strada_deref_array(__pm_r); ");
                emit($cg, "  if (__pm_ra) for (size_t __pm_j = 0; __pm_j < __pm_ra->size; __pm_j++) { ");
                emit($cg, "    StradaValue *__pm_re = __pm_ra->elements[__pm_ra->head + __pm_j]; ");
                emit($cg, "    if (__pm_re) strada_incref(__pm_re); strada_array_push_take(__pm_oav, __pm_re ? __pm_re : strada_new_undef()); } ");
                emit($cg, "  strada_decref(__pm_r); ");
                emit($cg, "} else if (__pm_r) { strada_array_push_take(__pm_oav, __pm_r); } ");
                emit($cg, "else { strada_array_push_take(__pm_oav, strada_new_undef()); } ");
            }
            emit($cg, "} v_a = __pm_sa; v_b = __pm_sb; ");
            emit($cg, "__perla_want_list ? __pm_out : ({ int64_t __pm_c = (int64_t)(__pm_oav ? __pm_oav->size : 0); strada_decref(__pm_out); STRADA_MAKE_TAGGED_INT(__pm_c); }); })");
            return;
        }
        emit($cg, "({ StradaValue *__ga = strada_new_array(); StradaArray *__gav = strada_deref_array(__ga); ");
        emit($cg, "int __sav_wl_lu = __perla_want_list; __perla_want_list = 1; StradaValue *__gl = ");
        gen_expr($cg, $node->{"list"});
        emit($cg, "; __perla_want_list = __sav_wl_lu; ");
        # `grep BLOCK %hash` iterates the hash's flattened key/value pairs.
        emit($cg, "StradaValue *__gl_hf = perla_hash_kv_list(__gl); StradaValue *__gl_eff = __gl_hf ? __gl_hf : __gl; ");
        emit($cg, "StradaArray *__gla = strada_deref_array(__gl_eff); ");
        # Scalar-in-list-context: `grep { } ($text)` and `grep { } $text`
        # should iterate the scalar as a 1-element list. Without this,
        # strada_deref_array(scalar) returns NULL and the loop runs 0
        # times. Build a one-shot StradaArray holding __gl.
        emit($cg, "StradaArray *__gla_tmp = NULL; if (!__gla && __gl) { __gla_tmp = strada_array_new(); strada_array_push(__gla_tmp, __gl); strada_incref(__gl); __gla = __gla_tmp; } ");
        emit($cg, "int __glen = __gla ? strada_array_length(__gla) : 0; ");
        # Save the global \$_ so nested sub calls during the block see the
        # per-iteration value (Perl's dynamic-scope semantics). Previously
        # the loop declared a LOCAL `perla_dollar_underscore`, which
        # shadowed the global but didn't propagate — `grep { \$fn->() }`
        # left the called sub reading the OUTER \$_.
        emit($cg, "StradaValue *__gr_prev_du = perla_dollar_underscore; ");
        emit($cg, "for (int __gi = 0; __gi < __glen; __gi++) { ");
        emit($cg, "StradaValue *__gi_orig = strada_array_get(__gla, __gi); ");
        emit($cg, "perla_dollar_underscore = __gi_orig; ");
        emit($cg, "int __gkeep = perla_to_bool(");
        _gen_map_block($cg, $node->{"block"});
        emit($cg, "); ");
        # Aliasing write-back: Perl aliases `$_` to each list element in
        # `grep { ... } @arr`. If the block mutated `$_`, propagate to
        # the source array slot.
        emit($cg, "if (perla_dollar_underscore != __gi_orig) { ");
        emit($cg, "  if (perla_dollar_underscore) strada_incref(perla_dollar_underscore); ");
        emit($cg, "  if (__gla) strada_array_set(__gla, __gi, perla_dollar_underscore); ");
        emit($cg, "} ");
        # In scalar context, grep returns the count of matches (Perl).
        # Otherwise yield the filtered array. Without this, `my \$n =
        # grep { … } @arr` stored the entire filtered array in \$n;
        # printf/print read it as the first element instead of the count.
        emit($cg, "if (__gkeep) strada_array_push(__gav, perla_dollar_underscore); } ");
        emit($cg, "perla_dollar_underscore = __gr_prev_du; ");
        emit($cg, "if (__gla_tmp) strada_free_array(__gla_tmp); ");
        emit($cg, "if (__gl_hf) strada_decref(__gl_hf); ");
        emit($cg, "(__perla_want_list == 0) ? ({ int64_t __gc = (int64_t)(__gav ? __gav->size : 0); strada_decref(__ga); STRADA_MAKE_TAGGED_INT(__gc); }) : __ga; })");
        return;
    }

    # Regex literal
    if ($type == Perla::AST::N_REGEX()) {
        my str $pat = Perla::CodeGen::Escape::escape_c_str($node->{"pattern"});
        my str $flags = "";
        if (defined($node->{"flags"})) { $flags = $node->{"flags"}; }
        # qr// — produce a stringified regex value matching Perl's
        # `(?FLAGS:PATTERN)` form. Callers using `=~ $qr_var` parse this
        # at match time. Without this, qr// fell through to the immediate
        # match against $_ and stored 0/1 in hashes, breaking
        # SAC/`List::Util::first { $op =~ $_->{regex} }` dispatch.
        my int $is_qr = 0;
        if (defined($node->{"is_qr"}) && $node->{"is_qr"} == 1) { $is_qr = 1; }
        if ($is_qr == 1) {
            # Use ^ to mark Perl's "default flags then specified flags"
            # form. PCRE understands `(?FLAGS:PATTERN)` for the flags we
            # care about (i, m, s, x). Bless the resulting str value as
            # 'Regexp' so `ref($qr) eq "Regexp"` works (DBIC's
            # _Util::sigwarn_silencer croaks otherwise). The value stays
            # a plain string for stringify and =~ pattern extraction.
            # Interpolate \$vars (incl. nested qr// objects) at runtime —
            # without this, \`qr/\$x/\` stored "(?^:\$x)" literally
            # instead of expanding \$x's value.
            my int $qr_has_var = has_perl_var($pat);
            if ($qr_has_var == 1) {
                emit($cg, "({ char *__qrp = strada_to_str(");
                Perla::CodeGen::Interp::gen_interp_c_str($cg, $node->{"pattern"});
                emit($cg, "); size_t __qrl = strlen(__qrp); char *__qrb = malloc(__qrl + 16); ");
                emit($cg, "int __qrn = snprintf(__qrb, __qrl + 16, \"(?^" . $flags . ":%s)\", __qrp); ");
                emit($cg, "(void)__qrn; free(__qrp); StradaValue *__qrr = strada_bless(strada_new_str(__qrb), \"Regexp\"); free(__qrb); __qrr; })");
            } else {
                emit($cg, "strada_bless(strada_new_str(\"(?^" . $flags . ":" . $pat . ")\"), \"Regexp\")");
            }
            return;
        }
        # Standalone regex — implicit match against $_ (like in grep { /pat/ }, if (/pat/)).
        # Always populate $1..$9 (and named captures) so subsequent uses of
        # the capture variables work. Sub::Quote::capture_unroll relies on
        # `/^([\@\%\$])/` then `${1}` interpolation to build qsub'd subs.
        # Interpolate $vars in pattern (e.g. `/^$re$/` where $re is a qr//).
        # Standalone /pat/ — implicit match against $_. In list context
        # returns captures (matching Perl), in scalar context returns
        # 0/1. Mirror the =~ form so `my @m = /(\d+)/` against $_ gets
        # the captures instead of the boolean.
        my int $std_pat_has_var = has_perl_var($pat);
        # If we're inside a `while (/pat/g)` loop, use the global-match
        # form that advances the position tracker; otherwise plain match.
        # Without this, `while (/(\d+)/g)` (implicit \$_) matched at
        # pos 0 every iteration and infinite-looped.
        my int $std_is_g = 0;
        if (index($flags, "g") >= 0
            && defined($cg->{"regex_g_pos_var"}) && length($cg->{"regex_g_pos_var"}) > 0) {
            $std_is_g = 1;
        }
        emit($cg, "({ char *__rs = strada_to_str(perla_dollar_underscore ? perla_dollar_underscore : strada_new_str(\"\")); StradaValue *__rmv; ");
        if ($std_is_g == 1) {
            if ($std_pat_has_var == 1) {
                emit($cg, "char *__pat = strada_to_str(");
                Perla::CodeGen::Interp::gen_interp_c_str($cg, $node->{"pattern"});
                emit($cg, "); int __rm = strada_regex_match_global(__rs, __pat, \"" . $flags . "\", &" . $cg->{"regex_g_pos_var"} . "); free(__pat); __rmv = STRADA_MAKE_TAGGED_INT(__rm); ");
            } else {
                emit($cg, "int __rm = strada_regex_match_global(__rs, \"" . $pat . "\", \"" . $flags . "\", &" . $cg->{"regex_g_pos_var"} . "); __rmv = STRADA_MAKE_TAGGED_INT(__rm); ");
            }
        } elsif ($std_pat_has_var == 1) {
            emit($cg, "char *__pat = strada_to_str(");
            Perla::CodeGen::Interp::gen_interp_c_str($cg, $node->{"pattern"});
            # Perl: m// in scalar context returns 1 on match, "" (empty)
            # on no match — NOT 0. Without this, `"abc" =~ /z/` rendered
            # as "0" in interpolated output instead of "".
            emit($cg, "); if (__perla_want_list) { __rmv = strada_regex_match_list(__rs, __pat, \"" . $flags . "\"); } else { int __rmi = strada_regex_match_with_capture(__rs, __pat, \"" . $flags . "\"); __rmv = __rmi ? STRADA_MAKE_TAGGED_INT(1) : strada_new_str(\"\"); } free(__pat); ");
        } else {
            emit($cg, "if (__perla_want_list) { __rmv = strada_regex_match_list(__rs, \"" . $pat . "\", \"" . $flags . "\"); } else { int __rmi = strada_regex_match_with_capture(__rs, \"" . $pat . "\", \"" . $flags . "\"); __rmv = __rmi ? STRADA_MAKE_TAGGED_INT(1) : strada_new_str(\"\"); } ");
        }
        emit($cg, "free(__rs); __rmv; })");
        return;
    }

    # sort { $a <=> $b } @list — custom comparator
    if ($type == Perla::AST::N_SORT()) {
        # sort SUBNAME LIST — named bareword comparator. Emits a thunk
        # call that sets v_a/v_b before invoking the named sub.
        if (defined($node->{"cmp_sub"})) {
            my str $csub = $node->{"cmp_sub"};
            my str $cqname = $cg->{"pkg"} . "::" . $csub;
            if (index($csub, "::") >= 0) { $cqname = $csub; }
            my str $cfname = sub_cname_q($cqname);
            emit($cg, "({ __perla_sort_named_target = " . $cfname . "; StradaValue *__sl = ");
            gen_expr($cg, $node->{"list"});
            emit($cg, "; perla_sort_custom(__sl, (void*)__perla_sort_named_thunk); })");
            return;
        }
        # sort $coderef LIST — scalar comparator. Uses
        # perla_sort_by_coderef which calls back into Perl land via
        # perla_call_code with $a/$b set.
        if (defined($node->{"comparator_expr"})) {
            emit($cg, "({ StradaValue *__cmpv = ");
            gen_expr($cg, $node->{"comparator_expr"});
            emit($cg, "; __perla_sort_coderef_target = __cmpv; StradaValue *__sl = ");
            gen_expr($cg, $node->{"list"});
            emit($cg, "; perla_sort_custom(__sl, (void*)__perla_sort_coderef_thunk); })");
            return;
        }
        my scalar $block = $node->{"block"};
        if (!defined($block) || !defined($block->{"stmts"}) || scalar(@{$block->{"stmts"}}) == 0) {
            # No block: default alphabetical sort. strada_sort takes a
            # borrowed input and returns a fresh array — if the list
            # expression is owned (e.g. `sort keys %h` produces a fresh
            # array via strada_new_array_from_av), we must decref the
            # input or it leaks once per call.
            my int $sl_borrowed = expr_is_borrowed($node->{"list"});
            emit($cg, "({ StradaValue *__sli = ");
            gen_expr($cg, $node->{"list"});
            emit($cg, "; StradaValue *__slr = strada_sort(__sli); ");
            if ($sl_borrowed == 0) {
                emit($cg, "if (__sli) strada_decref(__sli); ");
            }
            emit($cg, "__slr; })");
            return;
        }
        # Fast path: canonical comparators `{ $a <=> $b }` / `{ $b <=> $a }`
        # / `{ $a cmp $b }` / `{ $b cmp $a }` sort natively in C with no
        # per-comparison Perl call (what perl special-cases too).
        my int $canon = -1;
        if (defined($block->{"stmts"}) && scalar(@{$block->{"stmts"}}) == 1) {
            my scalar $cst = $block->{"stmts"}->[0];
            if (defined($cst) && defined($cst->{"expr"})) { $cst = $cst->{"expr"}; }
            if (defined($cst) && $cst->{"type"} == Perla::AST::N_BINOP()) {
                my str $cop = "" . $cst->{"op"};
                if ($cop eq "<=>" || $cop eq "cmp") {
                    my scalar $cl = $cst->{"left"}; my scalar $cr = $cst->{"right"};
                    if (defined($cl) && defined($cr)
                        && $cl->{"type"} == Perla::AST::N_SCALAR_VAR()
                        && $cr->{"type"} == Perla::AST::N_SCALAR_VAR()) {
                        my str $cln = "" . $cl->{"name"}; my str $crn = "" . $cr->{"name"};
                        my int $cnum = ($cop eq "<=>") ? 1 : 0;
                        if ($cln eq "a" && $crn eq "b") { $canon = $cnum ? 0 : 2; }
                        elsif ($cln eq "b" && $crn eq "a") { $canon = $cnum ? 1 : 3; }
                    }
                }
            }
        }
        if ($canon >= 0) {
            my int $csl_borrowed = expr_is_borrowed($node->{"list"});
            emit($cg, "({ StradaValue *__sli = ");
            gen_expr($cg, $node->{"list"});
            emit($cg, "; StradaValue *__slr = perla_sort_native(__sli, " . $canon . "); ");
            if ($csl_borrowed == 0) { emit($cg, "if (__sli) strada_decref(__sli); "); }
            emit($cg, "__slr; })");
            return;
        }
        # Generate an anonymous comparator function
        $cg->{"tmp_count"} = $cg->{"tmp_count"} + 1;
        my str $cmp_name = "__perla_sort_cmp_" . $cg->{"tmp_count"};

        # Scan block for free variable references (not $a/$b) that need capture
        my scalar $free_vars = Perla::CodeGen::FreeVars::find_sort_free_vars($block);
        my int $nfv = scalar(@{$free_vars});

        # Collect the sort block and generate a C comparator
        my scalar $sort_sub = Perla::AST::node(Perla::AST::N_SUB());
        $sort_sub->{"name"} = $cmp_name;
        $sort_sub->{"package"} = $cg->{"pkg"};
        $sort_sub->{"body"} = $block;
        $sort_sub->{"is_sort_cmp"} = 1;
        if ($nfv > 0) {
            $sort_sub->{"sort_captures"} = $free_vars;
        }
        push(@{$cg->{"anon_subs"}}, $sort_sub);

        my str $fname = sub_cname_q($cg->{"pkg"} . "::" . $cmp_name);

        if ($nfv > 0) {
            emit($cg, "({ ");
            my int $fi = 0;
            while ($fi < $nfv && $fi < 16) {
                # Store pointer-to-variable so sort callback's `$count++`
                # writes back to the outer var (perla_sort_ctx is now
                # StradaValue** to enable write-through). Without this,
                # captures were value-copies and outer scope never saw
                # the comparator's mutations.
                emit($cg, "__perla_sort_ctx[" . $fi . "] = &" . c_var($free_vars->[$fi]) . "; ");
                $fi++;
            }
            emit($cg, "StradaValue *__sl = ");
            gen_expr($cg, $node->{"list"});
            emit($cg, "; perla_sort_custom(__sl, (void*)" . $fname . "); })");
        } else {
            emit($cg, "({ StradaValue *__sl = ");
            gen_expr($cg, $node->{"list"});
            emit($cg, "; perla_sort_custom(__sl, (void*)" . $fname . "); })");
        }
        return;
    }

    # Array slice: @arr[indices]
    if ($type == Perla::AST::N_ARRAY_SLICE()) {
        # `array` may be a plain variable name (string) when parsed via the
        # `@arr[...]` ARRAY_VAR path, or an AST node when parsed via the
        # postfix `@{EXPR}[...]` path. Generate the source-array expression
        # accordingly.
        my scalar $indices = $node->{"indices"};
        my int $ni = scalar(@{$indices});
        emit($cg, "({ StradaValue *__sl = strada_new_array(); StradaArray *__sla = strada_deref_array(__sl); ");
        # The slice operand evaluates in LIST context (Perl semantics:
        # `(FUNC())[i]` always calls FUNC in list context regardless of
        # the outer scalar/list context). Without this wrapper, a slice
        # inside `my $one = (gl())[0]` ran gl() in scalar context and
        # got the last list element only — then index [0] of that single
        # value was undef.
        emit($cg, "int __sav_wl_sl = __perla_want_list; __perla_want_list = 1; ");
        emit($cg, "StradaArray *__src = strada_deref_array(");
        my scalar $arr = $node->{"array"};
        if (defined($arr) && ref($arr) eq "HASH") {
            gen_expr($cg, $arr);
        } elsif (defined($arr) && ("" . $arr) eq "_") {
            # @_ — special case, the @_ array is in `perla_at_`, not v__
            # (`v__` is `$_`). Without this, `@_[0..N]` slice reads the
            # default scalar $_ instead of the function args.
            emit($cg, "perla_at_");
        } elsif (defined($arr) && index("" . $arr, "::") > 0) {
            # @Pkg::arr[i,j] — slice the ARRAY slot of the stash glob.
            # Without this, c_var_a emits v_Pkg_arr (a local that never
            # exists), so the slice returns all-undef.
            my str $apn = "" . $arr;
            my int $ali = -1;
            my int $asi = 0;
            while ($asi < length($apn) - 1) {
                if (substr($apn, $asi, 2) eq "::") { $ali = $asi; }
                $asi = $asi + 1;
            }
            my str $apkg = substr($apn, 0, $ali);
            my str $aname = substr($apn, $ali + 2, length($apn) - $ali - 2);
            emit($cg, "perla_array_get(\"" . $apkg . "\", \"" . $aname . "\")");
        } else {
            emit($cg, c_var_a($arr));
        }
        emit($cg, "); __perla_want_list = __sav_wl_sl; ");
        # `%arr[...]` is the key-value array-slice form (5.20+): for
        # each index push BOTH the (normalized, non-negative) index
        # and the value at that index.
        my int $is_kv_arr = 0;
        if (defined($node->{"is_kv_slice"}) && $node->{"is_kv_slice"} == 1) { $is_kv_arr = 1; }
        my int $si = 0;
        while ($si < $ni) {
            my scalar $idx = $indices->[$si];
            if (defined($idx) && $idx->{"type"} == Perla::AST::N_RANGE()) {
                # Range: @arr[0..5] — expand from..to
                emit($cg, "{ int __from = (int)strada_to_num(");
                gen_expr($cg, $idx->{"from"});
                emit($cg, "); int __to = (int)strada_to_num(");
                gen_expr($cg, $idx->{"to"});
                emit($cg, "); for (int __ri = __from; __ri <= __to; __ri++) { ");
                emit($cg, "int __si = __ri; if (__si < 0 && __src) __si += strada_array_length(__src); ");
                if ($is_kv_arr == 1) {
                    emit($cg, "strada_array_push(__sla, STRADA_MAKE_TAGGED_INT((int64_t)__si)); ");
                }
                emit($cg, "strada_array_push(__sla, __src ? strada_array_get(__src, __si) : strada_new_undef()); } } ");
            } elsif (defined($idx) && $idx->{"type"} == Perla::AST::N_ARRAY_VAR()) {
                # @arr[@indices] — iterate the index array. Special-case @_
                # which lives in perla_at_ (the sub's args), not the
                # file-scope v__ (which is $_). Must include head when
                # indexing elements — shift/unshift adjust head, so reading
                # __ia->elements[__ii] silently picks up the shifted-off slot.
                my str $ia_cvar = c_var_a($idx->{"name"});
                if (defined($idx->{"name"}) && $idx->{"name"} eq "_") {
                    $ia_cvar = "perla_at_";
                }
                emit($cg, "{ StradaArray *__ia = strada_deref_array(" . $ia_cvar . "); ");
                emit($cg, "if (__ia) for (size_t __ii = 0; __ii < __ia->size; __ii++) { ");
                emit($cg, "int __si = (int)strada_to_num(__ia->elements[__ia->head + __ii]); ");
                emit($cg, "if (__si < 0 && __src) __si += strada_array_length(__src); ");
                if ($is_kv_arr == 1) {
                    emit($cg, "strada_array_push(__sla, STRADA_MAKE_TAGGED_INT((int64_t)__si)); ");
                }
                emit($cg, "strada_array_push(__sla, __src ? strada_array_get(__src, __si) : strada_new_undef()); } } ");
            } elsif (defined($idx) && Perla::CodeGen::Predicate::idx_is_list_expr($idx) == 1) {
                # `@arr[FUNC()]` / `@arr[reverse 0..4]` — list-returning
                # expression used as slice indices. Evaluate in list
                # context, then iterate to slice each. If the runtime
                # result is NOT an array (e.g. `int(@arr/2)` returns a
                # tagged int), treat as a single index — without this
                # fallback, deref_array(tagged_int) = NULL and the loop
                # never runs, so `(sort ...)[int(@arr/2)]` silently
                # returned an empty list.
                emit($cg, "{ int __sav_wl_six = __perla_want_list; __perla_want_list = 1; StradaValue *__six = ");
                gen_expr($cg, $idx);
                emit($cg, "; __perla_want_list = __sav_wl_six; StradaArray *__ixa = strada_deref_array(__six); ");
                emit($cg, "if (__ixa) { for (size_t __ixi = 0; __ixi < __ixa->size; __ixi++) { ");
                emit($cg, "int __si = (int)strada_to_num(__ixa->elements[__ixa->head + __ixi]); ");
                emit($cg, "if (__si < 0 && __src) __si += strada_array_length(__src); ");
                if ($is_kv_arr == 1) {
                    emit($cg, "strada_array_push(__sla, STRADA_MAKE_TAGGED_INT((int64_t)__si)); ");
                }
                emit($cg, "strada_array_push(__sla, __src ? strada_array_get(__src, __si) : strada_new_undef()); } } ");
                if ($is_kv_arr == 1) {
                    emit($cg, "else { int __si = (int)strada_to_num(__six); if (__si < 0 && __src) __si += strada_array_length(__src); strada_array_push(__sla, STRADA_MAKE_TAGGED_INT((int64_t)__si)); strada_array_push(__sla, __src ? strada_array_get(__src, __si) : strada_new_undef()); } } ");
                } else {
                    emit($cg, "else { int __si = (int)strada_to_num(__six); if (__si < 0 && __src) __si += strada_array_length(__src); strada_array_push(__sla, __src ? strada_array_get(__src, __si) : strada_new_undef()); } } ");
                }
            } else {
                emit($cg, "{ int __si = (int)strada_to_num(");
                gen_expr($cg, $idx);
                emit($cg, "); if (__si < 0 && __src) __si += strada_array_length(__src); ");
                if ($is_kv_arr == 1) {
                    emit($cg, "strada_array_push(__sla, STRADA_MAKE_TAGGED_INT((int64_t)__si)); ");
                }
                emit($cg, "strada_array_push(__sla, __src ? strada_array_get(__src, __si) : strada_new_undef()); } ");
            }
            $si++;
        }
        # In scalar context, an array slice yields its last element
        # (Perl: scalar(LIST) is the last value). Without this, `my $x =
        # (LIST)[0]` returned the 1-elem array which downstream coerced
        # to its size (1) — `(sort @arr)[0]` gave "1" instead of the
        # first sorted element.
        emit($cg, "(__sav_wl_sl == 0 && __sla && __sla->size > 0) ? ({ StradaValue *__sle = strada_array_get(__sla, (int)__sla->size - 1); if (__sle) strada_incref(__sle); strada_decref(__sl); __sle; }) : __sl; })");
        return;
    }

    # Hash slice: @hash{keys}
    if ($type == Perla::AST::N_HASH_SLICE()) {
        my scalar $hash_node = $node->{"hash"};
        my scalar $keys_list = $node->{"keys_list"};
        my int $nk = scalar(@{$keys_list});
        # Build the hash expression — might be a var name, $ref deref, or complex expr
        emit($cg, "({ StradaValue *__slh = ");
        if (defined($hash_node) && ref($hash_node) eq "HASH") {
            # AST node — generate as expression. `@{EXPR}{keys}` is parsed
            # with hash_node being an N_DEREF_ARRAY wrapping the inner ref;
            # generate the inner ref directly so we can hash-deref it.
            if ($hash_node->{"type"} == Perla::AST::N_DEREF_ARRAY() && defined($hash_node->{"ref"})) {
                gen_expr($cg, $hash_node->{"ref"});
            } else {
                gen_expr($cg, $hash_node);
            }
        } elsif (defined($hash_node) && length("" . $hash_node) > 1 && substr("" . $hash_node, 0, 1) eq "$") {
            # @$ref{keys} — deref the scalar variable (plain scalar, not hash sigil)
            my str $ref_var = substr("" . $hash_node, 1, length("" . $hash_node) - 1);
            emit($cg, c_var($ref_var));
        } else {
            # %hash{keys} slice — $hash_node is a hash var name.
            # Package-qualified name (`@Pkg::Name::var{...}`) needs a
            # stash lookup; the bare `v_NAME__h` static doesn't exist
            # for cross-package hashes. Surfaced via URI::Escape's
            # `@URI::Escape::escapes{split //, $str}` — without the
            # stash path every slice key resolved to undef, so URL
            # escape returned empty strings and URI->new corrupted
            # every URL down to a single char ("c" from "http://...").
            my str $hname = "" . $hash_node;
            if (index($hname, "::") >= 0) {
                # Split on last `::` to get pkg and short name.
                my int $i_last = -1;
                my int $i_search = 0;
                while ($i_search < length($hname) - 1) {
                    if (substr($hname, $i_search, 2) eq "::") {
                        $i_last = $i_search;
                    }
                    $i_search = $i_search + 1;
                }
                if ($i_last >= 0) {
                    my str $hpkg = substr($hname, 0, $i_last);
                    my str $hshort = substr($hname, $i_last + 2, length($hname) - $i_last - 2);
                    emit($cg, "({ PerlGlob *__hsg = perla_glob_get_or_create(perla_stash_get_or_create(\"" . $hpkg . "\"), \"" . $hshort . "\"); __hsg->slots[PERLA_SLOT_HASH] ? __hsg->slots[PERLA_SLOT_HASH] : strada_new_hash(); })");
                } else {
                    emit($cg, c_var_h($hname));
                }
            } else {
                emit($cg, c_var_h($hname));
            }
        }
        emit($cg, "; StradaValue *__sl = strada_new_array(); StradaArray *__sla = strada_deref_array(__sl); ");
        # `%hash{...}` is the key-value slice form (5.20+): each
        # selected key produces TWO list elements — the key followed
        # by its value. The plain `@hash{...}` form is values only.
        my int $is_kv = 0;
        if (defined($node->{"is_kv_slice"}) && $node->{"is_kv_slice"} == 1) { $is_kv = 1; }
        my int $si = 0;
        while ($si < $nk) {
            my scalar $knode = $keys_list->[$si];
            my int $ktype = $knode->{"type"};
            if ($ktype == Perla::AST::N_QWORD() || $ktype == Perla::AST::N_ANON_ARRAY()) {
                my scalar $elems = $knode->{"elems"};
                my int $ei = 0;
                while ($ei < scalar(@{$elems})) {
                    if ($is_kv == 1) {
                        emit($cg, "{ char *__sk = strada_to_str(");
                        gen_expr($cg, $elems->[$ei]);
                        emit($cg, "); strada_array_push(__sla, strada_new_str(__sk)); strada_array_push(__sla, strada_hv_fetch_owned(__slh, __sk)); free(__sk); } ");
                    } else {
                        emit($cg, "{ char *__sk = strada_to_str(");
                        gen_expr($cg, $elems->[$ei]);
                        emit($cg, "); strada_array_push(__sla, strada_hv_fetch_owned(__slh, __sk)); free(__sk); } ");
                    }
                    $ei++;
                }
            } else {
                # `@hash{EXPR}` — EXPR could be a single scalar key OR
                # a list-returning expression. Eval in list context so
                # map/grep/etc. return their full list, then dispatch
                # on the runtime type.
                emit($cg, "{ int __sav_wl_hs = __perla_want_list; __perla_want_list = 1; StradaValue *__skv = ");
                gen_expr($cg, $knode);
                emit($cg, "; __perla_want_list = __sav_wl_hs; if (__skv && !STRADA_IS_TAGGED_INT(__skv) && __skv->type == STRADA_ARRAY) { ");
                emit($cg, "StradaArray *__skav = strada_deref_array(__skv); ");
                emit($cg, "if (__skav) for (size_t __ski = 0; __ski < __skav->size; __ski++) { ");
                emit($cg, "char *__sk = strada_to_str(__skav->elements[__skav->head + __ski]); ");
                if ($is_kv == 1) {
                    emit($cg, "strada_array_push(__sla, strada_new_str(__sk)); ");
                }
                emit($cg, "strada_array_push(__sla, strada_hv_fetch_owned(__slh, __sk)); free(__sk); } ");
                emit($cg, "} else { char *__sk = strada_to_str(__skv); ");
                if ($is_kv == 1) {
                    emit($cg, "strada_array_push(__sla, strada_new_str(__sk)); ");
                }
                emit($cg, "strada_array_push(__sla, strada_hv_fetch_owned(__slh, __sk)); free(__sk); } } ");
            }
            $si++;
        }
        emit($cg, "__sl; })");
        return;
    }

    # Range operator: from..to. Delegate to perla_range_array which
    # picks numeric vs string range based on operand shape — string
    # ranges (e.g. "a".."e") use Perl's magic-increment semantics.
    if ($type == Perla::AST::N_RANGE()) {
        my int $is3 = 0;
        if (defined($node->{"is_3dot"}) && $node->{"is_3dot"} == 1) { $is3 = 1; }
        # Context-sensitive: list context → range array; scalar context →
        # flip-flop. As a VALUE (e.g. `my $x = /a/../b/`), Perl returns ""
        # while off, the running sequence number (1, 2, …) while on, and
        # "<seq>E0" on the evaluation the end matched. Per-site static state.
        emit($cg, "({ static int __ff_st = 0; static long __ff_sq = 0; StradaValue *__ff_rv; ");
        emit($cg, "if (__perla_want_list) { __ff_rv = perla_range_array(");
        gen_expr($cg, $node->{"from"});
        emit($cg, ", ");
        gen_expr($cg, $node->{"to"});
        emit($cg, "); } else { if (!__ff_st) { if (");
        _gen_cond($cg, $node->{"from"});
        emit($cg, ") { __ff_st = 1; __ff_sq = 1; ");
        if ($is3 == 0) {
            emit($cg, "if (");
            _gen_cond($cg, $node->{"to"});
            emit($cg, ") { __ff_st = 0; __ff_rv = ({ char __b[32]; snprintf(__b, sizeof(__b), \"%ldE0\", __ff_sq); strada_new_str(__b); }); } else { __ff_rv = STRADA_MAKE_TAGGED_INT(__ff_sq); } ");
        } else {
            emit($cg, "__ff_rv = STRADA_MAKE_TAGGED_INT(__ff_sq); ");
        }
        emit($cg, "} else { __ff_rv = strada_new_str(\"\"); } } ");
        emit($cg, "else { __ff_sq++; if (");
        _gen_cond($cg, $node->{"to"});
        emit($cg, ") { __ff_st = 0; __ff_rv = ({ char __b[32]; snprintf(__b, sizeof(__b), \"%ldE0\", __ff_sq); strada_new_str(__b); }); } else { __ff_rv = STRADA_MAKE_TAGGED_INT(__ff_sq); } } } __ff_rv; })");
        return;
    }

    # <$fh> readline
    if ($type == Perla::AST::N_READLINE()) {
        # `<$fh>` in scalar context: one line. In list context: ALL lines.
        # If $/ (perla_irs) is undef, slurp the whole file in scalar
        # context (the `do { local $/; <$fh> }` idiom). Without this,
        # the slurp idiom returned only the first line.
        my str $handle = $node->{"handle"};
        my str $fhref = "NULL";
        # Bare diamond `<>` (lexer emits handle="ARGV"). Reads from
        # @ARGV files in sequence, falling back to STDIN if @ARGV is
        # empty. Use a dedicated runtime helper rather than the generic
        # filehandle reader.
        if ($handle eq "ARGV") {
            emit($cg, "perla_readline_argv(v_ARGV)");
            return;
        }
        if ($handle eq "STDIN") {
            $fhref = "NULL";
        } else {
            # Bareword filehandle vs $-variable filehandle.
            # `<FH>` uses a bareword stored in the package stash (open(FH, ...)
            # calls perla_scalar_set on the stash); `<$fh>` reads a local
            # C variable. Distinguish by initial-uppercase: ALL_CAPS / Tcase
            # is the Perl bareword-filehandle convention, $-prefixed are
            # the var form. Fall back to stash lookup at runtime when
            # the local is not a filehandle, so user code that opens via
            # `open(FH, ...)` and reads via `<FH>` works.
            my str $first_ch = substr($handle, 0, 1);
            if ($first_ch ge "A" && $first_ch le "Z") {
                # Tied-handle dispatch: when FH was set up via
                # `tie *FH, 'Class'`, the IO slot holds a blessed
                # object — call its READLINE. Falls through to the
                # regular stash-FH path when no tied handle is set.
                emit($cg, "({ StradaValue *__th_rl = perla_tied_handle_for_name(\"" . $cg->{"pkg"} . "\", \"" . $handle . "\"); __th_rl ? perla_tied_handle_readline(\"" . $cg->{"pkg"} . "\", \"" . $handle . "\") : ");
                $fhref = "({ StradaValue *__fhbw = perla_scalar_get(\"" . $cg->{"pkg"} . "\", \"" . $handle . "\"); __fhbw; })";
            } else {
                $fhref = c_var($handle);
            }
        }
        # Pick list-context branch only when __perla_want_list is positive.
        # The void marker (-1) is truthy in C, so `__perla_want_list ?
        # list : scalar` incorrectly picked the list branch for void
        # context (e.g. inside `chomp(my $line = <$fh>)` where the outer
        # wraps the whole thing in void context but the inner readline
        # is in scalar context).
        my int $__rl_close_tied = 0;
        if ($handle ne "ARGV" && $handle ne "STDIN") {
            my str $__first_ch = substr($handle, 0, 1);
            if ($__first_ch ge "A" && $__first_ch le "Z") { $__rl_close_tied = 1; }
        }
        emit($cg, "(__perla_want_list > 0 ? perla_read_all_lines_fh(" . $fhref . ") : ");
        # Scalar context: check $/ — undef means slurp; otherwise use the
        # perla helper that preserves the trailing record separator (Perl
        # semantics — `<$fh>` returns "line\n", not "line").
        emit($cg, "((!perla_irs || (!STRADA_IS_TAGGED_INT(perla_irs) && perla_irs->type == STRADA_UNDEF)) ");
        if ($handle eq "STDIN") {
            emit($cg, "? strada_slurp_fh(NULL) : strada_readline()))");
        } else {
            emit($cg, "? strada_slurp_fh(" . $fhref . ") : perla_readline_fh(" . $fhref . ")))");
        }
        if ($__rl_close_tied == 1) {
            emit($cg, "; })");
        }
        return;
    }

    # $#array — last index
    if ($type == Perla::AST::N_SPECIAL_VAR()) {
        my str $val = $node->{"value"};
        if (substr($val, 0, 1) eq "#") {
            my str $arr_name = substr($val, 1, length($val) - 1);
            # $#_ is the last index of @_, not of $_. @_ is perla_at_, a
            # per-sub local; c_var("_") would emit the file-scope `v__`
            # ($_ global) and always read 0/-1. Mo::Inline's default
            # wrapper tests `$#_ ? $m->(@_) : ...` to decide get-vs-set,
            # so a wrong $#_ collapses the dispatch and the accessor
            # returns undef regardless of args.
            if ($arr_name eq "_") {
                emit($cg, "STRADA_MAKE_TAGGED_INT((int64_t)(strada_array_length(strada_deref_array(perla_at_)) - 1))");
                return;
            }
            if (index($arr_name, "::") > 0) {
                my int $lai_li = -1;
                my int $lai_si = 0;
                while ($lai_si < length($arr_name) - 1) {
                    if (substr($arr_name, $lai_si, 2) eq "::") { $lai_li = $lai_si; }
                    $lai_si = $lai_si + 1;
                }
                my str $lai_pkg = substr($arr_name, 0, $lai_li);
                my str $lai_name = substr($arr_name, $lai_li + 2, length($arr_name) - $lai_li - 2);
                # Tied-aware: route through strada_av_fetchsize_sv so
                # `$#arr` calls FETCHSIZE for tied arrays.
                emit($cg, "STRADA_MAKE_TAGGED_INT(strada_av_fetchsize_sv(perla_array_get(\"" . $lai_pkg . "\", \"" . $lai_name . "\")) - 1)");
                return;
            }
            # Tied-aware: route through strada_av_fetchsize_sv so
            # `$#arr` calls FETCHSIZE for tied arrays. Without this,
            # for-loops `for my $i (0..$#arr)` and similar idioms
            # returned 0..-1 (empty) for tied arrays of any size.
            emit($cg, "STRADA_MAKE_TAGGED_INT(strada_av_fetchsize_sv(" . c_var_a($arr_name) . ") - 1)");
            return;
        }
        # Backtick: `command` — interpolate the command string before
        # running, so `$var` / `@arr` / etc. expand the same way they do
        # in double-quoted strings. Without this, `\`echo \$word\`` ran
        # `echo $word` literally (no expansion). In LIST context the
        # output is split on \$/ (newline by default) and each line
        # keeps its trailing separator, matching Perl's
        # \`my @lines = \\\`cmd\\\`\` idiom.
        if (substr($val, 0, 9) eq "backtick:") {
            my str $cmd_raw = substr($val, 9, length($val) - 9);
            emit($cg, "({ StradaValue *__qxs = ");
            Perla::CodeGen::Interp::gen_interp_str($cg, $cmd_raw);
            emit($cg, "; StradaValue *__qxr = strada_qx(__qxs); strada_decref(__qxs); ");
            # Mirror the pclose wait status into perla's `$?` so subsequent
            # `$? >> 8` reads the child's exit code. Without this, qx() on
            # `false` left $? = 0 — code that gated retries on the qx exit
            # silently treated every failure as success.
            emit($cg, "perla_dollar_question = strada_last_qx_status; ");
            emit($cg, "if (__perla_want_list && __qxr && !STRADA_IS_TAGGED_INT(__qxr) && __qxr->type == STRADA_STR && __qxr->value.pv) { ");
            emit($cg, "  size_t __qxl = strada_str_len(__qxr); const char *__qxd = __qxr->value.pv; ");
            emit($cg, "  StradaValue *__qx_arr = strada_new_array(); StradaArray *__qx_av = strada_deref_array(__qx_arr); ");
            emit($cg, "  size_t __qx_start = 0; for (size_t __qx_i = 0; __qx_i < __qxl; __qx_i++) { ");
            emit($cg, "    if (__qxd[__qx_i] == '\\n') { strada_array_push_take(__qx_av, strada_new_str_len(__qxd + __qx_start, __qx_i - __qx_start + 1)); __qx_start = __qx_i + 1; } ");
            emit($cg, "  } ");
            emit($cg, "  if (__qx_start < __qxl) strada_array_push_take(__qx_av, strada_new_str_len(__qxd + __qx_start, __qxl - __qx_start)); ");
            emit($cg, "  strada_decref(__qxr); __qxr = __qx_arr; ");
            emit($cg, "} __qxr; })");
            return;
        }
        # do "file" — slurp file and eval its contents. The eval runs
        # in the current package; lexical scope behaves like eval STRING.
        if (substr($val, 0, 8) eq "do_file:") {
            my str $filename = Perla::CodeGen::Escape::escape_c_str(substr($val, 8, length($val) - 8));
            emit($cg, "({ StradaValue *__df_src = strada_slurp(\"" . $filename . "\"); ");
            emit($cg, "StradaValue *__df_r = (__df_src && !STRADA_IS_TAGGED_INT(__df_src) && __df_src->type == STRADA_STR) ? perla_eval_string_with_args(__df_src, \"" . $cg->{"pkg"} . "\", perla_at_) : strada_new_undef(); ");
            emit($cg, "if (__df_src) strada_decref(__df_src); __df_r; })");
            return;
        }
        emit($cg, "strada_new_undef()");
        return;
    }
    # `do $expr` / `do { }` — filename evaluated at runtime, then slurp+eval.
    if ($type == Perla::AST::N_DO_FILE_EXPR()) {
        emit($cg, "({ char *__dfp = strada_to_str(");
        gen_expr($cg, $node->{"path"});
        emit($cg, "); StradaValue *__df_src = __dfp ? strada_slurp(__dfp) : NULL; free(__dfp); ");
        emit($cg, "StradaValue *__df_r = (__df_src && !STRADA_IS_TAGGED_INT(__df_src) && __df_src->type == STRADA_STR) ? perla_eval_string_with_args(__df_src, \"" . $cg->{"pkg"} . "\", perla_at_) : strada_new_undef(); ");
        emit($cg, "if (__df_src) strada_decref(__df_src); __df_r; })");
        return;
    }

    # Fallback
    # Anonymous sub: sub { ... }
    if ($type == Perla::AST::N_SUB() && !defined($node->{"name"})) {
        $cg->{"tmp_count"} = $cg->{"tmp_count"} + 1;
        my str $anon_name = "__perla_anon_" . $cg->{"tmp_count"};
        $node->{"name"} = $anon_name;
        $node->{"package"} = $cg->{"pkg"};
        my str $fname = sub_cname_q($cg->{"pkg"} . "::" . $anon_name);

        # Scan body for free variables (outer captures)
        my scalar $captures = Perla::CodeGen::FreeVars::find_free_vars($cg, $node);
        # Scan body for `state $X` declarations. Each anon sub instance
        # gets per-closure pad slots for these (mirrors perl's CV pad).
        # State vars are appended to the captures list with a synthetic
        # `__state_` prefix so the body's macro mapping (`#define v_X
        # (*captures[K])`) treats them like outer captures — but they
        # don't come from outer scope, they're allocated fresh per
        # closure instance and start NULL.
        my array @state_vars = Perla::CodeGen::FreeVars::find_state_vars($node);
        my int $nstate = scalar(@state_vars);
        # Bypass per-closure state allocation when this anon sub is
        # being emitted as a SHARED function body (e.g. named sub
        # promoted via gen_sub_def). The static fallback is correct in
        # those cases since there's only one body, not many closures.
        # Detect by absence of $cg->{"anon_subs"} push later (no shape
        # difference for now; just always allocate for anon).
        # Mark state vars on the node for body codegen.
        $node->{"state_vars"} = \@state_vars;
        # Push state-var names to captures so the body's #define maps
        # v_NAME to *captures[K]. Use the bare name; collision with a
        # same-name outer free var is impossible because state vars
        # are sub-local and scan_declared already marks them as
        # declared (so they don't appear as free vars).
        my int $svi = 0;
        while ($svi < $nstate) {
            push(@{$captures}, $state_vars[$svi]);
            $svi = $svi + 1;
        }
        my int $ncaps = scalar(@{$captures});

        if ($ncaps > 0) {
            # Store capture info on the node for gen_sub_def
            $node->{"captures"} = $captures;
            push(@{$cg->{"anon_subs"}}, $node);
            # Build closure struct manually — captures are shared mutable cells
            # Track shared cells: if a variable was already captured in this scope,
            # reuse the same cell (enables two closures to share a mutable variable)
            if (!defined($cg->{"shared_cells"})) { $cg->{"shared_cells"} = {}; }
            # Shared capture cells via global __perla_cell[] array
            if (!defined($cg->{"shared_cells"})) { $cg->{"shared_cells"} = {}; }
            if (!defined($cg->{"cell_idx"})) { $cg->{"cell_idx"} = 0; }
            my int $ci = 0;
            my array @cell_indices = ();
            # State var names start at index ($ncaps - $nstate) — these
            # are per-closure pad slots, never shared via shared_cells.
            my int $state_start = $ncaps - $nstate;
            while ($ci < $ncaps) {
                my str $varname = $captures->[$ci];
                # State-var slot: always allocate a fresh cell index;
                # don't reuse a sibling closure's cell.
                if ($ci >= $state_start) {
                    my int $idx = $cg->{"cell_idx"};
                    $cg->{"cell_idx"} = $idx + 1;
                    push(@cell_indices, $idx);
                } elsif (defined($cg->{"shared_cells"}->{$varname})) {
                    push(@cell_indices, $cg->{"shared_cells"}->{$varname});
                } else {
                    my int $idx = $cg->{"cell_idx"};
                    $cg->{"cell_idx"} = $idx + 1;
                    $cg->{"shared_cells"}->{$varname} = $idx;
                    push(@cell_indices, $idx);
                }
                $ci++;
            }
            emit($cg, "({ ");
            # Allocate a FRESH cell per closure creation. The previous
            # implementation cached cells in a file-scope `__perla_cell[N]`
            # array keyed by variable name, which silently broke closures
            # created by the same sub more than once:
            #
            #   sub make_adder { my $n = shift; return sub { $_[0] + $n }; }
            #   my $add5  = make_adder(5);   # allocates cell[0], stores 5
            #   my $add10 = make_adder(10);  # cell[0] exists, SKIP  — bug
            #   $add5->(3)  == 8   ✓
            #   $add10->(3) == 8   ✗ (should be 13)
            #
            # A fresh per-invocation cell fixes this. For the pattern that
            # actually needs sharing ("two closures in the same enclosing
            # scope touching the same $var"), both closures are created
            # from the SAME invocation of the enclosing sub, and codegen
            # emits two separate closure expressions — each would allocate
            # its own cell. Real sharing (mutation visible across calls)
            # requires a different mechanism; the old guard didn't deliver
            # that either, it just lost state.
            $ci = 0;
            if (!defined($cg->{"shared_cells_emitted"})) { $cg->{"shared_cells_emitted"} = {}; }
            while ($ci < $ncaps) {
                my str $varname = $captures->[$ci];
                # Find the captured var's sigil in the enclosing-sub
                # my_lexicals so the cell init uses the right C name
                # (`v_q` vs `v_q__a` vs `v_q__h` per collision-mangling).
                # `my @q` / `my %h` capture targets would otherwise read
                # the wrong slot via plain `_c_var`.
                my str $__cap_sigil = "\$";
                if (defined($cg->{"my_lexicals"})) {
                    my scalar $__mxs = $cg->{"my_lexicals"};
                    my int $__mxi = 0;
                    while ($__mxi < scalar(@{$__mxs})) {
                        my scalar $__mxe = $__mxs->[$__mxi];
                        if (defined($__mxe) && defined($__mxe->{"name"})
                            && $__mxe->{"name"} eq $varname
                            && defined($__mxe->{"sigil"})) {
                            $__cap_sigil = $__mxe->{"sigil"};
                        }
                        $__mxi = $__mxi + 1;
                    }
                }
                my str $vn = c_var($varname);
                if ($__cap_sigil eq "@") { $vn = c_var_a($varname); }
                elsif ($__cap_sigil eq "%") { $vn = c_var_h($varname); }
                my int $cidx = $cell_indices[$ci];
                # State-var pad slot (per-closure-instance): always
                # allocate a fresh refcount cell, init slot = NULL.
                # Body lazily initializes via `if (!*cell) { *cell =
                # INIT; }` on first execution. Each closure instance
                # gets its own cell so sibling closures don't share.
                if ($ci >= $state_start) {
                    emit($cg, "__perla_cell[" . $cidx . "] = strada_cell_alloc(); ");
                    emit($cg, "*__perla_cell[" . $cidx . "] = NULL; ");
                    $ci++;
                    next;
                }
                # Only allocate the cell the FIRST time this varname is
                # captured in this scope. Subsequent closures in the same
                # scope must REUSE the existing cell so they share state.
                # Without this, `sub make { my $n=5; return { get=>sub{$n},
                # inc=>sub{++$n} } }` had each closure point to its OWN
                # malloc'd cell — `inc->()` incremented one cell while
                # `get->()` read another, both reporting 5 forever.
                if (!defined($cg->{"shared_cells_emitted"}->{$varname})) {
                    # If the captured var is file-scope (i.e., a STATIC C
                    # global), the cell can point at &v_NAME directly so
                    # the closure shares storage with the outer scope.
                    # Writes inside the closure are immediately visible
                    # outside, and vice versa. For sub-local lexicals we
                    # still malloc a fresh slot since the C local goes
                    # out of scope. Exception: if the same name is also in
                    # my_lexicals (e.g. `for my $X` iter var inside a
                    # function that has a top-level `my $X`), the LOCAL
                    # shadow is the one we want to capture per-iteration —
                    # using &v_X (the static) would tie every closure to
                    # the same address, so they'd all see the LAST iter's
                    # value. Treat as non-file-scope when shadowed.
                    # Detect "foreach-iter-var shadow" case: a my_lexicals
                    # entry tagged from_foreach=1 means an enclosing
                    # `for my $X` push is active, and we want each iter
                    # to have its own cell (not the shared file-scope
                    # slot). Plain top-level `my $X; sub { ... $X ... }`
                    # is NOT tagged, so the static-share path keeps
                    # working ($X++ in main is visible inside closure).
                    my int $__cap_shadowed_by_foreach = 0;
                    if (defined($cg->{"my_lexicals"})) {
                        my scalar $__lcl_mxs = $cg->{"my_lexicals"};
                        my int $__lcl_mxi = 0;
                        while ($__lcl_mxi < scalar(@{$__lcl_mxs})) {
                            my scalar $__lcl_e = $__lcl_mxs->[$__lcl_mxi];
                            if (defined($__lcl_e) && defined($__lcl_e->{"name"})
                                && $__lcl_e->{"name"} eq $varname
                                && defined($__lcl_e->{"from_foreach"})
                                && $__lcl_e->{"from_foreach"} == 1) {
                                $__cap_shadowed_by_foreach = 1;
                                last;
                            }
                            $__lcl_mxi = $__lcl_mxi + 1;
                        }
                    }
                    # `state $X` is a sub-scope C-static — closures
                    # returned from the sub must capture &v_X (share the
                    # static) so all invocations see the same cell.
                    # Without this, each call to make_counter() with a
                    # `state $n = 0; return sub { $n++ }` would malloc a
                    # fresh cell pre-seeded with v_n's current value,
                    # and the two closures wouldn't share state.
                    my int $__cap_is_state = 0;
                    if (defined($cg->{"state_vars"})
                        && exists($cg->{"state_vars"}->{$varname})) {
                        $__cap_is_state = 1;
                    }
                    if (($__cap_is_state == 1)
                        || (_is_file_scope($cg, $varname) == 1 && $__cap_shadowed_by_foreach == 0)) {
                        emit($cg, "__perla_cell[" . $cidx . "] = &" . $vn . "; ");
                        if (!defined($cg->{"cells_malloc_d"})) { $cg->{"cells_malloc_d"} = {}; }
                        $cg->{"cells_malloc_d"}->{$varname} = 0;
                    } else {
                        # Refcounted heap cell — strada_cell_alloc() returns a
                        # slot pointer with header refcount=1. Subsequent
                        # closures in this scope that capture the same var
                        # incref the cell so the LAST one freed releases the
                        # captured value. Without refcounting, both closures'
                        # free paths would decref the cell+value, double-free.
                        #
                        # RUNTIME alloc-vs-incref: the "first capture" is a
                        # COMPILE-TIME notion (source order), but at runtime a
                        # closure may sit inside a conditional (`... sub {$x}
                        # if EXPR`) so the textually-first closure's alloc may
                        # not execute while a later sibling's incref does. And
                        # __perla_cell[N] persists across foreach iterations.
                        # So key the decision on whether the slot already holds
                        # THIS scope's current value: if empty or stale (a new
                        # iteration's value), alloc fresh; else incref to share.
                        # Fixes Moose::Meta::Role's `add_method(..., sub{$reader})
                        # if exists $methods{KEY}` cascade (cell double-free).
                        emit($cg, "if (!__perla_cell[" . $cidx . "] || *__perla_cell[" . $cidx . "] != " . $vn . ") { ");
                        emit($cg, "__perla_cell[" . $cidx . "] = strada_cell_alloc(); ");
                        emit($cg, "*__perla_cell[" . $cidx . "] = " . $vn . "; ");
                        emit($cg, "if (" . $vn . ") strada_incref(" . $vn . "); ");
                        emit($cg, "} else { strada_cell_incref(__perla_cell[" . $cidx . "]); } ");
                        if (!defined($cg->{"cells_malloc_d"})) { $cg->{"cells_malloc_d"} = {}; }
                        $cg->{"cells_malloc_d"}->{$varname} = 1;
                    }
                    $cg->{"shared_cells_emitted"}->{$varname} = 1;
                    # Track this cell so assignments to the captured var in
                    # the surrounding scope can mirror the new value back
                    # into the cell. Required for self-reference patterns
                    # `\$f = sub { ... \$f->(...) }` — the closure captured
                    # the pre-assignment v_f (undef), so without a mirror
                    # the closure body sees undef.
                    if (!defined($cg->{"closure_cell_mirror"})) {
                        $cg->{"closure_cell_mirror"} = {};
                    }
                    $cg->{"closure_cell_mirror"}->{$varname} = $cidx;
                } else {
                    # Another closure in this scope already allocated the cell.
                    # If it was a heap (refcounted) cell, this closure shares
                    # ownership — incref so both closures' free paths balance.
                    # Static cells (file-scope &v_x) are not refcounted.
                    if (defined($cg->{"cells_malloc_d"})
                        && defined($cg->{"cells_malloc_d"}->{$varname})
                        && $cg->{"cells_malloc_d"}->{$varname} == 1) {
                        # Same runtime alloc-vs-incref as the first-capture path:
                        # this "reuse" closure may actually be the first to run
                        # (the textual first sits in an un-taken conditional), or
                        # a new foreach iteration may have left __perla_cell[N]
                        # holding a stale prior-iteration cell. Alloc fresh when
                        # the slot is empty/stale; else incref to share.
                        emit($cg, "if (!__perla_cell[" . $cidx . "] || *__perla_cell[" . $cidx . "] != " . $vn . ") { __perla_cell[" . $cidx . "] = strada_cell_alloc(); *__perla_cell[" . $cidx . "] = " . $vn . "; if (" . $vn . ") strada_incref(" . $vn . "); } else { strada_cell_incref(__perla_cell[" . $cidx . "]); } ");
                    }
                }
                $ci++;
            }
            # Build closure with shared cells.
            # calloc zeros the prototype pointer (and any future fields).
            # Without this, `cl->prototype` was uninitialised — strada_free_value
            # later read it in `if (cl->prototype) free(cl->prototype);` and
            # passed garbage to free() on every closure teardown when the codegen
            # didn't explicitly emit a `strada_closure_set_prototype` call.
            # Surfaced via valgrind on `t/87_*` as a "Conditional jump or move
            # depends on uninitialised value(s) at strada_free_value".
            emit($cg, "StradaClosure *__cl = calloc(1, sizeof(StradaClosure)); ");
            emit($cg, "__cl->func_ptr = (void*)" . $fname . "; ");
            emit($cg, "__cl->param_count = 1; ");
            emit($cg, "__cl->capture_count = " . $ncaps . "; ");
            emit($cg, "__cl->captures = malloc(" . $ncaps . " * sizeof(StradaValue**)); ");
            # Per-capture is_static flag — matches the cell-init choice above.
            # A capture is "static" only when the name is file-scope AND NOT
            # shadowed by a my_lexicals entry (an enclosing `for my $X` /
            # `my $X` that takes precedence). The init above mallocs when
            # shadowed; this must match or free() will crash.
            my array @__is_static_caps = ();
            my int $any_static = 0;
            $ci = 0;
            while ($ci < $ncaps) {
                my str $__c_vn = $captures->[$ci];
                my int $__c_shadowed_by_foreach = 0;
                if (defined($cg->{"my_lexicals"})) {
                    my scalar $__c_mxs = $cg->{"my_lexicals"};
                    my int $__c_mxi = 0;
                    while ($__c_mxi < scalar(@{$__c_mxs})) {
                        my scalar $__c_e = $__c_mxs->[$__c_mxi];
                        if (defined($__c_e) && defined($__c_e->{"name"})
                            && $__c_e->{"name"} eq $__c_vn
                            && defined($__c_e->{"from_foreach"})
                            && $__c_e->{"from_foreach"} == 1) {
                            $__c_shadowed_by_foreach = 1;
                            last;
                        }
                        $__c_mxi = $__c_mxi + 1;
                    }
                }
                my int $__c_static = 0;
                # Mark file-scope statics AND sub-scope state vars so
                # cell free-path skips free() — both point at static
                # storage rather than malloc'd cells.
                # EXCEPTION: state vars added at $state_start..$ncaps
                # range are the per-closure-pad state slots (NOT shared
                # with an outer-scope C static). They're malloc'd via
                # strada_cell_alloc and must be freed via strada_cell_decref
                # at closure teardown — so leave is_static = 0.
                if ($ci < $state_start) {
                    if (_is_file_scope($cg, $__c_vn) == 1 && $__c_shadowed_by_foreach == 0) {
                        $__c_static = 1;
                        $any_static = 1;
                    }
                    if (defined($cg->{"state_vars"}) && exists($cg->{"state_vars"}->{$__c_vn})) {
                        $__c_static = 1;
                        $any_static = 1;
                    }
                }
                push(@__is_static_caps, $__c_static);
                $ci++;
            }
            $ci = 0;
            while ($ci < $ncaps) {
                emit($cg, "__cl->captures[" . $ci . "] = __perla_cell[" . $cell_indices[$ci] . "]; ");
                $ci++;
            }
            # Mark file-scope captures so strada_free_value() skips free() on
            # cells that point at static C globals (`&v_file_scope_my`). Without
            # this, dropping the last ref to such a closure crashes with
            # `free(): invalid pointer`.
            if ($any_static == 1) {
                emit($cg, "__cl->capture_is_static = calloc(" . $ncaps . ", 1); ");
                $ci = 0;
                while ($ci < $ncaps) {
                    if ($__is_static_caps[$ci] == 1) {
                        emit($cg, "__cl->capture_is_static[" . $ci . "] = 1; ");
                    }
                    $ci++;
                }
            } else {
                emit($cg, "__cl->capture_is_static = NULL; ");
            }
            emit($cg, "StradaValue *__csv = strada_new_undef(); ");
            emit($cg, "__csv->type = STRADA_CLOSURE; __csv->value.ptr = __cl; ");
            # If the anon sub has a declared prototype, propagate it to
            # the closure so prototype(\\&anon) finds it later.
            if (defined($node->{"prototype"})) {
                my str $proto = "" . $node->{"prototype"};
                my str $proto_esc = Perla::CodeGen::Escape::escape_c_str($proto);
                emit($cg, "strada_closure_set_prototype(__csv, \"" . $proto_esc . "\"); ");
            } elsif (defined($node->{"empty_proto"}) && $node->{"empty_proto"} == 1) {
                emit($cg, "strada_closure_set_prototype(__csv, \"\"); ");
            }
            emit($cg, "__csv; })");
        } else {
            push(@{$cg->{"anon_subs"}}, $node);
            # When the anon sub has a declared prototype (`sub ($) {...}`
            # or `sub () {...}`), wrap it as a STRADA_CLOSURE with a
            # zero-capture cl struct so the prototype string can be
            # stashed on it for prototype(\\&anon) lookups. The plain
            # CPOINTER path has no place to hold the prototype.
            my int $has_proto = 0;
            my str $proto_for_anon = "";
            if (defined($node->{"prototype"})) {
                $has_proto = 1;
                $proto_for_anon = "" . $node->{"prototype"};
            } elsif (defined($node->{"empty_proto"}) && $node->{"empty_proto"} == 1) {
                $has_proto = 1;
                $proto_for_anon = "";
            }
            if ($has_proto == 1) {
                my str $proto_esc = Perla::CodeGen::Escape::escape_c_str($proto_for_anon);
                emit($cg, "({ StradaValue *__csv = strada_closure_new((void*)" . $fname . ", 0, 0, NULL); ");
                emit($cg, "strada_closure_set_prototype(__csv, \"" . $proto_esc . "\"); __csv; })");
            } else {
                emit($cg, "strada_cpointer_new((void*)" . $fname . ")");
            }
        }
        return;
    }

    # N_OUR in expression context: `our $X` as a value/lvalue — the `=~`
    # subject in `( our $AUTOLOAD =~ /::(\w+)$/ )` (Type::Tiny AUTOLOAD).
    # gen_expr had no N_OUR case, so it fell through to the default
    # `strada_new_undef() /* TODO node type N */` and the match subject was
    # empty. A scalar `our $X` is backed by the v_X file-scope static, so
    # yield it: no-init keeps the existing global value (our re-aliases, it
    # does NOT reset); with-init assigns then yields. (Statement-position
    # `our` still goes through gen_stmt -> _gen_our for glob/stash sync.)
    if ($type == Perla::AST::N_OUR()) {
        if (defined($node->{"var"})
            && (length("" . $node->{"var"}->{"type"}) == 0 || ("" . $node->{"var"}->{"type"}) eq "SCALAR_VAR")) {
            my str $o_vname = $node->{"var"}->{"value"};
            my str $o_cvar = c_var_for_vtype("SCALAR_VAR", $o_vname);
            # Register only in declared_vars (for strict 'vars'); do NOT add to
            # our_vars — the undeclared-v_* auto-declare post-pass EXCLUDES
            # our_vars names (assumes they're declared elsewhere), so a
            # first-mention inline `our $X` here would then never get its
            # `static StradaValue *v_X = NULL;` emitted (v_X undeclared at cc).
            if (defined($cg->{"declared_vars"})) { $cg->{"declared_vars"}->{$o_cvar} = 1; }
            if (defined($node->{"init"}) && $node->{"init"}->{"type"} != Perla::AST::N_OUR()) {
                emit($cg, "(" . $o_cvar . " = ");
                gen_expr($cg, $node->{"init"});
                emit($cg, ")");
            } else {
                emit($cg, $o_cvar);
            }
            return;
        }
        emit($cg, "strada_new_undef()");
        return;
    }
    # N_MY in expression context: (my $x = expr) — declare and return value.
    # Two AST shapes: single-var (node->var) and destructuring (node->vars).
    # Perl idiom `(my $x = $src) =~ s/a/b/g;` expects the declared scalar to
    # be the lvalue for the subsequent op, so emit an lvalue-returning form.
    if ($type == Perla::AST::N_MY()) {
        # Destructuring form: `my ($a, $b, ...) = LIST`. Without a special
        # case here, the if-cond `if (my (\$a, \$b) = LIST)` always
        # short-circuited to false because the fallback `gen_expr(N_MY)`
        # returned `strada_new_undef()`. Plus, calling `_gen_stmt` inside
        # the statement expression emits fresh `StradaValue *v_X = NULL;`
        # locals that shadow the auto-declared file-scope statics — the
        # if-body then reads the still-null statics.
        #
        # Emit the assignment WITHOUT re-declaring locals: evaluate the
        # init in list context, slice elements into the auto-declared
        # static v_X vars by position, then return a non-empty marker
        # (the count of elements written, so an empty match-list resolves
        # to falsy and the if-body is skipped).
        if (!defined($node->{"var"}) && defined($node->{"vars"})
            && scalar(@{$node->{"vars"}}) >= 1) {
            my scalar $vars_list = $node->{"vars"};
            my int $nv_e = scalar(@{$vars_list});
            emit($cg, "({ int __sav_wl_destr = __perla_want_list; __perla_want_list = 1; StradaValue *__destr_sv = ");
            if (defined($node->{"init"})) {
                gen_expr($cg, $node->{"init"});
            } else {
                emit($cg, "strada_new_undef()");
            }
            emit($cg, "; __perla_want_list = __sav_wl_destr; StradaArray *__destr_av = strada_deref_array(__destr_sv); ");
            # If the init wasn't an array (e.g. `my (\$x) = (10)` parses to
            # init=int literal 10), wrap it in a one-element array so the
            # destructure path treats it as a single-elem list.
            emit($cg, "StradaValue *__destr_wrap = NULL; if (!__destr_av && __destr_sv) { __destr_wrap = strada_new_array(); strada_incref(__destr_sv); strada_array_push_take(strada_deref_array(__destr_wrap), __destr_sv); __destr_av = strada_deref_array(__destr_wrap); } ");
            emit($cg, "int __destr_n = __destr_av ? (int)strada_array_length(__destr_av) : 0; ");
            my int $vli = 0;
            while ($vli < $nv_e) {
                my scalar $vli_node = $vars_list->[$vli];
                my str $vli_name = $vli_node->{"value"};
                my str $vli_type = "" . $vli_node->{"type"};
                if (length($vli_type) == 0) { $vli_type = "SCALAR_VAR"; }
                my str $vli_cvar = c_var_for_vtype($vli_type, $vli_name);
                # Register the destructured `my ($a, $b, ...)` names in
                # declared_vars so strict 'vars' sees them on later reads.
                if (defined($cg->{"declared_vars"})) {
                    $cg->{"declared_vars"}->{$vli_cvar} = 1;
                }
                # use-warnings: "my X masks earlier declaration" — fire when
                # this name was already declared in the current scope.
                if (defined($cg->{"same_scope_decls"})
                    && defined($cg->{"same_scope_decls"}->{$vli_cvar})
                    && defined($cg->{"use_warnings"}) && $cg->{"use_warnings"} == 1) {
                    my str $__mm_s = "\$";
                    if ($vli_type eq "ARRAY_VAR") { $__mm_s = "@"; }
                    elsif ($vli_type eq "HASH_VAR") { $__mm_s = "%"; }
                    my int $__mm_l = 0;
                    if (defined($cg->{"current_my_line"}) && $cg->{"current_my_line"} > 0) {
                        $__mm_l = $cg->{"current_my_line"} + 0;
                    } elsif (defined($node->{"line"})) {
                        $__mm_l = $node->{"line"} + 0;
                    }
                    my str $__mm_f = "" . $cg->{"filename"};
                    if (length($__mm_f) == 0) { $__mm_f = "-"; }
                    say(STDERR, "\"my\" variable " . $__mm_s . $vli_name . " masks earlier declaration in same scope at " . $__mm_f . " line " . $__mm_l . ".");
                }
                if (defined($cg->{"same_scope_decls"})) {
                    $cg->{"same_scope_decls"}->{$vli_cvar} = 1;
                }
                emit($cg, "if (" . $vli_cvar . ") strada_decref(" . $vli_cvar . "); ");
                emit($cg, $vli_cvar . " = (__destr_n > " . $vli . ") ? ({ StradaValue *__el = strada_array_get(__destr_av, " . $vli . "); if (__el) strada_incref(__el); __el; }) : strada_new_undef(); ");
                $vli++;
            }
            # The yield depends on the CALLER's context (__sav_wl_destr — the
            # want_list captured BEFORE we forced list for the RHS):
            #   * list context (==1): Perl's list-assignment returns the LHS
            #     lvalue list (the just-assigned vars). Needed for
            #     `(my ($num) = grep {...} @args)[0]` (Sub::Exporter::Progressive's
            #     installed import closure) and `my @x = (my ($n) = ...)`.
            #     Previously this yielded the element COUNT, so the slice
            #     `(...)[0]` saw `(count)[0]` — e.g. empty list → count 0 →
            #     `defined(0)` true → spurious "leading digit" croak that
            #     blocked Drogo::Dispatch → Abe::App in e.pl.
            #   * scalar/void: the element count, the truthy/falsy marker for
            #     `if (my ($a,$b)=...)` / `while (my ($k,$v)=each %h)`.
            emit($cg, "StradaValue *__destr_yield; ");
            emit($cg, "if (__sav_wl_destr == 1) { __destr_yield = strada_new_array(); StradaArray *__destr_yav = strada_deref_array(__destr_yield); ");
            my int $vyi = 0;
            while ($vyi < $nv_e) {
                my scalar $vy_node = $vars_list->[$vyi];
                my str $vy_name = $vy_node->{"value"};
                my str $vy_type = "" . $vy_node->{"type"};
                if (length($vy_type) == 0) { $vy_type = "SCALAR_VAR"; }
                my str $vy_cvar = c_var_for_vtype($vy_type, $vy_name);
                emit($cg, "if (" . $vy_cvar . ") { strada_incref(" . $vy_cvar . "); strada_array_push_take(__destr_yav, " . $vy_cvar . "); } else { strada_array_push_take(__destr_yav, strada_new_undef()); } ");
                $vyi++;
            }
            emit($cg, "} else { __destr_yield = STRADA_MAKE_TAGGED_INT((int64_t)__destr_n); } ");
            emit($cg, "if (__destr_wrap) strada_decref(__destr_wrap); __destr_yield; })");
            return;
        }
        my scalar $single_var = undef;
        my scalar $single_init = undef;
        if (defined($node->{"var"})) {
            $single_var = $node->{"var"};
            $single_init = $node->{"init"};
        } elsif (defined($node->{"vars"}) && scalar(@{$node->{"vars"}}) > 0) {
            my scalar $v0 = $node->{"vars"}->[0];
            if (defined($v0->{"var"})) {
                $single_var = $v0->{"var"};
                $single_init = $v0->{"init"};
            } else {
                # Single-element `my ($x) = ...` — $vars->[0] is the var
                # node itself, not a wrapper. Use it directly.
                $single_var = $v0;
                $single_init = $node->{"init"};
            }
        }
        if (defined($single_var) && length($single_var->{"value"}) > 0) {
            my str $vname = $single_var->{"value"};
            my str $svt = "" . $single_var->{"type"};
            if (length($svt) == 0) { $svt = "SCALAR_VAR"; }
            my str $cvar = c_var_for_vtype($svt, $vname);
            # Register the inline `my $X` in declared_vars so subsequent
            # reads under strict 'vars' see the declaration. Required for
            # idioms like `pipe(my $rfh, my $wfh); read $rfh, ...;` where
            # the my-decl is buried inside a function call arg list.
            # Also fire use-warnings "my X masks earlier declaration" here
            # — the inline-expression form bypasses _my_prefix_vt entirely.
            if (defined($cg->{"same_scope_decls"})
                && defined($cg->{"same_scope_decls"}->{$cvar})
                && defined($cg->{"use_warnings"}) && $cg->{"use_warnings"} == 1) {
                my str $__mm_s = "\$";
                if ($svt eq "ARRAY_VAR") { $__mm_s = "@"; }
                elsif ($svt eq "HASH_VAR") { $__mm_s = "%"; }
                my int $__mm_l = 0;
                if (defined($cg->{"current_my_line"}) && $cg->{"current_my_line"} > 0) {
                    $__mm_l = $cg->{"current_my_line"} + 0;
                } elsif (defined($node->{"line"})) {
                    $__mm_l = $node->{"line"} + 0;
                }
                my str $__mm_f = "" . $cg->{"filename"};
                if (length($__mm_f) == 0) { $__mm_f = "-"; }
                say(STDERR, "\"my\" variable " . $__mm_s . $vname . " masks earlier declaration in same scope at " . $__mm_f . " line " . $__mm_l . ".");
            }
            if (defined($cg->{"same_scope_decls"})) {
                $cg->{"same_scope_decls"}->{$cvar} = 1;
            }
            if (defined($cg->{"declared_vars"})) {
                $cg->{"declared_vars"}->{$cvar} = 1;
            }
            # Emit `(v_NAME = EXPR)` without a local redeclaration. The
            # auto-declare post-pass will emit `static StradaValue *v_NAME = NULL;`
            # at file scope. Previously we emitted
            # `({ StradaValue *v_NAME = EXPR; v_NAME; })` which declared a
            # new local inside a statement expression — that shadowed the
            # auto-declared static only within the `({ })`. A user
            # expression like `if (my @x = EXPR) { ...uses @x... }` then
            # referenced the NULL file-scope copy inside the if body
            # instead of the just-assigned local value.
            # For array/hash targets, force LIST context around the RHS
            # so `if (my @x = (1,2,3))` evaluates (1,2,3) as a list, not
            # as the comma-operator's scalar-context last-value.
            my int $force_list = 0;
            if ($svt eq "ARRAY_VAR" || $svt eq "HASH_VAR") { $force_list = 1; }
            if ($force_list == 1) {
                emit($cg, "({ int __sav_wl_my_e = __perla_want_list; __perla_want_list = 1; StradaValue *__my_r = (" . $cvar . " = ");
                if (defined($single_init)) {
                    gen_expr($cg, $single_init);
                } elsif ($svt eq "HASH_VAR") {
                    # Uninitialised expression-context `my %h` (e.g. `\my %h`)
                    # must create an empty HASH, not a scalar undef — else
                    # `ref(\my %h)` is SCALAR and the ref is unusable.
                    emit($cg, "strada_new_hash()");
                } else {
                    # Uninitialised expression-context `my @a` → empty ARRAY.
                    emit($cg, "strada_new_array()");
                }
                emit($cg, "); __perla_want_list = __sav_wl_my_e; __my_r; })");
            } else {
                emit($cg, "(" . $cvar . " = ");
                if (defined($single_init)) {
                    gen_expr($cg, $single_init);
                } else {
                    emit($cg, "strada_new_undef()");
                }
                emit($cg, ")");
            }
        } else {
            emit($cg, "strada_new_undef()");
        }
        return;
    }

    # Postfix for in expression context: execute loop, return undef.
    # List context for the iterator expression — same fix as the
    # statement-level path.
    if ($type == Perla::AST::N_POSTFIX_FOR()) {
        emit($cg, "({ int __sav_wl_pf = __perla_want_list; __perla_want_list = 1; StradaValue *__pf_list = ");
        gen_expr($cg, $node->{"list"});
        emit($cg, "; __perla_want_list = __sav_wl_pf; StradaArray *__pf_av = strada_deref_array(__pf_list); ");
        emit($cg, "int __pf_len = __pf_av ? strada_array_length(__pf_av) : 0; ");
        emit($cg, "StradaValue *__pf_prev_du = perla_dollar_underscore; ");
        emit($cg, "for (int __pf_i = 0; __pf_i < __pf_len; __pf_i++) { ");
        emit($cg, "perla_dollar_underscore = strada_array_get(__pf_av, __pf_i); ");
        emit($cg, "StradaValue *__orig_pf_du = perla_dollar_underscore; ");
        gen_expr($cg, $node->{"expr"});
        emit($cg, "; if (perla_dollar_underscore != __orig_pf_du) { strada_incref(perla_dollar_underscore); strada_array_set(__pf_av, __pf_i, perla_dollar_underscore); }");
        emit($cg, " } perla_dollar_underscore = __pf_prev_du; (StradaValue*)NULL; })");
        return;
    }

    # N_ASSIGN in expression context — emit without decref wrapper
    if ($type == Perla::AST::N_ASSIGN() && $node->{"op"} eq "=") {
        my scalar $target = $node->{"target"};
        my int $target_type = $target->{"type"};
        if ($target_type == Perla::AST::N_SCALAR_VAR()) {
            # Tied-scalar dispatch: when v_x is a tied SV, the
            # straight `v_x = new_value` would replace the placeholder
            # SV and drop the tied state, silently dropping STORE for
            # `tie my $x, 'C'; $x = ...` patterns inside loops/blocks
            # (where the simple `our $x = ...` mirror-sync path doesn't
            # fire). Predict-not-taken — non-tied vars hit one
            # meta-pointer load on the cold path.
            emit($cg, "({ StradaValue *__sa_new = ");
            gen_expr($cg, $node->{"value"});
            emit($cg, "; StradaValue *__sa_old = ");
            gen_expr($cg, $target);
            emit($cg, "; if (__builtin_expect(__sa_old && !STRADA_IS_TAGGED_INT(__sa_old) && __sa_old->meta && __sa_old->meta->is_tied, 0)) { ");
            emit($cg, "  strada_tied_scalar_store(__sa_old, __sa_new); if (__sa_new) strada_decref(__sa_new); __sa_old; ");
            emit($cg, "} else { ");
            gen_expr($cg, $target);
            emit($cg, " = __sa_new; } })");
            return;
        }
        if ($target_type == Perla::AST::N_ARRAY_VAR() || $target_type == Perla::AST::N_HASH_VAR()) {
            emit($cg, "(");
            gen_expr($cg, $target);
            emit($cg, " = ");
            gen_expr($cg, $node->{"value"});
            emit($cg, ")");
            return;
        }
    }

    # Postfix-if/unless as the last expression of a sub is a
    # statement-form construct that perla otherwise lowers via
    # _gen_stmt. When it lands in _gen_expr (e.g. as the implicit
    # return value), produce an expression form: evaluate cond, then
    # the inner expr (or undef on the false branch). _gen_cond emits
    # a raw C int (truthy value) directly, so DON'T wrap in
    # perla_to_bool — that expects a StradaValue*. The bug it
    # surfaced: DBIx::Class::mk_classaccessor's
    # `$self->set_inherited(@_) if @_ > 1;` was the last expression
    # of the sub, which generated `perla_to_bool(LEN > 1)` — passing
    # an int through a StradaValue* pointer parameter, evaluating
    # garbage as truthy/falsy.
    if ($type == Perla::AST::N_POSTFIX_IF()) {
        # If the inner is a control-flow statement (return/last/next/redo),
        # the ternary-expression form is wrong — `_gen_expr` on N_RETURN
        # falls through to `/* TODO */` and the call inside `return EXPR`
        # never runs. Use a statement-expression so `if (cond) { return …; }`
        # actually generates the return code and the enclosing block falls
        # out as undef when the condition is false. Surfaced via Abe::App's
        # `return $self->setup_site($args) if $bootstrap;` (last stmt of
        # init): silently skipped under perla → setup_site never ran →
        # $self->{package_config} stayed undef → DBI connect with no creds.
        my int $inner_type = $node->{"expr"}->{"type"};
        if ($inner_type == Perla::AST::N_RETURN() || $inner_type == Perla::AST::N_LAST()
            || $inner_type == Perla::AST::N_NEXT() || $inner_type == Perla::AST::N_REDO()) {
            emit($cg, "({ if (");
            _gen_cond($cg, $node->{"cond"});
            emit($cg, ") { ");
            Perla::CodeGen::Stmt::gen_stmt($cg, $node->{"expr"});
            emit($cg, " } strada_new_undef(); })");
            return;
        }
        emit($cg, "((");
        _gen_cond($cg, $node->{"cond"});
        emit($cg, ") ? (");
        gen_expr($cg, $node->{"expr"});
        emit($cg, ") : strada_new_undef())");
        return;
    }
    if ($type == Perla::AST::N_POSTFIX_UNLESS()) {
        my int $inner_type = $node->{"expr"}->{"type"};
        if ($inner_type == Perla::AST::N_RETURN() || $inner_type == Perla::AST::N_LAST()
            || $inner_type == Perla::AST::N_NEXT() || $inner_type == Perla::AST::N_REDO()) {
            emit($cg, "({ if (!(");
            _gen_cond($cg, $node->{"cond"});
            emit($cg, ")) { ");
            Perla::CodeGen::Stmt::gen_stmt($cg, $node->{"expr"});
            emit($cg, " } strada_new_undef(); })");
            return;
        }
        emit($cg, "(!(");
        _gen_cond($cg, $node->{"cond"});
        emit($cg, ") ? (");
        gen_expr($cg, $node->{"expr"});
        emit($cg, ") : strada_new_undef())");
        return;
    }
    # `STMT while COND` / `STMT until COND` / `STMT for/foreach LIST` as
    # the last expression of a sub: lower to a statement-expression so
    # the loop actually runs. Perl semantics: the loop returns undef
    # as an expression. Without this, the codegen emitted
    # `strada_new_undef() /* TODO */` and the loop body never ran —
    # silent miscompilation of e.g. `push @x, $1 while $s =~ /.../g;`
    # at the tail of a sub.
    if ($type == Perla::AST::N_POSTFIX_WHILE()
        || $type == Perla::AST::N_POSTFIX_UNTIL()
        || $type == Perla::AST::N_POSTFIX_FOR()) {
        emit($cg, "({ ");
        Perla::CodeGen::Stmt::gen_stmt($cg, $node);
        emit($cg, " strada_new_undef(); })");
        return;
    }
    emit($cg, "strada_new_undef() /* TODO: node type " . $type . " */");
}
# --- Anonymous hash ---
# Generate the expression value of a map/grep block (last expression)
# Generate an expression in scalar context (@array → count)
func _gen_expr_scalar(scalar $cg, scalar $node) void {
    if (!defined($node)) { emit($cg, "strada_new_undef()"); return; }
    if ($node->{"type"} == Perla::AST::N_ARRAY_VAR()) {
        my str $aname = $node->{"name"};
        if ($aname eq "_") {
            emit($cg, "STRADA_MAKE_TAGGED_INT((int64_t)strada_array_length(strada_deref_array(perla_at_)))");
        } else {
            emit($cg, "STRADA_MAKE_TAGGED_INT((int64_t)strada_array_length(strada_deref_array(" . c_var_a($aname) . ")))");
        }
        return;
    }
    gen_expr($cg, $node);
}

func gen_expr_safe(scalar $cg, scalar $node) void {
    # Like _gen_expr but guarantees output (emits undef if nothing generated)
    if (!defined($node)) { emit($cg, "strada_new_undef()"); return; }
    my int $type = $node->{"type"};
    # Skip node types that don't produce expressions
    # N_SUB with a name is a declaration (not an expression)
    # N_SUB without a name is an anonymous sub (IS an expression)
    if ($type == Perla::AST::N_USE() || $type == Perla::AST::N_PACKAGE() ||
        ($type == Perla::AST::N_SUB() && defined($node->{"name"})) ||
        $type == Perla::AST::N_BEGIN() || $type == Perla::AST::N_END()) {
        # `no MODULE` in expression context (e.g. inside `do { no Foo() }`
        # appearing as the last statement of an eval body) needs its
        # require side-effect preserved — that's how YAML::Mo's `extends`
        # sub loads parent classes. The bare-USE no-op skip was eating
        # the call. Emit the require inline and yield undef as the value.
        if ($type == Perla::AST::N_USE()
            && defined($node->{"is_no"}) && $node->{"is_no"} == 1
            && defined($node->{"module"}) && length($node->{"module"}) > 0) {
            my str $nm = $node->{"module"};
            emit($cg, "({ StradaValue *__nrm = strada_new_str(\"" . $nm . "\"); ");
            emit($cg, "StradaValue *__nrr = perla_require_module(__nrm); ");
            emit($cg, "if (__nrr) strada_decref(__nrr); strada_decref(__nrm); strada_new_undef(); })");
            return;
        }
        emit($cg, "strada_new_undef()");
        return;
    }
    # `return EXPR` inside a do-block returns from the enclosing sub
    # (Perl semantics). Emit a C block that captures the value, drains
    # cleanup, and `return`s — matches what `_gen_stmt` does for the
    # statement form. Without this, eval STRING'd code like
    # `eval "require X; X->import; return 'loaded';"` (Date::Manip's
    # backend probe) saw the wrapper return undef instead of 'loaded',
    # so Date::Manip thought DM6 failed to load and bailed bizowie at
    # BZ:2.
    if ($type == Perla::AST::N_RETURN() && $cg->{"in_sub"} == 1) {
        # GCC statement-expression `({ … })` requires the last subexpression
        # to yield a value, so we follow `return` with an unreachable
        # `(StradaValue*)NULL` to satisfy the type.
        #
        # `return EXPR` must evaluate EXPR in the *caller's* wantarray
        # context — not the do-block's. Without restoring __perla_want_list
        # here, `sub g { my $rv = do { return (1,2,3); }; }` reduced
        # (1,2,3) to its last element 3 because the surrounding `my $rv =`
        # set __perla_want_list=0 for the do-block. The statement-form
        # N_RETURN handler does this restore (line ~2727); this expr-form
        # variant has to mirror it. Also mirror the scalar-context
        # reductions (list→last-elem, array→size, hash→entry-count) so the
        # value matches Perl's `return EXPR` semantics.
        my int $reduce_last_e = 0;
        my int $reduce_size_e = 0;
        if (defined($node->{"value"})) {
            my int $vt_e = $node->{"value"}->{"type"};
            if ($vt_e == Perla::AST::N_ANON_ARRAY()) {
                my int $isref_e = 0;
                if (defined($node->{"value"}->{"is_ref"})) {
                    $isref_e = $node->{"value"}->{"is_ref"};
                }
                if ($isref_e == 0) { $reduce_last_e = 1; }
            } elsif ($vt_e == Perla::AST::N_ARRAY_VAR()) {
                $reduce_size_e = 1;
            }
        }
        emit($cg, "({ __perla_want_list = __perla_caller_want_list; StradaValue *__ret_val = ");
        if (defined($node->{"value"})) {
            gen_expr($cg, $node->{"value"});
        } else {
            emit($cg, "(__perla_caller_want_list ? strada_new_array() : strada_new_undef())");
        }
        emit($cg, ";");
        if ($reduce_last_e == 1) {
            emit($cg, " if (!__perla_caller_want_list && __ret_val && !STRADA_IS_TAGGED_INT(__ret_val) && __ret_val->type == STRADA_ARRAY) { StradaArray *__rrav = strada_deref_array(__ret_val); StradaValue *__rrlast = (__rrav && __rrav->size > 0) ? __rrav->elements[__rrav->head + __rrav->size - 1] : strada_new_undef(); strada_incref(__rrlast); strada_decref(__ret_val); __ret_val = __rrlast; }");
        } elsif ($reduce_size_e == 1) {
            emit($cg, " if (!__perla_caller_want_list && __ret_val && !STRADA_IS_TAGGED_INT(__ret_val) && __ret_val->type == STRADA_ARRAY) { StradaArray *__rrav = strada_deref_array(__ret_val); int64_t __rrsz = __rrav ? (int64_t)__rrav->size : 0; strada_decref(__ret_val); __ret_val = STRADA_MAKE_TAGGED_INT(__rrsz); }");
        }
        emit($cg, " if (!__perla_caller_want_list && __ret_val && !STRADA_IS_TAGGED_INT(__ret_val) && __ret_val->type == STRADA_HASH) { StradaHash *__rrhv = strada_deref_hash(__ret_val); int64_t __rrhn = __rrhv ? (int64_t)__rrhv->num_entries : 0; strada_decref(__ret_val); __ret_val = STRADA_MAKE_TAGGED_INT(__rrhn); }");
        emit($cg, " strada_incref(__ret_val); strada_cleanup_drain_to(__perla_cleanup_mark); ");
        emit($cg, "if (__perla_local_chain != __perla_local_chain_mark) { perla_local_chain_restore_to(__perla_local_chain, __perla_local_chain_mark); __perla_local_chain = __perla_local_chain_mark; } perla_call_pop(); ");
        emit($cg, "return __ret_val; (StradaValue*)NULL; })");
        return;
    }
    gen_expr($cg, $node);
}

func _gen_map_block(scalar $cg, scalar $block) void {
    my scalar $stmts = $block->{"stmts"};
    if (!defined($stmts) || scalar(@{$stmts}) == 0) {
        emit($cg, "strada_new_undef()");
        return;
    }
    # If single statement, generate as expression. Control-flow forms
    # (N_IF / N_UNLESS) need to be wrapped in a statement-expression
    # so the value of the chosen branch is the map's result. Without
    # this, `map { if (...) { HREF } else { HREF } } LIST` emitted
    # `strada_new_undef() /* TODO: node type 23 */` and every element
    # was undef. Use Perla::CodeGen::Stmt::gen_if_capture_return (the existing helper used
    # by sub bodies) which walks the if/elsif/else chain and assigns
    # each branch's last expression to the result var.
    if (scalar(@{$stmts}) == 1) {
        my scalar $single = $stmts->[0];
        my int $st0 = defined($single) ? $single->{"type"} : -1;
        if ($st0 == Perla::AST::N_IF() || $st0 == Perla::AST::N_UNLESS()) {
            $cg->{"tmp_count"} = $cg->{"tmp_count"} + 1;
            my str $rv = "__map_if_rv_" . $cg->{"tmp_count"};
            emit($cg, "({ StradaValue *" . $rv . " = strada_new_undef(); ");
            Perla::CodeGen::Stmt::gen_if_capture_return($cg, $single, $rv);
            emit($cg, " " . $rv . "; })");
            return;
        }
        gen_expr_safe($cg, $single);
        return;
    }
    # Multiple statements: use statement expression, last one is the value.
    # Non-last statements may be control-flow forms (N_IF, N_WHILE, N_FOR,
    # N_MY, N_OUR, etc.) which `_gen_expr` doesn't know how to compile —
    # it emits `strada_new_undef() /* TODO: node type N */`. Use `_gen_stmt`
    # for those so the if/elsif/else chain actually fires inside the map
    # body. Without this, DBIC's `_resolve_bindattrs`-style map { my $x;
    # if (...) {...} elsif (...) {...} ... $rv } skipped every branch and
    # left $rv undef.
    emit($cg, "({ ");
    my int $i = 0;
    my int $last = scalar(@{$stmts}) - 1;
    while ($i < $last) {
        my scalar $stmt = $stmts->[$i];
        my int $st = defined($stmt) ? $stmt->{"type"} : -1;
        if ($st == Perla::AST::N_IF() || $st == Perla::AST::N_UNLESS() ||
            $st == Perla::AST::N_WHILE() || $st == Perla::AST::N_UNTIL() ||
            $st == Perla::AST::N_FOR_C() || $st == Perla::AST::N_FOREACH() ||
            $st == Perla::AST::N_MY() || $st == Perla::AST::N_OUR() ||
            $st == Perla::AST::N_LOCAL() || $st == Perla::AST::N_RETURN()) {
            Perla::CodeGen::Stmt::gen_stmt($cg, $stmt);
        } else {
            gen_expr($cg, $stmt);
            emit($cg, "; ");
        }
        $i++;
    }
    # Last stmt: if it's a control-flow form (most commonly N_IF), use
    # gen_if_capture_return to thread the chosen-branch value into a
    # result var so the map block yields it. Without this, multi-stmt
    # `map { my $n = $_; if (...) { X } else { Y } } LIST` emitted the
    # if as a statement (no return value) and the map block's result
    # was strada_new_undef() / TODO. Mirrors the single-stmt N_IF path.
    my scalar $last_stmt = $stmts->[$last];
    my int $lst = defined($last_stmt) ? $last_stmt->{"type"} : -1;
    if ($lst == Perla::AST::N_IF() || $lst == Perla::AST::N_UNLESS()) {
        $cg->{"tmp_count"} = $cg->{"tmp_count"} + 1;
        my str $rv = "__map_if_lrv_" . $cg->{"tmp_count"};
        emit($cg, "StradaValue *" . $rv . " = strada_new_undef(); ");
        Perla::CodeGen::Stmt::gen_if_capture_return($cg, $last_stmt, $rv);
        emit($cg, " " . $rv . "; })");
        return;
    }
    gen_expr_safe($cg, $last_stmt);
    emit($cg, "; })");
}

func _gen_anon_hash(scalar $cg, scalar $node) void {
    my int $prev_in_hash = $cg->{"in_hash_constructor"};
    $cg->{"in_hash_constructor"} = 1;
    my scalar $pairs = $node->{"pairs"};
    my int $count = scalar(@{$pairs});
    if ($count == 0) {
        # `_take` consumes the fresh hash without extra incref. The
        # plain strada_new_ref incref's the target, but here we hold
        # no other pointer to it — the extra ref leaked the hash
        # forever, which in turn pinned the blessed ref's refcount
        # above 0 at scope exit, preventing DESTROY from firing.
        emit($cg, "strada_new_ref_take(strada_new_hash(), '%')");
        $cg->{"in_hash_constructor"} = $prev_in_hash;
        return;
    }
    # Check for {@array} — single array that should be spread into key-value pairs
    if ($count == 1 && $pairs->[0]->{"type"} == Perla::AST::N_ARRAY_VAR()) {
        emit($cg, "({ StradaValue *__src = ");
        gen_expr($cg, $pairs->[0]);
        emit($cg, "; StradaValue *__h = strada_new_hash(); ");
        emit($cg, "StradaArray *__sa = strada_deref_array(__src); ");
        emit($cg, "if (__sa) for (int __si = 0; __si + 1 < (int)strada_array_length(__sa); __si += 2) { ");
        emit($cg, "char *__k = strada_to_str(strada_array_get(__sa, __si)); ");
        emit($cg, "strada_hv_store(__h, __k, strada_array_get(__sa, __si + 1)); free(__k); } ");
        emit($cg, "strada_new_ref(__h, '%'); })");
        $cg->{"in_hash_constructor"} = $prev_in_hash;
        return;
    }
    # Check for {%hash} — single hash var that should be flattened
    if ($count == 1 && $pairs->[0]->{"type"} == Perla::AST::N_HASH_VAR()) {
        emit($cg, "({ StradaValue *__src = ");
        gen_expr($cg, $pairs->[0]);
        emit($cg, "; StradaValue *__h = strada_new_hash(); ");
        emit($cg, "StradaHash *__sh = strada_deref_hash(__src); ");
        emit($cg, "if (__sh) { StradaArray *__sk = strada_hash_keys(__sh); ");
        emit($cg, "for (size_t __si = 0; __si < __sk->size; __si++) { ");
        emit($cg, "char *__k = strada_to_str(__sk->elements[__si]); ");
        emit($cg, "strada_hv_store(__h, __k, strada_hash_get(__sh, __k)); free(__k); } ");
        emit($cg, "strada_free_array(__sk); } strada_new_ref(__h, '%'); })");
        $cg->{"in_hash_constructor"} = $prev_in_hash;
        return;
    }
    # `{ map {...} LIST }` and other list-returning expressions — when the
    # single pair's value is an N_GREP (map/grep/etc.) or any expression
    # whose runtime result may be an ARRAY, flatten the result into pairs.
    # Without this, `{ map { K => V } LIST }` gives an empty hash because
    # the map's flat list isn't unpacked into key/value pairs. DBIC's
    # `_mk_row_parser` builds its `val_index => { map { ... } 0..N }` this
    # way and silently produced an empty val_index → empty parser source.
    if ($count == 1) {
        my int $pt = $pairs->[0]->{"type"};
        my int $is_list_paren = 0;
        if ($pt == Perla::AST::N_ANON_ARRAY() && !defined($pairs->[0]->{"is_ref"})) {
            # Bare `( a, b, c )` parses as N_ANON_ARRAY with no is_ref —
            # it's a parenthesized list expression, not an arrayref. In
            # `{ ( "k" => "v" ) }` we must flatten the elements into pairs.
            $is_list_paren = 1;
        }
        if ($is_list_paren == 1) {
            my scalar $list_elems = $pairs->[0]->{"elems"};
            my int $le_count = scalar(@{$list_elems});
            emit($cg, "({ StradaValue *__h = strada_new_hash(); ");
            my int $lei = 0;
            while ($lei + 1 < $le_count) {
                emit($cg, "{ char *__k = strada_to_str(");
                gen_expr($cg, $list_elems->[$lei]);
                emit($cg, "); StradaValue *__v = ");
                gen_expr($cg, $list_elems->[$lei + 1]);
                emit($cg, "; strada_hv_store_take(__h, __k, __v); free(__k); } ");
                $lei = $lei + 2;
            }
            emit($cg, "strada_new_ref(__h, '%'); })");
            $cg->{"in_hash_constructor"} = $prev_in_hash;
            return;
        }
        if ($pt == Perla::AST::N_GREP() || $pt == Perla::AST::N_MAP() ||
            $pt == Perla::AST::N_CALL() || $pt == Perla::AST::N_RANGE() ||
            $pt == Perla::AST::N_DEREF_HASH() || $pt == Perla::AST::N_DEREF_ARRAY()) {
            emit($cg, "({ int __sav_wl_ah = __perla_want_list; __perla_want_list = 1; ");
            emit($cg, "StradaValue *__src = ");
            gen_expr($cg, $pairs->[0]);
            emit($cg, "; __perla_want_list = __sav_wl_ah; ");
            emit($cg, "StradaValue *__h = strada_new_hash(); ");
            # If runtime value is an ARRAY, treat as flat k,v list. If it's a
            # HASH or REF→HASH, copy entries. Otherwise scalar — store as
            # single key with value = undef (matches Perl 'odd number of
            # elements' warning, but doesn't warn).
            emit($cg, "if (__src && !STRADA_IS_TAGGED_INT(__src)) { ");
            emit($cg, "if (__src->type == STRADA_ARRAY) { ");
            emit($cg, "StradaArray *__sa = __src->value.av; ");
            emit($cg, "if (__sa) for (size_t __si = 0; __si + 1 < __sa->size; __si += 2) { ");
            emit($cg, "char *__k = strada_to_str(__sa->elements[__sa->head + __si]); ");
            emit($cg, "StradaValue *__v = __sa->elements[__sa->head + __si + 1]; ");
            emit($cg, "if (__v) strada_incref(__v); ");
            emit($cg, "strada_hv_store_take(__h, __k, __v); free(__k); } ");
            emit($cg, "} else if (__src->type == STRADA_HASH) { ");
            emit($cg, "StradaHash *__sh = __src->value.hv; ");
            emit($cg, "if (__sh) { StradaArray *__sk = strada_hash_keys(__sh); ");
            emit($cg, "for (size_t __si = 0; __si < __sk->size; __si++) { ");
            emit($cg, "char *__k = strada_to_str(__sk->elements[__si]); ");
            emit($cg, "StradaValue *__v = strada_hash_get(__sh, __k); if (__v) strada_incref(__v); ");
            emit($cg, "strada_hv_store_take(__h, __k, __v); free(__k); } ");
            emit($cg, "strada_free_array(__sk); } ");
            emit($cg, "} else if (__src->type == STRADA_REF && __src->value.rv) { ");
            emit($cg, "StradaValue *__rv = __src->value.rv; ");
            emit($cg, "if (!STRADA_IS_TAGGED_INT(__rv) && __rv->type == STRADA_HASH) { ");
            emit($cg, "StradaHash *__sh = __rv->value.hv; ");
            emit($cg, "if (__sh) { StradaArray *__sk = strada_hash_keys(__sh); ");
            emit($cg, "for (size_t __si = 0; __si < __sk->size; __si++) { ");
            emit($cg, "char *__k = strada_to_str(__sk->elements[__si]); ");
            emit($cg, "StradaValue *__v = strada_hash_get(__sh, __k); if (__v) strada_incref(__v); ");
            emit($cg, "strada_hv_store_take(__h, __k, __v); free(__k); } ");
            emit($cg, "strada_free_array(__sk); } ");
            emit($cg, "} else if (!STRADA_IS_TAGGED_INT(__rv) && __rv->type == STRADA_ARRAY) { ");
            emit($cg, "StradaArray *__sa = __rv->value.av; ");
            emit($cg, "if (__sa) for (size_t __si = 0; __si + 1 < __sa->size; __si += 2) { ");
            emit($cg, "char *__k = strada_to_str(__sa->elements[__sa->head + __si]); ");
            emit($cg, "StradaValue *__v = __sa->elements[__sa->head + __si + 1]; ");
            emit($cg, "if (__v) strada_incref(__v); ");
            emit($cg, "strada_hv_store_take(__h, __k, __v); free(__k); } ");
            emit($cg, "} ");
            emit($cg, "} else { ");
            emit($cg, "char *__k = strada_to_str(__src); strada_hv_store(__h, __k, strada_new_undef()); free(__k); ");
            emit($cg, "} } ");
            emit($cg, "strada_new_ref(__h, '%'); })");
            $cg->{"in_hash_constructor"} = $prev_in_hash;
            return;
        }
    }
    emit($cg, "({ StradaValue *__h = strada_new_hash(); ");
    my int $i = 0;
    while ($i < $count) {
        my scalar $knode = $pairs->[$i];
        my int $kt = -1;
        if (defined($knode)) { $kt = $knode->{"type"}; }
        # Spread a hash value: `{ %hash, ... }` or `{ %{$ref}, ... }`.
        # The spread occupies ONE AST slot but flattens to an even number
        # of key/value pairs at runtime. Without this, the spread is
        # treated as a single key and the pair-counter misaligns so
        # `database => $v, host => $w` get inverted (key=$v, value="host").
        if ($kt == Perla::AST::N_HASH_VAR() || $kt == Perla::AST::N_DEREF_HASH()) {
            # Force list context around the spread expression. N_DEREF_HASH
            # has a scalar-context short-circuit that returns
            # num_entries (an integer) instead of the hash — fine for
            # `scalar %h` but wrong here, where we want to enumerate
            # entries. Without this, `{ %\$opts, x => 10 }` spread
            # nothing because __sr was a tagged-int count.
            emit($cg, "{ int __sav_wl_hsp = __perla_want_list; __perla_want_list = 1; StradaValue *__sr = ");
            gen_expr($cg, $knode);
            emit($cg, "; __perla_want_list = __sav_wl_hsp; StradaHash *__sh = strada_deref_hash(({ StradaValue *__dr = __sr; (!__dr || STRADA_IS_TAGGED_INT(__dr)) ? strada_new_hash() : (__dr->type == STRADA_REF && __dr->value.rv) ? __dr->value.rv : __dr; })); ");
            emit($cg, "if (__sh) { StradaArray *__sk = strada_hash_keys(__sh); ");
            emit($cg, "for (size_t __si = 0; __si < __sk->size; __si++) { ");
            emit($cg, "char *__k = strada_to_str(__sk->elements[__si]); ");
            emit($cg, "StradaValue *__sv = strada_hash_get(__sh, __k); if (__sv) strada_incref(__sv); ");
            emit($cg, "strada_hv_store_take(__h, __k, __sv); free(__k); } ");
            emit($cg, "strada_free_array(__sk); } } ");
            $i = $i + 1;
            next;
        }
        # Spread an array value: `{ @arr, ... }` or `{ @{$ref}, ... }`.
        # Like the hash-spread case above: occupies ONE pair slot but
        # flattens to N elements at runtime treated as alternating k/v.
        # Without this, `{ @_, type => "pet" }` (a common pattern for
        # passing args to bless) stored `@_` as a single ARRAY key.
        if ($kt == Perla::AST::N_ARRAY_VAR() || $kt == Perla::AST::N_DEREF_ARRAY()) {
            emit($cg, "{ StradaValue *__asr = ");
            gen_expr($cg, $knode);
            emit($cg, "; StradaArray *__ssa = strada_deref_array(({ StradaValue *__adr = __asr; (!__adr || STRADA_IS_TAGGED_INT(__adr)) ? strada_new_array() : (__adr->type == STRADA_REF && __adr->value.rv) ? __adr->value.rv : __adr; })); ");
            emit($cg, "if (__ssa) for (size_t __asi = 0; __asi + 1 < __ssa->size; __asi += 2) { ");
            emit($cg, "char *__ak = strada_to_str(__ssa->elements[__ssa->head + __asi]); ");
            emit($cg, "StradaValue *__av = __ssa->elements[__ssa->head + __asi + 1]; ");
            emit($cg, "if (__av) strada_incref(__av); ");
            emit($cg, "strada_hv_store_take(__h, __ak, __av); free(__ak); } } ");
            $i = $i + 1;
            next;
        }
        # Array slice / hash slice / range as a value-position spread —
        # `{ k => v, @_[1..\$#_] }`, `{ k => v, @arr[0..2] }`, etc. The
        # slice produces a flat list at runtime; treat it as alternating
        # k/v pairs into the hash. Without this, the slice was treated
        # as a single key and the rest of the pairs misaligned (so
        # `bless { type => "x", @_[1..\$#_] }, \$c` ended up with
        # type="x" only and the splatted name/value pairs went into a
        # bogus key).
        if ($kt == Perla::AST::N_ARRAY_SLICE() || $kt == Perla::AST::N_HASH_SLICE()
            || $kt == Perla::AST::N_RANGE()) {
            emit($cg, "{ int __sav_wl_assl = __perla_want_list; __perla_want_list = 1; StradaValue *__sssv = ");
            gen_expr($cg, $knode);
            emit($cg, "; __perla_want_list = __sav_wl_assl; StradaArray *__ssla = strada_deref_array(({ StradaValue *__sldr = __sssv; (!__sldr || STRADA_IS_TAGGED_INT(__sldr)) ? strada_new_array() : (__sldr->type == STRADA_REF && __sldr->value.rv) ? __sldr->value.rv : __sldr; })); ");
            emit($cg, "if (__ssla) for (size_t __ssli = 0; __ssli + 1 < __ssla->size; __ssli += 2) { ");
            emit($cg, "char *__slk = strada_to_str(__ssla->elements[__ssla->head + __ssli]); ");
            emit($cg, "StradaValue *__slv = __ssla->elements[__ssla->head + __ssli + 1]; ");
            emit($cg, "if (__slv) strada_incref(__slv); ");
            emit($cg, "strada_hv_store_take(__h, __slk, __slv); free(__slk); } } ");
            $i = $i + 1;
            next;
        }
        # Ternary `$cond ? %hash_or_list : ()` — flatten runtime array
        # result into key/value pairs. Real Perl evaluates each expr in
        # list context and concatenates; if the ternary returns an empty
        # list `()` the whole thing collapses to nothing. Without this,
        # `{ $cond ? %a : (), name => 'x' }` shifts subsequent pairs by
        # one slot (DBIx::Class's ResultSourceProxy::Table::table uses
        # exactly this pattern).
        if ($kt == Perla::AST::N_TERNARY()) {
            # Force list context: hash-literal value-positions are list
            # context, so the ternary's branches must materialize their
            # full list. Without this, `my $h = { K => V, $c ? (K2=>V2) : (), ... }`
            # in scalar context (`my $h = ...`) inherits scalar context,
            # so each branch collapses to its last scalar via __sl_last.
            emit($cg, "{ int __sav_wl_ht = __perla_want_list; __perla_want_list = 1; StradaValue *__tv = ");
            gen_expr($cg, $knode);
            emit($cg, "; __perla_want_list = __sav_wl_ht; if (__tv && !STRADA_IS_TAGGED_INT(__tv)) { ");
            # ARRAY: take pairs of consecutive elements
            emit($cg, "if (__tv->type == STRADA_ARRAY) { ");
            emit($cg, "StradaArray *__tav = __tv->value.av; ");
            emit($cg, "if (__tav) for (size_t __ti = 0; __ti + 1 < __tav->size; __ti += 2) { ");
            emit($cg, "char *__tk = strada_to_str(__tav->elements[__tav->head + __ti]); ");
            emit($cg, "StradaValue *__tvv = __tav->elements[__tav->head + __ti + 1]; ");
            emit($cg, "if (__tvv) strada_incref(__tvv); ");
            emit($cg, "strada_hv_store_take(__h, __tk, __tvv); free(__tk); } ");
            emit($cg, "} ");
            # HASH or REF→HASH: copy entries
            emit($cg, "else { StradaHash *__tsh = strada_deref_hash(({ StradaValue *__tdr = __tv; (__tdr->type == STRADA_REF && __tdr->value.rv) ? __tdr->value.rv : __tdr; })); ");
            emit($cg, "if (__tsh) { StradaArray *__tsk = strada_hash_keys(__tsh); ");
            emit($cg, "for (size_t __tsi = 0; __tsi < __tsk->size; __tsi++) { ");
            emit($cg, "char *__tkn = strada_to_str(__tsk->elements[__tsi]); ");
            emit($cg, "StradaValue *__tvn = strada_hash_get(__tsh, __tkn); if (__tvn) strada_incref(__tvn); ");
            emit($cg, "strada_hv_store_take(__h, __tkn, __tvn); free(__tkn); } ");
            emit($cg, "strada_free_array(__tsk); } } ");
            emit($cg, "} ");
            emit($cg, "if (__tv) strada_decref(__tv); } ");
            $i = $i + 1;
            next;
        }
        if ($i + 1 >= $count) { last; }
        # Pick hv_store vs hv_store_take based on whether the value
        # expression produces a fresh allocation (take ownership, no
        # incref) or a borrowed reference (must incref via store).
        # Storing a borrowed ref via _take and then having the caller
        # decref the source drops refcounts that weren't owned — seen
        # with `bless({ name => $_[1] }, 'Foo')` where $_[1] pointed into
        # the args array, which the caller then freed.
        my str $store_fn = "strada_hv_store_take";
        if (Perla::CodeGen::Predicate::value_is_borrowed($cg, $pairs->[$i + 1]) == 1) {
            $store_fn = "strada_hv_store";
        }
        if (defined($knode) && ($knode->{"type"} == Perla::AST::N_STR_LIT() || ($knode->{"type"} == Perla::AST::N_INTERP_STR() && has_perl_var($knode->{"value"}) == 0))) {
            emit($cg, $store_fn . "(__h, \"" . Perla::CodeGen::Escape::str_node_to_c($knode) . "\", ");
            gen_expr($cg, $pairs->[$i + 1]);
            emit($cg, "); ");
        } else {
            emit($cg, "{ char *__k = strada_to_str(");
            gen_expr($cg, $knode);
            emit($cg, "); " . $store_fn . "(__h, __k, ");
            gen_expr($cg, $pairs->[$i + 1]);
            emit($cg, "); free(__k); } ");
        }
        $i = $i + 2;
    }
    emit($cg, "strada_new_ref(__h, '%'); })");
    $cg->{"in_hash_constructor"} = $prev_in_hash;
}

# --- Anonymous array ---
func _gen_anon_array(scalar $cg, scalar $node) void {
    my scalar $elems = $node->{"elems"};
    my int $count = scalar(@{$elems});
    if ($count == 0) {
        if ($node->{"is_ref"} == 1) {
            # `_take` — see _gen_anon_hash empty case.
            emit($cg, "strada_new_ref_take(strada_new_array(), '@')");
        } else {
            # Empty list `()` — list context returns the empty array,
            # scalar context returns undef (Perl: \`my \$x = ()\` is undef).
            emit($cg, "(__perla_want_list ? strada_new_array() : strada_new_undef())");
        }
        return;
    }
    emit($cg, "({ StradaValue *__a = strada_new_array(); StradaArray *__av = strada_deref_array(__a); ");
    my int $i = 0;
    while ($i < $count) {
        my scalar $arg = $elems->[$i];
        my int $arg_type = $arg->{"type"};
        # Flatten @array, @{$ref}, qw(), and %hash args
        if ($arg_type == Perla::AST::N_QWORD()) {
            # qw(a b c) — push each word as individual element
            my scalar $qw_elems = $arg->{"elems"};
            if (defined($qw_elems)) {
                my int $qi = 0;
                while ($qi < scalar(@{$qw_elems})) {
                    emit($cg, "strada_array_push(__av, ");
                    gen_expr($cg, $qw_elems->[$qi]);
                    emit($cg, "); ");
                    $qi++;
                }
            }
        } elsif ($arg_type == Perla::AST::N_ANON_ARRAY() && $arg->{"is_ref"} != 1) {
            # Parenthesized list (a, b, c) — flatten elements. If the inner
            # element is itself a paren-list, evaluate it as a list and
            # flatten at runtime so multi-level nesting like
            # (1, (2, (3, 4)), 5) yields (1,2,3,4,5) and not (1,2,5).
            my scalar $inner_elems = $arg->{"elems"};
            if (defined($inner_elems)) {
                my int $ii = 0;
                while ($ii < scalar(@{$inner_elems})) {
                    my scalar $inner_arg = $inner_elems->[$ii];
                    my int $inner_at = $inner_arg->{"type"};
                    if (($inner_at == Perla::AST::N_ANON_ARRAY() && $inner_arg->{"is_ref"} != 1)
                        || $inner_at == Perla::AST::N_ARRAY_VAR()
                        || $inner_at == Perla::AST::N_DEREF_ARRAY()
                        || $inner_at == Perla::AST::N_ARRAY_SLICE()
                        || $inner_at == Perla::AST::N_HASH_SLICE()
                        || $inner_at == Perla::AST::N_RANGE()) {
                        emit($cg, "{ int __sav_wl_ar2 = __perla_want_list; __perla_want_list = 1; StradaArray *__fa2 = strada_deref_array(");
                        gen_expr($cg, $inner_arg);
                        emit($cg, "); __perla_want_list = __sav_wl_ar2; if (__fa2) { for (int __fi2 = 0; __fi2 < (int)strada_array_length(__fa2); __fi2++) { ");
                        emit($cg, "strada_array_push(__av, strada_array_get(__fa2, __fi2)); } } } ");
                    } else {
                        emit($cg, "strada_array_push(__av, ");
                        gen_expr($cg, $inner_arg);
                        emit($cg, "); ");
                    }
                    $ii++;
                }
            }
        } elsif ($arg_type == Perla::AST::N_ARRAY_VAR() || $arg_type == Perla::AST::N_DEREF_ARRAY()
                 || $arg_type == Perla::AST::N_ARRAY_SLICE() || $arg_type == Perla::AST::N_HASH_SLICE()
                 || $arg_type == Perla::AST::N_RANGE()
                 || ($arg_type == Perla::AST::N_REGEX()
                     && (!defined($arg->{"is_qr"}) || $arg->{"is_qr"} != 1))) {
            # N_REGEX (without is_qr) means a match against $_ — in list
            # context it returns the captures. We want flattening so
            # `[/^(\w+)\s+(\S+)$/]` produces a 2-element array, not a
            # 1-element wrapping the captures sub-array.
            # Array/hash slices and ranges produce a flat array of values;
            # flatten them into the surrounding list. Force list context
            # for the slice/range expression itself — it captures the
            # outer __perla_want_list and uses it to decide whether to
            # collapse to its last element (scalar) or yield the array.
            # When the anon array is the RHS of `my \$r = [...]` the
            # outer want_list is 0; without forcing, the slice collapsed
            # to a single tagged-int and \$fa came back NULL.
            # /regex/g (implicit `\$_ =~`) is also a list-returning
            # construct — `[/(\d+)/g, \$_]` should put captures into
            # the array, not the scalar match-success bool.
            emit($cg, "{ int __sav_wl_ar = __perla_want_list; __perla_want_list = 1; StradaArray *__fa = strada_deref_array(");
            gen_expr($cg, $arg);
            emit($cg, "); __perla_want_list = __sav_wl_ar; if (__fa) { for (int __fi = 0; __fi < (int)strada_array_length(__fa); __fi++) { ");
            emit($cg, "strada_array_push(__av, strada_array_get(__fa, __fi)); } } } ");
        } elsif ($arg_type == Perla::AST::N_HASH_VAR()
                 || $arg_type == Perla::AST::N_DEREF_HASH()) {
            # Flatten %hash / %$ref as key, value, key, value, ...
            # N_DEREF_HASH (`%$defaults`) was previously pushed as a
            # single scalar element, so `(%$defaults, %opts)` lost the
            # default key/value pairs — `my %m = (%$defaults, %opts)`
            # gave back only the opts hash plus a HASH(0x..) key.
            #
            # Force list context around the hash expression so it
            # actually yields the hash (in list ctx) instead of the
            # bucket-count tag-int (in scalar ctx). Without this,
            # `my $err = validate(%$href)` saw __perla_want_list=0
            # (carried in from the outer scalar `my $err = …`), so
            # `%$href` collapsed to STRADA_MAKE_TAGGED_INT(num_entries)
            # — strada_deref_hash on a tagged int is NULL, the for-
            # loop pushed nothing, and validate got 0 args.
            emit($cg, "{ int __sav_wl_hf = __perla_want_list; __perla_want_list = 1; StradaValue *__hv = ");
            gen_expr($cg, $arg);
            emit($cg, "; __perla_want_list = __sav_wl_hf; StradaArray *__hk = strada_hash_keys(strada_deref_hash(__hv)); ");
            emit($cg, "for (int __hi = 0; __hi < (int)strada_array_length(__hk); __hi++) { ");
            emit($cg, "StradaValue *__key = strada_array_get(__hk, __hi); ");
            emit($cg, "strada_array_push(__av, __key); ");
            emit($cg, "char *__ks = strada_to_str(__key); strada_array_push_take(__av, strada_hv_fetch_owned(__hv, __ks)); free(__ks); ");
            emit($cg, "} strada_decref(strada_new_array_from_av(__hk)); } ");
        } elsif (($arg_type == Perla::AST::N_CALL() && !defined($arg->{"coderef"}))
                 || $arg_type == Perla::AST::N_METHOD()
                 || $arg_type == Perla::AST::N_GREP()
                 || $arg_type == Perla::AST::N_MAP()
                 || $arg_type == Perla::AST::N_SORT()
                 || $arg_type == Perla::AST::N_BINOP()
                 || $arg_type == Perla::AST::N_MY()
                 || $arg_type == Perla::AST::N_ASSIGN()
                 || $arg_type == Perla::AST::N_TERNARY()) {
            # N_MY / N_ASSIGN: a list-assignment in list context returns its
            # LHS lvalue list (a STRADA_ARRAY) — see the destructuring yield in
            # _gen_stmt's N_MY handler. It must be FLATTENED into the
            # surrounding list, not pushed as one array element. This is what
            # makes `(my ($num) = grep {...} @args)[0]` (wrapped by the primary
            # paren handler as N_ANON_ARRAY{[N_MY], paren_list}) index the LHS
            # list instead of a 1-elem array-of-array. Without it the slice saw
            # `( [LHS] )[0]` = the inner array (truthy) — e.g. empty match list
            # gave `(0)`/array → `defined` true → spurious croak in
            # Sub::Exporter::Progressive that blocked e.pl.
            # Function/method call result - may return list that should be
            # flattened in list context. Set `__perla_want_list = 1` so the
            # callee picks list return semantics (without it the callee
            # would `return (1,2,3)` as just `3` per scalar-context reduce).
            # N_METHOD missing here used to make `[@x, $obj->fn()]` keep the
            # function's return as a single scalar element — broke DBIC's
            # `_resolve_join` HASH branch (`[ @{$attrs->{from}}, $source->_resolve_join(...) ]`)
            # so prefetched joins never landed in `from`, alias_map stayed
            # empty, and DBIC threw "Unable to resolve prefetch".
            #
            # N_BINOP / N_TERNARY: `||`, `//`, ternary `?:` can return a list
            # (the empty list `()` in particular). DBIC uses
            # `($attrs->{rows} || (), $attrs->{offset} || ())` to omit
            # absent keys; without runtime flattening, `undef || ()`
            # added one element (an empty array) instead of zero.
            emit($cg, "{ int __sav_wl = __perla_want_list; __perla_want_list = 1; StradaValue *__fcr = ");
            gen_expr($cg, $arg);
            emit($cg, "; __perla_want_list = __sav_wl; if (__fcr && !STRADA_IS_TAGGED_INT(__fcr) && __fcr->type == STRADA_ARRAY) { ");
            emit($cg, "StradaArray *__fca = strada_deref_array(__fcr); ");
            emit($cg, "if (__fca) for (int __fci=0; __fci<(int)strada_array_length(__fca); __fci++) ");
            emit($cg, "strada_array_push(__av, strada_array_get(__fca, __fci)); ");
            emit($cg, "} else { strada_array_push(__av, __fcr); } strada_decref(__fcr); } ");
        } else {
            # Use push_take for freshly-allocated expressions to avoid leaking
            # the creator's rc=1 ref; incref-then-push_take for borrowed
            # values (variables, array elements) so the array gets its own ref
            # without stranding the original. The plain `push` increfs but
            # never takes the creator's ref, so PERLA_NEW_STR_LIT("x") through
            # this path silently leaked one ref per element.
            my int $__aae_borrowed = 0;
            if ($arg_type == Perla::AST::N_SCALAR_VAR()
                || $arg_type == Perla::AST::N_ARRAY_VAR()
                || $arg_type == Perla::AST::N_HASH_VAR()
                || $arg_type == Perla::AST::N_ARRAY_ELEM()) {
                $__aae_borrowed = 1;
            }
            emit($cg, "{ StradaValue *__ane = ");
            gen_expr($cg, $arg);
            emit($cg, "; ");
            # Tied-scalar FETCH on list construction. Plain SCALAR_VAR
            # references emit the raw SV pointer; if that SV is tied,
            # the array element should hold the FETCH'd value (matches
            # Perl: list construction is transparent over tie magic).
            # Replace __ane with the fetched value (owned ref).
            if ($arg_type == Perla::AST::N_SCALAR_VAR()) {
                emit($cg, "if (__ane && !STRADA_IS_TAGGED_INT(__ane) && __ane->meta && __ane->meta->is_tied) { __ane = strada_tied_scalar_fetch(__ane); } else ");
                if ($__aae_borrowed == 1) {
                    emit($cg, "if (__ane) strada_incref(__ane); ");
                } else {
                    emit($cg, "{} ");
                }
            } elsif ($__aae_borrowed == 1) {
                emit($cg, "if (__ane) strada_incref(__ane); ");
            }
            emit($cg, "strada_array_push_take(__av, __ane); } ");
        }
        $i++;
    }
    if ($node->{"is_ref"} == 1) {
        emit($cg, "strada_new_ref(__a, '@'); })");
    } elsif (defined($node->{"scalar_count"}) && $node->{"scalar_count"} == 1) {
        # List-valued `use constant` (`use constant DAYS => ('a','b','c')`).
        # Perl backs a multi-element list constant with `@list`, so in
        # scalar context it yields the element COUNT, not the comma
        # operator's last element. (A bare `my $x = ('a','b','c')` still
        # uses the last-element rule below — only the constant body opts in.)
        emit($cg, "(__perla_want_list ? __a : ({ ");
        emit($cg, "  int64_t __sl_n = __av ? (int64_t)__av->size : 0; strada_decref(__a); STRADA_MAKE_TAGGED_INT(__sl_n); })); })");
    } else {
        # Parenthesized list. In list context, return the array for
        # flattening. In scalar context, the comma operator yields the
        # LAST element (Perl: `my \$x = (1, 2, 3)` → 3). Without this
        # branch, scalar assignment got the array stringified to its
        # count. Refs and explicit anon-array (is_ref=1) skip this.
        emit($cg, "(__perla_want_list ? __a : ({ ");
        emit($cg, "  StradaValue *__sl_last = (__av && __av->size > 0) ? __av->elements[__av->head + __av->size - 1] : strada_new_undef(); ");
        emit($cg, "  if (__sl_last) strada_incref(__sl_last); strada_decref(__a); __sl_last; })); })");
    }
}


# Package-qualified scalar var? `$Pkg::Name` is read via perla_scalar_get
# (a function call, NOT an lvalue), so ++/-- can't use the standard
# `lvalue = NEW` pattern. These helpers route writes through perla_scalar_set.
func _is_pkg_qualified_scalar(scalar $node) int {
    if (!defined($node)) { return 0; }
    if ($node->{"type"} != Perla::AST::N_SCALAR_VAR()) { return 0; }
    if (!defined($node->{"name"})) { return 0; }
    if (index($node->{"name"}, "::") > 0) { return 1; }
    return 0;
}

# True when the operand is an unqualified scalar var declared `our` in
# the current package. Used to gate the stash-sync emit after a mutation
# (`$x++`, `++$x`, etc.) so external `$Pkg::x` readers see the updated
# value.
func _is_our_unqual_scalar(scalar $cg, scalar $node) int {
    if (!defined($node)) { return 0; }
    if ($node->{"type"} != Perla::AST::N_SCALAR_VAR()) { return 0; }
    if (!defined($node->{"name"})) { return 0; }
    my str $vn = $node->{"name"};
    if (index($vn, "::") >= 0) { return 0; }
    if (!defined($cg->{"our_vars"})) { return 0; }
    if (!exists($cg->{"our_vars"}->{$vn})) { return 0; }
    return 1;
}

# Emit a stash-sync call after a mutation of an unqualified our-var.
# Caller has already updated v_VNAME; this writes the same value into
# the package stash so `$Pkg::VNAME` readers stay in sync.
func _emit_our_sync(scalar $cg, scalar $node) void {
    if (_is_our_unqual_scalar($cg, $node) == 0) { return; }
    my str $vn = $node->{"name"};
    my str $pkg = $cg->{"pkg"};
    emit($cg, "; perla_scalar_set(\"" . $pkg . "\", \"" . $vn . "\", " . c_var($vn) . ")");
}

# Split "Pkg::Name" into ($pkg, $name); writes into $cg slots so caller can read.
func _split_pkg_qual_name(scalar $node) array {
    my str $qn = $node->{"name"};
    my int $li = -1;
    my int $si = 0;
    while ($si < length($qn) - 1) {
        if (substr($qn, $si, 2) eq "::") { $li = $si; }
        $si++;
    }
    my str $pkg = substr($qn, 0, $li);
    my str $name = substr($qn, $li + 2, length($qn) - $li - 2);
    my array @r = ($pkg, $name);
    return @r;
}

# Emit postfix ++/-- for $Pkg::Name as ({ __old = get; set(old+/-1); __old; }).
func _emit_pkg_scalar_inc_postfix(scalar $cg, scalar $node, str $sign) void {
    my array @pn = _split_pkg_qual_name($node);
    my str $pkg = $pn[0];
    my str $name = $pn[1];
    emit($cg, "({ StradaValue *__old = perla_scalar_get(\"" . $pkg . "\", \"" . $name . "\"); ");
    emit($cg, "perla_scalar_set(\"" . $pkg . "\", \"" . $name . "\", STRADA_MAKE_TAGGED_INT(strada_to_int(__old) " . $sign . " 1)); __old; })");
}

# Emit prefix ++/-- for $Pkg::Name as ({ __new = get+/-1; set(__new); __new; }).
func _emit_pkg_scalar_inc_prefix(scalar $cg, scalar $node, str $sign) void {
    my array @pn = _split_pkg_qual_name($node);
    my str $pkg = $pn[0];
    my str $name = $pn[1];
    emit($cg, "({ StradaValue *__new = STRADA_MAKE_TAGGED_INT(strada_to_int(perla_scalar_get(\"" . $pkg . "\", \"" . $name . "\")) " . $sign . " 1); ");
    emit($cg, "perla_scalar_set(\"" . $pkg . "\", \"" . $name . "\", __new); __new; })");
}

# Emit `$Pkg::Name OP= VALUE` compound assign via perla_scalar_set, since
# perla_scalar_get is a function call (rvalue), not a C lvalue.
# `$op` is one of "+", "-", "*", "/", "%", "**", ".".
func _emit_pkg_scalar_compound(scalar $cg, scalar $node, str $op, scalar $value) void {
    my array @pn = _split_pkg_qual_name($node);
    my str $pkg = $pn[0];
    my str $name = $pn[1];
    emit($cg, "({ StradaValue *__cur = perla_scalar_get(\"" . $pkg . "\", \"" . $name . "\"); ");
    emit($cg, "StradaValue *__rhs = ");
    gen_expr($cg, $value);
    emit($cg, "; StradaValue *__nv = ");
    if ($op eq "+") {
        emit($cg, "strada_new_num(strada_to_num(__cur) + strada_to_num(__rhs))");
    } elsif ($op eq "-") {
        emit($cg, "strada_new_num(strada_to_num(__cur) - strada_to_num(__rhs))");
    } elsif ($op eq "*") {
        emit($cg, "strada_new_num(strada_to_num(__cur) * strada_to_num(__rhs))");
    } elsif ($op eq "/") {
        emit($cg, "strada_new_num(strada_to_num(__cur) / strada_to_num(__rhs))");
    } elsif ($op eq "%") {
        emit($cg, "STRADA_MAKE_TAGGED_INT(strada_to_int(__cur) % strada_to_int(__rhs))");
    } elsif ($op eq "**") {
        emit($cg, "strada_new_num(pow(strada_to_num(__cur), strada_to_num(__rhs)))");
    } elsif ($op eq ".") {
        emit($cg, "strada_concat_sv(__cur, __rhs)");
    } else {
        emit($cg, "strada_new_undef()");
    }
    emit($cg, "; perla_scalar_set(\"" . $pkg . "\", \"" . $name . "\", __nv); __nv; })");
}

# Emit EXPR forced into scalar context (runtime __perla_want_list = 0) and yield
# its value. The RHS of a scalar compound-assign (`$x ||= …`, `//=`, `&&=`) is
# scalar context in Perl, but perla otherwise gens the RHS in the ambient
# context — so a list-returning RHS like `caller()` leaked its 3-element list
# (package,file,line), and `$x ||= caller()` assigned the list (→ "3" / a joined
# string) instead of just the package. Real-world: Moose::Exporter's
# `$args{exporting_package} ||= caller()`.
func gen_scalar_ctx_expr(scalar $cg, scalar $expr) void {
    emit($cg, "({ int __sav_wl_sx = __perla_want_list; __perla_want_list = 0; StradaValue *__sxv = ");
    gen_expr($cg, $expr);
    emit($cg, "; __perla_want_list = __sav_wl_sx; __sxv; })");
}


# --- Helper: C-safe variable name ---
# Sanitize a Perl name to a valid C identifier (no v_ prefix)
func _is_c_ident(str $name) int {
    my int $n = length($name);
    if ($n == 0) { return 0; }
    my str $c0 = substr($name, 0, 1);
    if (!(($c0 ge "a" && $c0 le "z") || ($c0 ge "A" && $c0 le "Z") || $c0 eq "_")) { return 0; }
    my int $i = 1;
    while ($i < $n) {
        my str $c = substr($name, $i, 1);
        if (!(($c ge "a" && $c le "z") || ($c ge "A" && $c le "Z") || ($c ge "0" && $c le "9") || $c eq "_")) { return 0; }
        $i++;
    }
    return 1;
}

func safe_ident(str $name) str {
    # Strip non-printable bytes (chr(1), chr(2)) used internally by
    # the interpolation codegen as field separators. These leak into
    # identifier construction in some paths (e.g. complex interpolated
    # hash keys in DBIx::Class::Storage::DBI's bind-cache lookups);
    # without stripping them, gcc rejects the .pm.c with
    # `stray '\1' in program`.
    my str $safe = replace_all($name, chr(1), "_");
    $safe = replace_all($safe, chr(2), "_");
    $safe = replace_all($safe, "::", "_");
    $safe = replace_all($safe, "^", "_caret_");
    $safe = replace_all($safe, "]", "_rbrack_");
    $safe = replace_all($safe, "[", "_lbrack_");
    $safe = replace_all($safe, ":", "_colon_");
    $safe = replace_all($safe, "!", "_bang_");
    $safe = replace_all($safe, "?", "_qmark_");
    $safe = replace_all($safe, "$", "_dollar_");
    $safe = replace_all($safe, "@", "_at_");
    $safe = replace_all($safe, "-", "_dash_");
    $safe = replace_all($safe, "/", "_slash_");
    $safe = replace_all($safe, "\\", "_bslash_");
    $safe = replace_all($safe, ".", "_dot_");
    $safe = replace_all($safe, "+", "_plus_");
    $safe = replace_all($safe, " ", "_sp_");
    $safe = replace_all($safe, "|", "_pipe_");
    $safe = replace_all($safe, "#", "_hash_");
    $safe = replace_all($safe, "'", "_sq_");
    $safe = replace_all($safe, ";", "_semi_");
    $safe = replace_all($safe, "%", "_pct_");
    $safe = replace_all($safe, "&", "_amp_");
    $safe = replace_all($safe, "*", "_star_");
    $safe = replace_all($safe, "~", "_tilde_");
    $safe = replace_all($safe, "<", "_lt_");
    $safe = replace_all($safe, ",", "_comma_");
    $safe = replace_all($safe, ">", "_gt_");
    $safe = replace_all($safe, "=", "_eq_");
    $safe = replace_all($safe, "(", "_lp_");
    $safe = replace_all($safe, ")", "_rp_");
    $safe = replace_all($safe, "{", "_lb_");
    $safe = replace_all($safe, "}", "_rb_");
    $safe = replace_all($safe, "\"", "_dq_");
    $safe = replace_all($safe, "`", "_bt_");
    return $safe;
}

func c_var(str $name) str {
    return "v_" . safe_ident($name);
}

# Sigil-aware C variable names. `my $foo` and `my %foo` (or `my @foo`)
# in the same scope are separate Perl variables but would otherwise
# compile to the same C `v_foo`. File::Spec.pm trips this:
#   my %module = (MSWin32 => 'Win32', ...);
#   my $module = $module{$^O} || 'Unix';
# Scalars keep `v_NAME`; hashes append `__h`, arrays `__a`.
# Collision-only mangling: only append __h/__a for names that we detect
# are declared under multiple sigils (e.g., both `my %module` and
# `my $module` in the same file). Non-colliding names keep `v_NAME` so
# they match legacy-style access sites that haven't been sigil-migrated
# and so that `$config->{key}` accessing a `%config`-declared hash still
# reads the same C variable.
my hash %__perla_mangle_collisions = ();
my hash %__perla_seen_sigils = ();
# Per-named-sub local collisions (qname → hashref of var names).
# Captured during collection by save/reset/recurse/restore around sub bodies,
# so intra-sub collisions don't bleed into the file-scope map. At codegen
# time, gen_sub_def merges file-scope collisions with the sub's local
# collisions before emitting body, then restores file-scope on exit.
my hash %__perla_sub_collisions = ();
my hash %__perla_file_collisions_snapshot = ();

func c_var_h(str $name) str {
    if (exists($__perla_mangle_collisions{$name})) {
        return "v_" . safe_ident($name) . "__h";
    }
    # `%INC` (the loaded-modules hash) is distinct from `@INC` (the
    # require-search-paths array). Route to a separate file-scope
    # static backed by the runtime's g_INC_hash so `keys %INC`,
    # `exists $INC{"X.pm"}` etc. reflect what `use`/`require` actually
    # loaded.
    if ($name eq "INC") {
        return "v_INC__h";
    }
    return c_var($name);
}

func c_var_a(str $name) str {
    if (exists($__perla_mangle_collisions{$name})) {
        return "v_" . safe_ident($name) . "__a";
    }
    return c_var($name);
}

func _perla_record_var_sigil(str $name, str $sigil) void {
    if (length($name) == 0) { return; }
    if (!exists($__perla_seen_sigils{$name})) {
        $__perla_seen_sigils{$name} = $sigil;
    } elsif ("" . $__perla_seen_sigils{$name} ne $sigil) {
        $__perla_mangle_collisions{$name} = 1;
    }
}

func _perla_reset_mangle_collisions() void {
    %__perla_mangle_collisions = ();
    %__perla_seen_sigils = ();
    %__perla_sub_collisions = ();
    %__perla_file_collisions_snapshot = ();
}

# Accessor for the module-private mangle-collision table, so extracted
# sub-modules (e.g. Perla::CodeGen::Call) can query it without direct
# access to the package-level `%__perla_mangle_collisions` global.
func _perla_has_mangle_collision(str $name) int {
    return exists($__perla_mangle_collisions{$name}) ? 1 : 0;
}

# Shallow-clone a hash through a hashref, returning a hashref of (key=>1) entries.
# For collision-set save/restore where presence is what matters.
func _perla_clone_hash(scalar $href) scalar {
    my hash %out = ();
    if (defined($href)) {
        my array @ks = keys(%{$href});
        my int $i = 0;
        while ($i < scalar(@ks)) {
            my str $k = $ks[$i];
            $out{$k} = 1;
            $i++;
        }
    }
    return \%out;
}

# Shallow-clone a hash preserving values (for seen_sigils which stores
# string sigils that need to round-trip).
func _perla_clone_hash_with_vals(scalar $href) scalar {
    my hash %out = ();
    if (defined($href)) {
        my array @ks = keys(%{$href});
        my int $i = 0;
        while ($i < scalar(@ks)) {
            my str $k = $ks[$i];
            my str $v = "" . $href->{$k};
            $out{$k} = $v;
            $i++;
        }
    }
    return \%out;
}

# Restore %__perla_seen_sigils from a saved hashref (preserves sigil string values).
func _perla_restore_seen_sigils(scalar $saved) void {
    %__perla_seen_sigils = ();
    if (defined($saved)) {
        my array @ks = keys(%{$saved});
        my int $i = 0;
        while ($i < scalar(@ks)) {
            my str $k = $ks[$i];
            my str $v = "" . $saved->{$k};
            $__perla_seen_sigils{$k} = $v;
            $i++;
        }
    }
}

# Restore %__perla_mangle_collisions from a saved hashref (presence-only).
func _perla_restore_collisions_inplace(scalar $saved) void {
    %__perla_mangle_collisions = ();
    if (defined($saved)) {
        my array @ks = keys(%{$saved});
        my int $i = 0;
        while ($i < scalar(@ks)) {
            my str $k = $ks[$i];
            $__perla_mangle_collisions{$k} = 1;
            $i++;
        }
    }
}

# Activate a sub's effective collision map: file-scope ∪ sub-local.
# Returns the previous map (as a hashref) so the caller can restore on exit.
func perla_activate_sub_collisions(str $qname) scalar {
    my scalar $saved = _perla_clone_hash(\%__perla_mangle_collisions);
    %__perla_mangle_collisions = ();
    my array @fks = keys(%__perla_file_collisions_snapshot);
    my int $fi = 0;
    while ($fi < scalar(@fks)) {
        my str $fk = $fks[$fi];
        $__perla_mangle_collisions{$fk} = 1;
        $fi++;
    }
    # Union sub-local
    if (length($qname) > 0 && exists($__perla_sub_collisions{$qname})) {
        my scalar $sub_local = $__perla_sub_collisions{$qname};
        my array @sks = keys(%{$sub_local});
        my int $si = 0;
        while ($si < scalar(@sks)) {
            my str $sk = $sks[$si];
            $__perla_mangle_collisions{$sk} = 1;
            $si++;
        }
    }
    return $saved;
}

func perla_restore_collisions(scalar $saved_ref) void {
    %__perla_mangle_collisions = ();
    if (defined($saved_ref)) {
        my array @ks = keys(%{$saved_ref});
        my int $i = 0;
        while ($i < scalar(@ks)) {
            my str $k = $ks[$i];
            $__perla_mangle_collisions{$k} = 1;
            $i++;
        }
    }
}

# Snapshot the current %__perla_mangle_collisions as the file-scope view.
func _perla_snapshot_file_collisions() void {
    %__perla_file_collisions_snapshot = ();
    my array @ks = keys(%__perla_mangle_collisions);
    my int $i = 0;
    while ($i < scalar(@ks)) {
        my str $k = $ks[$i];
        $__perla_file_collisions_snapshot{$k} = 1;
        $i++;
    }
}

# Pick C name from a var-decl sigil string ("SCALAR_VAR"/"HASH_VAR"/"ARRAY_VAR")
func c_var_for_vtype(str $vtype, str $name) str {
    if ($vtype eq "HASH_VAR") { return c_var_h($name); }
    if ($vtype eq "ARRAY_VAR") { return c_var_a($name); }
    return c_var($name);
}

# Pick C name from an AST var-access node's numeric type
func _c_var_for_node(scalar $node) str {
    if (!defined($node)) { return c_var(""); }
    my str $name = defined($node->{"name"}) ? $node->{"name"} : "";
    if (defined($node->{"type"})) {
        if ($node->{"type"} == Perla::AST::N_HASH_VAR()) { return c_var_h($name); }
        if ($node->{"type"} == Perla::AST::N_ARRAY_VAR()) { return c_var_a($name); }
    }
    return c_var($name);
}

func has_perl_var(str $s) int {
    my int $i = 0;
    my int $len = length($s);
    while ($i < $len - 1) {
        # Skip over backslash-escaped chars (e.g. \$ is a literal $).
        if (substr($s, $i, 1) eq "\\" && $i + 1 < $len) {
            $i = $i + 2;
            next;
        }
        if (substr($s, $i, 1) eq "$") {
            my str $next = substr($s, $i + 1, 1);
            if (($next ge "a" && $next le "z") || ($next ge "A" && $next le "Z") || $next eq "_") {
                return 1;
            }
            # `${...}` block form — also a variable interpolation.
            # Without this, code like `\"${pref}select\"` was treated as
            # a literal hash key and lookups against it always missed.
            # Specifically broke DBIx::Class::ResultSet::_normalize_selection
            # which uses `$attrs->{\"${pref}select\"}` to namespace its
            # +select / select keys — perla stored everything under one
            # bogus key \"${pref}select\" and the normalize loop ran with
            # the wrong attrs.
            if ($next eq "{") {
                return 1;
            }
            # Special scalars: $@, $!, $/, $\, $,, $;, $", $&, $`, $', $+, $|, $0
            # mirror the lexer's special-var list and the interp tokenizer's
            # branch. Without this, "[F] $@" got concat-optimized as a literal
            # C string (the @ wasn't ident-letter-or-underscore) so $@ never
            # got substituted — Class::C3::Componentised::ensure_class_loaded
            # passed an empty $@ to throw_exception, producing the
            # `{UNKNOWN}: at line` bizowie BZ:6 plateau.
            #
            # NOTE: $1..$9 are deliberately NOT in this list. They are regex
            # capture vars and need to pass through to PCRE2 as `$1`..`$9` in
            # s///-replacement strings (PCRE2 substitutes them itself). Marking
            # them as "has perl var" routes the replacement through
            # _gen_interp_c_str, which expands `$1` via Perla's variable
            # lookup (v_1 — usually undeclared/empty) before PCRE2 ever sees
            # it. The bare-string `$1` in a regular interpolation context is
            # already handled by the tokenizer's $1-$9 branch, which routes
            # to perla_capture_var().
            if ($next eq "@" || $next eq "!" || $next eq "/" || $next eq "\\" ||
                $next eq "," || $next eq ";" || $next eq "\"" || $next eq "&" ||
                $next eq "`" || $next eq "'" || $next eq "+" || $next eq "0" ||
                $next eq "|" || $next eq ".") {
                return 1;
            }
            # $$ (PID), $? (last child exit), $] (perl version),
            # $<, $>, $(, $) (UIDs/GIDs). Without these, interpolating
            # `"pid-$$"` left the key literal "pid-$$" and the hash
            # lookup missed.
            if ($next eq "\$" || $next eq "?" || $next eq "]" ||
                $next eq "<" || $next eq ">" || $next eq "(" || $next eq ")") {
                return 1;
            }
        }
        # `@var` array interpolation — same logic.
        if (substr($s, $i, 1) eq "@") {
            my str $next = substr($s, $i + 1, 1);
            if (($next ge "a" && $next le "z") || ($next ge "A" && $next le "Z") || $next eq "_" || $next eq "{") {
                return 1;
            }
        }
        $i = $i + 1;
    }
    return 0;
}

