                emit($cg, "strada_tied_hash_clear(__h_old_assign); ");
                emit($cg, "StradaArray *__tha = __hinit_t ? strada_deref_array(__hinit_t) : NULL; ");
                emit($cg, "if (__tha) for (int __thi = 0; __thi + 1 < (int)strada_array_length(__tha); __thi += 2) { ");
                emit($cg, "char *__thk = strada_to_str(strada_array_get(__tha, __thi)); ");
                emit($cg, "strada_hv_store(__h_old_assign, __thk, strada_array_get(__tha, __thi + 1)); free(__thk); } ");
                emit($cg, "if (__hinit_t && !STRADA_IS_TAGGED_INT(__hinit_t) && __hinit_t->type != STRADA_HASH) strada_decref(__hinit_t); ");
                emit($cg, "__h_result = __h_old_assign; } else { ");
                gen_expr($cg, $target);
