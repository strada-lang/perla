        # with a fresh strada_new_str() would lose the bless metadata
        # so `ref($@) eq 'Regexp'` would fail.
        emit($cg, "  if (__dlen > 0 && __dv->value.pv[__dlen - 1] != '\\n' && !perla_blessed(__dv)) { ");
        emit($cg, "    const char *__df = (perla_call_depth > 0) ? (perla_call_stack[perla_call_depth - 1].file ?: \"-\") : \"-\"; ");
        emit($cg, "    char __dbuf[1024]; snprintf(__dbuf, sizeof(__dbuf), \"%s at %s line " . $die_line . ".\\n\", __dv->value.pv, __df); ");
        emit($cg, "    strada_decref(__dv); __dv = strada_new_str(__dbuf); ");
        emit($cg, "  } ");
        # Non-string non-ref non-undef (tagged int, number) — stringify
        # and append the location, matching Perl's `die 42` → "42 at file
        # line N.\n" behavior. Without this, `die 42` produced just "42"
        # in $@.
