                gen_expr($cg, $node->{"value"});
                emit($cg, "; StradaValue *__ce_new = strada_concat_sv(__ce_tg, __ce_rv); ");
                # strada_concat_sv only READS its operands (never consumes
                # them), so an owned RHS temp — `$s .= "x$i"`, `.= func()` —
                # leaked every iteration. Release it once the concat has run.
                if (expr_is_borrowed($node->{"value"}) == 0) {
                    emit($cg, "if (__ce_rv) strada_decref(__ce_rv); ");
                }
                emit($cg, "if (__builtin_expect(__ce_tg && !STRADA_IS_TAGGED_INT(__ce_tg) && __ce_tg->meta && __ce_tg->meta->is_tied, 0)) { ");
                emit($cg, "  strada_tied_scalar_store(__ce_tg, __ce_new); ");
                emit($cg, "} else { ");
                emit($cg, "  if (__ce_tg) strada_decref(__ce_tg); ");
                gen_expr($cg, $node->{"target"});
                emit($cg, " = __ce_new; ");
                emit($cg, "  strada_incref(__ce_new); ");
                emit($cg, "} __ce_new; })");
            }
        }
        return;
    }
    if ($op eq "//=") {
        # `$@ //= V` — same lazy-init-wrapper-is-not-lvalue problem as ||= below.
        if ($target_type == Perla::AST::N_SCALAR_VAR()
            && defined($target->{"name"}) && $target->{"name"} eq "@") {
            emit($cg, "({ if (!perla_eval_error) { perla_eval_error = strada_new_str(\"\"); strada_incref(perla_eval_error); } ");
            emit($cg, "if (!strada_defined_bool(perla_eval_error)) { ");
            emit($cg, "if (perla_eval_error) strada_decref(perla_eval_error); perla_eval_error = ");
            gen_expr($cg, $node->{"value"});
            emit($cg, "; } perla_eval_error; })");
            return;
        }
        if ($target_type == Perla::AST::N_HASH_ELEM() || $target_type == Perla::AST::N_ARROW_HASH()) {
            _gen_hash_compound_assign($cg, $target, "//", $node->{"value"});
        } elsif ($target_type == Perla::AST::N_ARRAY_ELEM() || $target_type == Perla::AST::N_ARROW_ARRAY()) {
            # `$arr[i] //= V` / `$ar->[i] //= V` — same short-circuit
            # semantics as for hash elems; route to the array compound
            # assign which knows how to lvalue-store back to the array.
            # Without this, `gen_expr(target) = …` for array elem isn't
            # a C lvalue and we fell through to the "non-lvalue" die path.
            _gen_array_compound_assign($cg, $target, "//", $node->{"value"});
        } elsif (_is_pkg_qualified_scalar($target) == 1) {
            # `$Pkg::Name //= V` — $Pkg::Name reads via perla_scalar_get (a
            # function call, NOT a C lvalue), so the standard `LHS = NEW`
            # form fails to compile. Route writes through perla_scalar_set.
            # Concrete victim: DBI.pm's `$DBI::PurePerl //= 0` and similar
            # `$Pkg::var //= default` patterns common in module init code.
            my array @pn = _split_pkg_qual_name($target);
            my str $pkg = $pn[0];
            my str $name = $pn[1];
            emit($cg, "({ StradaValue *__l = perla_scalar_get(\"" . $pkg . "\", \"" . $name . "\"); ");
            emit($cg, "if (!strada_defined_bool(__l)) { perla_scalar_set(\"" . $pkg . "\", \"" . $name . "\", ");
            gen_expr($cg, $node->{"value"});
            emit($cg, "); __l = perla_scalar_get(\"" . $pkg . "\", \"" . $name . "\"); } __l; })");
        } elsif (Perla::CodeGen::Predicate::is_simple_lvalue($target_type) == 1) {
            emit($cg, "({ StradaValue *__l = ");
            gen_expr($cg, $node->{"target"});
            emit($cg, "; if (!strada_defined_bool(__l)) { ");
            gen_expr($cg, $node->{"target"});
            emit($cg, " = ");
            gen_expr($cg, $node->{"value"});
            emit($cg, "; } ");
            gen_expr($cg, $node->{"target"});
            emit($cg, "; })");
        } else {
            # Non-lvalue target (e.g. //= on a call result, anon hash, etc.).
            # Real Perl raises a compile-time error for these. At runtime we
            # die with a clear message so the author knows to fix the source.
            emit($cg, "({ strada_die(\"%s\", \"Can't modify non-lvalue in //= assignment\"); strada_new_undef(); })");
        }
        return;
    }
    # ||= : assign if falsy
    if ($op eq "||=") {
        # `$@ ||= V` — the N_SCALAR_VAR{name="@"} read path emits a lazy-init
        # statement expression `({ if (!perla_eval_error) ... perla_eval_error; })`
        # which is not a C lvalue, so the standard simple-lvalue compound-assign
        # produced `(STMT-EXPR) = V` and failed to compile (DBI.pm uses this
        # idiom in install_method). Use the global directly for the assignment.
        if ($target_type == Perla::AST::N_SCALAR_VAR()
            && defined($target->{"name"}) && $target->{"name"} eq "@") {
            emit($cg, "({ if (!perla_eval_error) { perla_eval_error = strada_new_str(\"\"); strada_incref(perla_eval_error); } ");
            emit($cg, "if (!perla_to_bool(perla_eval_error)) { ");
            emit($cg, "if (perla_eval_error) strada_decref(perla_eval_error); perla_eval_error = ");
            gen_expr($cg, $node->{"value"});
            emit($cg, "; } perla_eval_error; })");
            return;
        }
        if ($target_type == Perla::AST::N_HASH_ELEM() || $target_type == Perla::AST::N_ARROW_HASH()) {
            _gen_hash_compound_assign($cg, $target, "||", $node->{"value"});
        } elsif ($target_type == Perla::AST::N_ARRAY_ELEM() || $target_type == Perla::AST::N_ARROW_ARRAY()) {
            # $a[i] ||= v  /  $ref->[i] ||= v — fetch current, assign only
            # when falsy, yield new value. Used by YAML::Loader:
            # `$self->offset->[$self->level] ||= 0`.
            emit($cg, "({ StradaArray *__la_av = strada_deref_array(");
            if ($target_type == Perla::AST::N_ARRAY_ELEM()) {
                gen_expr($cg, $target->{"array"});
            } else {
                gen_expr($cg, $target->{"object"});
            }
            emit($cg, "); int __la_idx = (int)strada_to_int(");
            gen_expr($cg, $target->{"index"});
            emit($cg, "); if (__la_idx < 0 && __la_av) __la_idx += strada_array_length(__la_av); ");
            emit($cg, "StradaValue *__la_cur = __la_av ? strada_array_get(__la_av, __la_idx) : strada_new_undef(); ");
            emit($cg, "StradaValue *__la_r; if (perla_to_bool(__la_cur)) { __la_r = __la_cur; } else { __la_r = ");
            gen_expr($cg, $node->{"value"});
            emit($cg, "; if (__la_av) strada_array_set(__la_av, __la_idx, __la_r); } __la_r; })");
        } elsif (_is_pkg_qualified_scalar($target) == 1) {
            # `$Pkg::Name ||= V` — same lvalue issue as //= above.
            my array @pn = _split_pkg_qual_name($target);
            my str $pkg = $pn[0];
            my str $name = $pn[1];
            emit($cg, "({ StradaValue *__l = perla_scalar_get(\"" . $pkg . "\", \"" . $name . "\"); ");
            emit($cg, "if (!perla_to_bool(__l)) { perla_scalar_set(\"" . $pkg . "\", \"" . $name . "\", ");
            gen_expr($cg, $node->{"value"});
            emit($cg, "); __l = perla_scalar_get(\"" . $pkg . "\", \"" . $name . "\"); } __l; })");
        } elsif (Perla::CodeGen::Predicate::is_simple_lvalue($target_type) == 1) {
            emit($cg, "({ StradaValue *__l = ");
            gen_expr($cg, $target);
            emit($cg, "; if (!perla_to_bool(__l)) { ");
            gen_expr($cg, $target);
            emit($cg, " = ");
            gen_expr($cg, $node->{"value"});
            emit($cg, "; } ");
            gen_expr($cg, $target);
            emit($cg, "; })");
        } else {
            emit($cg, "({ strada_die(\"%s\", \"Can't modify non-lvalue in ||= assignment\"); strada_new_undef(); })");
        }
        return;
    }
    # &&= : assign if truthy
    if ($op eq "&&=") {
        if (_is_pkg_qualified_scalar($target) == 1) {
            # `$Pkg::Name &&= V` — same lvalue issue as //= / ||= above.
            my array @pn = _split_pkg_qual_name($target);
            my str $pkg = $pn[0];
            my str $name = $pn[1];
            emit($cg, "({ StradaValue *__l = perla_scalar_get(\"" . $pkg . "\", \"" . $name . "\"); ");
            emit($cg, "if (perla_to_bool(__l)) { perla_scalar_set(\"" . $pkg . "\", \"" . $name . "\", ");
            gen_expr($cg, $node->{"value"});
            emit($cg, "); __l = perla_scalar_get(\"" . $pkg . "\", \"" . $name . "\"); } __l; })");
            return;
        }
        emit($cg, "({ StradaValue *__l = ");
        gen_expr($cg, $target);
        emit($cg, "; if (perla_to_bool(__l)) { ");
        gen_expr($cg, $target);
        emit($cg, " = ");
        gen_expr($cg, $node->{"value"});
        emit($cg, "; } ");
        gen_expr($cg, $target);
        emit($cg, "; })");
        return;
    }
    # Fallback: plain assignment
    gen_expr($cg, $target);
    emit($cg, " = ");
    gen_expr($cg, $node->{"value"});
}

# --- Scalar-deref compound assignment: $$ref OP= val / ${expr} OP= val ---
func _gen_deref_scalar_compound_assign(scalar $cg, scalar $target, str $op, scalar $value) void {
    emit($cg, "({ StradaValue *__dc_ref = ");
    gen_expr($cg, $target->{"ref"});
    # Read the current target: for slot refs (e.g. \$arr[i]) the target
    # is *(StradaValue **)value.ptr; for heap refs it's value.rv. The
    # old code always read value.rv, which for slot refs is value.ptr
    # cast to a pointer — a corrupt StradaValue address that segfaulted
    # on the first deref. perla_scalar_deref_assign already handles both
    # ref types for the write side.
    emit($cg, "; StradaValue *__dc_cur; ");
    emit($cg, "if (__dc_ref && !STRADA_IS_TAGGED_INT(__dc_ref) && __dc_ref->type == STRADA_REF) { ");
    emit($cg, "  if (strada_is_slot_ref(__dc_ref)) { ");
    emit($cg, "    StradaValue **__dc_slot = (StradaValue**)__dc_ref->value.ptr; ");
    emit($cg, "    __dc_cur = (__dc_slot && *__dc_slot) ? *__dc_slot : strada_undef_static(); ");
    emit($cg, "  } else { __dc_cur = __dc_ref->value.rv ? __dc_ref->value.rv : strada_undef_static(); } ");
    emit($cg, "} else { __dc_cur = strada_undef_static(); } ");
    emit($cg, "StradaValue *__dc_rhs = ");
    gen_expr($cg, $value);
    emit($cg, "; StradaValue *__dc_new = ");
    if ($op eq "+") {
        emit($cg, "strada_new_num(strada_to_num(__dc_cur) + strada_to_num(__dc_rhs))");
    } elsif ($op eq "-") {
        emit($cg, "strada_new_num(strada_to_num(__dc_cur) - strada_to_num(__dc_rhs))");
    } elsif ($op eq "*") {
        emit($cg, "strada_new_num(strada_to_num(__dc_cur) * strada_to_num(__dc_rhs))");
    } elsif ($op eq "/") {
        emit($cg, "strada_new_num(strada_to_num(__dc_cur) / strada_to_num(__dc_rhs))");
    } elsif ($op eq "%") {
        emit($cg, "STRADA_MAKE_TAGGED_INT(strada_to_int(__dc_cur) % strada_to_int(__dc_rhs))");
    } elsif ($op eq "**") {
        emit($cg, "strada_new_num(pow(strada_to_num(__dc_cur), strada_to_num(__dc_rhs)))");
    } else {
        emit($cg, "strada_concat_sv(__dc_cur, __dc_rhs)");
    }
    emit($cg, "; perla_scalar_deref_assign(__dc_ref, __dc_new); ");
    # Release the owned RHS temp (the op only read it). __dc_new is left as the
    # yielded value; perla_scalar_deref_assign's incref behaviour differs
    # between slot-refs (increfs) and heap-refs (copies in place), so it is not
    # uniformly safe to drop a create-ref here — `$$ref OP=` is rare and
    # expr_is_borrowed reports it borrowed (consumers over-incref at worst).
    if (expr_is_borrowed($value) == 0) { emit($cg, "if (__dc_rhs) strada_decref(__dc_rhs); "); }
    emit($cg, "__dc_new; })");
}

# --- Array-element compound assignment: $arr[i] OP= val / $ref->[i] OP= val ---
func _gen_array_compound_assign(scalar $cg, scalar $target, str $op, scalar $value) void {
    my int $tt = $target->{"type"};
    emit($cg, "({ StradaArray *__ca_av = strada_deref_array(");
    # Sigil-array form (`$arr[i] op= V`) accesses @arr. With name collision
    # `c_var_a` handles the v_NAME → v_NAME__a remapping; plain gen_expr
    # of N_SCALAR_VAR returns v_NAME (the scalar). Mirrors the explicit
    # branch in the `+=` codegen above. Without this, `$sum[0] -= V` etc.
    # silently updated the wrong variable's deref.
    my scalar $ca_arr_node = ($tt == Perla::AST::N_ARRAY_ELEM()) ? $target->{"array"} : $target->{"object"};
    my int $ca_is_arrow = 0;
    if (defined($target->{"is_explicit_arrow"}) && $target->{"is_explicit_arrow"} == 1) { $ca_is_arrow = 1; }
    if ($ca_is_arrow == 0
        && defined($ca_arr_node) && $ca_arr_node->{"type"} == Perla::AST::N_SCALAR_VAR()
        && defined($ca_arr_node->{"name"}) && $ca_arr_node->{"name"} eq "_") {
        emit($cg, "perla_at_");
    } elsif ($ca_is_arrow == 0
        && defined($ca_arr_node) && $ca_arr_node->{"type"} == Perla::AST::N_SCALAR_VAR()
        && defined($ca_arr_node->{"name"}) && index($ca_arr_node->{"name"}, "::") > 0) {
        # $Pkg::arr[i] OP= V — fetch the ARRAY slot of the stash glob.
        my array @capn = _split_pkg_qual_name($ca_arr_node);
        emit($cg, "perla_array_get(\"" . $capn[0] . "\", \"" . $capn[1] . "\")");
    } elsif ($ca_is_arrow == 0
        && defined($ca_arr_node) && $ca_arr_node->{"type"} == Perla::AST::N_SCALAR_VAR()
        && defined($ca_arr_node->{"name"}) && length($ca_arr_node->{"name"}) > 0
        && index($ca_arr_node->{"name"}, "::") < 0) {
        emit($cg, c_var_a($ca_arr_node->{"name"}));
    } else {
        gen_expr($cg, $ca_arr_node);
    }
    emit($cg, "); int __ca_idx = (int)strada_to_int(");
    gen_expr($cg, $target->{"index"});
    emit($cg, "); if (__ca_idx < 0 && __ca_av) __ca_idx += strada_array_length(__ca_av); ");
    emit($cg, "StradaValue *__ca_cur = strada_array_get(__ca_av, __ca_idx); ");
    # //= / ||= — short-circuit: only evaluate RHS and store back when the
    # current value fails the defined / truthy check. Without this branch,
    # `$cache[$i] //= EXPR` fell through to the standard "Can't modify
    # non-lvalue" path because `gen_expr(target) = …` doesn't produce a
    # C lvalue for array elements.
    if ($op eq "//" || $op eq "||") {
        my str $tcond = "perla_to_bool";
        if ($op eq "//") { $tcond = "strada_defined_bool"; }
        emit($cg, "StradaValue *__ca_new = " . $tcond . "(__ca_cur) ? __ca_cur : ");
        gen_expr($cg, $value);
        emit($cg, "; if (__ca_new != __ca_cur) { strada_array_set(__ca_av, __ca_idx, __ca_new); } __ca_new; })");
        return;
    }
    emit($cg, "StradaValue *__ca_rhs = ");
    gen_expr($cg, $value);
    emit($cg, "; StradaValue *__ca_new = ");
    if ($op eq "+") {
        emit($cg, "strada_new_num(strada_to_num(__ca_cur) + strada_to_num(__ca_rhs))");
    } elsif ($op eq "-") {
        emit($cg, "strada_new_num(strada_to_num(__ca_cur) - strada_to_num(__ca_rhs))");
    } elsif ($op eq "*") {
        emit($cg, "strada_new_num(strada_to_num(__ca_cur) * strada_to_num(__ca_rhs))");
    } elsif ($op eq "/") {
        emit($cg, "strada_new_num(strada_to_num(__ca_cur) / strada_to_num(__ca_rhs))");
    } elsif ($op eq "%") {
        emit($cg, "STRADA_MAKE_TAGGED_INT(strada_to_int(__ca_cur) % strada_to_int(__ca_rhs))");
    } elsif ($op eq "**") {
        emit($cg, "strada_new_num(pow(strada_to_num(__ca_cur), strada_to_num(__ca_rhs)))");
    } else {
        emit($cg, "strada_concat_sv(__ca_cur, __ca_rhs)");
    }
    emit($cg, "; strada_array_set(__ca_av, __ca_idx, __ca_new); ");
    # Release the owned RHS temp (the op only read it) — it was previously
    # emitted inline and leaked every iteration. __ca_new is yielded OWNED
    # (rc=2: the create-ref + strada_array_set's incref); consumers take the
    # create-ref and the void-statement emitter decrefs it. __ca_cur came from
    # strada_array_get (borrowed) and was consumed by the op above.
    if (expr_is_borrowed($value) == 0) { emit($cg, "if (__ca_rhs) strada_decref(__ca_rhs); "); }
    emit($cg, "__ca_new; })");
}

# --- Function call ---
# --- Hash compound assignment: $h{k} += val ---
# Postfix $h{k}++ / $h{k}-- — return OLD value, then increment/decrement in
# place. `$op` is "+" or "-". Perl's postfix semantics: `$seen{$n}++`
# returns 0 the first time and 1 the second, which is critical for
# idioms like `die "dup" if $seen{$k}++`. Earlier we routed this through
# `_gen_hash_compound_assign` which returns the NEW value — so the dup
# check fired on the very first increment.
func _gen_hash_postfix_inc_dec(scalar $cg, scalar $target, str $op) void {
    my int $tt = $target->{"type"};
    my scalar $hash_expr = undef;
    my scalar $key_expr = undef;
    my int $hash_ctx = 0;
    if ($tt == Perla::AST::N_HASH_ELEM()) {
        $hash_expr = $target->{"hash"};
        $key_expr = $target->{"key"};
        $hash_ctx = 1;
    } elsif ($tt == Perla::AST::N_ARROW_HASH()) {
        $hash_expr = $target->{"object"};
        $key_expr = $target->{"key"};
        # `$h{k}` (no arrow) parses as N_ARROW_HASH without is_explicit_arrow.
        if (!defined($target->{"is_explicit_arrow"}) || $target->{"is_explicit_arrow"} != 1) {
            $hash_ctx = 1;
        }
    }
    my int $key_is_lit = 0;
    if (defined($key_expr) && $key_expr->{"type"} == Perla::AST::N_STR_LIT()) { $key_is_lit = 1; }
    # Single-probe lvalue RMW: ++/-- never resize beyond the existing slot, and
    # __nv is an immortal tagged int, so the slot pointer stays valid. Postfix
    # returns the OLD value, so we transfer the slot's ownership of the old
    # value into the return (no incref) rather than fetch_owned's extra ref.
    # strada_hv_fetch_lvalue_sv* returns NULL for tied/non-hash → fallback
    # branch keeps fetch/store so tie FETCH/STORE magic still fires.
    if ($key_is_lit == 1) {
        my str $lit_key = Perla::CodeGen::Escape::escape_c_str($key_expr->{"value"});
        emit($cg, "({ StradaValue *__ch = ");
        _gen_autoviv_outer_hash($cg, $hash_expr, $hash_ctx);
        emit($cg, "; StradaValue **__slot = strada_hv_fetch_lvalue_sv(__ch, \"" . $lit_key . "\", 1); StradaValue *__cv; ");
        emit($cg, "if (__slot) { __cv = *__slot; *__slot = STRADA_MAKE_TAGGED_INT(strada_to_int(__cv) " . $op . " 1); } ");
        emit($cg, "else { __cv = strada_hv_fetch_owned(__ch, \"" . $lit_key . "\"); strada_hv_store(__ch, \"" . $lit_key . "\", STRADA_MAKE_TAGGED_INT(strada_to_int(__cv) " . $op . " 1)); } ");
        # perl's postfix ++/-- numifies an undef old value to 0 in the result.
        emit($cg, "((__cv && !STRADA_IS_TAGGED_INT(__cv) && __cv->type == STRADA_UNDEF) ? (strada_decref(__cv), STRADA_MAKE_TAGGED_INT(0)) : __cv); })");
    } else {
        # When the key expr is an owned temp (e.g. a string-literal key that
        # parses to a non-N_STR_LIT node), __ck_sv must be freed — the borrowed
        # case (a bare scalar var, the common path) skips the decref entirely.
        my int $key_owned = 0;
        if (expr_is_borrowed($key_expr) == 0) { $key_owned = 1; }
        emit($cg, "({ StradaValue *__ck_sv = ");
        gen_expr($cg, $key_expr);
        emit($cg, "; StradaValue *__ch = ");
        _gen_autoviv_outer_hash($cg, $hash_expr, $hash_ctx);
        emit($cg, "; StradaValue **__slot = strada_hv_fetch_lvalue_sv_key(__ch, __ck_sv, 1); StradaValue *__cv; ");
        emit($cg, "if (__slot) { __cv = *__slot; *__slot = STRADA_MAKE_TAGGED_INT(strada_to_int(__cv) " . $op . " 1); } ");
        emit($cg, "else { __cv = strada_hv_fetch_owned_sv(__ch, __ck_sv); strada_hv_store_sv(__ch, __ck_sv, STRADA_MAKE_TAGGED_INT(strada_to_int(__cv) " . $op . " 1)); } ");
        # perl's postfix ++/-- numifies an undef old value to 0 in the result.
        emit($cg, "StradaValue *__res = (__cv && !STRADA_IS_TAGGED_INT(__cv) && __cv->type == STRADA_UNDEF) ? (strada_decref(__cv), STRADA_MAKE_TAGGED_INT(0)) : __cv; ");
        if ($key_owned == 1) { emit($cg, "strada_decref(__ck_sv); "); }
        emit($cg, "__res; })");
    }
}

# Emit `StradaValue *__nv = <op of __cv and the RHS>;` for hash/array-element
# compound assigns. For the non-short-circuit ops the owned RHS temp is
# captured into __hrhs and released after use (it was previously emitted
# inline and leaked). The short-circuit //=/||= must evaluate the RHS lazily,
# so they keep it inline (and only allocate when the branch is taken). __cv
# (the current owned value) must already be in scope.
func _emit_hash_cmpd_nv(scalar $cg, str $op, scalar $value) void {
    if ($op eq "//") {
        emit($cg, "StradaValue *__nv = strada_defined_bool(__cv) ? __cv : ");
        gen_expr($cg, $value);
        emit($cg, "; ");
        return;
    }
    if ($op eq "||") {
        emit($cg, "StradaValue *__nv = perla_to_bool(__cv) ? __cv : ");
        gen_expr($cg, $value);
        emit($cg, "; ");
        return;
    }
    emit($cg, "StradaValue *__hrhs = ");
    gen_expr($cg, $value);
    emit($cg, "; StradaValue *__nv = ");
    if ($op eq ".") {
        emit($cg, "strada_concat_sv(__cv, __hrhs)");
    } elsif ($op eq "%") {
        emit($cg, "STRADA_MAKE_TAGGED_INT(strada_to_int(__cv) % strada_to_int(__hrhs))");
    } elsif ($op eq "**") {
        emit($cg, "strada_new_num(pow(strada_to_num(__cv), strada_to_num(__hrhs)))");
    } elsif ($op eq "|" || $op eq "&" || $op eq "^" || $op eq "<<" || $op eq ">>") {
        emit($cg, "STRADA_MAKE_TAGGED_INT(strada_to_int(__cv) " . $op . " strada_to_int(__hrhs))");
    } else {
        if (Perla::CodeGen::Predicate::expr_is_int($value) == 1) {
            emit($cg, "STRADA_MAKE_TAGGED_INT(strada_to_int(__cv) " . $op . " strada_to_int(__hrhs))");
        } else {
            emit($cg, "strada_new_num(strada_to_num(__cv) " . $op . " strada_to_num(__hrhs))");
        }
    }
    emit($cg, "; ");
    if (expr_is_borrowed($value) == 0) {
        emit($cg, "if (__hrhs) strada_decref(__hrhs); ");
    }
}

func _gen_hash_compound_assign(scalar $cg, scalar $target, str $op, scalar $value) void {
    my int $tt = $target->{"type"};
    my scalar $hash_expr = undef;
    my scalar $key_expr = undef;
    my int $hash_ctx = 0;
    if ($tt == Perla::AST::N_HASH_ELEM()) {
        $hash_expr = $target->{"hash"};
        $key_expr = $target->{"key"};
        $hash_ctx = 1;
    } elsif ($tt == Perla::AST::N_ARROW_HASH()) {
        $hash_expr = $target->{"object"};
        $key_expr = $target->{"key"};
        if (!defined($target->{"is_explicit_arrow"}) || $target->{"is_explicit_arrow"} != 1) {
            $hash_ctx = 1;
        }
    }
    my int $key_is_lit = 0;
    if (defined($key_expr) && $key_expr->{"type"} == Perla::AST::N_STR_LIT()) { $key_is_lit = 1; }
    # A side-effect-free RHS cannot resize/mutate the hash mid-statement, so the
    # value-slot pointer stays valid across the read-modify-write — enabling the
    # single-probe lvalue path (vs fetch+store's two probes + two re-hashes).
    my int $rhs_safe = 0;
    if (defined($value)) {
        my int $vt = $value->{"type"};
        if ($vt == Perla::AST::N_INT_LIT() || $vt == Perla::AST::N_NUM_LIT()
            || $vt == Perla::AST::N_STR_LIT() || $vt == Perla::AST::N_SCALAR_VAR()) {
            $rhs_safe = 1;
        }
    }
    if ($key_is_lit == 1) {
        my str $lit_key = Perla::CodeGen::Escape::escape_c_str($key_expr->{"value"});
        if ($rhs_safe == 1) {
            emit($cg, "({ StradaValue *__ch = ");
            _gen_autoviv_outer_hash($cg, $hash_expr, $hash_ctx);
            emit($cg, "; StradaValue **__slot = strada_hv_fetch_lvalue_sv(__ch, \"" . $lit_key . "\", 1); StradaValue *__cv = __slot ? *__slot : strada_hv_fetch_owned(__ch, \"" . $lit_key . "\"); ");
            _emit_hash_cmpd_nv($cg, $op, $value);
            emit($cg, "if (__slot) { *__slot = __nv; strada_incref(__nv); if (__cv && __cv != __nv) strada_decref(__cv); } else { strada_decref(__cv); strada_hv_store(__ch, \"" . $lit_key . "\", __nv); } __nv; })");
        } else {
            emit($cg, "({ StradaValue *__ch = ");
            _gen_autoviv_outer_hash($cg, $hash_expr, $hash_ctx);
            emit($cg, "; StradaValue *__cv = strada_hv_fetch_owned(__ch, \"" . $lit_key . "\"); ");
            _emit_hash_cmpd_nv($cg, $op, $value);
            # __nv is yielded OWNED (rc=2 for non-short-circuit: the create-ref +
            # strada_hv_store's incref); consumers take the create-ref and the
            # void-statement emitter decrefs it. _emit_hash_cmpd_nv already released
            # the owned RHS temp (previously emitted inline and leaked).
            emit($cg, "strada_decref(__cv); strada_hv_store(__ch, \"" . $lit_key . "\", __nv); __nv; })");
        }
    } else {
        # Fast path: when the key is a borrowed scalar var, use the _sv
        # variants for fetch + store — sv_key_extract pulls the pv from
        # an existing StradaString without strdup, saving a per-iter
        # malloc/free pair. Falls back to the strada_to_str path for
        # arbitrary key expressions.
        my int $key_simple = 0;
        if (defined($key_expr) && $key_expr->{"type"} == Perla::AST::N_SCALAR_VAR()
            && defined($key_expr->{"name"}) && index($key_expr->{"name"}, "::") < 0) {
            $key_simple = 1;
        }
        # Single-probe lvalue fast path (rhs_safe computed above): the slot
        # pointer stays valid across the read-modify-write — one probe instead
        # of fetch+store's two. strada_hv_fetch_lvalue_sv* returns NULL for
        # tied/non-hash sv; the ternary then falls back so tie magic still fires.
        if ($rhs_safe == 1 && $key_simple == 1) {
            # single-probe + no-strdup: reuse the key scalar's pv directly
            emit($cg, "({ StradaValue *__ck_sv = ");
            gen_expr($cg, $key_expr);
            emit($cg, "; StradaValue *__ch = ");
            _gen_autoviv_outer_hash($cg, $hash_expr, $hash_ctx);
            emit($cg, "; StradaValue **__slot = strada_hv_fetch_lvalue_sv_key(__ch, __ck_sv, 1); StradaValue *__cv = __slot ? *__slot : strada_hv_fetch_owned_sv(__ch, __ck_sv); ");
            _emit_hash_cmpd_nv($cg, $op, $value);
            emit($cg, "if (__slot) { *__slot = __nv; strada_incref(__nv); if (__cv && __cv != __nv) strada_decref(__cv); } else { strada_decref(__cv); strada_hv_store_sv(__ch, __ck_sv, __nv); } __nv; })");
        } elsif ($rhs_safe == 1) {
            emit($cg, "({ char *__ck = strada_to_str(");
            gen_expr($cg, $key_expr);
            emit($cg, "); StradaValue *__ch = ");
            _gen_autoviv_outer_hash($cg, $hash_expr, $hash_ctx);
            emit($cg, "; StradaValue **__slot = strada_hv_fetch_lvalue_sv(__ch, __ck, 1); StradaValue *__cv = __slot ? *__slot : strada_hv_fetch_owned(__ch, __ck); ");
            _emit_hash_cmpd_nv($cg, $op, $value);
            emit($cg, "if (__slot) { *__slot = __nv; strada_incref(__nv); if (__cv && __cv != __nv) strada_decref(__cv); } else { strada_decref(__cv); strada_hv_store(__ch, __ck, __nv); } free(__ck); __nv; })");
        } else {
            if ($key_simple == 1) {
                emit($cg, "({ StradaValue *__ck_sv = ");
                gen_expr($cg, $key_expr);
                emit($cg, "; StradaValue *__ch = ");
                _gen_autoviv_outer_hash($cg, $hash_expr, $hash_ctx);
                emit($cg, "; StradaValue *__cv = strada_hv_fetch_owned_sv(__ch, __ck_sv); ");
            } else {
                emit($cg, "({ char *__ck = strada_to_str(");
                gen_expr($cg, $key_expr);
                emit($cg, "); StradaValue *__ch = ");
                _gen_autoviv_outer_hash($cg, $hash_expr, $hash_ctx);
                emit($cg, "; StradaValue *__cv = strada_hv_fetch_owned(__ch, __ck); ");
            }
            _emit_hash_cmpd_nv($cg, $op, $value);
            # __nv yielded OWNED (see literal-key path); _emit_hash_cmpd_nv already
            # released the owned RHS temp.
            if ($key_simple == 1) {
                emit($cg, "strada_decref(__cv); strada_hv_store_sv(__ch, __ck_sv, __nv); __nv; })");
            } else {
                emit($cg, "strada_decref(__cv); strada_hv_store(__ch, __ck, __nv); free(__ck); __nv; })");
            }
        }
    }
}

func _gen_call(scalar $cg, scalar $node) void {
    my str $name = $node->{"name"};
    my scalar $args = $node->{"args"};
    my int $argc = scalar(@{$args});

    # `CORE::name` — Perl's explicit-builtin form. Used by packages that
    # override built-in names (`sub push {...}` then `CORE::push @a, ...`).
    # Strip the prefix and reuse the unqualified handler so it routes
    # through perla's built-in inline codegen (push / pop / scalar /
    # length / uc / ...). Without this, `CORE::push` looked up the
    # "CORE" package in the stash, missed, and silently returned undef.
    if (length($name) > 6 && substr($name, 0, 6) eq "CORE::") {
        $name = substr($name, 6, length($name) - 6);
        $node->{"name"} = $name;
    }

    # Prototype-driven auto-reference. `sub takes_array (\@)` declares that
    # the caller's array arg should be promoted to a ref at the call site
    # — Perl's `\@`, `\%`, `\$`, `\&` proto chars. Without this, calls
    # like `takes_array(@arr)` flattened @arr to its elements and the
    # callee's `shift` got the first element rather than a ref.
    if (defined($cg->{"sub_protos"}) && $argc > 0) {
        my str $__proto_qn = "";
        if (index($name, "::") >= 0) {
            if (defined($cg->{"sub_protos"}->{$name})) { $__proto_qn = $name; }
        } else {
            my str $__cand = $cg->{"pkg"} . "::" . $name;
            if (defined($cg->{"sub_protos"}->{$__cand})) {
                $__proto_qn = $__cand;
            } elsif (defined($cg->{"sub_protos"}->{"main::" . $name})) {
                $__proto_qn = "main::" . $name;
            }
        }
        if (length($__proto_qn) > 0) {
            my str $__proto = "" . $cg->{"sub_protos"}->{$__proto_qn};
            if (length($__proto) > 0) {
                # Walk the proto char-by-char, building per-arg specs.
                # `\X` (X in @%$&*) means: take ref of arg N. Other chars
                # consume one arg slot without modifying it. `;` is the
                # required/optional separator (skip). `@` and `%` are
                # slurpy (consume remaining args, no per-arg rewrite).
                my int $__pi = 0;
                my int $__plen = length($__proto);
                my int $__slot = 0;
                while ($__pi < $__plen && $__slot < $argc) {
                    my str $__pc = substr($__proto, $__pi, 1);
                    if ($__pc eq ";") { $__pi = $__pi + 1; }
                    elsif ($__pc eq "\\") {
                        if ($__pi + 1 < $__plen) {
                            my str $__pnx = substr($__proto, $__pi + 1, 1);
                            if ($__pnx eq "@" || $__pnx eq "%" ||
                                $__pnx eq "\$" || $__pnx eq "&") {
                                my scalar $__orig = $args->[$__slot];
                                my scalar $__refn = Perla::AST::node(Perla::AST::N_REF());
                                $__refn->{"operand"} = $__orig;
                                $args->[$__slot] = $__refn;
                            }
                            $__pi = $__pi + 2;
                        } else { $__pi = $__pi + 1; }
                        $__slot = $__slot + 1;
                    }
                    elsif ($__pc eq "@" || $__pc eq "%") { last; }
                    elsif ($__pc eq "\$") {
                        # `$` proto slot: scalar context. If the arg is
                        # an N_ARRAY_VAR / N_HASH_VAR / N_ARRAY_SLICE
                        # the call site otherwise passes flattened
                        # elements; wrap in scalar(...) so the callee
                        # gets the count / single value.
                        my scalar $__sarg = $args->[$__slot];
                        my int $__sat = $__sarg->{"type"};
                        if ($__sat == Perla::AST::N_ARRAY_VAR() ||
                            $__sat == Perla::AST::N_HASH_VAR() ||
                            $__sat == Perla::AST::N_ARRAY_SLICE() ||
                            $__sat == Perla::AST::N_HASH_SLICE()) {
                            my scalar $__scn = Perla::AST::node(Perla::AST::N_CALL());
                            $__scn->{"name"} = "scalar";
                            my array @__sca = ($__sarg);
                            $__scn->{"args"} = \@__sca;
                            $args->[$__slot] = $__scn;
                        }
                        $__pi = $__pi + 1;
                        $__slot = $__slot + 1;
                    }
                    else {
                        $__pi = $__pi + 1;
                        $__slot = $__slot + 1;
                    }
                }
            }
        }
    }

    # tie %HASH, 'Class', HASHREF — Perl's tie semantics (FETCH/STORE
    # dispatch) aren't implemented; for the ubiquitous Config.pm-style
    # pattern `tie %H, 'Class', { ... }` we just copy the data hash into
    # %H so subsequent $H{key} lookups work without needing a real tie.
    # This matches real Perl's observable behavior for this specific
    # pattern: Config::FETCH returns $self->{key}, i.e. the passed-in
    # hash's values.
    if ($name eq "tie" && $argc >= 2) {
        my scalar $target = $args->[0];
        # Track whether the target came from an inline `my` declaration so
        # the scalar branch below can force-fresh-storage. Without this,
        # repeated `tie my $x, …` inside a for-loop body all share the same
        # C local v_x, so iter-N's tied state overwrites iter-(N-1)'s and
        # any references taken earlier in the loop end up aliased.
        my int $__tie_is_my = 0;
        # Inline `tie my $x, 'Class'` — peel the my-decl back to its var
        # so the scalar/array/hash branches below match. Mirrors how
        # pipe(my $rfh) etc. handle the inline-my form. The N_MY's var
        # is what we actually want to tie; the declaration itself was
        # registered in declared_vars by the call-args parser.
        if (defined($target) && $target->{"type"} == Perla::AST::N_MY()
            && defined($target->{"var"})) {
            $__tie_is_my = 1;
            my scalar $__tie_inner_var = $target->{"var"};
            my str $__tie_inner_t = "" . $__tie_inner_var->{"type"};
            if (length($__tie_inner_t) == 0) { $__tie_inner_t = "SCALAR_VAR"; }
            # Build a synthetic SCALAR_VAR / ARRAY_VAR / HASH_VAR node
            # to feed the branches below.
            my scalar $__tie_synth = Perla::AST::node(Perla::AST::N_SCALAR_VAR());
            if ($__tie_inner_t eq "ARRAY_VAR") {
                $__tie_synth = Perla::AST::node(Perla::AST::N_ARRAY_VAR());
            } elsif ($__tie_inner_t eq "HASH_VAR") {
                $__tie_synth = Perla::AST::node(Perla::AST::N_HASH_VAR());
            }
            $__tie_synth->{"name"} = $__tie_inner_var->{"value"};
            # Register in declared_vars so strict 'vars' sees the
            # declaration on subsequent reads.
            my str $__tie_cn = c_var_for_vtype($__tie_inner_t, $__tie_inner_var->{"value"});
            if (defined($cg->{"declared_vars"})) {
                $cg->{"declared_vars"}->{$__tie_cn} = 1;
            }
            $target = $__tie_synth;
        }
        # Scalar tie: `tie $x, 'Class', @args` → strada_tie_scalar(v_x, "Class", argc, args...)
        # Reads through the tied scalar dispatch FETCH via the to_int/str/num/bool
        # checks in strada_runtime.c; writes still go to v_x storage (STORE
        # dispatch is a separate codegen change).
        if (defined($target) && $target->{"type"} == Perla::AST::N_SCALAR_VAR()) {
            my scalar $class_arg = $args->[1];
            # Ensure v_x is materialized as a StradaValue before tying. For
            # the inline-my form (`tie my $x, …`), force fresh storage —
            # each lexical introduction should get its own SV. Without
            # forcing fresh, `for my $i (…) { tie my $x, …; push @refs,
            # \$x; }` would tie iter-N's "tied state" onto the same v_x
            # as iter-(N-1), so refs captured in earlier iters resolve to
            # the LAST iter's tied state. For the non-my form (`tie $x,
            # …`), $x already exists with its declaration's storage —
            # keep the existing slot and only init when NULL.
            my str $svname = "v_" . safe_ident($target->{"name"});
            if ($__tie_is_my == 1) {
                emit($cg, "({ if (" . $svname . ") strada_decref(" . $svname . "); " . $svname . " = strada_new_undef(); ");
            } else {
                emit($cg, "({ if (!" . $svname . ") " . $svname . " = strada_new_undef(); ");
            }
            emit($cg, "char *__tie_cls = strada_to_str(");
            gen_expr($cg, $class_arg);
            emit($cg, "); ");
            # Build extra-args list (everything after class name).
            my int $extra = $argc - 2;
            emit($cg, "StradaValue *__tie_obj = perla_tie_scalar(" . $svname . ", __tie_cls, " . $extra);
            my int $ai = 2;
            while ($ai < $argc) {
                emit($cg, ", ");
                gen_expr($cg, $args->[$ai]);
                $ai = $ai + 1;
            }
            emit($cg, "); free(__tie_cls); __tie_obj; })");
            return;
        }
        # NOTE: a previous "Config.pm shortcut" path used to copy the
        # passed-in hashref into the target hash and skip TIEHASH/STORE.
        # That broke real-tie semantics — `tie %h, 'Class', \%data` where
        # Class defines TIEHASH/STORE never fired the user's callbacks,
        # so STORE side-effects (validation, logging) and STORE-die
        # propagation through eval were silently dropped. Removed; real
        # tie via strada_tie_hash works for both the data-init and the
        # callback-driven patterns.

        # Generic hash tie: `tie %h, 'Class', @args` calls Class->TIEHASH(@args)
        # and attaches the result to v_h's meta. Subsequent $h{k} ops dispatch
        # FETCH/STORE/EXISTS/DELETE via the strada_hv_* tied checks.
        if (defined($target) && $target->{"type"} == Perla::AST::N_HASH_VAR()) {
            my scalar $class_arg_h = $args->[1];
            my str $hvname = "v_" . safe_ident($target->{"name"});
            emit($cg, "({ if (!" . $hvname . ") " . $hvname . " = strada_new_hash(); ");
            emit($cg, "char *__tie_cls = strada_to_str(");
            gen_expr($cg, $class_arg_h);
            emit($cg, "); ");
            my int $extra_h = $argc - 2;
            emit($cg, "StradaValue *__tie_obj = strada_tie_hash(" . $hvname . ", __tie_cls, " . $extra_h);
            my int $ai_h = 2;
            while ($ai_h < $argc) {
                emit($cg, ", ");
                gen_expr($cg, $args->[$ai_h]);
                $ai_h = $ai_h + 1;
            }
            emit($cg, "); free(__tie_cls); __tie_obj; })");
            return;
        }

        # Glob tie: `tie *FH, 'Class', @args` — calls Class->TIEHANDLE(@args)
        # and stores the resulting blessed object in FH's glob IO slot.
        # Diamond `<FH>`, `print FH …`, `close FH`, and `tied(*FH)` then
        # check the IO slot at runtime and dispatch through the blessed
        # object when set.
        if (defined($target) && $target->{"type"} == Perla::AST::N_GLOB_ACCESS()) {
            my str $gname = "" . $target->{"name"};
            my scalar $class_arg_g = $args->[1];
            emit($cg, "({ char *__tie_cls = strada_to_str(");
            gen_expr($cg, $class_arg_g);
            emit($cg, "); StradaValue *__tie_args = strada_new_array(); StradaArray *__tav = strada_deref_array(__tie_args); ");
            emit($cg, "{ StradaValue *__cn_e = strada_new_str(__tie_cls); strada_array_push_take(__tav, __cn_e); } ");
            my int $ai_g = 2;
            while ($ai_g < $argc) {
                emit($cg, "{ StradaValue *__tav_e = ");
                gen_expr($cg, $args->[$ai_g]);
                emit($cg, "; if (__tav_e) strada_incref(__tav_e); strada_array_push_take(__tav, __tav_e); } ");
                $ai_g = $ai_g + 1;
            }
            emit($cg, "StradaValue *__tie_obj = perla_tie_handle(\"" . $cg->{"pkg"} . "\", \"" . $gname . "\", __tie_cls, __tie_args); ");
            emit($cg, "strada_decref(__tie_args); free(__tie_cls); __tie_obj; })");
            return;
        }

        # Generic array tie: `tie @a, 'Class', @args`.
        if (defined($target) && $target->{"type"} == Perla::AST::N_ARRAY_VAR()) {
            my scalar $class_arg_a = $args->[1];
            my str $avname = "v_" . safe_ident($target->{"name"});
            emit($cg, "({ if (!" . $avname . ") " . $avname . " = strada_new_array(); ");
            emit($cg, "char *__tie_cls = strada_to_str(");
            gen_expr($cg, $class_arg_a);
            emit($cg, "); ");
            my int $extra_a = $argc - 2;
            emit($cg, "StradaValue *__tie_obj = strada_tie_array(" . $avname . ", __tie_cls, " . $extra_a);
            my int $ai_a = 2;
            while ($ai_a < $argc) {
                emit($cg, ", ");
                gen_expr($cg, $args->[$ai_a]);
                $ai_a = $ai_a + 1;
            }
            emit($cg, "); free(__tie_cls); __tie_obj; })");
            return;
        }
    }

    # tied $scalar / tied %hash / tied @array — return the tied object,
    # or undef if untied. The tie state lives on meta->tied_obj; just
    # route to strada_tied(). Without this, `tied` fell through to
    # perla_code_get looking for a sub.
    # IO::Compress::* / IO::Uncompress::* one-shot functions (native, libz/
    # libbz2). `VERB $src => $dst` — $src/$dst each a scalar-ref (\$buf,
    # in-memory) or a filename string. Trailing options (Level => ...) are
    # accepted and ignored. Returns 1 on success, "" (false) on failure.
    # gzip/gunzip (gzip), deflate/inflate (zlib), rawdeflate/rawinflate (raw),
    # bzip2/bunzip2 (bzip2). The bare verb or the fully-qualified name matches;
    # argc>=2 disambiguates from unrelated 0/1-arg subs (e.g. DBIC deflate).
    my str $cz_fn = "";
    if ($name eq "gzip" || $name eq "IO::Compress::Gzip::gzip") { $cz_fn = "perla_io_gzip"; }
    elsif ($name eq "gunzip" || $name eq "IO::Uncompress::Gunzip::gunzip") { $cz_fn = "perla_io_gunzip"; }
    elsif ($name eq "deflate" || $name eq "IO::Compress::Deflate::deflate") { $cz_fn = "perla_io_deflate"; }
    elsif ($name eq "inflate" || $name eq "IO::Uncompress::Inflate::inflate") { $cz_fn = "perla_io_inflate"; }
    elsif ($name eq "rawdeflate" || $name eq "IO::Compress::RawDeflate::rawdeflate") { $cz_fn = "perla_io_rawdeflate"; }
    elsif ($name eq "rawinflate" || $name eq "IO::Uncompress::RawInflate::rawinflate") { $cz_fn = "perla_io_rawinflate"; }
    elsif ($name eq "bzip2" || $name eq "IO::Compress::Bzip2::bzip2") { $cz_fn = "perla_io_bzip2"; }
    elsif ($name eq "bunzip2" || $name eq "IO::Uncompress::Bunzip2::bunzip2") { $cz_fn = "perla_io_bunzip2"; }
    if (length($cz_fn) > 0 && $argc >= 2) {
        emit($cg, "({ StradaValue *__cz_s = ");
        gen_expr($cg, $args->[0]);
        emit($cg, "; StradaValue *__cz_d = ");
        gen_expr($cg, $args->[1]);
        emit($cg, "; StradaValue *__cz_r = " . $cz_fn . "(__cz_s, __cz_d); ");
        if (expr_is_borrowed($args->[0]) == 0) { emit($cg, "strada_decref(__cz_s); "); }
        if (expr_is_borrowed($args->[1]) == 0) { emit($cg, "strada_decref(__cz_d); "); }
        emit($cg, "__cz_r; })");
        return;
    }

    if ($name eq "tied" && $argc == 1) {
        my scalar $tgt = $args->[0];
        if (defined($tgt)) {
            my int $tt = $tgt->{"type"};
            if ($tt == Perla::AST::N_SCALAR_VAR() ||
                $tt == Perla::AST::N_HASH_VAR() ||
                $tt == Perla::AST::N_ARRAY_VAR()) {
                emit($cg, "strada_tied(" . "v_" . safe_ident($tgt->{"name"}) . ")");
                return;
            }
            # tied(*FH) — read the tied handle object from the glob's
            # IO slot. Returns undef when *FH was never tied.
            if ($tt == Perla::AST::N_GLOB_ACCESS()) {
                emit($cg, "perla_tied_handle_get(\"" . $cg->{"pkg"} . "\", \"" . $tgt->{"name"} . "\")");
                return;
            }
        }
    }

    # untie $scalar / untie %hash / untie @array — clear tied state.
    if ($name eq "untie" && $argc == 1) {
        my scalar $utgt = $args->[0];
        if (defined($utgt)) {
            my int $utt = $utgt->{"type"};
            if ($utt == Perla::AST::N_SCALAR_VAR() ||
                $utt == Perla::AST::N_HASH_VAR() ||
                $utt == Perla::AST::N_ARRAY_VAR()) {
                # The "untie attempted while N inner references still exist"
                # warning is wired up in perla_stash.c (perla_warn_untie_with_refs)
                # but not emitted here yet — strada's refcount on the tied
                # object includes spurious leaks from `$_[0]->{...}` and
                # `my (...) = @_;` access paths (each leak +1 to refcount),
                # so the count we'd report is consistently higher than
                # perl's. Until those access leaks are plugged, suppress
                # the warning entirely to avoid false positives.
                emit($cg, "({ strada_untie(" . "v_" . safe_ident($utgt->{"name"}) . "); STRADA_MAKE_TAGGED_INT(1); })");
                return;
            }
        }
    }

    # select(FH) — set default output filehandle. Without this handler
    # \`select(\$fh); print "text";\` fell through to perla_code_get
    # looking for a user sub named "select" (none exists) and the
    # redirect was silently ignored. select() with no args returns the
    # current default.
    if ($name eq "select") {
        if ($argc == 0) {
            emit($cg, "strada_select_get()");
        } else {
            # Bareword-FH form (`select(STDOUT)`, `select(MYFH)`) gets
            # the handle name forwarded to perla_set_selected_handle
            # so per-handle $~ / $^ assignments under the new select
            # land on the right slot. The scalar form (`select($fh)`)
            # falls back to strada_select only — we can't recover the
            # name from the SV deterministically.
            my scalar $sa = $args->[0];
            my int $is_bareword = 0;
            my str $bw_name = "";
            if (defined($sa) && $sa->{"type"} == Perla::AST::N_CALL()
                && defined($sa->{"name"})) {
                my scalar $sargs = $sa->{"args"};
                my int $sac = 0;
                if (defined($sargs)) { $sac = scalar(@{$sargs}); }
                if ($sac == 0) {
                    my str $cand = "" . $sa->{"name"};
                    my int $sn = length($cand);
                    my int $sni = 0;
                    my int $allcaps = 1;
                    while ($sni < $sn) {
                        my str $sc = substr($cand, $sni, 1);
                        if (!(($sc ge "A" && $sc le "Z") || ($sc ge "0" && $sc le "9") || $sc eq "_")) {
                            $allcaps = 0; last;
                        }
                        $sni = $sni + 1;
                    }
                    if ($allcaps == 1 && $sn > 0) {
                        $is_bareword = 1;
                        $bw_name = $cand;
                    }
                }
            }
            if ($is_bareword == 1) {
                emit($cg, "({ perla_set_selected_handle(\"" . $bw_name . "\"); strada_select(");
                gen_expr($cg, $args->[0]);
                emit($cg, "); })");
            } else {
                emit($cg, "strada_select(");
                gen_expr($cg, $args->[0]);
                emit($cg, ")");
            }
        }
        return;
    }

    # print/say — with optional filehandle: print $fh "text" or print("text")
    if ($name eq "print" || $name eq "say") {
        my int $is_say = 0;
        if ($name eq "say") { $is_say = 1; }
        if ($argc == 0) {
            # `print;` / `say;` — no args, defaults to $_. strada_print returns
            # void; wrap so the expression yields STRADA_MAKE_TAGGED_INT(1) (Perl's
            # print returns 1 on success). Bare wrap (just the call) confuses the
            # statement-level void-rv capture path with `void value not ignored`.
            if ($is_say == 1) {
                emit($cg, "({ strada_print(perla_dollar_underscore ? perla_dollar_underscore : strada_new_str(\"\")); strada_print(strada_new_str(\"\\n\")); STRADA_MAKE_TAGGED_INT(1); })");
            } else {
                emit($cg, "({ strada_print(perla_dollar_underscore ? perla_dollar_underscore : strada_new_str(\"\")); STRADA_MAKE_TAGGED_INT(1); })");
            }
            return;
        }
        # Bareword filehandle: print STDERR "msg" / print STDOUT "msg".
        # Emit fprintf to the C stream directly. v_STDERR / v_STDOUT
        # are declared extern but never defined, so a plain
        # _gen_expr on a SCALAR_VAR named STDERR fails to link.
        # For generic uppercase barewords (FH, LOG, OUT, etc), look up the
        # filehandle from the package stash (where open(FH, ...) stored it)
        # and route through strada_print_fh.
        if (defined($node->{"fh_bareword"})) {
            my str $fhb = $node->{"fh_bareword"};
            my int $is_stdio = 0;
            my str $stream = "stdout";
            if ($fhb eq "STDOUT") { $is_stdio = 1; }
            elsif ($fhb eq "STDERR") { $stream = "stderr"; $is_stdio = 1; }
            elsif ($fhb eq "STDIN") { $stream = "stdin"; $is_stdio = 1; }  # nonsensical for print, but won't crash
            if ($is_stdio == 1) {
                # Capture args left-to-right before any output (Perl semantics
                # — side-effecting args fire before any printing starts).
                emit($cg, "({ ");
                my int $pi = 0;
                while ($pi < $argc) {
                    emit($cg, "char *__pfb_" . $pi . " = strada_to_str(");
                    gen_expr($cg, $args->[$pi]);
                    emit($cg, "); ");
                    $pi++;
                }
                $pi = 0;
                while ($pi < $argc) {
                    if ($pi > 0) {
                        emit($cg, "if (perla_ofs && !STRADA_IS_TAGGED_INT(perla_ofs) && perla_ofs->type == STRADA_STR && perla_ofs->value.pv[0]) { ");
                        emit($cg, "fputs(perla_ofs->value.pv, " . $stream . "); } ");
                    }
                    emit($cg, "fputs(__pfb_" . $pi . ", " . $stream . "); free(__pfb_" . $pi . "); ");
                    $pi++;
                }
                if ($is_say == 1) {
                    emit($cg, "fputc('\\n', " . $stream . "); ");
                } else {
                    emit($cg, "if (perla_ors && !STRADA_IS_TAGGED_INT(perla_ors) && perla_ors->type == STRADA_STR && perla_ors->value.pv[0]) { ");
                    emit($cg, "fputs(perla_ors->value.pv, " . $stream . "); } ");
                }
                emit($cg, "STRADA_MAKE_TAGGED_INT(1); })");
                return;
            }
            # Non-stdio bareword: look up from package stash and use
            # strada_print_fh. Capture args first for Perl gather-then-emit
            # semantics.
            # Tied-handle dispatch: if FH was tied via `tie *FH, 'Class'`,
            # the IO slot holds a blessed object whose PRINT method
            # receives the list of args. Detect at runtime via ternary;
            # fall through to the regular stash-FH path otherwise.
            emit($cg, "({ StradaValue *__pth_bw = perla_tied_handle_for_name(\"" . $cg->{"pkg"} . "\", \"" . $fhb . "\"); ");
            emit($cg, "__pth_bw ? ({ StradaValue *__pth_args = strada_new_array(); StradaArray *__pth_av = strada_deref_array(__pth_args); ");
            my int $tpi = 0;
            while ($tpi < $argc) {
                emit($cg, "{ StradaValue *__pth_a = ");
                gen_expr($cg, $args->[$tpi]);
                emit($cg, "; if (__pth_a) strada_incref(__pth_a); strada_array_push_take(__pth_av, __pth_a); } ");
                $tpi = $tpi + 1;
            }
            if ($is_say == 1) {
                emit($cg, "strada_array_push_take(__pth_av, strada_new_str(\"\\n\")); ");
            }
            emit($cg, "StradaValue *__pth_r = perla_tied_handle_print(\"" . $cg->{"pkg"} . "\", \"" . $fhb . "\", __pth_args); strada_decref(__pth_args); __pth_r; }) : ");
            emit($cg, "({ StradaValue *__pfh = perla_scalar_get(\"" . $cg->{"pkg"} . "\", \"" . $fhb . "\"); ");
            my int $pi2 = 0;
            while ($pi2 < $argc) {
                emit($cg, "StradaValue *__pfa_" . $pi2 . " = ");
                gen_expr($cg, $args->[$pi2]);
                emit($cg, "; ");
                $pi2++;
            }
            $pi2 = 0;
            while ($pi2 < $argc) {
                if ($pi2 > 0) {
                    emit($cg, "if (perla_ofs && !STRADA_IS_TAGGED_INT(perla_ofs) && perla_ofs->type == STRADA_STR && perla_ofs->value.pv[0]) { strada_print_fh(perla_ofs, __pfh); } ");
                }
                emit($cg, "strada_print_fh(__pfa_" . $pi2 . ", __pfh); ");
                $pi2++;
            }
            if ($is_say == 1) {
                emit($cg, "strada_print_fh(strada_new_str(\"\\n\"), __pfh); ");
            } else {
                emit($cg, "if (perla_ors && !STRADA_IS_TAGGED_INT(perla_ors) && perla_ors->type == STRADA_STR && perla_ors->value.pv[0]) { strada_print_fh(perla_ors, __pfh); } ");
            }
            # Close BOTH the inner ({ __pfh = ...; ... }) AND the outer
            # ({ __pth_bw = ...; __pth_bw ? (...) : (...); }) wrappers.
            emit($cg, "STRADA_MAKE_TAGGED_INT(1); }); })");
            return;
        }
        # Check if parser detected a filehandle (fh field set)
        my int $has_fh = 0;
        my int $fh_idx = -1;
        if (defined($node->{"fh"})) {
            $has_fh = 1;
        }
        if ($has_fh == 1) {
            # print $fh EXPR, ... — capture args left-to-right before any
            # output, matching Perl's gather-then-emit semantics. Each arg
            # is in LIST context; an array (or array-returning expression)
            # flattens to its elements (separated by $,). Without the
            # array-flatten branch, `print $fh @arr` called strada_print_fh
            # with an ARRAY StradaValue and wrote 0 bytes.
            emit($cg, "({ int __sav_wl_pfh = __perla_want_list; __perla_want_list = 1; ");
            emit($cg, "StradaValue *__pfh = ");
            gen_expr($cg, $node->{"fh"});
            emit($cg, "; ");
            my int $pi = 0;
            while ($pi < $argc) {
                emit($cg, "StradaValue *__pfa_" . $pi . " = ");
                gen_expr($cg, $args->[$pi]);
                emit($cg, "; ");
                $pi++;
            }
            emit($cg, "__perla_want_list = __sav_wl_pfh; ");
            $pi = 0;
            while ($pi < $argc) {
                if ($pi > 0) {
                    emit($cg, "if (perla_ofs && !STRADA_IS_TAGGED_INT(perla_ofs) && perla_ofs->type == STRADA_STR && perla_ofs->value.pv[0]) { strada_print_fh(perla_ofs, __pfh); } ");
                }
                # Flatten arrays into their elements (separated by $,).
                emit($cg, "if (__pfa_" . $pi . " && !STRADA_IS_TAGGED_INT(__pfa_" . $pi . ") && __pfa_" . $pi . "->type == STRADA_ARRAY) { ");
                emit($cg, "  StradaArray *__pfa_av = strada_deref_array(__pfa_" . $pi . "); ");
                emit($cg, "  if (__pfa_av) for (size_t __pfi = 0; __pfi < __pfa_av->size; __pfi++) { ");
                emit($cg, "    if (__pfi > 0 && perla_ofs && !STRADA_IS_TAGGED_INT(perla_ofs) && perla_ofs->type == STRADA_STR && perla_ofs->value.pv[0]) { strada_print_fh(perla_ofs, __pfh); } ");
                emit($cg, "    strada_print_fh(__pfa_av->elements[__pfa_av->head + __pfi], __pfh); ");
                emit($cg, "  } ");
                emit($cg, "} else { strada_print_fh(__pfa_" . $pi . ", __pfh); } ");
                $pi++;
            }
            if ($is_say == 1) {
                emit($cg, "strada_print_fh(strada_new_str(\"\\n\"), __pfh); ");
            } else {
                emit($cg, "if (perla_ors && !STRADA_IS_TAGGED_INT(perla_ors) && perla_ors->type == STRADA_STR && perla_ors->value.pv[0]) { strada_print_fh(perla_ors, __pfh); } ");
            }
            emit($cg, "STRADA_MAKE_TAGGED_INT(1); })");
        } elsif ($argc == 1) {
            # Single arg print: still evaluate in list context so a sub
            # returning a list expands to multiple printed items rather
            # than collapsing to its last value.
            emit($cg, "({ int __sav_wl_pr = __perla_want_list; __perla_want_list = 1; ");
            emit($cg, "StradaValue *__prv = ");
            gen_expr($cg, $args->[0]);
            emit($cg, "; __perla_want_list = __sav_wl_pr; ");
            emit($cg, "if (__prv && !STRADA_IS_TAGGED_INT(__prv) && __prv->type == STRADA_ARRAY) { ");
            emit($cg, "  StradaArray *__pra = strada_deref_array(__prv); ");
            emit($cg, "  if (__pra) for (size_t __pri = 0; __pri < __pra->size; __pri++) { ");
            emit($cg, "    if (__pri > 0 && perla_ofs && !STRADA_IS_TAGGED_INT(perla_ofs) && perla_ofs->type == STRADA_STR && perla_ofs->value.pv[0]) { strada_print(perla_ofs); } ");
            emit($cg, "    strada_print(__pra->elements[__pra->head + __pri]); } ");
            emit($cg, "} else if (__prv && !STRADA_IS_TAGGED_INT(__prv) && __prv->type == STRADA_HASH) { ");
            # Hash in list context: flatten as key1,val1,key2,val2.
            # strada_hash_keys returns StradaArray* (not StradaValue*);
            # walk the array directly and look up each value.
            emit($cg, "  StradaHash *__prh = strada_deref_hash(__prv); ");
            emit($cg, "  if (__prh) { ");
            emit($cg, "    int __prh_first = 1; ");
            emit($cg, "    StradaArray *__prh_kv = strada_hash_keys(__prh); ");
            emit($cg, "    if (__prh_kv) for (size_t __prki = 0; __prki < __prh_kv->size; __prki++) { ");
            emit($cg, "      StradaValue *__prh_k = __prh_kv->elements[__prh_kv->head + __prki]; ");
            emit($cg, "      char *__prh_ks = strada_to_str(__prh_k); ");
            emit($cg, "      StradaValue *__prh_v = __prh_ks ? strada_hash_get(__prh, __prh_ks) : strada_new_undef(); ");
            emit($cg, "      if (!__prh_first && perla_ofs && !STRADA_IS_TAGGED_INT(perla_ofs) && perla_ofs->type == STRADA_STR && perla_ofs->value.pv[0]) { strada_print(perla_ofs); } ");
            emit($cg, "      strada_print(__prh_k); ");
            emit($cg, "      if (perla_ofs && !STRADA_IS_TAGGED_INT(perla_ofs) && perla_ofs->type == STRADA_STR && perla_ofs->value.pv[0]) { strada_print(perla_ofs); } ");
            emit($cg, "      strada_print(__prh_v); ");
            emit($cg, "      free(__prh_ks); __prh_first = 0; } ");
            emit($cg, "    strada_free_array(__prh_kv); } ");
            emit($cg, "} else { ");
            if ($is_say == 1) {
                emit($cg, "strada_say(__prv); ");
            } else {
                emit($cg, "strada_print(__prv); ");
            }
            emit($cg, "} ");
            # If we're in `say` mode AND the result was a list, append \n
            # (strada_say already adds newline in the else branch).
            if ($is_say == 1) {
                emit($cg, "if (__prv && !STRADA_IS_TAGGED_INT(__prv) && __prv->type == STRADA_ARRAY) { strada_print(strada_new_str(\"\\n\")); } ");
            } else {
                emit($cg, "if (perla_ors && !STRADA_IS_TAGGED_INT(perla_ors) && perla_ors->type == STRADA_STR && perla_ors->value.pv[0]) { strada_print(perla_ors); } ");
            }
            emit($cg, "STRADA_MAKE_TAGGED_INT(1); })");
        } else {
            # Multi-arg print: each arg is in LIST context, so a sub call
            # returning a list flattens into multiple printed items (with
            # \$, between). Capture all arg VALUES first (left-to-right),
            # THEN print them. Without the upfront capture, a side-effecting
            # arg (e.g. a sub that itself prints) emits its output in the
            # middle of the print statement — Perl gathers args first, then
            # writes them as a unit.
            emit($cg, "({ int __sav_wl_pr = __perla_want_list; __perla_want_list = 1; ");
            my int $pi = 0;
            while ($pi < $argc) {
                emit($cg, "StradaValue *__pra_" . $pi . " = ");
                gen_expr($cg, $args->[$pi]);
                emit($cg, "; ");
                $pi++;
            }
            emit($cg, "__perla_want_list = __sav_wl_pr; ");
            $pi = 0;
            while ($pi < $argc) {
                if ($pi > 0) {
                    emit($cg, "if (perla_ofs && !STRADA_IS_TAGGED_INT(perla_ofs) && perla_ofs->type == STRADA_STR && perla_ofs->value.pv[0]) { strada_print(perla_ofs); } ");
                }
                emit($cg, "{ StradaValue *__prv = __pra_" . $pi . "; if (__prv && !STRADA_IS_TAGGED_INT(__prv) && __prv->type == STRADA_ARRAY) { ");
                emit($cg, "  StradaArray *__pra = strada_deref_array(__prv); ");
                emit($cg, "  if (__pra) for (size_t __pri = 0; __pri < __pra->size; __pri++) { ");
                emit($cg, "    if (__pri > 0 && perla_ofs && !STRADA_IS_TAGGED_INT(perla_ofs) && perla_ofs->type == STRADA_STR && perla_ofs->value.pv[0]) { strada_print(perla_ofs); } ");
                emit($cg, "    strada_print(__pra->elements[__pra->head + __pri]); } ");
                emit($cg, "} else if (__prv && !STRADA_IS_TAGGED_INT(__prv) && __prv->type == STRADA_HASH) { ");
                # Hash in list context flattens to key1,val1,key2,val2.
                # Iteration order is implementation-defined (perla's hash
                # iter order); both perl and perla treat this as one of
                # several legal orderings, so the specific sequence isn't
                # contractual.
                emit($cg, "  StradaHash *__prh = strada_deref_hash(__prv); ");
                emit($cg, "  if (__prh) { ");
                emit($cg, "    int __prh_first = 1; ");
                emit($cg, "    StradaArray *__prh_kv = strada_hash_keys(__prh); ");
                emit($cg, "    if (__prh_kv) for (size_t __prki = 0; __prki < __prh_kv->size; __prki++) { ");
                emit($cg, "      StradaValue *__prh_k = __prh_kv->elements[__prh_kv->head + __prki]; ");
                emit($cg, "      char *__prh_ks = strada_to_str(__prh_k); ");
                emit($cg, "      StradaValue *__prh_v = __prh_ks ? strada_hash_get(__prh, __prh_ks) : strada_new_undef(); ");
                emit($cg, "      if (!__prh_first && perla_ofs && !STRADA_IS_TAGGED_INT(perla_ofs) && perla_ofs->type == STRADA_STR && perla_ofs->value.pv[0]) { strada_print(perla_ofs); } ");
                emit($cg, "      strada_print(__prh_k); ");
                emit($cg, "      if (perla_ofs && !STRADA_IS_TAGGED_INT(perla_ofs) && perla_ofs->type == STRADA_STR && perla_ofs->value.pv[0]) { strada_print(perla_ofs); } ");
                emit($cg, "      strada_print(__prh_v); ");
                emit($cg, "      free(__prh_ks); __prh_first = 0; } ");
                emit($cg, "    strada_free_array(__prh_kv); } ");
                emit($cg, "} else { strada_print(__prv); } } ");
                $pi++;
            }
            if ($is_say == 1) {
                emit($cg, "strada_print(strada_new_str(\"\\n\")); ");
            } else {
                emit($cg, "if (perla_ors && !STRADA_IS_TAGGED_INT(perla_ors) && perla_ors->type == STRADA_STR && perla_ors->value.pv[0]) { strada_print(perla_ors); } ");
            }
            emit($cg, "STRADA_MAKE_TAGGED_INT(1); })");
        }
        return;
    }

    # die — preserve reference objects (hashref, blessed) in perla_eval_error
    if ($name eq "die") {
        my int $die_line = 0;
        if (defined($node->{"line"})) { $die_line = $node->{"line"} + 0; }
        emit($cg, "({ StradaValue *__dv = ");
        if ($argc > 1) {
            # Multi-arg die: Perl semantics joins LIST as strings (no
            # separator). `die "a", "b", "c", "\n"` produces "abc\n".
            # Without this, perla took only the first arg and the rest
            # silently vanished — common pattern broke when callers
            # composed messages from multiple parts.
            emit($cg, "({ StradaValue *__d0 = strada_new_str(\"\"); ");
            my int $di = 0;
            while ($di < $argc) {
                emit($cg, "__d0 = strada_concat_sv(__d0, ");
                gen_expr($cg, $args->[$di]);
                emit($cg, "); ");
                $di++;
            }
            emit($cg, "__d0; })");
        } elsif ($argc > 0) {
            # Single-arg die: pass through unchanged for refs/strings/etc.,
            # but for an array-flatten producing value (e.g. `die @_`) join
            # the elements into a string — Perl treats `die LIST` as
            # joining elements without a separator. Force list context
            # around gen_expr so @-vars don't collapse to count.
            emit($cg, "({ int __sav_wl_d = __perla_want_list; __perla_want_list = 1; StradaValue *__dv0 = ");
            gen_expr($cg, $args->[0]);
            emit($cg, "; __perla_want_list = __sav_wl_d; ");
            emit($cg, "if (__dv0 && !STRADA_IS_TAGGED_INT(__dv0) && __dv0->type == STRADA_ARRAY) { ");
            emit($cg, "  StradaArray *__dav = strada_deref_array(__dv0); ");
            emit($cg, "  StradaValue *__dj = strada_new_str(\"\"); ");
            emit($cg, "  if (__dav) for (size_t __di = 0; __di < __dav->size; __di++) { ");
            emit($cg, "    StradaValue *__de = __dav->elements[__dav->head + __di]; ");
            emit($cg, "    if (__de) __dj = strada_concat_sv(__dj, __de); ");
            emit($cg, "  } strada_decref(__dv0); __dv0 = __dj; } ");
            emit($cg, "__dv0; })");
        } else {
            emit($cg, "NULL");
        }
        # Perl semantics: `die` with no args rethrows $@ with a
        # "\t...propagated at FILE line N.\n" suffix appended (when $@
        # is a non-empty string). With undef/empty or a ref-typed $@,
        # the rethrow uses the value as-is. Falls back to "Died at..."
        # only when $@ is itself empty/undef. Without this fix, `die`
        # inside a nested eval lost the prior exception entirely.
        my int $die_no_args = 0;
        if ($argc == 0) { $die_no_args = 1; }
        emit($cg, "; ");
        if ($die_no_args == 1) {
            emit($cg, "if (perla_eval_error && (STRADA_IS_TAGGED_INT(perla_eval_error) || perla_eval_error->type != STRADA_UNDEF)) { ");
            emit($cg, "  __dv = perla_eval_error; strada_incref(__dv); ");
            emit($cg, "  if (!STRADA_IS_TAGGED_INT(__dv) && __dv->type == STRADA_STR && __dv->value.pv && __dv->value.pv[0]) { ");
            emit($cg, "    const char *__df = (perla_call_depth > 0) ? (perla_call_stack[perla_call_depth - 1].file ?: \"-\") : \"-\"; ");
            emit($cg, "    size_t __dlen = strlen(__dv->value.pv); ");
            emit($cg, "    char __dbuf[2048]; ");
            emit($cg, "    if (__dlen > 0 && __dv->value.pv[__dlen - 1] == '\\n') { ");
            emit($cg, "      snprintf(__dbuf, sizeof(__dbuf), \"%s\\t...propagated at %s line " . $die_line . ".\\n\", __dv->value.pv, __df); ");
            emit($cg, "    } else { ");
            emit($cg, "      snprintf(__dbuf, sizeof(__dbuf), \"%s at %s line " . $die_line . ".\\n\\t...propagated at %s line " . $die_line . ".\\n\", __dv->value.pv, __df, __df); ");
            emit($cg, "    } ");
            emit($cg, "    strada_decref(__dv); __dv = strada_new_str(__dbuf); ");
            emit($cg, "  } ");
            emit($cg, "} ");
        }
        emit($cg, "if (!__dv || (!STRADA_IS_TAGGED_INT(__dv) && __dv->type == STRADA_UNDEF) || ");
        emit($cg, "    (!STRADA_IS_TAGGED_INT(__dv) && __dv->type == STRADA_STR && (!__dv->value.pv || __dv->value.pv[0] == 0))) { ");
        emit($cg, "  if (__dv) strada_decref(__dv); ");
        emit($cg, "  const char *__df = (perla_call_depth > 0) ? (perla_call_stack[perla_call_depth - 1].file ?: \"-\") : \"-\"; ");
        emit($cg, "  char __dbuf[1024]; snprintf(__dbuf, sizeof(__dbuf), \"Died at %s line " . $die_line . ".\\n\", __df); ");
        emit($cg, "  __dv = strada_new_str(__dbuf); ");
        emit($cg, "} else if (__dv && !STRADA_IS_TAGGED_INT(__dv) && __dv->type == STRADA_STR && __dv->value.pv) { ");
        emit($cg, "  size_t __dlen = strlen(__dv->value.pv); ");
