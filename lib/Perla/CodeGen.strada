        # needs this — without it, the row-parser cref never makes it into the
        # cache hash and DBIC silently calls undef as the parser.
        if ($target_type == Perla::AST::N_HASH_SLICE()) {
            my scalar $hash_node_hs = $target->{"hash"};
            my scalar $keys_list_hs = $target->{"keys_list"};
            # Flatten keys from QWORD/ANON_ARRAY-style key lists.
            emit($cg, "({ StradaValue *__hs_h = ");
            if (defined($hash_node_hs) && ref($hash_node_hs) eq "HASH") {
                if ($hash_node_hs->{"type"} == Perla::AST::N_DEREF_ARRAY() && defined($hash_node_hs->{"ref"})) {
                    # `@{INNER_REF}{...}` — INNER_REF is whatever expr produces
                    # the hash. If it's a HASH_ELEM/ARROW_HASH chain (e.g.
                    # `@{$obj->{a}{b}}{k1, k2} = ...`), autovivify so missing
                    # intermediate hashes get created instead of writing to a
                    # throwaway local hash. DBIC's
                    # `@{$self->{_row_parser}{$ptype}}{qw(cref nullcheck)} = ...`
                    # depends on this — without autoviv, the row-parser cref
                    # never reaches the cache and the parser sub is silently
                    # undef.
                    my scalar $inner_ref = $hash_node_hs->{"ref"};
                    if (defined($inner_ref) && ref($inner_ref) eq "HASH" &&
                        ($inner_ref->{"type"} == Perla::AST::N_HASH_ELEM() ||
                         $inner_ref->{"type"} == Perla::AST::N_ARROW_HASH())) {
                        _gen_autoviv_hash($cg, $inner_ref);
                    } else {
                        gen_expr($cg, $inner_ref);
                    }
                } elsif ($hash_node_hs->{"type"} == Perla::AST::N_HASH_ELEM() ||
                         $hash_node_hs->{"type"} == Perla::AST::N_ARROW_HASH()) {
                    _gen_autoviv_hash($cg, $hash_node_hs);
                } else {
                    gen_expr($cg, $hash_node_hs);
                }
            } elsif (defined($hash_node_hs) && length("" . $hash_node_hs) > 1 && substr("" . $hash_node_hs, 0, 1) eq "$") {
                my str $rvar_hs = substr("" . $hash_node_hs, 1, length("" . $hash_node_hs) - 1);
                emit($cg, c_var($rvar_hs));
