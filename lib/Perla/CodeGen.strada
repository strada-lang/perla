    if ($name eq "values") {
        if ($argc > 0) {
            # Perl 5.12+: `values @arr` returns the array's elements
            # (same as @arr in list context, but parallel to `values %h`).
            # In scalar context it's the count. Detect array AST type
            # so we don't redirect through a NULL hash deref.
            my int $vt = $args->[0]->{"type"};
            if ($vt == Perla::AST::N_ARRAY_VAR()
                || $vt == Perla::AST::N_DEREF_ARRAY()) {
                emit($cg, "({ StradaArray *__va_av = strada_deref_array(");
                gen_expr($cg, $args->[0]);
                emit($cg, "); int64_t __va_n = __va_av ? (int64_t)__va_av->size : 0; ");
                emit($cg, "__perla_want_list ? ({ StradaValue *__var = strada_new_array(); StradaArray *__varr = strada_deref_array(__var); for (size_t __vai = 0; __vai < (size_t)__va_n; __vai++) { StradaValue *__vae = __va_av->elements[__va_av->head + __vai]; if (__vae) strada_incref(__vae); strada_array_push_take(__varr, __vae); } __var; }) : STRADA_MAKE_TAGGED_INT(__va_n); })");
                return;
            }
            # strada_hash_values_sv handles tied hashes (walks FIRSTKEY/
            # NEXTKEY + FETCHes each) AND plain hashes. Force scalar
            # context around the call for the same reason as keys
            # (FIRSTKEY/NEXTKEY contract is scalar).
            emit($cg, "({ int __sav_wl_v = __perla_want_list; __perla_want_list = 1; ");
            emit($cg, "StradaValue *__v_sv = ");
            gen_expr($cg, $args->[0]);
            emit($cg, "; __perla_want_list = 0; ");
            emit($cg, "StradaArray *__vka = strada_hash_values_sv(__v_sv); ");
            emit($cg, "__perla_want_list = __sav_wl_v; ");
            emit($cg, "__perla_want_list ? strada_new_array_from_av(__vka) : ({ ");
            emit($cg, "int64_t __vn = __vka ? (int64_t)__vka->size : 0; ");
            emit($cg, "strada_free_array(__vka); STRADA_MAKE_TAGGED_INT(__vn); }); })");
        }
        return;
    }

    # exists
    # Evaluate the hash BEFORE the key — Perl evaluates `exists $hash->{KEY}`
    # left-to-right. Was emitting key first, which broke patterns like
    # `exists shift->_relationships->{+shift}` (both shifts share @_, and the
    # original order shifted the key out of @_ first, leaving the key as $self
    # and the hash invocant as the rel name).
    if ($name eq "exists") {
        if ($argc > 0) {
            my scalar $arg = $args->[0];
            # `exists &SUB` and `exists &Pkg::SUB` — check whether
            # the sub exists in the package stash WITHOUT calling it.
            # Mirrors the `defined &SUB` handling above. Without this,
            # exists falls through to MAKE_TAGGED_INT(0), returning 0
            # (false) even when the sub is defined.
            if (defined($arg) && $arg->{"type"} == Perla::AST::N_CALL()
                && defined($arg->{"pass_caller_args"}) && $arg->{"pass_caller_args"} == 1
                && defined($arg->{"name"}) && length($arg->{"name"}) > 0
                && $arg->{"name"} ne "__coderef__") {
                my str $exn = $arg->{"name"};
                my int $ex_sep = -1;
                my int $ex_si = length($exn) - 1;
                while ($ex_si > 0) {
                    if (substr($exn, $ex_si - 1, 2) eq "::") { $ex_sep = $ex_si - 1; last; }
                    $ex_si--;
                }
                my str $expkg = ($ex_sep >= 0) ? substr($exn, 0, $ex_sep) : $cg->{"pkg"};
                my str $exshort = ($ex_sep >= 0) ? substr($exn, $ex_sep + 2, length($exn) - $ex_sep - 2) : $exn;
                emit($cg, "(perla_code_get(\"" . $expkg . "\", \"" . $exshort . "\") ? STRADA_MAKE_TAGGED_INT(1) : strada_new_str(\"\"))");
                return;
            }
            if ($arg->{"type"} == Perla::AST::N_HASH_ELEM()) {
                emit($cg, "({ StradaValue *__eh = ");
                my scalar $eh = $arg->{"hash"};
                my int $eh_stash_fallback = 0;
                my str $eh_stash_name = "";
                if (defined($eh) && $eh->{"type"} == Perla::AST::N_SCALAR_VAR()
                    && defined($eh->{"name"}) && length($eh->{"name"}) > 0
                    && index($eh->{"name"}, "::") < 0 && $eh->{"name"} ne "_"
                    && exists($__perla_mangle_collisions{$eh->{"name"}})) {
                    emit($cg, c_var_h($eh->{"name"}));
                } elsif (defined($eh) && $eh->{"type"} == Perla::AST::N_SCALAR_VAR()
                    && defined($eh->{"name"}) && $eh->{"name"} eq "INC") {
                    # `exists $INC{...}` reads the loaded-modules hash, not
                    # the @INC paths array. Route through v_INC__h
                    # (backed by runtime g_INC_hash).
                    emit($cg, "v_INC__h");
                } elsif (defined($eh) && $eh->{"type"} == Perla::AST::N_SCALAR_VAR()
                    && defined($eh->{"name"}) && index($eh->{"name"}, "::") > 0) {
                    # `exists $Pkg::Name{key}` — read the HASH slot of the
                    # stash, not the SCALAR slot.
                    my str $ehn = $eh->{"name"};
                    my int $ehli = -1;
                    my int $ehsi = 0;
                    while ($ehsi < length($ehn) - 1) {
                        if (substr($ehn, $ehsi, 2) eq "::") { $ehli = $ehsi; }
                        $ehsi++;
                    }
                    my str $ehpkg = substr($ehn, 0, $ehli);
                    my str $ehshort = substr($ehn, $ehli + 2, length($ehn) - $ehli - 2);
                    emit($cg, "perla_hash_get(\"" . $ehpkg . "\", \"" . $ehshort . "\")");
                } elsif (defined($eh) && $eh->{"type"} == Perla::AST::N_SCALAR_VAR()
                    && defined($eh->{"name"}) && length($eh->{"name"}) > 0
                    && index($eh->{"name"}, "::") < 0) {
                    # Imported-from-module hashes (e.g. \`use Config; $Config{X}\`)
                    # — v_Config is NULL because no `our %Config` was declared;
                    # the hash lives in the Config:: stash. Mirror the
                    # read-path fallback: try v_X first, then perla_hash_get
                    # of the same-named package's hash slot.
                    emit($cg, c_var_h($eh->{"name"}));
                    $eh_stash_fallback = 1;
                    $eh_stash_name = $eh->{"name"};
                } else {
                    gen_expr($cg, $eh);
                }
                if ($eh_stash_fallback == 1) {
                    # Don't fall back to the stash hash when the SV is tied —
                    # the tied dispatch is what we want, and the underlying
                    # StradaHash is intentionally empty (entries live in
                    # the tied object).
                    emit($cg, "; if ((!__eh || (!STRADA_IS_TAGGED_INT(__eh) && __eh->type == STRADA_HASH && __eh->value.hv && __eh->value.hv->num_entries == 0)) && (!__eh || STRADA_IS_TAGGED_INT(__eh) || !__eh->meta || !__eh->meta->is_tied)) { StradaValue *__ehsv = perla_hash_get(\"" . $eh_stash_name . "\", \"" . $eh_stash_name . "\"); if (__ehsv) __eh = __ehsv; }");
                }
                # Use the _sv variant when the key is a borrowed scalar
                # variable — sv_key_extract pulls pv directly from the
                # StradaString without strdup. Saves a per-iter malloc/
                # free in tight `exists $h{$k}` patterns (bench_data
                # frequency-table being the canonical case).
                my scalar $eh_ekey = $arg->{"key"};
                my int $eh_ekey_simple = 0;
                if (defined($eh_ekey) && $eh_ekey->{"type"} == Perla::AST::N_SCALAR_VAR()
                    && defined($eh_ekey->{"name"}) && index($eh_ekey->{"name"}, "::") < 0) {
                    $eh_ekey_simple = 1;
                }
                if ($eh_ekey_simple == 1) {
                    emit($cg, "; int __e = strada_hv_exists_sv(__eh, ");
                    gen_expr($cg, $eh_ekey);
                    emit($cg, "); __e ? STRADA_MAKE_TAGGED_INT(1) : strada_new_str(\"\"); })");
                } else {
                    emit($cg, "; char *__k = strada_to_str(");
                    gen_expr($cg, $eh_ekey);
                    emit($cg, "); int __e = strada_hv_exists(__eh, __k); free(__k); __e ? STRADA_MAKE_TAGGED_INT(1) : strada_new_str(\"\"); })");
                }
            } elsif ($arg->{"type"} == Perla::AST::N_ARROW_HASH()) {
                emit($cg, "({ StradaValue *__eh = ");
                my scalar $eo = $arg->{"object"};
                my int $eo_arrow = 0;
                if (defined($arg->{"is_explicit_arrow"}) && $arg->{"is_explicit_arrow"} == 1) { $eo_arrow = 1; }
                my int $eo_stash_fallback = 0;
                my str $eo_stash_name = "";
                if ($eo_arrow == 0 && defined($eo) && $eo->{"type"} == Perla::AST::N_SCALAR_VAR()
                    && defined($eo->{"name"}) && length($eo->{"name"}) > 0
                    && index($eo->{"name"}, "::") < 0 && $eo->{"name"} ne "_"
                    && exists($__perla_mangle_collisions{$eo->{"name"}})) {
                    emit($cg, c_var_h($eo->{"name"}));
                } elsif (defined($eo) && $eo->{"type"} == Perla::AST::N_SCALAR_VAR()
                    && defined($eo->{"name"}) && $eo->{"name"} eq "INC") {
                    emit($cg, "v_INC__h");
                } elsif (defined($eo) && $eo->{"type"} == Perla::AST::N_SCALAR_VAR()
                    && defined($eo->{"name"}) && index($eo->{"name"}, "::") > 0) {
                    my str $eon = $eo->{"name"};
                    my int $eoli = -1;
                    my int $eosi = 0;
                    while ($eosi < length($eon) - 1) {
                        if (substr($eon, $eosi, 2) eq "::") { $eoli = $eosi; }
                        $eosi++;
                    }
                    my str $eopkg = substr($eon, 0, $eoli);
                    my str $eoshort = substr($eon, $eoli + 2, length($eon) - $eoli - 2);
                    emit($cg, "perla_hash_get(\"" . $eopkg . "\", \"" . $eoshort . "\")");
                } elsif ($eo_arrow == 0 && defined($eo) && $eo->{"type"} == Perla::AST::N_SCALAR_VAR()
                    && defined($eo->{"name"}) && length($eo->{"name"}) > 0
                    && index($eo->{"name"}, "::") < 0 && $eo->{"name"} ne "_") {
                    # Imported-from-module hashes (e.g. \`use Config; exists $Config{X}\`)
                    # — v_X is NULL because no `our %X` was declared; the
                    # hash lives in the X:: stash. Mirror the read-path
                    # fallback to perla_hash_get.
                    emit($cg, c_var_h($eo->{"name"}));
                    $eo_stash_fallback = 1;
                    $eo_stash_name = $eo->{"name"};
                } else {
                    gen_expr($cg, $eo);
                }
                if ($eo_stash_fallback == 1) {
                    # Same tied-SV guard as N_HASH_ELEM path above.
                    emit($cg, "; if ((!__eh || (!STRADA_IS_TAGGED_INT(__eh) && __eh->type == STRADA_HASH && __eh->value.hv && __eh->value.hv->num_entries == 0)) && (!__eh || STRADA_IS_TAGGED_INT(__eh) || !__eh->meta || !__eh->meta->is_tied)) { StradaValue *__ehsv = perla_hash_get(\"" . $eo_stash_name . "\", \"" . $eo_stash_name . "\"); if (__ehsv) __eh = __ehsv; }");
                }
                emit($cg, "; char *__k = strada_to_str(");
                gen_expr($cg, $arg->{"key"});
                emit($cg, "); int __e = strada_hv_exists(__eh, __k); free(__k); __e ? STRADA_MAKE_TAGGED_INT(1) : strada_new_str(\"\"); })");
            } elsif ($arg->{"type"} == Perla::AST::N_ARROW_ARRAY() || $arg->{"type"} == Perla::AST::N_ARRAY_ELEM()) {
                # `exists $h{a}[0]` or `exists $arr[5]` — true iff the slot
                # is in bounds AND has not been tombstoned by a prior
                # `delete $arr[N]`. Tied-aware: dispatch EXISTS on the
                # tied object when SV is tied.
                emit($cg, "({ StradaValue *__ea_sv = ");
                if ($arg->{"type"} == Perla::AST::N_ARRAY_ELEM()) {
                    gen_expr($cg, $arg->{"array"});
                } else {
                    gen_expr($cg, $arg->{"object"});
                }
                emit($cg, "; int64_t __ea_i = strada_to_int(");
                gen_expr($cg, $arg->{"index"});
                emit($cg, "); int __ea_e = strada_av_exists_sv(__ea_sv, __ea_i); __ea_e ? STRADA_MAKE_TAGGED_INT(1) : strada_new_str(\"\"); })");
            } else {
                emit($cg, "STRADA_MAKE_TAGGED_INT(0)");
            }
        }
        return;
    }

    # delete — Perl returns the deleted value (or undef if it didn't exist).
    # Was hardcoding `strada_new_undef()` so callers like `delete $attrs->{-result_source}`
    # always saw undef, which broke DBIC's `Row::new` (couldn't recover the source).
    if ($name eq "delete") {
        if ($argc > 0) {
            my scalar $arg = $args->[0];
            if ($arg->{"type"} == Perla::AST::N_HASH_ELEM()) {
                # `delete $ENV{KEY}` also calls unsetenv so child processes
                # don't see the deleted key in their env.
                my int $is_env_del = 0;
                my scalar $del_hash = $arg->{"hash"};
                if (defined($del_hash) && $del_hash->{"type"} == Perla::AST::N_SCALAR_VAR()
                    && defined($del_hash->{"name"}) && $del_hash->{"name"} eq "ENV") {
                    $is_env_del = 1;
                }
                emit($cg, "({ StradaValue *__dh = ");
                if (defined($del_hash) && $del_hash->{"type"} == Perla::AST::N_SCALAR_VAR()
                    && defined($del_hash->{"name"}) && index($del_hash->{"name"}, "::") > 0) {
                    my array @dhpn = _split_pkg_qual_name($del_hash);
                    emit($cg, "perla_hash_get(\"" . $dhpn[0] . "\", \"" . $dhpn[1] . "\")");
                } else {
                    gen_expr($cg, $arg->{"hash"});
                }
                emit($cg, "; char *__k = strada_to_str(");
                gen_expr($cg, $arg->{"key"});
                # Tie-aware: hv_fetch_owned and hv_delete dispatch
                # FETCH/DELETE on tied hashes.
                emit($cg, "); StradaValue *__dv = strada_hv_fetch_owned(__dh, __k); ");
                emit($cg, "strada_hv_delete(__dh, __k); ");
                if ($is_env_del == 1) {
                    emit($cg, "unsetenv(__k); ");
                }
                emit($cg, "free(__k); ");
                emit($cg, "__dv ? __dv : strada_new_undef(); })");
            } elsif ($arg->{"type"} == Perla::AST::N_ARROW_HASH()) {
                my int $is_env_del_ah = 0;
                my scalar $del_obj = $arg->{"object"};
                if (defined($del_obj) && $del_obj->{"type"} == Perla::AST::N_SCALAR_VAR()
                    && defined($del_obj->{"name"}) && $del_obj->{"name"} eq "ENV") {
                    $is_env_del_ah = 1;
                }
                emit($cg, "({ StradaValue *__dh = ");
                # `delete $Pkg::H{k}` — route to HASH slot of stash glob.
                # Only when no explicit arrow (`$P::h{k}`, not `$P::h->{k}`)
                # so explicit arrow falls through to gen_expr (which derefs
                # the SCALAR slot holding a hashref).
                my int $do_is_arrow = 0;
                if (defined($arg->{"is_explicit_arrow"}) && $arg->{"is_explicit_arrow"} == 1) { $do_is_arrow = 1; }
                if ($do_is_arrow == 0 && defined($del_obj)
                    && $del_obj->{"type"} == Perla::AST::N_SCALAR_VAR()
                    && defined($del_obj->{"name"}) && index($del_obj->{"name"}, "::") > 0) {
                    my array @dopn = _split_pkg_qual_name($del_obj);
                    emit($cg, "perla_hash_get(\"" . $dopn[0] . "\", \"" . $dopn[1] . "\")");
                } else {
                    gen_expr($cg, $arg->{"object"});
                }
                emit($cg, "; char *__k = strada_to_str(");
                gen_expr($cg, $arg->{"key"});
                # Tie-aware (see N_HASH_ELEM branch above).
                emit($cg, "); StradaValue *__dv = strada_hv_fetch_owned(__dh, __k); ");
                emit($cg, "strada_hv_delete(__dh, __k); ");
                if ($is_env_del_ah == 1) {
                    emit($cg, "unsetenv(__k); ");
                }
                emit($cg, "free(__k); ");
                emit($cg, "__dv ? __dv : strada_new_undef(); })");
            } elsif ($arg->{"type"} == Perla::AST::N_HASH_SLICE()) {
                # delete @h{keys} — delete multiple keys, return their
                # values as a list. Without this branch, the call fell
                # through to "unhandled arg type".
                emit($cg, "({ StradaValue *__dh = ");
                my scalar $hs_hash = $arg->{"hash"};
                if (ref($hs_hash) eq "HASH") {
                    gen_expr($cg, $hs_hash);
                } else {
                    emit($cg, c_var_h("" . $hs_hash));
                }
                emit($cg, "; StradaHash *__dhv = strada_deref_hash(__dh); ");
                emit($cg, "StradaValue *__dr = strada_new_array(); StradaArray *__drv = strada_deref_array(__dr); ");
                # Build flat keys array — may be a list of expressions or a single qw/anon-array
                emit($cg, "StradaValue *__dks = strada_new_array(); StradaArray *__dkv = strada_deref_array(__dks); ");
                my scalar $hs_keys = $arg->{"keys_list"};
                my int $hs_n = scalar(@{$hs_keys});
                my int $hs_i = 0;
                while ($hs_i < $hs_n) {
                    my scalar $hs_k = $hs_keys->[$hs_i];
                    my int $hs_kt = $hs_k->{"type"};
                    if ($hs_kt == Perla::AST::N_QWORD() || ($hs_kt == Perla::AST::N_ANON_ARRAY() && $hs_k->{"is_ref"} != 1)) {
                        my scalar $hs_elems = $hs_k->{"elems"};
                        my int $hs_ei = 0;
                        while ($hs_ei < scalar(@{$hs_elems})) {
                            emit($cg, "strada_array_push(__dkv, ");
                            gen_expr($cg, $hs_elems->[$hs_ei]);
                            emit($cg, "); ");
                            $hs_ei++;
                        }
                    } elsif ($hs_kt == Perla::AST::N_ARRAY_VAR()
                          || $hs_kt == Perla::AST::N_DEREF_ARRAY()
                          || $hs_kt == Perla::AST::N_RANGE()
                          || $hs_kt == Perla::AST::N_ARRAY_SLICE()) {
                        # Array variable / range / slice — splat at runtime.
                        # Without this, `delete @h{@keys}` pushed the whole
                        # array as ONE element and the loop did
                        # `strada_to_str(array)` getting a stringified
                        # array that matched no hash key.
                        emit($cg, "{ StradaArray *__hs_av = strada_deref_array(");
                        gen_expr($cg, $hs_k);
                        emit($cg, "); if (__hs_av) for (size_t __hs_ai = 0; __hs_ai < __hs_av->size; __hs_ai++) { strada_array_push(__dkv, __hs_av->elements[__hs_av->head + __hs_ai]); } } ");
                    } else {
                        emit($cg, "strada_array_push(__dkv, ");
                        gen_expr($cg, $hs_k);
                        emit($cg, "); ");
                    }
                    $hs_i++;
                }
                # For each key, fetch its value then delete from hash.
                emit($cg, "if (__dhv && __dkv) { for (size_t __dki = 0; __dki < __dkv->size; __dki++) { ");
                emit($cg, "  StradaValue *__dkk = __dkv->elements[__dkv->head + __dki]; ");
                emit($cg, "  char *__dks_str = strada_to_str(__dkk); ");
                emit($cg, "  StradaValue *__dv = strada_hash_get(__dhv, __dks_str); ");
                emit($cg, "  if (__dv) strada_incref(__dv); else __dv = strada_new_undef(); ");
                emit($cg, "  strada_array_push_take(__drv, __dv); ");
                emit($cg, "  strada_hash_delete(__dhv, __dks_str); free(__dks_str); ");
                emit($cg, "} } strada_decref(__dks); __dr; })");
            } elsif ($arg->{"type"} == Perla::AST::N_ARRAY_ELEM() || $arg->{"type"} == Perla::AST::N_ARROW_ARRAY()) {
                # delete $arr[N] / delete $ref->[N] — use the runtime helper
                # so the slot becomes a real tombstone (so exists() returns
                # false afterwards) and the array shrinks on trailing
                # delete, matching Perl semantics. Tied-aware: dispatch
                # DELETE on the tied object when SV is tied.
                emit($cg, "({ StradaValue *__dae_sv = ");
                if ($arg->{"type"} == Perla::AST::N_ARRAY_ELEM()) {
                    my scalar $ae_arr = $arg->{"array"};
                    if (defined($ae_arr) && ref($ae_arr) eq "HASH") {
                        gen_expr($cg, $ae_arr);
                    } else {
                        emit($cg, c_var_a("" . $arg->{"array"}));
                    }
                } else {
                    gen_expr($cg, $arg->{"object"});
                }
                emit($cg, "; int64_t __dae_i = strada_to_int(");
                gen_expr($cg, $arg->{"index"});
                # Fetch the value BEFORE deleting so we can return it.
                # Perl's `delete $arr[N]` returns the deleted element
                # (or undef when the slot is already empty). Previously
                # the codegen unconditionally returned undef even on a
                # populated slot.
                emit($cg, "); StradaValue *__dae_old = NULL; ");
                emit($cg, "if (__dae_sv && !STRADA_IS_TAGGED_INT(__dae_sv) && __dae_sv->meta && __dae_sv->meta->is_tied) { ");
                emit($cg, "  __dae_old = strada_tied_array_fetch(__dae_sv, __dae_i); ");
                emit($cg, "  strada_tied_array_delete(__dae_sv, __dae_i); ");
                emit($cg, "} else { ");
                emit($cg, "  StradaArray *__dae_av = strada_deref_array(__dae_sv); ");
                emit($cg, "  if (__dae_av) { int64_t __dae_eff = __dae_i; if (__dae_eff < 0) __dae_eff += (int64_t)__dae_av->size; ");
                emit($cg, "    if (__dae_eff >= 0 && (size_t)__dae_eff < __dae_av->size) { __dae_old = __dae_av->elements[__dae_av->head + __dae_eff]; if (__dae_old) strada_incref(__dae_old); } } ");
                emit($cg, "  strada_array_delete_idx(__dae_av, __dae_i); ");
                emit($cg, "} ");
                emit($cg, "__dae_old ? __dae_old : strada_new_undef(); })");
            } elsif ($arg->{"type"} == Perla::AST::N_ARRAY_SLICE()) {
                # delete @arr[1,3] — slice delete: return list of deleted values,
                # leave undef in each slot
                emit($cg, "({ StradaValue *__das_a = ");
                my scalar $as_arr = $arg->{"array"};
                if (defined($as_arr) && ref($as_arr) eq "HASH") {
                    gen_expr($cg, $as_arr);
                } else {
                    emit($cg, c_var_a("" . $arg->{"array"}));
                }
                emit($cg, "; StradaArray *__das_av = strada_deref_array(__das_a); ");
                emit($cg, "StradaValue *__das_r = strada_new_array(); StradaArray *__das_rv = strada_deref_array(__das_r); ");
                emit($cg, "StradaValue *__das_ks = strada_new_array(); StradaArray *__das_kv = strada_deref_array(__das_ks); ");
                my scalar $as_keys = $arg->{"keys_list"};
                if (!defined($as_keys)) { $as_keys = $arg->{"indices"}; }
                if (defined($as_keys)) {
                    my int $as_n = scalar(@{$as_keys});
                    my int $as_i = 0;
                    while ($as_i < $as_n) {
                        my scalar $as_k = $as_keys->[$as_i];
                        my int $as_kt = $as_k->{"type"};
                        if ($as_kt == Perla::AST::N_QWORD() || ($as_kt == Perla::AST::N_ANON_ARRAY() && $as_k->{"is_ref"} != 1) || $as_kt == Perla::AST::N_RANGE()) {
                            my scalar $as_elems = $as_k->{"elems"};
                            if (!defined($as_elems) && $as_kt == Perla::AST::N_RANGE()) {
                                # range — expand at runtime
                                emit($cg, "{ int64_t __dr_a = strada_to_int(");
                                gen_expr($cg, $as_k->{"from"});
                                emit($cg, "); int64_t __dr_b = strada_to_int(");
                                gen_expr($cg, $as_k->{"to"});
                                emit($cg, "); for (int64_t __dr_i = __dr_a; __dr_i <= __dr_b; __dr_i++) strada_array_push_take(__das_kv, STRADA_MAKE_TAGGED_INT(__dr_i)); } ");
                            } elsif (defined($as_elems)) {
                                my int $as_ei = 0;
                                while ($as_ei < scalar(@{$as_elems})) {
                                    emit($cg, "strada_array_push(__das_kv, ");
                                    gen_expr($cg, $as_elems->[$as_ei]);
                                    emit($cg, "); ");
                                    $as_ei++;
                                }
                            }
                        } else {
                            emit($cg, "strada_array_push(__das_kv, ");
                            gen_expr($cg, $as_k);
                            emit($cg, "); ");
                        }
                        $as_i++;
                    }
                }
                emit($cg, "if (__das_av && __das_kv) { for (size_t __di = 0; __di < __das_kv->size; __di++) { ");
                emit($cg, "  int64_t __dki = strada_to_int(__das_kv->elements[__das_kv->head + __di]); ");
                emit($cg, "  StradaValue *__dv = strada_array_delete_idx(__das_av, __dki); ");
                emit($cg, "  strada_array_push_take(__das_rv, __dv); ");
                emit($cg, "} } strada_decref(__das_ks); __das_r; })");
            } else {
                emit($cg, "/* delete: unhandled arg type " . $arg->{"type"} . " */ strada_new_undef()");
            }
        }
        return;
    }

    # chomp — in-place, modifies the variable
    if ($name eq "chomp") {
        # Multi-arg form: `chomp(\$a, \$b, \$c)` chomps each in place.
        # All-scalar-var fast path — emit a per-arg chomp inline.
        if ($argc > 1) {
            my int $ch_all_simple = 1;
            my int $chk = 0;
            while ($chk < $argc) {
                if ($args->[$chk]->{"type"} != Perla::AST::N_SCALAR_VAR()) {
                    $ch_all_simple = 0;
                    last;
                }
                $chk++;
            }
            if ($ch_all_simple == 1) {
                emit($cg, "({ ");
                my int $chi = 0;
                while ($chi < $argc) {
                    my str $chvname = $args->[$chi]->{"name"};
                    my str $chcvar = ($chvname eq "_") ? "perla_dollar_underscore" : c_var($chvname);
                    emit($cg, "if (" . $chcvar . ") { ");
                    emit($cg, "char *__chs_" . $chi . " = strada_to_str(" . $chcvar . "); ");
                    emit($cg, "char *__chc_" . $chi . " = perla_chomp_irs(__chs_" . $chi . "); ");
                    # Preserve SVf_UTF8 from the source SV.
                    emit($cg, "StradaValue *__chnv_" . $chi . " = strada_new_str_like(__chc_" . $chi . ", " . $chcvar . "); ");
                    emit($cg, "strada_decref(" . $chcvar . "); " . $chcvar . " = __chnv_" . $chi . "; ");
                    emit($cg, "free(__chs_" . $chi . "); free(__chc_" . $chi . "); } ");
                    $chi++;
                }
                emit($cg, "STRADA_MAKE_TAGGED_INT(" . $argc . "); })");
                return;
            }
            # Mixed types: chomp just the first arg via the existing single-
            # arg path (matches the prior behavior so nothing regresses).
        }
        if ($argc > 0) {
            # If arg is itself a side-effecting lvalue (my $x = …, $x = …),
            # hoist to a prelude and rewrite to the underlying scalar var so
            # we don't re-evaluate it on the mutating assign (same pattern
            # as s/// and tr///).
            my int $at0 = $args->[0]->{"type"};
            my str $ch_vname = "";
            if ($at0 == Perla::AST::N_MY()) {
                my scalar $mn = $args->[0];
                my scalar $mv = $mn->{"var"};
                if (!defined($mv) && defined($mn->{"vars"}) && scalar(@{$mn->{"vars"}}) > 0) {
                    my scalar $mv0 = $mn->{"vars"}->[0];
                    if (defined($mv0->{"var"})) { $mv = $mv0->{"var"}; }
                }
                # Only hoist as scalar when the my-decl is itself a scalar.
                # `chomp(my @ml = split ...)` would otherwise read @ml as a
                # scalar string and overwrite v_ml with the chomped result,
                # so @ml ended up empty when later iterated.
                if (defined($mv) && length("" . $mv->{"value"}) > 0
                    && defined($mv->{"type"})
                    && "" . $mv->{"type"} ne "ARRAY_VAR"
                    && "" . $mv->{"type"} ne "HASH_VAR") {
                    $ch_vname = $mv->{"value"};
                }
            } elsif ($at0 == Perla::AST::N_ASSIGN() && defined($args->[0]->{"op"}) && $args->[0]->{"op"} eq "=") {
                my scalar $at = $args->[0]->{"target"};
                if (defined($at) && $at->{"type"} == Perla::AST::N_SCALAR_VAR()) {
                    $ch_vname = "" . $at->{"name"};
                }
            }
            # Element-style chomp on $_[N], $arr[N], $hash{k}, $ref->{k}, etc.
            # Route through _emit_subst_writeback so the chomped value is
            # written back into the array/hash slot.
            my int $ch_is_elem = 0;
            if ($at0 == Perla::AST::N_ARRAY_ELEM()
                || $at0 == Perla::AST::N_ARROW_ARRAY()
                || $at0 == Perla::AST::N_HASH_ELEM()
                || $at0 == Perla::AST::N_ARROW_HASH()
                || $at0 == Perla::AST::N_DEREF_SCALAR()) {
                $ch_is_elem = 1;
            }
            if ($ch_is_elem == 1) {
                # chomp on array element: emit the fetch + writeback
                # inline rather than going through emit_subst_writeback
                # (which was crashing perla compile-time on the array
                # branch — root cause not yet diagnosed, but the inline
                # pattern below avoids the bad codepath entirely).
                # Hash element still goes through the writeback helper.
                if (($at0 == Perla::AST::N_ARRAY_ELEM() || $at0 == Perla::AST::N_ARROW_ARRAY())
                    && defined($args->[0]->{"index"})) {
                    my scalar $ce_arr = $args->[0];
                    my scalar $ce_array_obj = ($at0 == Perla::AST::N_ARRAY_ELEM())
                        ? $ce_arr->{"array"} : $ce_arr->{"object"};
                    my int $ce_is_arrow = 0;
                    if ($at0 == Perla::AST::N_ARROW_ARRAY()
                        && defined($ce_arr->{"is_explicit_arrow"})
                        && $ce_arr->{"is_explicit_arrow"} == 1) {
                        $ce_is_arrow = 1;
                    }
                    emit($cg, "({ StradaArray *__ce_av = strada_deref_array(");
                    if ($ce_is_arrow == 0 && defined($ce_array_obj)
                        && $ce_array_obj->{"type"} == Perla::AST::N_SCALAR_VAR()
                        && $ce_array_obj->{"name"} eq "_") {
                        emit($cg, "perla_at_");
                    } elsif ($ce_is_arrow == 0 && defined($ce_array_obj)
                             && $ce_array_obj->{"type"} == Perla::AST::N_SCALAR_VAR()
                             && index($ce_array_obj->{"name"}, "::") < 0) {
                        emit($cg, c_var_a($ce_array_obj->{"name"}));
                    } else {
                        gen_expr($cg, $ce_array_obj);
                    }
                    emit($cg, "); int __ce_idx = (int)strada_to_int(");
                    gen_expr($cg, $ce_arr->{"index"});
                    emit($cg, "); if (__ce_idx < 0 && __ce_av) __ce_idx += strada_array_length(__ce_av); ");
                    emit($cg, "StradaValue *__ce_old = __ce_av ? strada_array_get(__ce_av, __ce_idx) : NULL; ");
                    emit($cg, "char *__s = strada_to_str(__ce_old); size_t __sl_pre = __s ? strlen(__s) : 0; ");
                    emit($cg, "char *__c = perla_chomp_irs(__s); size_t __sl_post = __c ? strlen(__c) : 0; ");
                    emit($cg, "StradaValue *__nv = strada_new_str_like(__c, __ce_old); ");
                    emit($cg, "if (__ce_av) strada_array_set(__ce_av, __ce_idx, __nv); else strada_decref(__nv); ");
                    emit($cg, "free(__s); free(__c); STRADA_MAKE_TAGGED_INT((int64_t)(__sl_pre - __sl_post)); })");
                    return;
                }
                emit($cg, "({ StradaValue *__ch_in = ");
                gen_expr($cg, $args->[0]);
                emit($cg, "; char *__s = strada_to_str(__ch_in); size_t __sl_pre = __s ? strlen(__s) : 0; ");
                emit($cg, "char *__c = perla_chomp_irs(__s); size_t __sl_post = __c ? strlen(__c) : 0; ");
                emit($cg, "StradaValue *__nv = strada_new_str_like(__c, __ch_in); ");
                Perla::CodeGen::Subst::emit_subst_writeback($cg, $args->[0], "__nv");
                emit($cg, " free(__s); free(__c); STRADA_MAKE_TAGGED_INT((int64_t)(__sl_pre - __sl_post)); })");
                return;
            }
            # Only chomp targets we can assign back to (plain scalar var, or
            # hoist-able scalar assign/my). Complex targets (e.g. chomp(@lines
             # = <STDIN>) which chomps per-element) fall back to a TODO that
             # still type-checks.
            my int $ch_ok = 0;
            if ($at0 == Perla::AST::N_SCALAR_VAR()) { $ch_ok = 1; }
            if (length($ch_vname) > 0) { $ch_ok = 1; }
            if ($ch_ok == 1) {
                emit($cg, "({ ");
                if (length($ch_vname) > 0) {
                    my str $cvar_ch = c_var($ch_vname);
                    if (!defined($cg->{"declared_vars"})) { $cg->{"declared_vars"} = {}; }
                    $cg->{"declared_vars"}->{$cvar_ch} = 1;
                    gen_expr($cg, $args->[0]); emit($cg, "; ");
                    emit($cg, "if (" . $cvar_ch . ") strada_incref(" . $cvar_ch . "); ");
                    my scalar $sv_node = Perla::AST::node(Perla::AST::N_SCALAR_VAR());
                    $sv_node->{"name"} = $ch_vname;
                    $args->[0] = $sv_node;
                }
                emit($cg, "StradaValue *__ch_in = ");
                gen_expr($cg, $args->[0]);
                emit($cg, "; char *__s = strada_to_str(__ch_in); size_t __sl_pre = __s ? strlen(__s) : 0; char *__c = perla_chomp_irs(__s); size_t __sl_post = __c ? strlen(__c) : 0; ");
                gen_expr($cg, $args->[0]);
                emit($cg, " = strada_new_str_like(__c, __ch_in); free(__s); free(__c); STRADA_MAKE_TAGGED_INT((int64_t)(__sl_pre - __sl_post)); })");
            } else {
                # Array-style: chomp(@arr) chomps each element in place.
                # Evaluate the arg to produce the array (whether `@arr` alone
                # or `@arr = <FH>`), then loop over it and rewrite each
                # element to its chomped value.
                emit($cg, "({ StradaValue *__ch_av_sv = ");
                gen_expr($cg, $args->[0]);
                emit($cg, "; StradaArray *__ch_av = strada_deref_array(__ch_av_sv); ");
                emit($cg, "int __ch_cnt = 0; ");
                emit($cg, "if (__ch_av) { for (size_t __ch_i = 0; __ch_i < __ch_av->size; __ch_i++) { ");
                emit($cg, "StradaValue *__ch_el = __ch_av->elements[__ch_av->head + __ch_i]; ");
                emit($cg, "if (!__ch_el) continue; char *__ch_s = strada_to_str(__ch_el); ");
                emit($cg, "size_t __ch_sl = __ch_s ? strlen(__ch_s) : 0; ");
                # Route through perla_chomp_irs so chomp respects $/ (notably
                # the slurp-mode no-op when $/ is undef).
                emit($cg, "char *__ch_c = perla_chomp_irs(__ch_s); size_t __ch_new_sl = __ch_c ? strlen(__ch_c) : 0; ");
                emit($cg, "if (__ch_new_sl < __ch_sl) { __ch_cnt += (int)(__ch_sl - __ch_new_sl); ");
                emit($cg, "StradaValue *__ch_nv = strada_new_str_like(__ch_c, __ch_el); ");
                emit($cg, "strada_array_set(__ch_av, __ch_i, __ch_nv); } free(__ch_s); free(__ch_c); } } ");
                emit($cg, "STRADA_MAKE_TAGGED_INT(__ch_cnt); })");
            }
        } else {
            # chomp with no args: default to $_
            emit($cg, "({ StradaValue *__ch_in = perla_dollar_underscore ? perla_dollar_underscore : strada_new_str(\"\"); ");
            emit($cg, "char *__s = strada_to_str(__ch_in); ");
            emit($cg, "size_t __sl_pre = __s ? strlen(__s) : 0; ");
            emit($cg, "char *__c = perla_chomp_irs(__s); size_t __sl_post = __c ? strlen(__c) : 0; ");
            emit($cg, "StradaValue *__ch_nv = strada_new_str_like(__c, __ch_in); ");
            emit($cg, "if (perla_dollar_underscore) strada_decref(perla_dollar_underscore); ");
            emit($cg, "perla_dollar_underscore = __ch_nv; free(__s); free(__c); STRADA_MAKE_TAGGED_INT((int64_t)(__sl_pre - __sl_post)); })");
        }
        return;
    }

    # length — must use the binary-safe stored length, not strlen,
    # so `length(chr(0))` returns 1 and embedded NULs in strings
    # are counted correctly.
    if ($name eq "length") {
        # Perl: length(undef) returns undef, not 0. Other args return
        # the character length. Scalar context on arg — without it,
        # `length(returns_list())` in print args got the stringification
        # of an empty STRADA_ARRAY ("array(0x...)" → length 21) instead
        # of length of last value.
        # Tied scalars: dispatch FETCH before length check — without
        # this, `length($tied_x)` sees the placeholder STRADA_UNDEF
        # type on the tied SV and returns undef. Match perl: FETCH
        # first, then measure the result.
        emit($cg, "({ int __sav_wl_len = __perla_want_list; __perla_want_list = 0; StradaValue *__lv = ");
        if ($argc > 0) { gen_expr($cg, $args->[0]); }
        else { emit($cg, "perla_dollar_underscore ? perla_dollar_underscore : strada_new_str(\"\")"); }
        emit($cg, "; __perla_want_list = __sav_wl_len; ");
        emit($cg, "StradaValue *__lv_f = NULL; ");
        emit($cg, "if (__lv && !STRADA_IS_TAGGED_INT(__lv) && __lv->meta && __lv->meta->is_tied && __lv->meta->tied_obj) { __lv_f = strada_tied_scalar_fetch(__lv); __lv = __lv_f; } ");
        # `use bytes` switches length() to byte count regardless of
        # SVf_UTF8 flag — emit STRADA_STR_BYTELEN instead of the char-
        # counting strada_str_len. Outside `use bytes`, the runtime
        # strada_str_len counts codepoints when the flag is set, bytes
        # otherwise (matches Perl).
        my int $__len_bytes = 0;
        if (defined($cg->{"use_bytes"}) && $cg->{"use_bytes"} == 1) { $__len_bytes = 1; }
        if ($__len_bytes == 1) {
            emit($cg, "StradaValue *__lr = (!__lv || (!STRADA_IS_TAGGED_INT(__lv) && __lv->type == STRADA_UNDEF)) ? strada_new_undef() : STRADA_MAKE_TAGGED_INT((int64_t)((__lv && !STRADA_IS_TAGGED_INT(__lv) && __lv->type == STRADA_STR) ? (STRADA_STR_BYTELEN(__lv) ? STRADA_STR_BYTELEN(__lv) : (__lv->value.pv ? strlen(__lv->value.pv) : 0)) : strada_str_len(__lv))); ");
        } else {
            emit($cg, "StradaValue *__lr = (!__lv || (!STRADA_IS_TAGGED_INT(__lv) && __lv->type == STRADA_UNDEF)) ? strada_new_undef() : STRADA_MAKE_TAGGED_INT((int64_t)strada_str_len(__lv)); ");
        }
        emit($cg, "if (__lv_f) strada_decref(__lv_f); __lr; })");
        return;
    }

    # pos — current /g match position. Only meaningful inside a
    # `while (\$s =~ /pat/g)` loop, where the surrounding codegen has
    # set regex_g_pos_var to the local size_t var tracking the position.
    # Outside that context, return undef (matches Perl).
    if ($name eq "pos") {
        if (defined($cg->{"regex_g_pos_var"}) && length($cg->{"regex_g_pos_var"}) > 0) {
            emit($cg, "STRADA_MAKE_TAGGED_INT((int64_t)" . $cg->{"regex_g_pos_var"} . ")");
        } elsif ($argc >= 1) {
            # pos($sv) reads sv->meta->regex_pos (set by /g matches).
            # Returns undef if unset or no meta.
            emit($cg, "({ StradaValue *__pv = ");
            gen_expr($cg, $args->[0]);
            emit($cg, "; StradaValue *__pr; if (__pv && !STRADA_IS_TAGGED_INT(__pv) && __pv->meta && __pv->meta->regex_pos >= 0) { __pr = STRADA_MAKE_TAGGED_INT((int64_t)__pv->meta->regex_pos); } else { __pr = strada_new_undef(); } __pr; })");
        } else {
            emit($cg, "strada_new_undef()");
        }
        return;
    }

    # substr
    if ($name eq "substr") {
        if ($argc == 4) {
            # 4-arg substr: substr(\$str, off, len, REPL) replaces the
            # substring with REPL AND returns the original substring.
            # Was falling through to 3-arg (no replacement) and silently
            # dropping REPL.
            emit($cg, "({ ");
            emit($cg, "StradaValue *__sub_old = strada_substr(");
            gen_expr($cg, $args->[0]);
            emit($cg, ", (int)strada_to_num(");
            gen_expr($cg, $args->[1]);
            emit($cg, "), (int)strada_to_num(");
            gen_expr($cg, $args->[2]);
            emit($cg, ")); ");
            emit($cg, "char *__sub_repl = strada_to_str(");
            gen_expr($cg, $args->[3]);
            emit($cg, "); ");
            emit($cg, "strada_substr_assign(&(");
            gen_expr($cg, $args->[0]);
            emit($cg, "), (int64_t)strada_to_num(");
            gen_expr($cg, $args->[1]);
            emit($cg, "), (int64_t)strada_to_num(");
            gen_expr($cg, $args->[2]);
            emit($cg, "), __sub_repl); free(__sub_repl); __sub_old; })");
            return;
        }
        if ($argc >= 3) {
            emit($cg, "strada_substr(");
            gen_expr($cg, $args->[0]);
            emit($cg, ", (int)strada_to_num(");
            gen_expr($cg, $args->[1]);
            emit($cg, "), (int)strada_to_num(");
            gen_expr($cg, $args->[2]);
            emit($cg, "))");
        } elsif ($argc >= 2) {
            # substr with just offset — to end of string. Route through
            # strada_substr (char-oriented for UTF-8 strings, byte-
            # oriented for raw); pass INT64_MAX as the length sentinel
            # so the runtime clamps to end. The previous inline emit
            # used byte offsets unconditionally, breaking
            # `use utf8; substr($s, 6)` on a multibyte string.
            emit($cg, "strada_substr(");
            gen_expr($cg, $args->[0]);
            emit($cg, ", (int64_t)strada_to_num(");
            gen_expr($cg, $args->[1]);
            emit($cg, "), INT64_MAX)");
        }
        return;
    }

    # join
    if ($name eq "join") {
        if ($argc == 1) {
            # join(SEP) with no list — emit empty string. Perl returns "".
            # Template::Context has `join(', ')` in a debug chain.
            emit($cg, "strada_new_str(\"\")");
            return;
        }
        if ($argc == 0) {
            emit($cg, "strada_new_str(\"\")");
            return;
        }
        if ($argc >= 2) {
            # Keep sep as StradaValue* so embedded NULs (e.g. join("\x00", ...))
            # are preserved — strada_to_str followed by strlen would truncate.
            my int $sep_borrowed = expr_is_borrowed($args->[0]);
            emit($cg, "({ StradaValue *__sep_sv = (");
            gen_expr($cg, $args->[0]);
            if ($argc == 2) {
                # join(",", @array) — single arg. If the arg is an array
                # (STRADA_ARRAY), join its elements. If it's a hash, flatten
                # to (k,v,k,v,...). Otherwise treat as a single-element list
                # — `join(",", "x")` should return "x", not "" (which
                # strada_deref_array on a scalar would produce by returning
                # NULL).
                # Force list context for the second arg so chains like
                # `join(",", map {...} sort {...} keys %h)` propagate
                # list context to keys (which otherwise returns count).
                emit($cg, "); int __sav_wl_jn = __perla_want_list; __perla_want_list = 1; StradaValue *__jv = ");
                gen_expr($cg, $args->[1]);
                emit($cg, "; __perla_want_list = __sav_wl_jn");
                emit($cg, "; StradaArray *__jav = strada_deref_array(__jv); ");
                emit($cg, "StradaValue *__jfb = NULL; ");
                emit($cg, "if (!__jav && __jv && !STRADA_IS_TAGGED_INT(__jv) && __jv->type == STRADA_HASH && __jv->value.hv) { ");
                emit($cg, "  __jfb = strada_new_array(); StradaArray *__hf_av = strada_deref_array(__jfb); ");
                emit($cg, "  StradaArray *__hf_keys = strada_hash_keys(__jv->value.hv); ");
                emit($cg, "  if (__hf_keys) { for (size_t __hf_i = 0; __hf_i < __hf_keys->size; __hf_i++) { ");
                emit($cg, "    StradaValue *__hf_k = __hf_keys->elements[__hf_keys->head + __hf_i]; ");
                emit($cg, "    char *__hf_ks = strada_to_str(__hf_k); ");
                emit($cg, "    StradaValue *__hf_v = strada_hash_get(__jv->value.hv, __hf_ks); ");
                emit($cg, "    free(__hf_ks); ");
                emit($cg, "    if (__hf_k) strada_incref(__hf_k); strada_array_push(__hf_av, __hf_k); ");
                emit($cg, "    if (__hf_v) strada_incref(__hf_v); strada_array_push(__hf_av, __hf_v); ");
                emit($cg, "  } strada_free_array(__hf_keys); } __jav = __hf_av; ");
                emit($cg, "} else if (!__jav && __jv) { __jfb = strada_new_array(); strada_array_push(strada_deref_array(__jfb), __jv); __jav = strada_deref_array(__jfb); } ");
                my int $jv_borrowed = expr_is_borrowed($args->[1]);
                emit($cg, "StradaValue *__jr = strada_join_sv(__sep_sv, __jav); ");
                emit($cg, "if (__jfb) strada_decref(__jfb); ");
                # Decref the SEP and LIST temps when they were owned exprs.
                # Without this, `join("|", LIST)` leaked the "|" literal
                # plus the LIST array container once per call.
                if ($sep_borrowed == 0) {
                    emit($cg, "if (__sep_sv) strada_decref(__sep_sv); ");
                }
                if ($jv_borrowed == 0) {
                    emit($cg, "if (__jv) strada_decref(__jv); ");
                }
                emit($cg, "__jr; })");
            } else {
                # join(",", "a", @b, "c", @d) — mixed scalars and arrays.
                # Each array argument must FLATTEN into the joined list (Perl
                # list-context semantics) — without flatten, perla's
                # `join('', $prefix, @msg)` produced just $prefix because
                # @msg got pushed as one ARRAY element and join()'s
                # stringification yielded "" for it. DBIx::Class::Carp's
                # `join('', $calling, @_)` was the visible casualty:
                # `{UNKNOWN}: <real message>` collapsed to `{UNKNOWN}: `,
                # the bizowie BZ:6 plateau's empty diagnostics.
                emit($cg, "); StradaValue *__ja = strada_new_array(); StradaArray *__jav = strada_deref_array(__ja); ");
                my int $ji = 1;
                while ($ji < $argc) {
                    my int $j_at = $args->[$ji]->{"type"};
                    my int $j_is_call = ($j_at == Perla::AST::N_CALL()
                                         || $j_at == Perla::AST::N_METHOD()) ? 1 : 0;
                    # Force list context for sub/method calls so
                    # `return (...)` produces an array, not just the
                    # last element. Without this, `join("-", mk(), "x")`
                    # where mk returns ("a","b") collapsed to "b-x"
                    # because mk() inherited the outer scalar context.
                    if ($j_is_call == 1) {
                        emit($cg, "{ int __j_sav_wl = __perla_want_list; __perla_want_list = 1; StradaValue *__jve = ");
                        gen_expr($cg, $args->[$ji]);
                        emit($cg, "; __perla_want_list = __j_sav_wl; ");
                    } else {
                        emit($cg, "{ StradaValue *__jve = ");
                        gen_expr($cg, $args->[$ji]);
                        emit($cg, "; ");
                    }
                    emit($cg, "if (__jve && !STRADA_IS_TAGGED_INT(__jve) && __jve->type == STRADA_ARRAY) { ");
                    emit($cg, "StradaArray *__jvea = strada_deref_array(__jve); if (__jvea) { for (size_t __jvi = 0; __jvi < __jvea->size; __jvi++) { ");
                    emit($cg, "StradaValue *__jvel = __jvea->elements[__jvea->head + __jvi]; if (__jvel) strada_incref(__jvel); strada_array_push(__jav, __jvel); } } ");
                    emit($cg, "} else { strada_array_push(__jav, __jve); } } ");
                    $ji++;
                }
                emit($cg, "StradaValue *__jr = strada_join_sv(__sep_sv, __jav); ");
                if ($sep_borrowed == 0) {
                    emit($cg, "if (__sep_sv) strada_decref(__sep_sv); ");
                }
                emit($cg, "strada_decref(__ja); __jr; })");
            }
        }
        return;
    }

    # split
    if ($name eq "split") {
        # `split` with no args = `split " ", $_` (whitespace split on $_).
        # Without this, perla treated `split` as a bareword and returned
        # empty for `split` in `map { split }` etc.
        if ($argc == 0) {
            # No-arg split: arm subject_len from $_ so NUL bytes in the
            # subject don't truncate the regex/string split below.
            emit($cg, "({ char *__sp = strdup(\"\\\\s+\"); ");
            emit($cg, "StradaValue *__ssv = perla_dollar_underscore ? perla_dollar_underscore : strada_new_str(\"\"); ");
            emit($cg, "strada_regex_set_subject_for_sv(__ssv); ");
            emit($cg, "char *__ss_raw = strada_to_str(__ssv); ");
            emit($cg, "char *__ss = __ss_raw; while (*__ss == ' ' || *__ss == '\\t' || *__ss == '\\n' || *__ss == '\\r') __ss++; ");
            emit($cg, "char *__ss_dup = strdup(__ss); free(__ss_raw); __ss = __ss_dup; ");
            emit($cg, "StradaArray *__sa = strada_regex_split(__ss, __sp); ");
            emit($cg, "strada_regex_clear_subject_len(); ");
            emit($cg, "while (__sa && __sa->size > 0) { StradaValue *__last = __sa->elements[__sa->head + __sa->size - 1]; if (__last && !STRADA_IS_TAGGED_INT(__last) && __last->type == STRADA_STR && (!__last->value.pv || __last->value.pv[0] == 0)) { __sa->size--; if (__last) strada_decref(__last); } else break; } ");
            emit($cg, "StradaValue *__sr = strada_new_array_from_av(__sa); ");
            emit($cg, "if (__ssv && !STRADA_IS_TAGGED_INT(__ssv) && __ssv->type == STRADA_STR && STRADA_STR_IS_UTF8(__ssv)) strada_array_set_utf8_flag(__sr, 1); ");
            emit($cg, "free(__sp); free(__ss); __sr; })");
            return;
        }
        if ($argc >= 1) {
            # Extract pattern: if first arg is a regex, use its pattern directly.
            # `m{/}` parses as `\$_ =~ /pat/` (N_BINOP). When it lands in
            # split's first slot we need the inner /pat/, not the implicit
            # \$_-match. Unwrap.
            my scalar $split_pat = $args->[0];
            if (defined($split_pat) && $split_pat->{"type"} == Perla::AST::N_BINOP()
                && defined($split_pat->{"op"}) && $split_pat->{"op"} eq "=~"
                && defined($split_pat->{"right"})
                && $split_pat->{"right"}->{"type"} == Perla::AST::N_REGEX()
                && defined($split_pat->{"left"})
                && $split_pat->{"left"}->{"type"} == Perla::AST::N_SCALAR_VAR()
                && defined($split_pat->{"left"}->{"name"})
                && $split_pat->{"left"}->{"name"} eq "_") {
                $split_pat = $split_pat->{"right"};
            }
            my int $is_regex_arg = 0;
            if (defined($split_pat) && $split_pat->{"type"} == Perla::AST::N_REGEX()) {
                $is_regex_arg = 1;
            }
            # Perl special: `split " "` (literal one-space string) acts
            # like `split /\s+/` AND strips leading whitespace from the
            # input. Detect a STR_LIT or no-interp INTERP_STR with value
            # " " and substitute the regex pattern "\\s+" with a leading-
            # whitespace-strip preprocessor.
            my int $is_special_space = 0;
            if ($is_regex_arg == 0 && defined($split_pat)) {
                my int $spt = $split_pat->{"type"};
                if ($spt == Perla::AST::N_STR_LIT() && "" . $split_pat->{"value"} eq " ") {
                    $is_special_space = 1;
                } elsif ($spt == Perla::AST::N_INTERP_STR() && "" . $split_pat->{"value"} eq " ") {
                    $is_special_space = 1;
                }
            }
            if ($is_special_space == 1) {
                # Capture subject SV first so we can propagate SVf_UTF8
                # to the result pieces.
                emit($cg, "({ char *__sp = strdup(\"\\\\s+\"); StradaValue *__ssv = ");
                if ($argc >= 2) {
                    gen_expr($cg, $args->[1]);
                } else {
                    emit($cg, "(perla_dollar_underscore ? perla_dollar_underscore : strada_new_str(\"\"))");
                }
                emit($cg, "; char *__ss_raw = strada_to_str(__ssv); ");
                emit($cg, "/* strip leading whitespace */ char *__ss = __ss_raw; while (*__ss == ' ' || *__ss == '\\t' || *__ss == '\\n' || *__ss == '\\r') __ss++; ");
                emit($cg, "char *__ss_dup = strdup(__ss); free(__ss_raw); __ss = __ss_dup; ");
                emit($cg, "StradaArray *__sa = strada_regex_split(__ss, __sp); ");
                # split " " also strips TRAILING empty fields by default
                # (like split without a third arg). Without this, leftover
                # whitespace at the end of the input produced a final ""
                # element. Reference Perl: `split " ", "  a b  "` → ("a","b").
                emit($cg, "while (__sa && __sa->size > 0) { ");
                emit($cg, "  StradaValue *__last = __sa->elements[__sa->head + __sa->size - 1]; ");
                emit($cg, "  if (__last && !STRADA_IS_TAGGED_INT(__last) && __last->type == STRADA_STR && (!__last->value.pv || __last->value.pv[0] == 0)) { ");
                emit($cg, "    __sa->size--; if (__last) strada_decref(__last); ");
                emit($cg, "  } else break; ");
                emit($cg, "} ");
                if ($argc >= 3) {
                    emit($cg, "int __sl = (int)strada_to_int(");
                    gen_expr($cg, $args->[2]);
                    emit($cg, "); if (__sl > 0 && (int)__sa->size > __sl) { ");
                    emit($cg, "StradaValue *__tail = strada_new_str(\"\"); ");
                    emit($cg, "for (int __si = __sl - 1; __si < (int)__sa->size; __si++) { ");
                    emit($cg, "if (__si > __sl - 1) __tail = strada_concat_sv(__tail, strada_new_str(__sp)); ");
                    emit($cg, "__tail = strada_concat_sv(__tail, __sa->elements[__si]); } ");
                    emit($cg, "__sa->elements[__sl - 1] = __tail; __sa->size = __sl; } ");
                }
                emit($cg, "StradaValue *__sr = strada_new_array_from_av(__sa); ");
                emit($cg, "if (__ssv && !STRADA_IS_TAGGED_INT(__ssv) && __ssv->type == STRADA_STR && STRADA_STR_IS_UTF8(__ssv)) strada_array_set_utf8_flag(__sr, 1); ");
                # If the subject was an owned expression (e.g. concat
                # result, not just $_/var), decref it. Borrowed inputs
                # skip the decref to avoid corrupting the caller's slot.
                my int $__ss_borrowed_sp = 0;
                if ($argc >= 2) {
                    $__ss_borrowed_sp = expr_is_borrowed($args->[1]);
                    if ($args->[1]->{"type"} == Perla::AST::N_SCALAR_VAR()
                        && defined($args->[1]->{"name"})
                        && $args->[1]->{"name"} eq "_") {
                        $__ss_borrowed_sp = 1;
                    }
                } else {
                    $__ss_borrowed_sp = 1;
                }
                if ($__ss_borrowed_sp == 0) {
                    emit($cg, "if (__ssv) strada_decref(__ssv); ");
                }
                emit($cg, "free(__sp); free(__ss); __sr; })");
                return;
            }

            if ($is_regex_arg == 1) {
                # Prepend inline flags (?ims…) so the pattern carries
                # its modifiers into strada_regex_split (which only takes
                # a bare pattern arg). Without this, `split /^/m` lost
                # the /m flag and split at one position instead of every
                # line-start.
                my str $sp_flags = "";
                if (defined($split_pat->{"flags"})) { $sp_flags = "" . $split_pat->{"flags"}; }
                my str $sp_prefix = "";
                if (length($sp_flags) > 0) {
                    # Filter to PCRE2-recognized inline flags (i, m, s, x).
                    my str $sp_kept = "";
                    my int $sp_fi = 0;
                    while ($sp_fi < length($sp_flags)) {
                        my str $sp_fc = substr($sp_flags, $sp_fi, 1);
                        if ($sp_fc eq "i" || $sp_fc eq "m" || $sp_fc eq "s" || $sp_fc eq "x") {
                            $sp_kept = $sp_kept . $sp_fc;
                        }
                        $sp_fi = $sp_fi + 1;
                    }
                    if (length($sp_kept) > 0) { $sp_prefix = "(?" . $sp_kept . ")"; }
                }
                # Detect `$var` interpolation in the pattern; build the
                # runtime pattern via gen_interp_c_str (matches the m// path).
                # Without this, `split /\Q$d\E/, $s` had `\Q$d\E` emitted
                # literally — split saw the unsubstituted source and never
                # matched the actual delimiter.
                my int $sp_pat_has_var = has_perl_var($split_pat->{"pattern"});
                if ($sp_pat_has_var == 1) {
                    emit($cg, "({ StradaValue *__ssv = NULL; char *__sp = strada_to_str(");
                    if (length($sp_prefix) > 0) {
                        emit($cg, "strada_concat_sv(PERLA_NEW_STR_LIT(\"" . Perla::CodeGen::Escape::escape_c_str($sp_prefix) . "\"), ");
                        Perla::CodeGen::Interp::gen_interp_c_str($cg, $split_pat->{"pattern"});
                        emit($cg, ")");
                    } else {
                        Perla::CodeGen::Interp::gen_interp_c_str($cg, $split_pat->{"pattern"});
                    }
                    emit($cg, "); char *__ss = ({ StradaValue *__tmp = (");
                } else {
                    emit($cg, "({ StradaValue *__ssv = NULL; char *__sp = strdup(\"" . Perla::CodeGen::Escape::escape_c_str($sp_prefix . $split_pat->{"pattern"}) . "\"); char *__ss = ({ StradaValue *__tmp = (");
                }
            } else {
                emit($cg, "({ StradaValue *__ssv = NULL; char *__sp = strada_to_str(");
                gen_expr($cg, $args->[0]);
                emit($cg, "); char *__ss = ({ StradaValue *__tmp = (");
            }
            # In Perl, `split PATTERN` without a string arg defaults to $_.
            if ($argc >= 2) {
                gen_expr($cg, $args->[1]);
            } else {
                emit($cg, "(perla_dollar_underscore ? perla_dollar_underscore : strada_new_str(\"\"))");
            }
            # Close the StradaValue capture (started by the `__ss = ({
            # StradaValue *__tmp = (` chunks above), arm subject_len so
            # the split below honours embedded NULs, then finish the
            # strada_to_str of __tmp. Stash __tmp into __ssv at the
            # outer scope so we can decref it after the char* has been
            # consumed — otherwise `split /,/, "literal $i"` leaks the
            # concat result once per call.
            emit($cg, "); strada_regex_set_subject_for_sv(__tmp); __ssv = __tmp; strada_to_str(__tmp); }); ");
            if ($argc >= 3) {
                # split with limit: use limit-aware runtime to preserve
                # the original separators in the tail. Perl's `split LIMIT`
                # semantics: positive LIMIT keeps trailing empties; LIMIT
                # <= 0 drops them (same as no LIMIT, with -1 keeping them).
                emit($cg, "int __sl = (int)strada_to_int(");
                gen_expr($cg, $args->[2]);
                emit($cg, "); StradaArray *__sa = strada_regex_split_limit(__ss, __sp, __sl);");
                emit($cg, " if (__sl == 0) { while (__sa && __sa->size > 0) { ");
                emit($cg, "  StradaValue *__last_l = __sa->elements[__sa->head + __sa->size - 1]; ");
                emit($cg, "  if (__last_l && !STRADA_IS_TAGGED_INT(__last_l) && __last_l->type == STRADA_STR && (!__last_l->value.pv || __last_l->value.pv[0] == 0)) { ");
                emit($cg, "    __sa->size--; if (__last_l) strada_decref(__last_l); ");
                emit($cg, "  } else break; ");
                emit($cg, "} }");
            } else {
                emit($cg, "StradaArray *__sa = strada_regex_split(__ss, __sp); ");
            }
            emit($cg, "strada_regex_clear_subject_len(); ");
            if ($argc < 3) {
                # No limit: strip trailing empty fields.
                emit($cg, "while (__sa && __sa->size > 0) { ");
                emit($cg, "  StradaValue *__last = __sa->elements[__sa->head + __sa->size - 1]; ");
                emit($cg, "  if (__last && !STRADA_IS_TAGGED_INT(__last) && __last->type == STRADA_STR && (!__last->value.pv || __last->value.pv[0] == 0)) { ");
                emit($cg, "    __sa->size--; if (__last) strada_decref(__last); ");
                emit($cg, "  } else break; ");
                emit($cg, "} ");
            }
            # Decref __ssv (the subject-string SV captured via __tmp at
            # the inner block) if the subject arg was an owned expression.
            # `split /,/, $var` (borrowed) skips this; `split /,/, "literal
            # $i"` decrefs the concat result.
            my int $ss_borrowed = 0;
            if ($argc >= 2) {
                $ss_borrowed = expr_is_borrowed($args->[1]);
                # `$_` (perla_dollar_underscore) is a global var — treat as borrowed.
                if ($args->[1]->{"type"} == Perla::AST::N_SCALAR_VAR()
                    && defined($args->[1]->{"name"})
                    && $args->[1]->{"name"} eq "_") {
                    $ss_borrowed = 1;
                }
            } else {
                $ss_borrowed = 1;  # implicit $_
            }
            if ($ss_borrowed == 0) {
                emit($cg, "if (__ssv) strada_decref(__ssv); ");
            }
            emit($cg, "StradaValue *__sr = strada_new_array_from_av(__sa); ");
            # Propagate SVf_UTF8 from subject SV to each result piece —
            # split splits BYTES then wraps each piece in a fresh STR
            # (no flag). The subject's char-orientation must follow.
            emit($cg, "if (__ssv && !STRADA_IS_TAGGED_INT(__ssv) && __ssv->type == STRADA_STR && STRADA_STR_IS_UTF8(__ssv)) strada_array_set_utf8_flag(__sr, 1); ");
            emit($cg, "free(__sp); free(__ss); __sr; })");
        }
        return;
    }

    # uc/lc/ucfirst/lcfirst
    if ($name eq "uc" || $name eq "lc" || $name eq "ucfirst" || $name eq "lcfirst" || $name eq "fc") {
        # Impose scalar context — without it, `lc(sub_returning_list())`
        # in print args got the array stringification "array(0x...)".
        # `fc` (fold case, Perl 5.16+ via `use feature 'fc'`) is treated
        # as an alias for lc — full Unicode case-folding diverges only
        # for non-ASCII codepoints, which is a separate gap.
        # Propagate SVf_UTF8: capture the input SV so we can stamp the
        # result with the same char-orientation flag, matching Perl's
        # `length(uc($u))` returning chars not bytes.
        my str $rt_fn = $name;
        if ($name eq "fc") { $rt_fn = "lc"; }
        emit($cg, "({ int __sav_wl_uc = __perla_want_list; __perla_want_list = 0; StradaValue *__uc_in = ");
        if ($argc > 0) { gen_expr($cg, $args->[0]); }
        else { emit($cg, "perla_dollar_underscore ? perla_dollar_underscore : strada_new_str(\"\")"); }
        emit($cg, "; __perla_want_list = __sav_wl_uc; char *__s = strada_to_str(__uc_in); int __uc_is_utf8 = (__uc_in && !STRADA_IS_TAGGED_INT(__uc_in) && __uc_in->type == STRADA_STR && STRADA_STR_IS_UTF8(__uc_in)); char *__r = __uc_is_utf8 ? strada_" . $rt_fn . "(__s) : strada_" . $rt_fn . "_ascii(__s); size_t __rl = strlen(__r); StradaValue *__rv = __uc_is_utf8 ? strada_new_str_len_utf8(__r, __rl) : strada_new_str_len(__r, __rl); free(__r); free(__s); __rv; })");
        return;
    }

    # index
    if ($name eq "index") {
        # Use strada_index_sv2 so embedded NUL bytes in either haystack
        # or needle survive (binary-safe). The legacy strada_to_str
        # path stopped at the first NUL.
        if ($argc >= 3) {
            emit($cg, "({ StradaValue *__h = ");
            gen_expr($cg, $args->[0]);
            emit($cg, "; StradaValue *__n = ");
            gen_expr($cg, $args->[1]);
            emit($cg, "; int64_t __off = strada_to_int(");
            gen_expr($cg, $args->[2]);
            emit($cg, "); int64_t __ir = strada_index_sv2(__h, __n, __off); STRADA_MAKE_TAGGED_INT(__ir); })");
        } elsif ($argc >= 2) {
            emit($cg, "({ StradaValue *__h = ");
            gen_expr($cg, $args->[0]);
            emit($cg, "; StradaValue *__n = ");
            gen_expr($cg, $args->[1]);
            emit($cg, "; int64_t __ir = strada_index_sv2(__h, __n, 0); STRADA_MAKE_TAGGED_INT(__ir); })");
        }
        return;
    }

    # rindex(haystack, needle [, position]) — Perl semantics: optional
    # third arg is the maximum position of the FOUND match (i.e., search
    # from the end but no later than position). Without it the search is
    # from the very end. We compute all match starts, then return the
    # largest start <= pos (or -1).
    if ($name eq "rindex") {
        if ($argc >= 2) {
            # Capture haystack SV so we can convert byte offset → char
            # offset when SVf_UTF8 is set (Perl's rindex returns char
            # position; perla previously returned byte position for
            # utf8 strings, off-by-one for any preceding multibyte).
            emit($cg, "({ StradaValue *__hsv = ");
            gen_expr($cg, $args->[0]);
            emit($cg, "; char *__h = strada_to_str(__hsv); char *__n = strada_to_str(");
            gen_expr($cg, $args->[1]);
            emit($cg, "); ");
            if ($argc >= 3) {
                emit($cg, "int64_t __maxp = (int64_t)strada_to_int(");
                gen_expr($cg, $args->[2]);
                emit($cg, "); ");
            } else {
                emit($cg, "int64_t __maxp = INT64_MAX; ");
            }
            emit($cg, "int64_t __best = -1; size_t __hl = strlen(__h); ");
            emit($cg, "if (__n[0] == '\\0') { __best = (__maxp < (int64_t)__hl) ? __maxp : (int64_t)__hl; } else { ");
            emit($cg, "char *__p = strstr(__h, __n); ");
            emit($cg, "while (__p) { int64_t __off = (int64_t)(__p - __h); if (__off <= __maxp) __best = __off; else break; __p = strstr(__p + 1, __n); } } ");
            # Char-offset conversion under SVf_UTF8.
            emit($cg, "if (__best >= 0 && __hsv && !STRADA_IS_TAGGED_INT(__hsv) && __hsv->type == STRADA_STR && STRADA_STR_IS_UTF8(__hsv) && !STRADA_STR_IS_ASCII(__hsv)) { __best = (int64_t)byte_to_char_offset(__h, (size_t)__best); } ");
            emit($cg, "StradaValue *__ir = STRADA_MAKE_TAGGED_INT(__best); free(__h); free(__n); __ir; })");
        }
        return;
    }

    # sprintf
    # formline(PICTURE, LIST) — runs the format-line renderer once
    # and appends the result (plus newline) to $^A. Returns 1.
    # Used by Text::Tabs and other text-shaping modules. The picture
    # is a string (often embedding \n for multi-line); the values are
    # flattened into a contiguous StradaValue* array passed to
    # perla_formline.
    if ($name eq "formline" && $argc >= 1) {
        emit($cg, "({ StradaValue *__fl_pic = ");
        gen_expr($cg, $args->[0]);
        emit($cg, "; char *__fl_pic_s = strada_to_str(__fl_pic);");
        # Build a flat StradaValue* array from the remaining args. Use
        # an alloca-allocated buffer so it auto-frees on stmt-expr exit.
        emit($cg, " StradaValue *__fl_a[" . ($argc + 1) . "];");
        emit($cg, " size_t __fl_n = 0;");
        my int $fi = 1;
        while ($fi < $argc) {
            my int $cat = $args->[$fi]->{"type"};
            if ($cat == Perla::AST::N_ARRAY_VAR()
                || $cat == Perla::AST::N_DEREF_ARRAY()) {
                emit($cg, " { StradaArray *__fla = strada_deref_array(");
                gen_expr($cg, $args->[$fi]);
                emit($cg, "); if (__fla) for (size_t __fli = 0; __fli < __fla->size && __fl_n < " . ($argc + 1) . "; __fli++) __fl_a[__fl_n++] = __fla->elements[__fla->head + __fli]; }");
            } else {
                emit($cg, " if (__fl_n < " . ($argc + 1) . ") __fl_a[__fl_n++] = ");
                gen_expr($cg, $args->[$fi]);
                emit($cg, ";");
            }
            $fi = $fi + 1;
        }
        emit($cg, " perla_formline(__fl_pic_s, __fl_a, __fl_n);");
        emit($cg, " free(__fl_pic_s);");
        emit($cg, " STRADA_MAKE_TAGGED_INT(1); })");
        return;
    }

    if ($name eq "sprintf") {
        if ($argc >= 1) {
            # Detect array-flattening args (slice / array / range / etc.).
            # If any arg needs flattening, build a StradaValue array and
            # call strada_sprintf_sv_arr (which flattens internally).
            # Otherwise emit the faster direct varargs form.
            my int $needs_flatten = 0;
            my int $ci = 1;
            while ($ci < $argc) {
                my int $cat = $args->[$ci]->{"type"};
                if ($cat == Perla::AST::N_ARRAY_VAR()
                    || $cat == Perla::AST::N_DEREF_ARRAY()
                    || $cat == Perla::AST::N_ARRAY_SLICE()
                    || $cat == Perla::AST::N_HASH_SLICE()
                    || $cat == Perla::AST::N_RANGE()
                    || $cat == Perla::AST::N_CALL()
                    || $cat == Perla::AST::N_METHOD()
                    || $cat == Perla::AST::N_GREP()
                    || $cat == Perla::AST::N_MAP()
                    || $cat == Perla::AST::N_SORT()
                    || $cat == Perla::AST::N_QWORD()) {
                    $needs_flatten = 1;
                    last;
                }
                $ci++;
            }
            if ($needs_flatten == 1) {
                emit($cg, "({ StradaValue *__sp_fmt = ");
                gen_expr($cg, $args->[0]);
                emit($cg, "; StradaValue *__sp_arr = strada_new_array(); StradaArray *__sp_av = strada_deref_array(__sp_arr); ");
                # Force list context around the slice/array args so the
                # slice's scalar-context "return last elem" branch doesn't
                # trigger when sprintf is itself called in scalar context
                # (the usual case — `my $s = sprintf(...)`).
                emit($cg, "int __sp_sav_wl = __perla_want_list; __perla_want_list = 1; ");
                my int $si = 1;
                while ($si < $argc) {
                    my int $aat = $args->[$si]->{"type"};
                    if ($aat == Perla::AST::N_ARRAY_VAR()
                        || $aat == Perla::AST::N_DEREF_ARRAY()
                        || $aat == Perla::AST::N_ARRAY_SLICE()
                        || $aat == Perla::AST::N_HASH_SLICE()
                        || $aat == Perla::AST::N_RANGE()
                        || $aat == Perla::AST::N_CALL()
                        || $aat == Perla::AST::N_METHOD()
                        || $aat == Perla::AST::N_GREP()
                        || $aat == Perla::AST::N_MAP()
                        || $aat == Perla::AST::N_SORT()
                        || $aat == Perla::AST::N_QWORD()) {
                        emit($cg, "{ StradaValue *__sp_fv = ");
                        gen_expr($cg, $args->[$si]);
                        emit($cg, "; if (__sp_fv && !STRADA_IS_TAGGED_INT(__sp_fv) && __sp_fv->type == STRADA_ARRAY) { ");
                        emit($cg, "  StradaArray *__sp_fa = __sp_fv->value.av; size_t __sp_fa_sz = __sp_fa ? __sp_fa->size : 0; size_t __sp_fa_hd = __sp_fa ? __sp_fa->head : 0; ");
                        emit($cg, "  for (size_t __sp_fi = 0; __sp_fi < __sp_fa_sz; __sp_fi++) strada_array_push(__sp_av, __sp_fa->elements[__sp_fa_hd + __sp_fi]); ");
                        emit($cg, "} else { strada_array_push(__sp_av, __sp_fv); } } ");
                    } else {
                        emit($cg, "strada_array_push(__sp_av, ");
                        gen_expr($cg, $args->[$si]);
                        emit($cg, "); ");
                    }
                    $si++;
                }
                emit($cg, "__perla_want_list = __sp_sav_wl; ");
                emit($cg, "StradaValue *__sp_r = strada_sprintf_sv_arr(__sp_fmt, __sp_arr); strada_decref(__sp_arr); __sp_r; })");
                return;
            }
            my int $nargs = $argc - 1;
            # Evaluate arguments left-to-right via temporary captures so
            # side effects fire in Perl order. Calling
            # `strada_sprintf_sv(fmt, n, a, b, c, …)` directly hands the
            # args to a varargs C function whose evaluation order is
            # unspecified — and gcc/clang typically evaluate right-to-left.
            # Track each arg's borrowed/owned status so we can decref the
            # owned temps after the call; without this the fmt string
            # literal and any computed args leak once per call.
            my int $sp_fmt_borrowed = expr_is_borrowed($args->[0]);
            emit($cg, "({ ");
            emit($cg, "StradaValue *__sp_fmt = ");
            gen_expr($cg, $args->[0]);
            emit($cg, "; ");
            my int $si = 1;
            while ($si < $argc) {
                emit($cg, "StradaValue *__sp_a" . $si . " = ");
                gen_expr($cg, $args->[$si]);
                emit($cg, "; ");
                $si++;
            }
            emit($cg, "StradaValue *__sp_r = strada_sprintf_sv(__sp_fmt, " . $nargs);
            $si = 1;
            while ($si < $argc) {
                emit($cg, ", __sp_a" . $si);
                $si++;
            }
            emit($cg, "); ");
            # Decref owned temps. Borrowed (variables, array elems) are
            # held alive by their slot — never decref those.
            if ($sp_fmt_borrowed == 0) {
                emit($cg, "if (__sp_fmt) strada_decref(__sp_fmt); ");
            }
            $si = 1;
            while ($si < $argc) {
                if (expr_is_borrowed($args->[$si]) == 0) {
                    emit($cg, "if (__sp_a" . $si . ") strada_decref(__sp_a" . $si . "); ");
                }
                $si++;
            }
            emit($cg, "__sp_r; })");
        }
        return;
    }

    # pack(FMT, LIST) → strada_pack(fmt_cstr, args_array). Without
    # dispatch, perla emitted `perla_code_get("main", "pack")` which
    # returns NULL → undef → broke binary I/O entirely.
    # vec(EXPR, OFFSET, BITS) — bit-vector accessor (rvalue form).
    # Lvalue form `vec($v, off, bits) = val` is handled in the N_ASSIGN
    # codegen which detects the vec(...) target and emits strada_vec_set
    # instead. Without that, `vec($v, 0, 8) = 65` would try to assign
    # to the result of vec() which is not an lvalue.
    if ($name eq "vec") {
        if ($argc == 3) {
            emit($cg, "STRADA_MAKE_TAGGED_INT(strada_vec_get(");
            gen_expr($cg, $args->[0]);
            emit($cg, ", strada_to_int(");
            gen_expr($cg, $args->[1]);
            emit($cg, "), (int)strada_to_int(");
            gen_expr($cg, $args->[2]);
            emit($cg, ")))");
            return;
        }
        emit($cg, "STRADA_MAKE_TAGGED_INT(0)");
        return;
    }
    if ($name eq "pack") {
        if ($argc >= 1) {
            emit($cg, "({ char *__fmt = strada_to_str(");
            gen_expr($cg, $args->[0]);
            emit($cg, "); StradaValue *__pa = strada_new_array(); ");
            my int $pi2 = 1;
            while ($pi2 < $argc) {
                my scalar $parg = $args->[$pi2];
                # pack(TEMPLATE, LIST) — every value arg is list context, and
                # list results flatten. Evaluate each arg with want_list=1
                # (so a bare range `1..5`, or reverse/map/grep/keys/values/a
                # list-returning call, yields its full list rather than the
                # scalar-context value — e.g. the flip-flop op for `1..5`),
                # then flatten if it came back as an array.
                emit($cg, "{ StradaValue *__pkv = ({ int __pk_swl = __perla_want_list; __perla_want_list = 1; StradaValue *__pk_rv = ");
                gen_expr($cg, $parg);
                emit($cg, "; __perla_want_list = __pk_swl; __pk_rv; }); if (__pkv && !STRADA_IS_TAGGED_INT(__pkv) && __pkv->type == STRADA_ARRAY) { ");
                emit($cg, "StradaArray *__pka = __pkv->value.av; ");
                emit($cg, "for (size_t __pki = 0; __pki < __pka->size; __pki++) strada_array_push(strada_deref_array(__pa), __pka->elements[__pka->head + __pki]); ");
                # A hash in list context flattens to its key/value pairs.
                emit($cg, "} else if (__pkv && !STRADA_IS_TAGGED_INT(__pkv) && __pkv->type == STRADA_HASH) { ");
                emit($cg, "StradaArray *__pkk = strada_hash_keys(__pkv->value.hv); ");
                emit($cg, "if (__pkk) { for (size_t __pki = 0; __pki < __pkk->size; __pki++) { ");
                emit($cg, "StradaValue *__pkey = __pkk->elements[__pkk->head + __pki]; char *__pks = strada_to_str(__pkey); ");
                emit($cg, "strada_array_push(strada_deref_array(__pa), __pkey); ");
                emit($cg, "strada_array_push(strada_deref_array(__pa), strada_hash_get(__pkv->value.hv, __pks ? __pks : \"\")); ");
                emit($cg, "if (__pks) free(__pks); } strada_free_array(__pkk); } ");
                emit($cg, "} else { strada_array_push(strada_deref_array(__pa), __pkv); } } ");
                $pi2++;
            }
            emit($cg, "StradaValue *__pr = strada_pack(__fmt, __pa); free(__fmt); strada_decref(__pa); __pr; })");
        }
        return;
    }

    if ($name eq "unpack") {
        if ($argc >= 2) {
            # Perl's unpack in scalar context returns only the FIRST
            # element of the result list (not the count). `my $hex =
            # unpack("H*", "AB")` returns "4142", not 1. perla used to
            # collapse to the array's `last element` count (1 here) via
            # the generic scalar-context array → length conversion.
            emit($cg, "({ char *__fmt = strada_to_str(");
            gen_expr($cg, $args->[0]);
            emit($cg, "); StradaValue *__dv = ");
            gen_expr($cg, $args->[1]);
            emit($cg, "; StradaValue *__pr = strada_unpack(__fmt, __dv); free(__fmt); ");
            emit($cg, "if (__perla_want_list != 1 && __pr && !STRADA_IS_TAGGED_INT(__pr) && __pr->type == STRADA_ARRAY) { ");
            emit($cg, "  StradaArray *__pra = __pr->value.av; ");
            emit($cg, "  StradaValue *__first = (__pra && __pra->size > 0) ? __pra->elements[__pra->head] : NULL; ");
            emit($cg, "  if (__first) strada_incref(__first); ");
            emit($cg, "  strada_decref(__pr); ");
            emit($cg, "  __pr = __first ? __first : strada_new_undef(); ");
            emit($cg, "} __pr; })");
        }
        return;
    }

    # printf — sprintf + print. perla previously routed `printf` through
    # perla_code_get("main", "printf") which returns NULL → silent no-op.
    if ($name eq "printf") {
        # printf STDERR / STDOUT "fmt", args — bareword filehandle.
        # Non-stdio barewords (FH, LOG, etc.) look up via package stash.
        if (defined($node->{"fh_bareword"})) {
            my str $fhb = $node->{"fh_bareword"};
            my int $is_stdio = 0;
            my str $stream = "stdout";
            if ($fhb eq "STDOUT") { $is_stdio = 1; }
            elsif ($fhb eq "STDERR") { $stream = "stderr"; $is_stdio = 1; }
            elsif ($fhb eq "STDIN") { $stream = "stdin"; $is_stdio = 1; }
            if ($is_stdio == 1) {
                if ($argc >= 1) {
                    my int $pfn = $argc - 1;
                    emit($cg, "({ StradaValue *__pfr = strada_sprintf_sv(");
                    gen_expr($cg, $args->[0]);
                    emit($cg, ", " . $pfn);
                    my int $pi = 1;
                    while ($pi < $argc) {
                        emit($cg, ", ");
                        gen_expr($cg, $args->[$pi]);
                        $pi++;
                    }
                    emit($cg, "); char *__pfs = strada_to_str(__pfr); fputs(__pfs, " . $stream . "); free(__pfs); strada_decref(__pfr); STRADA_MAKE_TAGGED_INT(1); })");
                } else {
                    emit($cg, "STRADA_MAKE_TAGGED_INT(1)");
                }
                return;
            }
            # Non-stdio: dispatch tied-FH PRINTF first (mirrors the print
            # path at ~16557). If tied, hand the (fmt, args) tuple to
            # perla_tied_handle_printf which prefers PRINTF, else formats
            # and falls back to PRINT. Otherwise: stash lookup +
            # strada_print_fh with the formatted string.
            if ($argc >= 1) {
                emit($cg, "({ StradaValue *__pth_bw = perla_tied_handle_for_name(\"" . $cg->{"pkg"} . "\", \"" . $fhb . "\"); ");
                emit($cg, "__pth_bw ? ({ StradaValue *__pth_args = strada_new_array(); StradaArray *__pth_av = strada_deref_array(__pth_args); ");
                my int $pi3 = 0;
                while ($pi3 < $argc) {
                    emit($cg, "{ StradaValue *__pth_a = ");
                    gen_expr($cg, $args->[$pi3]);
                    emit($cg, "; if (__pth_a) strada_incref(__pth_a); strada_array_push_take(__pth_av, __pth_a); } ");
                    $pi3 = $pi3 + 1;
                }
                emit($cg, "StradaValue *__pth_r = perla_tied_handle_printf(\"" . $cg->{"pkg"} . "\", \"" . $fhb . "\", __pth_args); strada_decref(__pth_args); __pth_r; }) : ");
                my int $pfn2 = $argc - 1;
                emit($cg, "({ StradaValue *__pfr = strada_sprintf_sv(");
                gen_expr($cg, $args->[0]);
                emit($cg, ", " . $pfn2);
                my int $pi2 = 1;
                while ($pi2 < $argc) {
                    emit($cg, ", ");
                    gen_expr($cg, $args->[$pi2]);
                    $pi2++;
                }
                emit($cg, "); StradaValue *__pfh = perla_scalar_get(\"" . $cg->{"pkg"} . "\", \"" . $fhb . "\"); strada_print_fh(__pfr, __pfh); strada_decref(__pfr); STRADA_MAKE_TAGGED_INT(1); }); })");
            } else {
                emit($cg, "STRADA_MAKE_TAGGED_INT(1)");
            }
            return;
        }
        # printf $fh "fmt", args — scalar var filehandle.
        if (defined($node->{"fh"})) {
            if ($argc >= 1) {
                my int $pfn = $argc - 1;
                emit($cg, "({ StradaValue *__pfr = strada_sprintf_sv(");
                gen_expr($cg, $args->[0]);
                emit($cg, ", " . $pfn);
                my int $pi = 1;
                while ($pi < $argc) {
                    emit($cg, ", ");
                    gen_expr($cg, $args->[$pi]);
                    $pi++;
                }
                emit($cg, "); strada_print_fh(__pfr, ");
                gen_expr($cg, $node->{"fh"});
                emit($cg, "); strada_decref(__pfr); STRADA_MAKE_TAGGED_INT(1); })");
            } else {
                emit($cg, "STRADA_MAKE_TAGGED_INT(1)");
            }
            return;
        }
        if ($argc >= 1) {
            my int $pf_nargs = $argc - 1;
            emit($cg, "({ StradaValue *__pfr = strada_sprintf_sv(");
            gen_expr($cg, $args->[0]);
            emit($cg, ", " . $pf_nargs);
            my int $pfi = 1;
            while ($pfi < $argc) {
                emit($cg, ", ");
                gen_expr($cg, $args->[$pfi]);
                $pfi++;
            }
            emit($cg, "); strada_print(__pfr); strada_decref(__pfr); STRADA_MAKE_TAGGED_INT(1); })");
        } else {
            emit($cg, "STRADA_MAKE_TAGGED_INT(1)");
        }
        return;
    }

    # chop — removes last char, returns it
    if ($name eq "chop") {
        # No-args form defaults to chop $_. Without this, `chop` was a
        # no-op when used in a `for ($var) { chop }` loop. Mirror chomp.
        if ($argc == 0) {
            emit($cg, "({ char *__s = strada_to_str(perla_dollar_underscore ? perla_dollar_underscore : strada_new_str(\"\")); ");
            emit($cg, "char *__c = strada_chop(__s); ");
            emit($cg, "StradaValue *__nv = strada_new_str_charflag(__c, __s); ");
            emit($cg, "if (perla_dollar_underscore) strada_decref(perla_dollar_underscore); perla_dollar_underscore = __nv; strada_incref(__nv); ");
            emit($cg, "StradaValue *__r = strada_new_str_charflag(__s + strlen(__c), __s); free(__s); free(__c); __r; })");
            return;
        }
        if ($argc > 0) {
            my scalar $chop_arg = $args->[0];
            my int $chop_argt = $chop_arg->{"type"};
            # `chop @arr` / `chop %hash` — chop each element in place
            # and return the last char chopped. Walk the underlying
            # StradaArray/StradaHash and chop each str entry, replacing
            # with the chopped string.
            if ($chop_argt == Perla::AST::N_ARRAY_VAR()) {
                my str $aname = $chop_arg->{"name"};
                my str $av_c = ($aname eq "_") ? "perla_at_" : c_var_a($aname);
                emit($cg, "({ StradaArray *__cha = strada_deref_array(" . $av_c . "); ");
                emit($cg, "StradaValue *__chr = strada_new_str(\"\"); ");
                emit($cg, "if (__cha) { for (size_t __chi = 0; __chi < __cha->size; __chi++) { ");
                emit($cg, "  StradaValue *__che = __cha->elements[__cha->head + __chi]; ");
                emit($cg, "  char *__chs = strada_to_str(__che); char *__chc = strada_chop(__chs); ");
                emit($cg, "  StradaValue *__chn = strada_new_str_charflag(__chc, __chs); ");
                emit($cg, "  strada_decref(__che); __cha->elements[__cha->head + __chi] = __chn; ");
                emit($cg, "  strada_decref(__chr); __chr = strada_new_str_charflag(__chs + strlen(__chc), __chs); ");
                emit($cg, "  free(__chs); free(__chc); ");
                emit($cg, "} } __chr; })");
                return;
            }
            # When the arg is a non-lvalue target (array elem, hash elem,
            # deref, etc.), the old `<expr> = strada_new_str(...)` pattern
            # produces an invalid C lvalue. Route the writeback through
            # `_emit_subst_writeback` for those cases.
            if ($chop_argt == Perla::AST::N_ARRAY_ELEM()
                || $chop_argt == Perla::AST::N_ARROW_ARRAY()
                || $chop_argt == Perla::AST::N_HASH_ELEM()
                || $chop_argt == Perla::AST::N_ARROW_HASH()
                || $chop_argt == Perla::AST::N_DEREF_SCALAR()) {
                emit($cg, "({ char *__s = strada_to_str(");
                gen_expr($cg, $chop_arg);
                emit($cg, "); char *__c = strada_chop(__s); StradaValue *__nv = strada_new_str_charflag(__c, __s); ");
                Perla::CodeGen::Subst::emit_subst_writeback($cg, $chop_arg, "__nv");
                emit($cg, " StradaValue *__r = strada_new_str_charflag(__s + strlen(__c), __s); free(__s); free(__c); __r; })");
            } else {
                emit($cg, "({ char *__s = strada_to_str(");
                gen_expr($cg, $chop_arg);
                emit($cg, "); char *__c = strada_chop(__s); ");
                gen_expr($cg, $chop_arg);
                emit($cg, " = strada_new_str_charflag(__c, __s); StradaValue *__r = strada_new_str_charflag(__s + strlen(__c), __s); free(__s); free(__c); __r; })");
            }
        }
        return;
    }

    # chr/ord
    if ($name eq "chr") {
        # Route through `strada_chr_sv` which UTF-8-encodes codepoints
        # >= 256 (Perl semantics). The previous inline path truncated
        # `(char)0x100` to 0x00 → `chr(0x100)` produced "\x00" instead
        # of the 2-byte UTF-8 sequence "\xc4\x80". `strada_chr_sv` also
        # handles `chr(0)` (returns a 1-byte NUL string, not "").
        # No-args form defaults to $_ — common idiom in
        # `map { chr } @ords`. Without this, perla called with 0
        # and got a space/null for every entry.
        emit($cg, "strada_chr_sv((int)strada_to_num(");
        if ($argc > 0) { gen_expr($cg, $args->[0]); }
        else { emit($cg, "perla_dollar_underscore"); }
        emit($cg, "))");
        return;
    }
    if ($name eq "ord") {
        # `ord` with no args defaults to $_ — common idiom in
        # `map { ord } split //, $str`. Without this, perla called
        # ord with NULL and got 0 for every char.
        #
        # Use `strada_ord` (UTF-8 aware) rather than reading a raw byte.
        # `ord(chr(0x100))` should round-trip to 256, but reading
        # `__s[0]` only sees the multi-byte leader byte (0xc4) for the
        # 2-byte UTF-8 sequence.
        # Scalar context on arg.
        emit($cg, "({ int __sav_wl_ord = __perla_want_list; __perla_want_list = 0; char *__s = strada_to_str(");
        if ($argc > 0) {
            gen_expr($cg, $args->[0]);
        } else {
            emit($cg, "(perla_dollar_underscore ? perla_dollar_underscore : strada_new_str(\"\"))");
        }
        emit($cg, "); __perla_want_list = __sav_wl_ord; StradaValue *__r = STRADA_MAKE_TAGGED_INT((int64_t)strada_ord(__s)); free(__s); __r; })");
        return;
    }

    # sprintf
    if ($name eq "sprintf") {
        # Simple: just do string concat for now
        emit($cg, "strada_new_str(\"TODO_sprintf\")");
        return;
    }

    # scalar
    if ($name eq "scalar") {
        if ($argc > 0) {
            # `scalar EXPR` enforces scalar context. Result depends on the
            # expression's type:
            #   - array (@arr)       → length
            #   - hash (%hash)       → "K/N" stat string (Perl); we return N
            #   - anything else      → the value itself (scalar pass-through)
            # Old behavior always returned strada_array_length, so
            # `scalar test()` where test returns a SCALAR or ARRAY-REF
            # got the count of an empty/wrong array. DBIC's
            # `scalar $self->_resolve_condition(...)` was returning
            # `count` instead of the function's `\@res` arrayref, so
            # the JOIN clause emitted `ON 0` instead of the real
            # condition.
            #
            # Set `__perla_want_list = 0` around the inner expression so
            # the callee picks its scalar-return branch.
            #
            # `scalar (a, b, c)` — when the parser splits the
            # parenthesized list into N args, treat it as Perl's
            # comma-operator-in-scalar-context: evaluate all and
            # return the last. Discard earlier args (run them for
            # side effects, drop their values).
            if ($argc > 1) {
                emit($cg, "({ ");
                my int $sxi = 0;
                while ($sxi < $argc - 1) {
                    emit($cg, "({ StradaValue *__sx = ");
                    gen_expr($cg, $args->[$sxi]);
                    emit($cg, "; if (__sx) strada_decref(__sx); }); ");
                    $sxi++;
                }
                gen_expr($cg, $args->[$argc - 1]);
                emit($cg, "; })");
                return;
            }
            my scalar $arg = $args->[0];
            my int $at = $arg->{"type"};
            if ($at == Perla::AST::N_ARRAY_VAR() || $at == Perla::AST::N_DEREF_ARRAY()) {
                # Static: definitely an array — length. Force list context
                # on the inner deref so N_DEREF_ARRAY's scalar short-circuit
                # (added in bdbf367d) doesn't reduce the deref to an int
                # before we can ask for the length.
                # Tied-aware: dispatch FETCHSIZE if the SV is tied.
                emit($cg, "({ int __sav_wl_sc = __perla_want_list; __perla_want_list = 1; ");
                emit($cg, "StradaValue *__sca = ");
                gen_expr($cg, $arg);
                emit($cg, "; __perla_want_list = __sav_wl_sc; ");
                emit($cg, "int64_t __scl = strada_av_fetchsize_sv(__sca); ");
                emit($cg, "STRADA_MAKE_TAGGED_INT(__scl); })");
            } elsif ($at == Perla::AST::N_HASH_VAR() || $at == Perla::AST::N_DEREF_HASH()) {
                # `scalar(%h)` — tied: dispatch SCALAR method if defined,
                # else default. Untied: number of keys (modern Perl 5.26+).
                # Force list context for the same reason as N_DEREF_ARRAY.
                emit($cg, "({ int __sav_wl_sh = __perla_want_list; __perla_want_list = 1; ");
                emit($cg, "StradaValue *__sh = ");
                gen_expr($cg, $arg);
                emit($cg, "; __perla_want_list = __sav_wl_sh; ");
                emit($cg, "StradaValue *__sh_t = (__sh && !STRADA_IS_TAGGED_INT(__sh) && __sh->meta && __sh->meta->is_tied) ? strada_tied_hash_scalar(__sh) : NULL; ");
                emit($cg, "StradaValue *__sh_r; if (__sh_t) { __sh_r = __sh_t; } else { StradaHash *__shv = strada_deref_hash(__sh); __sh_r = STRADA_MAKE_TAGGED_INT((int64_t)(__shv ? __shv->num_entries : 0)); } __sh_r; })");
            } else {
                # Dynamic: evaluate in scalar context, branch on type.
                emit($cg, "({ int __sav_wl = __perla_want_list; __perla_want_list = 0; StradaValue *__sv = ");
                gen_expr($cg, $arg);
                emit($cg, "; __perla_want_list = __sav_wl; ");
                emit($cg, "StradaValue *__sr; ");
                emit($cg, "if (__sv && !STRADA_IS_TAGGED_INT(__sv) && __sv->type == STRADA_ARRAY) { ");
                emit($cg, "  __sr = STRADA_MAKE_TAGGED_INT((int64_t)strada_array_length(strada_deref_array(__sv))); ");
                emit($cg, "  strada_decref(__sv); ");
                emit($cg, "} else if (__sv && !STRADA_IS_TAGGED_INT(__sv) && __sv->type == STRADA_HASH) { ");
                emit($cg, "  StradaHash *__shv = strada_deref_hash(__sv); ");
                emit($cg, "  __sr = STRADA_MAKE_TAGGED_INT((int64_t)(__shv ? __shv->num_entries : 0)); ");
                emit($cg, "  strada_decref(__sv); ");
                emit($cg, "} else { __sr = __sv ? __sv : strada_new_undef(); } __sr; })");
            }
        }
        return;
    }

    # sort
    if ($name eq "sort") {
        if ($argc == 1) {
            emit($cg, "strada_sort(");
            gen_expr($cg, $args->[0]);
            emit($cg, ")");
        } elsif ($argc > 1) {
            # sort(elem1, elem2, ...) — build array then sort
            emit($cg, "({ StradaValue *__sa = strada_new_array(); StradaArray *__sav = strada_deref_array(__sa); ");
            my int $si = 0;
            while ($si < $argc) {
                emit($cg, "strada_array_push(__sav, ");
                gen_expr($cg, $args->[$si]);
                emit($cg, "); ");
                $si++;
            }
            emit($cg, "strada_sort(__sa); })");
        }
        return;
    }

    # reverse — no-args form defaults to $_ (Perl semantics for the
    # scalar variant: `scalar reverse` reverses $_).
    if ($name eq "reverse") {
        # `reverse LIST` is context-sensitive: in list context returns the
        # reversed list; in scalar context joins-and-reverses-the-string.
        # perla_reverse_ctx checks __perla_want_list and dispatches.
        # Perl's `reverse` with no args defaults to $_ in scalar context
        # ONLY — in list context bare `reverse` is the empty list.
        # Arg eval imposes LIST context: reverse always wants a list as
        # input; the outer scalar/list context only affects what the
        # function RETURNS. Without this, `scalar(reverse sub_returning_list())`
        # ran the sub in scalar context (returning just the last value)
        # so reverse only saw (3) instead of (1,2,3).
        if ($argc == 0) {
            # Scalar context with no args: reverse $_ as string (char-reverse).
            # List context with no args: return empty list.
            emit($cg, "(__perla_want_list ? perla_reverse_ctx(strada_new_array()) : strada_reverse_sv(perla_dollar_underscore ? perla_dollar_underscore : strada_new_undef()))");
        } elsif ($argc == 1) {
            emit($cg, "({ int __sav_wl_rv = __perla_want_list; __perla_want_list = 1; StradaValue *__rva = ");
            gen_expr($cg, $args->[0]);
            emit($cg, "; __perla_want_list = __sav_wl_rv; perla_reverse_ctx(__rva); })");
        } elsif ($argc > 1) {
            emit($cg, "({ int __sav_wl_rv = __perla_want_list; __perla_want_list = 1; StradaValue *__ra = strada_new_array(); StradaArray *__rav = strada_deref_array(__ra); ");
            my int $ri = 0;
            while ($ri < $argc) {
                emit($cg, "strada_array_push(__rav, ");
                gen_expr($cg, $args->[$ri]);
                emit($cg, "); ");
                $ri++;
            }
            emit($cg, "__perla_want_list = __sav_wl_rv; perla_reverse_ctx(__ra); })");
        }
        return;
    }

    # bless
    if ($name eq "bless") {
        # Optimize: if class name is a string literal, use strdup directly
        my int $class_is_lit = 0;
        my str $class_lit = "";
        if ($argc > 1) {
            my scalar $carg = $args->[1];
            if (defined($carg) && $carg->{"type"} == Perla::AST::N_STR_LIT()) {
                $class_is_lit = 1;
                $class_lit = Perla::CodeGen::Escape::escape_c_str($carg->{"value"});
            }
        } else {
            $class_is_lit = 1;
            $class_lit = $cg->{"pkg"};
        }
        if ($class_is_lit == 1) {
            emit($cg, "({ char *__bp = strdup(\"" . $class_lit . "\"); StradaValue *__br = perla_bless(");
            gen_expr($cg, $args->[0]);
            emit($cg, ", __bp); free(__bp); __br; })");
        } else {
            # Dynamic class name — use perla_class_name which mirrors Perl's
            # bless semantics: if $class is a blessed ref, use its package
            # (not the "REF(0x…)" stringification). Without this, patterns
            # like `$rs->new({})` where ResultSet::new does `bless($self,
            # $class)` lose the package when $class is the invocant $rs.
            #
            # Argument evaluation order: Perl evaluates the BLOCK (1st
            # arg) before the class expression (2nd arg). This matters
            # for the idiomatic constructor `bless { @_[1..\$#_] }, shift`
            # where shift mutates @_ — the slice must see the pre-shift
            # @_, which only happens if we eval arg[0] first.
            emit($cg, "({ StradaValue *__bref = ");
            gen_expr($cg, $args->[0]);
            emit($cg, "; StradaValue *__bsv = ");
            gen_expr($cg, $args->[1]);
            emit($cg, "; strada_incref(__bsv); char *__bp = perla_class_name(__bsv); StradaValue *__br = perla_bless(__bref, __bp); strada_decref(__bsv); free(__bp); __br; })");
        }
        return;
    }

    # open — multiple forms
    if ($name eq "open") {
        if ($argc >= 3) {
            # 3-arg: open($fh, $mode, $file) — assigns to first arg
            my scalar $fh_arg = $args->[0];
            my str $fh_var = "";
            my str $fh_decl = "";
            my str $fh_bareword = "";
            if (defined($fh_arg) && $fh_arg->{"type"} == Perla::AST::N_SCALAR_VAR()) {
                $fh_var = c_var($fh_arg->{"name"});
            } elsif (defined($fh_arg) && $fh_arg->{"type"} == Perla::AST::N_MY()) {
                # open(my $fh, ...) — $fh is a fresh `my` declaration. We
                # can't emit a `StradaValue *v_fh = NULL;` inside the
                # statement-expression (that would create a fresh local
                # that shadows the outer auto-declared static and the
                # assignment would never be visible to the rest of the
                # enclosing block). Just assign into the auto-declared
                # file-scope static — subsequent `read($fh, …)`,
                # `close($fh)`, `<$fh>` all reference the same global.
                if (defined($fh_arg->{"var"})) {
                    $fh_var = c_var($fh_arg->{"var"}->{"value"});
                    _my_prefix($cg, $fh_arg->{"var"}->{"value"});
                }
            } elsif (defined($fh_arg) && $fh_arg->{"type"} == Perla::AST::N_CALL()) {
                # Bareword filehandle: open(FH, "<", $path). The parser sees
                # FH as a no-arg function call; falling through to
                # `gen_expr($fh_arg) = __fh` produces invalid C
                # (`perla_call_code(...) = ...`). Store the fh in the package
                # stash as a scalar instead — consistent with how Perl tracks
                # bareword filehandles on the symbol table.
                my scalar $fhargs = $fh_arg->{"args"};
                my int $acount = 0;
                if (defined($fhargs)) { $acount = scalar(@{$fhargs}); }
                if ($acount == 0 && defined($fh_arg->{"name"})) {
                    $fh_bareword = $fh_arg->{"name"};
                }
            }
            # In-memory I/O: open($fh, MODE, \$buf) — third arg is a scalar
            # ref. Detect at compile time and dispatch to strada_open_sv,
            # which fmemopens / open_memstreams the buffer and (for write
            # modes) writes back to the referent on close.
            my int $is_ref_target = 0;
            if (defined($args->[2]) && $args->[2]->{"type"} == Perla::AST::N_REF()) {
                $is_ref_target = 1;
            }
            if ($is_ref_target == 1) {
                emit($cg, "({ " . $fh_decl . "char *__pm = strada_to_str(");
                gen_expr($cg, $args->[1]);
                emit($cg, "); StradaValue *__refarg = ");
                gen_expr($cg, $args->[2]);
                emit($cg, "; StradaValue *__cm_sv; if (strcmp(__pm, \"<\") == 0) __cm_sv = strada_new_str(\"r\"); ");
                emit($cg, "else if (strcmp(__pm, \">\") == 0) __cm_sv = strada_new_str(\"w\"); ");
                emit($cg, "else if (strcmp(__pm, \">>\") == 0) __cm_sv = strada_new_str(\"a\"); ");
                emit($cg, "else __cm_sv = strada_new_str(__pm); ");
                emit($cg, "StradaValue *__fh = strada_open_sv(__refarg, __cm_sv); strada_decref(__cm_sv); ");
                if (length($fh_var) > 0) {
                    emit($cg, $fh_var . " = __fh; ");
                } elsif (length($fh_bareword) > 0) {
                    emit($cg, "perla_scalar_set(\"" . $cg->{"pkg"} . "\", \"" . $fh_bareword . "\", __fh); ");
                } else {
                    _emit_open_slot_store($cg, $fh_arg);
                }
                emit($cg, "int __op_ok = (__fh && !STRADA_IS_TAGGED_INT(__fh) && __fh->type == STRADA_FILEHANDLE && __fh->value.fh != NULL); ");
                emit($cg, "free(__pm); STRADA_MAKE_TAGGED_INT(__op_ok); })");
                return;
            }
            # `open my $new, ">&", $fh` (and "<&" / ">>&" / "+<&" / "+>&")
            # — filehandle DUP, not a fopen of a path. The third arg is
            # an existing filehandle SV, not a filename. Capture it as
            # an SV up-front; if the mode is a dup form, hand it to
            # perla_open_dup (dup+fdopen the underlying fd). Otherwise
            # fall through to the normal fopen path, where stringifying
            # the FH SV is harmless. IPC::Open3 and stderr→stdout redirect
            # patterns need this to work.
            emit($cg, "({ " . $fh_decl . "char *__pm = strada_to_str(");
            gen_expr($cg, $args->[1]);
            emit($cg, "); StradaValue *__src_fh_sv = ");
            gen_expr($cg, $args->[2]);
            emit($cg, "; char *__fn = (__pm && strchr(__pm, '&')) ? NULL : strada_to_str(__src_fh_sv); char *__cm = __pm; ");
            emit($cg, "if (strcmp(__pm, \"<\") == 0) __cm = \"r\"; ");
            emit($cg, "else if (strcmp(__pm, \">\") == 0) __cm = \"w\"; ");
            emit($cg, "else if (strcmp(__pm, \">>\") == 0) __cm = \"a\"; ");
            # `-|` (read from child) / `|-` (write to child) — third arg is
            # the command, not a filename. Dispatch to popen via
            # strada_popen so `open(my \$fh, "-|", "echo hi")` works.
            # Multi-arg form `open(my \$fh, "-|", "echo", "hi", "world")` —
            # Perl's exec-list semantics, no shell. We approximate by
            # concatenating arg2..argN with spaces and going through popen
            # anyway. Good enough for the common case (echo, basic argv)
            # but a true exec-list (fork+execvp) would be more correct for
            # args containing shell metacharacters.
            emit($cg, "StradaValue *__fh; ");
            emit($cg, "if (strcmp(__pm, \"-|\") == 0 || strcmp(__pm, \"|-\") == 0) { ");
            if ($argc > 3) {
                emit($cg, "  StradaValue *__cmd_sv = strada_new_str(__fn); ");
                my int $eai = 3;
                while ($eai < $argc) {
                    emit($cg, "  { StradaValue *__ea_p = strada_new_str(\" \"); ");
                    emit($cg, "    StradaValue *__ea_v = ");
                    gen_expr($cg, $args->[$eai]);
                    emit($cg, "; StradaValue *__ea_t1 = strada_concat_sv(__cmd_sv, __ea_p); strada_decref(__cmd_sv); strada_decref(__ea_p); ");
                    emit($cg, "    __cmd_sv = strada_concat_sv(__ea_t1, __ea_v); strada_decref(__ea_t1); strada_decref(__ea_v); } ");
                    $eai = $eai + 1;
                }
                emit($cg, "  StradaValue *__mode_sv = strada_new_str(strcmp(__pm, \"-|\") == 0 ? \"r\" : \"w\"); ");
                emit($cg, "  __fh = strada_popen(__cmd_sv, __mode_sv); ");
                emit($cg, "  strada_decref(__cmd_sv); strada_decref(__mode_sv); ");
            } else {
                emit($cg, "  StradaValue *__cmd_sv = strada_new_str(__fn); ");
                emit($cg, "  StradaValue *__mode_sv = strada_new_str(strcmp(__pm, \"-|\") == 0 ? \"r\" : \"w\"); ");
                emit($cg, "  __fh = strada_popen(__cmd_sv, __mode_sv); ");
                emit($cg, "  strada_decref(__cmd_sv); strada_decref(__mode_sv); ");
            }
            emit($cg, "} else if (__pm && strchr(__pm, '&')) { extern StradaValue *perla_open_dup(StradaValue *, const char *); __fh = perla_open_dup(__src_fh_sv, __pm); } ");
            emit($cg, "else { __fh = strada_open(__fn, __cm); } ");
            if (length($fh_var) > 0) {
                emit($cg, $fh_var . " = __fh; ");
            } elsif (length($fh_bareword) > 0) {
                emit($cg, "perla_scalar_set(\"" . $cg->{"pkg"} . "\", \"" . $fh_bareword . "\", __fh); ");
            } else {
                _emit_open_slot_store($cg, $fh_arg);
            }
            # strada_open returns strada_new_undef() (non-NULL but type
            # STRADA_UNDEF) on failure — checking \`__fh != NULL\` would
            # treat that as success. The correct check is "is it a
            # filehandle with a non-NULL FILE*". On failure, errno is
            # already set by fopen; preserve it for \$! to read.
            emit($cg, "int __op_ok = (__fh && !STRADA_IS_TAGGED_INT(__fh) && __fh->type == STRADA_FILEHANDLE && __fh->value.fh != NULL); ");
            emit($cg, "if (__fn) free(__fn); free(__pm); STRADA_MAKE_TAGGED_INT(__op_ok); })");
        } elsif ($argc >= 2) {
            # Perl's 2-arg `open(FH, EXPR)` form: FH is the filehandle,
            # EXPR is a string with optional mode prefix (`<name`, `>name`,
            # `>>name`, `+<name`, or bare `name` = read). Assigns the
            # opened handle to FH the same way as the 3-arg form.
            # Legacy code still uses `open(CF, $file);` for config slurps.
            my scalar $fh_arg = $args->[0];
            my str $fh_var = "";
            my str $fh_decl = "";
            my str $fh_bareword = "";
            if (defined($fh_arg) && $fh_arg->{"type"} == Perla::AST::N_SCALAR_VAR()) {
                $fh_var = c_var($fh_arg->{"name"});
            } elsif (defined($fh_arg) && $fh_arg->{"type"} == Perla::AST::N_MY()) {
                # `open(my $fh, EXPR)` — same trap as the 3-arg form: an
                # inner `StradaValue *v_fh = NULL;` inside the statement-
                # expression shadows the outer auto-declared static, so
                # `print $fh ...; close $fh;` after the open hit the
                # NULL outer. Just call _my_prefix to register the var
                # for the file-scope auto-decl pass and assign into the
                # outer static, leaving $fh_decl empty.
                if (defined($fh_arg->{"var"})) {
                    $fh_var = c_var($fh_arg->{"var"}->{"value"});
                    _my_prefix($cg, $fh_arg->{"var"}->{"value"});
                }
            } elsif (defined($fh_arg) && $fh_arg->{"type"} == Perla::AST::N_CALL()) {
                my scalar $fhargs = $fh_arg->{"args"};
                my int $acount = 0;
                if (defined($fhargs)) { $acount = scalar(@{$fhargs}); }
                if ($acount == 0 && defined($fh_arg->{"name"})) {
                    $fh_bareword = $fh_arg->{"name"};
                }
            }
            emit($cg, "({ " . $fh_decl . "char *__fn_raw = strada_to_str(");
            gen_expr($cg, $args->[1]);
            emit($cg, "); char *__fn = __fn_raw; const char *__cm = \"r\"; int __is_pipe = 0; const char *__pipe_mode = \"r\"; ");
            emit($cg, "while (*__fn == ' ' || *__fn == '\\t') __fn++; ");
            # Detect Perl 2-arg pipe forms: trailing `|` means "read from
            # this command's stdout"; leading `|` means "write to this
            # command's stdin". The pipe char + whitespace is stripped
            # so strada_popen receives a clean command string.
            emit($cg, "{ size_t __fl = strlen(__fn); ");
            emit($cg, "  if (__fl > 0 && __fn[__fl-1] == '|') { __is_pipe = 1; __pipe_mode = \"r\"; __fn[__fl-1] = '\\0'; __fl--; ");
            emit($cg, "    while (__fl > 0 && (__fn[__fl-1] == ' ' || __fn[__fl-1] == '\\t')) { __fn[__fl-1] = '\\0'; __fl--; } } ");
            emit($cg, "  else if (__fn[0] == '|') { __is_pipe = 1; __pipe_mode = \"w\"; __fn++; while (*__fn == ' ' || *__fn == '\\t') __fn++; } ");
            emit($cg, "} ");
            emit($cg, "if (!__is_pipe) { ");
            emit($cg, "  if (__fn[0] == '>' && __fn[1] == '>') { __cm = \"a\"; __fn += 2; } ");
            emit($cg, "  else if (__fn[0] == '>') { __cm = \"w\"; __fn += 1; } ");
            emit($cg, "  else if (__fn[0] == '<') { __cm = \"r\"; __fn += 1; } ");
            emit($cg, "  else if (__fn[0] == '+' && __fn[1] == '<') { __cm = \"r+\"; __fn += 2; } ");
            emit($cg, "  else if (__fn[0] == '+' && __fn[1] == '>') { __cm = \"w+\"; __fn += 2; } ");
            emit($cg, "  while (*__fn == ' ' || *__fn == '\\t') __fn++; ");
            emit($cg, "} ");
            emit($cg, "StradaValue *__fh; ");
            emit($cg, "if (__is_pipe) { StradaValue *__pc = strada_new_str(__fn); StradaValue *__pm = strada_new_str(__pipe_mode); __fh = strada_popen(__pc, __pm); strada_decref(__pc); strada_decref(__pm); } ");
            emit($cg, "else { __fh = strada_open(__fn, __cm); } ");
            if (length($fh_var) > 0) {
                emit($cg, $fh_var . " = __fh; ");
            } elsif (length($fh_bareword) > 0) {
                emit($cg, "perla_scalar_set(\"" . $cg->{"pkg"} . "\", \"" . $fh_bareword . "\", __fh); ");
            } else {
                _emit_open_slot_store($cg, $fh_arg);
            }
            # Same as 3-arg form: undef-on-failure means \`__fh != NULL\`
            # is wrong; check filehandle type + non-NULL FILE*.
            emit($cg, "int __op_ok = (__fh && !STRADA_IS_TAGGED_INT(__fh) && __fh->type == STRADA_FILEHANDLE && __fh->value.fh != NULL); ");
            emit($cg, "free(__fn_raw); STRADA_MAKE_TAGGED_INT(__op_ok); })");
        }
        return;
    }

    # sysopen($fh, $path, $flags [, $perms]) — POSIX open(2) flags, not
    # the mode-string form of `open()`. File::Temp + many CPAN modules
    # depend on this for O_CREAT|O_EXCL retry-on-race idioms. Routes
    # through perla_sysopen() which does open(2)+fdopen and returns a
    # FILEHANDLE on success, undef on failure.
    if ($name eq "sysopen" && $argc >= 3) {
        my scalar $fh_arg = $args->[0];
        my str $fh_var = "";
        my str $fh_bareword = "";
        if (defined($fh_arg) && $fh_arg->{"type"} == Perla::AST::N_SCALAR_VAR()) {
            $fh_var = c_var($fh_arg->{"name"});
        } elsif (defined($fh_arg) && $fh_arg->{"type"} == Perla::AST::N_MY()) {
            if (defined($fh_arg->{"var"})) {
                $fh_var = c_var($fh_arg->{"var"}->{"value"});
                _my_prefix($cg, $fh_arg->{"var"}->{"value"});
            }
        } elsif (defined($fh_arg) && $fh_arg->{"type"} == Perla::AST::N_CALL()) {
            my scalar $fhargs = $fh_arg->{"args"};
            my int $acount = 0;
            if (defined($fhargs)) { $acount = scalar(@{$fhargs}); }
            if ($acount == 0 && defined($fh_arg->{"name"})) {
                $fh_bareword = $fh_arg->{"name"};
            }
        }
        emit($cg, "({ StradaValue *__sop_path = ");
        gen_expr($cg, $args->[1]);
        emit($cg, "; int64_t __sop_flags = (int64_t)strada_to_int(");
        gen_expr($cg, $args->[2]);
        emit($cg, "); int64_t __sop_perms = ");
        if ($argc >= 4) {
            emit($cg, "(int64_t)strada_to_int(");
            gen_expr($cg, $args->[3]);
            emit($cg, ")");
        } else {
            emit($cg, "0666");
        }
        emit($cg, "; StradaValue *__sop_fh = perla_sysopen(__sop_path, __sop_flags, __sop_perms); ");
        if (length($fh_var) > 0) {
            emit($cg, "if (" . $fh_var . ") strada_decref(" . $fh_var . "); " . $fh_var . " = __sop_fh; ");
        } elsif (length($fh_bareword) > 0) {
            emit($cg, "perla_scalar_set(\"" . $cg->{"pkg"} . "\", \"" . $fh_bareword . "\", __sop_fh); ");
        } else {
            gen_expr($cg, $fh_arg);
            emit($cg, " = __sop_fh; ");
        }
        emit($cg, "int __sop_ok = (__sop_fh && !STRADA_IS_TAGGED_INT(__sop_fh) && __sop_fh->type == STRADA_FILEHANDLE && __sop_fh->value.fh != NULL); ");
        emit($cg, "STRADA_MAKE_TAGGED_INT(__sop_ok); })");
        return;
    }

    # eof($fh)
    if ($name eq "eof") {
        if ($argc > 0) {
            emit($cg, "strada_eof(");
            gen_expr($cg, $args->[0]);
            emit($cg, ")");
        } else {
            emit($cg, "STRADA_MAKE_TAGGED_INT(1)");
        }
        return;
    }

    # tell($fh)
    if ($name eq "tell") {
        if ($argc > 0) {
            emit($cg, "strada_tell(");
            gen_expr($cg, $args->[0]);
            emit($cg, ")");
        } else {
            emit($cg, "STRADA_MAKE_TAGGED_INT(-1)");
        }
        return;
    }

    # seek($fh, OFFSET, WHENCE)
    if ($name eq "seek") {
        if ($argc >= 3) {
            emit($cg, "strada_seek(");
            gen_expr($cg, $args->[0]);
            emit($cg, ", ");
            gen_expr($cg, $args->[1]);
            emit($cg, ", ");
            gen_expr($cg, $args->[2]);
            emit($cg, ")");
        } elsif ($argc == 2) {
            emit($cg, "strada_seek(");
            gen_expr($cg, $args->[0]);
            emit($cg, ", ");
            gen_expr($cg, $args->[1]);
            emit($cg, ", STRADA_MAKE_TAGGED_INT(0))");
        } else {
            emit($cg, "STRADA_MAKE_TAGGED_INT(0)");
        }
        return;
    }

    # syswrite($fh, $buf, $len?, $offset?) — write raw bytes. Mirrors
    # sysread shape; uses fwrite under the hood since perla filehandles
    # wrap stdio FILE*. Returns bytes written, or undef on error.
    if ($name eq "syswrite" && $argc >= 2) {
        emit($cg, "({ StradaValue *__swfh = ");
        my scalar $sw_fh = $args->[0];
        if (defined($sw_fh) && $sw_fh->{"type"} == Perla::AST::N_CALL()) {
            my scalar $swfhargs = $sw_fh->{"args"};
            my int $swacount = 0;
            if (defined($swfhargs)) { $swacount = scalar(@{$swfhargs}); }
            if ($swacount == 0 && defined($sw_fh->{"name"})) {
                emit($cg, "perla_scalar_get(\"" . $cg->{"pkg"} . "\", \"" . $sw_fh->{"name"} . "\")");
            } else {
                gen_expr($cg, $sw_fh);
            }
        } else {
            gen_expr($cg, $sw_fh);
        }
        emit($cg, "; StradaValue *__swbv = ");
        gen_expr($cg, $args->[1]);
        emit($cg, "; FILE *__swfp = NULL; ");
        emit($cg, "if (__swfh && !STRADA_IS_TAGGED_INT(__swfh) && __swfh->type == STRADA_FILEHANDLE) __swfp = __swfh->value.fh; ");
        emit($cg, "char *__swbs = strada_to_str(__swbv); size_t __swbl = strlen(__swbs); ");
        if ($argc >= 3) {
            emit($cg, "int __swlen = (int)strada_to_int(");
            gen_expr($cg, $args->[2]);
            emit($cg, "); if (__swlen >= 0 && (size_t)__swlen < __swbl) __swbl = (size_t)__swlen; ");
        }
        my int $sw_off = 0;
        if ($argc >= 4) { $sw_off = 1; }
        if ($sw_off == 1) {
            emit($cg, "int __swoff = (int)strada_to_int(");
            gen_expr($cg, $args->[3]);
            emit($cg, "); if (__swoff < 0) __swoff = (int)__swbl + __swoff; if (__swoff < 0) __swoff = 0; ");
            emit($cg, "if ((size_t)__swoff > __swbl) __swoff = (int)__swbl; ");
            emit($cg, "__swbl -= (size_t)__swoff; ");
        }
        emit($cg, "StradaValue *__swres; ");
        emit($cg, "if (__swfp) { ");
        if ($sw_off == 1) {
            emit($cg, "size_t __swwn = fwrite(__swbs + __swoff, 1, __swbl, __swfp); fflush(__swfp); ");
        } else {
            emit($cg, "size_t __swwn = fwrite(__swbs, 1, __swbl, __swfp); fflush(__swfp); ");
        }
        emit($cg, "__swres = STRADA_MAKE_TAGGED_INT((int64_t)__swwn); ");
        emit($cg, "} else { __swres = strada_new_undef(); } ");
        emit($cg, "free(__swbs); __swres; })");
        return;
    }

    # sysread($fh, $buf, $len, $offset=0) — read raw bytes. Perla
    # filehandles wrap stdio FILE* (no separate raw fd), so we use
    # fread; semantics match perl's "blocking read of up to LEN bytes".
    # Returns bytes read (0 at EOF, undef on error).
    if ($name eq "sysread" && $argc >= 3) {
        my scalar $sr_fh = $args->[0];
        my scalar $sr_buf = $args->[1];
        my scalar $sr_len = $args->[2];
        emit($cg, "({ StradaValue *__srfh = ");
        if (defined($sr_fh) && $sr_fh->{"type"} == Perla::AST::N_CALL()) {
            my scalar $srfhargs = $sr_fh->{"args"};
            my int $sracount = 0;
            if (defined($srfhargs)) { $sracount = scalar(@{$srfhargs}); }
            if ($sracount == 0 && defined($sr_fh->{"name"})) {
                emit($cg, "perla_scalar_get(\"" . $cg->{"pkg"} . "\", \"" . $sr_fh->{"name"} . "\")");
            } else {
                gen_expr($cg, $sr_fh);
            }
        } else {
            gen_expr($cg, $sr_fh);
        }
        emit($cg, "; int __srlen = (int)strada_to_int(");
        gen_expr($cg, $sr_len);
        emit($cg, "); FILE *__srfp = NULL; ");
        emit($cg, "if (__srfh && !STRADA_IS_TAGGED_INT(__srfh) && __srfh->type == STRADA_FILEHANDLE) __srfp = __srfh->value.fh; ");
        emit($cg, "StradaValue *__srres; int __srnbytes = 0; ");
        emit($cg, "if (__srfp && __srlen > 0) { char *__srb = (char*)malloc((size_t)__srlen + 1); __srnbytes = (int)fread(__srb, 1, (size_t)__srlen, __srfp); __srb[__srnbytes] = 0; ");
        emit($cg, "{ StradaValue *__srbv = strada_new_str_len(__srb, __srnbytes); ");
        my int $srbt = $sr_buf->{"type"};
        if ($srbt == Perla::AST::N_SCALAR_VAR()) {
            emit($cg, "strada_decref(" . c_var($sr_buf->{"name"}) . "); " . c_var($sr_buf->{"name"}) . " = __srbv; ");
        } elsif ($srbt == Perla::AST::N_MY() && defined($sr_buf->{"var"})) {
            my str $sr_my_name = $sr_buf->{"var"}->{"value"};
            my str $sr_my_cvar = c_var($sr_my_name);
            _my_prefix($cg, $sr_my_name);
            emit($cg, $sr_my_cvar . " = __srbv; ");
        } elsif (($srbt == Perla::AST::N_ARROW_ARRAY() || $srbt == Perla::AST::N_ARRAY_ELEM())
                 && (!defined($sr_buf->{"is_explicit_arrow"}) || $sr_buf->{"is_explicit_arrow"} != 1)) {
            # `sysread($fh, $_[N], ...)` or `sysread($fh, $arr[N], ...)` —
            # assign via strada_array_set into the underlying array element.
            # The default gen_expr path emits a statement-expression which
            # isn't a C lvalue and fails to compile.
            my scalar $sr_obj = ($srbt == Perla::AST::N_ARROW_ARRAY()) ? $sr_buf->{"object"} : $sr_buf->{"array"};
            emit($cg, "{ StradaArray *__srb_av = strada_deref_array(");
            if (defined($sr_obj) && $sr_obj->{"type"} == Perla::AST::N_SCALAR_VAR() && $sr_obj->{"name"} eq "_") {
                emit($cg, "perla_at_");
            } elsif (defined($sr_obj) && $sr_obj->{"type"} == Perla::AST::N_SCALAR_VAR()
                     && index("" . ($sr_obj->{"name"} // ""), "::") < 0) {
                emit($cg, c_var_a($sr_obj->{"name"}));
            } else {
                gen_expr($cg, $sr_obj);
            }
            emit($cg, "); int __srb_i = (int)strada_to_int(");
            gen_expr($cg, $sr_buf->{"index"});
            emit($cg, "); strada_array_set(__srb_av, __srb_i, __srbv); } ");
        } else {
            emit($cg, "({ StradaValue *__srb_tgt = __srbv; ");
            gen_expr($cg, $sr_buf);
            emit($cg, " = __srb_tgt; }); ");
        }
        emit($cg, "} free(__srb); __srres = STRADA_MAKE_TAGGED_INT(__srnbytes); } else if (!__srfp) { __srres = strada_new_undef(); } else { __srres = STRADA_MAKE_TAGGED_INT(0); } __srres; })");
        return;
    }

    # fileno($fh) — return the integer file descriptor for the handle.
    # Real Perl uses fileno(2) on the underlying stdio FILE*. Useful for
    # select-based I/O and IPC code that needs the raw fd.
    if ($name eq "fileno") {
        if ($argc > 0) {
            emit($cg, "({ StradaValue *__fnfh = ");
            gen_expr($cg, $args->[0]);
            emit($cg, "; int __fno = -1; ");
            emit($cg, "if (__fnfh && !STRADA_IS_TAGGED_INT(__fnfh) && __fnfh->type == STRADA_FILEHANDLE && __fnfh->value.fh) __fno = fileno(__fnfh->value.fh); ");
            # STDIN / STDOUT / STDERR / 0 / 1 / 2 — recognized by name string
            # since perla emits these barewords as plain str literals.
            emit($cg, "else if (__fnfh && !STRADA_IS_TAGGED_INT(__fnfh) && __fnfh->type == STRADA_STR && __fnfh->value.pv) { ");
            emit($cg, "  const char *__fnm = __fnfh->value.pv; ");
            emit($cg, "  if (strcmp(__fnm, \"STDIN\") == 0) __fno = 0; ");
            emit($cg, "  else if (strcmp(__fnm, \"STDOUT\") == 0) __fno = 1; ");
            emit($cg, "  else if (strcmp(__fnm, \"STDERR\") == 0) __fno = 2; ");
            emit($cg, "} ");
            emit($cg, "__fno >= 0 ? STRADA_MAKE_TAGGED_INT(__fno) : strada_new_undef(); })");
        } else {
            emit($cg, "strada_new_undef()");
        }
        return;
    }

    # getc($fh) — read one byte; returns single-char string or undef at EOF
    if ($name eq "getc") {
        if ($argc > 0) {
            emit($cg, "({ StradaValue *__gcfh = ");
            gen_expr($cg, $args->[0]);
            emit($cg, "; StradaValue *__gcr = strada_new_undef(); ");
            emit($cg, "if (__gcfh && !STRADA_IS_TAGGED_INT(__gcfh) && __gcfh->type == STRADA_FILEHANDLE && __gcfh->value.fh) { ");
            emit($cg, "int __gci = fgetc(__gcfh->value.fh); ");
            emit($cg, "if (__gci != EOF) { strada_decref(__gcr); char __gcb[2] = { (char)__gci, 0 }; __gcr = strada_new_str_len(__gcb, 1); } } __gcr; })");
        } else {
            emit($cg, "strada_new_undef()");
        }
        return;
    }

    # chomp on readline result: chomp(my $line = <$fh>)
    # This is handled by the normal chomp handler

    # umask() / umask(N) — wraps libc umask(2). 0-arg form returns the
    # current umask without changing it (the standard idiom: save +
    # restore around a section that needs a different mask).
    if ($name eq "umask") {
        if ($argc == 0) {
            emit($cg, "({ int __u = (int)umask(022); umask((mode_t)__u); STRADA_MAKE_TAGGED_INT((int64_t)__u); })");
        } else {
            emit($cg, "({ int __u = (int)umask((mode_t)strada_to_int(");
            gen_expr($cg, $args->[0]);
            emit($cg, ")); STRADA_MAKE_TAGGED_INT((int64_t)__u); })");
        }
        return;
    }

    # binmode(FH) / binmode(FH, ":layer") — perla strings are byte-oriented
    # already; this is effectively a no-op that returns 1 (success). Without
    # this handler the bareword fell through to perla_code_get lookup which
    # missed and returned undef, so `binmode($fh) or die` falsely triggered
    # on every call. Accepts 0+ args (some code calls bare `binmode;`).
    if ($name eq "binmode") {
        emit($cg, "({ STRADA_MAKE_TAGGED_INT(1); })");
        return;
    }

    # close(fh) — Perl returns 1 on success, 0 on failure; runtime helper is void
    if ($name eq "close") {
        if ($argc > 0) {
            # Bareword FH: resolve through the package stash (same as
            # open() stored it there). Otherwise evaluate the expression
            # — which handles scalar-var FHs.
            my scalar $clfh = $args->[0];
            # Tied-handle dispatch for bareword close FH.
            if (defined($clfh) && $clfh->{"type"} == Perla::AST::N_CALL()
                && defined($clfh->{"name"})) {
                my scalar $clfargs = $clfh->{"args"};
                my int $clacount = 0;
                if (defined($clfargs)) { $clacount = scalar(@{$clfargs}); }
                if ($clacount == 0) {
                    my str $clname = "" . $clfh->{"name"};
                    emit($cg, "({ StradaValue *__th_cl = perla_tied_handle_for_name(\"" . $cg->{"pkg"} . "\", \"" . $clname . "\"); __th_cl ? perla_tied_handle_close(\"" . $cg->{"pkg"} . "\", \"" . $clname . "\") : ({ strada_close(perla_scalar_get(\"" . $cg->{"pkg"} . "\", \"" . $clname . "\")); STRADA_MAKE_TAGGED_INT(1); }); })");
                    return;
                }
            }
            emit($cg, "({ strada_close(");
            if (defined($clfh) && $clfh->{"type"} == Perla::AST::N_CALL()) {
                my scalar $clfargs = $clfh->{"args"};
                my int $clacount = 0;
                if (defined($clfargs)) { $clacount = scalar(@{$clfargs}); }
                if ($clacount == 0 && defined($clfh->{"name"})) {
                    emit($cg, "perla_scalar_get(\"" . $cg->{"pkg"} . "\", \"" . $clfh->{"name"} . "\")");
                } else {
                    gen_expr($cg, $clfh);
                }
            } else {
                gen_expr($cg, $clfh);
            }
            emit($cg, "); STRADA_MAKE_TAGGED_INT(1); })");
        } else {
            emit($cg, "STRADA_MAKE_TAGGED_INT(0)");
        }
        return;
    }

    # readline(fh) — Perl semantics: preserve the trailing record separator.
    if ($name eq "readline") {
        if ($argc > 0) {
            emit($cg, "perla_readline_fh(");
            gen_expr($cg, $args->[0]);
            emit($cg, ")");
        } else {
            emit($cg, "strada_readline()");
        }
        return;
    }

    # read(FH, $buf, $length) — reads up to $length bytes into $buf,
    # returns bytes actually read (0 on EOF, undef on error). FH may be
    # a bareword (resolved via the package stash), a scalar variable, or
    # a filehandle expression. Used by legacy code for slurping config
    # files in the `open(CF, $file); read(CF, $buf, -s $file)` idiom.
    if ($name eq "read" && $argc >= 3) {
        my scalar $rfh = $args->[0];
        my scalar $rbuf = $args->[1];
        my scalar $rlen = $args->[2];
        emit($cg, "({ StradaValue *__rfh = ");
        if (defined($rfh) && $rfh->{"type"} == Perla::AST::N_CALL()) {
            my scalar $rfhargs = $rfh->{"args"};
            my int $racount = 0;
            if (defined($rfhargs)) { $racount = scalar(@{$rfhargs}); }
            if ($racount == 0 && defined($rfh->{"name"})) {
                emit($cg, "perla_scalar_get(\"" . $cg->{"pkg"} . "\", \"" . $rfh->{"name"} . "\")");
            } else {
                gen_expr($cg, $rfh);
            }
        } else {
            gen_expr($cg, $rfh);
        }
        emit($cg, "; int __rlen = (int)strada_to_int(");
        gen_expr($cg, $rlen);
        emit($cg, "); ");
        # 4-arg read: OFFSET preserves the leading OFFSET bytes of the
        # buffer; pad with NULs if the buffer is shorter; then place the
        # newly read bytes starting at OFFSET. Capture the current buffer
        # value BEFORE the fread so subsequent assignment doesn't
        # clobber it.
        if ($argc >= 4) {
            emit($cg, "int __roff = (int)strada_to_int(");
            gen_expr($cg, $args->[3]);
            emit($cg, "); if (__roff < 0) __roff = 0; ");
            emit($cg, "StradaValue *__rold_buf = ");
            gen_expr($cg, $rbuf);
            emit($cg, "; size_t __rold_len = (__rold_buf && !STRADA_IS_TAGGED_INT(__rold_buf) && __rold_buf->type == STRADA_STR) ? strada_str_len(__rold_buf) : 0; ");
            emit($cg, "const char *__rold_data = (__rold_buf && !STRADA_IS_TAGGED_INT(__rold_buf) && __rold_buf->type == STRADA_STR && __rold_buf->value.pv) ? __rold_buf->value.pv : \"\"; ");
        }
        emit($cg, "FILE *__rfp = NULL; ");
        emit($cg, "if (__rfh && !STRADA_IS_TAGGED_INT(__rfh) && __rfh->type == STRADA_FILEHANDLE) __rfp = __rfh->value.fh; ");
        emit($cg, "StradaValue *__rres; int __rnbytes = 0; ");
        emit($cg, "if (__rfp && __rlen > 0) { char *__rb = (char*)malloc((size_t)__rlen + 1); __rnbytes = (int)fread(__rb, 1, (size_t)__rlen, __rfp); __rb[__rnbytes] = 0; ");
        if ($argc >= 4) {
            emit($cg, "size_t __rkeep = ((size_t)__roff < __rold_len) ? (size_t)__roff : __rold_len; ");
            emit($cg, "size_t __rpad = ((size_t)__roff > __rold_len) ? ((size_t)__roff - __rold_len) : 0; ");
            emit($cg, "size_t __rfinal = __rkeep + __rpad + (size_t)__rnbytes; ");
            emit($cg, "char *__rcb = (char*)malloc(__rfinal + 1); ");
            emit($cg, "if (__rkeep > 0) memcpy(__rcb, __rold_data, __rkeep); ");
            emit($cg, "if (__rpad > 0) memset(__rcb + __rkeep, 0, __rpad); ");
            emit($cg, "if (__rnbytes > 0) memcpy(__rcb + __rkeep + __rpad, __rb, (size_t)__rnbytes); ");
            emit($cg, "__rcb[__rfinal] = 0; ");
            emit($cg, "{ StradaValue *__rbv = strada_new_str_len(__rcb, __rfinal); free(__rcb); ");
        } else {
            emit($cg, "{ StradaValue *__rbv = strada_new_str_len(__rb, __rnbytes); ");
        }
        # Write __rbv into $buf
        my int $rbt = $rbuf->{"type"};
        if ($rbt == Perla::AST::N_SCALAR_VAR()) {
            emit($cg, "strada_decref(" . c_var($rbuf->{"name"}) . "); " . c_var($rbuf->{"name"}) . " = __rbv; ");
        } elsif ($rbt == Perla::AST::N_ARRAY_ELEM() || $rbt == Perla::AST::N_ARROW_ARRAY()) {
            # `read($fh, $_[1], $len)` — buffer is `$_[N]` or `$ref->[N]`,
            # must use strada_array_set for the writeback (assignment to a
            # function call is invalid C). Surfaced via IO::Handle::read
            # which delegates to the builtin: `read($_[0], $_[1], $_[2], …)`.
            my scalar $rb_arr;
            if ($rbt == Perla::AST::N_ARRAY_ELEM()) {
                $rb_arr = $rbuf->{"array"};
            } else {
                $rb_arr = $rbuf->{"object"};
            }
            emit($cg, "({ StradaArray *__rb_av = strada_deref_array(");
            if (defined($rb_arr) && $rb_arr->{"type"} == Perla::AST::N_SCALAR_VAR()
                && defined($rb_arr->{"name"}) && $rb_arr->{"name"} eq "_") {
                # $_[N] indexes @_ which is perla_at_
                emit($cg, "perla_at_");
            } elsif ($rbt == Perla::AST::N_ARRAY_ELEM() && defined($rb_arr) && $rb_arr->{"type"} == Perla::AST::N_SCALAR_VAR()) {
                # $foo[N] indexes @foo
                emit($cg, c_var_a($rb_arr->{"name"}));
            } else {
                gen_expr($cg, $rb_arr);
            }
            emit($cg, "); int __rb_idx = (int)strada_to_int(");
            gen_expr($cg, $rbuf->{"index"});
            emit($cg, "); if (__rb_idx < 0 && __rb_av) __rb_idx += strada_array_length(__rb_av); ");
            emit($cg, "strada_incref(__rbv); strada_array_set(__rb_av, __rb_idx, __rbv); }); ");
        } elsif ($rbt == Perla::AST::N_DEREF_SCALAR()) {
            # `read($fh, $$ref, $len)` — buffer is dereffed scalar
            emit($cg, "({ StradaValue *__rb_dr = ");
            gen_expr($cg, $rbuf->{"target"});
            emit($cg, "; if (__rb_dr && !STRADA_IS_TAGGED_INT(__rb_dr) && __rb_dr->type == STRADA_REF) { ");
            emit($cg, "  if (__rb_dr->value.rv) strada_decref(__rb_dr->value.rv); ");
            emit($cg, "  __rb_dr->value.rv = __rbv; strada_incref(__rbv); ");
            emit($cg, "} }); ");
        } elsif ($rbt == Perla::AST::N_MY() && defined($rbuf->{"var"})) {
            # `read($fh, my $buf, $len)` — must declare the lexical then
            # assign __rbv directly to its C var. Falling through to the
            # generic `gen_expr(rbuf) = __rb_tgt` path emitted
            # `(v_buf = strada_new_undef()) = __rb_tgt;` (assignment to an
            # rvalue assign-expr) which gcc rejects with "lvalue required".
            my str $rb_my_name = $rbuf->{"var"}->{"value"};
            my str $rb_my_cvar = c_var($rb_my_name);
            _my_prefix($cg, $rb_my_name);
            emit($cg, $rb_my_cvar . " = __rbv; ");
        } else {
            emit($cg, "({ StradaValue *__rb_tgt = __rbv; ");
            gen_expr($cg, $rbuf);
            emit($cg, " = __rb_tgt; }); ");
        }
        emit($cg, "} free(__rb); __rres = STRADA_MAKE_TAGGED_INT(__rnbytes); } else { __rres = strada_new_undef(); } __rres; })");
        return;
    }

    # flock($fh, OP) — file locking. Perl built-in. Need our own codegen
    # because (a) strada_flock() in the runtime expects an int fd (not a
    # filehandle scalar) and (b) bareword constants LOCK_SH/LOCK_EX/LOCK_UN
    # /LOCK_NB from `use Fcntl qw(:flock)` fall through as STRADA_STR
    # literals (the broader bareword-as-constant-sub gap), so we map them
    # here. Combined flags like `LOCK_EX | LOCK_NB` become a numeric OR
    # which we trust the runtime constant resolution to handle.
    if ($name eq "flock") {
        if ($argc >= 2) {
            emit($cg, "({ StradaValue *__fl_fh = ");
            gen_expr($cg, $args->[0]);
            emit($cg, "; StradaValue *__fl_op = ");
            gen_expr($cg, $args->[1]);
            emit($cg, "; int __fl_fd = -1; ");
            emit($cg, "if (__fl_fh && !STRADA_IS_TAGGED_INT(__fl_fh) && __fl_fh->type == STRADA_FILEHANDLE && __fl_fh->value.fh) { __fl_fd = fileno(__fl_fh->value.fh); } else if (__fl_fh) { __fl_fd = (int)strada_to_int(__fl_fh); } ");
            emit($cg, "int __fl_op_val = 0; ");
            emit($cg, "if (__fl_op && !STRADA_IS_TAGGED_INT(__fl_op) && __fl_op->type == STRADA_STR && __fl_op->value.pv) { ");
            emit($cg, "  const char *__fls = __fl_op->value.pv; int __flv = 0; ");
            emit($cg, "  if (strstr(__fls, \"LOCK_SH\")) __flv |= LOCK_SH; ");
            emit($cg, "  if (strstr(__fls, \"LOCK_EX\")) __flv |= LOCK_EX; ");
            emit($cg, "  if (strstr(__fls, \"LOCK_UN\")) __flv |= LOCK_UN; ");
            emit($cg, "  if (strstr(__fls, \"LOCK_NB\")) __flv |= LOCK_NB; ");
            emit($cg, "  __fl_op_val = __flv; ");
            emit($cg, "} else { __fl_op_val = (int)strada_to_int(__fl_op); } ");
            emit($cg, "int __fl_r = (__fl_fd >= 0 && flock(__fl_fd, __fl_op_val) == 0) ? 1 : 0; ");
            emit($cg, "STRADA_MAKE_TAGGED_INT(__fl_r); })");
            return;
        }
    }

    # unlink(file, ...) — Perl semantics: takes a list, returns count of
    # successful deletes.
    if ($name eq "unlink") {
        if ($argc == 1) {
            # Single arg may itself be a list-returning expression; expand
            # at runtime if it's an array.
            emit($cg, "({ int __nok = 0; int __sav_wl_ul = __perla_want_list; __perla_want_list = 1; ");
            emit($cg, "StradaValue *__ula = ");
            gen_expr($cg, $args->[0]);
            emit($cg, "; __perla_want_list = __sav_wl_ul; ");
            emit($cg, "if (__ula && !STRADA_IS_TAGGED_INT(__ula) && __ula->type == STRADA_ARRAY) { ");
            emit($cg, "  StradaArray *__ulav = __ula->value.av; if (__ulav) for (size_t __uli = 0; __uli < __ulav->size; __uli++) { ");
            emit($cg, "    char *__ulfn = strada_to_str(__ulav->elements[__ulav->head + __uli]); ");
            emit($cg, "    if (__ulfn && remove(__ulfn) == 0) __nok++; free(__ulfn); } ");
            emit($cg, "} else if (__ula) { char *__ulfn = strada_to_str(__ula); if (__ulfn && remove(__ulfn) == 0) __nok++; free(__ulfn); } ");
            emit($cg, "STRADA_MAKE_TAGGED_INT(__nok); })");
        } elsif ($argc > 1) {
            emit($cg, "({ int __nok = 0; ");
            my int $uli = 0;
            while ($uli < $argc) {
                emit($cg, "{ char *__ulfn = strada_to_str(");
                gen_expr($cg, $args->[$uli]);
                emit($cg, "); if (__ulfn && remove(__ulfn) == 0) __nok++; free(__ulfn); } ");
                $uli++;
            }
            emit($cg, "STRADA_MAKE_TAGGED_INT(__nok); })");
        } else {
            # No args: unlink $_
            emit($cg, "({ char *__ulfn = strada_to_str(perla_dollar_underscore); int __r = (__ulfn && remove(__ulfn) == 0) ? 1 : 0; free(__ulfn); STRADA_MAKE_TAGGED_INT(__r); })");
        }
        return;
    }
    # truncate(FILE_OR_FH, LENGTH) — set file size. Accepts either a path
    # (str) or an open filehandle. Returns 1 on success, undef on failure.
    if ($name eq "truncate") {
        if ($argc >= 2) {
            emit($cg, "({ StradaValue *__tt_arg = ");
            gen_expr($cg, $args->[0]);
            emit($cg, "; off_t __tt_len = (off_t)strada_to_int(");
            gen_expr($cg, $args->[1]);
            emit($cg, "); int __tt_r = -1; ");
            emit($cg, "if (__tt_arg && !STRADA_IS_TAGGED_INT(__tt_arg) && __tt_arg->type == STRADA_FILEHANDLE && __tt_arg->value.fh) { ");
            emit($cg, "  fflush(__tt_arg->value.fh); __tt_r = ftruncate(fileno(__tt_arg->value.fh), __tt_len); ");
            emit($cg, "} else if (__tt_arg) { ");
            emit($cg, "  char *__tt_path = strada_to_str(__tt_arg); ");
            emit($cg, "  if (__tt_path) { __tt_r = truncate(__tt_path, __tt_len); free(__tt_path); } ");
            emit($cg, "} __tt_r == 0 ? STRADA_MAKE_TAGGED_INT(1) : strada_new_undef(); })");
        } else {
            emit($cg, "strada_new_undef()");
        }
        return;
    }
    # symlink(target, link) — create a symlink. Returns 1 on success.
    if ($name eq "symlink") {
        if ($argc >= 2) {
            emit($cg, "({ char *__sym_t = strada_to_str(");
            gen_expr($cg, $args->[0]);
            emit($cg, "); char *__sym_l = strada_to_str(");
            gen_expr($cg, $args->[1]);
            emit($cg, "); int __r = symlink(__sym_t, __sym_l); free(__sym_t); free(__sym_l); STRADA_MAKE_TAGGED_INT(__r == 0 ? 1 : 0); })");
        } else {
            emit($cg, "STRADA_MAKE_TAGGED_INT(0)");
        }
        return;
    }
    # readlink(path) — read the contents of a symlink.
    if ($name eq "readlink") {
        if ($argc > 0) {
            emit($cg, "({ char *__rl_p = strada_to_str(");
