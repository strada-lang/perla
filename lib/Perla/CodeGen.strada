        } else if (defined($node->{"expr"})) {
            emit($cg, "perla_require_module(");
            gen_expr($cg, $node->{"expr"});
            emit($cg, ")");
        } else {
            emit($cg, "strada_new_undef()");
        }
        return;
    }
    if ($type == Perla::AST::N_SCALAR_VAR()) {
        my str $name = $node->{"name"};
        # Special variables
        if ($name eq "_") {
            emit($cg, "perla_dollar_underscore");
            return;
        }
        if ($name eq "@") {
            # `$@` reads default to the empty string (not undef) in perl —
            # `defined($@)` at startup is true. The global starts NULL until
            # the first die/eval, so lazy-init on first read so user code
            # checking `defined($@)` doesn't see undef. Matches the
            # eval-success refcount pattern (rc=2 after init so external
            # decrefs don't free the slot).
            emit($cg, "({ if (!perla_eval_error) { perla_eval_error = strada_new_str(\"\"); strada_incref(perla_eval_error); } perla_eval_error; })");
            return;
        }
        if ($name eq "AUTOLOAD") {
            emit($cg, "perla_get_autoload_var()");
            return;
        }
        # $a and $b — sort comparator variables (only inside sort blocks)
        # These are always mapped to @_[0] and @_[1] in sort comparator subs
        # since the sub receives the pair as arguments
        if ($name eq "!") {
            # $! is a dualvar — string form is strerror(errno), numeric
            # form is errno itself. `$! + 0` must return the errno number,
            # not 0 (which strerror's string parses to). When errno is 0
            # (no error pending), emit "" — not strerror(0)'s "Success" /
            # "Unknown error 0" string, which made `if ($!)` truthy at
            # startup and `$! eq ""` always false. perl's documented
            # convention is that $! is empty when no error is set.
            emit($cg, "strada_new_dualvar((int64_t)errno, errno ? strerror(errno) : \"\")");
            return;
        }
        # $1-$9 capture variables
        if ($name ge "1" && $name le "9") {
            emit($cg, "strada_capture_var(" . $name . ")");
            return;
        }
        # $& — whole match (same as $0 capture in PCRE2)
        if ($name eq "&") {
            emit($cg, "strada_capture_var(0)");
            return;
        }
        # $` — prematch
        if ($name eq "`") {
            emit($cg, "strada_prematch()");
            return;
        }
        # $' — postmatch
        if ($name eq "'") {
            emit($cg, "strada_postmatch()");
            return;
        }
        # $0 — program name (from argv[0] at main() startup, mutable).
        if ($name eq "0") {
            emit($cg, "(perla_dollar_zero ? ({ strada_incref(perla_dollar_zero); perla_dollar_zero; }) : strada_new_str(\"perla\"))");
            return;
        }
        # \$ARGV — current filename during \`while (<>)\` reads. Set by
        # perla_readline_argv on each file boundary. perla_current_argv
        # is a runtime global; falls back to undef when no diamond read
        # has fired (matching Perl).
        if ($name eq "ARGV") {
            emit($cg, "(perla_current_argv ? ({ strada_incref(perla_current_argv); perla_current_argv; }) : strada_new_undef())");
            return;
        }
        # $+ — last paren match value (last successful capture).
        if ($name eq "+") {
            emit($cg, "strada_last_paren_match()");
            return;
        }
        # $$ — process ID
        if ($name eq "$") {
            emit($cg, "STRADA_MAKE_TAGGED_INT((int64_t)getpid())");
            return;
        }
        # $? — wait status of last system()/qx (raw waitpid status).
        if ($name eq "?") {
            emit($cg, "STRADA_MAKE_TAGGED_INT((int64_t)perla_dollar_question)");
            return;
        }
        # $. — current input line number (from last <FH> read).
        if ($name eq ".") {
            emit($cg, "STRADA_MAKE_TAGGED_INT((int64_t)perla_dollar_dot)");
            return;
        }
        # $/ — input record separator
        if ($name eq "/") {
            emit($cg, "perla_irs");
            return;
        }
        # $~ — current format name (default = handle name)
        if ($name eq "~") {
            emit($cg, "(perla_dollar_tilde ? perla_dollar_tilde : strada_new_undef())");
            return;
        }
        # $^ — top-of-page format name
        if ($name eq "^") {
            emit($cg, "(perla_dollar_caret ? perla_dollar_caret : strada_new_undef())");
            return;
        }
        # $= — current page length
        if ($name eq "=") {
            emit($cg, "(perla_dollar_equals ? perla_dollar_equals : STRADA_MAKE_TAGGED_INT(60))");
            return;
        }
        # $% — current page number (write-incremented by format_TOP)
        if ($name eq "%") {
            emit($cg, "(perla_dollar_percent ? perla_dollar_percent : STRADA_MAKE_TAGGED_INT(0))");
            return;
        }
        # $^A — formline accumulator
        if ($name eq "^A") {
            emit($cg, "(perla_dollar_caret_A ? perla_dollar_caret_A : strada_new_str(\"\"))");
            return;
        }
        # $\ — output record separator
        if ($name eq "\\") {
            emit($cg, "perla_ors");
            return;
        }
        # $, — output field separator
        if ($name eq ",") {
            emit($cg, "perla_ofs");
            return;
        }
        # $" — list separator for array interpolation
        if ($name eq "\"") {
            emit($cg, "perla_lse");
            return;
        }
        # $| — output autoflush
        if ($name eq "|") {
            emit($cg, "STRADA_MAKE_TAGGED_INT((int64_t)__perla_autoflush)");
            return;
        }
        # $; — subscript separator (real variable so `$; = "..."` is an
        # lvalue; default is "\034" set in main init).
        if ($name eq ";") {
            emit($cg, "perla_subsep");
            return;
        }
        # $< / $> — real / effective UID. Without this, `$<` parsed as
        # N_SCALAR_VAR name="<" then fell through to perla_scalar_get
        # which returned undef; common idiom `if ($< == 0) { root }`
        # always failed.
        if ($name eq "<") {
            emit($cg, "STRADA_MAKE_TAGGED_INT((int64_t)getuid())");
            return;
        }
        if ($name eq ">") {
            emit($cg, "STRADA_MAKE_TAGGED_INT((int64_t)geteuid())");
            return;
        }
        # $( / $) — real / effective GID.
        if ($name eq "(") {
            emit($cg, "STRADA_MAKE_TAGGED_INT((int64_t)getgid())");
            return;
        }
        if ($name eq ")") {
            emit($cg, "STRADA_MAKE_TAGGED_INT((int64_t)getegid())");
            return;
        }
        # Package-qualified $Pkg::Name reads go through the stash so
        # cross-package access sees any package's `our $VAR` (or file-scope
        # `my $VAR` we publish at startup). Without this the fully-qualified
        # form resolves to a file-static never updated from other packages.
        if (index($name, "::") > 0) {
            my int $li = -1;
            my int $si = 0;
            while ($si < length($name) - 1) {
                if (substr($name, $si, 2) eq "::") { $li = $si; }
                $si++;
            }
            my str $spkg = substr($name, 0, $li);
            my str $sname = substr($name, $li + 2, length($name) - $li - 2);
            emit($cg, "perla_scalar_get(\"" . $spkg . "\", \"" . $sname . "\")");
            return;
        }
        # Scalars stay on plain _c_var — no mangle suffix.
        _strict_check_var($cg, "\$", $name, $node->{"line"} + 0);
        emit($cg, c_var($name));
        return;
    }
    if ($type == Perla::AST::N_ARRAY_VAR()) {
        my str $name = $node->{"name"};
        if ($name eq "_") {
            emit($cg, "perla_at_");
            return;
        }
        # `@-` and `@+` — regex match offset arrays. Without these,
        # whole-array access of @- / @+ fell back to the generic
        # c_var_a path (v__minus_ / v__plus_) which was never
        # populated. Element access ($-[N] / $+[N]) already routes
        # correctly via the N_ARRAY_ELEM codegen; only whole-array
        # was broken.
        if ($name eq "-") {
            emit($cg, "strada_match_starts()");
            return;
        }
        if ($name eq "+") {
            emit($cg, "strada_match_ends()");
            return;
        }
        # Package-qualified @Pkg::Name reads go through the stash so
        # runtime assignments like `@{"Pkg::ISA"}=Parent` (which write to
        # the stash via perla_isa_assign) are visible here. Without this,
        # perla_isa_assign writes to stash->isa but the compiled access
        # reads a separate static C global that was never updated.
        if (index($name, "::") > 0) {
            my int $li = -1;
            my int $si = 0;
            while ($si < length($name) - 1) {
                if (substr($name, $si, 2) eq "::") { $li = $si; }
                $si++;
            }
            my str $apkg = substr($name, 0, $li);
            my str $aname = substr($name, $li + 2, length($name) - $li - 2);
            emit($cg, "perla_array_get(\"" . $apkg . "\", \"" . $aname . "\")");
            return;
        }
        _strict_check_var($cg, "@", $name, $node->{"line"} + 0);
        emit($cg, c_var_a($name));
        return;
    }
    if ($type == Perla::AST::N_HASH_VAR()) {
        my str $hvname = $node->{"name"};
        # `%+` — named regex captures hash. Route to strada_named_captures()
        # so `%parsed = %+` and friends iterate the actual captures.
        # Without this, c_var_h returned v__plus (a never-initialized
        # global) and %+ behaved as empty.
        if ($hvname eq "+") {
            emit($cg, "strada_named_captures()");
            return;
        }
        # `%Pkg::` (trailing `::` and no name after) — Perl's stash-as-hash
        # form. `keys %Mine::` returns the package's defined symbol names;
        # `each %Mine::` iterates them. perla_stash_as_hash snapshots the
        # current stash entries into a fresh HASH (value = "*Pkg::name"
        # matching Perl's typeglob stringification). Snapshot semantics
        # are sufficient for the common `keys`/`each`/`exists` patterns.
        if (length($hvname) >= 2 && substr($hvname, length($hvname) - 2, 2) eq "::") {
            my str $sn = substr($hvname, 0, length($hvname) - 2);
            emit($cg, "perla_stash_as_hash(\"" . $sn . "\")");
            return;
        }
        # Package-qualified %Pkg::Name reads go through the stash so a
        # package's `our %H` (published to its glob) and a cross-package
        # `$Pkg::H{$k}` read see the same hash. Without this the
        # fully-qualified form resolves to a distinct file-static that's
        # never linked to v_H.
        if (index($hvname, "::") > 0) {
            my int $li = -1;
            my int $si = 0;
            while ($si < length($hvname) - 1) {
                if (substr($hvname, $si, 2) eq "::") { $li = $si; }
                $si++;
            }
            my str $hpkg = substr($hvname, 0, $li);
            my str $hname = substr($hvname, $li + 2, length($hvname) - $li - 2);
            emit($cg, "perla_hash_get(\"" . $hpkg . "\", \"" . $hname . "\")");
            return;
        }
        _strict_check_var($cg, "%", $hvname, $node->{"line"} + 0);
        emit($cg, c_var_h($hvname));
        return;
    }

    if ($type == Perla::AST::N_RAW_C()) {
        # Codegen-internal placeholder: emit a raw C expression
        # already constructed by the caller. Used by N_CHAIN_CMP to
        # delegate sub-binop emission back into _gen_binop without
        # re-evaluating each operand.
        emit($cg, $node->{"text"});
        return;
    }
    if ($type == Perla::AST::N_BINOP()) {
        Perla::CodeGen::Operator::_gen_binop($cg, $node);
        return;
    }
    if ($type == Perla::AST::N_CHAIN_CMP()) {
        # Perl 5.32+ chained comparison: A op1 B op2 C op3 D ...
        # ≡ (A op1 B) && (B op2 C) && (C op3 D), with each operand
        # evaluated exactly once. Short-circuits on the first false
        # link. Materialise by capturing each operand into a fresh
        # __cc_NN slot and chaining ternary ANDs.
        my scalar $ops = $node->{"ops"};
        my scalar $operands = $node->{"operands"};
        my int $n_op = scalar(@{$ops});
        # Cache operands as __cc_0 .. __cc_n.
        emit($cg, "({ ");
        my int $ci = 0;
        while ($ci <= $n_op) {
            emit($cg, "StradaValue *__cc_" . $ci . " = ");
            gen_expr($cg, $operands->[$ci]);
            emit($cg, "; ");
            $ci++;
        }
        # Build the comparison chain. Each link is a single binop on
        # the two cached operands; we synthesise an N_BINOP node and
        # delegate to the existing _gen_binop emit. Tier-3 (=~/!~/~~)
        # is rejected by the parser before getting here, so all ops
        # are pure numeric or string comparisons whose codegen yields
        # a perl-truthy StradaValue (tagged-int 1 or strada_new_str("")).
        emit($cg, "int __cc_pass = 1; ");
        my int $li = 0;
        while ($li < $n_op) {
            emit($cg, "if (__cc_pass) { StradaValue *__cc_lr = ");
            my scalar $link = Perla::AST::node(Perla::AST::N_BINOP());
            $link->{"op"} = $ops->[$li];
            my scalar $lvar = Perla::AST::node(Perla::AST::N_RAW_C());
            $lvar->{"text"} = "__cc_" . $li;
            my scalar $rvar = Perla::AST::node(Perla::AST::N_RAW_C());
            $rvar->{"text"} = "__cc_" . ($li + 1);
            $link->{"left"} = $lvar;
            $link->{"right"} = $rvar;
            gen_expr($cg, $link);
            emit($cg, "; if (!perla_to_bool(__cc_lr)) __cc_pass = 0; ");
            emit($cg, "if (__cc_lr) strada_decref(__cc_lr); } ");
            $li++;
        }
        # Decref captured operands.
        my int $di = 0;
        while ($di <= $n_op) {
            emit($cg, "if (__cc_" . $di . ") strada_decref(__cc_" . $di . "); ");
            $di++;
        }
        emit($cg, "__cc_pass ? STRADA_MAKE_TAGGED_INT(1) : strada_new_str(\"\"); })");
        return;
    }
    if ($type == Perla::AST::N_UNOP()) {
        Perla::CodeGen::Operator::_gen_unop($cg, $node);
        return;
    }
    if ($type == Perla::AST::N_ASSIGN()) {
        # In expression context, plain `=` on a simple scalar/array/hash var
        # must use `(target = value)` form — the statement-level path would
        # emit `strada_decref(target); target = value` which is invalid when
        # embedded inside another expression (e.g. `__try_result = ASSIGN`).
        if (defined($node->{"op"}) && $node->{"op"} eq "=") {
            my scalar $atarget = $node->{"target"};
            # `vec(EXPR, OFFSET, BITS) = VALUE` — perl's bit-vector
            # lvalue. The target N_CALL("vec") isn't a real lvalue;
            # route through strada_vec_set which writes into EXPR's
            # underlying string. Returns VALUE (matching perl's
            # assignment-expression value).
            if (defined($atarget) && $atarget->{"type"} == Perla::AST::N_CALL()
                && defined($atarget->{"name"}) && $atarget->{"name"} eq "vec"
                && defined($atarget->{"args"}) && scalar(@{$atarget->{"args"}}) == 3) {
                emit($cg, "({ StradaValue *__vec_sv = ");
                gen_expr($cg, $atarget->{"args"}->[0]);
                emit($cg, "; int64_t __vec_off = strada_to_int(");
                gen_expr($cg, $atarget->{"args"}->[1]);
                emit($cg, "); int __vec_bits = (int)strada_to_int(");
                gen_expr($cg, $atarget->{"args"}->[2]);
                emit($cg, "); int64_t __vec_val = strada_to_int(");
                gen_expr($cg, $node->{"value"});
                emit($cg, "); strada_vec_set(__vec_sv, __vec_off, __vec_bits, __vec_val); STRADA_MAKE_TAGGED_INT(__vec_val); })");
                return;
            }
            if (defined($atarget)) {
                my int $attype = $atarget->{"type"};
                # Perl special scalars ($!, $/, $\, $,, $|) don't have real
                # lvalues — the read form expands to a function call (e.g.
                # strerror(errno)) so `(target = value)` fails at the C
                # level. Hand these off to _gen_assign which has per-var
                # statement-expression emitters that side-effect the
                # underlying C state correctly.
                if ($attype == Perla::AST::N_SCALAR_VAR()) {
                    my str $asvname = $atarget->{"name"};
                    if ($asvname eq "!" || $asvname eq "/" || $asvname eq "\\"
                        || $asvname eq "," || $asvname eq "|" || $asvname eq "0"
                        || $asvname eq "?" || $asvname eq "~" || $asvname eq "^"
                        || $asvname eq "=" || $asvname eq "%" || $asvname eq "^A") {
                        Perla::CodeGen::Assign::_gen_assign($cg, $node);
                        return;
                    }
                    # $AUTOLOAD reads emit perla_get_autoload_var() (non-lvalue);
                    # route writes through the setter helper.
                    if ($asvname eq "AUTOLOAD") {
                        emit($cg, "({ StradaValue *__al_v = ");
                        gen_expr($cg, $node->{"value"});
                        emit($cg, "; perla_set_autoload_var_sv(__al_v); strada_incref(__al_v); __al_v; })");
                        return;
                    }
                }
                # `$#arr = N` — N_SPECIAL_VAR with "#NAME" — route to
                # _gen_assign for the truncate/extend semantics.
                if ($attype == Perla::AST::N_SPECIAL_VAR()
                    && defined($atarget->{"value"})
                    && substr($atarget->{"value"}, 0, 1) eq "#") {
                    Perla::CodeGen::Assign::_gen_assign($cg, $node);
                    return;
                }
                # HASH_VAR = LIST needs the list-to-hash conversion, not a
                # plain `(target = value)` — otherwise `%h = ()` or
                # `%h = (k, v, ...)` assigns an array to the hash slot and
                # later strada_hv_store silently fails. Delegate to the
                # statement-level path which has the conversion logic.
                if ($attype == Perla::AST::N_HASH_VAR()) {
                    Perla::CodeGen::Assign::_gen_assign($cg, $node);
                    return;
                }
                # ARRAY_VAR = RHS needs list-context evaluation of RHS.
                # Without delegating, `@arr = func()` reduces func's return
                # to scalar (last elem). Delegate to _gen_assign which has
                # the list-context branch.
                if ($attype == Perla::AST::N_ARRAY_VAR()
                    && (!defined($atarget->{"name"})
                        || index($atarget->{"name"}, "::") < 0)) {
                    Perla::CodeGen::Assign::_gen_assign($cg, $node);
                    return;
                }
                # Package-qualified @Pkg::Name = ... — the read form uses
                # perla_array_get (which returns an rvalue), so the plain
                # `(target = value)` form would try to assign to a function
                # return. Delegate to _gen_assign which has a stash-aware
                # path (perla_isa_assign for ISA, perla_glob_store
                # otherwise).
                if ($attype == Perla::AST::N_ARRAY_VAR()
                    && defined($atarget->{"name"})
                    && index($atarget->{"name"}, "::") > 0) {
                    Perla::CodeGen::Assign::_gen_assign($cg, $node);
                    return;
                }
                # Package-qualified $Pkg::Name = ... — same reason
                # (perla_scalar_get is non-lvalue). Delegate to _gen_assign
                # which routes through perla_scalar_set.
                if ($attype == Perla::AST::N_SCALAR_VAR()
                    && defined($atarget->{"name"})
                    && index($atarget->{"name"}, "::") > 0) {
                    Perla::CodeGen::Assign::_gen_assign($cg, $node);
                    return;
                }
                # $1, ..., $9, $& — read-only regex capture vars. The
                # gen_expr path below would emit `strada_capture_var(N) =`
                # which gcc rejects. Delegate to _gen_assign which has a
                # runtime-die path for these.
                if ($attype == Perla::AST::N_SCALAR_VAR()
                    && defined($atarget->{"name"})
                    && ((length($atarget->{"name"}) == 1
                         && $atarget->{"name"} ge "1"
                         && $atarget->{"name"} le "9")
                        || $atarget->{"name"} eq "&")) {
                    Perla::CodeGen::Assign::_gen_assign($cg, $node);
                    return;
                }
                if ($attype == Perla::AST::N_SCALAR_VAR() || $attype == Perla::AST::N_ARRAY_VAR() || $attype == Perla::AST::N_HASH_VAR()) {
                    # strict 'vars' on the WRITE side. Without this, `use
                    # strict; $foo = 3;` silently registered $foo as
                    # IMPLICIT_GLOBAL and the error only surfaced on the
                    # next READ. Real Perl errors on both first read AND
                    # first write — match that here.
                    my str $__sw2_sigil = "\$";
                    if ($attype == Perla::AST::N_ARRAY_VAR()) { $__sw2_sigil = "@"; }
                    elsif ($attype == Perla::AST::N_HASH_VAR()) { $__sw2_sigil = "%"; }
                    _strict_check_var($cg, $__sw2_sigil, "" . $atarget->{"name"}, $atarget->{"line"} + 0);
                    # Mirror unqualified our/file-scope scalar writes to the
                    # package stash so cross-package `$Pkg::NAME` reads see
                    # them. (Qualified targets already dispatched above.)
                    my int $exp_mirror = 0;
                    my str $exp_mname = "";
                    if ($attype == Perla::AST::N_SCALAR_VAR()
                        && defined($atarget->{"name"})
                        && index($atarget->{"name"}, "::") < 0
                        && length($atarget->{"name"}) > 0) {
                        $exp_mname = $atarget->{"name"};
                        if (defined($cg->{"our_vars"}) && exists($cg->{"our_vars"}->{$exp_mname})) {
                            $exp_mirror = 1;
                        }
                        if ($exp_mirror == 0
                            && defined($cg->{"file_scope_vars"}) && exists($cg->{"file_scope_vars"}->{$exp_mname})) {
                            $exp_mirror = 1;
                        }
                    }
                    if ($exp_mirror == 1) {
                        # Decref the previous C-slot value before
                        # overwriting; without this, `$x = undef` leaked
                        # blessed refs and DESTROY never fired.
                        # Special case for `$_`: the read path emits
                        # `perla_dollar_underscore`, so we must use that
                        # same lvalue for the assignment and return —
                        # otherwise the assignment hits perla_dollar_underscore
                        # but the returned value is the unmodified file-scope
                        # `v__`, breaking `while ($_ = shift @data)`.
                        my str $slot_var = c_var($exp_mname);
                        if ($exp_mname eq "_") { $slot_var = "perla_dollar_underscore"; }
                        # Scalar-context of array/hash var → count, not container.
                        my int $__mir_scalarize_h = 0;
                        my int $__mir_scalarize_a = 0;
                        my int $__mir_rhs_t = $node->{"value"}->{"type"};
                        if ($__mir_rhs_t == Perla::AST::N_HASH_VAR()
                            && defined($node->{"value"}->{"name"})
                            && index($node->{"value"}->{"name"}, "::") < 0) {
                            $__mir_scalarize_h = 1;
                        }
                        if ($__mir_rhs_t == Perla::AST::N_ARRAY_VAR()
                            && defined($node->{"value"}->{"name"})
                            && index($node->{"value"}->{"name"}, "::") < 0
                            && $node->{"value"}->{"name"} ne "_") {
                            $__mir_scalarize_a = 1;
                        }
                        # Tie-aware scalar assignment. Capture the new value
                        # first, then if the current slot is a tied scalar,
                        # dispatch STORE and keep the tied SV in the slot.
                        # Otherwise do the normal slot replacement + stash
                        # sync. Predict-not-taken branch — tied SVs are rare.
                        # Scalar assignment puts RHS in SCALAR context so
                        # `our $x = sub_call()` inside a void-context caller
                        # sees scalar (0) via wantarray, not void (-1).
                        emit($cg, "({ StradaValue *__old_sv = " . $slot_var . "; ");
                        emit($cg, "int __sav_wl_sa3 = __perla_want_list; __perla_want_list = 0; ");
                        emit($cg, "StradaValue *__new_sv = ");
                        if ($__mir_scalarize_h == 1) {
                            my str $__rhs_cv = c_var_h($node->{"value"}->{"name"});
                            emit($cg, "({ StradaHash *__sh = strada_deref_hash(" . $__rhs_cv . "); STRADA_MAKE_TAGGED_INT((int64_t)(__sh ? __sh->num_entries : 0)); })");
                        } elsif ($__mir_scalarize_a == 1) {
                            my str $__rhs_cv = c_var_a($node->{"value"}->{"name"});
                            emit($cg, "STRADA_MAKE_TAGGED_INT((int64_t)strada_array_length(strada_deref_array(" . $__rhs_cv . ")))");
                        } else {
                            gen_expr($cg, $node->{"value"});
                        }
                        emit($cg, "; __perla_want_list = __sav_wl_sa3; ");
                        # Borrowed RHS (variable read / array slot) needs
                        # an explicit incref before assignment — gen_expr
                        # didn't bump the refcount, and the destination's
                        # stash mirror + old-slot decref otherwise drops
                        # the underlying SV's last ref. Concretely:
                        # `for my $w (@arr) { $longest = $w if cond }` —
                        # each iter the stash[SCALAR] decref of the prior
                        # iter's value (which was @arr[$i]) freed @arr[$i]
                        # while @arr[0..size-1] still held pointers,
                        # leaving the array with dangling slots.
                        my int $__rhs_borrowed = 0;
                        if ($__mir_scalarize_h == 0 && $__mir_scalarize_a == 0) {
                            $__rhs_borrowed = expr_is_borrowed($node->{"value"});
                        }
                        if ($__rhs_borrowed == 1) {
                            emit($cg, "if (__new_sv && !STRADA_IS_TAGGED_INT(__new_sv)) strada_incref(__new_sv); ");
                        }
                        emit($cg, "if (__builtin_expect(__old_sv && !STRADA_IS_TAGGED_INT(__old_sv) && __old_sv->meta && __old_sv->meta->is_tied, 0)) { ");
                        emit($cg, "strada_tied_scalar_store(__old_sv, __new_sv); if (__new_sv) strada_decref(__new_sv); ");
                        emit($cg, "} else { ");
                        emit($cg, $slot_var . " = __new_sv; ");
                        emit($cg, "if (__old_sv != " . $slot_var . ") strada_decref(__old_sv); ");
                        # Cache the stash-mirror glob: perla_glob_get_or_create
                        # (perla_stash_get_or_create(pkg), name) returns the SAME
                        # glob every time, so re-looking it up on every write was
                        # two hash lookups per assignment — pathological for a
                        # file-scope var written in a tight loop (`$c=$i` over
                        # 200M iters: 22.5s -> fast). The block-static is looked
                        # up once and reused.
                        emit($cg, "{ static PerlGlob *__ogc = (PerlGlob*)0; if (__builtin_expect(!__ogc, 0)) __ogc = perla_glob_get_or_create(perla_stash_get_or_create(\"" . $cg->{"pkg"} . "\"), \"" . $exp_mname . "\"); ");
                        emit($cg, "perla_glob_store(__ogc, PERLA_SLOT_SCALAR, " . $slot_var . "); } ");
                        emit($cg, "} ");
                        # If a closure has already captured this var, also
                        # write the new value through to the capture cell
                        # so the closure body sees the up-to-date value.
                        # Required for self-reference patterns:
                        #   my $f; $f = sub { ... $f->(...) };
                        # The closure was created BEFORE the assignment, so
                        # its cell still holds the pre-assignment v_f (= undef).
                        # Skip when the cell already holds the same pointer
                        # (assignment originated inside the closure body —
                        # *captures[N] already updated). Incref-first to
                        # avoid use-after-free when refcounts overlap.
                        if (defined($cg->{"closure_cell_mirror"})
                            && defined($cg->{"closure_cell_mirror"}->{$exp_mname})) {
                            my int $__cci = $cg->{"closure_cell_mirror"}->{$exp_mname};
                            emit($cg, "if (__perla_cell[" . $__cci . "] && *__perla_cell[" . $__cci . "] != " . $slot_var . ") { ");
                            emit($cg, "StradaValue *__cell_old = *__perla_cell[" . $__cci . "]; ");
                            emit($cg, "*__perla_cell[" . $__cci . "] = " . $slot_var . "; ");
                            emit($cg, "if (" . $slot_var . ") strada_incref(" . $slot_var . "); ");
                            emit($cg, "if (__cell_old) strada_decref(__cell_old); } ");
                        }
                        emit($cg, $slot_var . "; })");
                        return;
                    }
                    # Non-mirror path: simple `(v_X = expr)`. If the RHS
                    # creates a closure that captures this var, mirror the
                    # new value into the closure cell after the assignment
                    # so self-reference patterns inside subs work too. We
                    # don't know which cells will be touched until after
                    # the RHS is gen'd, so wrap in a statement expression
                    # and check the closure_cell_mirror table afterwards.
                    if ($attype == Perla::AST::N_SCALAR_VAR()
                        && defined($atarget->{"name"})) {
                        my str $__assn_name = $atarget->{"name"};
                        # \$. = N — input line number. Read path emits
                        # STRADA_MAKE_TAGGED_INT((int64_t)perla_dollar_dot)
                        # which isn't a C lvalue, so write goes directly
                        # to the int storage. Needed by IO::Handle's
                        # `\$. = \$_[1] if @_ > 1` in input_line_number.
                        if ($__assn_name eq ".") {
                            emit($cg, "({ int64_t __nv = strada_to_int(");
                            gen_expr($cg, $node->{"value"});
                            emit($cg, "); perla_dollar_dot = (int)__nv; STRADA_MAKE_TAGGED_INT(__nv); })");
                            return;
                        }
                        # `$@ = …` — the N_SCALAR_VAR{name="@"} read path
                        # emits a lazy-init statement expression that is not
                        # a C lvalue, so the default `gen_expr($atarget) = …`
                        # below would emit `({ … perla_eval_error; }) = …`
                        # and gcc'd refuse to compile. Route writes directly
                        # to the global, releasing the old value first.
                        # Surfaced by DBI.pm's `$@ ||= "…"` (which expands
                        # through the same plain-assign path after the ||=
                        # special-case above).
                        if ($__assn_name eq "@") {
                            emit($cg, "({ StradaValue *__ae_new = ");
                            gen_expr($cg, $node->{"value"});
                            emit($cg, "; if (perla_eval_error) strada_decref(perla_eval_error); perla_eval_error = __ae_new; __ae_new; })");
                            return;
                        }
                        # Scalar-context of array/hash var produces a count,
                        # not the underlying container. Without this special
                        # case `my \$s = %h` would copy the hash StradaValue
                        # itself, and \$s printed as empty/stringified-hash
                        # instead of the entry count.
                        my int $__rhs_t = $node->{"value"}->{"type"};
                        if ($__rhs_t == Perla::AST::N_HASH_VAR()
                            && defined($node->{"value"}->{"name"})
                            && index($node->{"value"}->{"name"}, "::") < 0) {
                            my str $__rhs_cv = c_var_h($node->{"value"}->{"name"});
                            emit($cg, "({ ");
                            gen_expr($cg, $atarget);
                            emit($cg, " = ({ StradaHash *__sh = strada_deref_hash(" . $__rhs_cv . "); STRADA_MAKE_TAGGED_INT((int64_t)(__sh ? __sh->num_entries : 0)); }); ");
                            gen_expr($cg, $atarget);
                            emit($cg, "; })");
                            return;
                        }
                        if ($__rhs_t == Perla::AST::N_ARRAY_VAR()
                            && defined($node->{"value"}->{"name"})
                            && index($node->{"value"}->{"name"}, "::") < 0
                            && $node->{"value"}->{"name"} ne "_") {
                            my str $__rhs_cv = c_var_a($node->{"value"}->{"name"});
                            emit($cg, "({ ");
                            gen_expr($cg, $atarget);
                            emit($cg, " = STRADA_MAKE_TAGGED_INT((int64_t)strada_array_length(strada_deref_array(" . $__rhs_cv . "))); ");
                            gen_expr($cg, $atarget);
                            emit($cg, "; })");
                            return;
                        }
                        # Tied-scalar dispatch for plain `\$x = …` (my-scoped,
                        # not stash-mirrored). If v_x is a tied SV, replacing
                        # the slot pointer would drop the tied state and lose
                        # the STORE. Capture new value, then if old is tied,
                        # dispatch strada_tied_scalar_store and keep the tied
                        # SV in the slot. Predict-not-taken — non-tied vars
                        # pay just one meta-pointer load.
                        # Scalar re-assignment refcount discipline:
                        # `$x = EXPR` for a my-scoped scalar. The sub's
                        # cleanup at exit does `strada_decref(v_x)` —
                        # treating v_x as owned. So after this assign:
                        # v_x must own a reference to __asn_new, and the
                        # old reference (if any) must be released. The
                        # bare `v_x = __asn_new` emit dropped the old
                        # reference (leak) and didn't incref the new
                        # reference for borrowed RHS — when the borrowed
                        # source was later decref'd, v_x dangled and the
                        # cleanup-time decref freed memory that storage
                        # elsewhere still pointed at.
                        #
                        # Concrete victim: `$cur = $next` inside a list
                        # constructor — $cur stored in a hash via
                        # `$cur->{next} = $next` but only the bare ptr
                        # assign-through happened. Sub-exit decref'd $cur
                        # to 0 and the hash's stored pointer dangled,
                        # surfacing as `$list->{next}->{value}` returning
                        # undef one frame later.
                        my int $__asn_rhs_borrowed = expr_is_borrowed($node->{"value"});
                        emit($cg, "({ int __sav_wl_asn = __perla_want_list; __perla_want_list = 0; ");
                        emit($cg, "StradaValue *__asn_new = ");
                        gen_expr($cg, $node->{"value"});
                        emit($cg, "; __perla_want_list = __sav_wl_asn; ");
                        emit($cg, "StradaValue *__asn_old = ");
                        gen_expr($cg, $atarget);
                        emit($cg, "; if (__builtin_expect(__asn_old && !STRADA_IS_TAGGED_INT(__asn_old) && __asn_old->meta && __asn_old->meta->is_tied, 0)) { ");
                        emit($cg, "  strada_tied_scalar_store(__asn_old, __asn_new); if (__asn_new) strada_decref(__asn_new); ");
                        emit($cg, "} else { ");
                        if ($__asn_rhs_borrowed == 1) {
                            # Borrowed RHS — take our own reference before
                            # storing. Owned RHS (call result, fresh literal)
                            # already came with rc=1 from gen_expr, so no
                            # extra incref needed.
                            emit($cg, "  if (__asn_new) strada_incref(__asn_new); ");
                        }
                        gen_expr($cg, $atarget);
                        emit($cg, " = __asn_new; ");
                        # Release the previous v_x value. Safe even when
                        # __asn_old == __asn_new: the conditional incref
                        # above bumped rc to N+1, and this decref brings
                        # it back to N. Without this decref a chain of
                        # `$x = $y; $x = ...` leaked each old reference.
                        emit($cg, "if (__asn_old && __asn_old != __asn_new) strada_decref(__asn_old); ");
                        # Pad mode: sync an our/package scalar's new value into its
                        # shared stash slot, mirroring the statement-context path
                        # (~line 8920). This expression-context path otherwise omits
                        # the write-back, so eval-body / REPL-line `our $x` writes
                        # never reach the registry. Keyed on the declared package
                        # ($cg->{"pkg"}), correct here during statement processing
                        # (eval bodies run in `package main`).
                        if ($cg->{"pad_mode"} == 1
                            && defined($atarget) && $atarget->{"type"} == Perla::AST::N_SCALAR_VAR()
                            && defined($atarget->{"name"})
                            && defined($cg->{"our_vars"})
                            && defined($cg->{"our_vars"}->{$atarget->{"name"}})) {
                            emit($cg, "{ PerlGlob *__pad_og = perla_glob_get_or_create(perla_stash_get_or_create(\"" . $cg->{"pkg"} . "\"), \"" . $atarget->{"name"} . "\"); perla_glob_store(__pad_og, PERLA_SLOT_SCALAR, ");
                            gen_expr($cg, $atarget);
                            emit($cg, "); } ");
                        }
                        emit($cg, "} ");
                        if (defined($cg->{"closure_cell_mirror"})
                            && defined($cg->{"closure_cell_mirror"}->{$__assn_name})) {
                            my int $__assn_mci = $cg->{"closure_cell_mirror"}->{$__assn_name};
                            # Skip the mirror when the assignment target IS
                            # the cell itself (i.e., the LHS resolves to
                            # `*__captures[N]` inside a closure body). The
                            # macro-driven assignment already wrote through
                            # the cell, and decrefing then re-incref'ing the
                            # same pointer can free-and-reread the value if
                            # the old refcount was 1. Mirror only when the
                            # cell is genuinely separate storage from the
                            # LHS slot — incref-first/decref-old to avoid
                            # use-after-free when values coincide.
                            emit($cg, "if (__perla_cell[" . $__assn_mci . "] && *__perla_cell[" . $__assn_mci . "] != ");
                            gen_expr($cg, $atarget);
                            emit($cg, ") { ");
                            emit($cg, "StradaValue *__cell_old = *__perla_cell[" . $__assn_mci . "]; ");
                            emit($cg, "*__perla_cell[" . $__assn_mci . "] = ");
                            gen_expr($cg, $atarget);
                            emit($cg, "; if (");
                            gen_expr($cg, $atarget);
                            emit($cg, ") strada_incref(");
                            gen_expr($cg, $atarget);
                            emit($cg, "); if (__cell_old) strada_decref(__cell_old); } ");
                        }
                        gen_expr($cg, $atarget);
                        emit($cg, "; })");
                        return;
                    }
                    emit($cg, "(");
                    gen_expr($cg, $atarget);
                    emit($cg, " = ");
                    gen_expr($cg, $node->{"value"});
                    emit($cg, ")");
                    return;
                }
            }
        }
        Perla::CodeGen::Assign::_gen_assign($cg, $node);
        return;
    }

    if ($type == Perla::AST::N_CALL()) {
        Perla::CodeGen::Call::_gen_call($cg, $node);
        return;
    }
    if ($type == Perla::AST::N_METHOD()) {
        Perla::CodeGen::Method::_gen_method_call($cg, $node);
        return;
    }

    if ($type == Perla::AST::N_HASH_ELEM()) {
        # Check for $+{key} — named regex captures
        my scalar $hash_node = $node->{"hash"};
        if (defined($hash_node) && $hash_node->{"type"} == Perla::AST::N_SCALAR_VAR() && $hash_node->{"name"} eq "+") {
            my scalar $hkey = $node->{"key"};
            emit($cg, "({ StradaValue *__nc = strada_named_captures(); StradaValue *__v = strada_hv_fetch_owned(__nc, ");
            if (defined($hkey) && ($hkey->{"type"} == Perla::AST::N_STR_LIT() || ($hkey->{"type"} == Perla::AST::N_INTERP_STR() && has_perl_var($hkey->{"value"}) == 0))) {
                emit($cg, "\"" . Perla::CodeGen::Escape::str_node_to_c($hkey) . "\"");
            } else {
                emit($cg, "strada_to_str(");
                gen_expr($cg, $hkey);
                emit($cg, ")");
            }
            emit($cg, "); strada_decref(__nc); __v; })");
            return;
        }
        my scalar $hkey = $node->{"key"};
        # $foo{key} actually reads from %foo — when hash_node is a plain
        # SCALAR_VAR with a simple name, emit the hash-sigil C var directly.
        my scalar $hash_obj = $node->{"hash"};
        my int $use_hash_sigil = 0;
        if (defined($hash_obj) && $hash_obj->{"type"} == Perla::AST::N_SCALAR_VAR()
            && defined($hash_obj->{"name"}) && length($hash_obj->{"name"}) > 0
            && index($hash_obj->{"name"}, "::") < 0 && $hash_obj->{"name"} ne "_") {
            $use_hash_sigil = 1;
        }
        # Package-qualified `$Pkg::Name{key}` reads the HASH slot of the
        # stash glob (not perla_scalar_get, which reads SCALAR slot).
        # Without this, `$Pkg::H{k}` for a hash-typed `our %H` would fall
        # back to perla_scalar_get and the lookup would silently fail.
        my int $he_route_stash = 0;
        my str $he_pkg = "";
        my str $he_name = "";
        if (defined($hash_obj) && $hash_obj->{"type"} == Perla::AST::N_SCALAR_VAR()
            && defined($hash_obj->{"name"}) && index($hash_obj->{"name"}, "::") > 0) {
            $he_route_stash = 1;
            my str $hen = $hash_obj->{"name"};
            my int $heli = -1;
            my int $hesi = 0;
            while ($hesi < length($hen) - 1) {
                if (substr($hen, $hesi, 2) eq "::") { $heli = $hesi; }
                $hesi++;
            }
            $he_pkg = substr($hen, 0, $heli);
            $he_name = substr($hen, $heli + 2, length($hen) - $heli - 2);
        }
        # Autoviv-on-read: when the inner $hash_obj is itself a chained
        # hash/array access (e.g. $h{a}{b} or $h{a}->{b}), reading the
        # inner must create the intermediate hashref if missing — Perl
        # semantics: `my $v = $h{a}{b}` leaves $h{a}={} even though $v
        # is undef. Use _gen_autoviv_hash for that inner emit, which
        # walks the chain and stores back empty hashrefs at each level.
        my int $inner_is_chained = 0;
        if (defined($hash_obj)) {
            my int $hot = $hash_obj->{"type"};
            if ($hot == Perla::AST::N_HASH_ELEM() || $hot == Perla::AST::N_ARROW_HASH()) {
                $inner_is_chained = 1;
            }
        }
        if (defined($hkey) && ($hkey->{"type"} == Perla::AST::N_STR_LIT() || ($hkey->{"type"} == Perla::AST::N_INTERP_STR() && has_perl_var($hkey->{"value"}) == 0))) {
            emit($cg, "({ StradaValue *__h = ");
            if ($use_hash_sigil == 1) { emit($cg, c_var_h($hash_obj->{"name"})); }
            elsif ($he_route_stash == 1) { emit($cg, "perla_hash_get(\"" . $he_pkg . "\", \"" . $he_name . "\")"); }
            elsif ($inner_is_chained == 1) { _gen_autoviv_hash($cg, $hash_obj); }
            else { gen_expr($cg, $hash_obj); }
            emit($cg, "; StradaValue *__v = strada_hv_fetch_owned(__h, \"" . Perla::CodeGen::Escape::str_node_to_c($hkey) . "\"); __v; })");
        } else {
            emit($cg, "({ StradaValue *__h = ");
            if ($use_hash_sigil == 1) { emit($cg, c_var_h($hash_obj->{"name"})); }
            elsif ($he_route_stash == 1) { emit($cg, "perla_hash_get(\"" . $he_pkg . "\", \"" . $he_name . "\")"); }
            elsif ($inner_is_chained == 1) { _gen_autoviv_hash($cg, $hash_obj); }
            else { gen_expr($cg, $hash_obj); }
            emit($cg, "; char *__k = strada_to_str(");
            gen_expr($cg, $hkey);
            emit($cg, "); StradaValue *__v = strada_hv_fetch_owned(__h, __k); free(__k); __v; })");
        }
        return;
    }

    if ($type == Perla::AST::N_ARRAY_ELEM()) {
        # $_[N] means @_[N] in Perl — access element of @_
        my scalar $arr = $node->{"array"};
        my scalar $aidx = $node->{"index"};
        # Detect list-shaped index: range, qword, or anon-array-non-ref.
        # These should produce a SLICE, not a single element. Without
        # this, `(LIST)[0..5]` collapsed to a single strada_array_get
        # at index = strada_to_int(range_array) (whatever that comes
        # out as — usually 0), so DateTime::from_epoch's
        #   @args{qw(...)} = (gmtime($epoch))[0..5]
        # populated %args with one value (or junk) instead of the 6
        # gmtime fields, leading to year=-1+1900=1899.
        my int $is_slice = 0;
        if (defined($aidx)) {
            my int $ait = $aidx->{"type"};
            if ($ait == Perla::AST::N_RANGE() || $ait == Perla::AST::N_QWORD()) {
                $is_slice = 1;
            } elsif ($ait == Perla::AST::N_ANON_ARRAY()) {
                my int $isref = 0;
                if (defined($aidx->{"is_ref"})) { $isref = $aidx->{"is_ref"}; }
                if ($isref == 0) { $is_slice = 1; }
            }
        }
        if ($is_slice == 1) {
            emit($cg, "({ StradaArray *__ae_av = strada_deref_array(");
            if ($arr->{"type"} == Perla::AST::N_SCALAR_VAR() && $arr->{"name"} eq "_") {
                emit($cg, "perla_at_");
            } elsif ($arr->{"type"} == Perla::AST::N_SCALAR_VAR() && $arr->{"name"} eq "-") {
                # `$-[N]` / `@-[a..b]` — regex match start offsets
                emit($cg, "strada_match_starts()");
            } elsif ($arr->{"type"} == Perla::AST::N_SCALAR_VAR() && $arr->{"name"} eq "+") {
                # `$+[N]` / `@+[a..b]` — regex match end offsets
                emit($cg, "strada_match_ends()");
            } elsif ($arr->{"type"} == Perla::AST::N_SCALAR_VAR() && index($arr->{"name"}, "::") < 0) {
                emit($cg, c_var_a($arr->{"name"}));
            } elsif ($arr->{"type"} == Perla::AST::N_SCALAR_VAR() && index($arr->{"name"}, "::") > 0) {
                my str $__pa_full = $arr->{"name"};
                my int $__pai = 0;
                my int $__pa_last = -1;
                while ($__pai < length($__pa_full) - 1) {
                    if (substr($__pa_full, $__pai, 2) eq "::") { $__pa_last = $__pai; }
                    $__pai = $__pai + 1;
                }
                my str $__pa_pkg = substr($__pa_full, 0, $__pa_last);
                my str $__pa_name = substr($__pa_full, $__pa_last + 2, length($__pa_full) - $__pa_last - 2);
                emit($cg, "perla_array_get(\"" . $__pa_pkg . "\", \"" . $__pa_name . "\")");
            } else {
                gen_expr($cg, $arr);
            }
            emit($cg, "); int __ae_len = __ae_av ? (int)strada_array_length(__ae_av) : 0; ");
            emit($cg, "StradaArray *__ae_idxs = strada_deref_array(({ int __sav_wl_sl = __perla_want_list; __perla_want_list = 1; StradaValue *__slv = ");
            gen_expr($cg, $aidx);
            emit($cg, "; __perla_want_list = __sav_wl_sl; __slv; })); ");
            emit($cg, "StradaValue *__ae_out = strada_new_array(); StradaArray *__ae_oa = strada_deref_array(__ae_out); ");
            emit($cg, "if (__ae_idxs) for (int __aei = 0; __aei < (int)strada_array_length(__ae_idxs); __aei++) { ");
            emit($cg, "int __idx = (int)strada_to_int(strada_array_get(__ae_idxs, __aei)); ");
            emit($cg, "if (__idx < 0 && __ae_av) __idx += __ae_len; ");
            emit($cg, "StradaValue *__ev = strada_array_get(__ae_av, __idx); ");
            emit($cg, "if (__ev) strada_incref(__ev); strada_array_push(__ae_oa, __ev); } ");
            emit($cg, "__ae_out; })");
            return;
        }
        my str $av_expr = "";
        if ($arr->{"type"} == Perla::AST::N_SCALAR_VAR() && $arr->{"name"} eq "_") {
            $av_expr = "strada_deref_array(perla_at_)";
        } else {
            $av_expr = "__ae_av";
        }
        # Handle negative indices: -1 = last, -2 = second to last
        # Tied-array element fetch: when the source is a simple lexical
        # array var, capture the SV so we can route through
        # strada_av_fetch_sv (which checks meta->is_tied and dispatches
        # FETCH on the tied obj). Without this, perla's read of $a[N]
        # for a tied @a returned the underlying StradaArray's element
        # (always undef or stale) without invoking FETCH.
        if ($arr->{"type"} == Perla::AST::N_SCALAR_VAR() && index($arr->{"name"}, "::") < 0
            && $arr->{"name"} ne "_" && $arr->{"name"} ne "-" && $arr->{"name"} ne "+") {
            emit($cg, "({ StradaValue *__ae_sv = " . c_var_a($arr->{"name"}) . "; ");
            if (defined($aidx) && $aidx->{"type"} == Perla::AST::N_INT_LIT()) {
                emit($cg, "int __ae_idx = " . $aidx->{"value"});
            } else {
                emit($cg, "int __ae_idx = (int)strada_to_int(");
                gen_expr($cg, $aidx);
                emit($cg, ")");
            }
            emit($cg, "; strada_av_fetch_sv(__ae_sv, __ae_idx); })");
            return;
        }
        emit($cg, "({ StradaArray *__ae_av = strada_deref_array(");
        if ($arr->{"type"} == Perla::AST::N_SCALAR_VAR() && $arr->{"name"} eq "_") {
            emit($cg, "perla_at_");
        } elsif ($arr->{"type"} == Perla::AST::N_SCALAR_VAR() && $arr->{"name"} eq "-") {
            # `$-[N]` — regex match start offsets array
            emit($cg, "strada_match_starts()");
        } elsif ($arr->{"type"} == Perla::AST::N_SCALAR_VAR() && $arr->{"name"} eq "+") {
            # `$+[N]` — regex match end offsets array
            emit($cg, "strada_match_ends()");
        } elsif ($arr->{"type"} == Perla::AST::N_SCALAR_VAR() && index($arr->{"name"}, "::") < 0) {
            # $foo[N] really indexes @foo — use the array-sigil C name.
            emit($cg, c_var_a($arr->{"name"}));
        } elsif ($arr->{"type"} == Perla::AST::N_SCALAR_VAR() && index($arr->{"name"}, "::") > 0) {
            # $Pkg::arr[N] — pkg-qualified scalar var indexed as @Pkg::arr.
            # Route to perla_array_get(pkg, name) directly; without this,
            # _gen_expr emits perla_scalar_get which reads SLOT_SCALAR
            # (always empty) instead of SLOT_ARRAY.
            my str $__pa_full = $arr->{"name"};
            my int $__pai = 0;
            my int $__pa_last = -1;
            while ($__pai < length($__pa_full) - 1) {
                if (substr($__pa_full, $__pai, 2) eq "::") { $__pa_last = $__pai; }
