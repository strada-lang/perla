        # for blessed-ref targets: `use overload '+=' => sub {...}` (or
        # fallback to '+'). Without this, `$obj += 5` where $obj is a
        # blessed ref just did strada_to_int(ref) which gave 0 then
        # reassigned $obj to a tagged int, destroying the object.
        emit($cg, "({ StradaValue *__rv = ");
        gen_expr($cg, $node->{"value"});
        emit($cg, "; StradaValue *__tg = ");
        gen_expr($cg, $target);
        emit($cg, "; StradaValue *__ovr = NULL; ");
        emit($cg, "if (__tg && !STRADA_IS_TAGGED_INT(__tg) && __tg->type == STRADA_REF) { ");
        emit($cg, "  __ovr = perla_overload_binary(__tg, __rv, \"+=\"); ");
        emit($cg, "  if (!__ovr) __ovr = perla_overload_binary(__tg, __rv, \"+\"); } ");
        emit($cg, "if (__ovr) { ");
        gen_expr($cg, $target);
        emit($cg, " = __ovr; ");
        emit($cg, "} else { ");
        # Tied-scalar STORE dispatch: when the target is a tied SV (e.g.
        # `tie my $x, 'C'; $x += 5;`), perl dispatches STORE with the new
        # value rather than replacing the SV. Without this, += computed
        # the new value via to_num (which fires FETCH), then overwrote
        # the tied SV with a fresh number — STORE never fired and the
        # tied object's internal state stayed unchanged.
        emit($cg, "StradaValue *__cv_new = STRADA_IS_TAGGED_INT(__tg) && STRADA_IS_TAGGED_INT(__rv) ? ");
        emit($cg, "STRADA_MAKE_TAGGED_INT(STRADA_TAGGED_INT_VAL(__tg) + STRADA_TAGGED_INT_VAL(__rv)) : ");
        emit($cg, "strada_new_num(strada_to_num(__tg) + strada_to_num(__rv)); ");
        emit($cg, "if (__builtin_expect(__tg && !STRADA_IS_TAGGED_INT(__tg) && __tg->meta && __tg->meta->is_tied, 0)) { ");
        emit($cg, "  strada_tied_scalar_store(__tg, __cv_new); strada_decref(__cv_new); ");
        emit($cg, "} else { ");
        gen_expr($cg, $target);
        emit($cg, " = __cv_new; ");
        # Release the OLD target value we just overwrote. The variable owned
        # exactly one ref (`__tg` captured it without an incref); reassigning
        # orphans it. Tagged ints decref to a no-op, but a heap NUM/UV/int —
        # e.g. the result of a previous `$s += 0.5` — leaked every iteration
        # otherwise. Skip for `our` (the global mirror holds a parallel ref
        # synced below) to avoid double-free.
        if ($is_our == 0) { emit($cg, "if (__tg) strada_decref(__tg); "); }
        emit($cg, "} } ");
        if ($is_our == 1) {
            _emit_our_sync($cg, $target);
            emit($cg, "; ");
        }
        # Release the RHS if it was an owned temp (fresh literal / call /
        # arithmetic result). Borrowed operands (variables, deref views) are
        # left alone. perla_overload_binary and strada_to_num both only read
        # __rv, never consume it, so this is safe on every branch above.
        if (expr_is_borrowed($node->{"value"}) == 0) {
            emit($cg, "if (__rv) strada_decref(__rv); ");
        }
        gen_expr($cg, $target);
        emit($cg, "; })");
        return;
    }
    if ($op eq "-=") {
        if ($target_type == Perla::AST::N_HASH_ELEM() || $target_type == Perla::AST::N_ARROW_HASH()) {
            _gen_hash_compound_assign($cg, $target, "-", $node->{"value"});
            return;
        }
        if ($target_type == Perla::AST::N_DEREF_SCALAR()) {
            _gen_deref_scalar_compound_assign($cg, $target, "-", $node->{"value"});
            return;
        }
        if ($target_type == Perla::AST::N_ARRAY_ELEM() || $target_type == Perla::AST::N_ARROW_ARRAY()) {
            _gen_array_compound_assign($cg, $target, "-", $node->{"value"});
            return;
        }
        if (_is_pkg_qualified_scalar($target) == 1) {
            _emit_pkg_scalar_compound($cg, $target, "-", $node->{"value"});
            return;
        }
        my int $sub_is_our = _is_our_unqual_scalar($cg, $target);
        # Overload dispatch for blessed-ref targets — same shape as += above.
        emit($cg, "({ StradaValue *__rv = ");
        gen_expr($cg, $node->{"value"});
        emit($cg, "; StradaValue *__tg = ");
        gen_expr($cg, $target);
        emit($cg, "; StradaValue *__ovr = NULL; ");
        emit($cg, "if (__tg && !STRADA_IS_TAGGED_INT(__tg) && __tg->type == STRADA_REF) { ");
        emit($cg, "  __ovr = perla_overload_binary(__tg, __rv, \"-=\"); ");
        emit($cg, "  if (!__ovr) __ovr = perla_overload_binary(__tg, __rv, \"-\"); } ");
        emit($cg, "if (__ovr) { ");
        gen_expr($cg, $target);
        emit($cg, " = __ovr; ");
        emit($cg, "} else { ");
        # Tied-scalar STORE dispatch (see += for rationale).
        emit($cg, "StradaValue *__cv_new = STRADA_IS_TAGGED_INT(__tg) && STRADA_IS_TAGGED_INT(__rv) ? ");
        emit($cg, "STRADA_MAKE_TAGGED_INT(STRADA_TAGGED_INT_VAL(__tg) - STRADA_TAGGED_INT_VAL(__rv)) : ");
        emit($cg, "strada_new_num(strada_to_num(__tg) - strada_to_num(__rv)); ");
        emit($cg, "if (__builtin_expect(__tg && !STRADA_IS_TAGGED_INT(__tg) && __tg->meta && __tg->meta->is_tied, 0)) { ");
        emit($cg, "  strada_tied_scalar_store(__tg, __cv_new); strada_decref(__cv_new); ");
        emit($cg, "} else { ");
        gen_expr($cg, $target);
        emit($cg, " = __cv_new; ");
        # Release the orphaned old value and the owned RHS temp (see += above).
        if ($sub_is_our == 0) { emit($cg, "if (__tg) strada_decref(__tg); "); }
        emit($cg, "} } ");
        if ($sub_is_our == 1) {
            _emit_our_sync($cg, $target);
            emit($cg, "; ");
        }
        if (expr_is_borrowed($node->{"value"}) == 0) { emit($cg, "if (__rv) strada_decref(__rv); "); }
        gen_expr($cg, $target);
        emit($cg, "; })");
        return;
