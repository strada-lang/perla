                gen_expr($cg, $akey);
            } else {
                emit($cg, "perla_dollar_underscore");
            }
            emit($cg, "); StradaValue *__v = strada_hv_fetch_owned(__o, __k); free(__k); ");
            if ($__ahx_obj_owned == 1) { emit($cg, "strada_decref(__o_orig); "); }
            emit($cg, "if (__hov) strada_decref(__hov); __v; })");
        }
