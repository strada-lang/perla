                emit($cg, "StradaValue *__slh_p = __avh_p ? strada_array_get(__avh_p, __aih_p) : NULL; ");
                emit($cg, "if (!__slh_p || STRADA_IS_TAGGED_INT(__slh_p) || __slh_p->type != STRADA_REF || !__slh_p->value.rv || __slh_p->value.rv->type != STRADA_HASH) { ");
                emit($cg, "  StradaValue *__nrh = strada_new_ref_take(strada_new_hash(), '%'); ");
