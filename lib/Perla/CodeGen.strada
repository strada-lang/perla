                # this we fell through to gen_expr which emits
                # perla_scalar_get (SCALAR slot) and the write silently
                # missed the package's actual %H.
                my str $hwn = $inner_obj->{"name"};
                my int $hwli = -1;
                my int $hwsi = 0;
                while ($hwsi < length($hwn) - 1) {
                    if (substr($hwn, $hwsi, 2) eq "::") { $hwli = $hwsi; }
                    $hwsi = $hwsi + 1;
                }
                my str $hw_pkg = substr($hwn, 0, $hwli);
                my str $hw_name = substr($hwn, $hwli + 2, length($hwn) - $hwli - 2);
