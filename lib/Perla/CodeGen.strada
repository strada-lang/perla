            # anon-array codegen otherwise consults the surrounding
            # __perla_want_list (which is 0 inside `my \$x = ...`) and
            # collapses to the last element, so `(1, 2, 3, 4, 5)[2]`
            # returned undef (and broke
            # `my \$mid = (sort ...)[int(@arr/2)]` median-pattern code).
            # Force list context for the inner list.
            emit($cg, "({ StradaArray *__ae_av = strada_deref_array(({ int __sav_wl_sl = __perla_want_list; __perla_want_list = 1; StradaValue *__sl_av = ");
            gen_expr($cg, $obj);
            emit($cg, "; __perla_want_list = __sav_wl_sl; __sl_av; })); ");
        } else {
            # `$ref->[N]` — explicit arrow deref + element access. Apply
            # @{} overload before strada_deref_array so blessed refs that
            # overload @{} (Hash-Of-Array proxies, ARef wrappers, etc.)
            # resolve via the user's overload method, not the raw ref.
            # Without this, `$obj->[0]` on an @{}-overloaded object
            # silently returned undef. Track obj-ownership so we can
            # decref the source SV (mirrors the ARROW_HASH leak fix:
            # N_ARRAY_ELEM/CALL/etc. yield owned temps which would
            # otherwise leak one ref per `$arr[N]->[i]` access).
            my int $__aa_obj_owned = 0;
            if (defined($obj)) {
                my int $__aa_aot = $obj->{"type"};
                if ($__aa_aot == Perla::AST::N_ARRAY_ELEM()
                    || $__aa_aot == Perla::AST::N_HASH_ELEM()
                    || $__aa_aot == Perla::AST::N_ARROW_HASH()
                    || $__aa_aot == Perla::AST::N_ARROW_ARRAY()
                    || $__aa_aot == Perla::AST::N_CALL()
                    || $__aa_aot == Perla::AST::N_METHOD()) {
                    $__aa_obj_owned = 1;
                }
            }
            emit($cg, "({ StradaValue *__ae_obj = ");
            gen_expr($cg, $obj);
            emit($cg, "; StradaValue *__ae_ov = (__ae_obj && !STRADA_IS_TAGGED_INT(__ae_obj) && __ae_obj->type == STRADA_REF) ? perla_overload_deref(__ae_obj, \"\@{}\") : NULL; ");
            emit($cg, "StradaArray *__ae_av = strada_deref_array(__ae_ov ? __ae_ov : __ae_obj); ");
            # Stash flag for the trailing emit (after the fetch) below.
            $cg->{"__aa_obj_owned_pending"} = $__aa_obj_owned;
        }
