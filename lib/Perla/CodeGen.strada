        my str $__fallback_emit = "";
        if ($route_simple_fallback == 1) {
            $__fallback_emit = "; if (!__o || (!STRADA_IS_TAGGED_INT(__o) && __o->type == STRADA_HASH && __o->value.hv && __o->value.hv->num_entries == 0 && !(__o->meta && __o->meta->is_tied))) { StradaValue *__o_sh = perla_hash_get(\"" . $__sf_name . "\", \"" . $__sf_name . "\"); if (__o_sh) __o = __o_sh; }";
        }
        # Symbolic-ref fallback for `\${\$name}{key}` and `\$\$name{key}`:
        # when the object is N_DEREF_SCALAR (`\${EXPR}` or `\$\$var`),
        # bypass the SCALAR-slot path (perla_scalar_via_qname returns the
        # scalar slot, not the hash we want) and look up the HASH by name
        # directly. Common idiom under `no strict 'refs'`.
        my int $__hsr_is_symref = 0;
        if (defined($aobj2) && $aobj2->{"type"} == Perla::AST::N_DEREF_SCALAR()
            && defined($aobj2->{"ref"})) {
            $__hsr_is_symref = 1;
        }
        # Track whether the object expression returns an OWNED (incref'd)
        # temp so we can decref __o after the fetch. N_ARRAY_ELEM and
        # friends incref the fetched element (their codegen ends with
        # `strada_incref(__ae_v); __ae_v;`) — without a balancing decref
        # here, the underlying object leaks one ref per `$arr[N]->{key}`
        # access. That kept blessed invocants alive past their `my` scope
        # and silently suppressed DESTROY. expr_is_borrowed mis-labels
        # N_ARRAY_ELEM as borrowed (the label predates the
        # safety-incref); we use the AST type directly to track ownership.
        # Inner-object ownership for the outer `$X->{...}` decref dance.
        #
        # N_ARRAY_ELEM and N_ARROW_ARRAY emit a safety-incref before
        # returning (see aa4d4a29 / bc3e22e7 — fixed an OOP invocant
        # leak), so the outer access must balance that with a decref.
        # N_CALL / N_METHOD also return owned values.
        #
        # N_HASH_ELEM / N_ARROW_HASH are routed through _gen_autoviv_hash
        # which emits `strada_hv_autoviv(...)`. That returns a BORROWED
        # pointer to a hash stored in the outer container — decref'ing
        # it pulls a refcount out from under the storage and after a
        # handful of accesses the hash gets freed mid-program. Surfaced
        # as `Service->run("greet"); Service->run("add")` returning
        # "unknown: add" because the second `$self->{actions}` lookup
        # found the actions hash already torn down by the first call's
        # over-decref.
        my int $__ahx_obj_owned = 0;
        if (defined($aobj2)) {
