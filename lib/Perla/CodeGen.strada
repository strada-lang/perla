        # The push helper records the mirror slot (perla_irs etc.) when
        # the local targets a special I/O var, so restore_to fixes the
        # mirror globally too.
        emit($cg, "if (__perla_local_chain != __db_local_mark) { perla_local_chain_restore_to(__perla_local_chain, __db_local_mark); __perla_local_chain = __db_local_mark; } ");
        # Synthetic N_PACKAGE restores (if any).
        if ($n < $total) {
            my int $ti = $n;
            while ($ti < $total) {
                gen_stmt($cg, $stmts->[$ti]);
                $ti++;
            }
        }
        # Restore shadowed file-scope vars. The inner `my $x = "inner"`
        # assigned to v_x's static slot; before yielding __db_rv we
        # must point the slot back at the outer pointer that was saved
        # at block entry. The inner ref's lifetime now transfers to
        # __db_rv (which the caller will own/decref). Incref __db_rv
        # before re-pointing the slot so the static-slot decref pattern
        # downstream stays consistent — without the incref, the only
        # owned reference would dangle once the body's auto-cleanup
        # decremented the slot count.
        my int $__db_si3 = 0;
        while ($__db_si3 < scalar(@__db_shadowed)) {
            my str $__db_sc3 = $__db_shadowed[$__db_si3];
            emit($cg, $__db_sc3 . " = __db_sav_" . $__db_sc3 . "; ");
            $__db_si3 = $__db_si3 + 1;
        }
        # Restore declared_vars / shared_cells_emitted / my_lexicals.
        $cg->{"declared_vars"} = $__db_saved_dv;
        $cg->{"same_scope_decls"} = $__db_saved_ssd;
        $cg->{"shared_cells_emitted"} = $__db_saved_sc;
        $cg->{"my_lexicals"} = $__db_saved_ml;
        # Restore lexical pragmas (use integer/utf8/bytes) at do-block exit.
        $cg->{"use_integer"} = $db_save_use_integer;
        $cg->{"use_utf8"} = $db_save_use_utf8;
        $cg->{"use_bytes"} = $db_save_use_bytes;
        emit($cg, "__db_rv; })");
        return;
    }

    if ($type == Perla::AST::N_GLOB_ACCESS()) {
        my scalar $gexpr = $node->{"expr"};
        if (defined($gexpr)) {
            # Dynamic: *{EXPR} / &{EXPR} — EXPR may already be a code ref
            # (CLOSURE / CPOINTER) when the caller did `&{\$sub}(args)`.
            # Try that first; if EXPR resolves to a string, fall through to
            # the stash lookup so `&{"main::foo"}()` still works.
            emit($cg, "({ StradaValue *__ge = ");
            gen_expr_safe($cg, $gexpr);
            emit($cg, "; StradaValue *__gv = NULL; ");
            emit($cg, "if (__ge && !STRADA_IS_TAGGED_INT(__ge) && (__ge->type == STRADA_CLOSURE || __ge->type == STRADA_CPOINTER)) { __gv = __ge; } ");
            emit($cg, "else { char *__gn = strada_to_str(__ge); char *__ls = NULL; for (char *__p = __gn; *__p; __p++) if (__p[0]==':'&&__p[1]==':') __ls=__p; ");
            emit($cg, "char *__gpkg = \"" . $cg->{"pkg"} . "\"; char *__gshort = __gn; char *__gpb = NULL; ");
            emit($cg, "if (__ls) { __gpb = strndup(__gn, __ls-__gn); __gpkg = __gpb; __gshort = __ls+2; } ");
            emit($cg, "PerlGlob *__g = perla_glob_get(perla_stash_get_or_create(__gpkg), __gshort); ");
            emit($cg, "__gv = strada_new_undef(); ");
            emit($cg, "if (__g && __g->slots[PERLA_SLOT_CODE]) { ");
            emit($cg, "  StradaValue *__csv = __g->slots[PERLA_SLOT_CODE]; ");
            emit($cg, "  if (__csv && !STRADA_IS_TAGGED_INT(__csv) && (__csv->type == STRADA_CLOSURE || __csv->type == STRADA_CPOINTER || __csv->type == STRADA_REF)) { __gv = __csv; } ");
            emit($cg, "  else if (__csv && !STRADA_IS_TAGGED_INT(__csv) && __csv->type == STRADA_STR) { ");
            emit($cg, "    char *__fn = strada_to_str(__csv); void *__fp = dlsym(RTLD_DEFAULT, __fn); ");
            emit($cg, "    if (__fp) __gv = strada_cpointer_new(__fp); free(__fn); } } ");
            emit($cg, "if (__gpb) free(__gpb); free(__gn); } __gv; })");
        } else {
            # Static: *Foo::bar
            my str $gname = $node->{"name"};
            my int $sep = -1;
            my int $gi = length($gname) - 1;
            while ($gi >= 0) {
                if ($gi > 0 && substr($gname, $gi - 1, 2) eq "::") { $sep = $gi - 1; last; }
                $gi--;
            }
            my str $gpkg = $cg->{"pkg"};
            my str $gshort = $gname;
            if ($sep >= 0) {
                $gpkg = substr($gname, 0, $sep);
                $gshort = substr($gname, $sep + 2, length($gname) - $sep - 2);
            }
            # Typeglob slot accessor: *NAME{CODE/SCALAR/ARRAY/HASH/IO}.
            # Returns a ref to the named slot's value (or undef if empty).
            my str $__sslot = "";
            if (defined($node->{"slot"})) { $__sslot = "" . $node->{"slot"}; }
            if ($__sslot eq "CODE") {
                # *NAME{CODE} → ref to the sub. perla stores subs as
                # CPOINTER (native) or STRADA_STR (C-symbol-name). Return
                # the CODE slot directly; ref() reports "CODE".
                emit($cg, "({ PerlGlob *__g = perla_glob_get(perla_stash_get_or_create(\"" . $gpkg . "\"), \"" . $gshort . "\"); ");
                emit($cg, "StradaValue *__cs = (__g && __g->slots[PERLA_SLOT_CODE]) ? __g->slots[PERLA_SLOT_CODE] : NULL; ");
                emit($cg, "if (__cs && !STRADA_IS_TAGGED_INT(__cs) && __cs->type == STRADA_STR && __cs->value.pv) { ");
                emit($cg, "  void *__fp = dlsym(RTLD_DEFAULT, __cs->value.pv); ");
                emit($cg, "  if (__fp) __cs = strada_cpointer_new(__fp); ");
                emit($cg, "} ");
                emit($cg, "(__cs ? ({ strada_incref(__cs); __cs; }) : strada_new_undef()); })");
            } elsif ($__sslot eq "SCALAR") {
                emit($cg, "({ StradaValue *__sv = perla_scalar_get(\"" . $gpkg . "\", \"" . $gshort . "\"); ");
                emit($cg, "if (!__sv) __sv = strada_new_undef(); ");
                emit($cg, "strada_new_ref_take(__sv, '\$'); })");
            } elsif ($__sslot eq "ARRAY") {
                emit($cg, "({ StradaValue *__av = perla_array_get(\"" . $gpkg . "\", \"" . $gshort . "\"); ");
                emit($cg, "if (!__av) __av = strada_new_array(); else strada_incref(__av); ");
                emit($cg, "strada_new_ref_take(__av, '@'); })");
            } elsif ($__sslot eq "HASH") {
                emit($cg, "({ StradaValue *__hv = perla_hash_get(\"" . $gpkg . "\", \"" . $gshort . "\"); ");
                emit($cg, "if (!__hv) __hv = strada_new_hash(); else strada_incref(__hv); ");
                emit($cg, "strada_new_ref_take(__hv, '%'); })");
            } elsif ($__sslot eq "NAME") {
                emit($cg, "strada_new_str(\"" . $gshort . "\")");
            } elsif ($__sslot eq "PACKAGE") {
                emit($cg, "strada_new_str(\"" . $gpkg . "\")");
            } else {
                # No slot (or unknown slot) → return CODE slot for back-compat.
                emit($cg, "({ PerlGlob *__g = perla_glob_get(perla_stash_get_or_create(\"" . $gpkg . "\"), \"" . $gshort . "\"); ");
