                && defined($inner_obj->{"name"}) && length($inner_obj->{"name"}) > 0
                && index($inner_obj->{"name"}, "::") < 0 && $inner_obj->{"name"} ne "_") {
                # `$ret->{key} = X` where $ret is a scalar — autovivify
                # the scalar to a hash REF when it's undef, so subsequent
                # `$ret->{other_key}` access also sees the same hash.
                # Real Perl does this transparently. perla used to emit
                # the bare scalar var, hand it to strada_hv_store which
                # called strada_deref_hash(undef) → NULL → silent no-op.
                # Surfaced via DBIC's `_resolve_relationship_condition`
                # `my $ret;` followed by `$ret->{condition} = ...` —
                # the autoviv never fired, $ret stayed undef, and the
                # JOIN clause emitted `ON ` (empty) instead of the
                # actual condition.
                my str $vc = c_var($inner_obj->{"name"});
                # Autoviv ONLY when the var is undef (or NULL ptr), to
                # match Perl's "autovivification triggered by undef
                # only" semantics. Don't clobber existing strings, ints,
                # or other refs — those would be runtime errors in
                # strict Perl, but the user might use them as symbolic
                # refs (`${"Pkg::Name"}->{key}`).
                emit($cg, "({ if (!" . $vc . " || STRADA_IS_TAGGED_INT(" . $vc . ") ? 0 : (" . $vc . "->type == STRADA_UNDEF)) { ");
                emit($cg, "  StradaValue *__nh = strada_new_ref_take(strada_new_hash(), '%'); ");
                emit($cg, "  if (" . $vc . ") strada_decref(" . $vc . "); ");
                emit($cg, "  " . $vc . " = __nh; ");
                emit($cg, "} else if (!" . $vc . ") { ");
                emit($cg, "  " . $vc . " = strada_new_ref_take(strada_new_hash(), '%'); ");
                emit($cg, "} " . $vc . "; })");
            } else {
                gen_expr($cg, $inner_obj);
            }
            emit($cg, ", __k, __hv_val); free(__k); ");
            if ($is_env_assign_ah == 1) {
                emit($cg, "{ char *__envk = strada_to_str(");
                gen_expr($cg, $tkey);
                emit($cg, "); char *__envv = strada_to_str(__hv_val); ");
                emit($cg, "if (__envk && __envv) setenv(__envk, __envv, 1); ");
                emit($cg, "if (__envk) free(__envk); if (__envv) free(__envv); } ");
            }
            if ($is_sig_assign_ah == 1) {
                emit($cg, "{ char *__sigk = strada_to_str(");
                gen_expr($cg, $tkey);
                emit($cg, "); if (__sigk) { perla_install_signal(__sigk, __hv_val); free(__sigk); } } ");
            }
            emit($cg, "__hv_val; })");
            return;
        }
        # Array-deref assignment: @{$ref} = LIST
        # Covers both the normal case (real array ref — replace contents) and
        # the symbolic-ref form `@{"Pkg::ISA"} = qw(Parent...)` used by
        # dynamic `import` subs (e.g. Drogo::Dispatch::import). The runtime
        # helper decides based on whether $ref is a string or a real ref.
        # `%{$ref} = (k => v, ...)` — hash deref LHS. Previously this
        # had no handler — the assignment silently evaluated the RHS
        # and dropped it. Now routes through perla_deref_hash_assign
        # which handles both real hashrefs and symbolic (package-
        # qualified) refs.
        if ($target_type == Perla::AST::N_DEREF_HASH()) {
            my int $__lh_strict = 0;
            if (defined($cg->{"strict_refs"}) && $cg->{"strict_refs"} == 1) {
                $__lh_strict = 1;
            }
            emit($cg, "({ StradaValue *__dh_ref = ");
            gen_expr($cg, $target->{"ref"});
            emit($cg, "; int __sav_wl_dh = __perla_want_list; __perla_want_list = 1; StradaValue *__dh_val = ");
            gen_expr($cg, $node->{"value"});
            emit($cg, "; __perla_want_list = __sav_wl_dh; ");
            if ($__lh_strict == 1) {
                emit($cg, "if (__dh_ref && !STRADA_IS_TAGGED_INT(__dh_ref) && __dh_ref->type == STRADA_STR && __dh_ref->value.pv) { char __sm[512]; snprintf(__sm, sizeof(__sm), \"Can't use string (\\\"%s\\\") as a HASH ref while \\\"strict refs\\\" in use\", __dh_ref->value.pv); strada_die(__sm); } ");
            }
            emit($cg, "perla_deref_hash_assign(__dh_ref, __dh_val); __dh_val; })");
            return;
        }
        if ($target_type == Perla::AST::N_DEREF_ARRAY()) {
            my int $__la_strict = 0;
            if (defined($cg->{"strict_refs"}) && $cg->{"strict_refs"} == 1) {
                $__la_strict = 1;
            }
            emit($cg, "({ StradaValue *__da_ref = ");
            # Autovivify the ref target: `@{ $h{k} } = LIST` (or `@{ $aref }`
            # when $aref/$h{k} is undef) must create the array ref AND store it
            # back into its container, then populate it. Plain gen_expr returned
            # the current (undef) value, so the assign had nothing to write into
            # and silently no-op'd. _gen_autoviv_array_value autovivs+stores-back
            # for scalar/hash-elem/array-elem lvalues and falls back to gen_expr
            # for any other ref expression.
            _gen_autoviv_array_value($cg, $target->{"ref"});
            # The RHS evaluates in LIST context (\@arr = LIST always is).
            # Without forcing want_list=1, list-returning expressions like
            # grep/map saw scalar context and collapsed to a count.
            emit($cg, "; int __sav_wl_da = __perla_want_list; __perla_want_list = 1; StradaValue *__da_val = ");
            gen_expr($cg, $node->{"value"});
            emit($cg, "; __perla_want_list = __sav_wl_da; ");
            if ($__la_strict == 1) {
                # strict 'refs': symbolic-ref assignment dies. perla_deref_
                # array_assign falls back to symbolic handling for strings,
                # which under strict refs is exactly the error case.
                emit($cg, "if (__da_ref && !STRADA_IS_TAGGED_INT(__da_ref) && __da_ref->type == STRADA_STR && __da_ref->value.pv) { char __sm[512]; snprintf(__sm, sizeof(__sm), \"Can't use string (\\\"%s\\\") as an ARRAY ref while \\\"strict refs\\\" in use\", __da_ref->value.pv); strada_die(__sm); } ");
            }
            emit($cg, "perla_deref_array_assign(__da_ref, __da_val); __da_val; })");
            return;
        }
        # Arrow array assignment: $ref->[idx] = val
        # When the inner object is itself an array/hash access (chained
        # form like \$a[0][1] = X or \$h{k}[0] = X), autovivify the inner
        # slot to an arrayref before the deref. Without this, the deref
        # of an undef slot returns NULL and the strada_array_set is a
        # no-op.
        if ($target_type == Perla::AST::N_ARROW_ARRAY()) {
            my scalar $aa_obj = $target->{"object"};
            my int $aa_obj_t = $aa_obj->{"type"};
            if ($aa_obj_t == Perla::AST::N_ARRAY_ELEM() || $aa_obj_t == Perla::AST::N_ARROW_ARRAY()) {
                # `\$arr[i][j] = X` or `\$ref->[i][j] = X` — inner is array elem.
                #
                # The OUTER array reference (`$g->{cells}` in `$g->{cells}[i][j]
                # = X`) may itself be undef when $g is fresh — autoviv it to
                # `[]` so `__av_p` is a real array. Without this, `strada_deref_
                # array(undef) = NULL` short-circuits the rest of the autoviv
                # chain and the assignment is silently dropped.
                emit($cg, "({ StradaArray *__av_p = strada_deref_array(");
                my scalar $aa_arr_node;
                if ($aa_obj_t == Perla::AST::N_ARRAY_ELEM()) {
                    $aa_arr_node = $aa_obj->{"array"};
                } else {
                    $aa_arr_node = $aa_obj->{"object"};
                }
                _gen_autoviv_array_value($cg, $aa_arr_node);
                emit($cg, "); int __ai_p = (int)strada_to_int(");
                gen_expr($cg, $aa_obj->{"index"});
                emit($cg, "); if (__ai_p < 0 && __av_p) __ai_p += strada_array_length(__av_p); ");
                emit($cg, "StradaValue *__sl_p = __av_p ? strada_array_get(__av_p, __ai_p) : NULL; ");
                emit($cg, "if (!__sl_p || STRADA_IS_TAGGED_INT(__sl_p) || __sl_p->type != STRADA_REF || !__sl_p->value.rv || __sl_p->value.rv->type != STRADA_ARRAY) { ");
                emit($cg, "  StradaValue *__nr = strada_new_ref_take(strada_new_array(), '@'); ");
                emit($cg, "  if (__av_p) strada_array_set(__av_p, __ai_p, __nr); ");
                emit($cg, "  __sl_p = __nr; ");
                emit($cg, "} StradaArray *__aa_av = strada_deref_array(__sl_p); ");
                emit($cg, "int __aa_idx = (int)strada_to_num(");
                gen_expr($cg, $target->{"index"});
                emit($cg, "); StradaValue *__aa_val = ");
                gen_expr($cg, $node->{"value"});
                emit($cg, "; strada_array_set(__aa_av, __aa_idx, __aa_val); __aa_val; })");
                return;
            }
            if ($aa_obj_t == Perla::AST::N_HASH_ELEM() || $aa_obj_t == Perla::AST::N_ARROW_HASH()) {
                # `\$h{k}[i] = X` — inner is hash elem; autoviv hash slot
                # to arrayref.
                #
                # The container chain UP TO the leaf key also needs autoviv:
                # `my $d; $d->{x}[0] = "alice"` would otherwise compile to
                # __hv_p = NULL → __hh_p = NULL → `if (__hh_p) strada_hash_set_take`
                # silently skipped → arrayref never linked back to $d.
                # Route the outer object through `_gen_autoviv_hash` when it's
                # itself a hash access (which autovivs each step to {}), and
                # emit a scalar-autoviv snippet when it's a plain scalar var.
                emit($cg, "({ StradaValue *__hv_p = ");
                my scalar $aa_outer = NULL;
                if ($aa_obj_t == Perla::AST::N_HASH_ELEM()) {
                    $aa_outer = $aa_obj->{"hash"};
                } else {
                    $aa_outer = $aa_obj->{"object"};
                }
                my int $aa_outer_t = $aa_outer->{"type"};
                if ($aa_outer_t == Perla::AST::N_HASH_ELEM()
                    || $aa_outer_t == Perla::AST::N_ARROW_HASH()) {
                    _gen_autoviv_hash($cg, $aa_outer);
                } elsif ($aa_outer_t == Perla::AST::N_SCALAR_VAR()
                    && defined($aa_outer->{"name"})
                    && length($aa_outer->{"name"}) > 0
                    && index($aa_outer->{"name"}, "::") < 0
                    && $aa_outer->{"name"} ne "_") {
                    my str $aa_outer_vc = c_var($aa_outer->{"name"});
                    emit($cg, "({ if (!" . $aa_outer_vc . " || (!STRADA_IS_TAGGED_INT(" . $aa_outer_vc . ") && " . $aa_outer_vc . "->type == STRADA_UNDEF)) { ");
                    emit($cg, "  if (" . $aa_outer_vc . ") strada_decref(" . $aa_outer_vc . "); ");
                    emit($cg, "  " . $aa_outer_vc . " = strada_new_ref_take(strada_new_hash(), '%'); ");
                    emit($cg, "} " . $aa_outer_vc . "; })");
                } else {
                    gen_expr($cg, $aa_outer);
                }
                emit($cg, "; char *__hk_p = strada_to_str(");
                gen_expr($cg, $aa_obj->{"key"});
                emit($cg, "); StradaHash *__hh_p = strada_deref_hash(__hv_p); ");
                emit($cg, "StradaValue *__sl_p = __hh_p ? strada_hash_get(__hh_p, __hk_p) : NULL; ");
                emit($cg, "if (!__sl_p || STRADA_IS_TAGGED_INT(__sl_p) || __sl_p->type != STRADA_REF || !__sl_p->value.rv || __sl_p->value.rv->type != STRADA_ARRAY) { ");
                emit($cg, "  StradaValue *__nr = strada_new_ref_take(strada_new_array(), '@'); ");
                emit($cg, "  if (__hh_p) strada_hash_set_take(__hh_p, __hk_p, __nr); ");
                emit($cg, "  __sl_p = __nr; ");
                emit($cg, "} StradaArray *__aa_av = strada_deref_array(__sl_p); ");
                emit($cg, "int __aa_idx = (int)strada_to_num(");
                gen_expr($cg, $target->{"index"});
                emit($cg, "); StradaValue *__aa_val = ");
                gen_expr($cg, $node->{"value"});
                emit($cg, "; strada_array_set(__aa_av, __aa_idx, __aa_val); free(__hk_p); __aa_val; })");
                return;
            }
            emit($cg, "({ StradaArray *__aa_av = strada_deref_array(");
            # Mirror the read path: bare $_[N] indexes @_ (not $_),
            # and bare $foo[N] indexes @foo (not $foo). Only when
            # is_explicit_arrow is set does N_ARROW_ARRAY mean deref.
            my int $aa_is_arrow = 0;
            if (defined($target->{"is_explicit_arrow"}) && $target->{"is_explicit_arrow"} == 1) { $aa_is_arrow = 1; }
            if ($aa_is_arrow == 0 && $aa_obj->{"type"} == Perla::AST::N_SCALAR_VAR() && $aa_obj->{"name"} eq "_") {
                emit($cg, "perla_at_");
            } elsif ($aa_is_arrow == 0 && $aa_obj->{"type"} == Perla::AST::N_SCALAR_VAR() && index("" . ($aa_obj->{"name"} // ""), "::") > 0) {
                # `$Pkg::arr[i] = X` — write to ARRAY slot of stash glob.
                # Without this, gen_expr emits perla_scalar_get (SCALAR slot)
                # and the write missed the package's actual @arr.
                my array @apn = _split_pkg_qual_name($aa_obj);
                emit($cg, "perla_array_get(\"" . $apn[0] . "\", \"" . $apn[1] . "\")");
            } elsif ($aa_is_arrow == 0 && $aa_obj->{"type"} == Perla::AST::N_SCALAR_VAR() && index("" . ($aa_obj->{"name"} // ""), "::") < 0) {
                emit($cg, c_var_a($aa_obj->{"name"}));
            } else {
                gen_expr($cg, $target->{"object"});
            }
            emit($cg, "); int __aa_idx = (int)strada_to_num(");
            gen_expr($cg, $target->{"index"});
            emit($cg, "); StradaValue *__aa_val = ");
            gen_expr($cg, $node->{"value"});
            # Tied-aware store: if the source is a lexical array var, also
            # dispatch STORE via strada_av_store_sv. We can't easily capture
            # the SV at this point (we already strada_deref_array'd), so
            # for tied dispatch we need to also re-emit with the SV. Use
            # an additional dispatch site that runs when the SV is tied.
            if ($aa_is_arrow == 0 && $aa_obj->{"type"} == Perla::AST::N_SCALAR_VAR()
                && $aa_obj->{"name"} ne "_"
                && index("" . ($aa_obj->{"name"} // ""), "::") < 0) {
                emit($cg, "; StradaValue *__aa_sv_t = " . c_var_a($aa_obj->{"name"}) . "; ");
                emit($cg, "if (__aa_sv_t && !STRADA_IS_TAGGED_INT(__aa_sv_t) && __aa_sv_t->meta && __aa_sv_t->meta->is_tied) { strada_tied_array_store(__aa_sv_t, __aa_idx, __aa_val); } else { strada_array_set(__aa_av, __aa_idx, __aa_val); } __aa_val; })");
            } else {
                emit($cg, "; strada_array_set(__aa_av, __aa_idx, __aa_val); __aa_val; })");
            }
            return;
        }
        # Direct array element assignment: $arr[idx] = val
        if ($target_type == Perla::AST::N_ARRAY_ELEM()) {
            emit($cg, "({ StradaArray *__ae_set_av = strada_deref_array(");
            gen_expr($cg, $target->{"array"});
            emit($cg, "); int __ae_set_idx = (int)strada_to_int(");
            gen_expr($cg, $target->{"index"});
            emit($cg, "); if (__ae_set_idx < 0 && __ae_set_av) __ae_set_idx += strada_array_length(__ae_set_av); StradaValue *__ae_set_val = ");
            gen_expr($cg, $node->{"value"});
            emit($cg, "; strada_array_set(__ae_set_av, __ae_set_idx, __ae_set_val); __ae_set_val; })");
            return;
        }
        # Package-qualified array assignment: `@Pkg::Name = LIST`. The
        # read path goes through perla_array_get (see N_ARRAY_VAR in
        # _gen_expr), so the default `target = value` form would write to
        # the return of a function call — not a valid lvalue. Route to
        # perla_isa_assign for the ISA idiom and to perla_glob_assign
        # otherwise so both sides see the same storage.
        if ($target_type == Perla::AST::N_ARRAY_VAR()
            && defined($target->{"name"}) && index($target->{"name"}, "::") > 0) {
            my str $tn = $target->{"name"};
            my int $tli = -1;
            my int $tsi = 0;
            while ($tsi < length($tn) - 1) {
                if (substr($tn, $tsi, 2) eq "::") { $tli = $tsi; }
                $tsi++;
            }
            my str $tpkg = substr($tn, 0, $tli);
            my str $tname = substr($tn, $tli + 2, length($tn) - $tli - 2);
            if ($tname eq "ISA") {
                emit($cg, "({ StradaValue *__isa_val = ");
                gen_expr($cg, $node->{"value"});
                emit($cg, "; perla_isa_assign(\"" . $tpkg . "::ISA\", __isa_val); __isa_val; })");
                return;
            }
            # `@Pkg::arr = LIST` — force list context around the RHS so
            # list literals expand to the full array rather than scalar-
            # context squashing to the last element. Without this,
            # `@main::arr = (10, 20, 30)` stored just 30 in the slot.
            emit($cg, "({ int __sav_wl_ga = __perla_want_list; __perla_want_list = 1; StradaValue *__ga_val = ");
            gen_expr($cg, $node->{"value"});
            emit($cg, "; __perla_want_list = __sav_wl_ga; PerlGlob *__ga_glob = perla_glob_get_or_create(perla_stash_get_or_create(\"" . $tpkg . "\"), \"" . $tname . "\"); ");
            emit($cg, "perla_glob_store(__ga_glob, PERLA_SLOT_ARRAY, __ga_val); __ga_val; })");
            return;
        }
        # Package-qualified scalar write — `$Pkg::NAME = RHS` — must go
        # through the stash setter since `perla_scalar_get(...)` emits a
        # function call (non-lvalue).
        if ($target_type == Perla::AST::N_SCALAR_VAR()
            && defined($target->{"name"}) && index($target->{"name"}, "::") > 0) {
            my str $tqn = $target->{"name"};
            my int $tli = -1;
            my int $tsi = 0;
            while ($tsi < length($tqn) - 1) {
                if (substr($tqn, $tsi, 2) eq "::") { $tli = $tsi; }
                $tsi++;
            }
            my str $tqpkg = substr($tqn, 0, $tli);
            my str $tqname = substr($tqn, $tli + 2, length($tqn) - $tli - 2);
            emit($cg, "({ StradaValue *__qa_val = ");
            gen_expr($cg, $node->{"value"});
            emit($cg, "; perla_scalar_set(\"" . $tqpkg . "\", \"" . $tqname . "\", __qa_val); __qa_val; })");
            return;
        }
        # Check if target is a valid lvalue
        if ($target_type == Perla::AST::N_SCALAR_VAR() || $target_type == Perla::AST::N_ARRAY_VAR() || $target_type == Perla::AST::N_HASH_VAR()) {
            # strict 'vars' on the write side for the @/% variants — same
            # rationale as the SCALAR_VAR check above. The N_SCALAR_VAR
            # branch already ran a check inside its own block; this catches
            # `@arr = (...)` and `%h = (...)` writes at file scope.
            my str $__sw_sigil = "\$";
            if ($target_type == Perla::AST::N_ARRAY_VAR()) { $__sw_sigil = "@"; }
            elsif ($target_type == Perla::AST::N_HASH_VAR()) { $__sw_sigil = "%"; }
            if ($target_type != Perla::AST::N_SCALAR_VAR()) {
                _strict_check_var($cg, $__sw_sigil, "" . $target->{"name"}, $target->{"line"} + 0);
            }
            # %hash = LIST needs to become a HASH, not an ARRAY. The default
            # `v_hash = <list-expr>` path lowers `()` to `strada_new_array()`
            # (and `(k, v, ...)` likewise), turning the variable into an
            # array slot — subsequent strada_hv_store on it silently
            # no-ops. Seen as `%SERVER_VARIABLES = ()` in Drogo::Server::Test
            # clobbering the hash at the start of new(), after which every
            # variable(key => val) call stored into a detached array and
            # reads returned undef.
            if ($target_type == Perla::AST::N_HASH_VAR()) {
                # Package-qualified %Pkg::Name = ... — read form is
                # perla_hash_get(...) which is not an lvalue. Route through
                # perla_hash_set so `%next::METHOD_CACHE = ();` (Class::C3
                # uses this to clear its cache) compiles. Without this,
                # gcc reports "lvalue required as left operand of
                # assignment" and the whole module fails to load.
                my str $thname = "" . $target->{"name"};
                my int $thsep = -1;
                my int $thi = 0;
                while ($thi < length($thname) - 1) {
                    if (substr($thname, $thi, 2) eq "::") { $thsep = $thi; }
                    $thi = $thi + 1;
                }
                if ($thsep >= 0) {
                    my str $thpkg = substr($thname, 0, $thsep);
                    my str $thshort = substr($thname, $thsep + 2, length($thname) - $thsep - 2);
                    # Force list context so kv-pair literal RHS expands fully.
                    emit($cg, "({ int __sav_wl_gh = __perla_want_list; __perla_want_list = 1; StradaValue *__hinit = ");
                    gen_expr($cg, $node->{"value"});
                    emit($cg, "; __perla_want_list = __sav_wl_gh; StradaValue *__hnew; ");
                    emit($cg, "if (__hinit && !STRADA_IS_TAGGED_INT(__hinit) && __hinit->type == STRADA_HASH) { __hnew = __hinit; strada_incref(__hnew); } ");
                    emit($cg, "else { __hnew = strada_new_hash(); StradaArray *__hsa = strada_deref_array(__hinit); ");
                    emit($cg, "if (__hsa) for (int __hi = 0; __hi + 1 < (int)strada_array_length(__hsa); __hi += 2) { ");
                    emit($cg, "char *__hk = strada_to_str(strada_array_get(__hsa, __hi)); ");
                    emit($cg, "strada_hv_store(__hnew, __hk, strada_array_get(__hsa, __hi + 1)); free(__hk); } } ");
                    emit($cg, "perla_hash_set(\"" . $thpkg . "\", \"" . $thshort . "\", __hnew); ");
                    emit($cg, "if (__hinit) strada_decref(__hinit); __hnew; })");
                    return;
                }
                # Same value mirroring as for scalars: when assigning to
                # `our %X`, also update the package stash so cross-package
                # reads (`%Pkg::X`) and runtime hash lookups via the stash
                # see the new value. Without this, `our (%Lang); %Lang =
                # qw(...)` populates the file-scope C global v_Lang but
                # leaves the stash slot pointing to the empty hash from
                # declaration time. Surfaced via Date::Manip::Lang::index
                # (`our (%Lang); %Lang = qw(en english ...);`) → `! exists
                # $Date::Manip::Lang::index::Lang{english}` always true →
                # "ERROR: [language] invalid: english".
                my str $h_mirror_name = "";
                my int $h_should_mirror = 0;
                if (defined($target->{"name"}) && index($target->{"name"}, "::") < 0
                    && length($target->{"name"}) > 0) {
                    $h_mirror_name = $target->{"name"};
                    if (defined($cg->{"our_vars"}) && exists($cg->{"our_vars"}->{$h_mirror_name})) {
                        $h_should_mirror = 1;
                    }
                }
                # Capture old hash for decref so `%h = ()` fires DESTROY
                # on blessed values (matches perl). Decref happens AFTER
                # new is bound to avoid stale-slot-during-DESTROY.
                # Tied-hash escape: if the old hash is tied, `%h = (...)`
                # must call CLEAR then STORE each pair through the tie,
                # NOT replace the SV (which would silently lose the tie).
                # perl's documented semantic: %tied_h = LIST → CLEAR +
                # STORE(k,v) per pair. Bypassing this left users unable to
                # reset / repopulate a tied hash and surprised tied class
                # hooks (no CLEAR fired, the tied object went dormant).
                # Pad mode + our-hash: refill the adopted shared container IN
                # PLACE (clear + re-store) rather than replacing it, so whole-
                # hash `%h=(...)` reassignment is visible across eval/REPL .so
                # loads (container identity preserved — the same property
                # in-place element mutation relies on). Tied-aware clear.
                if ($cg->{"pad_mode"} == 1 && $h_should_mirror == 1) {
                    emit($cg, "({ StradaValue *__h_tgt = ");
                    gen_expr($cg, $target);
                    emit($cg, "; int __sav_wl_hp = __perla_want_list; __perla_want_list = 1; StradaValue *__hl = ");
                    gen_expr($cg, $node->{"value"});
                    emit($cg, "; __perla_want_list = __sav_wl_hp; ");
                    emit($cg, "if (__h_tgt && !STRADA_IS_TAGGED_INT(__h_tgt) && __h_tgt->meta && __h_tgt->meta->is_tied) strada_tied_hash_clear(__h_tgt); else perla_hash_clear(__h_tgt); ");
                    emit($cg, "if (__hl && !STRADA_IS_TAGGED_INT(__hl) && __hl->type == STRADA_HASH) { StradaHash *__hlh = strada_deref_hash(__hl); StradaArray *__hlk = __hlh ? strada_hash_keys(__hlh) : NULL; if (__hlk) { for (size_t __hpi = 0; __hpi < __hlk->size; __hpi++) { StradaValue *__hpk = __hlk->elements[__hlk->head + __hpi]; char *__hpks = strada_to_str(__hpk); if (__hpks) { strada_hv_store(__h_tgt, __hpks, strada_hash_get(__hlh, __hpks)); free(__hpks); } } strada_free_array(__hlk); } } ");
                    emit($cg, "else { StradaArray *__ha = __hl ? strada_deref_array(__hl) : NULL; if (__ha) for (int __hi = 0; __hi + 1 < (int)strada_array_length(__ha); __hi += 2) { char *__hk = strada_to_str(strada_array_get(__ha, __hi)); strada_hv_store(__h_tgt, __hk, strada_array_get(__ha, __hi + 1)); free(__hk); } } ");
                    emit($cg, "if (__hl && !STRADA_IS_TAGGED_INT(__hl) && __hl->type != STRADA_HASH) strada_decref(__hl); ");
                    emit($cg, "__h_tgt; })");
