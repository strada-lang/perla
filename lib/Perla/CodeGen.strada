        my int $wi = 0;
        while ($wi < $argc) {
            emit($cg, "{ StradaValue *__we = ");
            gen_expr($cg, $args->[$wi]);
            emit($cg, "; if (__we && !STRADA_IS_TAGGED_INT(__we) && __we->type == STRADA_ARRAY) { ");
            emit($cg, "size_t __wn = __we->value.av->size; for (size_t __wj = 0; __wj < __wn; __wj++) { ");
            emit($cg, "StradaValue *__wel = strada_array_get(__we->value.av, __wj); ");
            emit($cg, "char *__ws = strada_to_str(__wel); size_t __wl = __ws ? strlen(__ws) : 0; ");
            emit($cg, "if (__wl > 0) { if (__wblen + __wl + 1 > __wbcap) { __wbcap = (__wblen + __wl + 1) * 2; __wbuf = realloc(__wbuf, __wbcap); } memcpy(__wbuf + __wblen, __ws, __wl); __wblen += __wl; __wnl = (__ws[__wl-1] == '\\n'); } ");
            emit($cg, "free(__ws); } ");
            emit($cg, "} else { char *__ws = strada_to_str(__we); size_t __wl = __ws ? strlen(__ws) : 0; ");
            emit($cg, "if (__wl > 0) { if (__wblen + __wl + 1 > __wbcap) { __wbcap = (__wblen + __wl + 1) * 2; __wbuf = realloc(__wbuf, __wbcap); } memcpy(__wbuf + __wblen, __ws, __wl); __wblen += __wl; __wnl = (__ws[__wl-1] == '\\n'); } ");
