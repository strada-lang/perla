            # like `_strip_trailing_sep($dirname)` which uses
            # `$_[0] =~ s|/$||`. Only direct N_SCALAR_VAR args are
            # written back; expressions / literals are not. Vars
            # are matched by AST position, not by aliasing — close
            # enough for the common case.
            my int $wb_ai = 0;
            while ($wb_ai < $argc) {
                my scalar $wb_arg = $args->[$wb_ai];
                if (defined($wb_arg) && $wb_arg->{"type"} == Perla::AST::N_SCALAR_VAR()
                    && defined($wb_arg->{"name"}) && length($wb_arg->{"name"}) > 0
                    && index($wb_arg->{"name"}, "::") < 0
                    && $wb_arg->{"name"} ne "_" && $wb_arg->{"name"} ne "@") {
                    # Skip read-only specials ($1-$9, $&, etc.)
                    my str $wb_name = $wb_arg->{"name"};
                    my int $wb_is_ro = 0;
                    if (length($wb_name) == 1) {
                        my int $wb_c0 = char_at($wb_name, 0);
                        if ($wb_c0 >= 49 && $wb_c0 <= 57) { $wb_is_ro = 1; }
                        if ($wb_name eq "&" || $wb_name eq "`" || $wb_name eq "'" || $wb_name eq "+") { $wb_is_ro = 1; }
                    }
                    if ($wb_is_ro == 0) {
                        my str $wb_cv = c_var($wb_name);
                        # Only write back if @_ wasn't shifted/popped (head
                        # unchanged, size still at least the index). A shift
                        # moves head forward, so __av[N] then reads a
                        # different element than the caller's original arg N
                        # — and the resulting writeback would mutate the
                        # caller's var to the curried/leftover element.
                        emit($cg, "if (__av && __av->head == __a_head_before && __av->size > " . $wb_ai . ") { ");
                        emit($cg, "StradaValue *__wb" . $wb_ai . " = strada_array_get(__av, " . $wb_ai . "); ");
                        emit($cg, "if (__wb" . $wb_ai . " != " . $wb_cv . ") { ");
                        emit($cg, "if (__wb" . $wb_ai . ") strada_incref(__wb" . $wb_ai . "); ");
                        emit($cg, "strada_decref(" . $wb_cv . "); " . $wb_cv . " = __wb" . $wb_ai . "; } } ");
                    }
                }
                # `inc($arr[0])` / `inc($h{k})` — @_[N] aliases the array
                # element / hash entry. Write back via strada_array_set
                # / strada_hash_set if @_ wasn't shifted. Both `$arr[i]`
                # (no-arrow) and `$ref->[i]` parse to N_ARROW_ARRAY in
                # perla — same node, the `is_explicit_arrow` flag
                # distinguishes. For writeback both forms work the same.
                elsif (defined($wb_arg) && $wb_arg->{"type"} == Perla::AST::N_ARROW_ARRAY()) {
                    emit($cg, "if (__av && __av->head == __a_head_before && __av->size > " . $wb_ai . ") { ");
                    emit($cg, "StradaValue *__wb" . $wb_ai . " = strada_array_get(__av, " . $wb_ai . "); ");
                    emit($cg, "StradaArray *__wba" . $wb_ai . " = strada_deref_array(");
                    gen_expr($cg, $wb_arg->{"object"});
                    emit($cg, "); int64_t __wbi" . $wb_ai . " = strada_to_int(");
                    gen_expr($cg, $wb_arg->{"index"});
                    emit($cg, "); if (__wba" . $wb_ai . " && __wb" . $wb_ai . ") { ");
                    emit($cg, "strada_array_set(__wba" . $wb_ai . ", (int)__wbi" . $wb_ai . ", __wb" . $wb_ai . "); } } ");
                }
                elsif (defined($wb_arg) && $wb_arg->{"type"} == Perla::AST::N_ARROW_HASH()) {
                    emit($cg, "if (__av && __av->head == __a_head_before && __av->size > " . $wb_ai . ") { ");
                    emit($cg, "StradaValue *__wb" . $wb_ai . " = strada_array_get(__av, " . $wb_ai . "); ");
                    emit($cg, "StradaHash *__wbh" . $wb_ai . " = strada_deref_hash(");
                    gen_expr($cg, $wb_arg->{"object"});
                    emit($cg, "); char *__wbk" . $wb_ai . " = strada_to_str(");
                    gen_expr($cg, $wb_arg->{"key"});
                    emit($cg, "); if (__wbh" . $wb_ai . " && __wb" . $wb_ai . ") { ");
                    emit($cg, "strada_hash_set(__wbh" . $wb_ai . ", __wbk" . $wb_ai . ", __wb" . $wb_ai . "); } ");
                    emit($cg, "free(__wbk" . $wb_ai . "); } ");
                }
                $wb_ai++;
            }
            emit($cg, "strada_incref(__fr); strada_decref(__a); __fr; })");
        }
        return;
    }

    # Check if it's an our (global) variable used as a bareword. ONLY for
    # scalar ones — bareword `ISA` is a string "ISA", not `@ISA`, even when
    # `our @ISA` is declared elsewhere. Perl's bareword rules never promote
    # a bareword to an array/hash deref. Without this narrowing,
    # YAML::Node's `our @ISA = qw(…)` leaks "ISA" into the shared
    # our_vars table and YAML::Mo's `$P.ISA` in sub_2 emits `v_ISA`
    # (@ISA of main) instead of the string "ISA", so @{$P.ISA}=… writes
    # to the wrong place.
    if ($argc == 0 && defined($cg->{"our_vars"}->{$name})
        && $cg->{"our_vars"}->{$name} eq "SCALAR_VAR") {
        emit($cg, c_var($name));
        return;
    }

    # Strada core:: and math:: namespace calls — emit direct runtime calls
    if (index($name, "::") >= 0) {
        my int $dc = index($name, "::");
        my str $ns = substr($name, 0, $dc);
        my str $fn = substr($name, $dc + 2, length($name) - $dc - 2);

        if ($ns eq "core" || $ns eq "sys") {
            # core::func() → strada_func(args)
            emit($cg, "strada_" . $fn . "(");
            _gen_call_args_inline($cg, $args, $argc);
            emit($cg, ")");
            return;
        }
        if ($ns eq "math") {
            # math::func() → strada function or C math function
            if ($fn eq "sqrt" || $fn eq "sin" || $fn eq "cos" || $fn eq "tan" ||
                $fn eq "log" || $fn eq "exp" || $fn eq "abs" || $fn eq "floor" ||
                $fn eq "ceil" || $fn eq "pow" || $fn eq "atan2" || $fn eq "fmod") {
                emit($cg, "strada_new_num(" . $fn . "(");
                if ($argc > 0) {
                    emit($cg, "strada_to_num(");
                    gen_expr($cg, $args->[0]);
                    emit($cg, ")");
                    my int $mai = 1;
                    while ($mai < $argc) {
                        emit($cg, ", strada_to_num(");
                        gen_expr($cg, $args->[$mai]);
                        emit($cg, ")");
                        $mai++;
                    }
                }
                emit($cg, "))");
                return;
            }
        }
    }

    # Unknown function — dispatch through stash at runtime (supports XS, dynamic loading)
    if (index($name, "::") >= 0) {
        # Find LAST :: for correct package::name split
        my int $dc = -1;
        my int $dci = 0;
        while ($dci < length($name) - 1) {
            if (substr($name, $dci, 2) eq "::") { $dc = $dci; }
            $dci++;
        }
        my str $call_pkg = substr($name, 0, $dc);
        my str $call_fn = substr($name, $dc + 2, length($name) - $dc - 2);
        # For 0-arg calls to a package-qualified bareword (e.g.
        # `Object::new` used as a string in `*{$M.Object::new}`), fall
        # back to the stringified bareword name when the sub isn't
        # defined. This matches Perl's no-strict-subs semantics and is
        # what YAML::Mo's Mo::Inline blob relies on:
        #   *{$M . Object::new} = sub {...};
        # Only applies to package-qualified barewords to keep the
        # unqualified case unchanged (no-arg builtin calls etc.).
        if ($argc == 0) {
            my int $has_parens = 0;
            if (defined($node->{"has_parens"}) && $node->{"has_parens"} == 1) { $has_parens = 1; }
            emit($cg, "({ StradaValue *__xs_fn_name = perla_code_get(\"" . $call_pkg . "\", \"" . $call_fn . "\"); ");
            emit($cg, "StradaValue *__xs_result; ");
            emit($cg, "if (__xs_fn_name) { StradaValue *__xs_args = strada_new_array(); __xs_result = perla_call_code(__xs_fn_name, __xs_args); strada_decref(__xs_args); } ");
            # When the call had explicit parens (`Foo::bar()`), it's a
            # function-call syntax — try AUTOLOAD as a final fallback
            # before returning undef. Matches Perl's function-call
            # dispatch semantics. Without parens (`Foo::bar` as a
            # bareword), fall back to the stringified name — needed by
            # YAML::Mo's `*{$M . Object::new} = sub {...}` idiom.
            if ($has_parens == 1) {
                # Die when sub doesn't exist (matches Perl). Without this
                # the call silently returned undef and eval STRING
                # couldn't set $@.
                emit($cg, "else { PerlGlob *__al_g = perla_autoload_resolve(\"" . $call_pkg . "\"); ");
                emit($cg, "  if (__al_g && __al_g->slots[PERLA_SLOT_CODE]) { ");
                emit($cg, "    perla_set_autoload_var(\"" . $call_pkg . "::" . $call_fn . "\"); ");
                emit($cg, "    StradaValue *__xs_args = strada_new_array(); ");
                emit($cg, "    __xs_result = perla_call_code(__al_g->slots[PERLA_SLOT_CODE], __xs_args); ");
                emit($cg, "    strada_decref(__xs_args); ");
                emit($cg, "  } else { strada_die(\"Undefined subroutine &" . $call_pkg . "::" . $call_fn . " called\"); __xs_result = strada_new_undef(); } } ");
            } else {
                emit($cg, "else { __xs_result = strada_new_str(\"" . $call_pkg . "::" . $call_fn . "\"); } ");
            }
            emit($cg, "__xs_result; })");
        } else {
            # When the sub isn't found, try AUTOLOAD as a final fallback:
            # set `$AUTOLOAD = "pkg::name"`, then call the package's
            # AUTOLOAD sub if it has one. Matches Perl's function-call
            # dispatch semantics (method calls already AUTOLOAD via
            # perla_method_resolve).
            emit($cg, "({ StradaValue *__xs_fn_name = perla_code_get(\"" . $call_pkg . "\", \"" . $call_fn . "\"); ");
            emit($cg, "StradaValue *__xs_args = strada_new_array(); StradaArray *__av = strada_deref_array(__xs_args); ");
            _gen_push_args($cg, $args, $argc);
            emit($cg, "StradaValue *__xs_result; ");
            emit($cg, "if (__xs_fn_name) { __xs_result = perla_call_code(__xs_fn_name, __xs_args); strada_decref(__xs_args); } ");
            emit($cg, "else { PerlGlob *__al_g = perla_autoload_resolve(\"" . $call_pkg . "\"); ");
            emit($cg, "  if (__al_g && __al_g->slots[PERLA_SLOT_CODE]) { ");
            emit($cg, "    perla_set_autoload_var(\"" . $call_pkg . "::" . $call_fn . "\"); ");
            emit($cg, "    __xs_result = perla_call_code(__al_g->slots[PERLA_SLOT_CODE], __xs_args); strada_decref(__xs_args); ");
            # Die when sub doesn't exist (matches Perl). Decref args first
            # since strada_die longjmps past anything after it.
            emit($cg, "  } else { strada_decref(__xs_args); strada_die(\"Undefined subroutine &" . $call_pkg . "::" . $call_fn . " called\"); __xs_result = strada_new_undef(); } } ");
            emit($cg, "__xs_result; })");
        }
    } else {
        # Unqualified unknown function: try current package stash, then main::.
        # 0-arg form applies the no-strict-subs bareword-as-string fallback
        # — Perl stringifies `BAREWORD` to "BAREWORD" when no such sub
        # exists. Mo::Inline-style modules rely on this to build symbol
        # names dynamically: `*{$M.import}=sub{...}` needs `import` to
        # stringify, not return undef.
        #
        # When the name is NOT in $cg->{"subs"} (no visible `sub NAME {}` in
        # the file), Perl's compile-time resolution has already decided this
        # is a bareword. Doing a runtime code_get lookup is wrong: sibling
        # code can install a sub by that name via `*{$M.NAME}=sub{...}`
        # before this expression is evaluated, and the lookup would then
        # accidentally CALL the installed sub during load — triggering
        # sub_2 in Mo::Inline before the user's `use YAML::Mo` fires, and
        # polluting the module's own stash with extends/has/@ISA entries.
        # Emit the string directly and skip the runtime lookup entirely.
        my str $try_pkg = $cg->{"pkg"};
        my int $has_parens_u = 0;
        if (defined($node->{"has_parens"}) && $node->{"has_parens"} == 1) { $has_parens_u = 1; }
        if ($argc == 0) {
            # With explicit parens (`NAME()`), this is a function-call syntax —
            # look up the sub at runtime. Without parens, treat as bareword
            # string (no-strict-subs Mo::Inline pattern). This matters for
            # `${\ greet()}` and `@{[greet()]}` interpolation idioms where
            # eval STRING compiles the inner expression as a fresh unit and
            # has no static knowledge of `greet`.
            if ($has_parens_u == 1) {
                emit($cg, "({ StradaValue *__xs_fn_name = perla_code_get(\"" . $try_pkg . "\", \"" . $name . "\"); ");
                emit($cg, "if (!__xs_fn_name) __xs_fn_name = perla_code_get(\"main\", \"" . $name . "\"); ");
                emit($cg, "if (!__xs_fn_name) __xs_fn_name = perla_code_get_walking(\"" . $name . "\"); ");
                emit($cg, "StradaValue *__xs_args = strada_new_array(); ");
                # Die with Perl's standard "Undefined subroutine" message
                # when the bareword resolves to no sub at runtime. Without
                # this, calls to non-existent subs silently returned undef
                # and (worse) eval STRING couldn't set $@ for the standard
                # `eval "no_such_func()"; print $@` introspection idiom.
                emit($cg, "StradaValue *__xs_result; ");
                emit($cg, "if (__xs_fn_name) { __xs_result = perla_call_code(__xs_fn_name, __xs_args); } ");
                emit($cg, "else { strada_decref(__xs_args); strada_die(\"Undefined subroutine &" . $try_pkg . "::" . $name . " called\"); __xs_result = strada_new_undef(); } ");
                emit($cg, "if (__xs_fn_name) strada_decref(__xs_args); __xs_result; })");
            } else {
                # Bareword without parens: if a sub of this name is known
                # via any stash, call it (covers `use POSIX qw(INT_MAX);
                # print INT_MAX` style — constants exported as 0-arg subs).
                # Otherwise fall back to a string literal (no-strict-subs
                # bareword string idiom). Walking respects load order so
                # explicitly-used modules win over init-time stubs.
                #
                # strict 'subs': under `use strict;`, the string-fallback
                # is a compile error in real Perl. We emit a runtime
                # check: if the lookup fails, die with the Perl-style
                # message rather than silently substituting the bareword
                # as a string. Compile-time `_resolve_sub` would false-
                # positive on imports loaded at runtime (`use POSIX qw(X)`
                # registers X via perla_code_set in the package init —
                # not visible to $cg->{"subs"} until runtime), so we
                # defer to runtime where the stash IS populated.
                my int $__bw_strict_subs = 0;
                if (defined($cg->{"strict_subs"}) && $cg->{"strict_subs"} == 1) {
                    $__bw_strict_subs = 1;
                }
                # Special filehandle barewords are valid filehandle
                # references even when not bound as subs — they're
                # built into the runtime. Without this, code like
                # `select(STDOUT)` died under strict 'subs' because
                # STDOUT isn't a registered sub. STDIN/STDOUT/STDERR
                # specifically resolve to runtime filehandle wrappers
                # via strada_new_filehandle(stdout) at the call site.
                if ($name eq "STDIN" || $name eq "STDOUT" || $name eq "STDERR"
                    || $name eq "ARGV" || $name eq "DATA") {
                    my str $__fh_stream = "stdout";
                    if ($name eq "STDIN")  { $__fh_stream = "stdin"; }
                    if ($name eq "STDERR") { $__fh_stream = "stderr"; }
                    if ($name eq "STDIN" || $name eq "STDOUT" || $name eq "STDERR") {
                        # Build an on-the-fly STRADA_FILEHANDLE wrapper.
                        # The libc stream isn't closed by strada's decref
                        # because we clear value.fh before decref.
                        emit($cg, "({ StradaValue *__fh = strada_new_filehandle(" . $__fh_stream . "); __fh; })");
                    } else {
                        # ARGV/DATA — fall through to runtime bareword string
                        emit($cg, "strada_new_str(\"" . $name . "\")");
                    }
                    return;
                }
                emit($cg, "({ StradaValue *__bw_fn = perla_code_get(\"" . $try_pkg . "\", \"" . $name . "\"); ");
                emit($cg, "if (!__bw_fn) __bw_fn = perla_code_get(\"main\", \"" . $name . "\"); ");
                emit($cg, "if (!__bw_fn) __bw_fn = perla_code_get_walking(\"" . $name . "\"); ");
                emit($cg, "StradaValue *__bw_v; ");
                emit($cg, "if (__bw_fn) { StradaValue *__bw_args = strada_new_array(); __bw_v = perla_call_code(__bw_fn, __bw_args); strada_decref(__bw_args); } ");
                if ($__bw_strict_subs == 1) {
                    emit($cg, "else { strada_die(\"Bareword \\\"" . $name . "\\\" not allowed while \\\"strict subs\\\" in use\"); __bw_v = strada_new_undef(); } ");
                } else {
                    emit($cg, "else { __bw_v = strada_new_str(\"" . $name . "\"); } ");
                }
                emit($cg, "__bw_v; })");
            }
        } else {
            emit($cg, "({ StradaValue *__xs_fn_name = perla_code_get(\"" . $try_pkg . "\", \"" . $name . "\"); ");
            emit($cg, "if (!__xs_fn_name) __xs_fn_name = perla_code_get(\"main\", \"" . $name . "\"); ");
            emit($cg, "if (!__xs_fn_name) __xs_fn_name = perla_code_get_walking(\"" . $name . "\"); ");
            emit($cg, "StradaValue *__xs_args = strada_new_array(); StradaArray *__av = strada_deref_array(__xs_args); ");
            _gen_push_args($cg, $args, $argc);
            emit($cg, "StradaValue *__xs_result = __xs_fn_name ? perla_call_code(__xs_fn_name, __xs_args) : strada_new_undef(); ");
            emit($cg, "strada_decref(__xs_args); __xs_result; })");
        }
    }
}

# Emit a slot-store of `__fh` into the open()/sysopen() first-arg target.
# Used for `open($h{k}, ...)`, `open($a[i], ...)`, `open($h->{k}, ...)`,
# `open($a->[i], ...)` and similar Perl-style out-parameter forms where
# the first arg is a hash/array slot rather than a scalar variable.
# Plain `gen_expr($fh_arg) = __fh` emits invalid C (`strada_hv_fetch_owned(...) = __fh`).
# __fh is an owned ref (refcount 1); strada_hash_set_take / strada_array_set take ownership.
func _emit_open_slot_store(scalar $cg, scalar $fh_arg) void {
    my int $tt = $fh_arg->{"type"};
    if ($tt == Perla::AST::N_HASH_ELEM()) {
        emit($cg, "{ char *__osk = strada_to_str(");
        gen_expr($cg, $fh_arg->{"key"});
        emit($cg, "); StradaValue *__osh = ");
        gen_expr($cg, $fh_arg->{"hash"});
        emit($cg, "; if (__osh && !STRADA_IS_TAGGED_INT(__osh) && __osh->type == STRADA_HASH) strada_hash_set_take(__osh->value.hv, __osk, __fh); else strada_decref(__fh); free(__osk); }");
        return;
    }
    if ($tt == Perla::AST::N_ARROW_HASH()) {
        emit($cg, "{ char *__osk = strada_to_str(");
        gen_expr($cg, $fh_arg->{"key"});
        emit($cg, "); StradaValue *__osr = ");
        gen_expr($cg, $fh_arg->{"object"});
        emit($cg, "; StradaValue *__osh = (__osr && !STRADA_IS_TAGGED_INT(__osr) && __osr->type == STRADA_REF) ? __osr->value.rv : __osr; if (__osh && !STRADA_IS_TAGGED_INT(__osh) && __osh->type == STRADA_HASH) strada_hash_set_take(__osh->value.hv, __osk, __fh); else strada_decref(__fh); free(__osk); }");
        return;
    }
    if ($tt == Perla::AST::N_ARRAY_ELEM()) {
        emit($cg, "{ StradaArray *__osa = strada_deref_array(");
        gen_expr($cg, $fh_arg->{"array"});
        emit($cg, "); int __osi = (int)strada_to_int(");
        gen_expr($cg, $fh_arg->{"index"});
        emit($cg, "); if (__osa) { if (__osi < 0) __osi += strada_array_length(__osa); strada_array_set(__osa, __osi, __fh); strada_decref(__fh); } else strada_decref(__fh); }");
        return;
    }
    if ($tt == Perla::AST::N_ARROW_ARRAY()) {
        emit($cg, "{ StradaArray *__osa = strada_deref_array(");
        gen_expr($cg, $fh_arg->{"object"});
        emit($cg, "); int __osi = (int)strada_to_int(");
        gen_expr($cg, $fh_arg->{"index"});
        emit($cg, "); if (__osa) { strada_array_set(__osa, __osi, __fh); strada_decref(__fh); } else strada_decref(__fh); }");
        return;
    }
    # Fallback: scalar-var / unsupported lvalue — try plain assignment.
    gen_expr($cg, $fh_arg);
    emit($cg, " = __fh; ");
}

# Resolve a function name to its qualified name, or "" if not found
func _resolve_sub(scalar $cg, str $name) str {
    my scalar $subs = $cg->{"subs"};
    # Check if already qualified (contains ::)
    if (index($name, "::") >= 0) {
        if (defined($subs->{$name})) {
            return $name;
        }
        return "";
    }
    # Try current package
    my str $qname = $cg->{"pkg"} . "::" . $name;
    if (defined($subs->{$qname})) {
        return $qname;
    }
    # Try main::
    my str $main_q = "main::" . $name;
    if (defined($subs->{$main_q})) {
        return $main_q;
    }
    return "";
}

# --- Method call ---
# --- Push args to __av, with hash/array flattening ---
# Generate inline comma-separated args (for direct C function calls)
func _gen_call_args_inline(scalar $cg, scalar $args, int $argc) void {
    my int $ai = 0;
    while ($ai < $argc) {
        if ($ai > 0) { emit($cg, ", "); }
        gen_expr($cg, $args->[$ai]);
        $ai++;
    }
}

func _gen_push_args(scalar $cg, scalar $args, int $argc) void {
    my int $ai = 0;
    while ($ai < $argc) {
        my scalar $arg = $args->[$ai];
        if ($arg->{"type"} == Perla::AST::N_HASH_VAR() || $arg->{"type"} == Perla::AST::N_DEREF_HASH()) {
            # Flatten hash (or %{$ref} dereference) into key-value pairs.
            # `%$ref` was previously falling through to the default branch
            # and getting pushed as one STRADA_HASH element, so DBIC's
            # `columns => { count => { count => '*' } }` followed by
            # SQLMaker's `%{ $columns->{count} }` iteration came out empty
            # and `_count_rs` produced `SELECT me., COUNT( * ) FROM ...`
            # — a malformed query that fetched no rows, hence the bizowie
            # BZ:6 plateau.
            #
            # Force list context around the hash expression so it
            # actually yields the hash (in list ctx) instead of the
            # bucket-count tag-int (in scalar ctx). Without this,
            # `my $err = validate(%$href)` saw __perla_want_list=0
            # (carried in from the outer scalar `my $err = …`), so
            # `%$href` collapsed to STRADA_MAKE_TAGGED_INT(num_entries)
            # — strada_deref_hash on a tagged int is NULL, the for-
            # loop pushed nothing, and validate got 0 args.
            emit($cg, "{ int __sav_wl_pa = __perla_want_list; __perla_want_list = 1; StradaValue *__hv = ");
            gen_expr($cg, $arg);
            emit($cg, "; __perla_want_list = __sav_wl_pa; StradaHash *__hh = strada_deref_hash(__hv); ");
            emit($cg, "if (__hh) { StradaArray *__hka = strada_hash_keys(__hh); ");
            emit($cg, "for (int __hi = 0; __hi < (int)__hka->size; __hi++) { ");
            emit($cg, "StradaValue *__key = __hka->elements[__hi]; ");
            emit($cg, "strada_array_push(__av, __key); ");
            emit($cg, "char *__ks = strada_to_str(__key); strada_array_push(__av, strada_hv_fetch_owned(__hv, __ks)); free(__ks); ");
            emit($cg, "} strada_free_array(__hka); } } ");
        } elsif ($arg->{"type"} == Perla::AST::N_ARRAY_VAR() || $arg->{"type"} == Perla::AST::N_DEREF_ARRAY()
                 || $arg->{"type"} == Perla::AST::N_ARRAY_SLICE() || $arg->{"type"} == Perla::AST::N_HASH_SLICE()
                 || $arg->{"type"} == Perla::AST::N_RANGE()) {
            # Flatten array elements (both @arr and @{$ref}) and slices/
            # ranges. Without N_RANGE here, `count(1..5)` passes a single
            # arrayref so @_ has size 1 in the callee.
            # Force list context around the slice/range expression —
            # array slices in scalar context collapse to the last
            # element (`@a[0..5]` inside `my $r = mktime(@a[0..5])`
            # returned just the 6th element). When passed as args to a
            # multi-arg builtin, we always want the full list.
            emit($cg, "{ int __sav_wl_pa = __perla_want_list; __perla_want_list = 1; StradaValue *__fav = ");
            gen_expr($cg, $arg);
            emit($cg, "; __perla_want_list = __sav_wl_pa; StradaArray *__fa = strada_deref_array(__fav); ");
            emit($cg, "if (__fa) for (int __fi = 0; __fi < (int)strada_array_length(__fa); __fi++) ");
            emit($cg, "strada_array_push(__av, strada_array_get(__fa, __fi)); } ");
        } elsif ($arg->{"type"} == Perla::AST::N_QWORD()) {
            # qw(a b c) in a call's arg list — flatten into individual
            # string args, not pushed as one array. Without this,
            # `$obj->load_components(qw/Row PK/)` passes a single
            # array ref as the sole arg; `load_components` in
            # perla_stash.c then stringifies it as "ARRAY(0x...)" and
            # the downstream require fails on a bogus path. Mirrors
            # the existing N_ANON_ARRAY flatten just below.
            my scalar $elems = $arg->{"elems"};
            my int $ei = 0;
            while ($ei < scalar(@{$elems})) {
                emit($cg, "strada_array_push(__av, ");
                gen_expr($cg, $elems->[$ei]);
                emit($cg, "); ");
                $ei++;
            }
        } elsif ($arg->{"type"} == Perla::AST::N_ANON_ARRAY() && defined($arg->{"elems"}) && $arg->{"is_ref"} != 1) {
            # Flatten parenthesized list (a, b, c) into individual args
            # But NOT [...] array ref constructors (is_ref=1)
            my scalar $elems = $arg->{"elems"};
            my int $ei = 0;
            while ($ei < scalar(@{$elems})) {
                my scalar $elem = $elems->[$ei];
                if (defined($elem) && $elem->{"type"} == Perla::AST::N_CALL() && !defined($elem->{"coderef"})) {
                    # Function call - may return array to flatten.
                    # Matches the pattern at line ~5256; needs the same
                    # strada_decref(__fcr) to avoid leaking one ref per
                    # call in flatten-call-inside-list contexts.
                    emit($cg, "{ StradaValue *__fcr = ");
                    gen_expr($cg, $elem);
                    emit($cg, "; if (__fcr && !STRADA_IS_TAGGED_INT(__fcr) && __fcr->type == STRADA_ARRAY) { ");
                    emit($cg, "StradaArray *__fca = strada_deref_array(__fcr); ");
                    emit($cg, "if (__fca) for (int __fci=0; __fci<(int)strada_array_length(__fca); __fci++) ");
                    emit($cg, "strada_array_push(__av, strada_array_get(__fca, __fci)); ");
                    emit($cg, "} else { strada_array_push(__av, __fcr); } strada_decref(__fcr); } ");
                } else {
                    emit($cg, "strada_array_push(__av, ");
                    gen_expr($cg, $elem);
                    emit($cg, "); ");
                }
                $ei++;
            }
        } elsif ($arg->{"type"} == Perla::AST::N_CALL() && defined($arg->{"name"}) && ($arg->{"name"} eq "_definition_context" || $arg->{"name"} eq "Class::MOP::_definition_context")) {
            # Special: _definition_context returns (key => value) that must be flattened
            emit($cg, "strada_array_push(__av, strada_new_str(\"definition_context\")); ");
            emit($cg, "{ StradaValue *__dch = strada_new_hash(); ");
            emit($cg, "strada_hv_store(__dch, \"package\", strada_new_str(\"" . $cg->{"pkg"} . "\")); ");
            emit($cg, "strada_hv_store(__dch, \"file\", strada_new_str(\"" . $cg->{"filename"} . "\")); ");
            emit($cg, "strada_hv_store(__dch, \"line\", STRADA_MAKE_TAGGED_INT(0)); ");
            emit($cg, "strada_array_push(__av, strada_new_ref(__dch, '%')); } ");
        } elsif (($arg->{"type"} == Perla::AST::N_CALL() && !defined($arg->{"coderef"}))
                 || $arg->{"type"} == Perla::AST::N_METHOD()
                 || $arg->{"type"} == Perla::AST::N_BINOP()
                 || $arg->{"type"} == Perla::AST::N_TERNARY()) {
            # Function/method/binop call result: may return array (list
            # context), flatten at runtime. Set `__perla_want_list = 1`
            # around the call so a callee that does `return (a,b,c)`
            # returns the full list, not the scalar-context last element.
            # N_METHOD missing here used to make `$obj->fn($obj->returns_list)`
            # pass only the LAST element of returns_list — broke DBIC's
            # `$self->_execute($self->_select_args(@_))` so _execute saw
            # ($self, ARRAY_REF, ...) instead of ($self, 'select', $ident, ...).
            # N_BINOP/N_TERNARY: `||`, `//`, `?:` can yield the empty list
            # `()` (which is a 0-length array StradaValue); without this
            # branch it was pushed as one empty-array element instead of
            # zero elements.
            # __fca is a temporary holding the call's return value (refcount 1);
            # strada_array_push bumps either __fca or its elements by +1,
            # giving __av its ref. Without the trailing decref, __fca's
            # original ref is never released - leak per call.
            emit($cg, "{ int __sav_wl = __perla_want_list; __perla_want_list = 1; StradaValue *__fca = ");
            gen_expr($cg, $arg);
            emit($cg, "; __perla_want_list = __sav_wl; if (__fca && !STRADA_IS_TAGGED_INT(__fca) && __fca->type == STRADA_ARRAY) { ");
            emit($cg, "StradaArray *__fcav = strada_deref_array(__fca); ");
            emit($cg, "if (__fcav) for (int __fci = 0; __fci < (int)strada_array_length(__fcav); __fci++) ");
            emit($cg, "strada_array_push(__av, strada_array_get(__fcav, __fci)); ");
            emit($cg, "} else { strada_array_push(__av, __fca); } strada_decref(__fca); } ");
        } elsif ($arg->{"type"} == Perla::AST::N_MAP()
                 || $arg->{"type"} == Perla::AST::N_GREP()
                 || $arg->{"type"} == Perla::AST::N_SORT()) {
            # map/grep/sort always return a list — flatten the resulting
            # array into the call args. Without this, code like
            #   _load_components( map { ... } grep { ... } @_ )
            # passes a single arrayref to _load_components, which then
            # tries to require ARRAY(0x...) — fatal in DBIx::Class load.
            # Push __perla_want_list = 1 around the evaluation so the
            # map/grep/sort returns the list (not the scalar count when
            # the surrounding context is scalar, e.g. `my $s = sum(map ...)`).
            emit($cg, "{ int __sav_wl_mc = __perla_want_list; __perla_want_list = 1; StradaValue *__mca = ");
            gen_expr($cg, $arg);
            emit($cg, "; __perla_want_list = __sav_wl_mc; ");
            emit($cg, "if (__mca && !STRADA_IS_TAGGED_INT(__mca) && __mca->type == STRADA_ARRAY) { ");
            emit($cg, "StradaArray *__mcav = strada_deref_array(__mca); ");
            emit($cg, "if (__mcav) for (int __mci = 0; __mci < (int)strada_array_length(__mcav); __mci++) ");
            emit($cg, "strada_array_push(__av, strada_array_get(__mcav, __mci)); ");
            emit($cg, "} else { strada_array_push(__av, __mca); } strada_decref(__mca); } ");
        } else {
            emit($cg, "strada_array_push(__av, ");
            gen_expr($cg, $arg);
            emit($cg, "); ");
        }
        $ai++;
    }
}

func _gen_method_call(scalar $cg, scalar $node) void {
    my str $method = $node->{"method"};
    my scalar $args = $node->{"args"};
    my int $argc = scalar(@{$args});

    # Built-in methods: isa(), can()
    if ($method eq "isa" && $argc >= 1) {
        # Check if object is a static class name (bare word / N_CALL with no args)
        my scalar $obj_node = $node->{"object"};
        my int $is_static_class = 0;
        my str $class_name = "";
        if (defined($obj_node) && $obj_node->{"type"} == Perla::AST::N_CALL() && defined($obj_node->{"name"}) && scalar(@{$obj_node->{"args"}}) == 0) {
            my str $cn = $obj_node->{"name"};
            if (length($cn) > 0 && char_at($cn, 0) >= 65 && char_at($cn, 0) <= 90) {
                $is_static_class = 1;
                $class_name = $cn;
            }
        }
        # Perl's isa returns 1 for true, "" (empty string) for false —
        # NOT 0. Code that does `print $obj->isa('X')` or builds strings
        # from the result depends on this convention.
        #
        # User-defined `sub isa` override: dispatch through the normal
        # method machinery when the package has its own `isa` slot
        # (i.e. a non-UNIVERSAL one). Without this, `\$obj->isa("X")`
        # always called perla_isa_check directly, bypassing the user
        # override and breaking classes that proxy isa for fake bases.
        if ($is_static_class == 1) {
            emit($cg, "({ StradaValue *__isa_res; ");
            emit($cg, "PerlGlob *__isag = perla_glob_get(perla_stash_get_or_create(\"" . $class_name . "\"), \"isa\"); ");
            emit($cg, "if (__isag && __isag->slots[PERLA_SLOT_CODE]) { ");
            # User override: dispatch as a normal method call
            emit($cg, "  StradaValue *__ia = strada_new_array(); StradaArray *__iav = strada_deref_array(__ia); ");
            emit($cg, "  strada_array_push_take(__iav, strada_new_str(\"" . $class_name . "\")); ");
            emit($cg, "  strada_array_push_take(__iav, ");
            gen_expr($cg, $args->[0]);
            emit($cg, "); __isa_res = perla_call_code(__isag->slots[PERLA_SLOT_CODE], __ia); strada_decref(__ia); ");
            emit($cg, "} else { ");
            emit($cg, "  char *__tc = strada_to_str(");
            gen_expr($cg, $args->[0]);
            emit($cg, "); int __r = perla_isa_check(\"" . $class_name . "\", __tc); free(__tc); ");
            emit($cg, "  __isa_res = __r ? STRADA_MAKE_TAGGED_INT(1) : strada_new_str(\"\"); ");
            emit($cg, "} __isa_res; })");
        } else {
            emit($cg, "({ StradaValue *__io = ");
            gen_expr($cg, $node->{"object"});
            emit($cg, "; const char *__bp = perla_blessed(__io); ");
            emit($cg, "char *__cn = NULL; if (!__bp && __io && !STRADA_IS_TAGGED_INT(__io) && __io->type == STRADA_STR) __cn = strada_to_str(__io); ");
            emit($cg, "const char *__ipkg = __bp ? __bp : (__cn ? __cn : \"\"); ");
            emit($cg, "StradaValue *__ires; ");
            emit($cg, "PerlGlob *__isag = __ipkg[0] ? perla_glob_get(perla_stash_get_or_create(__ipkg), \"isa\") : NULL; ");
            emit($cg, "if (__isag && __isag->slots[PERLA_SLOT_CODE]) { ");
            emit($cg, "  StradaValue *__ia = strada_new_array(); StradaArray *__iav = strada_deref_array(__ia); ");
            emit($cg, "  strada_incref(__io); strada_array_push_take(__iav, __io); ");
            emit($cg, "  strada_array_push_take(__iav, ");
            gen_expr($cg, $args->[0]);
            emit($cg, "); __ires = perla_call_code(__isag->slots[PERLA_SLOT_CODE], __ia); strada_decref(__ia); ");
            emit($cg, "} else { ");
            emit($cg, "  char *__tc = strada_to_str(");
            gen_expr($cg, $args->[0]);
            emit($cg, "); int __r = __ipkg[0] ? perla_isa_check(__ipkg, __tc) : 0; free(__tc); ");
            emit($cg, "  __ires = __r ? STRADA_MAKE_TAGGED_INT(1) : strada_new_str(\"\"); ");
            emit($cg, "} if (__cn) free(__cn); __ires; })");
        }
        return;
    }
    if ($method eq "can" && $argc >= 1) {
        # Real Perl `can` returns a CODE ref, not a bool. Returning a
        # tagged int (1/0) breaks any caller that does `$cref->(args)`
        # on the result — Module::Runtime::use_module reached via
        # Clone::Choose's `__PACKAGE__->can("clone")` is the canonical
        # case. Route through perla_can_code which returns the actual
        # value stored in the SLOT_CODE (a STRADA_STR sub-name, a
        # CPOINTER for native impls, or a STRADA_REF closure) so
        # `$u->("Storable")` dispatches the same way `&$u("Storable")`
        # would on a real coderef.
        #
        # Static-class fast path: when the invocant is a bareword
        # N_CALL with uppercase initial (e.g. `Foo->can(...)`), bake
        # the class name as a literal C string. Without this, the
        # bareword would route through the 0-arg lookup path and die
        # under strict 'subs' since the class isn't a sub.
        my scalar $can_obj = $node->{"object"};
        my int $can_is_static = 0;
        my str $can_class = "";
        if (defined($can_obj) && $can_obj->{"type"} == Perla::AST::N_CALL()
            && defined($can_obj->{"name"})
            && (!defined($can_obj->{"args"}) || scalar(@{$can_obj->{"args"}}) == 0)) {
            my str $cn = $can_obj->{"name"};
            if (length($cn) > 0 && char_at($cn, 0) >= 65 && char_at($cn, 0) <= 90) {
                $can_is_static = 1;
                $can_class = $cn;
            } elsif (length($cn) > 0 && _resolve_sub($cg, $cn) eq "") {
                # Lowercase bareword (e.g. `main`, `mypkg`) that ISN'T
                # a registered sub: treat as class name. Perl exempts
                # `bareword->method` from strict subs for any IDENT.
                $can_is_static = 1;
                $can_class = $cn;
            }
        }
        if ($can_is_static == 1) {
            emit($cg, "({ char *__mn = strada_to_str(");
            gen_expr($cg, $args->[0]);
            emit($cg, "); StradaValue *__r = perla_can_code(\"" . $can_class . "\", __mn); free(__mn); __r; })");
            return;
        }
        emit($cg, "({ StradaValue *__co = ");
        gen_expr($cg, $node->{"object"});
        emit($cg, "; const char *__bp = perla_blessed(__co); ");
        emit($cg, "char *__cn = NULL; if (!__bp && __co && !STRADA_IS_TAGGED_INT(__co) && __co->type == STRADA_STR) __cn = strada_to_str(__co); ");
        emit($cg, "const char *__cpkg = __bp ? __bp : (__cn ? __cn : \"\"); ");
        emit($cg, "char *__mn = strada_to_str(");
        gen_expr($cg, $args->[0]);
        emit($cg, "); StradaValue *__r = perla_can_code(__cpkg, __mn); free(__mn); if (__cn) free(__cn); __r; })");
        return;
    }

    # Class->method() — static method call (e.g., LazyAccessor->new(...))
    # Object is a bareword (N_CALL with no args, uppercase first letter).
    # Skip this block when the method name is a variable (dynamic dispatch)
    # — otherwise `Class->$method` baked the literal variable name into
    # the C call as if it were the method name.
    my int $is_dynamic_disp = 0;
    if (defined($node->{"dynamic_method"}) && $node->{"dynamic_method"} == 1) {
        $is_dynamic_disp = 1;
    }
    my scalar $obj_node = $node->{"object"};
    if ($is_dynamic_disp == 0 && defined($obj_node) && $obj_node->{"type"} == Perla::AST::N_CALL() &&
        (!defined($obj_node->{"args"}) || scalar(@{$obj_node->{"args"}}) == 0)) {
        my str $class_name = $obj_node->{"name"};
        # STDIN/STDOUT/STDERR as bareword invocant: build an on-the-fly
        # STRADA_FILEHANDLE wrapper around the libc stream so the
        # dispatch sees the right invocant type. We don't keep a global
        # v_STDOUT (just an extern declaration, no actual symbol), so
        # synthesize one here for the duration of the call.
        if ($class_name eq "STDIN" || $class_name eq "STDOUT" || $class_name eq "STDERR") {
            my str $stream = "stdout";
            if ($class_name eq "STDIN") { $stream = "stdin"; }
            if ($class_name eq "STDERR") { $stream = "stderr"; }
            emit($cg, "({ StradaValue *__stdfh = strada_new_filehandle(" . $stream . "); ");
            emit($cg, "StradaValue *__a = strada_new_array(); StradaArray *__av = strada_deref_array(__a); ");
            emit($cg, "strada_incref(__stdfh); strada_array_push_take(__av, __stdfh); ");
            _gen_push_args($cg, $args, $argc);
            emit($cg, "StradaValue *__mr = perla_method_dispatch(__stdfh, \"" . $method . "\", __a); ");
            # Don't close the libc stream — clear the FILE* before decref
            # so strada_close (on free) doesn't try to fclose stdin/out/err.
            emit($cg, "if (__stdfh->type == STRADA_FILEHANDLE) __stdfh->value.fh = NULL; ");
            emit($cg, "strada_decref(__stdfh); strada_decref(__a); __mr; })");
            return;
        }
        if (length($class_name) > 0 && char_at($class_name, 0) >= 65 && char_at($class_name, 0) <= 90) {
            # Check if method is defined in the class (direct call) or needs dispatch
            my str $qname = $class_name . "::" . $method;
            my int $has_direct = 0;
            my scalar $subs_check = $cg->{"subs"};
            if (defined($subs_check->{$qname})) { $has_direct = 1; }
            if ($has_direct == 1) {
                # Direct static call WITH a runtime override check. Real
                # Perl always goes through the symbol table for method
                # dispatch, so `*Foo::bar = sub {...}` after the fact
                # MUST take effect. Without this check, perla bypasses
                # the typeglob slot — `*{'Foo::method'} = sub { }` and
                # similar monkey-patches silently no-op.
                # Pattern: peek the glob's CODE slot. If it's been
                # overridden (now a CLOSURE / CPOINTER, not the original
                # STRADA_STR sub-name), call via perla_call_code. Else
                # fall back to the direct C-symbol call (fast path).
                my str $fname = sub_cname_q($qname);
                emit($cg, "({ StradaValue *__a = strada_new_array(); StradaArray *__av = strada_deref_array(__a); ");
                # push_take the fresh class-name string so its rc=1
                # isn't leaked by push's incref + decref(__a) cycle.
                emit($cg, "strada_array_push_take(__av, strada_new_str(\"" . $class_name . "\")); ");
                _gen_push_args($cg, $args, $argc);
                emit($cg, "StradaValue *__mr; ");
                # Cache the PerlGlob* per call site — pkg/method are
                # compile-time constants and the glob's heap address is
                # stable once allocated (only the stash entries[] array
                # reallocs, not the glob structs). Eliminates the per-call
                # O(n) stash-walk + glob-walk strcmp loop.
                emit($cg, "{ static PerlGlob *__og_c = NULL; PerlGlob *__og = __og_c; ");
                emit($cg, "  if (__builtin_expect(!__og, 0)) { __og = perla_glob_get_or_create(perla_stash_get_or_create(\"" . $class_name . "\"), \"" . $method . "\"); __og_c = __og; } ");
                emit($cg, "  StradaValue *__os = __og->slots[PERLA_SLOT_CODE]; ");
                emit($cg, "  if (__builtin_expect(__os && !STRADA_IS_TAGGED_INT(__os) ");
                emit($cg, "      && (__os->type == STRADA_CLOSURE || __os->type == STRADA_CPOINTER ");
                emit($cg, "          || (__os->type == STRADA_REF && __os->value.rv && !STRADA_IS_TAGGED_INT(__os->value.rv) ");
                emit($cg, "              && (__os->value.rv->type == STRADA_CLOSURE || __os->value.rv->type == STRADA_CPOINTER))), 0)) { ");
                emit($cg, "    __mr = perla_call_code(__os, __a); ");
                emit($cg, "  } else { ");
                emit($cg, "    __mr = " . $fname . "(__a); ");
                emit($cg, "  } } strada_decref(__a); __mr; })");
            } else {
                # Method dispatch (inherited method)
                emit($cg, "({ StradaValue *__a = strada_new_array(); StradaArray *__av = strada_deref_array(__a); ");
                emit($cg, "strada_array_push_take(__av, strada_new_str(\"" . $class_name . "\")); ");
                _gen_push_args($cg, $args, $argc);
                # The dispatch arg also passes a fresh class-name str — that's
                # passed through perla_method_dispatch which doesn't take
                # ownership, so it just leaks at the moment. The standard
                # method_dispatch fix has to happen in perla_stash.c.
                emit($cg, "StradaValue *__mr = perla_method_dispatch(strada_new_str(\"" . $class_name . "\"), \"" . $method . "\", __a); ");
                emit($cg, "strada_decref(__a); __mr; })");
            }
            return;
        }
    }

    # Dynamic method dispatch: $obj->$method_var — resolve at runtime.
    # Two forms:
    #   $obj->$var          -> method name is a plain scalar variable
    #   $obj->${ EXPR }     -> method name is an arbitrary expression
    # The parser records the variable in $method (for the simple form) or
    # stashes the AST in $method_expr (for the braced form).
    #
    # In Perl, `$obj->$x(args)` has *two* meanings depending on what $x
    # is: if $x is a string, it's a by-name method dispatch; if $x is a
    # code ref (CODE/CLOSURE), Perl calls the code directly with $obj
    # as the first arg (bypassing method lookup). YAML::Mo uses the
    # code-ref form — `$self->$_new_error(@_)` where $_new_error is a
    # closure. Without the ref check, strada_to_str(CLOSURE) stringifies
    # to "CPOINTER(0x...)" and we dispatch by that bogus method name.
    if (defined($node->{"dynamic_method"}) && $node->{"dynamic_method"} == 1) {
        # `Class->$method` — when the object is a bareword class
        # (N_CALL with no args), emit the class name as a literal
        # string. Otherwise the bareword goes through gen_expr's
        # sub-call path and trips strict 'subs'. Mirrors the same
        # logic in the general method-call code path below.
        my int $dyn_obj_is_bareword_class = 0;
        my str $dyn_obj_class_lit = "";
        my scalar $__dm_obj = $node->{"object"};
        if (defined($__dm_obj) && $__dm_obj->{"type"} == Perla::AST::N_CALL()
            && defined($__dm_obj->{"name"})
            && (!defined($__dm_obj->{"args"}) || scalar(@{$__dm_obj->{"args"}}) == 0)) {
            my str $bn = $__dm_obj->{"name"};
            if (length($bn) > 0) {
                my int $is_ident_shape = 1;
                my int $ci = 0;
                while ($ci < length($bn)) {
                    my str $cc = substr($bn, $ci, 1);
                    if (!(($cc ge "a" && $cc le "z") || ($cc ge "A" && $cc le "Z")
                          || ($cc ge "0" && $cc le "9") || $cc eq "_" || $cc eq ":")) {
                        $is_ident_shape = 0;
                        $ci = length($bn);
                    } else {
                        $ci = $ci + 1;
                    }
                }
                if ($is_ident_shape == 1 && _resolve_sub($cg, $bn) eq "") {
                    $dyn_obj_is_bareword_class = 1;
                    $dyn_obj_class_lit = $bn;
                }
            }
        }
        emit($cg, "({ StradaValue *__obj = ");
        if ($dyn_obj_is_bareword_class == 1) {
            emit($cg, "strada_new_str(\"" . $dyn_obj_class_lit . "\")");
        } else {
            gen_expr($cg, $node->{"object"});
        }
        if (defined($node->{"method_expr"})) {
            emit($cg, "; StradaValue *__mn = ");
            gen_expr($cg, $node->{"method_expr"});
            emit($cg, "; strada_incref(__mn); ");
        } else {
            # `$obj->$_` reads $_ via perla_dollar_underscore (the
            # canonical $_ slot updated by foreach/map/grep/sort), not
            # c_var("_") which is the unrelated file-scope v__ global.
            # Required for `$obj->$_(...)  for qw/m1 m2/` idioms (e.g.
            # DBIx::Class::Schema::clone line 1013).
            my str $mn_var = ($method eq "_") ? "perla_dollar_underscore" : c_var($method);
            emit($cg, "; StradaValue *__mn = " . $mn_var . "; if (__mn) strada_incref(__mn); ");
        }
        emit($cg, "StradaValue *__a = strada_new_array(); StradaArray *__av = strada_deref_array(__a); ");
        emit($cg, "strada_array_push(__av, __obj); ");
        _gen_push_args($cg, $args, $argc);
        emit($cg, "StradaValue *__mr; ");
        # Detect code-ref form: plain CLOSURE/CPOINTER, or REF to those.
        emit($cg, "int __is_code = 0; StradaValue *__code = __mn; ");
        emit($cg, "if (__mn && !STRADA_IS_TAGGED_INT(__mn)) { ");
        emit($cg, "  if (__mn->type == STRADA_CLOSURE || __mn->type == STRADA_CPOINTER) { __is_code = 1; } ");
        emit($cg, "  else if (__mn->type == STRADA_REF && __mn->value.rv && !STRADA_IS_TAGGED_INT(__mn->value.rv) ");
        emit($cg, "           && (__mn->value.rv->type == STRADA_CLOSURE || __mn->value.rv->type == STRADA_CPOINTER)) { __is_code = 1; __code = __mn->value.rv; } ");
        emit($cg, "} ");
        emit($cg, "if (__is_code) { __mr = perla_call_code(__code, __a); } ");
        emit($cg, "else { char *__dyn_method = strada_to_str(__mn); __mr = perla_method_dispatch(__obj, __dyn_method, __a); free(__dyn_method); } ");
        # Skip caller's incref — see comment near the main method dispatch.
        emit($cg, "strada_decref(__mn); strada_decref(__a); __mr; })");
        return;
    }

    # SUPER::method — call parent class method via runtime dispatch
    if (length($method) > 7 && substr($method, 0, 7) eq "SUPER::") {
        my str $super_method = substr($method, 7, length($method) - 7);
        my int $super_obj_borrowed = expr_is_borrowed($node->{"object"});
        emit($cg, "({ StradaValue *__obj = ");
        gen_expr($cg, $node->{"object"});
        emit($cg, "; StradaValue *__a = strada_new_array(); StradaArray *__av = strada_deref_array(__a); ");
        if ($super_obj_borrowed == 1) {
            emit($cg, "strada_array_push(__av, __obj); ");
        } else {
            emit($cg, "strada_array_push_take(__av, __obj); ");
        }
        _gen_push_args($cg, $args, $argc);
        emit($cg, "StradaValue *__mr = perla_super_dispatch(__obj, \"" . $cg->{"pkg"} . "\", \"" . $super_method . "\", __a); ");
        emit($cg, "strada_decref(__a); __mr; })");
        return;
    }

    my int $is_super = 0;
    my str $super_method = $method;

    # Try to dispatch: check blessed package + ISA hierarchy
    my scalar $subs = $cg->{"subs"};
    my array @sub_names = keys($subs);
    my int $si = 0;
    my int $found = 0;
    my str $only_fname = "";
    my str $only_qname = "";
    my str $dispatch_method = $super_method;  # use stripped name for SUPER::

    # First pass: count how many packages define this method
    while ($si < scalar(@sub_names)) {
        my str $qname = $sub_names[$si];
        my str $suffix = "::" . $dispatch_method;
        my int $slen = length($suffix);
        my int $qlen = length($qname);
        if ($qlen > $slen && substr($qname, $qlen - $slen, $slen) eq $suffix) {
            my str $mpkg = substr($qname, 0, $qlen - $slen);
            if ($is_super == 0 || $mpkg ne $cg->{"pkg"}) {
                $found++;
                $only_fname = sub_cname_q($qname);
                $only_qname = $qname;
            }
        }
        $si++;
    }

    # Optimization: if exactly one package defines this method, call directly (skip dispatch)
    # BUT: skip optimization if receiver is a method call result (type unknown at compile time)
    my int $receiver_is_method = 0;
    if (defined($node->{"object"}) && ($node->{"object"}->{"type"} == Perla::AST::N_METHOD() || $node->{"object"}->{"type"} == Perla::AST::N_CALL())) {
        $receiver_is_method = 1;
    }
    if ($found == 1 && $is_super == 0 && $receiver_is_method == 0 && 0) {
        # NOTE: __direct method dispatch disabled — runtime stubs registered via
        # perla_code_set need perla_method_dispatch to be found. Direct calls
        # bypass the stash and call the compiled version, ignoring overrides.
        my scalar $mpinfo = $cg->{"sub_params"}->{$only_qname};
        if (defined($mpinfo) && $mpinfo->{"arity"} == $argc + 1 && Perla::CodeGen::Predicate::args_are_simple($args, $argc) == 1) {
            # Direct-arg call: no array allocation at all
            emit($cg, "({ StradaValue *__obj = ");
            gen_expr($cg, $node->{"object"});
            emit($cg, "; " . $only_fname . "__direct(__obj");
            my int $ai = 0;
            while ($ai < $argc) {
                emit($cg, ", ");
                gen_expr($cg, $args->[$ai]);
                $ai++;
            }
            # Trailing perla_args_full = NULL (build from named params).
            emit($cg, ", NULL); })");
        } else if ($argc == 0) {
            # Single-package, no extra args: stack-allocated 1-element array.
            # stack_args1_init incref's __obj (mirrors heap-array push so
            # `shift @_` inside the callee doesn't underflow refcount).
            # Post-call: decref only the elements still in the array
            # (matches what strada_decref(heap_array) would have done by
            # walking [head, head+size) on free) — if the callee shifted,
            # size=0 and the element is now owned by the callee's local,
            # which will decref via its own scope cleanup.
            emit($cg, "({ StradaValue *__obj = ");
            gen_expr($cg, $node->{"object"});
            emit($cg, "; StradaStackArgs1 __sa; strada_stack_args1_init(&__sa, __obj); ");
            emit($cg, "StradaValue *__sa_rv = " . $only_fname . "(&__sa.sv); ");
            emit($cg, "for (size_t __sai = 0; __sai < __sa.av.size; __sai++) { StradaValue *__sae = __sa.av.elements[__sa.av.head + __sai]; if (__sae && !STRADA_IS_TAGGED_INT(__sae)) strada_decref(__sae); } __sa_rv; })");
        } else {
            # Single-package, with extra args: need heap array
            emit($cg, "({ StradaValue *__obj = ");
            gen_expr($cg, $node->{"object"});
            emit($cg, "; StradaValue *__a = strada_new_array(); StradaArray *__av = strada_deref_array(__a); ");
            emit($cg, "strada_array_push(__av, __obj); ");
            _gen_push_args($cg, $args, $argc);
            emit($cg, "StradaValue *__mr = " . $only_fname . "(__a); strada_incref(__mr); strada_decref(__a); __mr; })");
        }
        return;
    }

    # Build args array with $self as first element (multi-dispatch case).
    # Force scalar context around the receiver expression: if the receiver
    # is itself a method/call (i.e. `$x->A->B`), A's return is being USED
    # as B's invocant, which is scalar context in Perl. Without this save/
    # set/restore, A inherits the outer statement's want_list (often -1 /
    # void) and wantarray inside A returns undef — DBIC's `->search`
    # throws "->search is *not* a mutator, calling it in void context".
    # Use push_take for owned invocants (method chain: `$x->A->B`, the
    # A result is owned and should transfer its ref to __a, not get
    # incref'd). For variable invocants ($obj->method, $self->method),
    # the variable retains its slot ref and we incref via push.
    my int $obj_borrowed = expr_is_borrowed($node->{"object"});
    # Bareword-as-class-name shortcut: `main->method`, `Foo->method`,
    # `Some::Pkg->method` etc — the parser left the object as an N_CALL
    # with no args. Evaluating it as a sub call trips strict 'subs' for
    # the unregistered bareword (perl exempts these because of the `->`
    # context). Emit the name as a literal string so the method dispatcher
    # treats it as a class name (perla_method_dispatch already accepts a
    # STRADA_STR class-name invocant).
    my int $obj_is_bareword_class = 0;
    my str $obj_class_lit = "";
    my scalar $__mc_obj = $node->{"object"};
    if (defined($__mc_obj) && $__mc_obj->{"type"} == Perla::AST::N_CALL()
        && defined($__mc_obj->{"name"})
        && (!defined($__mc_obj->{"args"}) || scalar(@{$__mc_obj->{"args"}}) == 0)) {
        my str $bn = $__mc_obj->{"name"};
        # Only IDENT-shaped names (letters/digits/_/::). Skip anything
        # that's already a registered sub (those should dispatch normally).
        if (length($bn) > 0) {
            my int $is_ident_shape = 1;
            my int $ci = 0;
            while ($ci < length($bn)) {
                my str $cc = substr($bn, $ci, 1);
                if (!(($cc ge "a" && $cc le "z") || ($cc ge "A" && $cc le "Z")
                      || ($cc ge "0" && $cc le "9") || $cc eq "_" || $cc eq ":")) {
                    $is_ident_shape = 0;
                    $ci = length($bn);
                } else {
                    $ci = $ci + 1;
                }
            }
            if ($is_ident_shape == 1 && _resolve_sub($cg, $bn) eq "") {
                # Exclude known builtins that take no args / are named
                # unaries: `shift->method`, `pop->method`,
                # `caller->method`, etc. should actually call the
                # builtin and use the return as invocant — not treat
                # the builtin's name as a bareword class. Without this,
                # `sub throw { die shift->new(@_) }` died because
                # `shift` was bound as the class string.
                if ($bn eq "shift" || $bn eq "pop" || $bn eq "time"
                    || $bn eq "caller" || $bn eq "wantarray"
                    || $bn eq "fileno" || $bn eq "eof"
                    || $bn eq "ref" || $bn eq "defined"
                    || $bn eq "scalar" || $bn eq "blessed"
                    || $bn eq "reftype" || $bn eq "length") {
                    # Skip — let the call evaluate normally.
                } else {
                    $obj_is_bareword_class = 1;
                    $obj_class_lit = $bn;
                }
            }
        }
    }
    # Stack-allocated args wrapper for the single-arg case ($obj->method()
    # with no extra args). Saves the per-call heap array alloc + push
    # incref + decref-walk cost. Only safe when the callee can't escape
    # @_ as a REF outliving the call — the receivers we route here
    # (bench_oop `$c->increment()` is the canonical case) always
    # take @_ as a borrowed accessor for $_[0]. Pkg-bareword-class
    # invocants stay on the heap-args path so the just-malloc'd
    # class-name string can transfer ownership cleanly.
    my int $use_stack_args = 0;
    if ($argc == 0 && $obj_is_bareword_class == 0) {
        $use_stack_args = 1;
    }
    emit($cg, "({ StradaValue *__obj = ({ int __sav_wl_obj = __perla_want_list; __perla_want_list = 0; StradaValue *__inner_obj = ");
    if ($obj_is_bareword_class == 1) {
        emit($cg, "strada_new_str(\"" . $obj_class_lit . "\")");
    } else {
        gen_expr($cg, $node->{"object"});
    }
    if ($use_stack_args == 1) {
        # Stack args path — no heap array, no push/decref dance. The
        # wrapper is refcount=INT_MAX so any incidental incref/decref
        # by the callee is a no-op.
        emit($cg, "; __perla_want_list = __sav_wl_obj; __inner_obj; }); StradaStackArgs1 __sa; strada_stack_args1_init(&__sa, __obj); ");
    } else {
        emit($cg, "; __perla_want_list = __sav_wl_obj; __inner_obj; }); StradaValue *__a = strada_new_array(); StradaArray *__av = strada_deref_array(__a); ");
        if ($obj_borrowed == 1) {
            emit($cg, "strada_array_push(__av, __obj); ");
        } else {
            emit($cg, "strada_array_push_take(__av, __obj); ");
        }
        _gen_push_args($cg, $args, $argc);
    }

    # Multiple packages define this method — full dispatch
    emit($cg, "StradaValue *__result = NULL; int __dispatched = 0; ");
    emit($cg, "const char *__pkg = perla_blessed(__obj); ");

    # First pass: assign branch IDs and emit all static cache decls
    # together BEFORE the if/elseif chain. Mixing `static X = NULL;`
    # declarations between if-branches is illegal C (`else without a
    # previous if`); group them up front.
    if (!defined($cg->{"dispatch_branch_counter"})) {
        $cg->{"dispatch_branch_counter"} = 0;
    }
    my array @br_ids = ();
    my array @br_pkgs = ();
    my array @br_qnames = ();
    $si = 0;
    while ($si < scalar(@sub_names)) {
        my str $qname = $sub_names[$si];
        my str $suffix = "::" . $dispatch_method;
        my int $slen = length($suffix);
        my int $qlen = length($qname);
        if ($qlen > $slen && substr($qname, $qlen - $slen, $slen) eq $suffix) {
            my str $pkg = substr($qname, 0, $qlen - $slen);
            if (!($is_super == 1 && $pkg eq $cg->{"pkg"})
                && !exists($cg->{"moose_pkgs"}->{$pkg})) {
                my int $br_n = $cg->{"dispatch_branch_counter"};
                $cg->{"dispatch_branch_counter"} = $br_n + 1;
                push(@br_ids, $br_n);
                push(@br_pkgs, $pkg);
                push(@br_qnames, $qname);
                emit($cg, "static const char *__pkg_c_" . $br_n . " = NULL; ");
                emit($cg, "static PerlGlob *__og_c_" . $br_n . " = NULL; ");
            }
        }
        $si++;
    }

    $si = 0;
    $found = 0;
    while ($si < scalar(@br_ids)) {
        my int $br_n = $br_ids[$si];
        my str $pkg = $br_pkgs[$si];
        my str $qname = $br_qnames[$si];
        my str $fname = sub_cname_q($qname);
        # Already filtered by first pass; emit branches in order.
            my str $pkg_c_var = "__pkg_c_" . $br_n;
            my str $og_c_var = "__og_c_" . $br_n;
            my str $cond = "__pkg && (__pkg == " . $pkg_c_var . " || (!" . $pkg_c_var . " && strcmp(__pkg, \"" . $pkg . "\") == 0))";
            my str $branch_kw = "if";
            if ($found > 0) { $branch_kw = "else if"; }
            emit($cg, $branch_kw . " (" . $cond . ") { ");
            emit($cg, "if (__builtin_expect(!" . $pkg_c_var . ", 0)) " . $pkg_c_var . " = __pkg; ");
            emit($cg, "PerlGlob *__og = " . $og_c_var . "; ");
            emit($cg, "if (__builtin_expect(!__og, 0)) { __og = perla_glob_get_or_create(perla_stash_get_or_create(\"" . $pkg . "\"), \"" . $dispatch_method . "\"); " . $og_c_var . " = __og; } ");
            emit($cg, "StradaValue *__os = __og->slots[PERLA_SLOT_CODE]; ");
            emit($cg, "if (__builtin_expect(__os && !STRADA_IS_TAGGED_INT(__os) ");
            emit($cg, "    && (__os->type == STRADA_CLOSURE || __os->type == STRADA_CPOINTER ");
            emit($cg, "        || (__os->type == STRADA_REF && __os->value.rv && !STRADA_IS_TAGGED_INT(__os->value.rv) ");
            emit($cg, "            && (__os->value.rv->type == STRADA_CLOSURE || __os->value.rv->type == STRADA_CPOINTER))), 0)) { ");
            if ($use_stack_args == 1) {
                emit($cg, "  __result = perla_call_code(__os, &__sa.sv); ");
                emit($cg, "} else { __result = " . $fname . "(&__sa.sv); } __dispatched = 1; } ");
            } else {
                emit($cg, "  __result = perla_call_code(__os, __a); ");
                emit($cg, "} else { __result = " . $fname . "(__a); } __dispatched = 1; } ");
            }
            $found++;
        $si++;
    }
    if ($found > 0) {
        $si = 0;
        while ($si < scalar(@sub_names)) {
            my str $qname = $sub_names[$si];
            my str $suffix = "::" . $dispatch_method;
            my int $slen = length($suffix);
            my int $qlen = length($qname);
            if ($qlen > $slen && substr($qname, $qlen - $slen, $slen) eq $suffix) {
                my str $pkg = substr($qname, 0, $qlen - $slen);
                if ($is_super == 1 && $pkg eq $cg->{"pkg"}) { $si++; next; }
                my str $fname = sub_cname_q($qname);
                # Skip isa-based fallback: it can call parent method instead of child's override.
                # perla_method_dispatch handles inheritance correctly.
            }
            $si++;
        }
        # Last resort: use runtime method dispatch instead of static fallback
        # Static fallback can cause infinite recursion when the same method name
        # exists in both parent and child classes (e.g., search -> rs -> search)
        if ($use_stack_args == 1) {
            emit($cg, "if (!__dispatched) { __result = perla_method_dispatch(__obj, \"" . $dispatch_method . "\", &__sa.sv); __dispatched = 1; } ");
        } else {
            emit($cg, "if (!__dispatched) { __result = perla_method_dispatch(__obj, \"" . $dispatch_method . "\", __a); __dispatched = 1; } ");
        }
    }
    # Runtime method dispatch fallback: check the stash for methods not known at compile time
    # (e.g., from precompiled modules loaded via .o files)
    if ($found == 0) {
        if ($use_stack_args == 1) {
            emit($cg, "if (!__dispatched) { __result = perla_method_dispatch(__obj, \"" . $dispatch_method . "\", &__sa.sv); __dispatched = 1; } ");
        } else {
            emit($cg, "if (!__dispatched) { __result = perla_method_dispatch(__obj, \"" . $dispatch_method . "\", __a); __dispatched = 1; } ");
        }
    }
    # AUTOLOAD fallback: if no method was dispatched, try AUTOLOAD
    if ($use_stack_args == 1) {
        emit($cg, "if (!__dispatched && __pkg) { StradaValue *__al = perla_try_autoload(__pkg, \"" . $dispatch_method . "\", __obj, &__sa.sv); if (__al) { __result = __al; __dispatched = 1; } } ");
    } else {
        emit($cg, "if (!__dispatched && __pkg) { StradaValue *__al = perla_try_autoload(__pkg, \"" . $dispatch_method . "\", __obj, __a); if (__al) { __result = __al; __dispatched = 1; } } ");
    }
    emit($cg, "if (!__result) __result = strada_new_undef(); ");
    # @_ aliasing write-back for method calls. Same shape as plain sub
    # calls — when an arg is a bare N_SCALAR_VAR, propagate any change
    # the callee made to the slot back to the caller's variable. Index
    # 0 of __a is the object, so user args start at 1.
    my int $mwb_ai = 0;
    while ($mwb_ai < $argc) {
        my scalar $mwb_arg = $args->[$mwb_ai];
        if (defined($mwb_arg) && $mwb_arg->{"type"} == Perla::AST::N_SCALAR_VAR()
            && defined($mwb_arg->{"name"}) && length($mwb_arg->{"name"}) > 0
            && index($mwb_arg->{"name"}, "::") < 0
            && $mwb_arg->{"name"} ne "_" && $mwb_arg->{"name"} ne "@") {
            my str $mwb_name = $mwb_arg->{"name"};
            my int $mwb_is_ro = 0;
            if (length($mwb_name) == 1) {
                my int $mwb_c0 = char_at($mwb_name, 0);
                if ($mwb_c0 >= 49 && $mwb_c0 <= 57) { $mwb_is_ro = 1; }
                if ($mwb_name eq "&" || $mwb_name eq "`" || $mwb_name eq "'" || $mwb_name eq "+") { $mwb_is_ro = 1; }
            }
            if ($mwb_is_ro == 0) {
                my str $mwb_cv = c_var($mwb_name);
                # Arg slot in __a is at position $mwb_ai + 1 (slot 0 is __obj).
                my int $mwb_slot = $mwb_ai + 1;
                emit($cg, "if (__av && __av->size > " . $mwb_slot . ") { ");
                emit($cg, "StradaValue *__mwb" . $mwb_ai . " = strada_array_get(__av, " . $mwb_slot . "); ");
                emit($cg, "if (__mwb" . $mwb_ai . " != " . $mwb_cv . ") { ");
                emit($cg, "if (__mwb" . $mwb_ai . ") strada_incref(__mwb" . $mwb_ai . "); ");
                emit($cg, "strada_decref(" . $mwb_cv . "); " . $mwb_cv . " = __mwb" . $mwb_ai . "; } } ");
            }
        }
        $mwb_ai = $mwb_ai + 1;
    }
    # Skip caller's incref — the callee's conditional incref (for borrowed
    # returns like $_[0]) already transferred ownership. The strada_decref(__a)
    # below balances push's incref for borrowed invocants (push_take for
    # owned invocants already consumed the ref). Net: __result has exactly
    # one logical owner.
    if ($use_stack_args == 1) {
        # Stack-args path: SV/AV are stack-resident (refcount=INT_MAX),
        # but stack_args1_init incref'd __obj. Walk the post-call array
        # range [head, head+size) and decref the elements still there
        # — matches what strada_decref on a heap-allocated args array
        # would have done by walking [head, head+size) on free. If the
        # callee shifted, size=0 and ownership moved to the callee's
        # local; otherwise we decref to balance init's incref.
        emit($cg, "for (size_t __sai = 0; __sai < __sa.av.size; __sai++) { StradaValue *__sae = __sa.av.elements[__sa.av.head + __sai]; if (__sae && !STRADA_IS_TAGGED_INT(__sae)) strada_decref(__sae); } __result; })");
    } else {
        emit($cg, "strada_decref(__a); __result; })");
    }
}


# --- Helper: format body lexical bridge ---
# Scan a format body string for `$IDENT` references in value lines and
# return the unique list of identifiers that are file-scope lexicals.
# Value lines are the lines following any picture line containing `@`
# or `^` fields. Only simple `$IDENT` references count (no `$h{k}`,
# `$a[N]`, `$_->{x}`, etc. — those keep flowing through the runtime
# parser, which already handles `$_`-chains and stash lookups).
# Collect format-body value-line lex refs that are SUB-LOCAL — declared
# in the current scope (declared_vars) but NOT in file_scope_vars or
# our_vars. These need inline sync at every write site since the
# file-scope sync helper can't `extern` stack-allocated lexicals.
func _collect_format_sub_lex_refs(scalar $cg, str $body) array {
    my array @refs = ();
    my hash %seen = ();
    my int $blen = length($body);
    my int $i = 0;
    my int $expect_values = 0;
    while ($i < $blen) {
        my int $eol = $i;
        while ($eol < $blen && substr($body, $eol, 1) ne "\n") { $eol = $eol + 1; }
        my str $line = substr($body, $i, $eol - $i);
        my int $lln = length($line);
        if ($expect_values == 1) {
            my int $j = 0;
            while ($j < $lln) {
                my str $ch = substr($line, $j, 1);
                if ($ch eq "\$" && $j + 1 < $lln) {
                    my str $nc = substr($line, $j + 1, 1);
                    if (($nc ge "a" && $nc le "z") || ($nc ge "A" && $nc le "Z") || $nc eq "_") {
                        my int $ks = $j + 1;
                        my int $ke = $ks;
                        while ($ke < $lln) {
                            my str $kc = substr($line, $ke, 1);
                            if (($kc ge "a" && $kc le "z") || ($kc ge "A" && $kc le "Z") || ($kc ge "0" && $kc le "9") || $kc eq "_") {
                                $ke = $ke + 1;
                            } else { last; }
                        }
                        my str $name = substr($line, $ks, $ke - $ks);
                        my int $is_special = 0;
                        if ($name eq "_") { $is_special = 1; }
                        if ($is_special == 0 && !defined($seen{$name})) {
                            my int $is_file = 0;
                            if (defined($cg->{"file_scope_vars"}) && defined($cg->{"file_scope_vars"}->{$name})) {
                                $is_file = 1;
                            }
                            my int $is_sub_local = 0;
                            if ($is_file == 0
                                && defined($cg->{"declared_vars"})
                                && defined($cg->{"declared_vars"}->{"v_" . $name})) {
                                $is_sub_local = 1;
                            }
                            if ($is_sub_local == 1) {
                                push(@refs, $name);
                                $seen{$name} = 1;
                            }
                        }
                        $j = $ke;
                        next;
                    }
                }
                $j = $j + 1;
            }
            $expect_values = 0;
        } else {
            my int $j = 0;
            my int $has_field = 0;
            while ($j < $lln) {
                my str $cc = substr($line, $j, 1);
                if ($cc eq "@" || $cc eq "^") {
                    if ($j + 1 < $lln) {
                        my str $nx = substr($line, $j + 1, 1);
                        if ($nx eq "<" || $nx eq ">" || $nx eq "|" || $nx eq "#" || $nx eq "." || $nx eq "*") {
                            $has_field = 1; last;
                        }
                    }
                }
                $j = $j + 1;
            }
            if ($has_field == 1) { $expect_values = 1; }
        }
        $i = $eol + 1;
    }
    return @refs;
}

func _collect_format_lex_refs(scalar $cg, str $body) array {
    my array @refs = ();
    my hash %seen = ();
    my int $blen = length($body);
    my int $i = 0;
    my int $expect_values = 0;
    while ($i < $blen) {
        # Find end of line
        my int $eol = $i;
        while ($eol < $blen && substr($body, $eol, 1) ne "\n") { $eol = $eol + 1; }
        my str $line = substr($body, $i, $eol - $i);
        my int $lln = length($line);
        if ($expect_values == 1) {
            # Scan value line for `$IDENT`
            my int $j = 0;
            while ($j < $lln) {
                my str $ch = substr($line, $j, 1);
                if ($ch eq "\$" && $j + 1 < $lln) {
                    my str $nc = substr($line, $j + 1, 1);
                    if (($nc ge "a" && $nc le "z") || ($nc ge "A" && $nc le "Z") || $nc eq "_") {
                        # Read ident
                        my int $ks = $j + 1;
                        my int $ke = $ks;
                        while ($ke < $lln) {
                            my str $kc = substr($line, $ke, 1);
                            if (($kc ge "a" && $kc le "z") || ($kc ge "A" && $kc le "Z") || ($kc ge "0" && $kc le "9") || $kc eq "_") {
                                $ke = $ke + 1;
                            } else { last; }
                        }
                        my str $name = substr($line, $ks, $ke - $ks);
                        # Skip special vars handled directly by the runtime
                        # value parser ($_, $/, $\, etc.) — bridging them
                        # to a stash slot would shadow the runtime's
                        # global-mirror lookup. $_ in particular is
                        # served by perla_dollar_underscore, not v__.
                        my int $is_special = 0;
                        if ($name eq "_") { $is_special = 1; }
                        if ($is_special == 0 && !defined($seen{$name})) {
                            my int $is_lex = 0;
                            if (defined($cg->{"file_scope_vars"}) && defined($cg->{"file_scope_vars"}->{$name})) {
                                $is_lex = 1;
                            }
                            # `our`/package vars also have a file-static C
                            # local `v_NAME`, but assigning to them updates
                            # only that local — NOT the stash glob slot the
                            # format value-parser reads. Bridge them through
                            # the same mangled-name sync so reassigned our-vars
                            # render (the classic `our` format-report idiom).
                            if ($is_lex == 0 && defined($cg->{"our_vars"}) && defined($cg->{"our_vars"}->{$name})) {
                                $is_lex = 1;
                            }
                            if ($is_lex == 1) {
                                push(@refs, $name);
                                $seen{$name} = 1;
                            }
                        }
                        $j = $ke;
                        next;
                    }
                }
                $j = $j + 1;
            }
            $expect_values = 0;
        } else {
            # Picture line? Has `@` or `^` field markers?
            my int $j = 0;
            my int $has_field = 0;
            while ($j < $lln) {
                my str $cc = substr($line, $j, 1);
                if ($cc eq "@" || $cc eq "^") {
                    if ($j + 1 < $lln) {
                        my str $nx = substr($line, $j + 1, 1);
                        if ($nx eq "<" || $nx eq ">" || $nx eq "|" || $nx eq "#" || $nx eq "." || $nx eq "*") {
                            $has_field = 1; last;
                        }
                    }
                }
                $j = $j + 1;
            }
            if ($has_field == 1) { $expect_values = 1; }
        }
        $i = $eol + 1;
    }
    return @refs;
}

# Rewrite a format body in place: replace each `$IDENT` reference in a
# value line with `$__perla_lex_IDENT` if IDENT is in the lex-refs list.
# Picture lines stay untouched. Returns the new body string.
func _rewrite_format_body_for_lex(str $body, scalar $refs_aref) str {
    my array @refs = @{$refs_aref};
    if (scalar(@refs) == 0) { return $body; }
    my hash %ref_set = ();
    my int $ri = 0;
    while ($ri < scalar(@refs)) {
        $ref_set{$refs[$ri]} = 1;
        $ri = $ri + 1;
    }
    my str $out = "";
    my int $blen = length($body);
    my int $i = 0;
    my int $in_values = 0;
    while ($i < $blen) {
        my int $eol = $i;
        while ($eol < $blen && substr($body, $eol, 1) ne "\n") { $eol = $eol + 1; }
        my str $line = substr($body, $i, $eol - $i);
        my int $lln = length($line);
        if ($in_values == 1) {
            # Rewrite each `$IDENT` if IDENT in ref_set
            my str $rline = "";
            my int $j = 0;
            while ($j < $lln) {
                my str $ch = substr($line, $j, 1);
                if ($ch eq "\$" && $j + 1 < $lln) {
                    my str $nc = substr($line, $j + 1, 1);
                    if (($nc ge "a" && $nc le "z") || ($nc ge "A" && $nc le "Z") || $nc eq "_") {
                        my int $ks = $j + 1;
                        my int $ke = $ks;
                        while ($ke < $lln) {
                            my str $kc = substr($line, $ke, 1);
                            if (($kc ge "a" && $kc le "z") || ($kc ge "A" && $kc le "Z") || ($kc ge "0" && $kc le "9") || $kc eq "_") {
                                $ke = $ke + 1;
                            } else { last; }
                        }
                        my str $name = substr($line, $ks, $ke - $ks);
                        if (defined($ref_set{$name})) {
                            $rline = $rline . "\$__perla_lex_" . $name;
                        } else {
                            $rline = $rline . "\$" . $name;
                        }
                        $j = $ke;
                        next;
                    }
                }
                $rline = $rline . $ch;
                $j = $j + 1;
            }
            $out = $out . $rline;
            $in_values = 0;
        } else {
            $out = $out . $line;
            # Detect picture line
            my int $j = 0;
            my int $has_field = 0;
            while ($j < $lln) {
                my str $cc = substr($line, $j, 1);
                if ($cc eq "@" || $cc eq "^") {
                    if ($j + 1 < $lln) {
                        my str $nx = substr($line, $j + 1, 1);
                        if ($nx eq "<" || $nx eq ">" || $nx eq "|" || $nx eq "#" || $nx eq "." || $nx eq "*") {
                            $has_field = 1; last;
                        }
                    }
                }
                $j = $j + 1;
            }
            if ($has_field == 1) { $in_values = 1; }
        }
        if ($eol < $blen) { $out = $out . "\n"; }
        $i = $eol + 1;
    }
    return $out;
}

# --- Helper: C-safe variable name ---
# Sanitize a Perl name to a valid C identifier (no v_ prefix)
func safe_ident(str $name) str {
    # Strip non-printable bytes (chr(1), chr(2)) used internally by
    # the interpolation codegen as field separators. These leak into
    # identifier construction in some paths (e.g. complex interpolated
    # hash keys in DBIx::Class::Storage::DBI's bind-cache lookups);
    # without stripping them, gcc rejects the .pm.c with
    # `stray '\1' in program`.
    my str $safe = replace_all($name, chr(1), "_");
    $safe = replace_all($safe, chr(2), "_");
    $safe = replace_all($safe, "::", "_");
    $safe = replace_all($safe, "^", "_caret_");
    $safe = replace_all($safe, "]", "_rbrack_");
    $safe = replace_all($safe, "[", "_lbrack_");
    $safe = replace_all($safe, ":", "_colon_");
    $safe = replace_all($safe, "!", "_bang_");
    $safe = replace_all($safe, "?", "_qmark_");
    $safe = replace_all($safe, "$", "_dollar_");
    $safe = replace_all($safe, "@", "_at_");
    $safe = replace_all($safe, "-", "_dash_");
    $safe = replace_all($safe, "/", "_slash_");
    $safe = replace_all($safe, "\\", "_bslash_");
    $safe = replace_all($safe, ".", "_dot_");
    $safe = replace_all($safe, "+", "_plus_");
    $safe = replace_all($safe, " ", "_sp_");
    $safe = replace_all($safe, "|", "_pipe_");
    $safe = replace_all($safe, "#", "_hash_");
    $safe = replace_all($safe, "'", "_sq_");
    $safe = replace_all($safe, ";", "_semi_");
    $safe = replace_all($safe, "%", "_pct_");
    $safe = replace_all($safe, "&", "_amp_");
    $safe = replace_all($safe, "*", "_star_");
    $safe = replace_all($safe, "~", "_tilde_");
    $safe = replace_all($safe, "<", "_lt_");
    $safe = replace_all($safe, ",", "_comma_");
    $safe = replace_all($safe, ">", "_gt_");
    $safe = replace_all($safe, "=", "_eq_");
    $safe = replace_all($safe, "(", "_lp_");
    $safe = replace_all($safe, ")", "_rp_");
    $safe = replace_all($safe, "{", "_lb_");
    $safe = replace_all($safe, "}", "_rb_");
    $safe = replace_all($safe, "\"", "_dq_");
    $safe = replace_all($safe, "`", "_bt_");
    return $safe;
}

func c_var(str $name) str {
    return "v_" . safe_ident($name);
}

# Sigil-aware C variable names. `my $foo` and `my %foo` (or `my @foo`)
# in the same scope are separate Perl variables but would otherwise
# compile to the same C `v_foo`. File::Spec.pm trips this:
#   my %module = (MSWin32 => 'Win32', ...);
#   my $module = $module{$^O} || 'Unix';
# Scalars keep `v_NAME`; hashes append `__h`, arrays `__a`.
# Collision-only mangling: only append __h/__a for names that we detect
# are declared under multiple sigils (e.g., both `my %module` and
# `my $module` in the same file). Non-colliding names keep `v_NAME` so
# they match legacy-style access sites that haven't been sigil-migrated
# and so that `$config->{key}` accessing a `%config`-declared hash still
# reads the same C variable.
my hash %__perla_mangle_collisions = ();
my hash %__perla_seen_sigils = ();
# Per-named-sub local collisions (qname → hashref of var names).
# Captured during collection by save/reset/recurse/restore around sub bodies,
# so intra-sub collisions don't bleed into the file-scope map. At codegen
# time, gen_sub_def merges file-scope collisions with the sub's local
# collisions before emitting body, then restores file-scope on exit.
my hash %__perla_sub_collisions = ();
my hash %__perla_file_collisions_snapshot = ();

func c_var_h(str $name) str {
    if (exists($__perla_mangle_collisions{$name})) {
        return "v_" . safe_ident($name) . "__h";
    }
    # `%INC` (the loaded-modules hash) is distinct from `@INC` (the
    # require-search-paths array). Route to a separate file-scope
    # static backed by the runtime's g_INC_hash so `keys %INC`,
    # `exists $INC{"X.pm"}` etc. reflect what `use`/`require` actually
    # loaded.
    if ($name eq "INC") {
        return "v_INC__h";
    }
    return c_var($name);
}

func c_var_a(str $name) str {
    if (exists($__perla_mangle_collisions{$name})) {
        return "v_" . safe_ident($name) . "__a";
    }
    return c_var($name);
}

func _perla_record_var_sigil(str $name, str $sigil) void {
    if (length($name) == 0) { return; }
    if (!exists($__perla_seen_sigils{$name})) {
        $__perla_seen_sigils{$name} = $sigil;
    } elsif ("" . $__perla_seen_sigils{$name} ne $sigil) {
        $__perla_mangle_collisions{$name} = 1;
    }
}

func _perla_reset_mangle_collisions() void {
    %__perla_mangle_collisions = ();
    %__perla_seen_sigils = ();
    %__perla_sub_collisions = ();
    %__perla_file_collisions_snapshot = ();
}

# Shallow-clone a hash through a hashref, returning a hashref of (key=>1) entries.
# For collision-set save/restore where presence is what matters.
func _perla_clone_hash(scalar $href) scalar {
    my hash %out = ();
    if (defined($href)) {
        my array @ks = keys(%{$href});
        my int $i = 0;
        while ($i < scalar(@ks)) {
            my str $k = $ks[$i];
            $out{$k} = 1;
            $i++;
        }
    }
    return \%out;
}

# Shallow-clone a hash preserving values (for seen_sigils which stores
# string sigils that need to round-trip).
func _perla_clone_hash_with_vals(scalar $href) scalar {
    my hash %out = ();
    if (defined($href)) {
        my array @ks = keys(%{$href});
        my int $i = 0;
        while ($i < scalar(@ks)) {
            my str $k = $ks[$i];
            my str $v = "" . $href->{$k};
            $out{$k} = $v;
            $i++;
        }
    }
    return \%out;
}

# Restore %__perla_seen_sigils from a saved hashref (preserves sigil string values).
func _perla_restore_seen_sigils(scalar $saved) void {
    %__perla_seen_sigils = ();
    if (defined($saved)) {
        my array @ks = keys(%{$saved});
        my int $i = 0;
        while ($i < scalar(@ks)) {
            my str $k = $ks[$i];
            my str $v = "" . $saved->{$k};
            $__perla_seen_sigils{$k} = $v;
            $i++;
        }
    }
}

# Restore %__perla_mangle_collisions from a saved hashref (presence-only).
func _perla_restore_collisions_inplace(scalar $saved) void {
    %__perla_mangle_collisions = ();
    if (defined($saved)) {
        my array @ks = keys(%{$saved});
        my int $i = 0;
        while ($i < scalar(@ks)) {
            my str $k = $ks[$i];
            $__perla_mangle_collisions{$k} = 1;
            $i++;
        }
    }
}

# Activate a sub's effective collision map: file-scope ∪ sub-local.
# Returns the previous map (as a hashref) so the caller can restore on exit.
func perla_activate_sub_collisions(str $qname) scalar {
    my scalar $saved = _perla_clone_hash(\%__perla_mangle_collisions);
    %__perla_mangle_collisions = ();
    my array @fks = keys(%__perla_file_collisions_snapshot);
    my int $fi = 0;
    while ($fi < scalar(@fks)) {
        my str $fk = $fks[$fi];
        $__perla_mangle_collisions{$fk} = 1;
        $fi++;
    }
    # Union sub-local
    if (length($qname) > 0 && exists($__perla_sub_collisions{$qname})) {
        my scalar $sub_local = $__perla_sub_collisions{$qname};
        my array @sks = keys(%{$sub_local});
        my int $si = 0;
        while ($si < scalar(@sks)) {
            my str $sk = $sks[$si];
            $__perla_mangle_collisions{$sk} = 1;
            $si++;
        }
    }
    return $saved;
}

func perla_restore_collisions(scalar $saved_ref) void {
    %__perla_mangle_collisions = ();
    if (defined($saved_ref)) {
        my array @ks = keys(%{$saved_ref});
        my int $i = 0;
        while ($i < scalar(@ks)) {
            my str $k = $ks[$i];
            $__perla_mangle_collisions{$k} = 1;
            $i++;
        }
    }
}

# Snapshot the current %__perla_mangle_collisions as the file-scope view.
func _perla_snapshot_file_collisions() void {
    %__perla_file_collisions_snapshot = ();
    my array @ks = keys(%__perla_mangle_collisions);
    my int $i = 0;
    while ($i < scalar(@ks)) {
        my str $k = $ks[$i];
        $__perla_file_collisions_snapshot{$k} = 1;
        $i++;
    }
}

# Pick C name from a var-decl sigil string ("SCALAR_VAR"/"HASH_VAR"/"ARRAY_VAR")
func c_var_for_vtype(str $vtype, str $name) str {
    if ($vtype eq "HASH_VAR") { return c_var_h($name); }
    if ($vtype eq "ARRAY_VAR") { return c_var_a($name); }
    return c_var($name);
}

# Pick C name from an AST var-access node's numeric type
func _c_var_for_node(scalar $node) str {
    if (!defined($node)) { return c_var(""); }
    my str $name = defined($node->{"name"}) ? $node->{"name"} : "";
    if (defined($node->{"type"})) {
        if ($node->{"type"} == Perla::AST::N_HASH_VAR()) { return c_var_h($name); }
        if ($node->{"type"} == Perla::AST::N_ARRAY_VAR()) { return c_var_a($name); }
    }
    return c_var($name);
}

func has_perl_var(str $s) int {
    my int $i = 0;
    my int $len = length($s);
    while ($i < $len - 1) {
        # Skip over backslash-escaped chars (e.g. \$ is a literal $).
        if (substr($s, $i, 1) eq "\\" && $i + 1 < $len) {
            $i = $i + 2;
            next;
        }
        if (substr($s, $i, 1) eq "$") {
            my str $next = substr($s, $i + 1, 1);
            if (($next ge "a" && $next le "z") || ($next ge "A" && $next le "Z") || $next eq "_") {
                return 1;
            }
            # `${...}` block form — also a variable interpolation.
            # Without this, code like `\"${pref}select\"` was treated as
            # a literal hash key and lookups against it always missed.
            # Specifically broke DBIx::Class::ResultSet::_normalize_selection
            # which uses `$attrs->{\"${pref}select\"}` to namespace its
            # +select / select keys — perla stored everything under one
            # bogus key \"${pref}select\" and the normalize loop ran with
            # the wrong attrs.
            if ($next eq "{") {
                return 1;
            }
            # Special scalars: $@, $!, $/, $\, $,, $;, $", $&, $`, $', $+, $|, $0
            # mirror the lexer's special-var list and the interp tokenizer's
            # branch. Without this, "[F] $@" got concat-optimized as a literal
            # C string (the @ wasn't ident-letter-or-underscore) so $@ never
            # got substituted — Class::C3::Componentised::ensure_class_loaded
            # passed an empty $@ to throw_exception, producing the
            # `{UNKNOWN}: at line` bizowie BZ:6 plateau.
            #
            # NOTE: $1..$9 are deliberately NOT in this list. They are regex
            # capture vars and need to pass through to PCRE2 as `$1`..`$9` in
            # s///-replacement strings (PCRE2 substitutes them itself). Marking
            # them as "has perl var" routes the replacement through
            # _gen_interp_c_str, which expands `$1` via Perla's variable
            # lookup (v_1 — usually undeclared/empty) before PCRE2 ever sees
            # it. The bare-string `$1` in a regular interpolation context is
            # already handled by the tokenizer's $1-$9 branch, which routes
            # to perla_capture_var().
            if ($next eq "@" || $next eq "!" || $next eq "/" || $next eq "\\" ||
                $next eq "," || $next eq ";" || $next eq "\"" || $next eq "&" ||
                $next eq "`" || $next eq "'" || $next eq "+" || $next eq "0" ||
                $next eq "|" || $next eq ".") {
                return 1;
            }
            # $$ (PID), $? (last child exit), $] (perl version),
            # $<, $>, $(, $) (UIDs/GIDs). Without these, interpolating
            # `"pid-$$"` left the key literal "pid-$$" and the hash
            # lookup missed.
            if ($next eq "\$" || $next eq "?" || $next eq "]" ||
                $next eq "<" || $next eq ">" || $next eq "(" || $next eq ")") {
                return 1;
            }
        }
        # `@var` array interpolation — same logic.
        if (substr($s, $i, 1) eq "@") {
            my str $next = substr($s, $i + 1, 1);
            if (($next ge "a" && $next le "z") || ($next ge "A" && $next le "Z") || $next eq "_" || $next eq "{") {
                return 1;
            }
        }
        $i = $i + 1;
    }
    return 0;
}

