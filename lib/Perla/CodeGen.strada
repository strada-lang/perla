        # `my $X` inside this do { } block doesn't leak into a sibling
        # block. Two adjacent `do { my $x = 0; sub { ... $x ... } }`
        # blocks otherwise reused the same `v_x` and the same closure
        # cell — the second closure captured the first's slot (state
        # bleed). Concrete victim: `inc => do{my$x=0; sub{++$x}},
        # more => do{my$x=0; sub{$x+=2}}` shared $x.
        my scalar $__db_saved_dv = $cg->{"declared_vars"};
        my scalar $__db_saved_ssd = $cg->{"same_scope_decls"};
        my scalar $__db_saved_sc = $cg->{"shared_cells_emitted"};
        my scalar $__db_saved_ml = $cg->{"my_lexicals"};
        my hash %__db_branch_dv = ();
        if (defined($__db_saved_dv)) {
            my array @__db_dvk = keys($__db_saved_dv);
            my int $__db_dvi = 0;
            while ($__db_dvi < scalar(@__db_dvk)) {
                $__db_branch_dv{$__db_dvk[$__db_dvi]} = $__db_saved_dv->{$__db_dvk[$__db_dvi]};
                $__db_dvi = $__db_dvi + 1;
            }
        }
        $cg->{"declared_vars"} = \%__db_branch_dv;
        $cg->{"same_scope_decls"} = {};
        my hash %__db_branch_sc = ();
        if (defined($__db_saved_sc)) {
            my array @__db_sck = keys($__db_saved_sc);
            my int $__db_sci = 0;
            while ($__db_sci < scalar(@__db_sck)) {
                $__db_branch_sc{$__db_sck[$__db_sci]} = $__db_saved_sc->{$__db_sck[$__db_sci]};
                $__db_sci = $__db_sci + 1;
            }
        }
        $cg->{"shared_cells_emitted"} = \%__db_branch_sc;
        my array @__db_branch_ml = ();
        if (defined($__db_saved_ml)) {
            my int $__db_mli = 0;
            while ($__db_mli < scalar(@{$__db_saved_ml})) {
                push(@__db_branch_ml, $__db_saved_ml->[$__db_mli]);
                $__db_mli = $__db_mli + 1;
            }
        }
        $cg->{"my_lexicals"} = \@__db_branch_ml;
