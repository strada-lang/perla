                    emit($cg, "; { PerlGlob *__og = perla_glob_get_or_create(perla_stash_get_or_create(\"" . $cg->{"pkg"} . "\"), \"" . $h_mirror_name . "\"); if (!__og->slots[PERLA_SLOT_HASH]) { __og->slots[PERLA_SLOT_HASH] = " . c_var_h($h_mirror_name) . "; if (" . c_var_h($h_mirror_name) . ") strada_incref(" . c_var_h($h_mirror_name) . "); } }");
