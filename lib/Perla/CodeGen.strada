            else { gen_expr($cg, $node->{"object"}); }
            emit($cg, $__fallback_emit);
            emit($cg, "; StradaValue *__o_orig = __o; StradaValue *__hov = (__o && !STRADA_IS_TAGGED_INT(__o) && __o->type == STRADA_REF) ? perla_overload_deref(__o, \"\%{}\") : NULL; if (__hov) __o = __hov; ");
            emit($cg, "StradaValue *__v = strada_hv_fetch_owned(__o, \"" . Perla::CodeGen::Escape::escape_c_str($akey->{"value"}) . "\"); ");
            if ($__ahx_obj_owned == 1) {
