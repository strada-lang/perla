    # User-defined function call — resolve qualified name
    my str $qname = _resolve_sub($cg, $name);
    if (length($qname) > 0) {
        my str $fname = sub_cname_q($qname);
        # `&sub` (no args, no parens) — pass the caller's @_ THROUGH so
        # the callee sees and can shift/pop it. Hash::Merge's `_get_obj`
        # depends on this.
        my int $is_amp_pass = 0;
        if (defined($node->{"pass_caller_args"}) && $node->{"pass_caller_args"} == 1) { $is_amp_pass = 1; }
        if ($is_amp_pass == 1) {
            emit($cg, $fname . "(perla_at_)");
            return;
        }
        # Split qname into pkg + short for the stash-override check.
        # Glob assignment (`*Pkg::sub = sub {...}`) replaces the CODE
        # slot with a non-STRADA_STR value; the original perla_code_set
        # registered it as STRADA_STR("perla_sub_Pkg_sub"). At each
        # call site, peek the slot — if it's been overridden (non-STR),
        # route through perla_call_code; otherwise fall through to the
        # direct C call. Without this, glob replacement was silently
        # ignored (Devel::Mock-style patterns, around-overrides at
        # runtime, etc.).
        my int $__qn_li = -1;
        my int $__qn_si = 0;
        while ($__qn_si < length($qname) - 1) {
            if (substr($qname, $__qn_si, 2) eq "::") { $__qn_li = $__qn_si; }
