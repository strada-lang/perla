        }
        $cg->{"hoisted_loop_vars"} = $__ev_saved_hoisted;
        $cg->{"hoisted_shadows"} = $__ev_saved_shadows;
        $cg->{"declared_vars"} = $__ev_saved_declared;
        $cg->{"same_scope_decls"} = $__ev_saved_ssd;
        ind($cg); emit($cg, "    STRADA_TRY_POP();\n");
        ind($cg); emit($cg, "    if (__perla_local_chain != __eval_local_mark) { perla_local_chain_restore_to(__perla_local_chain, __eval_local_mark); __perla_local_chain = __eval_local_mark; }\n");
        ind($cg); emit($cg, "    if (perla_eval_error) strada_decref(perla_eval_error);\n");
        ind($cg); emit($cg, "    perla_eval_error = strada_new_str(\"\");\n");
        ind($cg); emit($cg, "    perla_call_pop();\n");
        ind($cg); emit($cg, "  } else {\n");
        ind($cg); emit($cg, "    STRADA_TRY_POP();\n");
        ind($cg); emit($cg, "    __perla_want_list = __eval_sav_wl;\n");
        ind($cg); emit($cg, "    while (perla_call_depth > __eval_sav_depth) perla_call_pop();\n");
        ind($cg); emit($cg, "    if (__perla_local_chain != __eval_local_mark) { perla_local_chain_restore_to(__perla_local_chain, __eval_local_mark); __perla_local_chain = __eval_local_mark; }\n");
        # Die path: any partial inner-shadow value must be freed and
        # the outer pointer restored. The hoist's normal-exit decref
        # never runs on this branch (longjmp jumps past it).
        my int $__ev_csi = 0;
        while ($__ev_csi < scalar(@__ev_shadowed)) {
            my str $__ev_csc = $__ev_shadowed[$__ev_csi]->{"cname"};
            ind($cg); emit($cg, "    if (" . $__ev_csc . ") strada_decref(" . $__ev_csc . "); " . $__ev_csc . " = __ev_sav_" . $__ev_csc . ";\n");
            $__ev_csi = $__ev_csi + 1;
        }
        # If die set perla_eval_error to a ref, keep it; otherwise use exception_msg
        ind($cg); emit($cg, "    if (!perla_eval_error || !STRADA_IS_TAGGED_INT(perla_eval_error) && perla_eval_error->type == STRADA_STR && perla_eval_error->value.pv && strlen(perla_eval_error->value.pv) == 0) {\n");
        ind($cg); emit($cg, "      if (perla_eval_error) strada_decref(perla_eval_error);\n");
        # Prefer strada_exception_value (preserves blessed refs) over the stringified message
        ind($cg); emit($cg, "      if (strada_exception_value) { perla_eval_error = strada_exception_value; strada_incref(perla_eval_error); }\n");
        ind($cg); emit($cg, "      else { perla_eval_error = strada_exception_msg ? strada_new_str(strada_exception_msg) : strada_new_str(\"Unknown error\"); }\n");
        ind($cg); emit($cg, "    }\n");
        # PERLA_TRACE_CATCH=1 prints each caught exception to stderr.
        # Diagnostic aid for silently-swallowed errors that Try::Tiny /
        # eval BLOCK consumers swallow (Bootstrap's
        # `catch { $drogo_obj=undef }` is the canonical case where the
        # downstream symptom — `$server->app` returning undef — gives
        # no clue what the actual exception was).
        ind($cg); emit($cg, "    if (getenv(\"PERLA_TRACE_CATCH\")) { char *__tc = strada_to_str(perla_eval_error); fprintf(stderr, \"[catch] %s\\n\", __tc ? __tc : \"(empty)\"); free(__tc); }\n");
        ind($cg); emit($cg, "  }\n");
        ind($cg); emit($cg, "}\n");
        return;
    }

    # Postfix if
    if ($type == Perla::AST::N_POSTFIX_IF()) {
        my scalar $inner = $node->{"expr"};
        my int $inner_type = $inner->{"type"};
        ind($cg); emit($cg, "if (");
        _gen_cond($cg, $node->{"cond"});
        emit($cg, ") { ");
        if ($inner_type == Perla::AST::N_LAST() || $inner_type == Perla::AST::N_NEXT() || $inner_type == Perla::AST::N_REDO() || $inner_type == Perla::AST::N_RETURN() || $inner_type == Perla::AST::N_GOTO_LABEL()) {
            gen_stmt($cg, $inner);
        } elsif ($inner_type == Perla::AST::N_ANON_ARRAY() && defined($inner->{"elems"})
                 && (!defined($inner->{"is_ref"}) || $inner->{"is_ref"} == 0)) {
            # Comma sequence (e.g. `$f = $x, last if cond`) — iterate the
            # elements and emit each as a statement. Without this, an
            # element like `last`/`next`/`return` was emitted as an
            # expression (which is a no-op) and the loop never broke.
            my scalar $__pi_elems = $inner->{"elems"};
            my int $__pi_n = scalar(@{$__pi_elems});
            my int $__pi_i = 0;
            while ($__pi_i < $__pi_n) {
                my scalar $__pi_e = $__pi_elems->[$__pi_i];
                my int $__pi_et = $__pi_e->{"type"};
                if ($__pi_et == Perla::AST::N_LAST() || $__pi_et == Perla::AST::N_NEXT()
                    || $__pi_et == Perla::AST::N_REDO() || $__pi_et == Perla::AST::N_RETURN()) {
                    gen_stmt($cg, $__pi_e);
                } else {
                    gen_expr($cg, $__pi_e);
                    emit($cg, "; ");
                }
                $__pi_i++;
            }
        } else {
            gen_expr($cg, $inner);
            emit($cg, "; ");
        }
        emit($cg, "}\n");
        return;
    }
    # Postfix unless
    if ($type == Perla::AST::N_POSTFIX_UNLESS()) {
        my scalar $inner = $node->{"expr"};
        my int $inner_type = $inner->{"type"};
        ind($cg); emit($cg, "if (!(");
        _gen_cond($cg, $node->{"cond"});
        emit($cg, ")) { ");
        if ($inner_type == Perla::AST::N_LAST() || $inner_type == Perla::AST::N_NEXT() || $inner_type == Perla::AST::N_REDO() || $inner_type == Perla::AST::N_RETURN() || $inner_type == Perla::AST::N_GOTO_LABEL()) {
            gen_stmt($cg, $inner);
        } elsif ($inner_type == Perla::AST::N_ANON_ARRAY() && defined($inner->{"elems"})
                 && (!defined($inner->{"is_ref"}) || $inner->{"is_ref"} == 0)) {
            # Same comma-sequence handling as postfix-if.
            my scalar $__pi_elems = $inner->{"elems"};
            my int $__pi_n = scalar(@{$__pi_elems});
            my int $__pi_i = 0;
            while ($__pi_i < $__pi_n) {
                my scalar $__pi_e = $__pi_elems->[$__pi_i];
                my int $__pi_et = $__pi_e->{"type"};
                if ($__pi_et == Perla::AST::N_LAST() || $__pi_et == Perla::AST::N_NEXT()
                    || $__pi_et == Perla::AST::N_REDO() || $__pi_et == Perla::AST::N_RETURN()) {
                    gen_stmt($cg, $__pi_e);
                } else {
                    gen_expr($cg, $__pi_e);
                    emit($cg, "; ");
                }
                $__pi_i++;
            }
        } else {
            gen_expr($cg, $inner);
            emit($cg, "; ");
        }
        emit($cg, "}\n");
        return;
    }
    # Postfix while
    if ($type == Perla::AST::N_POSTFIX_WHILE()) {
        # If the cond is a /g regex match, allocate a position-tracking
        # var so the match advances between iterations. Without this,
        # `\$count++ while \$s =~ /\\w+/g` always matched at pos 0 and
        # infinite-looped.
        my str $saved_g_pos_pw = "";
        my int $set_g_pos_pw = 0;
        if (defined($cg->{"regex_g_pos_var"})) { $saved_g_pos_pw = $cg->{"regex_g_pos_var"}; }
        my scalar $cond_pw = $node->{"cond"};
        if (defined($cond_pw) && $cond_pw->{"type"} == Perla::AST::N_BINOP() && $cond_pw->{"op"} eq "=~") {
            my scalar $rr_pw = $cond_pw->{"right"};
            if (defined($rr_pw) && $rr_pw->{"type"} == Perla::AST::N_REGEX() && defined($rr_pw->{"flags"}) && index($rr_pw->{"flags"}, "g") >= 0) {
                if (!defined($cg->{"regex_g_id"})) { $cg->{"regex_g_id"} = 0; }
                my str $pos_var_pw = "__perla_gpos_" . $cg->{"regex_g_id"};
                $cg->{"regex_g_id"} = $cg->{"regex_g_id"} + 1;
                ind($cg); emit($cg, "{ size_t " . $pos_var_pw . " = 0; ");
                $cg->{"regex_g_pos_var"} = $pos_var_pw;
                $set_g_pos_pw = 1;
            }
        }
        ind($cg); emit($cg, "while (");
        _gen_cond($cg, $node->{"cond"});
        emit($cg, ") ");
        gen_expr($cg, $node->{"expr"});
        emit($cg, ";\n");
        if ($set_g_pos_pw == 1) {
            ind($cg); emit($cg, "}\n");
            $cg->{"regex_g_pos_var"} = $saved_g_pos_pw;
        }
        return;
    }

    # Postfix until
    if ($type == Perla::AST::N_POSTFIX_UNTIL()) {
        ind($cg); emit($cg, "while (!(");
        _gen_cond($cg, $node->{"cond"});
        emit($cg, ")) ");
        gen_expr($cg, $node->{"expr"});
        emit($cg, ";\n");
        return;
    }

    # Postfix for: expr for LIST. The list expression must be evaluated
    # in list context — `for keys %h` returns the count in scalar context,
    # which then deref'd as an array yields nothing.
    if ($type == Perla::AST::N_POSTFIX_FOR()) {
        my int $pf_list_borrowed = expr_is_borrowed($node->{"list"});
        # `STMT for values %h` — alias $_ to each hash value slot so the body
        # writes back into the hash (see _gen_foreach for the block-form twin).
        my int $pf_values_alias = 0;
        my scalar $pf_values_hash = undef;
        if (defined($node->{"list"}) && $node->{"list"}->{"type"} == Perla::AST::N_CALL()
            && defined($node->{"list"}->{"name"})
            && ($node->{"list"}->{"name"} eq "values" || $node->{"list"}->{"name"} eq "CORE::values")
            && defined($node->{"list"}->{"args"}) && scalar(@{$node->{"list"}->{"args"}}) == 1) {
            my scalar $pvarg = $node->{"list"}->{"args"}->[0];
            my int $pvat = $pvarg->{"type"};
            if ($pvat == Perla::AST::N_HASH_VAR() || $pvat == Perla::AST::N_DEREF_HASH()) {
                $pf_values_alias = 1;
                $pf_values_hash = $pvarg;
            }
        }
        ind($cg); emit($cg, "{ int __sav_wl_pf = __perla_want_list; __perla_want_list = 1; ");
        emit($cg, "StradaValue *__pf_vhash = NULL; StradaArray *__pf_vkeys = NULL; ");
        if ($pf_values_alias == 1) {
            emit($cg, "__pf_vhash = ");
            gen_expr($cg, $pf_values_hash);
            emit($cg, "; if (__pf_vhash && !STRADA_IS_TAGGED_INT(__pf_vhash) && __pf_vhash->type == STRADA_REF) __pf_vhash = __pf_vhash->value.rv; ");
            emit($cg, "__pf_vkeys = __pf_vhash ? strada_hash_keys_sv(__pf_vhash) : NULL; ");
            emit($cg, "StradaValue *__pf_list = strada_new_array(); ");
            emit($cg, "{ StradaArray *__pf_vva = strada_deref_array(__pf_list); if (__pf_vkeys) for (size_t __pf_vi = 0; __pf_vi < __pf_vkeys->size; __pf_vi++) { StradaValue *__pf_vk = __pf_vkeys->elements[__pf_vkeys->head + __pf_vi]; char *__pf_vks = strada_to_str(__pf_vk); StradaValue *__pf_vv = strada_hv_fetch_owned(__pf_vhash, __pf_vks ? __pf_vks : \"\"); if (__pf_vks) free(__pf_vks); strada_array_push_take(__pf_vva, __pf_vv ? __pf_vv : strada_new_undef()); } } ");
        } else {
            emit($cg, "StradaValue *__pf_list = ");
            gen_expr($cg, $node->{"list"});
            emit($cg, "; ");
        }
        emit($cg, "__perla_want_list = __sav_wl_pf; StradaArray *__pf_av = strada_deref_array(__pf_list); ");
        # Single-scalar `for SCALAR` (e.g. `STMT for 1` or `STMT for (5)`):
        # Perl semantics — iterate once with $_ bound to that value. Without
        # this fallback, strada_deref_array of a tagged int / non-array
        # returns NULL and the loop body never runs.
        emit($cg, "StradaValue *__pf_fbarr = NULL; ");
        emit($cg, "if (!__pf_av && __pf_list) { __pf_fbarr = strada_new_array(); strada_array_push(strada_deref_array(__pf_fbarr), __pf_list); __pf_av = strada_deref_array(__pf_fbarr); } ");
        emit($cg, "int __pf_len = __pf_av ? strada_array_length(__pf_av) : 0; ");
        emit($cg, "StradaValue *__pf_prev_du = perla_dollar_underscore; ");
        emit($cg, "for (int __pf_i = 0; __pf_i < __pf_len; __pf_i++) { ");
        emit($cg, "perla_dollar_underscore = strada_array_get(__pf_av, __pf_i); ");
        emit($cg, "StradaValue *__orig_pf_du = perla_dollar_underscore; ");
        # When the body is a bare CALL or METHOD, it's in void context —
        # capture and decref the return value (just like the regular
        # expression-statement path below). Without this, calls that
        # return owned values (e.g. a closure returning a captured
        # array) leak one ref per iteration; in long loops this drives
        # perla_call_depth past the recursion limit and trips a "stack
        # overflow" abort at runtime.
        my int $__pf_expr_type = $node->{"expr"}->{"type"};
        my int $__pf_is_call = ($__pf_expr_type == Perla::AST::N_CALL()
                              || $__pf_expr_type == Perla::AST::N_METHOD()) ? 1 : 0;
        if ($__pf_is_call == 1) {
            emit($cg, "{ int __sav_wl_pfv = __perla_want_list; __perla_want_list = -1; StradaValue *__pf_void_rv = ");
            gen_expr($cg, $node->{"expr"});
            emit($cg, "; if (__pf_void_rv) strada_decref(__pf_void_rv); __perla_want_list = __sav_wl_pfv; }");
        } else {
            gen_expr($cg, $node->{"expr"});
        }
        # Aliasing writeback: `$_ = expr for @arr` modifies the array element.
        # DBIC uses this in ResultSet::_construct_results line 1497.
        emit($cg, "; if (perla_dollar_underscore != __orig_pf_du) { strada_incref(perla_dollar_underscore); strada_array_set(__pf_av, __pf_i, perla_dollar_underscore); }");
        if ($pf_values_alias == 1) {
            emit($cg, " if (__pf_vkeys && __pf_i < (int)__pf_vkeys->size) { StradaValue *__pf_wk = __pf_vkeys->elements[__pf_vkeys->head + __pf_i]; char *__pf_wks = strada_to_str(__pf_wk); strada_hv_store(__pf_vhash, __pf_wks ? __pf_wks : \"\", perla_dollar_underscore); if (__pf_wks) free(__pf_wks); }");
        }
        emit($cg, " } perla_dollar_underscore = __pf_prev_du; ");
        emit($cg, "if (__pf_fbarr) strada_decref(__pf_fbarr); ");
        if ($pf_values_alias == 1) {
            emit($cg, "if (__pf_vkeys) strada_free_array(__pf_vkeys); ");
        }
        # Decref __pf_list when the list expression was owned (e.g. a range
        # `1..5` produces a fresh perla_range_array). Borrowed forms keep
        # the source alive via the caller's variable.
        if ($pf_list_borrowed == 0) {
            emit($cg, "if (__pf_list) strada_decref(__pf_list); ");
        }
        emit($cg, "}\n");
        return;
    }

    # Expression statement.
    # When the expression is a bare CALL or METHOD at statement level,
    # the result is discarded — that's Perl's "void context". Set
    # __perla_want_list = -1 around the call so the callee can detect
    # void via `wantarray` returning undef. Other expressions skip the
    # set/restore (no behavior change).
    my int $__es_type = $node->{"type"};
    my int $__es_is_call = ($__es_type == Perla::AST::N_CALL()
                            || $__es_type == Perla::AST::N_METHOD()) ? 1 : 0;
    # Detect bare `bless ..., "C";` at statement level. perla_bless is
    # transparent (no incref) — the returned ref shares its refcount with
    # the FIRST ARGUMENT. So the void cleanup needed mirrors that arg's
    # ownership:
    #   - `bless $var, "C";`  -> arg is borrowed; usual decref would kill
    #     $var's only ref and fire DESTROY prematurely. Skip the wrap.
    #   - `bless {...}, "C";` -> arg is an owned anon temp; we must decref
    #     the result or the anon hash leaks (was: 0 DESTROYs fired).
    # Driven by expr_is_borrowed, which already recurses through bless.
    my int $__es_is_bless = 0;
    my int $__es_bless_borrowed = 0;
    if ($__es_type == Perla::AST::N_CALL() && defined($node->{"name"})) {
        my str $__es_nm = $node->{"name"};
        if ($__es_nm eq "bless" || $__es_nm eq "CORE::bless") {
            $__es_is_bless = 1;
            $__es_bless_borrowed = expr_is_borrowed($node);
        }
    }
    if ($__es_is_call == 1 && $__es_is_bless == 0) {
        ind($cg); emit($cg, "{ int __sav_wl_void = __perla_want_list; __perla_want_list = -1; ");
        # Set the call's source line so the callee's perla_call_push
        # records it in the new frame's `line` — that's what caller(0)
        # inside the callee reads via perla_caller.
        my int $__es_line = $node->{"line"} + 0;
        if ($__es_line > 0) {
            emit($cg, "perla_pending_call_line = " . $__es_line . "; ");
        }
        # Capture the return value into __void_rv and decref it. Callees
        # always `strada_incref(__ret_val); return __ret_val;` so the
        # caller is expected to consume one ref. Statement-level (void
        # context) discards the result — without this decref the extra
        # ref leaks once per call. Visible as the per-iter leak in
        # bless_create / func_call.
        emit($cg, "StradaValue *__void_rv = ");
        gen_expr($cg, $node);
        emit($cg, "; if (__void_rv) strada_decref(__void_rv); __perla_want_list = __sav_wl_void; }\n");
    } elsif ($__es_is_bless == 1 && $__es_bless_borrowed == 1) {
        # Borrowed-arg bless: the result shares the var's refcount, so a
        # decref would kill the var. Just evaluate and drop.
        ind($cg);
        gen_expr($cg, $node);
        emit($cg, ";\n");
    } elsif ($__es_is_bless == 1) {
        # Owned-arg bless (e.g. `bless {...}, "C";`): the anon temp needs
        # cleanup or the object leaks (DESTROY never fires). Capture and
        # decref. No __perla_want_list dance — bless isn't a Perl sub.
        ind($cg); emit($cg, "{ StradaValue *__void_bless_rv = ");
        gen_expr($cg, $node);
        emit($cg, "; if (__void_bless_rv) strada_decref(__void_bless_rv); }\n");
    } elsif ($__es_type == Perla::AST::N_ASSIGN() && defined($node->{"op"}) && $node->{"op"} eq "="
             && defined($node->{"target"}) && defined($node->{"value"})
             && ($node->{"target"}->{"type"} == Perla::AST::N_ARRAY_ELEM()
                 || $node->{"target"}->{"type"} == Perla::AST::N_ARROW_ARRAY()
                 || $node->{"target"}->{"type"} == Perla::AST::N_HASH_ELEM()
                 || $node->{"target"}->{"type"} == Perla::AST::N_ARROW_HASH())
             && expr_is_borrowed($node->{"value"}) == 0
             && $node->{"value"}->{"type"} != Perla::AST::N_STR_LIT()
             && $node->{"value"}->{"type"} != Perla::AST::N_INT_LIT()
             && $node->{"value"}->{"type"} != Perla::AST::N_NUM_LIT()
             && $node->{"value"}->{"type"} != Perla::AST::N_INTERP_STR()) {
        # `\$arr[N] = EXPR;` / `\$h{k} = EXPR;` at statement level —
        # array_set / hash_set incref the stored value, and the assign
        # expression returns the value (also held by the slot). In void
        # context the returned ref is leaked, leaving blessed values at
        # rc=2 — so DESTROY only fires at program exit instead of
        # whenever the slot's last reference goes (perl semantics).
        # Skip for borrowed values (variables, deref'd refs) and plain
        # literals — those don't have an extra owned ref to drop. Only
        # decref for owned expressions (function calls, anon ctors, etc.)
        # where the slot's incref is the second ref.
        ind($cg); emit($cg, "{ StradaValue *__void_rv_as = ");
        gen_expr($cg, $node);
        emit($cg, "; if (__void_rv_as) strada_decref(__void_rv_as); }\n");
    } elsif ($__es_type == Perla::AST::N_ASSIGN() && defined($node->{"op"})
             && $node->{"op"} ne "=" && $node->{"op"} ne "//=" && $node->{"op"} ne "||="
             && defined($node->{"target"})
             && ($node->{"op"} eq ".="
                 || $node->{"target"}->{"type"} == Perla::AST::N_ARRAY_ELEM()
                 || $node->{"target"}->{"type"} == Perla::AST::N_ARROW_ARRAY()
                 || $node->{"target"}->{"type"} == Perla::AST::N_HASH_ELEM()
                 || $node->{"target"}->{"type"} == Perla::AST::N_ARROW_HASH()
                 || $node->{"target"}->{"type"} == Perla::AST::N_DEREF_SCALAR())) {
        # Compound assignments whose codegen yields an OWNED ref at statement
        # (void) level must decref it or it leaks one heap StradaValue per
        # statement. Two families yield owned: scalar `.=` (incref's its
        # result so consumers — my-init, assign, return — can take ownership)
        # and array/hash-element / `$$ref OP=` (the helpers yield the fresh
        # value alongside the slot's own incref). Scalar arithmetic compounds
        # (`$x += …`) yield a BORROWED view of the target and fall through to
        # the plain-emit else below — decref'ing those would free the var.
        # `//=`/`||=` are excluded: they may yield the existing value (already
        # balanced by their decref+store), so a void decref would over-free.
        # Integer element compounds yield an immortal tagged int, so the
        # decref is a harmless no-op there.
        ind($cg); emit($cg, "{ StradaValue *__void_cmpd = ");
        gen_expr($cg, $node);
        emit($cg, "; if (__void_cmpd) strada_decref(__void_cmpd); }\n");
    } else {
        ind($cg);
        gen_expr($cg, $node);
        emit($cg, ";\n");
    }
}

# --- Variable declaration ---
func _gen_my(scalar $cg, scalar $node) void {
    # Stash the my-statement's source line so _my_prefix_vt (called via
    # several intermediaries) can quote it in the "masks earlier declaration"
    # warning. Cleared on return so unrelated declarations elsewhere don't
    # pick up a stale value.
    my int $__cmy_saved_line = 0;
    if (defined($cg->{"current_my_line"})) {
        $__cmy_saved_line = $cg->{"current_my_line"} + 0;
    }
    if (defined($node->{"line"})) {
        $cg->{"current_my_line"} = $node->{"line"} + 0;
    }
    # caller() line propagation for `my $x = call()` / `my $x = $obj->method()`.
    # The init expression's call must record the my-statement's line so
    # caller(0) inside the callee returns the right source location.
    # Without this, `my $r = callme();` at file scope read perla_pending_call_line
    # left over from prior code (commonly 0), and caller(0) returned line 0.
    if (defined($node->{"init"})) {
        my int $__mi_type = $node->{"init"}->{"type"};
        if ($__mi_type == Perla::AST::N_CALL() || $__mi_type == Perla::AST::N_METHOD()) {
            my int $__mi_line = $node->{"init"}->{"line"} + 0;
            if ($__mi_line > 0) {
                ind($cg); emit($cg, "perla_pending_call_line = " . $__mi_line . ";\n");
            }
        }
    }
    # Track variables for main-scope cleanup (only at top indent level).
    # Store {name, type} hashes so cleanup can pick the right sigil-aware
    # C var name.
    if (defined($cg->{"main_vars"}) && $cg->{"indent"} == 1) {
        if (defined($node->{"vars"})) {
            my int $mvi = 0;
            while ($mvi < scalar(@{$node->{"vars"}})) {
                my scalar $mvn = $node->{"vars"}->[$mvi];
                push(@{$cg->{"main_vars"}}, {"name" => $mvn->{"value"}, "type" => $mvn->{"type"}});
                $mvi++;
            }
        } elsif (defined($node->{"var"})) {
            push(@{$cg->{"main_vars"}}, {"name" => $node->{"var"}->{"value"}, "type" => $node->{"var"}->{"type"}});
        }
    }
    # Defer tracking scalar `my $x` decls until AFTER the init expression
    # is generated. Perl's `my $x = expr` evaluates `expr` *without* $x in
    # scope — so if `expr` is an `eval "..."`, the eval should NOT capture
    # a $x that hasn't been declared yet. The previous order pushed v_x to
    # my_lexicals first, the eval-with-caps emitter then read uninitialized
    # v_x to populate its lexical-caps hash, and the resulting `if (v_x)`
    # in the generated C dereferenced stack garbage → segfault.
    #
    # Collect the entries to push now (so we know which to push at the end)
    # but don't push until the init expression is gen'd. Subsequent
    # statements still see the var in scope as expected.
    my array @__pending_lex = ();
    if (defined($cg->{"my_lexicals"})) {
        if (defined($node->{"vars"})) {
            my int $mxi = 0;
            while ($mxi < scalar(@{$node->{"vars"}})) {
                my scalar $mxv = $node->{"vars"}->[$mxi];
                # Push array/hash vars too so inner closures can capture
                # `my @q` / `my %h`. Sigil determines which C name the
                # cell init uses; without this push, free-var analysis
                # couldn't see the var and the inner sub was emitted as
                # a plain CPOINTER instead of a closure.
                if ($mxv->{"type"} eq "SCALAR_VAR"
                    || $mxv->{"type"} eq "ARRAY_VAR"
                    || $mxv->{"type"} eq "HASH_VAR") {
                    my scalar $mxe = {};
                    $mxe->{"name"} = $mxv->{"value"};
                    my str $__s = "\$";
                    if ($mxv->{"type"} eq "ARRAY_VAR") { $__s = "@"; }
                    if ($mxv->{"type"} eq "HASH_VAR") { $__s = "%"; }
                    if ($__s eq "@") { $mxe->{"c_name"} = c_var_a($mxv->{"value"}); }
                    elsif ($__s eq "%") { $mxe->{"c_name"} = c_var_h($mxv->{"value"}); }
                    else { $mxe->{"c_name"} = c_var($mxv->{"value"}); }
                    $mxe->{"sigil"} = $__s;
                    push(@__pending_lex, $mxe);
                }
                $mxi++;
            }
        } elsif (defined($node->{"var"})) {
            my scalar $mxv = $node->{"var"};
            if ($mxv->{"type"} eq "SCALAR_VAR"
                || $mxv->{"type"} eq "ARRAY_VAR"
                || $mxv->{"type"} eq "HASH_VAR") {
                my scalar $mxe = {};
                $mxe->{"name"} = $mxv->{"value"};
                my str $__s = "\$";
                if ($mxv->{"type"} eq "ARRAY_VAR") { $__s = "@"; }
                if ($mxv->{"type"} eq "HASH_VAR") { $__s = "%"; }
                if ($__s eq "@") { $mxe->{"c_name"} = c_var_a($mxv->{"value"}); }
                elsif ($__s eq "%") { $mxe->{"c_name"} = c_var_h($mxv->{"value"}); }
                else { $mxe->{"c_name"} = c_var($mxv->{"value"}); }
                $mxe->{"sigil"} = $__s;
                push(@__pending_lex, $mxe);
            }
        }
    }
    # Stash on $cg so the end-of-_gen_my flush can pick them up. Push
    # immediately after the init expression has been emitted.
    $cg->{"__pending_lex"} = \@__pending_lex;
    if (defined($node->{"vars"})) {
        # Destructuring: my ($a, $b, %h) = @_;
        my scalar $vars = $node->{"vars"};
        my int $nv = scalar(@{$vars});
        my int $vi = 0;
        my int $is_at_init = 0;
        if (defined($node->{"init"})) {
            my scalar $init_node = $node->{"init"};
            if (defined($init_node) && $init_node->{"type"} == Perla::AST::N_ARRAY_VAR() && $init_node->{"name"} eq "_") {
                $is_at_init = 1;
            }
        }
        while ($vi < $nv) {
            my scalar $var = $vars->[$vi];
            my str $vname = $var->{"value"};
            my str $vtype = $var->{"type"};

            # `my (%h) = LIST` — single-element parenthesized hash decl
            # with non-@_ init. Treat like `my %h = LIST` (flatten the
            # list into k/v pairs). Without this special case, perla
            # stored the array literal in v_h and `keys %h` returned
            # nothing.
            if ($nv == 1 && $vtype eq "HASH_VAR" && $is_at_init == 0 && defined($node->{"init"})) {
                # Build a synthetic single-var N_MY node and recurse via
                # the regular my-hash path.
                my scalar $single = {};
                $single->{"type"} = Perla::AST::N_MY();
                $single->{"var"} = $var;
                $single->{"init"} = $node->{"init"};
                gen_stmt($cg, $single);
                $vi++;
                next;
            }
            # Same treatment for `my (@a) = LIST` (single array decl).
            if ($nv == 1 && $vtype eq "ARRAY_VAR" && $is_at_init == 0 && defined($node->{"init"})) {
                my scalar $single_a = {};
                $single_a->{"type"} = Perla::AST::N_MY();
                $single_a->{"var"} = $var;
                $single_a->{"init"} = $node->{"init"};
                gen_stmt($cg, $single_a);
                $vi++;
                next;
            }
            if ($vtype eq "HASH_VAR" && $is_at_init == 1) {
                # Hash slurp: my (%h) — collect remaining @_ pairs into hash
                ind($cg); emit($cg, _my_prefix_vt($cg, "HASH_VAR", $vname) . c_var_h($vname) . " = strada_new_hash();\n");
                ind($cg); emit($cg, "{ StradaArray *__av = strada_deref_array(perla_at_); int __alen = __av ? strada_array_length(__av) : 0;\n");
                ind($cg); emit($cg, "  for (int __hi = " . $vi . "; __hi + 1 < __alen; __hi += 2) {\n");
                ind($cg); emit($cg, "    char *__k = strada_to_str(strada_array_get(__av, __hi));\n");
                ind($cg); emit($cg, "    strada_hv_store(" . c_var_h($vname) . ", __k, strada_array_get(__av, __hi + 1));\n");
                ind($cg); emit($cg, "    free(__k);\n");
                ind($cg); emit($cg, "  }\n");
                ind($cg); emit($cg, "}\n");
            } elsif ($vtype eq "ARRAY_VAR" && $is_at_init == 1) {
                # Array slurp: my (@arr) — collect remaining @_ into array
                ind($cg); emit($cg, _my_prefix_vt($cg, "ARRAY_VAR", $vname) . c_var_a($vname) . " = strada_new_array();\n");
                ind($cg); emit($cg, "{ StradaArray *__av = strada_deref_array(perla_at_); int __alen = __av ? strada_array_length(__av) : 0;\n");
                ind($cg); emit($cg, "  for (int __ai = " . $vi . "; __ai < __alen; __ai++)\n");
                ind($cg); emit($cg, "    strada_array_push(strada_deref_array(" . c_var_a($vname) . "), strada_array_get(__av, __ai));\n");
                ind($cg); emit($cg, "}\n");
            } else {
                if ($is_at_init == 1) {
                    ind($cg); emit($cg, _my_prefix_vt($cg, $vtype, $vname) . c_var_for_vtype($vtype, $vname) . " = ");
                    emit($cg, "(" . $vi . " < strada_array_length(strada_deref_array(perla_at_)) ? strada_array_get(strada_deref_array(perla_at_), " . $vi . ") : strada_new_undef());\n");
                } elsif (defined($node->{"init"}) && $nv >= 1 && $vi == 0
                         && $vars->[0]->{"type"} ne "ARRAY_VAR"
                         && $vars->[0]->{"type"} ne "HASH_VAR") {
                    # `my ($x) = list_func()` is list-context assignment: $x
                    # binds to the FIRST element of the returned list, not
                    # the last (perla used to emit `v_x = list_func()` which
                    # collapsed the list to its trailing scalar — DBI's
                    # `my ($cnt) = $dbh->selectrow_array(...)` returned the
                    # last column instead of the first, and on a 1-column
                    # SELECT (like SELECT COUNT(*)) where the list-as-scalar
                    # collapse produced an empty value, $cnt came out undef.
                    # Use the same destructure path as multi-var; it already
                    # handles ARRAY/HASH RHS and one-element-list fallback.
                    # Multiple vars from one init — declare/decref, then assign from init.
                    # Always call _my_prefix_vt (even when already declared) so the
                    # use-warnings mask check fires; the empty-string return
                    # selects the decref+reassign branch.
                    my int $di = 0;
                    while ($di < $nv) {
                        my str $dname = $vars->[$di]->{"value"};
                        my str $dtype = $vars->[$di]->{"type"};
                        my str $__dmp = _my_prefix_vt($cg, $dtype, $dname);
                        if (length($__dmp) == 0) {
                            # Already hoisted — decref old value (will be reassigned below)
                            ind($cg); emit($cg, "strada_decref(" . c_var_for_vtype($dtype, $dname) . "); ");
                            if ($dtype eq "ARRAY_VAR") {
                                emit($cg, c_var_a($dname) . " = strada_new_array();\n");
                            } elsif ($dtype eq "HASH_VAR") {
                                emit($cg, c_var_h($dname) . " = strada_new_hash();\n");
                            } else {
                                emit($cg, c_var($dname) . " = NULL;\n");
                            }
                        } else {
                            if ($dtype eq "ARRAY_VAR") {
                                ind($cg); emit($cg, $__dmp . c_var_a($dname) . " = strada_new_array();\n");
                            } elsif ($dtype eq "HASH_VAR") {
                                ind($cg); emit($cg, $__dmp . c_var_h($dname) . " = strada_new_hash();\n");
                            } else {
                                ind($cg); emit($cg, $__dmp . c_var($dname) . " = NULL;\n");
                            }
                        }
                        $di++;
                    }
                    # Then assign from the init result (list context for wantarray).
                    # If the RHS turns out to be a scalar (not an array), Perl
                    # treats it as a one-element list: `my ($a, $b) = "foo"`
                    # gives $a = "foo", $b = undef. Perla's destructure used
                    # to turn NULL __da into length 0, assigning undef to
                    # EVERY lvalue — seen in Mo::Inline's
                    # `my ($P, %e, %o) = caller . '::';` where $P silently
                    # ended up undef and `@{$P.ISA} = ...` hit a bogus
                    # symbol.
                    ind($cg); emit($cg, "{ int __sav_wl_dl = __perla_want_list; __perla_want_list = 1; StradaValue *__dl = ");
                    gen_expr($cg, $node->{"init"});
                    emit($cg, "; __perla_want_list = __sav_wl_dl; StradaArray *__da = strada_deref_array(__dl); ");
                    emit($cg, "StradaValue *__dl_fallback = NULL; ");
                    # `my (...) = %h` — RHS is a hash; flatten to (k,v,k,v,...)
                    # so `my ($k, $v) = %h` and `my @a = %h` work like Perl.
                    emit($cg, "if (!__da && __dl && !STRADA_IS_TAGGED_INT(__dl) && __dl->type == STRADA_HASH && __dl->value.hv) { ");
                    emit($cg, "  __dl_fallback = strada_new_array(); StradaArray *__hf_av = strada_deref_array(__dl_fallback); ");
                    emit($cg, "  StradaArray *__hf_keys = strada_hash_keys(__dl->value.hv); ");
                    emit($cg, "  if (__hf_keys) { for (size_t __hf_i = 0; __hf_i < __hf_keys->size; __hf_i++) { ");
                    emit($cg, "    StradaValue *__hf_k = __hf_keys->elements[__hf_keys->head + __hf_i]; ");
                    emit($cg, "    char *__hf_ks = strada_to_str(__hf_k); ");
                    emit($cg, "    StradaValue *__hf_v = strada_hash_get(__dl->value.hv, __hf_ks); ");
                    emit($cg, "    free(__hf_ks); ");
                    emit($cg, "    if (__hf_k) strada_incref(__hf_k); strada_array_push(__hf_av, __hf_k); ");
                    emit($cg, "    if (__hf_v) strada_incref(__hf_v); strada_array_push(__hf_av, __hf_v); ");
                    emit($cg, "  } strada_free_array(__hf_keys); } __da = __hf_av; ");
                    emit($cg, "} else if (!__da && __dl) { __dl_fallback = strada_new_array(); strada_array_push(strada_deref_array(__dl_fallback), __dl); __da = strada_deref_array(__dl_fallback); } ");
                    emit($cg, "int __dlen = __da ? strada_array_length(__da) : 0;\n");
                    $di = 0;
                    while ($di < $nv) {
                        my str $dname = $vars->[$di]->{"value"};
                        my str $dtype = $vars->[$di]->{"type"};
                        if ($dtype eq "ARRAY_VAR") {
                            # Slurp remaining elements into array
                            ind($cg); emit($cg, "{ StradaArray *__rav = strada_deref_array(" . c_var_a($dname) . ");\n");
                            ind($cg); emit($cg, "  for (int __ri = " . $di . "; __ri < __dlen; __ri++) strada_array_push(__rav, strada_array_get(__da, __ri)); }\n");
                            $di = $nv;  # done
                        } elsif ($dtype eq "HASH_VAR") {
                            # Slurp remaining elements into hash as key/value pairs.
                            # Perl lets you interleave %hash with other lvalues:
                            # `my ($P, %e, %o) = LIST` binds %e to the remainder
                            # and leaves later hashes/arrays empty. Without this,
                            # Mo::Inline's `my ($P,%e,%o) = caller.'::';` would
                            # leave %e as undef so `\%e` then derefs nothing.
                            ind($cg); emit($cg, "{ StradaHash *__rhv = strada_deref_hash(" . c_var_h($dname) . ");\n");
                            ind($cg); emit($cg, "  for (int __ri = " . $di . "; __ri + 1 < __dlen; __ri += 2) {\n");
                            ind($cg); emit($cg, "    char *__rhk = strada_to_str(strada_array_get(__da, __ri));\n");
                            ind($cg); emit($cg, "    strada_hash_set(__rhv, __rhk, strada_array_get(__da, __ri + 1));\n");
                            ind($cg); emit($cg, "    free(__rhk);\n");
                            ind($cg); emit($cg, "  } }\n");
                            $di = $nv;  # done
                        } else {
                            ind($cg); emit($cg, c_var($dname) . " = (" . $di . " < __dlen ? strada_array_get(__da, " . $di . ") : strada_new_undef());\n");
                            $di++;
                        }
                    }
                    ind($cg); emit($cg, "}\n");
                    $vi = $nv;  # skip rest
                    next;
                } elsif (defined($node->{"init"})) {
                    # Always route through _my_prefix_vt so the use-warnings
                    # "my X masks earlier declaration" check sees both first
                    # and subsequent decls in the same scope. Result string
                    # is "" if the C var was already declared (decref+reassign
                    # path) and "StradaValue *" otherwise (fresh declaration).
                    my str $__mpr_init = _my_prefix_vt($cg, $vtype, $vname);
                    if (length($__mpr_init) == 0) {
                        # Variable already declared (e.g. inside a loop) — decref old and reassign
                        ind($cg); emit($cg, "strada_decref(" . c_var_for_vtype($vtype, $vname) . "); ");
                        emit($cg, c_var_for_vtype($vtype, $vname) . " = ");
                        gen_expr($cg, $node->{"init"});
                        emit($cg, ";\n");
                    } else {
                        ind($cg); emit($cg, $__mpr_init . c_var_for_vtype($vtype, $vname) . " = ");
                        gen_expr($cg, $node->{"init"});
                        emit($cg, ";\n");
                    }
                } else {
                    # Init-less declaration in multi-var `my (...)`. Pick the
                    # right empty value per sigil — `my @arr` is `()`, `my %h`
                    # is `{}`, scalars are undef. Was always emitting undef,
                    # which broke patterns like `my (@arr); $arr[0] = 1;`
                    # (strada_deref_array(undef) is NULL, strada_array_set is a
                    # no-op). Surfaced via DBIC's
                    # `my ($self, $cond, @res_args, $rel_name); (...) = @_;`
                    # in `_resolve_condition`, where the indexed lvalues into
                    # @res_args silently dropped their values.
                    my str $init_expr = "strada_new_undef()";
                    if ($vtype eq "ARRAY_VAR") { $init_expr = "strada_new_array()"; }
                    elsif ($vtype eq "HASH_VAR") { $init_expr = "strada_new_hash()"; }
                    # Route through _my_prefix_vt for the use-warnings mask
                    # detection (see comment in the init'd branch above).
                    my str $__mpr_noinit = _my_prefix_vt($cg, $vtype, $vname);
                    if (length($__mpr_noinit) == 0) {
                        ind($cg); emit($cg, "strada_decref(" . c_var_for_vtype($vtype, $vname) . "); ");
                        emit($cg, c_var_for_vtype($vtype, $vname) . " = " . $init_expr . ";\n");
                    } else {
                        ind($cg); emit($cg, $__mpr_noinit . c_var_for_vtype($vtype, $vname) . " = " . $init_expr . ";\n");
                    }
                }
            }
            $vi++;
        }
        # Flush pending_lex BEFORE the early return so destructure decls
        # actually land in my_lexicals. Without this, `my ($a, $b)` inside
        # a sub didn't add $a/$b to the enclosing-sub lexical set, so the
        # closure free-var scan missed them and the closure body read
        # file-scope statics instead of capturing.
        if (defined($cg->{"__pending_lex"}) && defined($cg->{"my_lexicals"})) {
            my scalar $__pl_dr = $cg->{"__pending_lex"};
            my int $__pli_dr = 0;
            while ($__pli_dr < scalar(@{$__pl_dr})) {
                push(@{$cg->{"my_lexicals"}}, $__pl_dr->[$__pli_dr]);
                $__pli_dr++;
            }
            $cg->{"__pending_lex"} = undef;
        }
        return;
    }
    if (defined($node->{"var"})) {
        my str $vtype = $node->{"var"}->{"type"};
        my str $vname = $node->{"var"}->{"value"};

        if ($vtype eq "HASH_VAR" && defined($node->{"init"})) {
            # my %hash = (key => val, ...); — build hash from flat list
            my scalar $init = $node->{"init"};
            # If any element of the list literal is a hash/array/slice
            # that needs runtime flattening, fall through to the dynamic
            # path. Otherwise `my %m = (%a, %b)` would try to use %a as a
            # single key and %b as its value, mangling the merge.
            my int $hh_has_flatten = 0;
            if ($init->{"type"} == Perla::AST::N_ANON_ARRAY()) {
                my scalar $hh_elems = $init->{"elems"};
                if (defined($hh_elems)) {
                    my int $hh_ei = 0;
                    while ($hh_ei < scalar(@{$hh_elems})) {
                        my int $hh_et = $hh_elems->[$hh_ei]->{"type"};
                        # Whole containers must run through the runtime
                        # flatten path so their elements interleave with
                        # the explicit pairs.
                        if ($hh_et == Perla::AST::N_HASH_VAR()
                            || $hh_et == Perla::AST::N_ARRAY_VAR()
                            || $hh_et == Perla::AST::N_DEREF_ARRAY()
                            || $hh_et == Perla::AST::N_DEREF_HASH()
                            || $hh_et == Perla::AST::N_HASH_SLICE()
                            || $hh_et == Perla::AST::N_ARRAY_SLICE()) {
                            $hh_has_flatten = 1;
                            last;
                        }
                        # Ternary, list-returning operators, calls — each
                        # may yield 0 or more values at runtime so the
                        # static pair-walk can't reason about pairing.
                        # \`(\$cond ? ("k" => "v") : ())\` inside a hash
                        # literal must flatten or the trailing pair is
                        # silently dropped (and any odd-arity element
                        # mis-keys the remaining pairs).
                        if ($hh_et == Perla::AST::N_TERNARY()
                            || $hh_et == Perla::AST::N_CALL()
                            || $hh_et == Perla::AST::N_METHOD()
                            || $hh_et == Perla::AST::N_RANGE()
                            || $hh_et == Perla::AST::N_MAP()
                            || $hh_et == Perla::AST::N_GREP()
                            || $hh_et == Perla::AST::N_SORT()) {
                            $hh_has_flatten = 1;
                            last;
                        }
                        $hh_ei++;
                    }
                }
            }
            if (($init->{"type"} == Perla::AST::N_ANON_ARRAY() || $init->{"type"} == Perla::AST::N_QWORD())
                && $hh_has_flatten == 0) {
                # Known list literal — generate hash directly
                my scalar $elems = $init->{"elems"};
                my int $ne = scalar(@{$elems});
                my str $cv = c_var_h($vname);
                my str $mp = _my_prefix_vt($cg, "HASH_VAR", $vname);
                # Decref old value before reassignment (prevents leak in loops)
                if (length($mp) == 0) {
                    ind($cg); emit($cg, "if (" . $cv . ") strada_decref(" . $cv . ");\n");
                }
                ind($cg); emit($cg, $mp . $cv . " = strada_new_hash();\n");
                my int $ei = 0;
                while ($ei + 1 < $ne) {
                    my scalar $key_node = $elems->[$ei];
                    my int $key_type = $key_node->{"type"};
                    # Pick hv_store vs hv_store_take based on whether the RHS
                    # is a fresh allocation. Same rationale as the hash-literal
                    # codegen path (see _value_is_borrowed): fresh values must
                    # use `_take` or they leak (refcount=1 going in, store
                    # increfs to 2, hash holds one ref, caller never drops
                    # the other); borrowed values need `store` so the hash
                    # gets its own ref, independent of the source.
                    my str $hstore = "strada_hv_store_take";
                    if (Perla::CodeGen::Predicate::value_is_borrowed($cg, $elems->[$ei + 1]) == 1) {
                        $hstore = "strada_hv_store";
                    }
                    if ($key_type == Perla::AST::N_STR_LIT() || $key_type == Perla::AST::N_INT_LIT()) {
                        # Static key: use strdup directly (avoids StradaValue
                        # allocation). Must C-escape — a literal backslash
                        # key (e.g. YAML::Loader's `'\\' => '\\'` unescape
                        # table) has value "\" (one char) which would emit
                        # `"\""` unescaped, producing a C string containing
                        # only a \-escaped quote and no terminating "`.
                        my str $key_val = Perla::CodeGen::Escape::escape_c_str($key_node->{"value"});
                        # Hash assignment is LIST context — wantarray() in a
                        # called sub here should report 1, not the outer
                        # want_list. Without the wrap, `my %h = (k=>ctx())`
                        # inside a scalar-context caller saw scalar context.
                        ind($cg); emit($cg, $hstore . "(" . c_var_h($vname) . ", \"" . $key_val . "\", ({ int __sav_wl_hkv = __perla_want_list; __perla_want_list = 1; StradaValue *__hkv = ");
                        gen_expr($cg, $elems->[$ei + 1]);
                        emit($cg, "; __perla_want_list = __sav_wl_hkv; __hkv; }));\n");
                    } else {
                        ind($cg); emit($cg, "{ int __sav_wl_hk = __perla_want_list; __perla_want_list = 1; char *__k = strada_to_str(");
                        gen_expr($cg, $key_node);
                        emit($cg, "); " . $hstore . "(" . c_var_h($vname) . ", __k, ");
                        gen_expr($cg, $elems->[$ei + 1]);
                        emit($cg, "); free(__k); __perla_want_list = __sav_wl_hk; }\n");
                    }
                    $ei = $ei + 2;
                }
            } else {
                # Dynamic init — check if result is already a hash, otherwise convert flat array.
                # Force list context on the RHS so callees that vary their
                # return shape (`return %hash` is a hash ref in scalar
                # context, kv-list in list context — what PVC's validator
                # subref returns) hand back the kv-list shape that this
                # code expects. Without this, `my %p = $validator->(@_)`
                # inside DateTime::TimeZone::new received the validator's
                # scalar-context result, %p was empty, $p{name} was undef,
                # and TimeZone fell through to OffsetOnly with ''.
                ind($cg); emit($cg, _my_prefix_vt($cg, "HASH_VAR", $vname) . c_var_h($vname) . " = strada_new_hash();\n");
                # Track whether the RHS is a borrowed value (eg @_ ==
                # perla_at_, or a variable). Borrowed → must NOT
                # decref __init at the end (would damage the caller's
                # storage). Owned → decref to release intermediate
                # blessed values for prompt DESTROY.
                my int $__mh_init_borrowed = expr_is_borrowed($init);
                ind($cg); emit($cg, "{ int __sav_wl_mh = __perla_want_list; __perla_want_list = 1; StradaValue *__init = ");
                gen_expr($cg, $init);
                emit($cg, "; __perla_want_list = __sav_wl_mh; ");
                # When the RHS is a hash, COPY entries into the new
                # hash. The previous code aliased __init directly, so
                # `my %h2 = %h; delete \$h2{k}` also deleted from %h.
                # Real Perl: hash assignment is always a copy.
                emit($cg, "if (__init && !STRADA_IS_TAGGED_INT(__init) && __init->type == STRADA_HASH && __init->value.hv) { ");
                emit($cg, "  StradaArray *__hck = strada_hash_keys(__init->value.hv); ");
                emit($cg, "  if (__hck) { for (size_t __hci = 0; __hci < __hck->size; __hci++) { ");
                emit($cg, "    StradaValue *__hcv = __hck->elements[__hck->head + __hci]; ");
                emit($cg, "    char *__hck_s = strada_to_str(__hcv); ");
                emit($cg, "    StradaValue *__hcvv = strada_hash_get(__init->value.hv, __hck_s); ");
                emit($cg, "    strada_hv_store(" . c_var_h($vname) . ", __hck_s, __hcvv); ");
                emit($cg, "    free(__hck_s); ");
                emit($cg, "  } strada_free_array(__hck); } ");
                emit($cg, "} else { StradaArray *__ia = strada_deref_array(__init); ");
                emit($cg, "if (__ia) for (int __ii = 0; __ii + 1 < (int)strada_array_length(__ia); __ii += 2) { ");
                emit($cg, "char *__k = strada_to_str(strada_array_get(__ia, __ii)); ");
                emit($cg, "strada_hv_store(" . c_var_h($vname) . ", __k, strada_array_get(__ia, __ii + 1)); free(__k); } } ");
                # Decref __init now that its entries have been copied
                # into the target hash — but only when __init is an
                # owned temp (literal list, fresh expression). For
                # borrowed RHS (\@_, %other_hash, etc.) decref would
                # damage the caller's storage. expr_is_borrowed
                # filters these cases out.
                if ($__mh_init_borrowed == 0) {
                    emit($cg, "if (__init) strada_decref(__init); }\n");
                } else {
                    emit($cg, "}\n");
                }
            }
        } else {
            # Track whether the my-decl reduces to a plain file-scope
            # assignment (no `StradaValue *` prefix). When it does, a
            # no-init `my @arr` should preserve any pushes BEGIN
            # blocks made into the file-scope v_arr — see the no-init
            # branch below. EXCEPT for the second (and later) `my @arr`
            # at file scope: re-declaration always resets.
            my int $is_file_scope_assign = 0;
            my int $is_repeat_file_my = 0;
            my str $__my_file_key = c_var_for_vtype($vtype, $vname);
            if (defined($cg->{"declared_vars"}->{$__my_file_key})) {
                # Re-declaration in the same C scope. Trigger the
                # use-warnings "my X masks earlier declaration" check by
                # consulting same_scope_decls directly (the warning emit
                # also lives inside _my_prefix_vt but the path that calls
                # it is taken only for fresh decls — for re-decls we
                # short-circuit to decref+reassign).
                if (defined($cg->{"same_scope_decls"})
                    && defined($cg->{"same_scope_decls"}->{$__my_file_key})
                    && defined($cg->{"use_warnings"}) && $cg->{"use_warnings"} == 1) {
                    my str $__mm_s = "\$";
                    if ($vtype eq "ARRAY_VAR") { $__mm_s = "@"; }
                    elsif ($vtype eq "HASH_VAR") { $__mm_s = "%"; }
                    my int $__mm_l = 0;
                    if (defined($cg->{"current_my_line"})) {
                        $__mm_l = $cg->{"current_my_line"} + 0;
                    }
                    my str $__mm_f = "" . $cg->{"filename"};
                    if (length($__mm_f) == 0) { $__mm_f = "-"; }
                    say(STDERR, "\"my\" variable " . $__mm_s . $vname . " masks earlier declaration in same scope at " . $__mm_f . " line " . $__mm_l . ".");
                }
                if (defined($cg->{"same_scope_decls"})) {
                    $cg->{"same_scope_decls"}->{$__my_file_key} = 1;
                }
                ind($cg); emit($cg, "strada_decref(" . $__my_file_key . "); " . $__my_file_key . " = ");
            } else {
                my str $__mp = _my_prefix_vt($cg, $vtype, $vname);
                if (length($__mp) == 0) { $is_file_scope_assign = 1; }
                ind($cg); emit($cg, $__mp . $__my_file_key . " = ");
            }
            # Track first-vs-subsequent `my @arr` at file scope so the
            # no-init "preserve BEGIN value" ternary only fires on the
            # FIRST decl. Second+ uses of the same name re-declare a
            # fresh, empty array (Perl `my` semantics — each `my` makes
            # a new lexical, not aliasing the previous).
            if ($is_file_scope_assign == 1) {
                if (!defined($cg->{"__my_file_emitted"})) { $cg->{"__my_file_emitted"} = {}; }
                if (defined($cg->{"__my_file_emitted"}->{$__my_file_key})) {
                    $is_repeat_file_my = 1;
                }
                $cg->{"__my_file_emitted"}->{$__my_file_key} = 1;
            }
            if (defined($node->{"init"})) {
                if ($vtype eq "ARRAY_VAR") {
                    # Set list context and ensure result is always an array.
                    # CRITICAL: copy elements into a fresh array so mutations
                    # to the new @arr don't bleed back into the source. Real
                    # Perl: `my @x = @{$ref}` is a copy. Without the copy,
                    # `my @copy = @{$h->{from}}; shift @copy;` mutated
                    # $h->{from} (since both aliased the same StradaArray) —
                    # broke DBIC's `_resolved_attrs` collapse-detection
                    # `while (@fromlist) { my $t = shift @fromlist; ... }`,
                    # which silently shifted the root HASH off $attrs->{from}
                    # so the real query saw `[JOIN1, JOIN2]` instead of
                    # `[ROOT_HASH, JOIN1, JOIN2]` and emitted `FROM JOIN ON 0`.
                    emit($cg, "({ int __sav_wl_wv = __perla_want_list; __perla_want_list = 1; StradaValue *__wv = ");
                    gen_expr($cg, $node->{"init"});
                    emit($cg, "; __perla_want_list = __sav_wl_wv; ");
                    emit($cg, "StradaValue *__cparr = strada_new_array(); StradaArray *__cpav = strada_deref_array(__cparr); ");
                    emit($cg, "if (__wv && !STRADA_IS_TAGGED_INT(__wv) && __wv->type == STRADA_ARRAY) { ");
                    emit($cg, "  StradaArray *__src = strada_deref_array(__wv); ");
                    emit($cg, "  if (__src) for (int __cpi = 0; __cpi < (int)strada_array_length(__src); __cpi++) { ");
                    # push() already increfs; the prior `incref(); push()` pair
                    # double-incref'd each element. Use push_take with an explicit
                    # incref so the dest gets exactly one owned ref while the
                    # source (__wv's array) retains its own.
                    emit($cg, "    StradaValue *__cpe = strada_array_get(__src, __cpi); if (__cpe) strada_incref(__cpe); strada_array_push_take(__cpav, __cpe); } ");
                    emit($cg, "} else if (__wv && !STRADA_IS_TAGGED_INT(__wv) && __wv->type == STRADA_HASH && __wv->value.hv) { ");
                    # `my @arr = %h` — flatten hash to (k,v,k,v,...).
                    emit($cg, "  StradaArray *__hf_keys = strada_hash_keys(__wv->value.hv); ");
                    emit($cg, "  if (__hf_keys) { for (size_t __hf_i = 0; __hf_i < __hf_keys->size; __hf_i++) { ");
                    emit($cg, "    StradaValue *__hf_k = __hf_keys->elements[__hf_keys->head + __hf_i]; ");
                    emit($cg, "    char *__hf_ks = strada_to_str(__hf_k); ");
                    emit($cg, "    StradaValue *__hf_v = strada_hash_get(__wv->value.hv, __hf_ks); ");
                    emit($cg, "    free(__hf_ks); ");
                    emit($cg, "    if (__hf_k) strada_incref(__hf_k); strada_array_push_take(__cpav, __hf_k); ");
                    emit($cg, "    if (__hf_v) strada_incref(__hf_v); strada_array_push_take(__cpav, __hf_v); ");
                    emit($cg, "  } strada_free_array(__hf_keys); } ");
                    emit($cg, "} else if (__wv) { strada_incref(__wv); strada_array_push_take(__cpav, __wv); } ");
                    # Decref __wv if it was a temporary (anon-list literal). Borrowed
                    # forms (@var, %h, scalar var, derefs) keep __wv alive via the
                    # caller — never decref those or we'd free their backing.
                    my int $__ima_t = -1;
                    if (defined($node->{"init"})) { $__ima_t = $node->{"init"}->{"type"}; }
                    my int $__ima_borrowed = 0;
                    if ($__ima_t == Perla::AST::N_ARRAY_VAR()
                        || $__ima_t == Perla::AST::N_HASH_VAR()
                        || $__ima_t == Perla::AST::N_SCALAR_VAR()
                        || $__ima_t == Perla::AST::N_DEREF_ARRAY()
                        || $__ima_t == Perla::AST::N_DEREF_HASH()
                        || $__ima_t == Perla::AST::N_ASSIGN()
                        || $__ima_t == Perla::AST::N_MY()
                        || $__ima_t == Perla::AST::N_OUR()) {
                        # An assignment / declaration used as the init expression
                        # (chained: `my @A = my @B = LIST` or `my @A = @B = LIST`)
                        # yields the *target's* container, which the target owns.
                        # Decref'ing __wv there would free it out from under the
                        # inner variable, leaving it empty. Treat as borrowed.
                        $__ima_borrowed = 1;
                    }
                    if ($__ima_borrowed == 0) {
                        emit($cg, "if (__wv) strada_decref(__wv); ");
                    }
                    emit($cg, "__cparr; })");
                } else {
                    # Scalar-var assignment: force scalar context for the init
                    # so chained calls (e.g. `my $x = YAML::Load($s)`) see
                    # __perla_want_list = 0 even if intermediate code left it
                    # mutated. Without this, Load → loader_object → load →
                    # _parse cascaded with wantarray=1 in bizowie's deep call
                    # chain — returned the docs ARRAY instead of last-doc HASH.
                    # If RHS is a borrowed variable ref (scalar var), incref —
                    # else `my $b = $a; $a = ...` decref's the shared value
                    # and leaves $b dangling. Only true VAR forms — hash/array
                    # access already returns owned via strada_hv_fetch_owned.
                    my int $imby_borrowed = 0;
                    my scalar $imby_init = $node->{"init"};
                    my int $imby_scalarize_hash = 0;
                    my int $imby_scalarize_array = 0;
                    if (defined($imby_init)) {
                        my int $imby_t = $imby_init->{"type"};
                        if ($imby_t == Perla::AST::N_SCALAR_VAR() ||
                            $imby_t == Perla::AST::N_ARRAY_VAR() ||
                            $imby_t == Perla::AST::N_HASH_VAR()) {
                            $imby_borrowed = 1;
                        }
                        # `my $s = %h` — scalar context of a hash is its
                        # entry count, NOT a copy of the hash StradaValue.
                        if ($imby_t == Perla::AST::N_HASH_VAR()
                            && defined($imby_init->{"name"})
                            && index($imby_init->{"name"}, "::") < 0) {
                            $imby_scalarize_hash = 1;
                            $imby_borrowed = 0;
                        }
                        # `my $s = @a` — scalar context of an array is its
                        # length. Skip `@_` (handled by perla_at_ runtime).
                        if ($imby_t == Perla::AST::N_ARRAY_VAR()
                            && defined($imby_init->{"name"})
                            && index($imby_init->{"name"}, "::") < 0
                            && $imby_init->{"name"} ne "_") {
                            $imby_scalarize_array = 1;
                            $imby_borrowed = 0;
                        }
                    }
                    emit($cg, "({ int __sav_wl_my = __perla_want_list; __perla_want_list = 0; StradaValue *__init_my = ");
                    if ($imby_scalarize_hash == 1) {
                        my str $__rhs_cv = c_var_h($imby_init->{"name"});
                        emit($cg, "({ StradaHash *__shv = strada_deref_hash(" . $__rhs_cv . "); STRADA_MAKE_TAGGED_INT((int64_t)(__shv ? __shv->num_entries : 0)); })");
                    } elsif ($imby_scalarize_array == 1) {
                        my str $__rhs_cv = c_var_a($imby_init->{"name"});
                        emit($cg, "STRADA_MAKE_TAGGED_INT((int64_t)strada_array_length(strada_deref_array(" . $__rhs_cv . ")))");
                    } else {
                        gen_expr($cg, $node->{"init"});
                    }
                    if ($imby_borrowed == 1) {
                        # $1..$9 / $& / capture vars are actually OWNED — strada_capture_var()
                        # incref's before returning. Adding another incref here gave the var
                        # rc+2 for a single owner, leaking once per capture read (e.g. inside
                        # a regex-match if-block).
                        my int $__imby_cap = 0;
                        if (defined($imby_init) && $imby_init->{"type"} == Perla::AST::N_SCALAR_VAR()) {
                            my str $__imby_n = "" . $imby_init->{"name"};
                            if ((length($__imby_n) == 1 && $__imby_n ge "1" && $__imby_n le "9")
                                || $__imby_n eq "&") {
                                $__imby_cap = 1;
                            }
                        }
                        if ($__imby_cap == 0) {
                            # Tied scalar dispatch: `my $v = $tied` must call
                            # FETCH at the read site so the tied object's log
                            # records the read (and the binding sees the FETCH
                            # result, not the tied SV placeholder). FETCH
                            # returns owned, replacing the incref. Limited to
                            # SCALAR_VAR init so we don't pay the meta probe
                            # for hash-access / array-access RHS (those return
                            # owned anyway and already dispatch FETCH at the
                            # access site).
                            my int $__imby_sv = 0;
                            if (defined($imby_init) && $imby_init->{"type"} == Perla::AST::N_SCALAR_VAR()) {
                                $__imby_sv = 1;
                            }
                            if ($__imby_sv == 1) {
                                emit($cg, "; if (__init_my && !STRADA_IS_TAGGED_INT(__init_my) && __init_my->meta && __init_my->meta->is_tied) { __init_my = strada_tied_scalar_fetch(__init_my); } else if (__init_my) { strada_incref(__init_my); }");
                            } else {
                                emit($cg, "; if (__init_my) strada_incref(__init_my)");
                            }
                        }
                    }
                    emit($cg, "; __perla_want_list = __sav_wl_my; __init_my; })");
                }
            } else {
                # No-init `my @arr` / `my %h`. When this reduces to a
                # plain file-scope assignment (no new local declared),
                # preserve any prior value the BEGIN-hoist (or perla's
                # pre-main auto-init) placed in v_X. Use a ternary so
                # we don't clobber it: `v_X = v_X ? v_X : new()`. The
                # local-shadow case (decl form) must stay unguarded —
                # the var being declared is in scope inside its
                # initializer, so reading it reads indeterminate
                # memory. EXCEPT: if this is the second+ `my @arr` at
                # file scope, always reset — Perl's `my` re-declares
                # a fresh lexical, not aliasing the previous.
                if ($vtype eq "ARRAY_VAR") {
                    if ($is_file_scope_assign == 1 && $is_repeat_file_my == 0) {
                        my str $__cvn = c_var_a($vname);
                        emit($cg, $__cvn . " ? " . $__cvn . " : strada_new_array()");
                    } else {
                        emit($cg, "strada_new_array()");
                    }
                } elsif ($vtype eq "HASH_VAR") {
                    if ($is_file_scope_assign == 1 && $is_repeat_file_my == 0) {
                        my str $__cvn = c_var_h($vname);
                        emit($cg, $__cvn . " ? " . $__cvn . " : strada_new_hash()");
                    } else {
                        emit($cg, "strada_new_hash()");
                    }
                } else {
                    # Same "preserve BEGIN value" pattern for scalars:
                    # `my $x; BEGIN { $x = ... }; print $x` should see the
                    # BEGIN's assignment. Without the ternary, the file-
                    # scope `v_x = strada_new_undef()` runs after the
                    # BEGIN block at module init and clobbers it.
                    # Re-declarations (second `my $x`) reset as before.
                    if ($is_file_scope_assign == 1 && $is_repeat_file_my == 0) {
                        my str $__cvn = c_var($vname);
                        emit($cg, $__cvn . " ? " . $__cvn . " : strada_new_undef()");
                    } else {
                        emit($cg, "strada_new_undef()");
                    }
                }
            }
            emit($cg, ";\n");
        }
    }
    # Flush pending lexicals NOW that the init expression has been emitted.
    # This makes the newly-declared var visible to subsequent statements'
    # eval STRING captures without exposing it to its own init expression
    # (where reading the still-uninitialised C variable would segfault).
    if (defined($cg->{"__pending_lex"}) && defined($cg->{"my_lexicals"})) {
        my scalar $__pl = $cg->{"__pending_lex"};
        my int $__pli = 0;
        while ($__pli < scalar(@{$__pl})) {
            push(@{$cg->{"my_lexicals"}}, $__pl->[$__pli]);
            $__pli++;
        }
        $cg->{"__pending_lex"} = undef;
    }
    # Restore the my-line counter so the next decl sees its own line, not
    # this one's value (stashed at function entry).
    $cg->{"current_my_line"} = $__cmy_saved_line;
}
# --- State variable (persists across calls) ---
func _gen_state(scalar $cg, scalar $node) void {
    if (defined($node->{"var"})) {
        my str $vname = $node->{"var"}->{"value"};
        my str $vtype = "" . $node->{"var"}->{"type"};
        if (length($vtype) == 0) { $vtype = "SCALAR_VAR"; }
        # Sigil-aware C var name + sigil-appropriate empty-init. Without
        # this, `state @history` and `state %seen` reused v_<name> (the
        # scalar slot) and initialized to undef — so `push @history,
        # $_` saw a non-array each invocation and dropped data.
        my str $cvar = c_var_for_vtype($vtype, $vname);
        my str $empty_init = "strada_new_undef()";
        if ($vtype eq "ARRAY_VAR") { $empty_init = "strada_new_array()"; }
        elsif ($vtype eq "HASH_VAR") { $empty_init = "strada_new_hash()"; }
        # Per-closure-instance state: if this anon sub was emitted with
        # a state-var pad slot for $vname (find_state_vars added it
        # to captures, create site allocated a fresh refcount cell),
        # the body's `#define v_NAME (*captures[K])` macro is already
        # in scope. Just emit the lazy-init check using the macro.
        # Each closure instance starts with cell->slot = NULL; first
        # call fills it. Sibling closures created at the same scope
        # each get their own cell, matching perl's CV-pad-per-instance.
        my int $is_anon_state = 0;
        if (defined($cg->{"anon_state_capture"})
            && exists($cg->{"anon_state_capture"}->{$vname})) {
            $is_anon_state = 1;
        }
        if ($is_anon_state == 1) {
            # Pad-slot init: INIT expression returns an owned ref
            # (refcount=1). Cell takes ownership directly. No extra
            # incref — strada_cell_decref at closure teardown decrefs
            # the value when the cell's refcount hits 0.
            if (defined($node->{"init"})) {
                ind($cg); emit($cg, "if (!" . $cvar . ") { " . $cvar . " = ");
                gen_expr($cg, $node->{"init"});
                emit($cg, "; }\n");
            } else {
                ind($cg); emit($cg, "if (!" . $cvar . ") { " . $cvar . " = " . $empty_init . "; }\n");
            }
            return;
        }
        $cg->{"tmp_count"} = $cg->{"tmp_count"} + 1;
        my str $flag = "__state_init_" . $cg->{"tmp_count"};
        ind($cg); emit($cg, "static StradaValue *" . $cvar . " = NULL;\n");
        ind($cg); emit($cg, "static int " . $flag . " = 0;\n");
        if (defined($node->{"init"})) {
            ind($cg); emit($cg, "if (!" . $flag . ") { " . $flag . " = 1; " . $cvar . " = ");
            gen_expr($cg, $node->{"init"});
            emit($cg, "; strada_incref(" . $cvar . "); }\n");
        } else {
            ind($cg); emit($cg, "if (!" . $flag . ") { " . $flag . " = 1; " . $cvar . " = " . $empty_init . "; }\n");
        }
        # Track state var so closures returned from this sub capture
        # &v_X (the static) rather than malloc a fresh cell-copy. Per
        # Perl semantics for state declared in NAMED subs: shared
        # across all invocations of the enclosing sub AND across any
        # closures that escape it. For state declared inside an anon
        # sub, the anon_state_capture path above handles per-instance
        # semantics.
        if (!defined($cg->{"state_vars"})) {
            $cg->{"state_vars"} = {};
        }
        $cg->{"state_vars"}->{$vname} = $vtype;
    }
}

# --- Sub definition ---
func _gen_block(scalar $cg, scalar $node) void {
    ind($cg); emit($cg, "{\n");
    $cg->{"indent"} = $cg->{"indent"} + 1;
    # Snapshot the local_vars set on block entry. Any new entries added
    # while generating the block body are scoped to THIS block — restore
    # them when the block closes (Perl `local` semantics: restoration at
    # end of enclosing scope, not at function exit).
    my scalar $saved_locals = {};
    if (defined($cg->{"local_vars"})) {
        my array @keys_before = keys($cg->{"local_vars"});
        my int $ki = 0;
        while ($ki < scalar(@keys_before)) {
            $saved_locals->{$keys_before[$ki]} = 1;
            $ki++;
        }
    }
    # Bare-block is a new lexical scope — reset same_scope_decls so any
    # `my $x` declared inside doesn't trigger the masks-earlier warning
    # against an outer-scope `my $x`.
    my scalar $__bb_saved_ssd = $cg->{"same_scope_decls"};
    $cg->{"same_scope_decls"} = {};
    gen_block_stmts($cg, $node);
    $cg->{"same_scope_decls"} = $__bb_saved_ssd;
    # Restore any `local $g = ...` whose save record was created in this
    # block (not present on entry). The save var __local_save_NAME was
    # written at the local stmt; we re-assign back here.
    if (defined($cg->{"local_vars"})) {
        my array @keys_after = keys($cg->{"local_vars"});
        my int $kj = 0;
        while ($kj < scalar(@keys_after)) {
            my str $kname = $keys_after[$kj];
            if (!defined($saved_locals->{$kname})) {
                my str $kvt = "" . $cg->{"local_vars"}->{$kname};
                if (length($kvt) == 0 || $kvt eq "1") { $kvt = "SCALAR_VAR"; }
                ind($cg); emit($cg, c_var_for_vtype($kvt, $kname) . " = __local_save_" . safe_ident($kname) . ";\n");
                # Mirror globals like perla_irs / perla_ors / perla_ofs / perla_lse
                # are synced at local-set time; resync them at block exit so
                # \`{ local \$/; ... }\` actually restores the input record
                # separator instead of leaving the I/O layer slurping forever.
                if ($kname eq "/") { ind($cg); emit($cg, "perla_irs = __local_save_" . safe_ident($kname) . ";\n"); }
                elsif ($kname eq "\\") { ind($cg); emit($cg, "perla_ors = __local_save_" . safe_ident($kname) . ";\n"); }
                elsif ($kname eq ",") { ind($cg); emit($cg, "perla_ofs = __local_save_" . safe_ident($kname) . ";\n"); }
                elsif ($kname eq "\"") { ind($cg); emit($cg, "perla_lse = __local_save_" . safe_ident($kname) . ";\n"); }
                $cg->{"local_vars"}->{$kname} = "__restored__";
            }
            $kj++;
        }
    }
    $cg->{"indent"} = $cg->{"indent"} - 1;
    ind($cg); emit($cg, "}\n");
}

func gen_block_stmts(scalar $cg, scalar $node) void {
    my scalar $stmts = $node->{"stmts"};
    if (!defined($stmts)) { return; }
    my int $i = 0;
    while ($i < scalar(@{$stmts})) {
        my scalar $s = $stmts->[$i];
        if (defined($s)) { gen_stmt($cg, $s); }
        $i++;
    }
}

# Hoist `my` variable declarations from a loop body before the loop
# Emits `StradaValue *v_name = NULL;` for each scalar variable declared with `my` in the body
# and marks them as declared so the `my` inside the loop just does decref+assign
func _hoist_loop_vars(scalar $cg, scalar $node) void {
    if (!defined($node)) { return; }
    my scalar $stmts = $node->{"stmts"};
    if (!defined($stmts)) { return; }
    # Track hoisted C names so _gen_for_c can decref them at scope exit.
    # Without this, `my $obj` inside `for (my $i; ...) { ... }` holds the
    # last iter's value past the block; the C local goes out of scope and
    # the ref leaks. Caller resets/reads $cg->{"hoisted_loop_vars"}.
    if (!defined($cg->{"hoisted_loop_vars"})) { $cg->{"hoisted_loop_vars"} = []; }
    # For file-scope-tracked vars, the hoist's normal `v_X = NULL;` would
    # clobber the outer lexical that owns that static slot. Instead emit
    # `StradaValue *__hsv_<cname> = <cname>; <cname> = NULL;` to save
    # the outer pointer, and record the cname in `hoisted_shadows` so the
    # caller can emit the corresponding `<cname> = __hsv_<cname>;` restore
    # after the body's hoisted-vars decref runs.
    if (!defined($cg->{"hoisted_shadows"})) { $cg->{"hoisted_shadows"} = []; }
    my int $i = 0;
    while ($i < scalar(@{$stmts})) {
        my scalar $s = $stmts->[$i];
        if (defined($s) && $s->{"type"} == Perla::AST::N_MY()) {
            if (defined($s->{"var"})) {
                my str $vname = $s->{"var"}->{"value"};
                my str $hvt = "" . $s->{"var"}->{"type"};
                if (length($hvt) == 0) { $hvt = "SCALAR_VAR"; }
                my str $hcn = c_var_for_vtype($hvt, $vname);
                if (!defined($cg->{"declared_vars"}->{$hcn})) {
                    if (_is_file_scope($cg, $vname) == 1) {
                        ind($cg); emit($cg, "StradaValue *__hsv_" . $hcn . " = " . $hcn . "; " . $hcn . " = NULL;\n");
                        push(@{$cg->{"hoisted_shadows"}}, $hcn);
                    } else {
                        ind($cg); emit($cg, _my_prefix_vt($cg, $hvt, $vname) . $hcn . " = NULL;\n");
                    }
                    $cg->{"declared_vars"}->{$hcn} = 1;
                    push(@{$cg->{"hoisted_loop_vars"}}, $hcn);
                }
            }
            if (defined($s->{"vars"})) {
                my scalar $vars = $s->{"vars"};
                my int $vi = 0;
                while ($vi < scalar(@{$vars})) {
                    my str $vname = $vars->[$vi]->{"value"};
                    my str $hvt2 = "" . $vars->[$vi]->{"type"};
                    if (length($hvt2) == 0) { $hvt2 = "SCALAR_VAR"; }
                    my str $hcn2 = c_var_for_vtype($hvt2, $vname);
                    if (!defined($cg->{"declared_vars"}->{$hcn2})) {
                        if (_is_file_scope($cg, $vname) == 1) {
                            ind($cg); emit($cg, "StradaValue *__hsv_" . $hcn2 . " = " . $hcn2 . "; " . $hcn2 . " = NULL;\n");
                            push(@{$cg->{"hoisted_shadows"}}, $hcn2);
                        } else {
                            ind($cg); emit($cg, _my_prefix_vt($cg, $hvt2, $vname) . $hcn2 . " = NULL;\n");
                        }
                        $cg->{"declared_vars"}->{$hcn2} = 1;
                        push(@{$cg->{"hoisted_loop_vars"}}, $hcn2);
                    }
                    $vi++;
                }
            }
        }
        $i++;
    }
}

# --- If/Unless ---
func _gen_if(scalar $cg, scalar $node) void {
    # `if (my $X = expr)` — the my-decl in the condition writes to the
    # file-scope-static v_X slot, which would corrupt outer $X for the
    # rest of the program. Detect that pattern, wrap the whole if/elsif/
    # else chain in a C block, save outer v_X, and restore after.
    my array @__if_shadowed = ();
    my scalar $__if_cond_node = $node->{"cond"};
    if (defined($__if_cond_node) && $__if_cond_node->{"type"} == Perla::AST::N_MY()) {
        my scalar $__if_my = $__if_cond_node;
        if (defined($__if_my->{"var"})) {
            my str $__if_vn = $__if_my->{"var"}->{"value"};
            if (_is_file_scope($cg, $__if_vn) == 1) {
                my str $__if_vt = "" . $__if_my->{"var"}->{"type"};
                if (length($__if_vt) == 0) { $__if_vt = "SCALAR_VAR"; }
                push(@__if_shadowed, c_var_for_vtype($__if_vt, $__if_vn));
            }
        }
        if (defined($__if_my->{"vars"})) {
            my int $__if_dvi = 0;
            while ($__if_dvi < scalar(@{$__if_my->{"vars"}})) {
                my scalar $__if_dv = $__if_my->{"vars"}->[$__if_dvi];
                my str $__if_dvn = $__if_dv->{"value"};
                if (_is_file_scope($cg, $__if_dvn) == 1) {
                    my str $__if_dvt = "" . $__if_dv->{"type"};
                    if (length($__if_dvt) == 0) { $__if_dvt = "SCALAR_VAR"; }
                    push(@__if_shadowed, c_var_for_vtype($__if_dvt, $__if_dvn));
                }
                $__if_dvi = $__if_dvi + 1;
            }
        }
    }
    if (scalar(@__if_shadowed) > 0) {
        ind($cg); emit($cg, "{\n");
        $cg->{"indent"} = $cg->{"indent"} + 1;
        my int $__if_shi = 0;
        while ($__if_shi < scalar(@__if_shadowed)) {
            my str $__if_shc = $__if_shadowed[$__if_shi];
            ind($cg); emit($cg, "StradaValue *__if_sav_" . $__if_shc . " = " . $__if_shc . "; " . $__if_shc . " = NULL;\n");
            $__if_shi = $__if_shi + 1;
        }
    }
    ind($cg);
    if ($node->{"type"} == Perla::AST::N_UNLESS()) {
        emit($cg, "if (!(");
        _gen_cond($cg, $node->{"cond"});
        emit($cg, "))");
    } else {
        emit($cg, "if (");
        _gen_cond($cg, $node->{"cond"});
        emit($cg, ")");
    }
    emit($cg, " {\n");
    $cg->{"indent"} = $cg->{"indent"} + 1;
    my str $body_key = "then";
    if ($node->{"type"} == Perla::AST::N_UNLESS()) { $body_key = "body"; }
    # Snapshot declared_vars: each C `{...}` is its own scope, so a `my $x`
    # declared in the if branch is NOT visible in the else branch's C
    # scope. Without restoring, the else branch sees `v_x` in declared_vars
    # and emits `strada_decref(v_x); v_x = NULL;` instead of
    # `StradaValue *v_x = NULL;` — leaving v_x undeclared in C.
    # Surfaced via Abe::Plugin::Excel::_write_field with two elsif branches
    # both doing `my ($month, $day, $year) = ...`.
    my scalar $__if_saved_dv = $cg->{"declared_vars"};
    my scalar $__if_saved_ssd = $cg->{"same_scope_decls"};
    # Also snapshot shared_cells_emitted / closure_cell_mirror — two
    # mutually-exclusive if branches that each build a closure capturing
    # the same var must each emit their own cell allocation. Without
    # reset, branch 2 sees branch 1's cell as "already emitted" and skips
    # the malloc — the closure's captures[N] then points at an
    # uninitialized __perla_cell entry and segfaults on first invocation.
    my scalar $__if_saved_sc = $cg->{"shared_cells_emitted"};
    my scalar $__if_saved_cm = $cg->{"closure_cell_mirror"};
    my hash %__if_branch_dv = ();
    my array @__if_dvk = keys($__if_saved_dv);
    my int $__if_dvi = 0;
    while ($__if_dvi < scalar(@__if_dvk)) {
        $__if_branch_dv{$__if_dvk[$__if_dvi]} = $__if_saved_dv->{$__if_dvk[$__if_dvi]};
        $__if_dvi++;
    }
    $cg->{"declared_vars"} = \%__if_branch_dv;
    $cg->{"same_scope_decls"} = {};
    if (defined($__if_saved_sc)) {
        my hash %__if_branch_sc = ();
        my array @__if_sck = keys($__if_saved_sc);
        my int $__if_sci = 0;
        while ($__if_sci < scalar(@__if_sck)) {
            $__if_branch_sc{$__if_sck[$__if_sci]} = $__if_saved_sc->{$__if_sck[$__if_sci]};
            $__if_sci++;
        }
        $cg->{"shared_cells_emitted"} = \%__if_branch_sc;
    }
    if (defined($__if_saved_cm)) {
        my hash %__if_branch_cm = ();
        my array @__if_cmk = keys($__if_saved_cm);
        my int $__if_cmi = 0;
        while ($__if_cmi < scalar(@__if_cmk)) {
            $__if_branch_cm{$__if_cmk[$__if_cmi]} = $__if_saved_cm->{$__if_cmk[$__if_cmi]};
            $__if_cmi++;
        }
        $cg->{"closure_cell_mirror"} = \%__if_branch_cm;
    }
    # Hoist body's my-vars and decref at branch exit. Without this,
    # `if (COND) { my $w = $1; ...; }` left v_w's value stranded in the
    # C scope when the if-block ended, leaking once per evaluation.
    my scalar $__if_saved_hoisted = $cg->{"hoisted_loop_vars"};
    my scalar $__if_saved_shadows = $cg->{"hoisted_shadows"};
    $cg->{"hoisted_loop_vars"} = [];
    $cg->{"hoisted_shadows"} = [];
    _hoist_loop_vars($cg, $node->{$body_key});
    my scalar $__if_this_hoisted = $cg->{"hoisted_loop_vars"};
    my scalar $__if_this_shadows = $cg->{"hoisted_shadows"};
    # Collect top-level scalar `my $x` decls in the if-branch body so
    # we can decref + NULL them at branch close — matches Perl's
    # block-scoped DESTROY: `if (cond) { my $g = Guard->new; ... }`
    # fires DESTROY at the if-block's close. Same pattern as the
    # sub-local cleanup (Subs.strada); just narrower scope.
    #
    # Two paths: (1) the branch falls through normally — emit decref
    # at the end of the branch body. (2) a `return` inside the body
    # exits early — N_RETURN's cleanup walk handles it via the
    # extended sub_local_scalars list (push our locals, restore after).
    my array @__if_then_locals = ();
    if (defined($node->{$body_key}) && defined($node->{$body_key}->{"stmts"})) {
        my scalar $__ifts = $node->{$body_key}->{"stmts"};
        my int $__ifti = 0;
        while ($__ifti < scalar(@{$__ifts})) {
            my scalar $__iftss = $__ifts->[$__ifti];
            if (defined($__iftss) && $__iftss->{"type"} == Perla::AST::N_MY()
                && defined($__iftss->{"var"})) {
                my str $__iftvt = "" . $__iftss->{"var"}->{"type"};
                if (length($__iftvt) == 0) { $__iftvt = "SCALAR_VAR"; }
                if ($__iftvt eq "SCALAR_VAR") {
                    push(@__if_then_locals, $__iftss->{"var"}->{"value"});
                }
            }
            $__ifti = $__ifti + 1;
        }
    }
    # Extend sub_local_scalars so any nested N_RETURN cleans up these
    # if-branch locals before exiting the sub. Restore the original
    # list after gen_block_stmts returns.
    my scalar $__if_t_sls_saved = $cg->{"sub_local_scalars"};
    if (scalar(@__if_then_locals) > 0) {
        my array @__if_t_sls_ext = ();
        if (defined($__if_t_sls_saved)) {
            my int $__sse_i = 0;
            while ($__sse_i < scalar(@{$__if_t_sls_saved})) {
                push(@__if_t_sls_ext, $__if_t_sls_saved->[$__sse_i]);
                $__sse_i = $__sse_i + 1;
            }
        }
        my int $__add_i = 0;
        while ($__add_i < scalar(@__if_then_locals)) {
            push(@__if_t_sls_ext, $__if_then_locals[$__add_i]);
            $__add_i = $__add_i + 1;
        }
        $cg->{"sub_local_scalars"} = \@__if_t_sls_ext;
    }
    gen_block_stmts($cg, $node->{$body_key});
    $cg->{"sub_local_scalars"} = $__if_t_sls_saved;
    my int $__if_hi = 0;
    while ($__if_hi < scalar(@{$__if_this_hoisted})) {
        ind($cg); emit($cg, "strada_decref(" . $__if_this_hoisted->[$__if_hi] . ");\n");
        $__if_hi = $__if_hi + 1;
    }
    # Emit decref+NULL for collected then-body my-decls at branch end
    # (covers the fall-through path; the return path was handled by the
    # sub_local_scalars extension above).
    my int $__iftl_i = 0;
    while ($__iftl_i < scalar(@__if_then_locals)) {
        my str $__iftl_cv = c_var($__if_then_locals[$__iftl_i]);
        ind($cg); emit($cg, "if (" . $__iftl_cv . ") { strada_decref(" . $__iftl_cv . "); " . $__iftl_cv . " = NULL; }\n");
        $__iftl_i = $__iftl_i + 1;
    }
    # Restore file-scope shadows: outer pointer was saved into __hsv_<cn>
    # at hoist time; the decref above freed the inner value, now point
    # the static slot back at the outer.
    my int $__if_sri = 0;
    while ($__if_sri < scalar(@{$__if_this_shadows})) {
        my str $__if_src = $__if_this_shadows->[$__if_sri];
        ind($cg); emit($cg, $__if_src . " = __hsv_" . $__if_src . ";\n");
        $__if_sri = $__if_sri + 1;
    }
    $cg->{"hoisted_loop_vars"} = $__if_saved_hoisted;
    $cg->{"hoisted_shadows"} = $__if_saved_shadows;
    $cg->{"declared_vars"} = $__if_saved_dv;
    $cg->{"same_scope_decls"} = $__if_saved_ssd;
    $cg->{"shared_cells_emitted"} = $__if_saved_sc;
    $cg->{"closure_cell_mirror"} = $__if_saved_cm;
    $cg->{"indent"} = $cg->{"indent"} - 1;
    ind($cg); emit($cg, "}");
    if (defined($node->{"else"})) {
        emit($cg, " else ");
        if ($node->{"else"}->{"type"} == Perla::AST::N_IF()) {
            _gen_if($cg, $node->{"else"});
            # Emit the if-my close+restore BEFORE the early return so the
            # outermost call's wrap is properly terminated. Inner calls
            # have empty @__if_shadowed and emit nothing here.
            if (scalar(@__if_shadowed) > 0) {
                my int $__if_rsi = 0;
                while ($__if_rsi < scalar(@__if_shadowed)) {
                    my str $__if_rsc = $__if_shadowed[$__if_rsi];
                    ind($cg); emit($cg, "if (" . $__if_rsc . ") strada_decref(" . $__if_rsc . "); " . $__if_rsc . " = __if_sav_" . $__if_rsc . ";\n");
                    $__if_rsi = $__if_rsi + 1;
                }
                $cg->{"indent"} = $cg->{"indent"} - 1;
                ind($cg); emit($cg, "}\n");
            }
            return;
        }
        emit($cg, "{\n");
        $cg->{"indent"} = $cg->{"indent"} + 1;
        # Same scope-restore for the else branch.
        my hash %__if_else_dv = ();
        my array @__if_e_dvk = keys($__if_saved_dv);
        my int $__if_e_dvi = 0;
        while ($__if_e_dvi < scalar(@__if_e_dvk)) {
            $__if_else_dv{$__if_e_dvk[$__if_e_dvi]} = $__if_saved_dv->{$__if_e_dvk[$__if_e_dvi]};
            $__if_e_dvi++;
        }
        $cg->{"declared_vars"} = \%__if_else_dv;
        $cg->{"same_scope_decls"} = {};
        if (defined($__if_saved_sc)) {
            my hash %__if_else_sc = ();
            my array @__if_e_sck = keys($__if_saved_sc);
            my int $__if_e_sci = 0;
            while ($__if_e_sci < scalar(@__if_e_sck)) {
                $__if_else_sc{$__if_e_sck[$__if_e_sci]} = $__if_saved_sc->{$__if_e_sck[$__if_e_sci]};
                $__if_e_sci++;
            }
            $cg->{"shared_cells_emitted"} = \%__if_else_sc;
        }
        if (defined($__if_saved_cm)) {
            my hash %__if_else_cm = ();
            my array @__if_e_cmk = keys($__if_saved_cm);
            my int $__if_e_cmi = 0;
            while ($__if_e_cmi < scalar(@__if_e_cmk)) {
                $__if_else_cm{$__if_e_cmk[$__if_e_cmi]} = $__if_saved_cm->{$__if_e_cmk[$__if_e_cmi]};
                $__if_e_cmi++;
            }
            $cg->{"closure_cell_mirror"} = \%__if_else_cm;
        }
        # Same hoist + shadow handling as the then-branch.
        my scalar $__if_e_saved_hoisted = $cg->{"hoisted_loop_vars"};
        my scalar $__if_e_saved_shadows = $cg->{"hoisted_shadows"};
        $cg->{"hoisted_loop_vars"} = [];
        $cg->{"hoisted_shadows"} = [];
        _hoist_loop_vars($cg, $node->{"else"});
        my scalar $__if_e_this_hoisted = $cg->{"hoisted_loop_vars"};
        my scalar $__if_e_this_shadows = $cg->{"hoisted_shadows"};
        # Collect top-level scalar my-decls in else-body (see then-body
        # comment above).
        my array @__if_else_locals = ();
        if (defined($node->{"else"}) && defined($node->{"else"}->{"stmts"})) {
            my scalar $__ifes = $node->{"else"}->{"stmts"};
            my int $__ifei = 0;
            while ($__ifei < scalar(@{$__ifes})) {
                my scalar $__ifess = $__ifes->[$__ifei];
                if (defined($__ifess) && $__ifess->{"type"} == Perla::AST::N_MY()
                    && defined($__ifess->{"var"})) {
                    my str $__ifevt = "" . $__ifess->{"var"}->{"type"};
                    if (length($__ifevt) == 0) { $__ifevt = "SCALAR_VAR"; }
                    if ($__ifevt eq "SCALAR_VAR") {
                        push(@__if_else_locals, $__ifess->{"var"}->{"value"});
                    }
                }
                $__ifei = $__ifei + 1;
            }
        }
        # Extend sub_local_scalars (see then-branch comment).
        my scalar $__if_e_sls_saved = $cg->{"sub_local_scalars"};
        if (scalar(@__if_else_locals) > 0) {
            my array @__if_e_sls_ext = ();
            if (defined($__if_e_sls_saved)) {
                my int $__esse_i = 0;
                while ($__esse_i < scalar(@{$__if_e_sls_saved})) {
                    push(@__if_e_sls_ext, $__if_e_sls_saved->[$__esse_i]);
                    $__esse_i = $__esse_i + 1;
                }
            }
            my int $__eadd_i = 0;
            while ($__eadd_i < scalar(@__if_else_locals)) {
                push(@__if_e_sls_ext, $__if_else_locals[$__eadd_i]);
                $__eadd_i = $__eadd_i + 1;
            }
            $cg->{"sub_local_scalars"} = \@__if_e_sls_ext;
        }
        gen_block_stmts($cg, $node->{"else"});
        $cg->{"sub_local_scalars"} = $__if_e_sls_saved;
        my int $__if_e_hi = 0;
        while ($__if_e_hi < scalar(@{$__if_e_this_hoisted})) {
            ind($cg); emit($cg, "strada_decref(" . $__if_e_this_hoisted->[$__if_e_hi] . ");\n");
            $__if_e_hi = $__if_e_hi + 1;
        }
        # Emit decref+NULL for else-body my-decls.
        my int $__ifel_i = 0;
        while ($__ifel_i < scalar(@__if_else_locals)) {
            my str $__ifel_cv = c_var($__if_else_locals[$__ifel_i]);
            ind($cg); emit($cg, "if (" . $__ifel_cv . ") { strada_decref(" . $__ifel_cv . "); " . $__ifel_cv . " = NULL; }\n");
            $__ifel_i = $__ifel_i + 1;
        }
        my int $__if_e_sri = 0;
        while ($__if_e_sri < scalar(@{$__if_e_this_shadows})) {
            my str $__if_e_src = $__if_e_this_shadows->[$__if_e_sri];
            ind($cg); emit($cg, $__if_e_src . " = __hsv_" . $__if_e_src . ";\n");
            $__if_e_sri = $__if_e_sri + 1;
        }
        $cg->{"hoisted_loop_vars"} = $__if_e_saved_hoisted;
        $cg->{"hoisted_shadows"} = $__if_e_saved_shadows;
        $cg->{"declared_vars"} = $__if_saved_dv;
        $cg->{"same_scope_decls"} = $__if_saved_ssd;
        $cg->{"shared_cells_emitted"} = $__if_saved_sc;
        $cg->{"closure_cell_mirror"} = $__if_saved_cm;
        $cg->{"indent"} = $cg->{"indent"} - 1;
        ind($cg); emit($cg, "}");
    }
    emit($cg, "\n");
    # Emit the if-my close+restore for the case where this _gen_if call
    # is the chain terminus (no elsif beyond this point).
    if (scalar(@__if_shadowed) > 0) {
        my int $__if_rsi2 = 0;
        while ($__if_rsi2 < scalar(@__if_shadowed)) {
            my str $__if_rsc2 = $__if_shadowed[$__if_rsi2];
            ind($cg); emit($cg, "if (" . $__if_rsc2 . ") strada_decref(" . $__if_rsc2 . "); " . $__if_rsc2 . " = __if_sav_" . $__if_rsc2 . ";\n");
            $__if_rsi2 = $__if_rsi2 + 1;
        }
        $cg->{"indent"} = $cg->{"indent"} - 1;
        ind($cg); emit($cg, "}\n");
    }
}

# As _gen_if, but each branch's last statement (if it's an expression) is
# captured into $ret_var, mirroring Perl's implicit-return-from-if semantics
# at the tail of a sub or do{} block:
#
#   sub schema {
#     if (...) { 5 }
#     else    { 10 }   # the function returns 5 or 10
#   }
#
# Without this, perla's sub-body codegen treats N_IF as a bare statement and
# always falls through to `return strada_undef_static();`. Surfaced via
# DBIC's `sub schema { if (@_>1) {...} else { $self->{schema} || do {...} } }`
# where the schema accessor silently returned undef even when the slot was
# populated, breaking storage()/relname_to_table_alias()/_resolve_join().
func gen_if_capture_return(scalar $cg, scalar $node, str $ret_var) void {
    # Same if-my shadow wrap as _gen_if (see comment there).
    my array @__icr_shadowed = ();
    my scalar $__icr_cond_node = $node->{"cond"};
    if (defined($__icr_cond_node) && $__icr_cond_node->{"type"} == Perla::AST::N_MY()) {
        my scalar $__icr_my = $__icr_cond_node;
        if (defined($__icr_my->{"var"})) {
            my str $__icr_vn = $__icr_my->{"var"}->{"value"};
            if (_is_file_scope($cg, $__icr_vn) == 1) {
                my str $__icr_vt = "" . $__icr_my->{"var"}->{"type"};
                if (length($__icr_vt) == 0) { $__icr_vt = "SCALAR_VAR"; }
                push(@__icr_shadowed, c_var_for_vtype($__icr_vt, $__icr_vn));
            }
        }
        if (defined($__icr_my->{"vars"})) {
            my int $__icr_dvi = 0;
            while ($__icr_dvi < scalar(@{$__icr_my->{"vars"}})) {
                my scalar $__icr_dv = $__icr_my->{"vars"}->[$__icr_dvi];
                my str $__icr_dvn = $__icr_dv->{"value"};
                if (_is_file_scope($cg, $__icr_dvn) == 1) {
                    my str $__icr_dvt = "" . $__icr_dv->{"type"};
                    if (length($__icr_dvt) == 0) { $__icr_dvt = "SCALAR_VAR"; }
                    push(@__icr_shadowed, c_var_for_vtype($__icr_dvt, $__icr_dvn));
                }
                $__icr_dvi = $__icr_dvi + 1;
            }
        }
    }
    if (scalar(@__icr_shadowed) > 0) {
        ind($cg); emit($cg, "{\n");
        $cg->{"indent"} = $cg->{"indent"} + 1;
        my int $__icr_shi = 0;
        while ($__icr_shi < scalar(@__icr_shadowed)) {
            my str $__icr_shc = $__icr_shadowed[$__icr_shi];
            ind($cg); emit($cg, "StradaValue *__icr_sav_" . $__icr_shc . " = " . $__icr_shc . "; " . $__icr_shc . " = NULL;\n");
            $__icr_shi = $__icr_shi + 1;
        }
    }
    ind($cg);
    if ($node->{"type"} == Perla::AST::N_UNLESS()) {
        emit($cg, "if (!(");
        _gen_cond($cg, $node->{"cond"});
        emit($cg, "))");
    } else {
        emit($cg, "if (");
        _gen_cond($cg, $node->{"cond"});
        emit($cg, ")");
    }
    emit($cg, " {\n");
    $cg->{"indent"} = $cg->{"indent"} + 1;
    my str $body_key = "then";
    if ($node->{"type"} == Perla::AST::N_UNLESS()) { $body_key = "body"; }
    # Snapshot/restore declared_vars per branch (see _gen_if comment).
    my scalar $__icr_saved = $cg->{"declared_vars"};
    my scalar $__icr_saved_ssd = $cg->{"same_scope_decls"};
    # Snapshot shared_cells_emitted per branch — without this, two
    # mutually-exclusive branches that each build a closure capturing the
    # same var share state: the second branch sees the first's cell as
    # already-emitted and SKIPS its own malloc, then the closure's
    # captures[N] = NULL → segfault when invoked.
    my scalar $__icr_saved_sc = $cg->{"shared_cells_emitted"};
    my scalar $__icr_saved_cm = $cg->{"closure_cell_mirror"};
    my hash %__icr_b1 = ();
    my array @__icr_k1 = keys($__icr_saved);
    my int $__icr_i1 = 0;
    while ($__icr_i1 < scalar(@__icr_k1)) {
        $__icr_b1{$__icr_k1[$__icr_i1]} = $__icr_saved->{$__icr_k1[$__icr_i1]};
        $__icr_i1++;
    }
    $cg->{"declared_vars"} = \%__icr_b1;
    $cg->{"same_scope_decls"} = {};
    # Reset shared cells state to pre-if snapshot (clone, not alias).
    if (defined($__icr_saved_sc)) {
        my hash %__icr_b1_sc = ();
        my array @__sc_k1 = keys($__icr_saved_sc);
        my int $__sc_i1 = 0;
        while ($__sc_i1 < scalar(@__sc_k1)) {
            $__icr_b1_sc{$__sc_k1[$__sc_i1]} = $__icr_saved_sc->{$__sc_k1[$__sc_i1]};
            $__sc_i1++;
        }
        $cg->{"shared_cells_emitted"} = \%__icr_b1_sc;
    }
    if (defined($__icr_saved_cm)) {
        my hash %__icr_b1_cm = ();
        my array @__cm_k1 = keys($__icr_saved_cm);
        my int $__cm_i1 = 0;
        while ($__cm_i1 < scalar(@__cm_k1)) {
            $__icr_b1_cm{$__cm_k1[$__cm_i1]} = $__icr_saved_cm->{$__cm_k1[$__cm_i1]};
            $__cm_i1++;
        }
        $cg->{"closure_cell_mirror"} = \%__icr_b1_cm;
    }
    _gen_block_stmts_capture_return($cg, $node->{$body_key}, $ret_var);
    $cg->{"declared_vars"} = $__icr_saved;
    $cg->{"same_scope_decls"} = $__icr_saved_ssd;
    $cg->{"shared_cells_emitted"} = $__icr_saved_sc;
    $cg->{"closure_cell_mirror"} = $__icr_saved_cm;
    $cg->{"indent"} = $cg->{"indent"} - 1;
    ind($cg); emit($cg, "}");
    if (defined($node->{"else"})) {
        emit($cg, " else ");
        if ($node->{"else"}->{"type"} == Perla::AST::N_IF()) {
            gen_if_capture_return($cg, $node->{"else"}, $ret_var);
            # if-my close+restore for outer call (see _gen_if).
            if (scalar(@__icr_shadowed) > 0) {
                my int $__icr_rsi = 0;
                while ($__icr_rsi < scalar(@__icr_shadowed)) {
                    my str $__icr_rsc = $__icr_shadowed[$__icr_rsi];
                    ind($cg); emit($cg, "if (" . $__icr_rsc . ") strada_decref(" . $__icr_rsc . "); " . $__icr_rsc . " = __icr_sav_" . $__icr_rsc . ";\n");
                    $__icr_rsi = $__icr_rsi + 1;
                }
                $cg->{"indent"} = $cg->{"indent"} - 1;
                ind($cg); emit($cg, "}\n");
            }
            return;
        }
        emit($cg, "{\n");
        $cg->{"indent"} = $cg->{"indent"} + 1;
        my hash %__icr_b2 = ();
        my array @__icr_k2 = keys($__icr_saved);
        my int $__icr_i2 = 0;
        while ($__icr_i2 < scalar(@__icr_k2)) {
            $__icr_b2{$__icr_k2[$__icr_i2]} = $__icr_saved->{$__icr_k2[$__icr_i2]};
            $__icr_i2++;
        }
        $cg->{"declared_vars"} = \%__icr_b2;
        $cg->{"same_scope_decls"} = {};
        if (defined($__icr_saved_sc)) {
            my hash %__icr_b2_sc = ();
            my array @__sc_k2 = keys($__icr_saved_sc);
            my int $__sc_i2 = 0;
            while ($__sc_i2 < scalar(@__sc_k2)) {
                $__icr_b2_sc{$__sc_k2[$__sc_i2]} = $__icr_saved_sc->{$__sc_k2[$__sc_i2]};
                $__sc_i2++;
            }
            $cg->{"shared_cells_emitted"} = \%__icr_b2_sc;
        }
        if (defined($__icr_saved_cm)) {
            my hash %__icr_b2_cm = ();
            my array @__cm_k2 = keys($__icr_saved_cm);
            my int $__cm_i2 = 0;
            while ($__cm_i2 < scalar(@__cm_k2)) {
                $__icr_b2_cm{$__cm_k2[$__cm_i2]} = $__icr_saved_cm->{$__cm_k2[$__cm_i2]};
                $__cm_i2++;
            }
            $cg->{"closure_cell_mirror"} = \%__icr_b2_cm;
        }
        _gen_block_stmts_capture_return($cg, $node->{"else"}, $ret_var);
        $cg->{"declared_vars"} = $__icr_saved;
        $cg->{"same_scope_decls"} = $__icr_saved_ssd;
        $cg->{"shared_cells_emitted"} = $__icr_saved_sc;
        $cg->{"closure_cell_mirror"} = $__icr_saved_cm;
        $cg->{"indent"} = $cg->{"indent"} - 1;
        ind($cg); emit($cg, "}");
    }
    emit($cg, "\n");
    # if-my close+restore — chain terminus.
    if (scalar(@__icr_shadowed) > 0) {
        my int $__icr_rsi2 = 0;
        while ($__icr_rsi2 < scalar(@__icr_shadowed)) {
            my str $__icr_rsc2 = $__icr_shadowed[$__icr_rsi2];
            ind($cg); emit($cg, "if (" . $__icr_rsc2 . ") strada_decref(" . $__icr_rsc2 . "); " . $__icr_rsc2 . " = __icr_sav_" . $__icr_rsc2 . ";\n");
            $__icr_rsi2 = $__icr_rsi2 + 1;
        }
        $cg->{"indent"} = $cg->{"indent"} - 1;
        ind($cg); emit($cg, "}\n");
    }
}

# Emit a block-node's stmts where the last stmt — if it's an expression —
# is captured into $ret_var. If the last stmt is itself an if/unless, recurse
# so each branch's tail also captures. Other control-flow stmts (return,
# while, for, etc.) are emitted as-is and don't update $ret_var.
# Mirrors gen_block_stmts: takes a node and reads its "stmts" array.
func _gen_block_stmts_capture_return(scalar $cg, scalar $node, str $ret_var) void {
    if (!defined($node)) { return; }
    my scalar $stmts = $node->{"stmts"};
    if (!defined($stmts)) { return; }
    my int $n = scalar(@{$stmts});
    if ($n == 0) { return; }
    my int $i = 0;
    while ($i < $n - 1) {
        gen_stmt($cg, $stmts->[$i]);
        $i++;
    }
    my scalar $last = $stmts->[$n - 1];
    if (!defined($last)) { return; }
    my int $lt = $last->{"type"};
    if ($lt == Perla::AST::N_IF() || $lt == Perla::AST::N_UNLESS()) {
        gen_if_capture_return($cg, $last, $ret_var);
    } elsif ($lt == Perla::AST::N_SUB() && !defined($last->{"name"})) {
        # Anonymous sub { ... } as the last statement of a branch is an
        # expression (closure literal). Capture it as the return value;
        # otherwise the closure is emitted as a statement and the if/else
        # branches yield nothing, breaking `if ... { sub {...} } else { sub {...} }`
        # idioms — common when building dispatch tables conditionally.
        ind($cg); emit($cg, "{ StradaValue *__cap = ");
        gen_expr_safe($cg, $last);
        emit($cg, "; if (__cap) strada_incref(__cap); if (" . $ret_var . ") strada_decref(" . $ret_var . "); " . $ret_var . " = __cap; }\n");
    } elsif ($lt == Perla::AST::N_RETURN() || $lt == Perla::AST::N_WHILE()
             || $lt == Perla::AST::N_UNTIL() || $lt == Perla::AST::N_FOR_C()
             || $lt == Perla::AST::N_FOREACH() || $lt == Perla::AST::N_SUB()
             || $lt == Perla::AST::N_PACKAGE() || $lt == Perla::AST::N_USE()
             || $lt == Perla::AST::N_BEGIN() || $lt == Perla::AST::N_END()
             || $lt == Perla::AST::N_GOTO_SUB()) {
        gen_stmt($cg, $last);
    } else {
        ind($cg); emit($cg, "{ StradaValue *__cap = ");
        gen_expr_safe($cg, $last);
        emit($cg, "; if (__cap) strada_incref(__cap); if (" . $ret_var . ") strada_decref(" . $ret_var . "); " . $ret_var . " = __cap; }\n");
    }
}

# --- While/Until ---
# Track whether we're inside any kind of C loop so bare last/next/redo can
# decide whether a plain break/continue/goto is safe. Set to 1 on entry to
# _gen_while / _gen_foreach / _gen_for_c and restored on exit.
func _gen_while(scalar $cg, scalar $node) void {
    my int $__old_in_loop = 0;
    if (defined($cg->{"in_loop"})) { $__old_in_loop = $cg->{"in_loop"}; }
    $cg->{"in_loop"} = 1;
    _gen_while_inner($cg, $node);
    $cg->{"in_loop"} = $__old_in_loop;
}

func _gen_while_inner(scalar $cg, scalar $node) void {
    my str $label = "";
    my str $user_label = "";
    if (defined($node->{"label"})) {
        $user_label = $node->{"label"};
        $cg->{"label_count"} = $cg->{"label_count"} + 1;
        $label = $user_label . "_" . $cg->{"label_count"};
        $cg->{"label_map"}->{$user_label} = $label;
    }
    if (length($label) > 0) {
        ind($cg); emit($cg, "__perla_redo_" . $label . ":\n");
    }
    # Handle: while (my $var = <$fh>) { ... }
    if (defined($node->{"init_my"})) {
        # Wrap in a block for the declared variable's scope
        ind($cg); emit($cg, "{\n");
        $cg->{"indent"} = $cg->{"indent"} + 1;
        # Declare the variable (without init — loop body does the assignment)
        my scalar $init_my_node = $node->{"init_my"};
        if (defined($init_my_node->{"var"})) {
            my str $imv = $init_my_node->{"var"}->{"value"};
            my str $imvt = "" . $init_my_node->{"var"}->{"type"};
            if (length($imvt) == 0) { $imvt = "SCALAR_VAR"; }
            my str $imcn = c_var_for_vtype($imvt, $imv);
            my str $wh_prefix = "StradaValue *";
            # Check if this is a closure capture
            if (defined($cg->{"capture_vars"})) {
                my str $cv_check = "" . $cg->{"capture_vars"}->{$imcn};
                if (length($cv_check) > 0) { $wh_prefix = ""; }
            }
            # Track the declaration so strict-vars and de-dupe checks see it.
            if (defined($cg->{"declared_vars"})) {
                $cg->{"declared_vars"}->{$imcn} = 1;
            }
            ind($cg); emit($cg, $wh_prefix . $imcn . " = strada_new_undef();\n");
        } elsif (defined($init_my_node->{"vars"})) {
            # Plural destructuring: while (my ($k, $v) = each %h) — declare each as NULL
            my scalar $plvars = $init_my_node->{"vars"};
            my int $pvi = 0;
            while ($pvi < scalar(@{$plvars})) {
                my str $pvn = $plvars->[$pvi]->{"value"};
                my str $pvt = "" . $plvars->[$pvi]->{"type"};
                if (length($pvt) == 0) { $pvt = "SCALAR_VAR"; }
                my str $pvcn = c_var_for_vtype($pvt, $pvn);
                my str $pwh_prefix = "StradaValue *";
                if (defined($cg->{"capture_vars"})) {
                    my str $cv_check2 = "" . $cg->{"capture_vars"}->{$pvcn};
                    if (length($cv_check2) > 0) { $pwh_prefix = ""; }
                }
                if (defined($cg->{"declared_vars"})) {
                    $cg->{"declared_vars"}->{$pvcn} = 1;
                }
                ind($cg); emit($cg, $pwh_prefix . $pvcn . " = NULL;\n");
                $pvi++;
            }
        }
        # Generate while loop — condition re-assigns and checks defined
        ind($cg); emit($cg, "while (1) {\n");
        $cg->{"indent"} = $cg->{"indent"} + 1;
        # Per-iteration local-chain snapshot.
        ind($cg); emit($cg, "void *__w_local_mark_im = __perla_local_chain;\n");
        # Re-assign: $var = <$fh>
        my scalar $init_my = $node->{"init_my"};
        if (defined($init_my->{"var"}) && defined($init_my->{"init"})) {
            my str $imv2 = $init_my->{"var"}->{"value"};
            my str $imvt2 = "" . $init_my->{"var"}->{"type"};
            if (length($imvt2) == 0) { $imvt2 = "SCALAR_VAR"; }
            my str $vname = c_var_for_vtype($imvt2, $imv2);
            # Force list context for ARRAY_VAR / HASH_VAR targets so the
            # RHS doesn't collapse to last-element / entry-count when
            # __perla_want_list is 0 at the surrounding block scope.
            my int $is_listy = ($imvt2 eq "ARRAY_VAR" || $imvt2 eq "HASH_VAR") ? 1 : 0;
            if ($is_listy == 1) {
                ind($cg); emit($cg, $vname . " = ({ int __sav_wl_wm = __perla_want_list; __perla_want_list = 1; StradaValue *__wm_v = ");
                gen_expr($cg, $init_my->{"init"});
                emit($cg, "; __perla_want_list = __sav_wl_wm; __wm_v; });\n");
                # Array/hash boolean: non-empty is true, empty is false.
                # `defined_bool` on a freshly-allocated empty array still
                # returns true, so `while (my @c = splice(...))` looped
                # forever — splice returned an empty array, the loop
                # never broke. Check size > 0 instead.
                if ($imvt2 eq "ARRAY_VAR") {
                    ind($cg); emit($cg, "{ StradaArray *__wm_av = strada_deref_array(" . $vname . "); if (!__wm_av || __wm_av->size == 0) break; }\n");
                } else {
                    ind($cg); emit($cg, "{ StradaHash *__wm_hv = strada_deref_hash(" . $vname . "); if (!__wm_hv || __wm_hv->num_entries == 0) break; }\n");
                }
            } else {
                ind($cg); emit($cg, $vname . " = ");
                gen_expr($cg, $init_my->{"init"});
                emit($cg, ";\n");
                # Perl's `while (my $v = EXPR)` rule: when EXPR is
                # readline-like (<FH>, readline, m//g), auto-wrap in
                # defined() so empty-string lines/zero captures keep
                # the loop running. For other expressions, use plain
                # truthiness — `while (my $v = expr)` with expr
                # returning 0 / "" / undef should exit the loop.
                # Previously this path always used strada_defined_bool,
                # which kept the loop running for `my $v = 0` (`0` is
                # defined!) — an infinite loop for `while (my $v =
                # (cond ? "X" : 0))`.
                my int $imv_use_defined = 0;
                my scalar $imv_init = $init_my->{"init"};
                if (defined($imv_init)) {
                    my int $imv_init_t = $imv_init->{"type"};
                    if ($imv_init_t == Perla::AST::N_READLINE()) {
                        $imv_use_defined = 1;
                    }
                }
                if ($imv_use_defined == 1) {
                    ind($cg); emit($cg, "if (!strada_defined_bool(" . $vname . ")) break;\n");
                } else {
                    ind($cg); emit($cg, "if (!strada_to_bool(" . $vname . ")) break;\n");
                }
            }
        } elsif (defined($init_my->{"vars"}) && defined($init_my->{"init"})) {
            # Plural destructuring: eval in list context, break if empty list, destructure
            my scalar $dvars = $init_my->{"vars"};
            ind($cg); emit($cg, "{\n");
            $cg->{"indent"} = $cg->{"indent"} + 1;
            ind($cg); emit($cg, "int __sav_wl_wf = __perla_want_list; __perla_want_list = 1;\n");
            ind($cg); emit($cg, "StradaValue *__wl = ");
            gen_expr($cg, $init_my->{"init"});
            emit($cg, ";\n");
            ind($cg); emit($cg, "__perla_want_list = __sav_wl_wf;\n");
            ind($cg); emit($cg, "StradaArray *__wa = strada_deref_array(__wl);\n");
            ind($cg); emit($cg, "int __wlen = __wa ? strada_array_length(__wa) : 0;\n");
            ind($cg); emit($cg, "if (__wlen == 0) { strada_decref(__wl); break; }\n");
            my int $dvi = 0;
            while ($dvi < scalar(@{$dvars})) {
                my str $dvt3 = "" . $dvars->[$dvi]->{"type"};
                if (length($dvt3) == 0) { $dvt3 = "SCALAR_VAR"; }
                my str $dvn = c_var_for_vtype($dvt3, $dvars->[$dvi]->{"value"});
                ind($cg); emit($cg, "strada_decref(" . $dvn . "); ");
                emit($cg, $dvn . " = (" . $dvi . " < __wlen ? strada_array_get(__wa, " . $dvi . ") : strada_new_undef());\n");
                ind($cg); emit($cg, "if (" . $dvn . ") strada_incref(" . $dvn . ");\n");
                $dvi++;
            }
            ind($cg); emit($cg, "strada_decref(__wl);\n");
            $cg->{"indent"} = $cg->{"indent"} - 1;
            ind($cg); emit($cg, "}\n");
        }
        gen_block_stmts($cg, $node->{"body"});
        if (length($label) > 0) {
            ind($cg); emit($cg, "__perla_next_" . $label . ": ;\n");
        }
        if (defined($node->{"continue"})) {
            gen_block_stmts($cg, $node->{"continue"});
        }
        ind($cg); emit($cg, "if (__perla_local_chain != __w_local_mark_im) { perla_local_chain_restore_to(__perla_local_chain, __w_local_mark_im); __perla_local_chain = __w_local_mark_im; }\n");
        $cg->{"indent"} = $cg->{"indent"} - 1;
        ind($cg); emit($cg, "}\n");
        if (length($label) > 0) {
            ind($cg); emit($cg, "__perla_end_" . $label . ": ;\n");
        }
        $cg->{"indent"} = $cg->{"indent"} - 1;
        ind($cg); emit($cg, "}\n");
        return;
    }

    # Hoist loop body variable declarations before the loop
    ind($cg); emit($cg, "{\n");
    $cg->{"indent"} = $cg->{"indent"} + 1;
    my scalar $saved_declared = $cg->{"declared_vars"};
    my scalar $__w_saved_ssd = $cg->{"same_scope_decls"};
    $cg->{"declared_vars"} = {};
    $cg->{"same_scope_decls"} = {};
    # Copy parent declared vars so we don't re-hoist them
    my array @sdk = keys($saved_declared);
    my int $sdi = 0;
    while ($sdi < scalar(@sdk)) {
        $cg->{"declared_vars"}->{$sdk[$sdi]} = 1;
        $sdi++;
    }
    my scalar $__w_saved_shadows = $cg->{"hoisted_shadows"};
    $cg->{"hoisted_shadows"} = [];
    _hoist_loop_vars($cg, $node->{"body"});
    my scalar $__w_this_shadows = $cg->{"hoisted_shadows"};
    # Check if condition is a /g regex match — emit position variable
    # so the match advances between iterations. Handles both forms:
    # explicit `while (\$s =~ /pat/g)` (N_BINOP with op =~) and implicit
    # `while (/pat/g)` (standalone N_REGEX against \$_). Without the
    # standalone branch, implicit /g loops infinite-matched at pos 0.
    my str $saved_g_pos = "";
    if (defined($cg->{"regex_g_pos_var"})) { $saved_g_pos = $cg->{"regex_g_pos_var"}; }
    my scalar $cond = $node->{"cond"};
    my int $has_g = 0;
    if (defined($cond) && $cond->{"type"} == Perla::AST::N_BINOP() && $cond->{"op"} eq "=~") {
        my scalar $rr = $cond->{"right"};
        if (defined($rr) && $rr->{"type"} == Perla::AST::N_REGEX() && defined($rr->{"flags"}) && index($rr->{"flags"}, "g") >= 0) {
            $has_g = 1;
        }
    } elsif (defined($cond) && $cond->{"type"} == Perla::AST::N_REGEX() && defined($cond->{"flags"}) && index($cond->{"flags"}, "g") >= 0) {
        $has_g = 1;
    }
    if ($has_g == 1) {
        if (!defined($cg->{"regex_g_id"})) { $cg->{"regex_g_id"} = 0; }
        my str $pos_var = "__perla_gpos_" . $cg->{"regex_g_id"};
        $cg->{"regex_g_id"} = $cg->{"regex_g_id"} + 1;
        ind($cg); emit($cg, "size_t " . $pos_var . " = 0;\n");
        $cg->{"regex_g_pos_var"} = $pos_var;
    }
    # `while/until (my $x = expr)` shadow protection (mirror if-my fix).
    # Detect N_MY in cond targeting file-scope vars; save+null outer
    # before the loop, restore after. Only applies to the regular cond
    # path, not the `init_my` path which already handles its own scope.
    my array @__wl_shadowed = ();
    my scalar $__wl_cond_node = $node->{"cond"};
    if (defined($__wl_cond_node) && $__wl_cond_node->{"type"} == Perla::AST::N_MY()) {
        my scalar $__wl_my = $__wl_cond_node;
        if (defined($__wl_my->{"var"})) {
            my str $__wl_vn = $__wl_my->{"var"}->{"value"};
            if (_is_file_scope($cg, $__wl_vn) == 1) {
                my str $__wl_vt = "" . $__wl_my->{"var"}->{"type"};
                if (length($__wl_vt) == 0) { $__wl_vt = "SCALAR_VAR"; }
                push(@__wl_shadowed, c_var_for_vtype($__wl_vt, $__wl_vn));
            }
        }
        if (defined($__wl_my->{"vars"})) {
            my int $__wl_dvi = 0;
            while ($__wl_dvi < scalar(@{$__wl_my->{"vars"}})) {
                my scalar $__wl_dv = $__wl_my->{"vars"}->[$__wl_dvi];
                my str $__wl_dvn = $__wl_dv->{"value"};
                if (_is_file_scope($cg, $__wl_dvn) == 1) {
                    my str $__wl_dvt = "" . $__wl_dv->{"type"};
                    if (length($__wl_dvt) == 0) { $__wl_dvt = "SCALAR_VAR"; }
                    push(@__wl_shadowed, c_var_for_vtype($__wl_dvt, $__wl_dvn));
                }
                $__wl_dvi = $__wl_dvi + 1;
            }
        }
    }
    if (scalar(@__wl_shadowed) > 0) {
        ind($cg); emit($cg, "{\n");
        $cg->{"indent"} = $cg->{"indent"} + 1;
        my int $__wl_shi = 0;
        while ($__wl_shi < scalar(@__wl_shadowed)) {
            my str $__wl_shc = $__wl_shadowed[$__wl_shi];
            ind($cg); emit($cg, "StradaValue *__wl_sav_" . $__wl_shc . " = " . $__wl_shc . "; " . $__wl_shc . " = NULL;\n");
            $__wl_shi = $__wl_shi + 1;
        }
    }
    ind($cg);
    if ($node->{"type"} == Perla::AST::N_UNTIL()) {
        emit($cg, "while (!(");
        _gen_cond($cg, $node->{"cond"});
        emit($cg, "))");
    } else {
        emit($cg, "while (");
        _gen_cond($cg, $node->{"cond"});
        emit($cg, ")");
    }
    emit($cg, " {\n");
    $cg->{"indent"} = $cg->{"indent"} + 1;
    # Per-iteration local-chain snapshot so `local $x = ...` in the body
    # is restored at iteration end (Perl per-iteration scope semantics).
    ind($cg); emit($cg, "void *__w_local_mark = __perla_local_chain;\n");
    # redo label for bare `redo;` inside this loop.
    if (!defined($cg->{"loop_label_counter"})) { $cg->{"loop_label_counter"} = 0; }
    my int $__lcw = $cg->{"loop_label_counter"} + 1;
    $cg->{"loop_label_counter"} = $__lcw;
    my str $__wredo = "__perla_redo_w_" . $__lcw;
    ind($cg); emit($cg, $__wredo . ": ;\n");
    my str $saved_redo_label_w = "" . $cg->{"redo_label"};
    # Stash synthetic next-label for bare `next` when continue block
    # exists — see _gen_foreach for rationale.
    my str $saved_next_label_w = "";
    if (defined($cg->{"current_next_label"})) { $saved_next_label_w = "" . $cg->{"current_next_label"}; }
    if (defined($node->{"continue"}) && length($label) == 0) {
        $cg->{"current_next_label"} = "__perla_next_anon_" . $__lcw;
    } elsif (length($label) > 0) {
        $cg->{"current_next_label"} = "__perla_next_" . $label;
    } else {
        $cg->{"current_next_label"} = "";
    }
    $cg->{"redo_label"} = $__wredo;
    # Collect top-level scalar my-decls in body for per-iter DESTROY.
    # Without this, the last iter's blessed obj defers to program exit
    # (intermediate iters' values are freed by slot-reassignment on the
    # next iter's `my $x = ...`).
    my array @__w_body_locals = ();
    if (defined($node->{"body"}) && defined($node->{"body"}->{"stmts"})) {
        my scalar $__wbs = $node->{"body"}->{"stmts"};
        my int $__wbi = 0;
        while ($__wbi < scalar(@{$__wbs})) {
            my scalar $__wbss = $__wbs->[$__wbi];
            if (defined($__wbss) && $__wbss->{"type"} == Perla::AST::N_MY()
                && defined($__wbss->{"var"})) {
                my str $__wbvt = "" . $__wbss->{"var"}->{"type"};
                if (length($__wbvt) == 0) { $__wbvt = "SCALAR_VAR"; }
                if ($__wbvt eq "SCALAR_VAR") {
                    push(@__w_body_locals, $__wbss->{"var"}->{"value"});
                }
            }
            $__wbi = $__wbi + 1;
        }
    }
    # Extend sub_local_scalars so a `return` inside the loop body
    # cleans up the iter's locals before exiting the sub (mirrors
    # if-branch handling).
    my scalar $__w_sls_saved = $cg->{"sub_local_scalars"};
    if (scalar(@__w_body_locals) > 0) {
        my array @__w_sls_ext = ();
        if (defined($__w_sls_saved)) {
            my int $__wse_i = 0;
            while ($__wse_i < scalar(@{$__w_sls_saved})) {
                push(@__w_sls_ext, $__w_sls_saved->[$__wse_i]);
                $__wse_i = $__wse_i + 1;
            }
        }
        my int $__wadd_i = 0;
        while ($__wadd_i < scalar(@__w_body_locals)) {
            push(@__w_sls_ext, $__w_body_locals[$__wadd_i]);
            $__wadd_i = $__wadd_i + 1;
        }
        $cg->{"sub_local_scalars"} = \@__w_sls_ext;
    }
    gen_block_stmts($cg, $node->{"body"});
    $cg->{"sub_local_scalars"} = $__w_sls_saved;
    # Per-iter decref+NULL so DESTROY fires at end of EACH iter (not
    # just intermediate iters via the next iter's slot-reassign).
    my int $__wbl_i = 0;
    while ($__wbl_i < scalar(@__w_body_locals)) {
        my str $__wbl_cv = c_var($__w_body_locals[$__wbl_i]);
        ind($cg); emit($cg, "if (" . $__wbl_cv . ") { strada_decref(" . $__wbl_cv . "); " . $__wbl_cv . " = NULL; }\n");
        $__wbl_i = $__wbl_i + 1;
    }
    $cg->{"redo_label"} = $saved_redo_label_w;
    $cg->{"current_next_label"} = $saved_next_label_w;
    if (length($label) > 0) {
        ind($cg); emit($cg, "__perla_next_" . $label . ": ;\n");
    } elsif (defined($node->{"continue"})) {
        # Synthetic next-label for unlabeled while-with-continue.
        ind($cg); emit($cg, "__perla_next_anon_" . $__lcw . ": ;\n");
    }
    # `while (...) { BODY } continue { CONT }` — emit the continue
    # block here so it runs after the body AND after any `next` jump
    # (which lands at __perla_next_LABEL above).
    if (defined($node->{"continue"})) {
        gen_block_stmts($cg, $node->{"continue"});
    }
    ind($cg); emit($cg, "if (__perla_local_chain != __w_local_mark) { perla_local_chain_restore_to(__perla_local_chain, __w_local_mark); __perla_local_chain = __w_local_mark; }\n");
    $cg->{"indent"} = $cg->{"indent"} - 1;
    ind($cg); emit($cg, "}\n");
    if (length($label) > 0) {
        ind($cg); emit($cg, "__perla_end_" . $label . ": ;\n");
    }
    # Close hoisted vars block and restore declared_vars scope
    $cg->{"declared_vars"} = $saved_declared;
    $cg->{"same_scope_decls"} = $__w_saved_ssd;
    $cg->{"regex_g_pos_var"} = $saved_g_pos;
    # Decref + restore hoisted body-shadowed file-scope vars. The body's
    # last-iter `my $x` is still pointing at the inner value; we free it
    # and restore the outer pointer from __hsv_<cn> saved at hoist time.
    my int $__w_sri = 0;
    while ($__w_sri < scalar(@{$__w_this_shadows})) {
        my str $__w_src = $__w_this_shadows->[$__w_sri];
        ind($cg); emit($cg, "if (" . $__w_src . ") strada_decref(" . $__w_src . "); " . $__w_src . " = __hsv_" . $__w_src . ";\n");
        $__w_sri = $__w_sri + 1;
    }
    $cg->{"hoisted_shadows"} = $__w_saved_shadows;
    # Emit while/until-my shadow restore BEFORE closing the wrap block
    # (the save var was declared inside this block; once we emit `}`
    # the C local goes out of scope).
    if (scalar(@__wl_shadowed) > 0) {
        my int $__wl_rsi = 0;
        while ($__wl_rsi < scalar(@__wl_shadowed)) {
            my str $__wl_rsc = $__wl_shadowed[$__wl_rsi];
            ind($cg); emit($cg, "if (" . $__wl_rsc . ") strada_decref(" . $__wl_rsc . "); " . $__wl_rsc . " = __wl_sav_" . $__wl_rsc . ";\n");
            $__wl_rsi = $__wl_rsi + 1;
        }
    }
    $cg->{"indent"} = $cg->{"indent"} - 1;
    ind($cg); emit($cg, "}\n");
    if (scalar(@__wl_shadowed) > 0) {
        $cg->{"indent"} = $cg->{"indent"} - 1;
        ind($cg); emit($cg, "}\n");
    }
}

# --- Foreach ---
func _gen_foreach(scalar $cg, scalar $node) void {
    my int $__old_in_loop_fe = 0;
    if (defined($cg->{"in_loop"})) { $__old_in_loop_fe = $cg->{"in_loop"}; }
    $cg->{"in_loop"} = 1;
    _gen_foreach_inner($cg, $node);
    $cg->{"in_loop"} = $__old_in_loop_fe;
}

func _gen_foreach_inner(scalar $cg, scalar $node) void {
    my str $label = "";
    if (defined($node->{"label"})) {
        my str $user_label = $node->{"label"};
        $cg->{"label_count"} = $cg->{"label_count"} + 1;
        $label = $user_label . "_" . $cg->{"label_count"};
        $cg->{"label_map"}->{$user_label} = $label;
    }
    ind($cg); emit($cg, "/* foreach */\n");
    ind($cg); emit($cg, "{\n");
    $cg->{"indent"} = $cg->{"indent"} + 1;
    # `for (values %h)` / `for (values %$ref)` — Perl aliases the loop var to
    # each hash value slot, so `$_ *= 2` / `$v = X` inside the body writes
    # back into the hash. Detect it here; the list is then iterated key-by-key
    # with a writeback to the hash at the end of each iteration (see below).
    # Gated entirely on $fe_values_alias — normal foreach is unaffected.
    my int $fe_values_alias = 0;
    my scalar $fe_values_hash = undef;
    if (defined($node->{"list"}) && $node->{"list"}->{"type"} == Perla::AST::N_CALL()
        && defined($node->{"list"}->{"name"})
        && ($node->{"list"}->{"name"} eq "values" || $node->{"list"}->{"name"} eq "CORE::values")
        && defined($node->{"list"}->{"args"}) && scalar(@{$node->{"list"}->{"args"}}) == 1) {
        my scalar $varg = $node->{"list"}->{"args"}->[0];
        my int $vat = $varg->{"type"};
        if ($vat == Perla::AST::N_HASH_VAR() || $vat == Perla::AST::N_DEREF_HASH()) {
            $fe_values_alias = 1;
            $fe_values_hash = $varg;
        }
    }
    # Save perla_dollar_underscore around `for (LIST) { ... }` (default $_)
    # so an outer map/sort/grep iter var isn't clobbered. Perl semantics:
    # the for-loop's $_ is an alias to each list element, and after the
    # loop exits $_ is restored to its outer binding. Without this,
    # `map { ...; for (@inner) { ... }; $_->[1] }` reads $_->[1] from
    # the LAST element of @inner instead of the map's iter var. DBIC's
    # `_resolve_column_info` (called from a closure inside DBIC's
    # `_resolve_bindattrs` map) does this internally — so the bind value
    # came out as the wrong array's [1] slot, and the WHERE clause
    # substituted `'HASH(0x…)'` instead of the real column value.
    ind($cg); emit($cg, "StradaValue *__sav_du_fe = perla_dollar_underscore;\n");
    ind($cg); emit($cg, "int __sav_wl_fe = __perla_want_list; __perla_want_list = 1;\n");
    # __fe_vhash / __fe_vkeys are declared unconditionally (NULL for the
    # non-values case) so the writeback emit can reference them safely.
    ind($cg); emit($cg, "StradaValue *__fe_vhash = NULL; StradaArray *__fe_vkeys = NULL;\n");
    if ($fe_values_alias == 1) {
        # Capture the hash and a STABLE key array, then build the values list
        # parallel to those keys. The writeback at iteration end stores the
        # (possibly reassigned) loop var back into the hash under its key.
        ind($cg); emit($cg, "__fe_vhash = ");
        gen_expr($cg, $fe_values_hash);
        emit($cg, ";\n");
        ind($cg); emit($cg, "if (__fe_vhash && !STRADA_IS_TAGGED_INT(__fe_vhash) && __fe_vhash->type == STRADA_REF) __fe_vhash = __fe_vhash->value.rv;\n");
        ind($cg); emit($cg, "__fe_vkeys = __fe_vhash ? strada_hash_keys_sv(__fe_vhash) : NULL;\n");
        ind($cg); emit($cg, "StradaValue *__fe_arr = strada_new_array();\n");
        ind($cg); emit($cg, "{ StradaArray *__fe_vva = strada_deref_array(__fe_arr); if (__fe_vkeys) for (size_t __fe_vi = 0; __fe_vi < __fe_vkeys->size; __fe_vi++) { StradaValue *__fe_vk = __fe_vkeys->elements[__fe_vkeys->head + __fe_vi]; char *__fe_vks = strada_to_str(__fe_vk); StradaValue *__fe_vv = strada_hv_fetch_owned(__fe_vhash, __fe_vks ? __fe_vks : \"\"); if (__fe_vks) free(__fe_vks); strada_array_push_take(__fe_vva, __fe_vv ? __fe_vv : strada_new_undef()); } }\n");
        ind($cg); emit($cg, "__perla_want_list = __sav_wl_fe;\n");
    } else {
        ind($cg); emit($cg, "StradaValue *__fe_arr = ");
        gen_expr($cg, $node->{"list"});
        emit($cg, ";\n");
        ind($cg); emit($cg, "__perla_want_list = __sav_wl_fe;\n");
    }
    # `for (\@arr)` / `for (\%h)` / `for (\$x)` — the list expression
    # evaluates to a single reference value, so the loop iterates once
    # with $_ bound to the ref (Perl list semantics: `\@arr` is one
    # element). Without this special case, the generic deref_array path
    # below would unwrap the REF→ARRAY and iterate the underlying array.
    #
    # Same shape for `for ($aref)` (scalar holding a ref) and `for
    # (CALL())` when the call returns a single arrayref: Perl treats
    # those as 1-element lists. We can't distinguish at codegen time
    # whether a CALL result is "I returned the array" vs "I returned a
    # ref to one", so the rule is: only iterate over the contents when
    # __fe_arr is *directly* an ARRAY value (not a REF→ARRAY).
    my int $list_is_ref = 0;
    if (defined($node->{"list"}) && $node->{"list"}->{"type"} == Perla::AST::N_REF()) {
        $list_is_ref = 1;
    }
    if ($list_is_ref == 1) {
        ind($cg); emit($cg, "StradaArray *__fe_av = NULL;\n");
    } else {
        # Iterate only when the value is directly ARRAY. REF→ARRAY is a
        # 1-element list. Without this, `for my $x ($aref) { }` iterated
        # over the underlying array instead of the ref itself, and
        # `for (CALL_RETURNING_REF()) { }` did the same.
        ind($cg); emit($cg, "StradaArray *__fe_av = (__fe_arr && !STRADA_IS_TAGGED_INT(__fe_arr) && __fe_arr->type == STRADA_ARRAY) ? __fe_arr->value.av : NULL;\n");
    }
    # `for $x (%h)` — Perl flattens the hash to (k1,v1,k2,v2,...) and
    # iterates each scalar. For tied hashes, route through
    # strada_hash_keys_sv (which uses FIRSTKEY/NEXTKEY) and FETCH on
    # each key. Without this, `for (%h)` iterated once with $x = the
    # hash ref / undef.
    ind($cg); emit($cg, "StradaValue *__fe_fb = NULL; ");
    ind($cg); emit($cg, "if (!__fe_av && __fe_arr && !STRADA_IS_TAGGED_INT(__fe_arr) && __fe_arr->type == STRADA_HASH) { ");
    emit($cg, "  __fe_fb = strada_new_array(); StradaArray *__fe_fba = strada_deref_array(__fe_fb); ");
    emit($cg, "  StradaArray *__fe_hk = strada_hash_keys_sv(__fe_arr); ");
    emit($cg, "  if (__fe_hk) for (size_t __fe_hi = 0; __fe_hi < __fe_hk->size; __fe_hi++) { ");
    emit($cg, "    StradaValue *__fe_kv = __fe_hk->elements[__fe_hk->head + __fe_hi]; ");
    emit($cg, "    char *__fe_kstr = strada_to_str(__fe_kv); ");
    emit($cg, "    if (__fe_kv) strada_incref(__fe_kv); strada_array_push_take(__fe_fba, __fe_kv); ");
    emit($cg, "    StradaValue *__fe_vv = strada_hv_fetch_owned(__fe_arr, __fe_kstr ? __fe_kstr : \"\"); ");
    emit($cg, "    if (__fe_kstr) free(__fe_kstr); strada_array_push_take(__fe_fba, __fe_vv ? __fe_vv : strada_new_undef()); ");
    emit($cg, "  } if (__fe_hk) strada_free_array(__fe_hk); ");
    emit($cg, "  __fe_av = __fe_fba; ");
    emit($cg, "} ");
    # `for $k ("col")` — single-elem list parses as a scalar (parens
    # grouping). Wrap into a 1-elem array so the loop iterates once.
    # (`for $k ()` — empty list — leaves __fe_av=NULL with len=0, correct.)
    # `for (undef)` / `for ($x)` where $x is undef iterates once with
    # $_=undef per Perl — wrap the undef value into a 1-elem array too.
    ind($cg); emit($cg, "if (!__fe_av && __fe_arr && !STRADA_IS_TAGGED_INT(__fe_arr)) { ");
    emit($cg, "__fe_fb = strada_new_array(); strada_array_push(strada_deref_array(__fe_fb), __fe_arr); __fe_av = strada_deref_array(__fe_fb); ");
    emit($cg, "} else if (!__fe_av && STRADA_IS_TAGGED_INT(__fe_arr)) { __fe_fb = strada_new_array(); strada_array_push(strada_deref_array(__fe_fb), __fe_arr); __fe_av = strada_deref_array(__fe_fb); }\n");
    ind($cg); emit($cg, "int __fe_len = __fe_av ? strada_array_length(__fe_av) : 0;\n");
    # Outer local-chain mark so `last` / `break` (which skip the
    # per-iteration restore at the bottom of the body) still unwinds
    # locals pushed in the current iteration. The per-iteration restore
    # at the body's tail is still emitted; this outer restore catches
    # the break / labeled-last paths.
    ind($cg); emit($cg, "void *__fe_outer_local_mark = __perla_local_chain;\n");
    # Hoist body's my-decls so file-scope shadows get save/restore
    # (same mechanism as if/while). The hoist emits at this point
    # (inside foreach's outer wrap, before the for loop) so the save
    # var is in scope for the restore after the loop.
    my scalar $__fe_saved_shadows = $cg->{"hoisted_shadows"};
    my scalar $__fe_saved_hoisted_lv = $cg->{"hoisted_loop_vars"};
    $cg->{"hoisted_shadows"} = [];
    $cg->{"hoisted_loop_vars"} = [];
    _hoist_loop_vars($cg, $node->{"body"});
    my scalar $__fe_this_shadows = $cg->{"hoisted_shadows"};
    my scalar $__fe_this_hoisted = $cg->{"hoisted_loop_vars"};
    if (length($label) > 0) {
        ind($cg); emit($cg, "__perla_redo_" . $label . ":\n");
    }
    ind($cg); emit($cg, "for (int __fe_i = 0; __fe_i < __fe_len; __fe_i++) {\n");
    $cg->{"indent"} = $cg->{"indent"} + 1;
    # Snapshot the local-chain head at the START of each iteration so
    # `local $x = ...` inside the body is restored at iteration end
    # (Perl per-iteration scope semantics).
    ind($cg); emit($cg, "void *__fe_local_mark = __perla_local_chain;\n");
    my str $vname = $node->{"var"}->{"value"};
    my str $cvar = c_var($vname);
    my str $fe_prefix = "StradaValue *";
    if ($vname eq "" || $vname eq "_") {
        $cvar = "perla_dollar_underscore";
        $fe_prefix = "";  # perla_dollar_underscore is a global, don't redeclare
    }
    # Check if this is a closure capture (#define'd variable)
    if (defined($cg->{"capture_vars"})) {
        my str $cv_check = "" . $cg->{"capture_vars"}->{$cvar};
        if (length($cv_check) > 0) {
            $fe_prefix = "";  # Captured var — don't redeclare
        }
    }
    ind($cg); emit($cg, $fe_prefix . $cvar . " = strada_array_get(__fe_av, __fe_i);\n");
    # Perl-style for-loop aliasing: body-side `$r = expr` writes through to
    # the array element. Snapshot the original pointer; if the body changed
    # it, write the new value back. Required by DBIC's _construct_results
    # `for my $r (@$rows) { $r = $inflator->(...); }` row inflation pattern.
    # incref before strada_array_set because set takes ownership without
    # increfing — safe for both fresh allocations and aliased existing
    # values. (For fresh allocations we leak 1 ref per reassigned iteration
    # — same magnitude as the pre-existing leak when v_r is reassigned with
    # no writeback.)
    ind($cg); emit($cg, "StradaValue *__orig_" . $cvar . " = " . $cvar . ";\n");
    # Mark the loop variable as declared in this scope so inner `my $same_name`
    # doesn't emit a C redeclaration (Perl allows shadowing; C doesn't in the
    # same block). Restored after the body.
    my int $saved_fe_declared = 0;
    if (defined($cg->{"declared_vars"}->{$cvar})) { $saved_fe_declared = 1; }
    $cg->{"declared_vars"}->{$cvar} = 1;
    if (!defined($cg->{"loop_label_counter"})) { $cg->{"loop_label_counter"} = 0; }
    my int $__lcf = $cg->{"loop_label_counter"} + 1;
    $cg->{"loop_label_counter"} = $__lcf;
    my str $__fredo = "__perla_redo_f_" . $__lcf;
    ind($cg); emit($cg, $__fredo . ": ;\n");
    my str $saved_redo_label_f = "" . $cg->{"redo_label"};
    $cg->{"redo_label"} = $__fredo;
    # If continue block exists, stash a synthetic next-label so bare
    # `next` jumps to it instead of using C `continue` (which skips
    # the perla-continue block).
    my str $saved_next_label_f = "";
    if (defined($cg->{"current_next_label"})) { $saved_next_label_f = "" . $cg->{"current_next_label"}; }
    if (defined($node->{"continue"}) && length($label) == 0) {
        $cg->{"current_next_label"} = "__perla_next_anon_" . $__lcf;
    } elsif (length($label) > 0) {
        $cg->{"current_next_label"} = "__perla_next_" . $label;
    } else {
        $cg->{"current_next_label"} = "";
    }
    # Push the iter var onto my_lexicals so closures inside the body
    # capture this iteration's slot (not the file-scope static of the
    # same name). Without this, `my $n = 99; for my $n (1..3) { push
    # @subs, sub { $n } }` had the closure read file-scope v_n (== 99)
    # because find_free_vars saw `n` in file_scope_vars and skipped
    # it — every closure returned 99 / 0 instead of the iter value.
    # Only applies to `for my $X` (not `for $X` over a pre-existing X).
    # Tag the entry with from_foreach=1 so closure-cell-init can tell
    # this is a per-iteration shadow that needs malloc, NOT a regular
    # my-decl that should share storage with outer file-scope.
    my int $__fe_pushed_lex = 0;
    if (defined($node->{"my"}) && $node->{"my"} == 1
        && length($vname) > 0 && $vname ne "_"
        && defined($cg->{"my_lexicals"})) {
        my scalar $__fe_lex_entry = {};
        $__fe_lex_entry->{"name"} = $vname;
        $__fe_lex_entry->{"c_name"} = $cvar;
        $__fe_lex_entry->{"sigil"} = "\$";
        $__fe_lex_entry->{"from_foreach"} = 1;
        push(@{$cg->{"my_lexicals"}}, $__fe_lex_entry);
        $__fe_pushed_lex = 1;
    }
    # Collect body my-decls for per-iter DESTROY (mirrors while-body fix).
    my array @__fe_body_locals = ();
    if (defined($node->{"body"}) && defined($node->{"body"}->{"stmts"})) {
        my scalar $__febs = $node->{"body"}->{"stmts"};
        my int $__febi = 0;
        while ($__febi < scalar(@{$__febs})) {
            my scalar $__febss = $__febs->[$__febi];
            if (defined($__febss) && $__febss->{"type"} == Perla::AST::N_MY()
                && defined($__febss->{"var"})) {
                my str $__febvt = "" . $__febss->{"var"}->{"type"};
                if (length($__febvt) == 0) { $__febvt = "SCALAR_VAR"; }
                if ($__febvt eq "SCALAR_VAR") {
                    push(@__fe_body_locals, $__febss->{"var"}->{"value"});
                }
            }
            $__febi = $__febi + 1;
        }
    }
    my scalar $__fe_sls_saved = $cg->{"sub_local_scalars"};
    if (scalar(@__fe_body_locals) > 0) {
        my array @__fe_sls_ext = ();
        if (defined($__fe_sls_saved)) {
            my int $__fese_i = 0;
            while ($__fese_i < scalar(@{$__fe_sls_saved})) {
                push(@__fe_sls_ext, $__fe_sls_saved->[$__fese_i]);
                $__fese_i = $__fese_i + 1;
            }
        }
        my int $__feadd_i = 0;
        while ($__feadd_i < scalar(@__fe_body_locals)) {
            push(@__fe_sls_ext, $__fe_body_locals[$__feadd_i]);
            $__feadd_i = $__feadd_i + 1;
        }
        $cg->{"sub_local_scalars"} = \@__fe_sls_ext;
    }
    # Foreach body is a new lexical scope — reset same_scope_decls so a `my $x`
    # in the body doesn't trigger "masks earlier declaration" against an
    # outer `my $x`.
    my scalar $__fe_saved_ssd = $cg->{"same_scope_decls"};
    $cg->{"same_scope_decls"} = {};
    gen_block_stmts($cg, $node->{"body"});
    $cg->{"same_scope_decls"} = $__fe_saved_ssd;
    $cg->{"sub_local_scalars"} = $__fe_sls_saved;
    # Per-iter decref+NULL of body my-decls.
    my int $__febl_i = 0;
    while ($__febl_i < scalar(@__fe_body_locals)) {
        my str $__febl_cv = c_var($__fe_body_locals[$__febl_i]);
        ind($cg); emit($cg, "if (" . $__febl_cv . ") { strada_decref(" . $__febl_cv . "); " . $__febl_cv . " = NULL; }\n");
        $__febl_i = $__febl_i + 1;
    }
    if ($__fe_pushed_lex == 1) {
        pop(@{$cg->{"my_lexicals"}});
        # Clear the shared-cells-emitted marker for this iter var so a
        # subsequent `for my $SAME (...)` block at the same scope level
        # emits a fresh per-iteration malloc instead of skipping cell
        # init and reusing whatever __perla_cell[N] last pointed at.
        # Without this, the second loop's closures all read the FIRST
        # loop's final $i value (or worse, freed memory).
        if (defined($cg->{"shared_cells_emitted"})
            && defined($cg->{"shared_cells_emitted"}->{$vname})) {
            $cg->{"shared_cells_emitted"}->{$vname} = undef;
        }
        if (defined($cg->{"closure_cell_mirror"})
            && defined($cg->{"closure_cell_mirror"}->{$vname})) {
            $cg->{"closure_cell_mirror"}->{$vname} = undef;
        }
        if (defined($cg->{"cells_malloc_d"})
            && defined($cg->{"cells_malloc_d"}->{$vname})) {
            $cg->{"cells_malloc_d"}->{$vname} = undef;
        }
    }
    $cg->{"redo_label"} = $saved_redo_label_f;
    $cg->{"current_next_label"} = $saved_next_label_f;
    if ($saved_fe_declared == 0) {
        $cg->{"declared_vars"}->{$cvar} = undef;
    }
    if (length($label) > 0) {
        ind($cg); emit($cg, "__perla_next_" . $label . ": ;\n");
    } elsif (defined($node->{"continue"})) {
        # No user label, but a continue block exists — emit a synthetic
        # next-label so unlabeled `next` jumps to it (and then runs
        # the continue block). Without this, bare `next` becomes
        # C `continue` which SKIPS the continue block (it sits below
        # the next site in the C for-body), missing iter's continue.
        ind($cg); emit($cg, "__perla_next_anon_" . $__lcf . ": ;\n");
    }
    # `foreach my $x (...) { ... } continue { ... }` — continue block
    # runs after the body and after `next` jumps to __perla_next_LABEL.
    if (defined($node->{"continue"})) {
        gen_block_stmts($cg, $node->{"continue"});
    }
    # Aliasing writeback (placed after the next-label so `next LABEL` jumps
    # also flow through the writeback path).
    ind($cg); emit($cg, "if (" . $cvar . " != __orig_" . $cvar . ") { strada_incref(" . $cvar . "); strada_array_set(__fe_av, __fe_i, " . $cvar . "); }\n");
    # `for (values %h)` aliasing: store the (possibly reassigned) loop var
    # back into the hash under this iteration's key.
    if ($fe_values_alias == 1) {
        ind($cg); emit($cg, "if (__fe_vkeys && __fe_i < (int)__fe_vkeys->size) { StradaValue *__fe_wk = __fe_vkeys->elements[__fe_vkeys->head + __fe_i]; char *__fe_wks = strada_to_str(__fe_wk); strada_hv_store(__fe_vhash, __fe_wks ? __fe_wks : \"\", " . $cvar . "); if (__fe_wks) free(__fe_wks); }\n");
    }
    # Per-iteration local-chain restore — unwind any `local $x = ...`
    # that the body pushed.
    ind($cg); emit($cg, "if (__perla_local_chain != __fe_local_mark) { perla_local_chain_restore_to(__perla_local_chain, __fe_local_mark); __perla_local_chain = __fe_local_mark; }\n");
    $cg->{"indent"} = $cg->{"indent"} - 1;
    ind($cg); emit($cg, "}\n");
    # `for (values %h)` cleanup: free the stable key array and the temp values
    # list built for the iteration (mirrors the %h-flatten cleanup above).
    if ($fe_values_alias == 1) {
        ind($cg); emit($cg, "if (__fe_vkeys) strada_free_array(__fe_vkeys);\n");
        ind($cg); emit($cg, "if (__fe_arr) strada_decref(__fe_arr);\n");
    }
    if (length($label) > 0) {
        ind($cg); emit($cg, "__perla_end_" . $label . ": ;\n");
    }
    # Outer chain unwind: catches `last` / `break` paths where the
    # per-iteration restore at body's tail didn't run. Idempotent on
    # the natural-exit path (chain == outer mark already).
    ind($cg); emit($cg, "if (__perla_local_chain != __fe_outer_local_mark) { perla_local_chain_restore_to(__perla_local_chain, __fe_outer_local_mark); __perla_local_chain = __fe_outer_local_mark; }\n");
    # Decref and restore body's hoisted shadows (file-scope shadowing
    # vars). Last-iter value freed; static slot pointed back at outer
    # via __hsv_<cn>.
    my int $__fe_sri = 0;
    while ($__fe_sri < scalar(@{$__fe_this_shadows})) {
        my str $__fe_src = $__fe_this_shadows->[$__fe_sri];
        ind($cg); emit($cg, "if (" . $__fe_src . ") strada_decref(" . $__fe_src . "); " . $__fe_src . " = __hsv_" . $__fe_src . ";\n");
        $__fe_sri = $__fe_sri + 1;
    }
    $cg->{"hoisted_shadows"} = $__fe_saved_shadows;
    $cg->{"hoisted_loop_vars"} = $__fe_saved_hoisted_lv;
    # Restore perla_dollar_underscore (only matters when the loop's iter
    # var was the default $_; if it had a `my $x` form the assignment
    # was to a different cell anyway, but the restore is harmless).
    if ($vname eq "" || $vname eq "_") {
        ind($cg); emit($cg, "perla_dollar_underscore = __sav_du_fe;\n");
    }
    $cg->{"indent"} = $cg->{"indent"} - 1;
    ind($cg); emit($cg, "}\n");
}

# --- C-style for ---
func _gen_for_c(scalar $cg, scalar $node) void {
    my int $__old_in_loop_fc = 0;
    if (defined($cg->{"in_loop"})) { $__old_in_loop_fc = $cg->{"in_loop"}; }
    $cg->{"in_loop"} = 1;
    _gen_for_c_inner($cg, $node);
    $cg->{"in_loop"} = $__old_in_loop_fc;
}

func _gen_for_c_inner(scalar $cg, scalar $node) void {
    my scalar $init = $node->{"init"};
    # Unique ID for this for loop (supports nesting)
    if (!defined($cg->{"for_c_id"})) { $cg->{"for_c_id"} = 0; }
    my int $for_id = $cg->{"for_c_id"};
    $cg->{"for_c_id"} = $for_id + 1;
    my str $step_label = "__perla_for_step_" . $for_id;
    # If init is a my declaration, emit it before the for and use the variable
    if (defined($init) && $init->{"type"} == Perla::AST::N_MY()) {
        # `for (my $x = ...; ...)` where outer $x is file-scope-tracked
        # — same shadow protection as if-my. Save outer pointer before
        # the my-decl reassigns the static slot, restore after the loop.
        my array @__fc_shadowed = ();
        if (defined($init->{"var"})) {
            my str $__fc_vn = $init->{"var"}->{"value"};
            if (_is_file_scope($cg, $__fc_vn) == 1) {
                my str $__fc_vt = "" . $init->{"var"}->{"type"};
                if (length($__fc_vt) == 0) { $__fc_vt = "SCALAR_VAR"; }
                push(@__fc_shadowed, c_var_for_vtype($__fc_vt, $__fc_vn));
            }
        }
        if (defined($init->{"vars"})) {
            my int $__fc_dvi = 0;
            while ($__fc_dvi < scalar(@{$init->{"vars"}})) {
                my scalar $__fc_dv = $init->{"vars"}->[$__fc_dvi];
                my str $__fc_dvn = $__fc_dv->{"value"};
                if (_is_file_scope($cg, $__fc_dvn) == 1) {
                    my str $__fc_dvt = "" . $__fc_dv->{"type"};
                    if (length($__fc_dvt) == 0) { $__fc_dvt = "SCALAR_VAR"; }
                    push(@__fc_shadowed, c_var_for_vtype($__fc_dvt, $__fc_dvn));
                }
                $__fc_dvi = $__fc_dvi + 1;
            }
        }
        ind($cg); emit($cg, "{\n");
        $cg->{"indent"} = $cg->{"indent"} + 1;
        my int $__fc_shi = 0;
        while ($__fc_shi < scalar(@__fc_shadowed)) {
            my str $__fc_shc = $__fc_shadowed[$__fc_shi];
            ind($cg); emit($cg, "StradaValue *__fc_sav_" . $__fc_shc . " = " . $__fc_shc . "; " . $__fc_shc . " = NULL;\n");
            $__fc_shi = $__fc_shi + 1;
        }
        _gen_my($cg, $init);
        my scalar $saved_declared_fc = $cg->{"declared_vars"};
        my scalar $__fc_saved_ssd = $cg->{"same_scope_decls"};
        $cg->{"declared_vars"} = {};
        $cg->{"same_scope_decls"} = {};
        my array @sdk2 = keys($saved_declared_fc);
        my int $sdi2 = 0;
        while ($sdi2 < scalar(@sdk2)) {
            $cg->{"declared_vars"}->{$sdk2[$sdi2]} = 1;
            $sdi2++;
        }
        my scalar $saved_hoisted = $cg->{"hoisted_loop_vars"};
        my scalar $__fcb_saved_shadows = $cg->{"hoisted_shadows"};
        $cg->{"hoisted_loop_vars"} = [];
        $cg->{"hoisted_shadows"} = [];
        _hoist_loop_vars($cg, $node->{"body"});
        my scalar $this_hoisted = $cg->{"hoisted_loop_vars"};
        my scalar $__fcb_this_shadows = $cg->{"hoisted_shadows"};
        ind($cg); emit($cg, "while (");
        if (defined($node->{"cond"})) {
            _gen_cond($cg, $node->{"cond"});
        } else {
            emit($cg, "1");
        }
        emit($cg, ") {\n");
        $cg->{"indent"} = $cg->{"indent"} + 1;
        ind($cg); emit($cg, "void *__fc_local_mark = __perla_local_chain;\n");
        my str $redo_label = "__perla_redo_" . $for_id;
        ind($cg); emit($cg, $redo_label . ": ;\n");
        my int $saved_in_for_c = $cg->{"in_for_c"};
        my str $saved_step_label = "" . $cg->{"for_step_label"};
        my str $saved_redo_label = "" . $cg->{"redo_label"};
        $cg->{"in_for_c"} = 1;
        $cg->{"for_step_label"} = $step_label;
        $cg->{"redo_label"} = $redo_label;
        gen_block_stmts($cg, $node->{"body"});
        $cg->{"in_for_c"} = $saved_in_for_c;
        $cg->{"for_step_label"} = $saved_step_label;
        $cg->{"redo_label"} = $saved_redo_label;
        # Step expression — placed at unique label so next can reach it
        ind($cg); emit($cg, $step_label . ": ");
        if (defined($node->{"steps"})) {
            # Comma-separated step list (`$i++, $j--`): emit as a single
            # C statement with each expr inside an evaluated (cast)(void)
            # wrapper so values are discarded but side effects run.
            my int $__ssi = 0;
            my scalar $__ss_arr = $node->{"steps"};
            while ($__ssi < scalar(@{$__ss_arr})) {
                if ($__ssi > 0) { emit($cg, ", "); }
                emit($cg, "(void)(");
                gen_expr($cg, $__ss_arr->[$__ssi]);
                emit($cg, ")");
                $__ssi = $__ssi + 1;
            }
        } elsif (defined($node->{"step"})) {
            gen_expr($cg, $node->{"step"});
        } else {
            emit($cg, "(void)0");
        }
        emit($cg, ";\n");
        ind($cg); emit($cg, "if (__perla_local_chain != __fc_local_mark) { perla_local_chain_restore_to(__perla_local_chain, __fc_local_mark); __perla_local_chain = __fc_local_mark; }\n");
        $cg->{"indent"} = $cg->{"indent"} - 1;
        ind($cg); emit($cg, "}\n");
        # Decref hoisted my-vars at end of loop block — without this the
        # final iter's value is held by the block-local C var until scope
        # exit and never freed (the file-scope static was shadowed).
        # Visible as the bless_create / func_call per-iter leak.
        my int $hi = 0;
        while ($hi < scalar(@{$this_hoisted})) {
            ind($cg); emit($cg, "strada_decref(" . $this_hoisted->[$hi] . ");\n");
            $hi = $hi + 1;
        }
        # Restore body shadows (file-scope hoisted in body).
        my int $__fcb_sri = 0;
        while ($__fcb_sri < scalar(@{$__fcb_this_shadows})) {
            my str $__fcb_src = $__fcb_this_shadows->[$__fcb_sri];
            ind($cg); emit($cg, "if (" . $__fcb_src . ") strada_decref(" . $__fcb_src . "); " . $__fcb_src . " = __hsv_" . $__fcb_src . ";\n");
            $__fcb_sri = $__fcb_sri + 1;
        }
        $cg->{"hoisted_loop_vars"} = $saved_hoisted;
        $cg->{"hoisted_shadows"} = $__fcb_saved_shadows;
        $cg->{"declared_vars"} = $saved_declared_fc;
        $cg->{"same_scope_decls"} = $__fc_saved_ssd;
        # Restore shadowed file-scope vars at end of for-loop block
        # (from for-c init my-decl).
        my int $__fc_rsi = 0;
        while ($__fc_rsi < scalar(@__fc_shadowed)) {
            my str $__fc_rsc = $__fc_shadowed[$__fc_rsi];
            ind($cg); emit($cg, "if (" . $__fc_rsc . ") strada_decref(" . $__fc_rsc . "); " . $__fc_rsc . " = __fc_sav_" . $__fc_rsc . ";\n");
            $__fc_rsi = $__fc_rsi + 1;
        }
        $cg->{"indent"} = $cg->{"indent"} - 1;
        ind($cg); emit($cg, "}\n");
    } else {
        ind($cg); emit($cg, "for (");
        if (defined($init)) {
            gen_expr($cg, $init);
        }
        emit($cg, "; ");
        if (defined($node->{"cond"})) {
            _gen_cond($cg, $node->{"cond"});
        } else {
            emit($cg, "1");
        }
        emit($cg, "; ");
        if (defined($node->{"steps"})) {
            my int $__ssi2 = 0;
            my scalar $__ss_arr2 = $node->{"steps"};
            while ($__ssi2 < scalar(@{$__ss_arr2})) {
                if ($__ssi2 > 0) { emit($cg, ", "); }
                emit($cg, "(void)(");
                gen_expr($cg, $__ss_arr2->[$__ssi2]);
                emit($cg, ")");
                $__ssi2 = $__ssi2 + 1;
            }
        } elsif (defined($node->{"step"})) {
            gen_expr($cg, $node->{"step"});
        }
        emit($cg, ") {\n");
        $cg->{"indent"} = $cg->{"indent"} + 1;
        ind($cg); emit($cg, "void *__fc_local_mark2 = __perla_local_chain;\n");
        my str $redo_label2 = "__perla_redo_" . $for_id;
        ind($cg); emit($cg, $redo_label2 . ": ;\n");
        my str $saved_redo_label2 = "" . $cg->{"redo_label"};
        $cg->{"redo_label"} = $redo_label2;
        gen_block_stmts($cg, $node->{"body"});
        $cg->{"redo_label"} = $saved_redo_label2;
        ind($cg); emit($cg, "if (__perla_local_chain != __fc_local_mark2) { perla_local_chain_restore_to(__perla_local_chain, __fc_local_mark2); __perla_local_chain = __fc_local_mark2; }\n");
        $cg->{"indent"} = $cg->{"indent"} - 1;
        ind($cg); emit($cg, "}\n");
    }
}

# --- Expression generation ---
func gen_expr(scalar $cg, scalar $node) void {
    if (!defined($node)) { emit($cg, "strada_new_undef()"); return; }
    my int $type = $node->{"type"};

    if ($type == Perla::AST::N_INT_LIT()) {
        # Tagged ints store 62 bits of signed integer. Values outside
        # [-2^62, 2^62-1] would corrupt during the `(val << 1) | 1` encode
        # (e.g., 9223372036854775807 shifted left becomes -2, then ORed
        # gives -1). Emit those as heap ints via strada_new_int instead.
        my str $litv = "" . $node->{"value"};
        my int $needs_heap = 0;
        # Compare magnitude as a string vs the boundary 4611686018427387904
        my str $cmp_lit = $litv;
        my int $is_neg = 0;
        if (length($cmp_lit) > 0 && substr($cmp_lit, 0, 1) eq "-") {
            $is_neg = 1;
            $cmp_lit = substr($cmp_lit, 1, length($cmp_lit) - 1);
        }
        # Strip leading zeros
        while (length($cmp_lit) > 1 && substr($cmp_lit, 0, 1) eq "0") {
            $cmp_lit = substr($cmp_lit, 1, length($cmp_lit) - 1);
        }
        if (length($cmp_lit) > 19) {
            $needs_heap = 1;
        } elsif (length($cmp_lit) == 19) {
            # Compare against "4611686018427387903" (positive) or
            # "4611686018427387904" (allowed magnitude for negative).
            my str $bound;
            if ($is_neg == 1) { $bound = "4611686018427387904"; }
            else { $bound = "4611686018427387903"; }
            if ($cmp_lit gt $bound) { $needs_heap = 1; }
        }
        # Above the i64 range: a POSITIVE literal that still fits an
        # unsigned 64-bit (<= 18446744073709551615) becomes a UV via
        # strada_new_uint — matching Perl, which holds such values as UV
        # rather than promoting to NV. Only literals beyond UINT64_MAX (or
        # any out-of-range negative) fall back to NUM (double), since they
        # can't be represented exactly as an integer at all.
        my int $needs_num = 0;
        my int $needs_uint = 0;
        if ($is_neg == 1) {
            # Negatives can't be UV. NUM if magnitude exceeds INT64 min.
            if (length($cmp_lit) > 19) {
                $needs_num = 1;
            } elsif (length($cmp_lit) == 19 && $cmp_lit gt "9223372036854775808") {
                $needs_num = 1;
            }
        } else {
            if (length($cmp_lit) > 20) {
                $needs_num = 1;
            } elsif (length($cmp_lit) == 20) {
                if ($cmp_lit gt "18446744073709551615") { $needs_num = 1; }
                else { $needs_uint = 1; }
            } elsif (length($cmp_lit) == 19 && $cmp_lit gt "9223372036854775807") {
                $needs_uint = 1;
            }
        }
        # Under `use bigint`, a literal that doesn't fit a tagged int is carried
        # as an exact decimal string (the bignum representation) rather than
        # losing precision as a UV/double — `99999999999999999999 + 1` etc.
        if (defined($cg->{"use_bigint"}) && $cg->{"use_bigint"} == 1
            && ($needs_num == 1 || $needs_uint == 1 || $needs_heap == 1)) {
            emit($cg, "strada_new_str(\"" . $litv . "\")");
            return;
        }
        if ($needs_num == 1) {
            emit($cg, "strada_new_num(" . $litv . ".0)");
        } elsif ($needs_uint == 1) {
            emit($cg, "strada_new_uint(" . $litv . "ULL)");
        } elsif ($needs_heap == 1) {
            emit($cg, "strada_new_int((int64_t)" . $litv . "LL)");
        } else {
            emit($cg, "STRADA_MAKE_TAGGED_INT(" . $litv . ")");
        }
        return;
    }
    if ($type == Perla::AST::N_NUM_LIT()) {
        emit($cg, "strada_new_num(" . $node->{"value"} . ")");
        return;
    }
    if ($type == Perla::AST::N_STR_LIT()) {
        # Under `use utf8`, source string literals are char-oriented:
        # set SVf_UTF8 so length()/uc()/lc()/etc. count code points
        # rather than bytes. Without the pragma, perl treats source
        # as bytes (Latin-1 in 5.x); perla then emits the literal
        # byte-oriented.
        my int $__sl_utf8 = 0;
        if (defined($cg->{"use_utf8"}) && $cg->{"use_utf8"} == 1) { $__sl_utf8 = 1; }
        if (defined($node->{"is_utf8"}) && $node->{"is_utf8"} == 1) { $__sl_utf8 = 1; }
        if ($__sl_utf8 == 1) {
            my str $__sl_val = $node->{"value"};
            my str $__sl_esc = Perla::CodeGen::Escape::escape_c_str($__sl_val);
            emit($cg, "strada_new_str_len_utf8(\"" . $__sl_esc . "\", " . length($__sl_val) . ")");
        } else {
            emit($cg, "strada_new_str(\"" . Perla::CodeGen::Escape::escape_c_str($node->{"value"}) . "\")");
        }
        return;
    }
    if ($type == Perla::AST::N_INTERP_STR()) {
        Perla::CodeGen::Interp::gen_interp_str($cg, $node->{"value"});
        return;
    }
    if ($type == Perla::AST::N_UNDEF()) {
        emit($cg, "strada_new_undef()");
        return;
    }
    # do { BLOCK } as expression — returns value of last statement
    if ($type == Perla::AST::N_BLOCK()) {
        my scalar $stmts = $node->{"stmts"};
        if (!defined($stmts) || scalar(@{$stmts}) == 0) {
            emit($cg, "strada_new_undef()");
            return;
        }
        # Lexical pragma save (use utf8 / use bytes / use integer) —
        # do-block-as-expression scopes the pragma to its body. Without
        # save/restore here, `do { use bytes; ... }` leaked use_bytes
        # into subsequent code.
        my int $db_save_use_integer = 0;
        if (defined($cg->{"use_integer"})) { $db_save_use_integer = $cg->{"use_integer"}; }
        my int $db_save_use_utf8 = 0;
        if (defined($cg->{"use_utf8"})) { $db_save_use_utf8 = $cg->{"use_utf8"}; }
        my int $db_save_use_bytes = 0;
        if (defined($cg->{"use_bytes"})) { $db_save_use_bytes = $cg->{"use_bytes"}; }
        # Snapshot active `local` saves so `local $X = ...` inside the
        # do block restores at block exit. Without this, `do { local $/;
        # … }` left $/ undef after the block (perla_irs stayed NULL),
        # breaking subsequent line reads.
        my scalar $bb_saved_locals = {};
        if (defined($cg->{"local_vars"})) {
            my array @bb_keys_b = keys($cg->{"local_vars"});
            my int $bb_ki = 0;
            while ($bb_ki < scalar(@bb_keys_b)) {
                my str $bb_v = "" . $cg->{"local_vars"}->{$bb_keys_b[$bb_ki]};
                if ($bb_v ne "__restored__") {
                    $bb_saved_locals->{$bb_keys_b[$bb_ki]} = 1;
                }
                $bb_ki++;
            }
        }
        my int $total = scalar(@{$stmts});
        # Skip trailing synthetic N_PACKAGE restore stmts when picking the
        # block's value-producing last statement. The parser appends a
        # restore stmt to any block that did `package X;` so the outer
        # package context is reinstated; codegen still needs to emit it
        # for runtime-side `caller()` correctness, but it must NOT be
        # treated as the do-block's value. Without this, `do { package
        # Foo; sub { 42 } }` returned undef because the synthetic restore
        # was the AST's last stmt — broke Eval::Closure's sandbox-wrapped
        # `eval q{ package Sandbox_N; sub { ... } };` (every validator
        # silently returned undef instead of a code ref).
        my int $n = $total;
        while ($n > 1 && defined($stmts->[$n - 1])
               && $stmts->[$n - 1]->{"type"} == Perla::AST::N_PACKAGE()
               && defined($stmts->[$n - 1]->{"synthetic"})
               && $stmts->[$n - 1]->{"synthetic"} == 1) {
            $n = $n - 1;
        }
        my scalar $last = $stmts->[$n - 1];
        my int $lt = defined($last) ? $last->{"type"} : 0;
        # If the last stmt is an if/unless, capture each branch's tail
        # expression so the do block returns the right list (matches Perl
        # semantics). Without this, `do { if (X) { LIST_A } else { LIST_B } }`
        # emitted the if as a void C statement and the surrounding
        # statement-expression returned an empty value. Surfaced via
        # SQL::Abstract's
        # `join(' ', do { if (...) { ($table, $as) } elsif (...) { $$x } ... })`
        # — the do block produced empty SQL fragments so the FROM clause
        # came out as `FROM   JOIN  ON 0`.
        if ($lt == Perla::AST::N_IF() || $lt == Perla::AST::N_UNLESS()) {
            emit($cg, "({ StradaValue *__bv = NULL; ");
            my int $bi = 0;
            while ($bi < $n - 1) {
                gen_stmt($cg, $stmts->[$bi]);
                $bi++;
            }
            gen_if_capture_return($cg, $last, "__bv");
            emit($cg, "__bv ? __bv : strada_new_undef(); })");
            return;
        }
        emit($cg, "({ ");
        # Snapshot the local-chain head at block entry. `local $X = ...`
        # inside the block pushes scalar saves on the chain; restoring at
        # block exit unwinds them. Same idea as the eval-block mark, but
        # for plain do { ... } / bare blocks.
        emit($cg, "void *__db_local_mark = __perla_local_chain; ");
