                    emit($cg, "if (__og->slots[PERLA_SLOT_HASH]) strada_decref(__og->slots[PERLA_SLOT_HASH]); ");
                    emit($cg, "__og->slots[PERLA_SLOT_HASH] = " . c_var_h($h_mirror_name) . "; if (" . c_var_h($h_mirror_name) . ") strada_incref(" . c_var_h($h_mirror_name) . "); }");
