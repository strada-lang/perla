            }
        }
        if (defined($akey) && $akey->{"type"} == Perla::AST::N_STR_LIT()) {
            emit($cg, "({ StradaValue *__o = ");
            if ($route_to_stash_h == 1) { emit($cg, "perla_hash_get(\"" . $__sh_pkg . "\", \"" . $__sh_name . "\")"); }
            else if ($route_to_hash == 1) { emit($cg, c_var_h($aobj2->{"name"})); }
            elsif ($__hsr_is_symref == 1) {
                emit($cg, "({ StradaValue *__sym = ");
                gen_expr($cg, $aobj2->{"ref"});
                emit($cg, "; (__sym && !STRADA_IS_TAGGED_INT(__sym) && __sym->type == STRADA_STR && __sym->value.pv) ? perla_hash_via_qname(__sym->value.pv) : ((__sym && !STRADA_IS_TAGGED_INT(__sym) && __sym->type == STRADA_REF) ? __sym->value.rv : __sym); })");
            }
            elsif (defined($aobj2) && ($aobj2->{"type"} == Perla::AST::N_HASH_ELEM() || $aobj2->{"type"} == Perla::AST::N_ARROW_HASH())) {
