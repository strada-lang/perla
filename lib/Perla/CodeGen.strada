        # outer static pointing into freed memory. We use a chain of
        # comma operators inside the statement expression so the saves
        # are visible to the restores.
        my array @__db_shadowed = ();
        my int $__db_si = 0;
        while ($__db_si < $n) {
            my scalar $__db_ss = $stmts->[$__db_si];
            if (defined($__db_ss) && $__db_ss->{"type"} == Perla::AST::N_MY()) {
                if (defined($__db_ss->{"var"})) {
                    my str $__db_vn = $__db_ss->{"var"}->{"value"};
                    if (_is_file_scope($cg, $__db_vn) == 1) {
                        my str $__db_vt = "" . $__db_ss->{"var"}->{"type"};
                        if (length($__db_vt) == 0) { $__db_vt = "SCALAR_VAR"; }
                        push(@__db_shadowed, c_var_for_vtype($__db_vt, $__db_vn));
                    }
                }
                if (defined($__db_ss->{"vars"})) {
                    my int $__db_dvi = 0;
                    while ($__db_dvi < scalar(@{$__db_ss->{"vars"}})) {
                        my scalar $__db_dv = $__db_ss->{"vars"}->[$__db_dvi];
                        my str $__db_dvn = $__db_dv->{"value"};
                        if (_is_file_scope($cg, $__db_dvn) == 1) {
                            my str $__db_dvt = "" . $__db_dv->{"type"};
                            if (length($__db_dvt) == 0) { $__db_dvt = "SCALAR_VAR"; }
                            push(@__db_shadowed, c_var_for_vtype($__db_dvt, $__db_dvn));
