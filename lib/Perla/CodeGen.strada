        # regexes (STRADA_REGEX) as-is so `ref($@)` returns
        # CODE / Regexp instead of being stringified into a message.
        emit($cg, "} else if (__dv && (STRADA_IS_TAGGED_INT(__dv) || ");
        emit($cg, "          (!STRADA_IS_TAGGED_INT(__dv) && __dv->type != STRADA_REF && __dv->type != STRADA_UNDEF && __dv->type != STRADA_CLOSURE && __dv->type != STRADA_CPOINTER && __dv->type != STRADA_REGEX))) { ");
        emit($cg, "  char *__dvs = strada_to_str(__dv); ");
        emit($cg, "  const char *__df = (perla_call_depth > 0) ? (perla_call_stack[perla_call_depth - 1].file ?: \"-\") : \"-\"; ");
        emit($cg, "  char __dbuf[1024]; snprintf(__dbuf, sizeof(__dbuf), \"%s at %s line " . $die_line . ".\\n\", __dvs ? __dvs : \"\", __df); ");
        emit($cg, "  free(__dvs); ");
        emit($cg, "  if (!STRADA_IS_TAGGED_INT(__dv)) strada_decref(__dv); ");
