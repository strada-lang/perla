        my str $__ev_pkg_expr = "main";
        if (defined($cg->{"pkg"})) { $__ev_pkg_expr = "" . $cg->{"pkg"}; }
        emit($cg, "perla_pending_call_line = " . $__ev_pln_expr . "; ");
        emit($cg, "perla_call_push(\"" . $__ev_pkg_expr . "\", \"(eval)\", \"" . $cg->{"filename"} . "\", 0); ");
        emit($cg, "if (perla_eval_error) strada_decref(perla_eval_error); ");
        emit($cg, "perla_eval_error = strada_new_str(\"\"); ");
        emit($cg, "jmp_buf *__ev_jb = STRADA_TRY_PUSH(); ");
        emit($cg, "if (__ev_jb && setjmp(*__ev_jb) == 0) { do { ");
        # Track depth so a `return` inside the body emits a `break`
        # that exits the do-while(0) instead of returning from the
        # enclosing sub. Stacks naturally via integer increment.
        my int $__save_eb = 0;
        if (defined($cg->{"eval_block_expr_active"})) { $__save_eb = $cg->{"eval_block_expr_active"}; }
        $cg->{"eval_block_expr_active"} = $__save_eb + 1;
        # Emit block's stmts; track the last and capture its value.
        my scalar $ev_body = $node->{"body"};
        my scalar $ev_stmts = defined($ev_body) ? $ev_body->{"stmts"} : undef;
        if (defined($ev_stmts)) {
            my int $ev_n = scalar(@{$ev_stmts});
            my int $ev_i = 0;
            while ($ev_i < $ev_n - 1) {
                # Regular statement — emit normally.
                my scalar $ev_s = $ev_stmts->[$ev_i];
                if (defined($ev_s)) {
                    gen_stmt($cg, $ev_s);
                }
                $ev_i++;
            }
            # Capture the last stmt's value if it's an expression-bearing form.
            if ($ev_n > 0) {
                my scalar $ev_last = $ev_stmts->[$ev_n - 1];
                my int $ev_last_t = defined($ev_last) ? $ev_last->{"type"} : 0;
