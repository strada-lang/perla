    }

    # unshift — returns new array length (Perl semantics)
    if ($name eq "unshift") {
        # Tied-array fast path: mirror push for unshift.
        if ($argc >= 2 && defined($args->[0])
            && $args->[0]->{"type"} == Perla::AST::N_ARRAY_VAR()
            && defined($args->[0]->{"name"})
            && index($args->[0]->{"name"}, "::") < 0
            && $args->[0]->{"name"} ne "_") {
            my str $__tu_name = $args->[0]->{"name"};
            my str $__tu_cvar = c_var_a($__tu_name);
            emit($cg, "({ StradaValue *__tu_sv = " . $__tu_cvar . "; ");
            emit($cg, "StradaValue *__tu_args = strada_new_array(); StradaArray *__tu_av = strada_deref_array(__tu_args); ");
            my int $__tui = 1;
            while ($__tui < $argc) {
                my scalar $__tu_arg = $args->[$__tui];
                my int $__tu_at = $__tu_arg->{"type"};
                # `unshift @arr, (L1, L2, ...)` — parens become non-ref
                # N_ANON_ARRAY; flatten in place (mirrors push's fix).
                if ($__tu_at == Perla::AST::N_ANON_ARRAY()
                    && (!defined($__tu_arg->{"is_ref"}) || $__tu_arg->{"is_ref"} == 0)
                    && defined($__tu_arg->{"elems"})) {
                    my scalar $__tu_elems = $__tu_arg->{"elems"};
                    my int $__tu_ne = scalar(@{$__tu_elems});
                    my int $__tu_ei = 0;
                    while ($__tu_ei < $__tu_ne) {
                        my scalar $__tu_el = $__tu_elems->[$__tu_ei];
                        my int $__tu_el_t = $__tu_el->{"type"};
                        my int $__tu_el_is_call = ($__tu_el_t == Perla::AST::N_CALL()
                                                  || $__tu_el_t == Perla::AST::N_METHOD()) ? 1 : 0;
                        if ($__tu_el_t == Perla::AST::N_ARRAY_VAR()
                            || $__tu_el_t == Perla::AST::N_DEREF_ARRAY()
                            || $__tu_el_t == Perla::AST::N_RANGE()
                            || $__tu_el_is_call == 1) {
                            my int $__tu_el_owned = ($__tu_el_t == Perla::AST::N_RANGE()
                                                    || $__tu_el_is_call == 1) ? 1 : 0;
                            if ($__tu_el_is_call == 1) {
                                emit($cg, "{ int __tu_sav_wl = __perla_want_list; __perla_want_list = 1; StradaValue *__tu_v = ");
                                gen_expr($cg, $__tu_el);
                                emit($cg, "; __perla_want_list = __tu_sav_wl; ");
                            } else {
                                emit($cg, "{ StradaValue *__tu_v = ");
                                gen_expr($cg, $__tu_el);
