# Perla CodeGen - Generates C code from the Perl 5 AST
#
# Output links against strada_runtime.c + perla_stash.c
# All package variables go through the stash; lexicals use C locals.

use Perla::AST;
use Perla::Lexer;
use Perla::Parser;
use Perla::CodeGen::Escape;
use Perla::CodeGen::FreeVars;
use Perla::CodeGen::Collect;
use Perla::CodeGen::Predicate;
use Perla::CodeGen::Eval;
use Perla::CodeGen::Subst;
use Perla::CodeGen::Interp;
use Perla::CodeGen::Subs;
use Perla::CodeGen::Call;
use Perla::CodeGen::Assign;
use Perla::CodeGen::Operator;
use Perla::CodeGen::Method;
use Perla::CodeGen::Stmt;

package Perla::CodeGen;

func generate(scalar $ast) str {
    my scalar $sb = sb_new(65536);
    # PERLA_PHASE_TIME=1: split codegen into the AST-walk/emit phase and the
    # post-pass (whole-$code scan/splice) phase. Inline CLOCK_MONOTONIC reads
    # (distinct timespec names per block — same C function scope).
    my int $__pt = (core::getenv("PERLA_PHASE_TIME") eq "1") ? 1 : 0;
    my num $__g0 = 0.0;
    __C__ { struct timespec __ta; clock_gettime(CLOCK_MONOTONIC, &__ta); strada_decref(__g0); __g0 = strada_new_num((double)__ta.tv_sec + (double)__ta.tv_nsec/1e9); }
    my hash %cg = ();
    $cg{"sb"} = $sb;
    $cg{"indent"} = 0;
    $cg{"pkg"} = "main";
    $cg{"filename"} = defined($ast->{"filename"}) ? $ast->{"filename"} : "(eval)";
    $cg{"lib_paths"} = defined($ast->{"lib_paths"}) ? $ast->{"lib_paths"} : [];
    $cg{"subs"} = {};          # name -> 1 (for forward decls)
    $cg{"anon_subs"} = [];     # collected anonymous sub nodes
    $cg{"our_vars"} = {};      # name -> 1 (our variables)
    # REPL/eval "pad" mode (experimental, default OFF). When PERLA_REPL_PAD=1,
    # top-level package/our scalars are aliased to the process-shared stash
    # registry (perla_scalar_lvalue) so their values persist across dlopen'd
    # REPL-line / eval-body .so's. OFF => byte-identical normal codegen.
    $cg{"pad_mode"} = (core::getenv("PERLA_REPL_PAD") eq "1") ? 1 : 0;
    $cg{"lexical_depth"} = 0;
    $cg{"tmp_count"} = 0;
    $cg{"label_count"} = 0;
    $cg{"label_map"} = {};      # user label -> unique C label
    $cg{"capture_vars"} = {};   # captured variable names in current closure
    $cg{"declared_vars"} = {};  # track declared C variables for loop cleanup
    $cg{"same_scope_decls"} = {};  # `my` vars declared in current scope only
                                # — used to detect "my X masks earlier
                                # declaration in same scope" warning. Reset
                                # (not copied) at every scope boundary.
    $cg{"my_lexicals"} = [];    # ordered list of in-scope `my` scalars
                                # for eval STRING lexical capture. Each entry
                                # is { name => perl_name, c_name => v_NAME,
                                # sigil => '$'|'@'|'%' }. Sub-scope save/restore
                                # mirrors declared_vars.
    $cg{"main_vars"} = [];      # track top-level variables for exit cleanup
    $cg{"file_scope_vars"} = {};  # my vars at file scope (hoisted to static)
    $cg{"moose_pkgs"} = {};     # packages using Moose (skip direct dispatch)

    # Collect all sub declarations and our variables
    Perla::CodeGen::Collect::collect_subs(\%cg, $ast);
    Perla::CodeGen::Collect::register_builtin_protos(\%cg);
    Perla::CodeGen::Collect::collect_our_vars(\%cg, $ast);
    Perla::CodeGen::Collect::collect_file_scope_vars(\%cg, $ast);
    _perla_reset_mangle_collisions();
    _collect_sigil_collisions(\%cg, $ast);
    _perla_snapshot_file_collisions();

    # Header
    emit(\%cg, "/* Generated by Perla - Perl 5 compiler */\n");
    emit(\%cg, "#include \"strada_runtime.h\"\n");
    emit(\%cg, "#include \"perla_stash.h\"\n");
    emit(\%cg, "#include \"perla_dbi.h\"\n");
    emit(\%cg, "#include <string.h>\n");
    emit(\%cg, "#include <stdio.h>\n");
    emit(\%cg, "#include <errno.h>\n");
    emit(\%cg, "#include <math.h>\n");
    emit(\%cg, "#include <stdlib.h>\n");
    emit(\%cg, "#include <stddef.h>\n");
    emit(\%cg, "#include <sys/wait.h>\n");
    emit(\%cg, "#include <sys/stat.h>\n");
    emit(\%cg, "#include <unistd.h>\n");
    emit(\%cg, "#include <time.h>\n");
    emit(\%cg, "#include <dirent.h>\n");
    emit(\%cg, "#include <sys/file.h>\n");
    emit(\%cg, "#include <sys/times.h>\n");
    emit(\%cg, "#include <fcntl.h>\n");
    emit(\%cg, "#include <utime.h>\n");
    emit(\%cg, "#include <signal.h>\n\n");
    emit(\%cg, "/* Strada runtime globals */\n");
    emit(\%cg, "extern StradaValue *v_STDIN;\n");
    emit(\%cg, "extern StradaValue *v_STDOUT;\n");
    emit(\%cg, "extern StradaValue *v_STDERR;\n\n");
    emit(\%cg, "/* Perl special variables (global for precompiled module linking) */\n");
    emit(\%cg, "StradaValue *perla_eval_error = NULL;\n");
    emit(\%cg, "StradaValue *perla_dollar_underscore = NULL;\n");
    emit(\%cg, "extern StradaValue *perla_increment(StradaValue *sv);\n");
    emit(\%cg, "extern StradaValue *perla_decrement(StradaValue *sv);\n");
    emit(\%cg, "extern StradaValue *perla_range_array(StradaValue *from, StradaValue *to);\n");
    emit(\%cg, "extern StradaValue *perla_readline_fh(StradaValue *fh);\n");
    emit(\%cg, "extern StradaValue *perla_read_all_lines_fh(StradaValue *fh);\n");
    emit(\%cg, "extern StradaValue *perla_readline_argv(StradaValue *argv);\n");
    emit(\%cg, "extern StradaValue *perla_reverse_ctx(StradaValue *sv);\n");
    emit(\%cg, "extern StradaValue *perla_overload_binary(StradaValue *left, StradaValue *right, const char *op);\n");
    emit(\%cg, "extern StradaValue *perla_overload_deref(StradaValue *sv, const char *slot_suffix);\n");
    emit(\%cg, "extern PerlGlob *perla_autoload_resolve(const char *pkg);\n");
    emit(\%cg, "extern void perla_set_autoload_var(const char *fullname);\n");
    emit(\%cg, "extern StradaValue *perla_getpwuid_list(StradaValue *uid);\n");
    emit(\%cg, "extern StradaValue *perla_getpwuid_name(StradaValue *uid);\n");
    emit(\%cg, "extern StradaValue *perla_getpwnam_list(StradaValue *name);\n");
    emit(\%cg, "extern StradaValue *perla_getpwnam_name(StradaValue *name);\n");
    emit(\%cg, "StradaValue *perla_irs = NULL;  /* $/ input record separator */\n");
    emit(\%cg, "StradaValue *perla_ors = NULL;  /* $\\ output record separator */\n");
    emit(\%cg, "StradaValue *perla_ofs = NULL;  /* $, output field separator */\n");
    emit(\%cg, "StradaValue *perla_lse = NULL;  /* $\" list-separator for array interp */\n");
    emit(\%cg, "StradaValue *perla_subsep = NULL;  /* $; subscript separator */\n");
    # Format-related specials are defined in perla_stash.c (so the
    # runtime's perla_write_format can read them); main only declares.
    emit(\%cg, "extern StradaValue *perla_dollar_tilde;   /* $~ format name */\n");
    emit(\%cg, "extern StradaValue *perla_dollar_caret;   /* $^ top-of-page name */\n");
    emit(\%cg, "extern StradaValue *perla_dollar_equals;  /* $= page length */\n");
    emit(\%cg, "extern StradaValue *perla_dollar_minus;   /* $- lines-left */\n");
    emit(\%cg, "extern StradaValue *perla_dollar_percent; /* $% page number */\n");
    emit(\%cg, "extern StradaValue *perla_dollar_caret_L; /* $^L form-feed */\n");
    emit(\%cg, "extern StradaValue *perla_dollar_caret_A; /* $^A formline accumulator */\n");
    emit(\%cg, "extern int perla_formline(const char *picture, StradaValue **values, size_t nvalues);\n");
    emit(\%cg, "extern int perla_warnings_active;  /* set by `use warnings;` */\n");
    emit(\%cg, "extern void perla_warn_non_numeric(StradaValue *sv, const char *op_long, const char *file, int line);\n");
    emit(\%cg, "extern void perla_warn_my_masks(const char *varname, const char *file, int line);\n");
    emit(\%cg, "extern void perla_warn_untie_with_refs(int nrefs, const char *file, int line);\n");
    emit(\%cg, "extern long perla_code_override_gen;\n");
    emit(\%cg, "extern void perla_register_format(const char *name, const char *body);\n");
    emit(\%cg, "extern void perla_write_format(const char *name);\n");
    emit(\%cg, "extern void perla_write_format_to_fh(StradaValue *fh_sv);\n");
    emit(\%cg, "extern void perla_register_format_sync(const char *name, void (*fn)(void));\n");
    emit(\%cg, "extern StradaValue *perla_tie_handle(const char *pkg, const char *name, const char *classname, StradaValue *args);\n");
    emit(\%cg, "extern StradaValue *perla_tied_handle_for_name(const char *pkg, const char *name);\n");
    emit(\%cg, "extern StradaValue *perla_tied_handle_get(const char *pkg, const char *name);\n");
    emit(\%cg, "extern StradaValue *perla_tied_handle_readline(const char *pkg, const char *name);\n");
    emit(\%cg, "extern StradaValue *perla_tied_handle_print(const char *pkg, const char *name, StradaValue *args);\n");
    emit(\%cg, "extern StradaValue *perla_tied_handle_printf(const char *pkg, const char *name, StradaValue *args);\n");
    emit(\%cg, "extern StradaValue *perla_tied_handle_close(const char *pkg, const char *name);\n");
    emit(\%cg, "extern void perla_set_selected_handle(const char *name);\n");
    emit(\%cg, "extern void perla_format_set_selected_fmt_name(const char *fmt_name);\n");
    emit(\%cg, "extern void perla_format_set_selected_top_name(const char *top_name);\n");
    emit(\%cg, "int __perla_autoflush = 0;      /* $| */\n");
    emit(\%cg, "int __perla_want_list = 0;\n");
    # Global fallback for wantarray at top-level scope or anywhere
    # outside a sub. Subs shadow this with a local declaration. -1 is
    # the void-context sentinel, so top-level `wantarray` returns
    # undef (matching Perl), not "" (scalar).
    emit(\%cg, "int __perla_caller_want_list = -1;\n");
    emit(\%cg, "StradaValue *v_ARGV = NULL;    /* @ARGV */\n");
    emit(\%cg, "StradaValue *v_ENV = NULL;     /* %ENV */\n");
    emit(\%cg, "StradaValue *v_ISA = NULL;     /* @ISA */\n");
    emit(\%cg, "StradaValue *v__ = NULL;      /* $_ */\n");
    emit(\%cg, "StradaValue *v_SIG = NULL;    /* %SIG */\n");
    emit(\%cg, "StradaValue *v_a = NULL;      /* $a (sort) */\n");
    emit(\%cg, "StradaValue *v_b = NULL;      /* $b (sort) */\n");
    emit(\%cg, "StradaValue *v_INC = NULL;    /* @INC */\n");
    emit(\%cg, "StradaValue *v_INC__h = NULL; /* %INC (loaded modules) */\n");
    emit(\%cg, "StradaValue *__local_save_SIG = NULL;\n");
    emit(\%cg, "StradaValue *__local_save_Data = NULL;\n");
    emit(\%cg, "StradaValue *__local_save_Data_Dumper_Maxdepth = NULL;\n");
    emit(\%cg, "StradaValue *__local_save_ = NULL;\n");
    emit(\%cg, "StradaValue *__local_save__ = NULL;\n");
    emit(\%cg, "StradaValue *__local_save__caret_W = NULL;\n");
    emit(\%cg, "StradaValue *v__caret_W = NULL; /* $^W */\n");
    emit(\%cg, "StradaValue *perla_at_ = NULL; /* @_ fallback */\n");
    emit(\%cg, "StradaValue *v__caret_O = NULL; /* $^O */\n");
    emit(\%cg, "StradaValue *v__rbrack_ = NULL; /* $] */\n");
    emit(\%cg, "StradaValue *v__caret_V = NULL; /* $^V */\n");
    emit(\%cg, "StradaValue *v__caret_X = NULL; /* $^X */\n");
    emit(\%cg, "StradaValue *v__caret_GLOBAL_PHASE = NULL; /* perl GLOBAL_PHASE */\n");
    emit(\%cg, "StradaValue *v__slash_ = NULL; /* $/ - input record separator */\n");
    emit(\%cg, "StradaValue *perla_dollar_zero = NULL; /* $0 */\n");
    emit(\%cg, "extern StradaValue *perla_current_argv;\n");
    emit(\%cg, "int perla_dollar_question = 0; /* $? -- wait status of last system/qx */\n");
    emit(\%cg, "int perla_dollar_dot = 0; /* $. -- current input line number */\n");
    emit(\%cg, "StradaValue **__perla_sort_ctx[16] = {0}; /* sort block captures (write-through slots) */\n");
    emit(\%cg, "StradaValue **__perla_cell[64] = {0}; /* shared closure cells */\n");
    # Named-comparator sort thunk: sets v_a/v_b before calling the named
    # comparator sub (which reads $a/$b as globals). Used by
    # `sort SUBNAME LIST` form. Non-reentrant via the function-pointer
    # global, same as perla_sort_qsort_cmp's g_sort_cmp_fn.
    emit(\%cg, "static StradaValue *(*__perla_sort_named_target)(StradaValue*) = NULL;\n");
    emit(\%cg, "static StradaValue *__perla_sort_named_thunk(StradaValue *args) {\n");
    emit(\%cg, "    StradaValue *__sa = v_a; StradaValue *__sb = v_b;\n");
    emit(\%cg, "    StradaArray *__av = strada_deref_array(args);\n");
    emit(\%cg, "    v_a = (__av && __av->size > 0) ? __av->elements[__av->head + 0] : NULL;\n");
    emit(\%cg, "    v_b = (__av && __av->size > 1) ? __av->elements[__av->head + 1] : NULL;\n");
    # $a/$b are package globals in Perl: also publish to the main:: stash so
    # a comparator that reads them qualified ($main::a, $::a) or from another
    # package (sort Foo::cmp) sees the values, not just the C-local v_a/v_b.
    emit(\%cg, "    if (v_a) perla_scalar_set(\"main\", \"a\", v_a); if (v_b) perla_scalar_set(\"main\", \"b\", v_b);\n");
    emit(\%cg, "    StradaValue *__r = __perla_sort_named_target ? __perla_sort_named_target(args) : NULL;\n");
    emit(\%cg, "    v_a = __sa; v_b = __sb; return __r;\n");
    emit(\%cg, "}\n");
    # Coderef sort thunk: routes through perla_call_code with v_a/v_b set.
    emit(\%cg, "static StradaValue *__perla_sort_coderef_target = NULL;\n");
    emit(\%cg, "static StradaValue *__perla_sort_coderef_thunk(StradaValue *args) {\n");
    emit(\%cg, "    StradaValue *__sa = v_a; StradaValue *__sb = v_b;\n");
    emit(\%cg, "    StradaArray *__av = strada_deref_array(args);\n");
    emit(\%cg, "    v_a = (__av && __av->size > 0) ? __av->elements[__av->head + 0] : NULL;\n");
    emit(\%cg, "    v_b = (__av && __av->size > 1) ? __av->elements[__av->head + 1] : NULL;\n");
    emit(\%cg, "    if (v_a) perla_scalar_set(\"main\", \"a\", v_a); if (v_b) perla_scalar_set(\"main\", \"b\", v_b);\n");
    emit(\%cg, "    StradaValue *__r = __perla_sort_coderef_target ? perla_call_code(__perla_sort_coderef_target, args) : NULL;\n");
    emit(\%cg, "    v_a = __sa; v_b = __sb; return __r;\n");
    emit(\%cg, "}\n");
    # Emit our (global) variable declarations
    my scalar $our_vars = $cg{"our_vars"};
    my array @our_names = keys($our_vars);
    my int $oi = 0;
    my hash %default_vars = ();
    $default_vars{"ARGV"} = 1; $default_vars{"ENV"} = 1; $default_vars{"ISA"} = 1;
    $default_vars{"_"} = 1; $default_vars{"SIG"} = 1; $default_vars{"a"} = 1;
    $default_vars{"b"} = 1; $default_vars{"INC"} = 1;
    $default_vars{"STDOUT"} = 1; $default_vars{"STDIN"} = 1; $default_vars{"STDERR"} = 1;
    my hash %__our_emitted = ();
    while ($oi < scalar(@our_names)) {
        my str $on = $our_names[$oi];
        if (!exists($default_vars{$on})) {
            my str $ot = "" . $our_vars->{$on};
            my str $cname = c_var_for_vtype($ot, $on);
            if (!defined($__our_emitted{$cname})) {
                if ($cg{"pad_mode"} == 1 && $ot eq "SCALAR_VAR") {
                    # Pad mode: alias the scalar to its shared stash slot so its
                    # value persists across REPL-line / eval-body .so loads. The
                    # macro makes every existing read/write of $cname hit the
                    # registry (perla_scalar_lvalue), no per-site changes needed.
                    my str $__pad_pkg = "" . $cg{"pkg"};
                    emit(\%cg, "#define " . $cname . " (*perla_scalar_lvalue(\"" . $__pad_pkg . "\", \"" . $on . "\"))\n");
                } else {
                    emit(\%cg, "static StradaValue *" . $cname . " = NULL;\n");
                }
                $__our_emitted{$cname} = 1;
            }
            # When a name has multiple sigils (`our $x` + `our @x` + `our %x`
            # together), our_vars stores only the last-seen type. Without
            # this fan-out, only one of v_x / v_x__a / v_x__h would be
            # declared, leaving sibling-sigil writes referencing an
            # undeclared identifier. Mirrors the file-scope my-vars fix
            # at line ~193.
            if (exists($__perla_mangle_collisions{$on})) {
                my str $sn = c_var_for_vtype("SCALAR_VAR", $on);
                my str $an = c_var_for_vtype("ARRAY_VAR", $on);
                my str $hn = c_var_for_vtype("HASH_VAR", $on);
                if (!defined($__our_emitted{$sn})) {
                    emit(\%cg, "static StradaValue *" . $sn . " = NULL;\n");
                    $__our_emitted{$sn} = 1;
                }
                if (!defined($__our_emitted{$an})) {
                    emit(\%cg, "static StradaValue *" . $an . " = NULL;\n");
                    $__our_emitted{$an} = 1;
                }
                if (!defined($__our_emitted{$hn})) {
                    emit(\%cg, "static StradaValue *" . $hn . " = NULL;\n");
                    $__our_emitted{$hn} = 1;
                }
            }
        }
        $oi++;
    }
    # Emit file-scope my variables as static (accessible from subs).
    # When a name has multiple sigils (`my $s`+`my @s` at file scope),
    # emit a declaration for EACH sigil so `v_s` (for $s), `v_s__a`
    # (for @s), `v_s__h` (for %s) all exist. Previously only the last
    # `my` win recorded; the others compiled to undeclared identifiers.
    my scalar $fs_vars = $cg{"file_scope_vars"};
    my array @fs_names = keys($fs_vars);
    my int $fi = 0;
    my hash %__fs_emitted = ();
    while ($fi < scalar(@fs_names)) {
        my str $fsn = $fs_names[$fi];
        # Don't re-declare if already an our var or a default variable
        # $/ is owned by main and declared as extern in module mode —
        # skip the static emit here so we don't collide with the extern decl.
        if (!exists($our_vars->{$fsn}) && $fsn ne "a" && $fsn ne "b" && $fsn ne "_" && $fsn ne "ISA" && $fsn ne "SIG" && $fsn ne "ARGV" && $fsn ne "ENV" && $fsn ne "INC" && $fsn ne "STDOUT" && $fsn ne "STDIN" && $fsn ne "STDERR" && $fsn ne "/") {
            my str $fst = "" . $fs_vars->{$fsn};
            my str $cname = c_var_for_vtype($fst, $fsn);
            if (!defined($__fs_emitted{$cname})) {
                emit(\%cg, "static StradaValue *" . $cname . " = NULL;\n");
                $__fs_emitted{$cname} = 1;
            }
            # If the name has multiple sigils at file scope, declare the
            # OTHER sigils too. file_scope_vars stores only one type per
            # name (the last `my` wins), so without this, `my $s` after
            # `my @s` only emitted v_s__a and v_s remained undeclared.
            if (exists($__perla_mangle_collisions{$fsn})) {
                my str $sn = c_var_for_vtype("SCALAR_VAR", $fsn);
                my str $an = c_var_for_vtype("ARRAY_VAR", $fsn);
                my str $hn = c_var_for_vtype("HASH_VAR", $fsn);
                if (!defined($__fs_emitted{$sn})) {
                    emit(\%cg, "static StradaValue *" . $sn . " = NULL;\n");
                    $__fs_emitted{$sn} = 1;
                }
                if (!defined($__fs_emitted{$an})) {
                    emit(\%cg, "static StradaValue *" . $an . " = NULL;\n");
                    $__fs_emitted{$an} = 1;
                }
                if (!defined($__fs_emitted{$hn})) {
                    emit(\%cg, "static StradaValue *" . $hn . " = NULL;\n");
                    $__fs_emitted{$hn} = 1;
                }
            }
        }
        $fi++;
    }
    emit(\%cg, "\n");

    # Emit file-scope __C__ blocks (includes, statics, typedefs)
    my scalar $stmts_pre = $ast->{"stmts"};
    my int $ci = 0;
    while ($ci < scalar(@{$stmts_pre})) {
        my scalar $cs = $stmts_pre->[$ci];
        if (defined($cs) && $cs->{"type"} == Perla::AST::N_C_BLOCK()) {
            my str $code = $cs->{"code"};
            if (index($code, "#include") >= 0 || index($code, "static ") >= 0 ||
                index($code, "typedef") >= 0 || index($code, "extern ") >= 0) {
                emit(\%cg, "/* __C__ (file scope) */\n");
                emit(\%cg, $code);
                emit(\%cg, "\n\n");
                # Mark as emitted so it's not re-emitted inside main()
                $cs->{"_emitted"} = 1;
            }
        }
        $ci++;
    }

    # Forward declarations for subs
    my scalar $subs = $cg{"subs"};
    my array @sub_names = keys($subs);
    my int $si = 0;
    while ($si < scalar(@sub_names)) {
        my str $qname = $sub_names[$si];
        my str $fname = sub_cname_q($qname);
        emit(\%cg, "StradaValue* " . $fname . "(StradaValue *perla_args);\n");
        # Forward declare direct-arg version if sub has known params
        my scalar $pinfo = $cg{"sub_params"}->{$qname};
        if (defined($pinfo)) {
            my int $arity = $pinfo->{"arity"};
            emit(\%cg, "StradaValue* " . $fname . "__direct(");
            my int $pi = 0;
            while ($pi < $arity) {
                if ($pi > 0) { emit(\%cg, ", "); }
                emit(\%cg, "StradaValue*");
                $pi++;
            }
            # Trailing perla_args_full param.
            if ($arity > 0) { emit(\%cg, ", "); }
            emit(\%cg, "StradaValue*");
            emit(\%cg, ");\n");
        }
        $si++;
    }
    if (scalar(@sub_names) > 0) { emit(\%cg, "\n"); }

    # Main function
    emit(\%cg, "int main(int argc, char **argv) {\n");
    $cg{"indent"} = 1;
    $cg{"in_main"} = 1;
    # Per-main closure-cell table — shadows the file-scope global (declared
    # at line 118) so top-level closures in main don't collide with closures
    # created by code we call (or vice-versa). See gen_sub_def for the
    # detailed rationale.
    ind(\%cg); emit(\%cg, "StradaValue **__perla_cell[64] __attribute__((unused)) = {0};\n");
    ind(\%cg); emit(\%cg, "perla_init();\n");
    ind(\%cg); emit(\%cg, "perla_dbi_init();\n");
    ind(\%cg); emit(\%cg, "strada_init_proctitle(argc, argv);\n");
    # Seed runtime `require` search paths from the compile-time
    # lib_paths (which already combined perla.conf, PERL5LIB, -I
    # flags, etc). Also include inc_roots (from `perl -V @INC` under
    # PERLA_PERL) so binaries inherit whatever Perl install they were
    # compiled against. Baking these in means the compiled binary
    # doesn't depend on /etc/perla.conf being present at runtime. If
    # PERLA_LIB is set at runtime it overrides.
    {
        my str $baked = "";
        my scalar $cg_lib_paths = $cg{"lib_paths"};
        if (defined($cg_lib_paths)) {
            my int $lpi = 0;
            while ($lpi < scalar(@{$cg_lib_paths})) {
                my str $lp = $cg_lib_paths->[$lpi];
                if (length($lp) > 0) {
                    if (length($baked) > 0) { $baked = $baked . ":"; }
                    $baked = $baked . Perla::CodeGen::Escape::escape_c_str($lp);
                }
                $lpi++;
            }
        }
        my scalar $cg_inc_roots = $ast->{"inc_roots"};
        if (defined($cg_inc_roots)) {
            my int $iri = 0;
            while ($iri < scalar(@{$cg_inc_roots})) {
                my str $ir = $cg_inc_roots->[$iri];
                if (length($ir) > 0) {
                    if (length($baked) > 0) { $baked = $baked . ":"; }
                    $baked = $baked . Perla::CodeGen::Escape::escape_c_str($ir);
                }
                $iri++;
            }
        }
        ind(\%cg); emit(\%cg, "{ const char *__rpl = getenv(\"PERLA_LIB\"); extern void perla_require_set_paths(const char *); if (__rpl && __rpl[0]) perla_require_set_paths(__rpl); else perla_require_set_paths(\"" . $baked . "\"); }\n");
    }
    # Set perla path for eval STRING runtime — try PERLA_PATH, then derive from STRADA_DIR.
    # If derivation from /proc/self/exe fails (binary in shallow path), fall
    # back to searching PATH for 'perla' so eval STRING keeps working.
    # Additionally, bake in the compile-time path to perla itself as a final fallback —
    # this guarantees eval STRING works from any directory without requiring env vars
    # or PATH setup.
    my str $baked_perla_path = "";
    my str $baked_strada_dir = "";
    # Bake in the path to the perla binary for runtime eval STRING / require
    # (which re-invoke perla). The authoritative source is /proc/self/exe — the
    # very perla compiling this program — which is correct whether perla is
    # installed, run from its build dir, or anywhere else. PERLA_PATH overrides;
    # a $STRADA_DIR/perla/perla guess is kept only as a legacy fallback for the
    # old "perla inside the strada tree" layout.
    my str $compile_perla = core::getenv("PERLA_PATH");
    if (length($compile_perla) == 0) {
        my str $cp_readlink = "";
        __C__ {
            char buf[2048];
            ssize_t len = readlink("/proc/self/exe", buf, sizeof(buf)-1);
            if (len > 0) {
                buf[len] = '\0';
                strada_decref(cp_readlink);
                cp_readlink = strada_new_str(buf);
            }
        }
        if (length($cp_readlink) > 0) { $compile_perla = $cp_readlink; }
    }
    # Legacy fallback: perla as a subdir of a Strada source tree.
    if (length($compile_perla) == 0) {
        my str $compile_sd = core::getenv("STRADA_DIR");
        if (length($compile_sd) > 0) { $compile_perla = $compile_sd . "/perla/perla"; }
    }
    # strada_dir hint passed to the child perla. The child self-detects Strada
    # (system install or its own STRADA_DIR), so this is only used when the user
    # explicitly set STRADA_DIR at compile time; otherwise leave it empty.
    $baked_strada_dir = core::getenv("STRADA_DIR");
    $baked_perla_path = Perla::CodeGen::Escape::escape_c_str($compile_perla);
    $baked_strada_dir = Perla::CodeGen::Escape::escape_c_str($baked_strada_dir);

    # Resolution order for eval STRING's perla binary + strada_dir hint:
    # 1. PERLA_PATH env var (explicit user override), if it exists.
    # 2. Compile-time baked path = the perla that built this program. Authoritative
    #    and cwd-independent; correct whether perla is installed or run in place.
    # 3. PATH walk for an installed 'perla'.
    # 4. Legacy $STRADA_DIR/perla/perla (old "perla inside the strada tree" layout).
    # 5. Literal "perla" (hope PATH picks it up at popen time).
    ind(\%cg); emit(\%cg, "{ const char *__pp = getenv(\"PERLA_PATH\"); const char *__sd = getenv(\"STRADA_DIR\");\n");
    ind(\%cg); emit(\%cg, "  char __ppbuf[1024] = \"\";\n");
    # Verify any user-supplied PERLA_PATH actually exists.
    ind(\%cg); emit(\%cg, "  if (__pp && __pp[0]) { FILE *__tp = fopen(__pp, \"r\"); if (!__tp) { __pp = NULL; } else { fclose(__tp); } }\n");
    # Baked-at-compile-time path (the perla that compiled us; works in any cwd).
    ind(\%cg); emit(\%cg, "  if (!__pp) { FILE *__bt = fopen(\"" . $baked_perla_path . "\", \"r\"); if (__bt) { fclose(__bt); __pp = \"" . $baked_perla_path . "\"; if (!__sd || !__sd[0]) __sd = \"" . $baked_strada_dir . "\"; } }\n");
    # PATH walk for an installed 'perla'.
    ind(\%cg); emit(\%cg, "  static char __path_found[1024] = \"\";\n");
    ind(\%cg); emit(\%cg, "  if (!__pp) { const char *__path = getenv(\"PATH\"); if (__path) { const char *__s = __path; while (*__s) { const char *__e = strchr(__s, ':'); size_t __ln = __e ? (size_t)(__e - __s) : strlen(__s); if (__ln > 0 && __ln < 900) { snprintf(__path_found, sizeof(__path_found), \"%.*s/perla\", (int)__ln, __s); FILE *__pt = fopen(__path_found, \"r\"); if (__pt) { fclose(__pt); __pp = __path_found; break; } } if (!__e) break; __s = __e + 1; } } }\n");
    # Legacy: perla as a subdir of $STRADA_DIR (old in-tree layout), guarded by existence.
    ind(\%cg); emit(\%cg, "  if (!__pp && __sd && __sd[0]) { snprintf(__ppbuf, sizeof(__ppbuf), \"%s/perla/perla\", __sd); FILE *__tp = fopen(__ppbuf, \"r\"); if (__tp) { fclose(__tp); __pp = __ppbuf; } }\n");
    ind(\%cg); emit(\%cg, "  perla_eval_set_paths(__pp ? __pp : \"perla\", __sd ? __sd : \".\"); }\n");
    ind(\%cg); emit(\%cg, "perla_irs = strada_new_str(\"\\n\");\n");
    # Mirror to v__slash_ so \`local \$/\` saves the actual current value
    # rather than NULL. Without this the save-and-restore correctly
    # cycled v__slash_ but perla_irs ended up NULL after restore, and
    # the next read mistook NULL for slurp-mode.
    ind(\%cg); emit(\%cg, "v__slash_ = perla_irs; if (v__slash_) strada_incref(v__slash_);\n");
    # \$\\ and \$, default to undef in Perl, not empty string. Initializing
    # to "" makes \`defined \$\\\` and \`(\$\\ // "x") eq "x"\` give wrong
    # answers. Existing print-time guards already treat NULL as no-op.
    ind(\%cg); emit(\%cg, "/* perla_ors / perla_ofs left NULL (undef) */\n");
    ind(\%cg); emit(\%cg, "perla_lse = strada_new_str(\" \");\n");
    ind(\%cg); emit(\%cg, "perla_subsep = strada_new_str(\"\\034\");\n");
    # @ARGV from command line args (skip argv[0] which is program name)
    ind(\%cg); emit(\%cg, "v_ARGV = strada_new_array();\n");
    ind(\%cg); emit(\%cg, "for (int __ai = 1; __ai < argc; __ai++) strada_array_push(strada_deref_array(v_ARGV), strada_new_str(argv[__ai]));\n");
    # %ENV from environment
    ind(\%cg); emit(\%cg, "v_ENV = strada_new_hash();\n");
    ind(\%cg); emit(\%cg, "{ extern char **environ; char **__ep = environ; while (__ep && *__ep) { char *__eq = strchr(*__ep, '='); if (__eq) { char *__k = strndup(*__ep, __eq - *__ep); strada_hv_store(v_ENV, __k, strada_new_str(__eq + 1)); free(__k); } __ep++; } }\n");
    # Clear errno so `$!` at script start reads empty (matches perl). Perla's
    # init may leave errno non-zero from a failed syscall during startup
    # (env walk, stat, etc.), making `if ($!) { ... }` truthy before any
    # user error happens.
    ind(\%cg); emit(\%cg, "errno = 0;\n\n");

    # Push main call frame for caller() support
    ind(\%cg); emit(\%cg, "perla_call_push(\"main\", \"(main)\", \"" . $cg{"filename"} . "\", 0);\n");

    # Per-call mark for `local $h->{k} = v` save records — captures the
    # current global chain head so we can unwind back to it on exit. The
    # chain itself (__perla_local_chain) is a runtime-owned global so
    # die-unwind through nested frames lands at the eval BLOCK with all
    # intermediate locals still recoverable.
    ind(\%cg); emit(\%cg, "void *__perla_local_chain_mark __attribute__((unused)) = __perla_local_chain;\n");

    # Initialize our/my hash/array variables (static vars start as NULL)
    $oi = 0;
    while ($oi < scalar(@our_names)) {
        my str $on = $our_names[$oi];
        if (!exists($default_vars{$on})) {
            my str $ot = "" . $our_vars->{$on};
            if ($ot eq "HASH_VAR") {
                ind(\%cg); emit(\%cg, "if (!" . c_var_h($on) . ") " . c_var_h($on) . " = strada_new_hash();\n");
            } elsif ($ot eq "ARRAY_VAR") {
                ind(\%cg); emit(\%cg, "if (!" . c_var_a($on) . ") " . c_var_a($on) . " = strada_new_array();\n");
            }
            # When `our $x`+`our @x`+`our %x` collide, our_vars only
            # records one type. Init the other container sigils too so
            # later assignments find a valid container.
            if (exists($__perla_mangle_collisions{$on})) {
                if ($ot ne "ARRAY_VAR") {
                    ind(\%cg); emit(\%cg, "if (!" . c_var_a($on) . ") " . c_var_a($on) . " = strada_new_array();\n");
                }
                if ($ot ne "HASH_VAR") {
                    ind(\%cg); emit(\%cg, "if (!" . c_var_h($on) . ") " . c_var_h($on) . " = strada_new_hash();\n");
                }
            }
        }
        $oi++;
    }
    # Also init file-scope my hash/array vars
    $fi = 0;
    while ($fi < scalar(@fs_names)) {
        my str $fsn = $fs_names[$fi];
        if (!exists($our_vars->{$fsn}) && !exists($default_vars{$fsn})) {
            my str $fst = "" . $fs_vars->{$fsn};
            if ($fst eq "HASH_VAR") {
                ind(\%cg); emit(\%cg, "if (!" . c_var_h($fsn) . ") " . c_var_h($fsn) . " = strada_new_hash();\n");
            } elsif ($fst eq "ARRAY_VAR") {
                ind(\%cg); emit(\%cg, "if (!" . c_var_a($fsn) . ") " . c_var_a($fsn) . " = strada_new_array();\n");
            }
        }
        $fi++;
    }

    # Initialize special variables
    ind(\%cg); emit(\%cg, "v_SIG = strada_new_hash();\n");
    # Pre-populate %SIG with all known signal names so `keys %SIG`
    # returns the same set as Perl. perla_populate_sig_hash walks the
    # libc signal-name table and stores each as undef (Perl uses
    # \"DEFAULT\" but undef matches Perl's display when print-ing).
    ind(\%cg); emit(\%cg, "{ extern void perla_populate_sig_hash(StradaValue *); perla_populate_sig_hash(v_SIG); }\n");
    ind(\%cg); emit(\%cg, "v_INC = strada_new_array();\n");
    # Populate v_INC from the runtime require paths so user code that
    # examines @INC (e.g. for module discovery) sees the same paths
    # that `use`/`require` actually search. The paths are set above by
    # `perla_require_set_paths(baked)`.
    ind(\%cg); emit(\%cg, "{ extern char **g_require_paths; extern size_t g_require_path_count; ");
    emit(\%cg, "if (g_require_paths) { StradaArray *__inca = strada_deref_array(v_INC); ");
    emit(\%cg, "for (size_t __ii = 0; __ii < g_require_path_count; __ii++) { ");
    emit(\%cg, "if (g_require_paths[__ii]) strada_array_push_take(__inca, strada_new_str(g_require_paths[__ii])); ");
    emit(\%cg, "} } }\n");
    # %INC (loaded-modules hash) — point v_INC__h at the runtime's
    # g_INC_hash so `exists \$INC{"Mod.pm"}` reflects perla_mark_loaded
    # / perla_require_module state.
    ind(\%cg); emit(\%cg, "{ extern StradaValue *g_INC_hash; if (!g_INC_hash) g_INC_hash = strada_new_hash(); v_INC__h = g_INC_hash; strada_incref(v_INC__h); }\n");
    ind(\%cg); emit(\%cg, "v_ISA = strada_new_array();\n");
    ind(\%cg); emit(\%cg, "if (!v_ARGV) v_ARGV = strada_new_array();\n");
    ind(\%cg); emit(\%cg, "v__caret_O = strada_new_str(\"linux\");\n");
    ind(\%cg); emit(\%cg, "v__rbrack_ = strada_new_str(\"5.042000\");\n");
    # $^V is Perl's v-string version. The lexer now tokenizes `N.N.N`
    # literals as a single STRING "N.N.N"; Config.pm's
    # `$^V eq 5.42.0` thus compares against the string "5.42.0".
    ind(\%cg); emit(\%cg, "v__caret_V = strada_new_str(\"5.42.0\");\n");
    # $^X is the perl binary path. Used by some boot paths; baking in a
    # reasonable default (the PERLA_PERL at compile time, else "perl").
    ind(\%cg); emit(\%cg, "{ const char *__px = getenv(\"PERLA_PERL\"); v__caret_X = strada_new_str(__px && __px[0] ? __px : \"perl\"); }\n");
    # perl GLOBAL_PHASE — phase indicator. perla doesn't track
    # phase transitions through BEGIN/CHECK/INIT, so we initialize to
    # "RUN" (the most common observed value) so that
    # `if (..GLOBAL_PHASE eq 'DESTRUCT')` guards (common in CPAN
    # modules like Variable::Magic, Devel::GlobalDestruction, DBIx::
    # Class) follow the normal path.
    ind(\%cg); emit(\%cg, "v__caret_GLOBAL_PHASE = strada_new_str(\"RUN\");\n");
    # $0 — program name. Perl sets this to the script path (e.g.
    # `/tmp/foo.pl`); the user can write to it to change the proc
    # title. perla compiles the .pl to a native binary, so argv[0]
    # is the compiled binary path (no .pl extension). Bake in the
    # source-file path so $0 matches Perl by default; if the user
    # invoked the binary directly (not via `perla script.pl`),
    # PERLA_DOLLAR_ZERO env var can override.
    my str $__src_file_lit = "";
    if (defined($cg{"filename"})) { $__src_file_lit = Perla::CodeGen::Escape::escape_c_str("" . $cg{"filename"}); }
    elsif (defined($cg{"src_file"})) { $__src_file_lit = Perla::CodeGen::Escape::escape_c_str("" . $cg{"src_file"}); }
    if (length($__src_file_lit) > 0) {
        ind(\%cg); emit(\%cg, "{ const char *__d0_env = getenv(\"PERLA_DOLLAR_ZERO\"); ");
        emit(\%cg, "perla_dollar_zero = strada_new_str(__d0_env ? __d0_env : \"" . $__src_file_lit . "\"); }\n");
    } else {
        ind(\%cg); emit(\%cg, "perla_dollar_zero = strada_new_str(argc > 0 && argv[0] ? argv[0] : \"perla\");\n");
    }

    # __DATA__ section — if the source had a `__DATA__` marker, the
    # parser stashed the post-marker content here. Open it as an
    # in-memory filehandle and set main::DATA so `<DATA>` reads it.
    if (defined($ast->{"data_section"})) {
        my str $data_lit = Perla::CodeGen::Escape::escape_c_str($ast->{"data_section"});
        ind(\%cg); emit(\%cg, "{ extern StradaValue *strada_open_str(const char *, const char *); ");
        emit(\%cg, "StradaValue *__data_fh = strada_open_str(\"" . $data_lit . "\", \"r\"); ");
        emit(\%cg, "perla_scalar_set(\"main\", \"DATA\", __data_fh); }\n");
    }

    # Register subs in the stash
    $si = 0;
    while ($si < scalar(@sub_names)) {
        my str $qname = $sub_names[$si];
        my str $fname = sub_cname_q($qname);
        # Split qname into pkg::name
        # Find LAST :: to split into package + short name
        my int $sep = -1;
        my int $si2 = 0;
        while ($si2 < length($qname) - 1) {
            if (substr($qname, $si2, 2) eq "::") { $sep = $si2; }
            $si2++;
        }
        my str $pkg = "main";
        my str $short = $qname;
        if ($sep >= 0) {
            $pkg = substr($qname, 0, $sep);
            $short = substr($qname, $sep + 2, length($qname) - $sep - 2);
        }
        # Skip registration for subs that have native C runtime implementations
        # (e.g., Exporter::import). Those C impls are installed in perla_init()
        # and the compiled .pm version is broken / incomplete (Exporter.pm uses
        # Exporter::Heavy via goto).
        if (!($pkg eq "Exporter" && $short eq "import")) {
            ind(\%cg); emit(\%cg, "perla_code_set(\"" . $pkg . "\", \"" . $short . "\", strada_new_str(\"" . $fname . "\"));\n");
        }
        $si++;
    }
    if (scalar(@sub_names) > 0) { emit(\%cg, "\n"); }

    # Register prototypes for any sub declared with `(PROTO)`. Looked up
    # at runtime via prototype("PKG::name"). Without this, Sub::Util's
    # `prototype()` always returned empty.
    if (defined($cg{"sub_protos"})) {
        my array @proto_keys = keys($cg{"sub_protos"});
        my int $pki = 0;
        while ($pki < scalar(@proto_keys)) {
            my str $pq = $proto_keys[$pki];
            my str $pv = "" . $cg{"sub_protos"}->{$pq};
            # Escape backslashes and double quotes for the C string literal.
            my str $pv_esc = "";
            my int $ei = 0;
            while ($ei < length($pv)) {
                my str $ch = substr($pv, $ei, 1);
                if ($ch eq "\\") { $pv_esc = $pv_esc . "\\\\"; }
                elsif ($ch eq "\"") { $pv_esc = $pv_esc . "\\\""; }
                else { $pv_esc = $pv_esc . $ch; }
                $ei = $ei + 1;
            }
            ind(\%cg); emit(\%cg, "perla_set_prototype(\"" . $pq . "\", \"" . $pv_esc . "\");\n");
            $pki = $pki + 1;
        }
    }

    # Emit sub-attribute registrations + MODIFY_CODE_ATTRIBUTES dispatch.
    # perla_set_attributes stores the list keyed by qname; attributes::get
    # reads it back. perla_dispatch_modify_code_attributes invokes the
    # user-defined MODIFY_CODE_ATTRIBUTES on each sub's package if
    # present (deferred after all sub registrations so the hook itself
    # is callable). Per Perl: an empty return means accept; a non-empty
    # return is the list of unaccepted attrs (which we currently warn
    # about but don't fatally reject — TODO).
    if (defined($cg{"sub_attrs"})) {
        my array @attr_keys = keys($cg{"sub_attrs"});
        my int $aki = 0;
        while ($aki < scalar(@attr_keys)) {
            my str $aq = $attr_keys[$aki];
            my scalar $alist = $cg{"sub_attrs"}->{$aq};
            my int $alen = scalar(@{$alist});
            # Pkg = portion before final "::"
            my str $apkg = "main";
            my int $lc = -1;
            my int $sx = 0;
            while ($sx < length($aq) - 1) {
                if (substr($aq, $sx, 2) eq "::") { $lc = $sx; }
                $sx = $sx + 1;
            }
            if ($lc > 0) { $apkg = substr($aq, 0, $lc); }
            ind(\%cg); emit(\%cg, "perla_set_attributes(\"" . $aq . "\", " . $alen);
            my int $aj = 0;
            while ($aj < $alen) {
                my str $av = "" . $alist->[$aj];
                my str $av_esc = "";
                my int $eei = 0;
                while ($eei < length($av)) {
                    my str $ch = substr($av, $eei, 1);
                    if ($ch eq "\\") { $av_esc = $av_esc . "\\\\"; }
                    elsif ($ch eq "\"") { $av_esc = $av_esc . "\\\""; }
                    else { $av_esc = $av_esc . $ch; }
                    $eei = $eei + 1;
                }
                emit(\%cg, ", \"" . $av_esc . "\"");
                $aj = $aj + 1;
            }
            emit(\%cg, ");\n");
            ind(\%cg);
            emit(\%cg, "perla_dispatch_modify_code_attributes(\"" . $apkg . "\", \"" . $aq . "\");\n");
            $aki = $aki + 1;
        }
    }

    # Generate top-level statements. Perl runs BEGIN blocks BEFORE the
    # rest of main code (in source order among themselves), regardless
    # of their position in the source. Without this hoist,
    # `BEGIN { ...A... } CODE BEGIN { ...B... }` ran A, then CODE, then
    # B, while Perl runs A, B, then CODE.
    my scalar $stmts = $ast->{"stmts"};
    # int type-inference (M1): compute int-eligible locals for main scope.
    Perla::CodeGen::Stmt::_compute_int_vars(\%cg, $stmts);
    my int $i = 0;
    # Perl phase ordering: BEGIN (source order) → CHECK/UNITCHECK (reverse
    # declaration order) → INIT (source order) → main. perla runs them all at
    # program start (it compiles ahead of time), but the relative order still
    # matters — `BEGIN{}INIT{}` must print B then I. `use`/`no` are wrapped in
    # phase-less BEGINs and stay in the BEGIN pass.
    # Pass 1 — BEGIN blocks, source order.
    while ($i < scalar(@{$stmts})) {
        my scalar $stmt = $stmts->[$i];
        if (defined($stmt) && $stmt->{"type"} == Perla::AST::N_BEGIN()
            && (!defined($stmt->{"phase"}) || $stmt->{"phase"} eq "BEGIN")) {
            Perla::CodeGen::Stmt::gen_stmt(\%cg, $stmt);
        }
        $i++;
    }
    # Pass 2 — CHECK / UNITCHECK blocks, REVERSE declaration order.
    $i = scalar(@{$stmts}) - 1;
    while ($i >= 0) {
        my scalar $stmt = $stmts->[$i];
        if (defined($stmt) && $stmt->{"type"} == Perla::AST::N_BEGIN()
            && defined($stmt->{"phase"})
            && ($stmt->{"phase"} eq "CHECK" || $stmt->{"phase"} eq "UNITCHECK")) {
            Perla::CodeGen::Stmt::gen_stmt(\%cg, $stmt);
        }
        $i = $i - 1;
    }
    # Pass 3 — INIT blocks, source order.
    $i = 0;
    while ($i < scalar(@{$stmts})) {
        my scalar $stmt = $stmts->[$i];
        if (defined($stmt) && $stmt->{"type"} == Perla::AST::N_BEGIN()
            && defined($stmt->{"phase"}) && $stmt->{"phase"} eq "INIT") {
            Perla::CodeGen::Stmt::gen_stmt(\%cg, $stmt);
        }
        $i++;
    }
    $i = 0;
    while ($i < scalar(@{$stmts})) {
        my scalar $stmt = $stmts->[$i];
        if (defined($stmt) && $stmt->{"type"} != Perla::AST::N_SUB()
            && $stmt->{"type"} != Perla::AST::N_BEGIN()
            && $stmt->{"type"} != Perla::AST::N_END()
            && !($stmt->{"type"} == Perla::AST::N_C_BLOCK() && $stmt->{"_emitted"} == 1)) {
            Perla::CodeGen::Stmt::gen_stmt(\%cg, $stmt);
        }
        $i++;
    }

    emit(\%cg, "\n");
    # END blocks run in LIFO order before program exit (Perl semantics).
    # Emit them after the main body but before cleanup so they can still
    # touch package vars and lexical state.
    my array @end_blocks;
    $i = 0;
    while ($i < scalar(@{$stmts})) {
        my scalar $stmt = $stmts->[$i];
        if (defined($stmt) && $stmt->{"type"} == Perla::AST::N_END()) {
            push(@end_blocks, $stmt);
        }
        $i = $i + 1;
    }
    my int $ei = scalar(@end_blocks) - 1;
    while ($ei >= 0) {
        my scalar $eb = $end_blocks[$ei];
        ind(\%cg); emit(\%cg, "/* END block */\n");
        Perla::CodeGen::Stmt::_gen_block(\%cg, $eb->{"body"});
        $ei = $ei - 1;
    }

    # Cleanup top-level variables
    my scalar $mv = $cg{"main_vars"};
    if (defined($mv)) {
        my int $di = 0;
        while ($di < scalar(@{$mv})) {
            my scalar $mve = $mv->[$di];
            ind(\%cg); emit(\%cg, "strada_decref(" . c_var_for_vtype($mve->{"type"}, $mve->{"name"}) . ");\n");
            $di++;
        }
    }
    ind(\%cg); emit(\%cg, "perla_cleanup();\n");
    ind(\%cg); emit(\%cg, "return 0;\n");
    emit(\%cg, "}\n\n");
    $cg{"in_main"} = 0;

    # Hoisted sub bodies must be emitted under THIS module's own strict state,
    # not whatever strict_vars an inlined dependency's `use strict` left behind
    # after the statement pass (that leak caused nondeterministic
    # "Global symbol requires explicit package name" on no-strict modules that
    # use a strict dependency). module_own_strict is set only by a top-level
    # (non-inlined) use/no strict; default off.
    my int $__mos = defined($cg{"module_own_strict"}) ? $cg{"module_own_strict"} : 0;
    $cg{"strict_vars"} = $__mos;
    $cg{"strict_subs"} = $__mos;
    $cg{"strict_refs"} = $__mos;

    # Generate sub bodies (including from nested blocks)
    Perla::CodeGen::Subs::gen_sub_bodies_from_stmts(\%cg, $stmts);

    # Generate anonymous sub bodies (collected during codegen above)
    my scalar $anon_subs = $cg{"anon_subs"};
    $i = 0;
    while ($i < scalar(@{$anon_subs})) {
        Perla::CodeGen::Subs::gen_sub_def(\%cg, $anon_subs->[$i]);
        $i++;
    }

    my str $code = sb_to_string($sb);
    my num $__g1 = 0.0;
    __C__ { struct timespec __tb; clock_gettime(CLOCK_MONOTONIC, &__tb); strada_decref(__g1); __g1 = strada_new_num((double)__tb.tv_sec + (double)__tb.tv_nsec/1e9); }
    # The generated C is manipulated below (and in perla.strada's fix passes)
    # with byte-offset index()/substr() surgery — e.g. the auto-declared-vars
    # post-pass splices a block at `index($code, "int main(")`. If a non-ASCII
    # string literal in the source made $code UTF-8-flagged, those offsets are
    # CODEPOINT offsets, not byte offsets, so the splice lands mid-token and
    # produces broken C (e.g. `NUL` + comment + `L` instead of `NULL`). The C
    # text is ASCII-structured (only some string-literal contents are
    # non-ASCII), so treat $code as bytes throughout the post-processing.
    __C__ {
        if (code && !STRADA_IS_TAGGED_INT(code) && code->type == STRADA_STR) {
            strada_set_utf8_flag(code, 0);
        }
    }

    # If we have anon subs, prepend their forward declarations.
    # Mark them `static` so each .pm.so keeps its own copy file-local —
    # otherwise two .so's loaded with RTLD_GLOBAL into the same process
    # both export `perla_sub_main___perla_anon_1` and the dynamic linker
    # interposes them: every closure built in the second .so points at
    # the first .so's body. Surfaced by Eval::Closure (used by
    # Params::ValidationCompiler / DateTime::TimeZone validators) where
    # all eval'd validators silently delegated to the first one.
    if (scalar(@{$anon_subs}) > 0) {
        my str $fwd = "";
        $i = 0;
        while ($i < scalar(@{$anon_subs})) {
            my scalar $asub = $anon_subs->[$i];
            my str $afname = sub_cname_q($asub->{"package"} . "::" . $asub->{"name"});
            my scalar $acaps = $asub->{"captures"};
            if (defined($acaps) && scalar(@{$acaps}) > 0) {
                $fwd = $fwd . "static StradaValue* " . $afname . "(StradaValue ***, StradaValue *);\n";
            } else {
                $fwd = $fwd . "static StradaValue* " . $afname . "(StradaValue *perla_args);\n";
            }
            $i++;
        }
        # Insert after the first occurrence of the newline after includes
        my int $insert_pos = index($code, "int main(");
        if ($insert_pos > 0) {
            $code = substr($code, 0, $insert_pos) . $fwd . "\n" . substr($code, $insert_pos);
        }
    }

    # Inject extern declarations for precompiled module init functions
    my scalar $pc_externs = $cg{"precompiled_externs"};
    if (defined($pc_externs) && scalar(@{$pc_externs}) > 0) {
        my str $ext_block = "/* Precompiled module init declarations */\n";
        my int $ei = 0;
        while ($ei < scalar(@{$pc_externs})) {
            $ext_block = $ext_block . $pc_externs->[$ei] . "\n";
            $ei++;
        }
        $ext_block = $ext_block . "\n";
        my int $main_pos2 = index($code, "int main(");
        if ($main_pos2 > 0) {
            $code = substr($code, 0, $main_pos2) . $ext_block . substr($code, $main_pos2);
        }
    }

    # Embed precompiled .o paths in a comment for the linker
    my scalar $pc_objects = $cg{"precompiled_objects"};
    if (defined($pc_objects) && scalar(@{$pc_objects}) > 0) {
        my str $obj_comment = "/* PERLA_LINK_OBJECTS:";
        my int $oi2 = 0;
        while ($oi2 < scalar(@{$pc_objects})) {
            $obj_comment = $obj_comment . " " . $pc_objects->[$oi2];
            $oi2++;
        }
        $obj_comment = $obj_comment . " */\n";
        $code = $obj_comment . $code;
    }

    # Post-process: find undeclared v_* variables and auto-declare them
    # Only do this for large programs (module code that has variable leaks)
    if (length($code) < 500) {
        return $code;
    }
    # Clear $code's UTF-8 flag BEFORE the used/declared scan below. The scan
    # uses index() (which returns a BYTE offset) together with substr() (which
    # treats a UTF-8-flagged string's offset as a CODEPOINT offset). On a $code
    # containing non-ASCII string literals, the two disagree and the extracted
    # v_NAME window is shifted left by the number of extra UTF-8 bytes earlier
    # on the line — e.g. an excluded `v_SIG` becomes `T(v_SIG` (from
    # `...TAGGED_INT(v_SIG)`), which then leaks into the auto-declared block as
    # invalid C (`static StradaValue *T(v_SIG = NULL;`). Clearing the flag here
    # (not just before the pre-main splice at line ~974) makes every index()/
    # substr() in this function byte-consistent. Surfaced by a real Abe app
    # whose `$SIG{__DIE__}`/`__WARN__` handler lines carry UTF-8 text.
    __C__ {
        if (code && !STRADA_IS_TAGGED_INT(code) && code->type == STRADA_STR) {
            strada_set_utf8_flag(code, 0);
        }
    }
    my hash %declared = ();
    my hash %used = ();
    my array @lines = split("\n", $code);
    my int $li = 0;
    while ($li < scalar(@lines)) {
        my str $ln = $lines[$li];
        # Hoist length() — a line can be a huge (529KB+) string literal; see
        # the $__fln_len note in the function-body scan below.
        my int $__ln_len = length($ln);
        # Track declarations: "static StradaValue *v_NAME" or "StradaValue *v_NAME"
        my int $dp = index($ln, "StradaValue *v_");
        while ($dp >= 0) {
            my int $vs = $dp + 13;
            my int $ve = $vs;
            while ($ve < $__ln_len) {
                my str $vc = substr($ln, $ve, 1);
                if (($vc ge "a" && $vc le "z") || ($vc ge "A" && $vc le "Z") || ($vc ge "0" && $vc le "9") || $vc eq "_") { $ve++; } else { last; }
            }
            if ($ve > $vs) { $declared{substr($ln, $vs, $ve - $vs)} = 1; }
            $dp = index($ln, "StradaValue *v_", $dp + 15);
        }
        # Track uses: any v_NAME
        my int $up = index($ln, "v_");
        while ($up >= 0) {
            my int $ue = $up + 2;
            while ($ue < $__ln_len) {
                my str $uc = substr($ln, $ue, 1);
                if (($uc ge "a" && $uc le "z") || ($uc ge "A" && $uc le "Z") || ($uc ge "0" && $uc le "9") || $uc eq "_") { $ue++; } else { last; }
            }
            if ($ue > $up + 2) { $used{substr($ln, $up, $ue - $up)} = 1; }
            $up = index($ln, "v_", $ue);
        }
        $li++;
    }
    my str $decl_block = "";
    my array @unames = keys(%used);
    # Exclude variables declared in runtime headers or as file-scope vars
    my hash %exclude = ();
    $exclude{"v_STDOUT"} = 1;
    $exclude{"v_STDIN"} = 1;
    $exclude{"v_STDERR"} = 1;
    $exclude{"v_ARGV"} = 1;
    $exclude{"v_ENV"} = 1;
    $exclude{"v_ISA"} = 1;
    $exclude{"v__"} = 1;
    $exclude{"v_SIG"} = 1;
    $exclude{"v_a"} = 1;
    $exclude{"v_b"} = 1;
    $exclude{"v_INC"} = 1;
    $exclude{"v_INC__h"} = 1;
    $exclude{"v__caret_O"} = 1;
    $exclude{"v__rbrack_"} = 1;
    $exclude{"v__caret_W"} = 1;
    $exclude{"v__caret_V"} = 1;
    $exclude{"v__caret_X"} = 1;
    $exclude{"v__caret_GLOBAL_PHASE"} = 1;
    # Also exclude anything that appears in the our_vars or file_scope_vars
    my scalar $ov = $cg{"our_vars"};
    if (defined($ov)) {
        my array @ovk = keys($ov);
        my int $ovi = 0;
        while ($ovi < scalar(@ovk)) { $exclude{"v_" . replace_all($ovk[$ovi], "::", "_")} = 1; $ovi++; }
    }
    my scalar $fv = $cg{"file_scope_vars"};
    if (defined($fv)) {
        my array @fvk = keys($fv);
        my int $fvi = 0;
        while ($fvi < scalar(@fvk)) { $exclude{"v_" . replace_all($fvk[$fvi], "::", "_")} = 1; $fvi++; }
    }
    # Only count declarations at file scope (static) or before main, not inside functions
    # A variable declared inside a function body is NOT visible in main()
    # Re-clear $code's UTF-8 flag here: an earlier concat (e.g. the anon-sub
    # forward-decl prepend) can re-flag it after the clear at assembly time, and
    # the index()/substr() splice below MUST use byte offsets — index() returns a
    # byte offset but substr() treats a flagged string's offset as a CODEPOINT
    # offset, so on a $code containing a non-ASCII string literal the splice
    # lands mid-token (`NULL` -> `NUL` + block + `L`), breaking the C.
    __C__ {
        if (code && !STRADA_IS_TAGGED_INT(code) && code->type == STRADA_STR) {
            strada_set_utf8_flag(code, 0);
        }
    }
    my hash %file_declared = ();
    my int $main_start = index($code, "int main(");
    if ($main_start < 0) { $main_start = 0; }
    my str $pre_main = substr($code, 0, $main_start);
    my int $__pre_main_len = length($pre_main);
    my int $pdp = index($pre_main, "StradaValue *v_");
    while ($pdp >= 0) {
        my int $pvs = $pdp + 13;
        my int $pve = $pvs;
        while ($pve < $__pre_main_len) {
            my str $pvc = substr($pre_main, $pve, 1);
            if (($pvc ge "a" && $pvc le "z") || ($pvc ge "A" && $pvc le "Z") || ($pvc ge "0" && $pvc le "9") || $pvc eq "_") { $pve++; } else { last; }
        }
        if ($pve > $pvs) { $file_declared{substr($pre_main, $pvs, $pve - $pvs)} = 1; }
        $pdp = index($pre_main, "StradaValue *v_", $pdp + 15);
    }
    my int $ui = 0;
    while ($ui < scalar(@unames)) {
        my str $vn = $unames[$ui];
        # Defense-in-depth: never emit a decl whose name isn't a valid C
        # identifier. The scan above can only mis-extract under an offset bug
        # (now fixed by the UTF-8-flag clear), but a bad name here produces
        # uncompilable C that's very hard to trace back, so guard it.
        if (_is_c_ident($vn) && !exists($file_declared{$vn}) && !exists($exclude{$vn})) {
            $decl_block = $decl_block . "static StradaValue *" . $vn . " = NULL;\n";
        }
        $ui++;
    }
    # Also auto-declare __local_save_* variables used in the code
    # ($code is multi-MB for big programs — hoist length() out of the inner
    # scan loop; recomputing it per character is O(n^2) and hung e.pl's
    # cold-cache recompile of large modules.)
    my int $__code_len = length($code);
    my int $lsp = index($code, "__local_save_");
    while ($lsp >= 0) {
        my int $lse = $lsp + 13;
        while ($lse < $__code_len) {
            my str $lsc = substr($code, $lse, 1);
            if (($lsc ge "a" && $lsc le "z") || ($lsc ge "A" && $lsc le "Z") || ($lsc ge "0" && $lsc le "9") || $lsc eq "_") { $lse++; } else { last; }
        }
        my str $lsname = substr($code, $lsp, $lse - $lsp);
        # Length > 13 skips the bare "__local_save_" prefix itself (13 chars)
        # while still including all suffixed forms, including "__local_save__"
        # (14 chars) used for `local $_`.
        if (index($code, "StradaValue *" . $lsname) < 0 && index($decl_block, $lsname) < 0 && length($lsname) > 13) {
            $decl_block = $decl_block . "static StradaValue *" . $lsname . " = NULL;\n";
        }
        $lsp = index($code, "__local_save_", $lse);
    }

    if (length($decl_block) > 0) {
        my int $main_pos = index($code, "int main(");
        if ($main_pos > 0) {
            $code = substr($code, 0, $main_pos) . "/* auto-declared variables */\n" . $decl_block . "\n" . substr($code, $main_pos);
        }
    }

    # Auto-declare undeclared variables inside function bodies
    # Scan each function for v_* variables used but not declared
    my array @lines2 = split("\n", $code);
    my int $len2 = size(@lines2);
    my int $li2 = 0;
    my int $modified = 0;
    while ($li2 < $len2) {
        my str $ln2 = $lines2[$li2];
        # Detect function start: "StradaValue* perla_sub_...(..." or "void perla_mod_init_..."
        if ((index($ln2, "StradaValue* perla_sub_") >= 0 || index($ln2, "void perla_mod_init_") >= 0) && index($ln2, ";") < 0 && index($ln2, "{") >= 0) {
            # Find function body end (matching closing brace)
            my int $brace_depth = 1;
            my int $fn_start = $li2 + 1;
            my int $fn_end = $fn_start;
            while ($fn_end < $len2 && $brace_depth > 0) {
                my str $fl = $lines2[$fn_end];
                my int $fi2 = 0;
                my int $__fl_len = length($fl);
                while ($fi2 < $__fl_len) {
                    my str $fc = substr($fl, $fi2, 1);
                    if ($fc eq "{") { $brace_depth++; }
                    if ($fc eq "}") { $brace_depth--; }
                    $fi2++;
                }
                $fn_end++;
            }
            # Scan function body for declared and used v_* variables
            my hash %fn_declared = ();
            my hash %fn_used = ();
            my int $fli = $fn_start;
            while ($fli < $fn_end) {
                my str $fln = $lines2[$fli];
                # A single line can be huge (a 529KB string literal emitted as
                # one PERLA_NEW_STR_LIT(...) — e.g. Locale::SubCountry::Codes'
                # JSON). Hoist length() out of the per-char scan loops below;
                # recomputing it per character is O(n^2) and hung e.pl's
                # cold-cache recompile of such modules.
                my int $__fln_len = length($fln);
                # Track declarations: "StradaValue *v_NAME"
                my int $dp2 = index($fln, "StradaValue *v_");
                while ($dp2 >= 0) {
                    my int $vs2 = $dp2 + 13;
                    my int $ve2 = $vs2;
                    while ($ve2 < $__fln_len) {
                        my str $vc2 = substr($fln, $ve2, 1);
                        if (($vc2 ge "a" && $vc2 le "z") || ($vc2 ge "A" && $vc2 le "Z") || ($vc2 ge "0" && $vc2 le "9") || $vc2 eq "_") { $ve2++; } else { last; }
                    }
                    if ($ve2 > $vs2) { $fn_declared{substr($fln, $vs2, $ve2 - $vs2)} = 1; }
                    $dp2 = index($fln, "StradaValue *v_", $dp2 + 15);
                }
                # Track uses: v_NAME (only at word boundaries)
                my int $up2 = index($fln, "v_");
                while ($up2 >= 0) {
                    if ($up2 == 0 || substr($fln, $up2 - 1, 1) eq " " || substr($fln, $up2 - 1, 1) eq "(" || substr($fln, $up2 - 1, 1) eq "," || substr($fln, $up2 - 1, 1) eq "*" || substr($fln, $up2 - 1, 1) eq "!") {
                        my int $ue2 = $up2 + 2;
                        while ($ue2 < $__fln_len) {
                            my str $uc2 = substr($fln, $ue2, 1);
                            if (($uc2 ge "a" && $uc2 le "z") || ($uc2 ge "A" && $uc2 le "Z") || ($uc2 ge "0" && $uc2 le "9") || $uc2 eq "_") { $ue2++; } else { last; }
                        }
                        $fn_used{substr($fln, $up2, $ue2 - $up2)} = 1;
                        $up2 = index($fln, "v_", $ue2);
                    } else {
                        $up2 = index($fln, "v_", $up2 + 1);
                    }
                }
                $fli++;
            }
            # Also scan for __local_save_* in function body
            $fli = $fn_start;
            while ($fli < $fn_end) {
                my str $fln2 = $lines2[$fli];
                my int $lsp2 = index($fln2, "__local_save_");
                while ($lsp2 >= 0) {
                    my int $lse2 = $lsp2 + 13;
                    while ($lse2 < length($fln2)) {
                        my str $lc = substr($fln2, $lse2, 1);
                        if (($lc ge "a" && $lc le "z") || ($lc ge "A" && $lc le "Z") || ($lc ge "0" && $lc le "9") || $lc eq "_") { $lse2++; } else { last; }
                    }
                    my str $lsn = substr($fln2, $lsp2, $lse2 - $lsp2);
                    if (length($lsn) > 13) {
                        $fn_used{$lsn} = 1;
                        # Also check if it's declared
                        if (index($fln2, "StradaValue *" . $lsn) >= 0) {
                            $fn_declared{$lsn} = 1;
                        }
                    }
                    $lsp2 = index($fln2, "__local_save_", $lse2);
                }
                $fli++;
            }
            # Add declarations for undeclared variables
            my str $fn_decls = "";
            my array @fn_unames = keys(%fn_used);
            my int $fui = 0;
            while ($fui < scalar(@fn_unames)) {
                my str $fvn = $fn_unames[$fui];
                if (!exists($fn_declared{$fvn}) && !exists($exclude{$fvn})) {
                    # For __local_save_* vars, always declare locally
                    # For v_* vars, check if it's a file-scope static (don't shadow)
                    my int $is_file_scope = 0;
                    if (index($fvn, "__local_save_") != 0) {
                        # Check if this var is declared before main() (file scope)
                        my str $static_decl = "static StradaValue *" . $fvn . " = NULL;";
                        my str $global_decl = "StradaValue *" . $fvn . " = NULL;";
                        my int $main_start = index($code, "int main(");
                        if ($main_start > 0) {
                            my str $pre = substr($code, 0, $main_start);
                            if (index($pre, $static_decl) >= 0 || index($pre, $global_decl) >= 0) {
                                $is_file_scope = 1;
                            }
                        }
                    }
                    if ($is_file_scope == 0) {
                        $fn_decls = $fn_decls . "    StradaValue *" . $fvn . " = NULL;\n";
                    }
                }
                $fui++;
            }
            if (length($fn_decls) > 0) {
                $lines2[$fn_start] = $fn_decls . $lines2[$fn_start];
                $modified = 1;
            }
        }
        $li2++;
    }
    if ($modified == 1) {
        $code = join("\n", @lines2);
    }

    # Inject any format-sync helper functions BEFORE `int main(` so the
    # static defs are visible to the main body's perla_register_format_sync
    # calls. The helpers reference file-scope C vars (`v_x`) which are
    # declared earlier in the file, so the insertion point only needs to
    # precede main.
    if (defined($cg{"format_sync_defs"}) && length($cg{"format_sync_defs"}) > 0) {
        my int $__fs_main_at = index($code, "int main(");
        if ($__fs_main_at > 0) {
            $code = substr($code, 0, $__fs_main_at)
                  . $cg{"format_sync_defs"}
                  . substr($code, $__fs_main_at, length($code) - $__fs_main_at);
        }
    }

    if ($__pt == 1) {
        my num $__g2 = 0.0;
        __C__ { struct timespec __tc; clock_gettime(CLOCK_MONOTONIC, &__tc); strada_decref(__g2); __g2 = strada_new_num((double)__tc.tv_sec + (double)__tc.tv_nsec/1e9); }
        say(STDERR, "[gen] emit=" . ($__g1 - $__g0) . "s postpass=" . ($__g2 - $__g1) . "s");
    }
    return $code;
}

# Generate a standalone C file for a precompiled module (.o)
# Instead of main(), emits an init function: void perla_mod_init_Pkg_Name(void)
# The init function registers all subs in the stash and runs module-level code.
func generate_module(scalar $ast, str $mod_name) str {
    my scalar $sb = sb_new(65536);
    my hash %cg = ();
    $cg{"sb"} = $sb;
    $cg{"indent"} = 0;
    $cg{"pkg"} = $mod_name;
    $cg{"subs"} = {};
    $cg{"anon_subs"} = [];
    $cg{"our_vars"} = {};
    $cg{"pad_mode"} = (core::getenv("PERLA_REPL_PAD") eq "1") ? 1 : 0;
    $cg{"lexical_depth"} = 0;
    $cg{"tmp_count"} = 0;
    $cg{"label_count"} = 0;
    $cg{"label_map"} = {};
    $cg{"capture_vars"} = {};
    $cg{"declared_vars"} = {};
    $cg{"same_scope_decls"} = {};
    $cg{"my_lexicals"} = [];
    $cg{"main_vars"} = [];
    $cg{"file_scope_vars"} = {};
    $cg{"module_mode"} = 1;

    # Collect all sub declarations and our variables
    Perla::CodeGen::Collect::collect_subs(\%cg, $ast);
    Perla::CodeGen::Collect::register_builtin_protos(\%cg);
    Perla::CodeGen::Collect::collect_our_vars(\%cg, $ast);
    Perla::CodeGen::Collect::collect_file_scope_vars(\%cg, $ast);
    _perla_reset_mangle_collisions();
    _collect_sigil_collisions(\%cg, $ast);
    _perla_snapshot_file_collisions();

    # C init function name: perla_mod_init_Pkg_Name
    my str $init_name = "perla_mod_init_" . replace_all($mod_name, "::", "_");

    # Header
    emit(\%cg, "/* Precompiled Perla module: " . $mod_name . " */\n");
    emit(\%cg, "#include \"strada_runtime.h\"\n");
    emit(\%cg, "#include \"perla_stash.h\"\n");
    emit(\%cg, "#include \"perla_dbi.h\"\n");
    emit(\%cg, "#include <string.h>\n");
    emit(\%cg, "#include <stdio.h>\n");
    emit(\%cg, "#include <errno.h>\n");
    emit(\%cg, "#include <math.h>\n");
    emit(\%cg, "#include <stdlib.h>\n");
    emit(\%cg, "#include <stddef.h>\n");
    emit(\%cg, "#include <sys/wait.h>\n");
    emit(\%cg, "#include <sys/stat.h>\n");
    emit(\%cg, "#include <unistd.h>\n");
    emit(\%cg, "#include <time.h>\n");
    emit(\%cg, "#include <dirent.h>\n");
    emit(\%cg, "#include <sys/times.h>\n");
    emit(\%cg, "#include <fcntl.h>\n");
    emit(\%cg, "#include <utime.h>\n\n");

    # Perla runtime globals as extern (defined in the main program)
    emit(\%cg, "/* Strada runtime globals */\n");
    emit(\%cg, "extern StradaValue *v_STDIN;\n");
    emit(\%cg, "extern StradaValue *v_STDOUT;\n");
    emit(\%cg, "extern StradaValue *v_STDERR;\n\n");

    # Perl special variables - extern (owned by main)
    emit(\%cg, "/* Perl special variables (extern - owned by main) */\n");
    emit(\%cg, "extern StradaValue *perla_eval_error;\n");
    emit(\%cg, "extern StradaValue *perla_dollar_underscore;\n");
    emit(\%cg, "extern StradaValue *perla_increment(StradaValue *sv);\n");
    emit(\%cg, "extern StradaValue *perla_decrement(StradaValue *sv);\n");
    emit(\%cg, "extern StradaValue *perla_range_array(StradaValue *from, StradaValue *to);\n");
    emit(\%cg, "extern StradaValue *perla_readline_fh(StradaValue *fh);\n");
    emit(\%cg, "extern StradaValue *perla_read_all_lines_fh(StradaValue *fh);\n");
    emit(\%cg, "extern StradaValue *perla_readline_argv(StradaValue *argv);\n");
    emit(\%cg, "extern StradaValue *perla_reverse_ctx(StradaValue *sv);\n");
    emit(\%cg, "extern StradaValue *perla_overload_binary(StradaValue *left, StradaValue *right, const char *op);\n");
    emit(\%cg, "extern StradaValue *perla_overload_deref(StradaValue *sv, const char *slot_suffix);\n");
    emit(\%cg, "extern PerlGlob *perla_autoload_resolve(const char *pkg);\n");
    emit(\%cg, "extern void perla_set_autoload_var(const char *fullname);\n");
    emit(\%cg, "extern StradaValue *perla_getpwuid_list(StradaValue *uid);\n");
    emit(\%cg, "extern StradaValue *perla_getpwuid_name(StradaValue *uid);\n");
    emit(\%cg, "extern StradaValue *perla_getpwnam_list(StradaValue *name);\n");
    emit(\%cg, "extern StradaValue *perla_getpwnam_name(StradaValue *name);\n");
    emit(\%cg, "extern StradaValue *perla_irs;\n");
    emit(\%cg, "extern StradaValue *perla_ors;\n");
    emit(\%cg, "extern StradaValue *perla_ofs;\n");
    emit(\%cg, "extern StradaValue *perla_lse;\n");
    emit(\%cg, "extern StradaValue *perla_subsep;\n");
    emit(\%cg, "extern StradaValue *perla_dollar_tilde;\n");
    emit(\%cg, "extern StradaValue *perla_dollar_caret;\n");
    emit(\%cg, "extern StradaValue *perla_dollar_equals;\n");
    emit(\%cg, "extern StradaValue *perla_dollar_minus;\n");
    emit(\%cg, "extern StradaValue *perla_dollar_caret_L;\n");
    emit(\%cg, "extern int __perla_autoflush;\n");
    emit(\%cg, "extern int __perla_want_list;\n");
    emit(\%cg, "extern StradaValue *v_ARGV;\n");
    emit(\%cg, "extern StradaValue *v_ENV;\n");
    emit(\%cg, "extern StradaValue *v_ISA;\n");
    emit(\%cg, "extern StradaValue *v__;\n");
    emit(\%cg, "extern StradaValue *v_SIG;\n");
    emit(\%cg, "extern StradaValue *v_a;\n");
    emit(\%cg, "extern StradaValue *v_b;\n");
    emit(\%cg, "extern StradaValue *v_INC;\n");
    emit(\%cg, "extern StradaValue *v_INC__h;\n");
    emit(\%cg, "extern StradaValue *perla_at_;\n");
    emit(\%cg, "extern StradaValue *v__caret_O;\n");
    emit(\%cg, "extern StradaValue *v__rbrack_;\n");
    emit(\%cg, "extern StradaValue *v__caret_W;\n");
    emit(\%cg, "extern StradaValue *v__caret_V;\n");
    emit(\%cg, "extern StradaValue *v__caret_X;\n");
    emit(\%cg, "extern StradaValue *v__caret_GLOBAL_PHASE;\n");
    # $/ — Perl's input record separator. Owned by main; modules that
    # use `local $/ = ...` or `local $/;` (e.g. YAML.pm's slurp idiom)
    # need this declared so v__slash_ is in scope at compile time.
    emit(\%cg, "extern StradaValue *v__slash_;\n");
    emit(\%cg, "extern StradaValue *perla_dollar_zero;\n");
    emit(\%cg, "extern int perla_dollar_question;\n");
    emit(\%cg, "extern int perla_dollar_dot;\n");
    # `use warnings;` in a runtime-compiled module emits `perla_warnings_active = 1;`
    # — declare it here too (the main-program prelude already does) so the
    # module's own .c compiles instead of failing with "undeclared".
    emit(\%cg, "extern int perla_warnings_active;\n");
    # `perla_code_get` override-cache generation counter: a module body that
    # calls another sub through the override-aware fast path emits
    # `if (__cv_g != perla_code_override_gen) ...`. Declare it here too (the
    # main-program prelude already does) so the module .c compiles instead of
    # failing with "perla_code_override_gen undeclared". Surfaced by
    # Abe::Utils::crnd / get_states_hash dispatch inside Abe::DatabaseRecord.
    emit(\%cg, "extern long perla_code_override_gen;\n");
    emit(\%cg, "extern StradaValue **__perla_sort_ctx[16];\n");
    emit(\%cg, "extern StradaValue **__perla_cell[64];\n");
    # local() save variables (used by modules that do local $SIG{...} etc.)
    emit(\%cg, "extern StradaValue *__local_save_SIG;\n");
    emit(\%cg, "extern StradaValue *__local_save_Data;\n");
    emit(\%cg, "extern StradaValue *__local_save_Data_Dumper_Maxdepth;\n");
    emit(\%cg, "extern StradaValue *__local_save_;\n");
    emit(\%cg, "extern StradaValue *__local_save__;\n");
    emit(\%cg, "extern StradaValue *__local_save__caret_W;\n\n");

    # Module-scoped static variables (our vars + file-scope my vars)
    my scalar $our_vars = $cg{"our_vars"};
    my array @our_names = keys($our_vars);
    my hash %default_vars = ();
    $default_vars{"ARGV"} = 1; $default_vars{"ENV"} = 1; $default_vars{"ISA"} = 1;
    $default_vars{"_"} = 1; $default_vars{"SIG"} = 1; $default_vars{"a"} = 1;
    $default_vars{"b"} = 1; $default_vars{"INC"} = 1;
    $default_vars{"STDOUT"} = 1; $default_vars{"STDIN"} = 1; $default_vars{"STDERR"} = 1;
    # Perl special variables (extern in module mode)
    $default_vars{"_caret_O"} = 1; $default_vars{"_rbrack_"} = 1; $default_vars{"_caret_W"} = 1;
    $default_vars{"_caret_V"} = 1; $default_vars{"_caret_X"} = 1;
    # $/ — input record separator. file_scope_vars stores under the
    # raw name "/" (collect_file_scope_vars uses var->{value} which
    # for `local $/` is "/"). The C variable name is `v__slash_` after
    # safe_ident, declared extern above. Skip the static emit here so
    # we don't get a static-vs-extern conflict.
    $default_vars{"/"} = 1;
    my int $oi = 0;
    while ($oi < scalar(@our_names)) {
        my str $onm = $our_names[$oi];
        if (!exists($default_vars{$onm})) {
            my str $ot2 = "" . $our_vars->{$onm};
            emit(\%cg, "static StradaValue *" . c_var_for_vtype($ot2, $onm) . " = NULL;\n");
        }
        $oi++;
    }
    my scalar $fs_vars = $cg{"file_scope_vars"};
    my array @fs_names = keys($fs_vars);
    my int $fi = 0;
    while ($fi < scalar(@fs_names)) {
        my str $fsn = $fs_names[$fi];
        if (!exists($our_vars->{$fsn}) && !exists($default_vars{$fsn})) {
            my str $fst2 = "" . $fs_vars->{$fsn};
            emit(\%cg, "static StradaValue *" . c_var_for_vtype($fst2, $fsn) . " = NULL;\n");
        }
        $fi++;
    }
    emit(\%cg, "\n");

    # File-scope __C__ blocks
    my scalar $stmts_pre = $ast->{"stmts"};
    my int $ci = 0;
    while ($ci < scalar(@{$stmts_pre})) {
        my scalar $cs = $stmts_pre->[$ci];
        if (defined($cs) && $cs->{"type"} == Perla::AST::N_C_BLOCK()) {
            my str $c_code = $cs->{"code"};
            if (index($c_code, "#include") >= 0 || index($c_code, "static ") >= 0 ||
                index($c_code, "typedef") >= 0 || index($c_code, "extern ") >= 0) {
                emit(\%cg, "/* __C__ (file scope) */\n");
                emit(\%cg, $c_code);
                emit(\%cg, "\n\n");
                $cs->{"_emitted"} = 1;
            }
        }
        $ci++;
    }

    # Forward declarations for subs
    my scalar $subs = $cg{"subs"};
    my array @sub_names = keys($subs);
    my int $si = 0;
    while ($si < scalar(@sub_names)) {
        my str $qname = $sub_names[$si];
        my str $fname = sub_cname_q($qname);
        emit(\%cg, "StradaValue* " . $fname . "(StradaValue *perla_args);\n");
        my scalar $pinfo = $cg{"sub_params"}->{$qname};
        if (defined($pinfo)) {
            my int $arity = $pinfo->{"arity"};
            emit(\%cg, "StradaValue* " . $fname . "__direct(");
            my int $pi = 0;
            while ($pi < $arity) {
                if ($pi > 0) { emit(\%cg, ", "); }
                emit(\%cg, "StradaValue*");
                $pi++;
            }
            # Trailing perla_args_full param.
            if ($arity > 0) { emit(\%cg, ", "); }
            emit(\%cg, "StradaValue*");
            emit(\%cg, ");\n");
        }
        $si++;
    }
    if (scalar(@sub_names) > 0) { emit(\%cg, "\n"); }

    # Init function (replaces main)
    emit(\%cg, "/* Module init - registers subs and runs module-level code */\n");
    emit(\%cg, "void " . $init_name . "(void) {\n");
    # Once-guard: when modules import each other in a cycle (e.g.
    # Abe::App::Shared::SearchTable uses Abe::App::Shared::ReportViews
    # which uses SearchTable back), runtime require can re-enter this
    # init via a different path (statically linked .pm.o + dlopen'd
    # .pm.so calling each other). Without the guard the recursion is
    # unbounded and blows the stack. The static init across compilation
    # units doesn't cover this — each .pm.so has its own static — so
    # the guard fires per-translation-unit, which is exactly what we
    # want: the first entry runs the body, every re-entry is a no-op.
    emit(\%cg, "    static int __perla_init_done = 0;\n");
    emit(\%cg, "    if (__perla_init_done) return;\n");
    emit(\%cg, "    __perla_init_done = 1;\n");
    # Per-call mark for `local` save records (chain itself is a runtime global).
    emit(\%cg, "    void *__perla_local_chain_mark __attribute__((unused)) = __perla_local_chain;\n");
    # Per-module closure-cell table — shadows the file-scope global so
    # module-init closures don't collide with closures in code we call.
    # See gen_sub_def for rationale.
    emit(\%cg, "    StradaValue **__perla_cell[64] __attribute__((unused)) = {0};\n");
    # Push a call frame for the module's top-level so any code that reads
    # `perla_call_stack[depth-1].package` (perla_moose_import, the `has`
    # accessor registration path, `caller()` at file scope) sees OUR
    # package, not whatever caller invoked our init via dlopen. Without
    # this, Moo's `has`/`extends`/etc. and the `has X => (...)` calls
    # that follow register accessors in the WRONG package and `$obj->attr`
    # later misses dispatch with "Can't locate object method ... via
    # package ...". The frame is popped at end-of-init.
    emit(\%cg, "    perla_call_push(\"" . $mod_name . "\", \"(init)\", \"" . $cg{"filename"} . "\", 0);\n");
    # Mark this stash as fully inlined so a runtime `require` of this
    # module short-circuits past the compile+dlopen path. Without this,
    # require() falls back to "is the stash non-empty" — which is wrong
    # when native overrides have pre-seeded a few subs into a stash for
    # a module that hasn't actually been loaded yet.
    emit(\%cg, "    perla_stash_mark_inlined(\"" . $mod_name . "\");\n");
    $cg{"indent"} = 1;
    $cg{"in_main"} = 1;

    # Register subs in the stash
    $si = 0;
    while ($si < scalar(@sub_names)) {
        my str $qname = $sub_names[$si];
        my str $fname = sub_cname_q($qname);
        # Find LAST :: to split into package + short name
        my int $sep = -1;
        my int $si2 = 0;
        while ($si2 < length($qname) - 1) {
            if (substr($qname, $si2, 2) eq "::") { $sep = $si2; }
            $si2++;
        }
        my str $pkg = $mod_name;
        my str $short = $qname;
        if ($sep >= 0) {
            $pkg = substr($qname, 0, $sep);
            $short = substr($qname, $sep + 2, length($qname) - $sep - 2);
        }
        # Skip registration for subs that have native C runtime implementations
        # (see main codegen above for rationale).
        if (!($pkg eq "Exporter" && $short eq "import")) {
            ind(\%cg); emit(\%cg, "perla_code_set(\"" . $pkg . "\", \"" . $short . "\", strada_new_str(\"" . $fname . "\"));\n");
        }
        $si++;
    }
    if (scalar(@sub_names) > 0) { emit(\%cg, "\n"); }

    # Register prototypes for any sub declared with `(PROTO)` in this
    # module (including eval-string wrappers). Without this, an
    # `eval q{ sub myadd ($$) { ... } }` body produced a .pm.so whose
    # init registered the sub but not its prototype, so
    # prototype("myadd") returned undef. Mirrors the same block in
    # generate() above.
    if (defined($cg{"sub_protos"})) {
        my array @mod_proto_keys = keys($cg{"sub_protos"});
        my int $mpki = 0;
        while ($mpki < scalar(@mod_proto_keys)) {
            my str $mpq = $mod_proto_keys[$mpki];
            my str $mpv = "" . $cg{"sub_protos"}->{$mpq};
            my str $mpv_esc = "";
            my int $mei = 0;
            while ($mei < length($mpv)) {
                my str $mch = substr($mpv, $mei, 1);
                if ($mch eq "\\") { $mpv_esc = $mpv_esc . "\\\\"; }
                elsif ($mch eq "\"") { $mpv_esc = $mpv_esc . "\\\""; }
                else { $mpv_esc = $mpv_esc . $mch; }
                $mei = $mei + 1;
            }
            ind(\%cg); emit(\%cg, "perla_set_prototype(\"" . $mpq . "\", \"" . $mpv_esc . "\");\n");
            $mpki = $mpki + 1;
        }
        if (scalar(@mod_proto_keys) > 0) { emit(\%cg, "\n"); }
    }

    # Generate top-level statements (module-level code: package, our, has, @ISA, etc.)
    my scalar $stmts = $ast->{"stmts"};
    my int $i = 0;
    while ($i < scalar(@{$stmts})) {
        my scalar $stmt = $stmts->[$i];
        if (defined($stmt) && $stmt->{"type"} != Perla::AST::N_SUB() &&
            !($stmt->{"type"} == Perla::AST::N_C_BLOCK() && $stmt->{"_emitted"} == 1)) {
            Perla::CodeGen::Stmt::gen_stmt(\%cg, $stmt);
        }
        $i++;
    }

    # End-of-init sync hook marker. Replaced in post-processing with
    # sync code for each file-scope `v_X` that's NOT declared `our` in
    # this module. Each .pm.o has its own `static StradaValue *v_X` for
    # every package variable it references. When `our %X` is declared,
    # codegen mirrors v_X into the stash. When %X is *imported* via
    # `use Foo` (Foo's Exporter copies its hash slot into our stash),
    # the stash has the data but our v_X stays NULL — so sub bodies that
    # reference v_X see nothing. Surfaced via Locale::Codes referencing
    # `%ALL_CODESETS` (imported from Locale::Codes::Constants); _init's
    # `! exists $ALL_CODESETS{$type}` used the NULL v_ALL_CODESETS and
    # silently failed for every type. The actual sync emission happens
    # in post-processing because the full set of file-scope vars isn't
    # known until the auto-declared-variable scan runs over the body.
    emit(\%cg, "    /* __PERLA_SYNC_HOOK__ */\n");

    # Pop the synthetic init frame pushed at the top of the function.
    emit(\%cg, "    perla_call_pop();\n");

    emit(\%cg, "}\n\n");
    $cg{"in_main"} = 0;

    # Hoisted sub bodies must be emitted under THIS module's own strict state,
    # not whatever strict_vars an inlined dependency's `use strict` left behind
    # after the statement pass (that leak caused nondeterministic
    # "Global symbol requires explicit package name" on no-strict modules that
    # use a strict dependency). module_own_strict is set only by a top-level
    # (non-inlined) use/no strict; default off.
    my int $__mos = defined($cg{"module_own_strict"}) ? $cg{"module_own_strict"} : 0;
    $cg{"strict_vars"} = $__mos;
    $cg{"strict_subs"} = $__mos;
    $cg{"strict_refs"} = $__mos;

    # Generate sub bodies (including from nested blocks)
    Perla::CodeGen::Subs::gen_sub_bodies_from_stmts(\%cg, $stmts);

    # Generate anonymous sub bodies
    my scalar $anon_subs = $cg{"anon_subs"};
    $i = 0;
    while ($i < scalar(@{$anon_subs})) {
        Perla::CodeGen::Subs::gen_sub_def(\%cg, $anon_subs->[$i]);
        $i++;
    }

    my str $code = sb_to_string($sb);

    # Prepend anon sub forward declarations if any. `static` keeps each
    # .pm.so's anon symbols file-local so RTLD_GLOBAL doesn't interpose
    # them across modules (see comment in generate()).
    if (scalar(@{$anon_subs}) > 0) {
        my str $fwd = "";
        $i = 0;
        while ($i < scalar(@{$anon_subs})) {
            my scalar $asub = $anon_subs->[$i];
            my str $afname = sub_cname_q($asub->{"package"} . "::" . $asub->{"name"});
            my scalar $acaps = $asub->{"captures"};
            if (defined($acaps) && scalar(@{$acaps}) > 0) {
                $fwd = $fwd . "static StradaValue* " . $afname . "(StradaValue ***, StradaValue *);\n";
            } else {
                $fwd = $fwd . "static StradaValue* " . $afname . "(StradaValue *perla_args);\n";
            }
            $i++;
        }
        my int $insert_pos = index($code, "void " . $init_name);
        if ($insert_pos > 0) {
            $code = substr($code, 0, $insert_pos) . $fwd . "\n" . substr($code, $insert_pos);
        }
    }

    # Auto-declare undeclared variables (same as generate()). Previously gated
    # on code size > 50000 as an optimization, but smaller modules can still
    # reference package vars (e.g. $VERSION) that need file-scope statics for
    # the resulting .c to link.
    if (length($code) > 0) {
        my hash %declared = ();
        my hash %used = ();
        my array @lines = split("\n", $code);
        my int $li = 0;
        while ($li < scalar(@lines)) {
            my str $ln = $lines[$li];
            my int $dp = index($ln, "static StradaValue *v_");
            while ($dp >= 0) {
                my int $vs = $dp + 20;
                my int $ve = $vs;
                while ($ve < length($ln) && substr($ln, $ve, 1) ne " " && substr($ln, $ve, 1) ne "=" && substr($ln, $ve, 1) ne ";") { $ve++; }
                $declared{substr($ln, $vs, $ve - $vs)} = 1;
                $dp = index($ln, "static StradaValue *v_", $ve);
            }
            my int $up = index($ln, "v_");
            while ($up >= 0) {
                # `&` prefix added: perla_local_push_scalar_slot takes the
                # ADDRESS of the var (&v_NAME). Without recognizing `&` as
                # a valid prefix, vars only used in &-form (e.g.
                # `local $Pkg::var = ...` from a *different* package)
                # were not auto-declared and the resulting .pm.c failed
                # gcc with `'v_Pkg_var' undeclared`.
                if ($up == 0 || substr($ln, $up - 1, 1) eq " " || substr($ln, $up - 1, 1) eq "(" || substr($ln, $up - 1, 1) eq "," || substr($ln, $up - 1, 1) eq "*" || substr($ln, $up - 1, 1) eq "!" || substr($ln, $up - 1, 1) eq "&") {
                    my int $ue = $up;
                    while ($ue < length($ln) && substr($ln, $ue, 1) ne " " && substr($ln, $ue, 1) ne ")" && substr($ln, $ue, 1) ne "," && substr($ln, $ue, 1) ne ";" && substr($ln, $ue, 1) ne "[" && substr($ln, $ue, 1) ne "-") { $ue++; }
                    $used{substr($ln, $up, $ue - $up)} = 1;
                    $up = index($ln, "v_", $ue);
                } else {
                    $up = index($ln, "v_", $up + 1);
                }
            }
            $li++;
        }
        my str $decl_block = "";
        my array @unames = keys(%used);
        my hash %exclude = ();
        $exclude{"v_STDOUT"} = 1; $exclude{"v_STDIN"} = 1; $exclude{"v_STDERR"} = 1;
        $exclude{"v_ARGV"} = 1; $exclude{"v_ENV"} = 1; $exclude{"v_ISA"} = 1;
        $exclude{"v__"} = 1; $exclude{"v_SIG"} = 1; $exclude{"v_a"} = 1;
        $exclude{"v_b"} = 1; $exclude{"v_INC"} = 1; $exclude{"v_INC__h"} = 1;
        $exclude{"v__caret_O"} = 1; $exclude{"v__rbrack_"} = 1; $exclude{"v__caret_W"} = 1;
        $exclude{"v__caret_V"} = 1; $exclude{"v__caret_X"} = 1;
        $exclude{"v__caret_GLOBAL_PHASE"} = 1;
        # $/ is externed via the runtime globals block above; don't
        # auto-declare a conflicting static here.
        $exclude{"v__slash_"} = 1;
        my int $ui = 0;
        while ($ui < scalar(@unames)) {
            my str $vn = $unames[$ui];
            if (!exists($declared{$vn}) && !exists($exclude{$vn})) {
                $decl_block = $decl_block . "static StradaValue *" . $vn . " = NULL;\n";
            }
            $ui++;
        }
        if (length($decl_block) > 0) {
            my int $init_pos = index($code, "void " . $init_name);
            if ($init_pos > 0) {
                $code = substr($code, 0, $init_pos) . "/* auto-declared variables */\n" . $decl_block . "\n" . substr($code, $init_pos);
            }
        }

        # Expand the end-of-init sync hook. For each used-but-not-declared
        # `v_X` (auto-declared above), emit a sync from the module's stash
        # slot. This connects Exporter-imported package vars to the file
        # static so `$X{key}` reads in sub bodies see the imported data.
        # Sigil prefix is recovered from the C var-name suffix: `_h` →
        # hash, `_a` → array, otherwise scalar (legacy v_NAME for
        # collision-free names, since we don't carry sigil through to
        # the post-pass).
        my str $sync_block = "";
        my array @snames = keys(%used);
        my int $sui = 0;
        while ($sui < scalar(@snames)) {
            my str $svn = $snames[$sui];
            if (!exists($declared{$svn}) && !exists($exclude{$svn})) {
                # Strip leading "v_"; recover sigil from suffix when present
                # (collision-mangled names get _h/_a/_s suffix).
                my str $bare = substr($svn, 2, length($svn) - 2);
                my int $blen = length($bare);
                my str $force_slot = "";
                if ($blen > 2 && substr($bare, $blen - 2, 2) eq "_h") {
                    $bare = substr($bare, 0, $blen - 2);
                    $force_slot = "PERLA_SLOT_HASH";
                } elsif ($blen > 2 && substr($bare, $blen - 2, 2) eq "_a") {
                    $bare = substr($bare, 0, $blen - 2);
                    $force_slot = "PERLA_SLOT_ARRAY";
                } elsif ($blen > 2 && substr($bare, $blen - 2, 2) eq "_s") {
                    $bare = substr($bare, 0, $blen - 2);
                    $force_slot = "PERLA_SLOT_SCALAR";
                }
                # Skip names with C-encoded special chars (e.g. _caret_O,
                # _rbrack_) — those are Perl special vars, not stashable.
                if (index($bare, "_caret_") >= 0 || index($bare, "_rbrack_") >= 0) {
                    $sui++;
                    next;
                }
                # Pad mode: our-vars are pad-managed (adopted/refilled against
                # their declared package). This sync reads the *module's* stash
                # ($mod_name) and would clobber the adopted container with the
                # module's empty slot — defeating the in-place pad refill. Skip.
                if ($cg->{"pad_mode"} == 1 && defined($cg->{"our_vars"})
                    && defined($cg->{"our_vars"}->{$bare})) {
                    $sui++;
                    next;
                }
                if (length($force_slot) > 0) {
                    # Sigil known from collision suffix: only check that one slot.
                    $sync_block = $sync_block . "    { PerlGlob *__sg = perla_glob_get(perla_stash_get_or_create(\"" . $mod_name . "\"), \"" . $bare . "\"); if (__sg && __sg->slots[" . $force_slot . "] && " . $svn . " != __sg->slots[" . $force_slot . "]) { if (" . $svn . ") strada_decref(" . $svn . "); " . $svn . " = __sg->slots[" . $force_slot . "]; strada_incref(" . $svn . "); } }\n";
                } else {
                    # Sigil unknown (legacy v_NAME without _h/_a/_s suffix): try
                    # HASH, ARRAY, SCALAR in order. The first populated slot wins.
                    # Hash is the most common for Exporter-imported data tables.
                    $sync_block = $sync_block . "    { PerlGlob *__sg = perla_glob_get(perla_stash_get_or_create(\"" . $mod_name . "\"), \"" . $bare . "\"); if (__sg) { StradaValue *__ss = NULL; if (__sg->slots[PERLA_SLOT_HASH]) __ss = __sg->slots[PERLA_SLOT_HASH]; else if (__sg->slots[PERLA_SLOT_ARRAY]) __ss = __sg->slots[PERLA_SLOT_ARRAY]; else if (__sg->slots[PERLA_SLOT_SCALAR]) __ss = __sg->slots[PERLA_SLOT_SCALAR]; if (__ss && " . $svn . " != __ss) { if (" . $svn . ") strada_decref(" . $svn . "); " . $svn . " = __ss; strada_incref(" . $svn . "); } } }\n";
                }
            }
            $sui++;
        }
        if (length($sync_block) > 0) {
            $code = replace_all($code, "    /* __PERLA_SYNC_HOOK__ */\n", "    /* sync Exporter-imported file-scope vars from stash */\n" . $sync_block);
        } else {
            $code = replace_all($code, "    /* __PERLA_SYNC_HOOK__ */\n", "");
        }
    }

    # Auto-declare __local_save_* variables used in the module but not in the
    # fixed extern preamble. Matching generate()'s scanner: any suffixed form
    # (length > 13) that the module references needs a local static so the
    # module's own `local $var` code compiles without extern-linker churn.
    my int $lsp_m = index($code, "__local_save_");
    my str $ls_decls = "";
    my hash %ls_seen = ();
    while ($lsp_m >= 0) {
        my int $lse_m = $lsp_m + 13;
        while ($lse_m < length($code)) {
            my str $lsc_m = substr($code, $lse_m, 1);
            if (($lsc_m ge "a" && $lsc_m le "z") || ($lsc_m ge "A" && $lsc_m le "Z") || ($lsc_m ge "0" && $lsc_m le "9") || $lsc_m eq "_") { $lse_m++; } else { last; }
        }
        my str $lsname_m = substr($code, $lsp_m, $lse_m - $lsp_m);
        if (length($lsname_m) > 13 && !exists($ls_seen{$lsname_m}) && index($code, "extern StradaValue *" . $lsname_m) < 0) {
            $ls_seen{$lsname_m} = 1;
            $ls_decls = $ls_decls . "static StradaValue *" . $lsname_m . " = NULL;\n";
        }
        $lsp_m = index($code, "__local_save_", $lse_m);
    }
    if (length($ls_decls) > 0) {
        my int $init_pos_ls = index($code, "void " . $init_name);
        if ($init_pos_ls > 0) {
            $code = substr($code, 0, $init_pos_ls) . "/* auto-declared local() save slots */\n" . $ls_decls . "\n" . substr($code, $init_pos_ls);
        }
    }

    # Embed dependency .o paths for the linker
    my scalar $pc_objects2 = $cg{"precompiled_objects"};
    if (defined($pc_objects2) && scalar(@{$pc_objects2}) > 0) {
        my str $obj_comment = "/* PERLA_LINK_OBJECTS:";
        my int $oi3 = 0;
        while ($oi3 < scalar(@{$pc_objects2})) {
            $obj_comment = $obj_comment . " " . $pc_objects2->[$oi3];
            $oi3++;
        }
        $obj_comment = $obj_comment . " */\n";
        $code = $obj_comment . $code;
    }

    return $code;
}

func _collect_sigil_collisions(scalar $cg, scalar $ast) void {
    _collect_sigil_collisions_stmts($cg, $ast->{"stmts"});
}

func _collect_sigil_collisions_stmts(scalar $cg, scalar $stmts) void {
    if (!defined($stmts)) { return; }
    my int $i = 0;
    while ($i < scalar(@{$stmts})) {
        my scalar $s = $stmts->[$i];
        if (defined($s)) {
            my int $t = $s->{"type"};
            # Recurse into sub bodies too: function-local `my @foo` /
            # `my $foo` collisions (e.g. Date::Manip::Base::_config_var_workdaybegend
            # which has both `my @beg` and `my $beg`) need the same
            # __h/__a mangling, otherwise the second `my` decrefs the
            # first variable and reuses its C name.
            if ($t == Perla::AST::N_SUB() || $t == Perla::AST::N_METHOD()
                || $t == Perla::AST::N_ANON_SUB()) {
                # Save file-scope collision state, recurse into sub body
                # with a fresh local view, then capture the sub's own
                # collisions and restore. This keeps function-local
                # `my @foo` / `my $foo` collisions (e.g.
                # Date::Manip::Base::_config_var_workdaybegend) mangled
                # within that sub, without leaking them into other scopes
                # where they'd cause false-positive mangling.
                # E.g. `sub make1 { my %info; ... }` shouldn't make
                # `my $info = make1()` in main route to the hash slot.
                my scalar $saved_seen = _perla_clone_hash_with_vals(\%__perla_seen_sigils);
                my scalar $saved_collisions = _perla_clone_hash(\%__perla_mangle_collisions);
                %__perla_seen_sigils = ();
                %__perla_mangle_collisions = ();
                if (defined($s->{"body"}) && defined($s->{"body"}->{"stmts"})) {
                    _collect_sigil_collisions_stmts($cg, $s->{"body"}->{"stmts"});
                } elsif (defined($s->{"body"})) {
                    _collect_sigil_collisions_stmts($cg, $s->{"body"});
                }
                # Capture sub-local collisions for named subs/methods
                # (anon subs are skipped — they fall back to file-scope only).
                if ($t == Perla::AST::N_SUB() || $t == Perla::AST::N_METHOD()) {
                    my str $sn = "";
                    if (defined($s->{"name"})) { $sn = $s->{"name"}; }
                    my str $spkg = "";
                    if (defined($s->{"package"})) { $spkg = $s->{"package"}; }
                    if (length($spkg) == 0 && defined($cg->{"pkg"})) { $spkg = $cg->{"pkg"}; }
                    if (length($sn) > 0 && scalar(keys(%__perla_mangle_collisions)) > 0) {
                        my str $qname = $spkg . "::" . $sn;
                        $__perla_sub_collisions{$qname} = _perla_clone_hash(\%__perla_mangle_collisions);
                    }
                }
                # Restore file-scope state
                _perla_restore_seen_sigils($saved_seen);
                _perla_restore_collisions_inplace($saved_collisions);
                $i++;
                next;
            }
            if ($t == Perla::AST::N_MY() || $t == Perla::AST::N_OUR() || $t == Perla::AST::N_STATE()) {
                if (defined($s->{"var"})) {
                    _perla_record_var_sigil($s->{"var"}->{"value"}, "" . $s->{"var"}->{"type"});
                }
                if (defined($s->{"vars"})) {
                    my int $vi = 0;
                    while ($vi < scalar(@{$s->{"vars"}})) {
                        _perla_record_var_sigil($s->{"vars"}->[$vi]->{"value"}, "" . $s->{"vars"}->[$vi]->{"type"});
                        $vi++;
                    }
                }
            }
            # Recurse into compound nodes with a body/stmts field.
            if (defined($s->{"stmts"})) {
                _collect_sigil_collisions_stmts($cg, $s->{"stmts"});
            }
            if (defined($s->{"body"}) && defined($s->{"body"}->{"stmts"})) {
                _collect_sigil_collisions_stmts($cg, $s->{"body"}->{"stmts"});
            }
            if (defined($s->{"then"}) && defined($s->{"then"}->{"stmts"})) {
                _collect_sigil_collisions_stmts($cg, $s->{"then"}->{"stmts"});
            }
            if (defined($s->{"else"}) && defined($s->{"else"}->{"stmts"})) {
                _collect_sigil_collisions_stmts($cg, $s->{"else"}->{"stmts"});
            }
            if (defined($s->{"init_my"})) {
                my scalar $im = $s->{"init_my"};
                if (defined($im->{"var"})) {
                    _perla_record_var_sigil($im->{"var"}->{"value"}, "" . $im->{"var"}->{"type"});
                }
                if (defined($im->{"vars"})) {
                    my int $ivi = 0;
                    while ($ivi < scalar(@{$im->{"vars"}})) {
                        _perla_record_var_sigil($im->{"vars"}->[$ivi]->{"value"}, "" . $im->{"vars"}->[$ivi]->{"type"});
                        $ivi++;
                    }
                }
            }
        }
        $i++;
    }
}

# --- Generate our variable (global) ---
# Build a plain variable-reference AST node (N_ARRAY_VAR / N_HASH_VAR /
# N_SCALAR_VAR) for the variable declared by an inner `my`/`our` decl node.
# Used to rewrite a chained `our @A = our @B = LIST` outer init into `@B`.
func _decl_var_ref(scalar $decl) scalar {
    my scalar $v = $decl->{"var"};
    my str $vt = "" . $v->{"type"};
    my scalar $ref = undef;
    if ($vt eq "ARRAY_VAR") {
        $ref = Perla::AST::node(Perla::AST::N_ARRAY_VAR());
    } elsif ($vt eq "HASH_VAR") {
        $ref = Perla::AST::node(Perla::AST::N_HASH_VAR());
    } else {
        $ref = Perla::AST::node(Perla::AST::N_SCALAR_VAR());
    }
    $ref->{"name"} = $v->{"value"};
    return $ref;
}

func _gen_our(scalar $cg, scalar $node) void {
    # Chained `our X = our Y = LIST` (e.g. Exporter's
    # `our @EXPORT = our @EXPORT_OK = qw(...)`). gen_expr can't yield a value
    # for an inner `our` declaration — it falls back to undef, so the outer
    # target came out empty. Emit the inner `our` decl as its own statement
    # first (which assigns it AND syncs its glob/stash slot), then rewrite the
    # outer init to reference the inner variable so the outer gets a proper
    # copy. Handles arbitrarily deep chains via the recursive gen_stmt call.
    if (defined($node->{"init"}) && defined($node->{"var"})
        && $node->{"init"}->{"type"} == Perla::AST::N_OUR()
        && defined($node->{"init"}->{"var"})) {
        my scalar $inner = $node->{"init"};
        Perla::CodeGen::Stmt::gen_stmt($cg, $inner);
        $node->{"init"} = _decl_var_ref($inner);
    }
    if (defined($node->{"var"})) {
        my str $vname = $node->{"var"}->{"value"};
        my str $vtype = $node->{"var"}->{"type"};
        # Pad mode: ensure this our-var is recorded in our_vars (scalar/array/
        # hash) so the pad write-back / in-place container refill fires for it.
        # collect_our_vars doesn't descend into the eval wrapper's `my $rv = do
        # { ... }` initializer where eval-body `our` decls live, but the decl is
        # always codegen'd here before the body's assignments run.
        if ($cg->{"pad_mode"} == 1 && length($vname) > 0) {
            $cg->{"our_vars"}->{$vname} = $vtype;
        }

        # Special case: our @ISA = (...) — register inheritance
        if ($vname eq "ISA" && $vtype eq "ARRAY_VAR" && defined($node->{"init"})) {
            my scalar $init = $node->{"init"};
            my str $pkg = $cg->{"pkg"};
            # Reset @Pkg::ISA before pushing — `our @ISA = (...)` is an
            # ASSIGNMENT, not an addition. Without reset, perla's pre-
            # populated @ISA for known modules (e.g., @B::ISA pre-seeded
            # with "Exporter" for Perl's B core module) would leak into
            # user packages that happen to share the name. With reset,
            # `package B; our @ISA = ("A")` correctly yields ["A"].
            ind($cg); emit($cg, "perla_isa_reset(\"" . $pkg . "\");\n");
            if ($init->{"type"} == Perla::AST::N_ANON_ARRAY() || $init->{"type"} == Perla::AST::N_QWORD()) {
                my scalar $elems = $init->{"elems"};
                my int $ei = 0;
                while ($ei < scalar(@{$elems})) {
                    my scalar $elem = $elems->[$ei];
                    my int $et = $elem->{"type"};
                    if ($et == Perla::AST::N_STR_LIT()) {
                        ind($cg); emit($cg, "perla_isa_push(\"" . $pkg . "\", \"" . $elem->{"value"} . "\");\n");
                    } elsif ($et == Perla::AST::N_INTERP_STR()) {
                        # If the interp string has no `$var`/`@var` refs,
                        # treat as literal. Otherwise evaluate at runtime
                        # so `our @ISA = ("File::Spec::$module")` pushes the
                        # interpolated parent name (e.g., "File::Spec::Unix")
                        # rather than the literal `"File::Spec::$module"`
                        # (which perla_isa_push would then try to load as a
                        # module named with a dollar sign).
                        if (has_perl_var($elem->{"value"}) == 0) {
                            ind($cg); emit($cg, "perla_isa_push(\"" . $pkg . "\", \"" . $elem->{"value"} . "\");\n");
                        } else {
                            ind($cg); emit($cg, "{ char *__ipn = strada_to_str(");
                            gen_expr($cg, $elem);
                            emit($cg, "); perla_isa_push(\"" . $pkg . "\", __ipn); free(__ipn); }\n");
                        }
                    } else {
                        ind($cg); emit($cg, "{ char *__ipn = strada_to_str(");
                        gen_expr($cg, $elem);
                        emit($cg, "); perla_isa_push(\"" . $pkg . "\", __ipn); free(__ipn); }\n");
                    }
                    $ei++;
                }
            } elsif ($init->{"type"} == Perla::AST::N_STR_LIT()) {
                # Single string: our @ISA = ('Parent')
                ind($cg); emit($cg, "perla_isa_push(\"" . $pkg . "\", \"" . $init->{"value"} . "\");\n");
            } elsif ($init->{"type"} == Perla::AST::N_INTERP_STR()) {
                if (has_perl_var($init->{"value"}) == 0) {
                    ind($cg); emit($cg, "perla_isa_push(\"" . $pkg . "\", \"" . $init->{"value"} . "\");\n");
                } else {
                    ind($cg); emit($cg, "{ char *__ipn = strada_to_str(");
                    gen_expr($cg, $init);
                    emit($cg, "); perla_isa_push(\"" . $pkg . "\", __ipn); free(__ipn); }\n");
                }
            }
            return;
        }

        # our vars are already declared as globals — just initialize
        if ($vtype eq "HASH_VAR") {
            # Hash vars: always init as hash
            if (defined($node->{"init"}) && $node->{"init"}->{"type"} == Perla::AST::N_ANON_ARRAY()) {
                # my %h = ("k" => "v", ...) — convert from flat array
                my scalar $init_elems = $node->{"init"}->{"elems"};
                if (defined($init_elems) && scalar(@{$init_elems}) > 0) {
                    # Force list context so the N_ANON_ARRAY yields the
                    # full flat array, not the scalar-context last elem.
                    ind($cg); emit($cg, c_var_h($vname) . " = strada_hash_from_flat_array(({ int __sav_wl = __perla_want_list; __perla_want_list = 1; StradaValue *__hi = ");
                    gen_expr($cg, $node->{"init"});
                    emit($cg, "; __perla_want_list = __sav_wl; __hi; }));\n");
                } else {
                    ind($cg); emit($cg, c_var_h($vname) . " = strada_new_hash();\n");
                }
                # Mirror into the stash so `%Pkg::NAME` reads see the value.
                # Without this, `our %h = (a => 1)` populates only v_h; the
                # stash HASH slot stays empty and `%Pkg::h` reads return undef.
                ind($cg); emit($cg, "{ PerlGlob *__og = perla_glob_get_or_create(perla_stash_get_or_create(\"" . $cg->{"pkg"} . "\"), \"" . $vname . "\"); ");
                emit($cg, "if (__og->slots[PERLA_SLOT_HASH]) strada_decref(__og->slots[PERLA_SLOT_HASH]); ");
                emit($cg, "__og->slots[PERLA_SLOT_HASH] = " . c_var_h($vname) . "; if (" . c_var_h($vname) . ") strada_incref(" . c_var_h($vname) . "); }\n");
            } elsif (defined($node->{"init"})) {
                # Init from non-anon-array expr (map, function call, @list,
                # explicit hashref, etc.). When the RHS is a flat key/value
                # array (e.g. `map { $_=>length $_ } @keys` or `@kv_pairs`),
                # we need to convert to a real hash. When it's already a
                # hash (e.g. `(%other_hash)` or a hashref deref), keep it.
                ind($cg); emit($cg, c_var_h($vname) . " = ({ int __sav_wl = __perla_want_list; __perla_want_list = 1; StradaValue *__hi = ");
                gen_expr($cg, $node->{"init"});
                emit($cg, "; __perla_want_list = __sav_wl; ");
                # `our %h = %g` is a COPY, not an alias — copy entries into a
                # fresh hash so a later `$h{k}=...` doesn't leak into %g (and
                # the chained `our %h = our %g = (...)` gives independent hashes).
                emit($cg, "(__hi && !STRADA_IS_TAGGED_INT(__hi) && __hi->type == STRADA_HASH) ? ({ StradaValue *__ohcp = strada_new_hash(); StradaHash *__ohdst = strada_deref_hash(__ohcp); StradaHash *__ohsrc = strada_deref_hash(__hi); StradaArray *__ohk = __ohsrc ? strada_hash_keys(__ohsrc) : (StradaArray*)NULL; if (__ohk) { for (size_t __ohi = 0; __ohi < __ohk->size; __ohi++) { StradaValue *__ohkk = __ohk->elements[__ohk->head + __ohi]; char *__ohks = strada_to_str(__ohkk); StradaValue *__ohv = strada_hash_get(__ohsrc, __ohks); if (__ohv) strada_incref(__ohv); strada_hash_set_take(__ohdst, __ohks, __ohv); free(__ohks); } strada_free_array(__ohk); } __ohcp; }) : strada_hash_from_flat_array(__hi); });\n");
                # Mirror into the stash so `%Pkg::NAME` reads see the value.
                ind($cg); emit($cg, "{ PerlGlob *__og = perla_glob_get_or_create(perla_stash_get_or_create(\"" . $cg->{"pkg"} . "\"), \"" . $vname . "\"); ");
                emit($cg, "if (__og->slots[PERLA_SLOT_HASH]) strada_decref(__og->slots[PERLA_SLOT_HASH]); ");
                emit($cg, "__og->slots[PERLA_SLOT_HASH] = " . c_var_h($vname) . "; if (" . c_var_h($vname) . ") strada_incref(" . c_var_h($vname) . "); }\n");
            } else {
                # `our %h;` with no init — adopt any value already in the
                # HASH slot (e.g. set by BEGIN), or create a fresh one.
                ind($cg); emit($cg, "{ PerlGlob *__og = perla_glob_get_or_create(perla_stash_get_or_create(\"" . $cg->{"pkg"} . "\"), \"" . $vname . "\"); ");
                emit($cg, "if (__og->slots[PERLA_SLOT_HASH]) { ");
                emit($cg, "  if (" . c_var_h($vname) . ") strada_decref(" . c_var_h($vname) . "); ");
                emit($cg, "  " . c_var_h($vname) . " = __og->slots[PERLA_SLOT_HASH]; ");
                emit($cg, "  strada_incref(" . c_var_h($vname) . "); ");
                emit($cg, "} else { ");
                emit($cg, "  if (!" . c_var_h($vname) . ") " . c_var_h($vname) . " = strada_new_hash(); ");
                emit($cg, "  __og->slots[PERLA_SLOT_HASH] = " . c_var_h($vname) . "; strada_incref(" . c_var_h($vname) . "); ");
                emit($cg, "} }\n");
            }
        } elsif ($vtype eq "ARRAY_VAR") {
            # Array vars: always init as array
            if (defined($node->{"init"})) {
                # Wrap scalar inits into a 1-element array — `our @arr =
                # ('hello')` parses the single-element parens as just
                # the scalar 'hello', so gen_expr produces a STRADA_STR.
                # Without the wrap, the slot would hold the string and
                # @arr reads return empty. Exporter::import's @EXPORT
                # check broke for `our @EXPORT = ('name')` (single-name
                # export lists) because of this. Already-array values
                # (literals, deref'd refs, returns from map/grep/sort)
                # pass through unchanged.
                # Copy the RHS elements into a FRESH array. Perl's `our @A = @B`
                # (and the chained `our @A = our @B = LIST`) is a copy, not an
                # alias — using __ai directly made @A and @B share one backbone
                # so `push @A` leaked into @B. Mirrors the `my @x = ...` copy.
                my int $__oa_t = $node->{"init"}->{"type"};
                my int $__oa_borrowed = 0;
                if ($__oa_t == Perla::AST::N_ARRAY_VAR()
                    || $__oa_t == Perla::AST::N_HASH_VAR()
                    || $__oa_t == Perla::AST::N_SCALAR_VAR()
                    || $__oa_t == Perla::AST::N_DEREF_ARRAY()
                    || $__oa_t == Perla::AST::N_DEREF_HASH()
                    || $__oa_t == Perla::AST::N_ASSIGN()
                    || $__oa_t == Perla::AST::N_MY()
                    || $__oa_t == Perla::AST::N_OUR()) {
                    $__oa_borrowed = 1;
                }
                ind($cg); emit($cg, c_var_a($vname) . " = ({ int __sav_wl = __perla_want_list; __perla_want_list = 1; StradaValue *__ai = ");
                gen_expr($cg, $node->{"init"});
                emit($cg, "; __perla_want_list = __sav_wl; ");
                emit($cg, "StradaValue *__oacp = strada_new_array(); StradaArray *__oacpv = strada_deref_array(__oacp); ");
                emit($cg, "if (__ai && !STRADA_IS_TAGGED_INT(__ai) && __ai->type == STRADA_ARRAY) { StradaArray *__oasrc = strada_deref_array(__ai); if (__oasrc) for (int __oai = 0; __oai < (int)strada_array_length(__oasrc); __oai++) { StradaValue *__oae = strada_array_get(__oasrc, __oai); if (__oae) strada_incref(__oae); strada_array_push_take(__oacpv, __oae); } } ");
                emit($cg, "else if (__ai && !STRADA_IS_TAGGED_INT(__ai) && __ai->type == STRADA_HASH && __ai->value.hv) { StradaArray *__oahk = strada_hash_keys(__ai->value.hv); if (__oahk) { for (size_t __oahi = 0; __oahi < __oahk->size; __oahi++) { StradaValue *__oahkk = __oahk->elements[__oahk->head + __oahi]; char *__oahks = strada_to_str(__oahkk); StradaValue *__oahv = strada_hash_get(__ai->value.hv, __oahks); free(__oahks); if (__oahkk) strada_incref(__oahkk); strada_array_push_take(__oacpv, __oahkk); if (__oahv) strada_incref(__oahv); strada_array_push_take(__oacpv, __oahv); } strada_free_array(__oahk); } } ");
                emit($cg, "else if (__ai) { strada_incref(__ai); strada_array_push_take(__oacpv, __ai); } ");
                if ($__oa_borrowed == 0) {
                    emit($cg, "if (__ai) strada_decref(__ai); ");
                }
                emit($cg, "__oacp; });\n");
                # Mirror into the package stash so `@Pkg::NAME` reads (which go
                # through perla_array_get on the stash) see the `our` value.
                # Without this, `use YAML qw(Load)` → Exporter::import → reads
                # @YAML::EXPORT from the stash and finds it empty, so `Load`
                # never gets exported into main.
                ind($cg); emit($cg, "{ PerlGlob *__og = perla_glob_get_or_create(perla_stash_get_or_create(\"" . $cg->{"pkg"} . "\"), \"" . $vname . "\"); ");
                emit($cg, "if (__og->slots[PERLA_SLOT_ARRAY]) strada_decref(__og->slots[PERLA_SLOT_ARRAY]); ");
                emit($cg, "__og->slots[PERLA_SLOT_ARRAY] = " . c_var_a($vname) . "; if (" . c_var_a($vname) . ") strada_incref(" . c_var_a($vname) . "); }\n");
            } else {
                # `our @a;` with no init — adopt any value already in the
                # ARRAY slot (e.g. set by BEGIN), or create a fresh one.
                ind($cg); emit($cg, "{ PerlGlob *__og = perla_glob_get_or_create(perla_stash_get_or_create(\"" . $cg->{"pkg"} . "\"), \"" . $vname . "\"); ");
                emit($cg, "if (__og->slots[PERLA_SLOT_ARRAY]) { ");
                emit($cg, "  if (" . c_var_a($vname) . ") strada_decref(" . c_var_a($vname) . "); ");
                emit($cg, "  " . c_var_a($vname) . " = __og->slots[PERLA_SLOT_ARRAY]; ");
                emit($cg, "  strada_incref(" . c_var_a($vname) . "); ");
                emit($cg, "} else { ");
                emit($cg, "  if (!" . c_var_a($vname) . ") " . c_var_a($vname) . " = strada_new_array(); ");
                emit($cg, "  __og->slots[PERLA_SLOT_ARRAY] = " . c_var_a($vname) . "; strada_incref(" . c_var_a($vname) . "); ");
                emit($cg, "} }\n");
            }
            # Register the array file-static so typeglob array-slot writes
            # (`*alias = \@source`) propagate into the v_X mirror. Without
            # this, `our @alias_for; *alias_for = \@source` updates the
            # stash slot but compiled reads of `@alias_for` (via v_alias_for)
            # see the empty array from declaration time.
            ind($cg); emit($cg, "perla_register_our_local_array(\"" . $cg->{"pkg"} . "\", \"" . $vname . "\", &" . c_var_a($vname) . ");\n");
        } else {
            if (defined($node->{"init"})) {
                ind($cg); emit($cg, c_var($vname) . " = ");
                gen_expr($cg, $node->{"init"});
                emit($cg, ";\n");
                # Mirror init expression into the package stash so
                # `$Pkg::NAME` reads see it.
                ind($cg); emit($cg, "{ PerlGlob *__og = perla_glob_get_or_create(perla_stash_get_or_create(\"" . $cg->{"pkg"} . "\"), \"" . $vname . "\"); ");
                emit($cg, "perla_glob_store(__og, PERLA_SLOT_SCALAR, " . c_var($vname) . "); }\n");
            } else {
                # `our $x;` with no init — adopt any value already in the
                # stash SCALAR slot (e.g. set by an earlier BEGIN block).
                # Without this, the unconditional sync below would clobber
                # the BEGIN's assignment with undef.
                ind($cg); emit($cg, "{ PerlGlob *__og = perla_glob_get_or_create(perla_stash_get_or_create(\"" . $cg->{"pkg"} . "\"), \"" . $vname . "\"); ");
                emit($cg, "if (__og->slots[PERLA_SLOT_SCALAR]) { ");
                emit($cg, "  if (" . c_var($vname) . ") strada_decref(" . c_var($vname) . "); ");
                emit($cg, "  " . c_var($vname) . " = __og->slots[PERLA_SLOT_SCALAR]; ");
                emit($cg, "  strada_incref(" . c_var($vname) . "); ");
                emit($cg, "} else { ");
                emit($cg, "  if (!" . c_var($vname) . ") " . c_var($vname) . " = strada_new_undef(); ");
                emit($cg, "  perla_glob_store(__og, PERLA_SLOT_SCALAR, " . c_var($vname) . "); ");
                emit($cg, "} }\n");
            }
            # Register the file-static for stash-set sync so external
            # writes (`$Pkg::var = X` from another package) propagate
            # into compiled subs that read `v_x` directly. Without this
            # registration, subs in pkg would see the declaration-time
            # value forever.
            ind($cg); emit($cg, "perla_register_our_local(\"" . $cg->{"pkg"} . "\", \"" . $vname . "\", &" . c_var($vname) . ");\n");
            # Pad mode: ensure this our-scalar is in our_vars so the
            # expression-context assignment write-back (Path B, ~line 9063)
            # fires. collect_our_vars misses `our $x` buried in a `my $rv = do
            # { ... }` initializer (the eval-body wrapper shape), but the decl is
            # always codegen'd here before the body's assignments run.
            if ($cg->{"pad_mode"} == 1) {
                $cg->{"our_vars"}->{$vname} = "SCALAR_VAR";
            }
        }
    }
    # Multi-var form: `our (@CONSTANTS, %TBL, $X);` — parser produces
    # node->{"vars"} as a list. Emit init + stash mirror for each so
    # cross-package reads (`%Pkg::TBL`) and Exporter's @EXPORT lookups
    # find the slot. Without this, `Locale::Codes::Constants`'s
    # `our (@CONSTANTS, %ALL_CODESETS);` populated only the file-scope
    # C static, leaving the stash empty — every Locale::Codes type
    # registration ("country", "currency", …) silently failed because
    # `$ALL_CODESETS{$type}` looked up the empty stash slot in the
    # importing package. (Bare `our %TBL;` already mirrors via the
    # single-var branch above.)
    if (defined($node->{"vars"})) {
        my int $mvi = 0;
        my array @mvs = @{$node->{"vars"}};
        while ($mvi < scalar(@mvs)) {
            my scalar $mv = $mvs[$mvi];
            my str $mvname = $mv->{"value"};
            my str $mvtype = $mv->{"type"};
            if ($mvtype eq "HASH_VAR") {
                ind($cg); emit($cg, "if (!" . c_var_h($mvname) . ") " . c_var_h($mvname) . " = strada_new_hash();\n");
                ind($cg); emit($cg, "{ PerlGlob *__og = perla_glob_get_or_create(perla_stash_get_or_create(\"" . $cg->{"pkg"} . "\"), \"" . $mvname . "\"); ");
                emit($cg, "if (__og->slots[PERLA_SLOT_HASH]) strada_decref(__og->slots[PERLA_SLOT_HASH]); ");
                emit($cg, "__og->slots[PERLA_SLOT_HASH] = " . c_var_h($mvname) . "; if (" . c_var_h($mvname) . ") strada_incref(" . c_var_h($mvname) . "); }\n");
            } elsif ($mvtype eq "ARRAY_VAR") {
                ind($cg); emit($cg, "if (!" . c_var_a($mvname) . ") " . c_var_a($mvname) . " = strada_new_array();\n");
                ind($cg); emit($cg, "{ PerlGlob *__og = perla_glob_get_or_create(perla_stash_get_or_create(\"" . $cg->{"pkg"} . "\"), \"" . $mvname . "\"); ");
                emit($cg, "if (__og->slots[PERLA_SLOT_ARRAY]) strada_decref(__og->slots[PERLA_SLOT_ARRAY]); ");
                emit($cg, "__og->slots[PERLA_SLOT_ARRAY] = " . c_var_a($mvname) . "; if (" . c_var_a($mvname) . ") strada_incref(" . c_var_a($mvname) . "); }\n");
            } else {
                ind($cg); emit($cg, "if (!" . c_var($mvname) . ") " . c_var($mvname) . " = strada_new_undef();\n");
                ind($cg); emit($cg, "{ PerlGlob *__og = perla_glob_get_or_create(perla_stash_get_or_create(\"" . $cg->{"pkg"} . "\"), \"" . $mvname . "\"); ");
                emit($cg, "perla_glob_store(__og, PERLA_SLOT_SCALAR, " . c_var($mvname) . "); }\n");
            }
            $mvi++;
        }
        # `our (\$p, \$q) = LIST` — distribute init values across the
        # declared vars. Without this, `our (\$p, \$q) = (10, 20)`
        # declared the vars but left them at their pre-init values.
        # Evaluate init in list context, then assign each var from
        # index N of the result array.
        if (defined($node->{"init"})) {
            ind($cg); emit($cg, "{ int __sav_wl_ml = __perla_want_list; __perla_want_list = 1; StradaValue *__ml_rhs = ");
            gen_expr($cg, $node->{"init"});
            emit($cg, "; __perla_want_list = __sav_wl_ml; StradaArray *__ml_av = strada_deref_array(__ml_rhs); ");
            my int $oli = 0;
            while ($oli < scalar(@mvs)) {
                my scalar $omv = $mvs[$oli];
                my str $omn = $omv->{"value"};
                my str $omt = $omv->{"type"};
                if ($omt eq "SCALAR_VAR") {
                    my str $ocn = c_var($omn);
                    emit($cg, "if (__ml_av && " . $oli . " < (int)__ml_av->size) { ");
                    emit($cg, "  StradaValue *__mle = __ml_av->elements[__ml_av->head + " . $oli . "]; ");
                    emit($cg, "  if (__mle) strada_incref(__mle); ");
                    emit($cg, "  if (" . $ocn . ") strada_decref(" . $ocn . "); ");
                    emit($cg, "  " . $ocn . " = __mle ? __mle : strada_new_undef(); ");
                    emit($cg, "  { PerlGlob *__og2 = perla_glob_get_or_create(perla_stash_get_or_create(\"" . $cg->{"pkg"} . "\"), \"" . $omn . "\"); ");
                    emit($cg, "    perla_glob_store(__og2, PERLA_SLOT_SCALAR, " . $ocn . "); } } ");
                }
                $oli = $oli + 1;
            }
            emit($cg, "if (__ml_rhs) strada_decref(__ml_rhs); }\n");
        }
    }
}

# --- C name for a sub from qualified name ---
func sub_cname_q(str $qname) str {
    return "perla_sub_" . replace_all($qname, "::", "_");
}

# --- C name for a sub ---
func _sub_cname(scalar $cg, str $name) str {
    my str $pkg = $cg->{"pkg"};
    return "perla_sub_" . replace_all($pkg, "::", "_") . "_" . $name;
}

# --- Check if variable is file-scope (already declared as static) ---
func _is_file_scope(scalar $cg, str $vname) int {
    if (defined($cg->{"file_scope_vars"}) && $cg->{"in_main"} == 1) {
        return exists($cg->{"file_scope_vars"}->{$vname});
    }
    return 0;
}

# --- Variable declaration prefix: "StradaValue *" or "" for file-scope/already-declared vars ---
# Legacy signature (scalar default). Prefer _my_prefix_vt when the sigil
# is known so hash/array mangling tracks under the correct C name.
func _my_prefix(scalar $cg, str $vname) str {
    return _my_prefix_vt($cg, "SCALAR_VAR", $vname);
}

func _my_prefix_vt(scalar $cg, str $vtype, str $vname) str {
    # `use warnings;` "my X masks earlier declaration in same scope" must
    # fire BEFORE the file-scope early-return below — file-scope `my`
    # decls compile to static slots that we WANT to flag on redeclare.
    # Check same_scope_decls first; downstream code still gets to suppress
    # the C-level re-declaration via the standard declared_vars guard.
    if (defined($cg->{"same_scope_decls"})) {
        my str $__ssd_cname = c_var_for_vtype($vtype, $vname);
        if (defined($cg->{"same_scope_decls"}->{$__ssd_cname})
            && defined($cg->{"use_warnings"}) && $cg->{"use_warnings"} == 1) {
            # Perl's "my X masks earlier declaration in same scope" is a
            # compile-time warning, so emit to STDERR from perla itself
            # rather than via a runtime call in the generated C (which
            # would only fire when the enclosing sub actually runs).
            my str $__mm_sigil = "\$";
            if ($vtype eq "ARRAY_VAR") { $__mm_sigil = "@"; }
            elsif ($vtype eq "HASH_VAR") { $__mm_sigil = "%"; }
            my int $__mm_line = 0;
            if (defined($cg->{"current_my_line"})) {
                $__mm_line = $cg->{"current_my_line"} + 0;
            }
            my str $__mm_file = "" . $cg->{"filename"};
            if (length($__mm_file) == 0) { $__mm_file = "-"; }
            my str $__mm_varname = $__mm_sigil . $vname;
            if ($__mm_line == 0) {
                # Last-statement-of-sub gen_expr-safe path doesn't go
                # through _gen_my; fall back to whatever node we have.
                $__mm_line = $cg->{"current_my_line"} + 0;
            }
            say(STDERR, "\"my\" variable " . $__mm_varname . " masks earlier declaration in same scope at " . $__mm_file . " line " . $__mm_line . ".");
        }
        $cg->{"same_scope_decls"}->{$__ssd_cname} = 1;
    }
    if (_is_file_scope($cg, $vname) == 1) {
        return "";
    }
    # Track declared vars per function to avoid C redefinition errors.
    # Key by sigil-aware C name so `%foo` and `$foo` in the same scope
    # don't fight over the same `v_foo` slot.
    # Use defined() (not exists()): the foreach cleanup at end-of-loop
    # sets declared_vars[iter] = undef rather than deleting the key,
    # which left exists() returning true. A later `my %X` after a
    # `for my $X` then suppressed the local declaration and routed
    # the my-decl through the file-scope-assign branch (the bug from
    # `my %s; $s{$_}++ for ...` inside a foreach not resetting between
    # iterations — see /tmp/r2.pl). All other declared_vars readers
    # in this file already use defined() — this aligns the contract.
    my str $cname = c_var_for_vtype($vtype, $vname);
    if (defined($cg->{"declared_vars"}->{$cname})) {
        return "";
    }
    if (defined($cg->{"capture_vars"})) {
        my str $cv_check = "" . $cg->{"capture_vars"}->{$cname};
        if (length($cv_check) > 0) {
            return "";
        }
    }
    $cg->{"declared_vars"}->{$cname} = 1;
    return "StradaValue *";
}

# --- strict 'vars' check ---
# When `use strict;` (or `use strict 'vars';`) is in scope, reading or
# writing an undeclared variable is a compile-time error in real Perl.
# perla now enforces the check at codegen time. The check is called
# from the N_SCALAR_VAR / N_ARRAY_VAR / N_HASH_VAR emit sites BEFORE
# falling through to the c_var path so we abort with a Perl-style
# error message that the user expects.
#
# Exempted from the check (return true = "declared / exempt"):
#   - any name containing "::" (package-qualified)
#   - perl built-in special names (ARGV, ENV, INC, SIG, ARGVOUT,
#     STDIN/STDOUT/STDERR/__FILE__/__LINE__/__PACKAGE__/__SUB__, etc.)
#     — these are tracked at file scope by perla startup
#   - any name found in declared_vars, our_vars, file_scope_vars,
#     or capture_vars
#   - single-char punctuation names ($_, @_, $!, $@, $1-$9 etc) — these
#     all branch off earlier in the var emit; if any leaks through it
#     would be an internal bug. Allow them here so we don't fire the
#     check on weird codegen paths.
func _strict_check_var(scalar $cg, str $sigil, str $name, int $line) void {
    if (!defined($cg->{"strict_vars"}) || $cg->{"strict_vars"} != 1) {
        return;
    }
    if (length($name) == 0) { return; }
    # Package-qualified: $Pkg::name / @Pkg::names etc.
    if (index($name, "::") > 0) { return; }
    # Single-character non-alpha — punctuation special var.
    if (length($name) == 1) {
        my int $c0 = char_at($name, 0);
        my int $is_alpha = (($c0 >= 65 && $c0 <= 90) || ($c0 >= 97 && $c0 <= 122) || $c0 == 95) ? 1 : 0;
        if ($is_alpha == 0) { return; }
    }
    # Caret special vars ($^O, $^X, $^W, $^V, etc) — name is "^X" form
    # from the lexer. Also the braced form ${^NAME} (${^TAINT},
    # ${^GLOBAL_PHASE}, etc.) which the lexer emits as "^TAINT" etc.
    # All caret-prefixed names are Perl built-ins, never need declaration.
    if (length($name) >= 2 && char_at($name, 0) == 94) { return; }  # '^'
    # All-digit names ($1..$9, $10, etc) — capture vars.
    my int $__sc_all_digit = 1;
    my int $__sc_ci = 0;
    while ($__sc_ci < length($name)) {
        my int $__sc_c = char_at($name, $__sc_ci);
        if ($__sc_c < 48 || $__sc_c > 57) { $__sc_all_digit = 0; }
        $__sc_ci++;
    }
    if ($__sc_all_digit == 1) { return; }
    # Perl built-ins that should always be in scope. ARGV/ENV/INC/SIG
    # are at the array+hash sigil level (so a bare `$ENV{...}` form
    # works for hash). __PACKAGE__/__FILE__/__LINE__/__SUB__ are also
    # exempt though they read more like keyword tokens.
    if ($name eq "ARGV" || $name eq "ARGVOUT" || $name eq "ENV"
        || $name eq "INC" || $name eq "SIG" || $name eq "STDIN"
        || $name eq "STDOUT" || $name eq "STDERR" || $name eq "DATA"
        || $name eq "ARGV_PERL" || $name eq "__PACKAGE__"
        || $name eq "__FILE__" || $name eq "__LINE__"
        || $name eq "__SUB__" || $name eq "PERL_VERSION"
        || $name eq "OS_ERROR" || $name eq "SUBSCRIPT_SEPARATOR"
        || $name eq "OUTPUT_RECORD_SEPARATOR"
        || $name eq "INPUT_RECORD_SEPARATOR"
        || $name eq "LIST_SEPARATOR"
        || $name eq "OUTPUT_FIELD_SEPARATOR"
        || $name eq "PROGRAM_NAME"
        # %Config (from `use Config`) and %ENV-like external-population
        # globals are runtime-imported via Exporter — the compile-time
        # tracker doesn't see them. Exempt the standard ones so
        # `$Config{KEY}` doesn't trip strict 'vars'.
        || $name eq "Config") {
        return;
    }
    # `$a` and `$b` are special — sort/reduce block comparator vars.
    # Real Perl exempts them via strict.pm. Match that.
    if ($name eq "a" || $name eq "b") { return; }
    # `$_` / `@_` / `%_` are the implicit topic and arg array. Real Perl
    # treats these as always-in-scope (effectively predeclared at file
    # scope) and never errors on them under strict 'vars'. My single-char
    # punctuation skip earlier doesn't cover `_` (underscore is alpha)
    # so handle it explicitly here.
    if ($name eq "_") { return; }
    # Look up the declaration. The codegen scope-tracks under C-mangled
    # names — same mangling as c_var/_a/_h emits, so build the key with
    # c_var_for_vtype.
    my str $__sc_vtype = "SCALAR_VAR";
    if ($sigil eq "@") { $__sc_vtype = "ARRAY_VAR"; }
    elsif ($sigil eq "%") { $__sc_vtype = "HASH_VAR"; }
    my str $__sc_cname = c_var_for_vtype($__sc_vtype, $name);
    if (defined($cg->{"declared_vars"}) && defined($cg->{"declared_vars"}->{$__sc_cname})) {
        return;
    }
    if (defined($cg->{"capture_vars"})) {
        my str $__sc_cv = "" . $cg->{"capture_vars"}->{$__sc_cname};
        if (length($__sc_cv) > 0) { return; }
        my str $__sc_cv2 = "" . $cg->{"capture_vars"}->{$name};
        if (length($__sc_cv2) > 0) { return; }
    }
    if (defined($cg->{"state_vars"}) && defined($cg->{"state_vars"}->{$name})) {
        return;
    }
    if (defined($cg->{"our_vars"}) && defined($cg->{"our_vars"}->{$name})) {
        return;
    }
    # file_scope_vars is populated by collect_file_scope_vars_from_stmts.
    # Real `my $X` declarations get type "SCALAR_VAR" / "ARRAY_VAR" /
    # "HASH_VAR"; bare assignments at file scope (`$x = 42;` without a
    # prior `my`) get type "IMPLICIT_GLOBAL" — those are exactly the
    # ones strict 'vars' is supposed to flag.
    if (defined($cg->{"file_scope_vars"}) && defined($cg->{"file_scope_vars"}->{$name})) {
        my str $__sc_fst = "" . $cg->{"file_scope_vars"}->{$name};
        if ($__sc_fst ne "IMPLICIT_GLOBAL") { return; }
    }
    # `our` declarations sometimes get tracked in the C-mangled form
    # (v_foo / v_foo__a / v_foo__h) and sometimes in the Perl-name form.
    # Check the c_var-mangled key in our_vars too.
    if (defined($cg->{"our_vars"}) && defined($cg->{"our_vars"}->{$__sc_cname})) {
        return;
    }
    # File-wide `my` lexical: declared via `my` in SOME scope of this file
    # (collected into all_my_lexicals). perla's per-sub declared_vars is reset
    # entering each sub, so a nested sub / sort / map / grep block referencing
    # an enclosing-scope lexical would otherwise false-positive. Real Perl makes
    # enclosing lexicals visible at compile time, so treat any file-declared
    # `my` name as in scope.
    if (defined($cg->{"all_my_lexicals"}) && defined($cg->{"all_my_lexicals"}->{$name})) {
        return;
    }
    # `local $x = expr;` auto-declares the package var in real Perl, but
    # only under strict if it was already declared. We don't track that
    # specifically — defer to file/our scope.
    # Not declared — emit the canonical Perl strict error.
    my str $__sc_loc = "";
    if ($line > 0) {
        $__sc_loc = " at " . $cg->{"src_file"} . " line " . $line . ".";
    }
    die("Global symbol \"" . $sigil . $name . "\" requires explicit package name (did you forget to declare \"my " . $sigil . $name . "\"?)" . $__sc_loc);
}

# --- Emit helpers ---

# Classify an expression node as "borrowed" (the caller does not own a
# fresh ref — gen_expr returns a pointer aliasing a longer-lived value)
# or "owned" (gen_expr returns a freshly-allocated value with rc=1 that
# the caller must release).
#
# Borrowed: scalar/array/hash variables, array element subscripts.
# Owned: everything else (literals, refs, anon constructors, calls,
# concats, regex results, hash element fetches via hv_fetch_owned, etc).
#
# Used by codegen sites that capture gen_expr result into a temp and
# need to decide whether to decref the temp. Conservative: when in doubt,
# return 0 (owned) so we decref; double-frees only happen if we'd
# decref a borrowed value, which is the dangerous direction.
func expr_is_borrowed(scalar $node) int {
    if (!defined($node)) { return 0; }
    my int $t = $node->{"type"};
    if ($t == Perla::AST::N_SCALAR_VAR()) {
        # Match/capture vars ($1..$9, $&, $`, $', $+) read as OWNED values —
        # strada_capture_var / strada_prematch / strada_postmatch /
        # strada_last_paren_match all incref before returning. Treating them
        # as borrowed makes consumers either over-incref (incref-to-keep) or
        # skip the release (use-without-cleanup); both leak one ref per read
        # (e.g. `$sum += $1` in a loop). All other scalar vars are borrowed.
        if (defined($node->{"name"})) {
            my str $cvn = "" . $node->{"name"};
            if (length($cvn) == 1
                && (($cvn ge "1" && $cvn le "9") || $cvn eq "&" || $cvn eq "\`" || $cvn eq "'" || $cvn eq "+")) {
                return 0;
            }
        }
        return 1;
    }
    if ($t == Perla::AST::N_ARRAY_VAR()) { return 1; }
    if ($t == Perla::AST::N_HASH_VAR()) { return 1; }
    if ($t == Perla::AST::N_ARRAY_ELEM()) { return 1; }
    # Deref of a reference produces a borrowed view of the inner value.
    # The deref codegen returns `__dr->value.rv` without incref, so
    # callers must NOT decref afterward — otherwise the inner ARRAY/
    # HASH/SCALAR gets freed underneath the owning REF, dangling the
    # pointer for any subsequent access. Caused recursive `find_r`
    # crashes where `if (\$idx >= @\$arr)` decref'd \$arr's inner array.
    if ($t == Perla::AST::N_DEREF_ARRAY()) { return 1; }
    if ($t == Perla::AST::N_DEREF_HASH()) { return 1; }
    if ($t == Perla::AST::N_DEREF_SCALAR()) { return 1; }
    # Assignment returns the RHS value as the expression result. If
    # the RHS is itself borrowed (a sub-local `my` scalar), then the
    # whole assignment is borrowed. Without this, `sub { my $v = $_[1];
    # $h{$_[0]} = $v; }` as a closure's implicit-return-last-expr
    # path skipped the incref of __ret_val — the subsequent sub-local
    # decref of $v made the caller's received pointer dangle, and the
    # hash slot's value (which strada_hash_set incref'd from the same
    # storage) read 0 on subsequent fetches because the underlying
    # value had been pool-recycled.
    if ($t == Perla::AST::N_ASSIGN() && defined($node->{"value"})) {
        return expr_is_borrowed($node->{"value"});
    }
    # bless($x, "C") returns its first argument unchanged (perla_bless does not
    # incref — same in-place semantics as strada_bless). The bless result's
    # borrowed-ness therefore mirrors its first arg's. Without this, any caller
    # that uses expr_is_borrowed to decide cleanup would unconditionally treat
    # `bless($var, "C")` as owned and decref it, killing $var's only ref ->
    # premature DESTROY / use-after-free. A handful of call sites (e.g. the
    # named-sub return path) already special-case bless explicitly; recursing
    # here makes those redundant but harmless and covers every other caller.
    if ($t == Perla::AST::N_CALL() && defined($node->{"name"})) {
        my str $__bname = $node->{"name"};
        if ($__bname eq "bless" || $__bname eq "CORE::bless") {
            my scalar $__bargs = $node->{"args"};
            if (defined($__bargs) && scalar(@{$__bargs}) >= 1) {
                return expr_is_borrowed($__bargs->[0]);
            }
            return 0;
        }
    }
    # Ternary `COND ? A : B` yields one of its branches. If EITHER branch is
    # borrowed (a sub-local `my` scalar, a deref view, …), the whole result may
    # be borrowed, so callers that decide incref-on-keep (notably the `return`
    # path) must treat it as borrowed and incref — otherwise sub-exit cleanup
    # decrefs the local and the returned pointer dangles. Concrete victim:
    # Type::Tiny::inline_check's `return @r == 1 ? $r : "($r)"` returned a
    # freed string, so Eval::TypeTiny compiled a garbled
    # `<freed>lar::Util::blessed(...)` check ("Scalar" → garbage) and DBIx::Class
    # type checks died "Undefined subroutine &lar::Util::blessed".
    if ($t == Perla::AST::N_TERNARY()) {
        if (defined($node->{"then"}) && expr_is_borrowed($node->{"then"}) == 1) { return 1; }
        if (defined($node->{"else"}) && expr_is_borrowed($node->{"else"}) == 1) { return 1; }
        return 0;
    }
    return 0;
}

# === Central operand capture/release (refcount discipline) ============
# perla's integer/builtin codegens historically captured operand SVs and
# managed their refcounts INLINE, per op — easy to forget, and the source
# of the UV (heap-integer) leaks. These helpers centralize the ONE
# error-prone decision: an OWNED operand (a fresh temp — literal, call
# result, arithmetic) must be decref'd after use; a BORROWED operand (a
# variable / deref view) must not. The body between capture and release
# uses the temp and yields an INDEPENDENT result (incref-on-return or a
# fresh value), so it never touches operand refcounts itself.
#
# Usage (the op body must compute an independent/owned result):
#   my array @sc = ();
#   emit($cg, "({ ");
#   op_capture($cg, \@sc, "__a", $node, 1);     # 1 = evaluate in scalar ctx
#   emit($cg, "StradaValue *__res = "); ...body using __a...; emit($cg, "; ");
#   op_release($cg, \@sc);
#   emit($cg, "__res; })");
func op_capture(scalar $cg, scalar $rec, str $cvar, scalar $node, int $scalar_ctx) void {
    emit($cg, "StradaValue *" . $cvar . " = ");
    if ($scalar_ctx == 1) {
        emit($cg, "({ int __ocwl = __perla_want_list; __perla_want_list = 0; StradaValue *__ocv = ");
        gen_expr($cg, $node);
        emit($cg, "; __perla_want_list = __ocwl; __ocv; })");
    } else {
        gen_expr($cg, $node);
    }
    emit($cg, "; ");
    my int $owned = 0;
    if (expr_is_borrowed($node) == 0) { $owned = 1; }
    push(@{$rec}, { "cvar" => $cvar, "owned" => $owned });
}

# Capture a raw C expression (e.g. perla_dollar_underscore) as a BORROWED
# operand — never released. Used for the no-arg `$_` default.
func op_capture_c(scalar $cg, scalar $rec, str $cvar, str $cexpr) void {
    emit($cg, "StradaValue *" . $cvar . " = " . $cexpr . "; ");
    push(@{$rec}, { "cvar" => $cvar, "owned" => 0 });
}

# Emit `if (cv) strada_decref(cv);` for each OWNED captured operand.
func op_release(scalar $cg, scalar $rec) void {
    my int $i = 0;
    while ($i < scalar(@{$rec})) {
        my scalar $e = $rec->[$i];
        if ($e->{"owned"} == 1) {
            emit($cg, "if (" . $e->{"cvar"} . ") strada_decref(" . $e->{"cvar"} . "); ");
        }
        $i = $i + 1;
    }
}

func emit(scalar $cg, str $s) void {
    sb_append($cg->{"sb"}, $s);
}

func ind(scalar $cg) void {
    my int $i = 0;
    while ($i < $cg->{"indent"}) {
        sb_append($cg->{"sb"}, "    ");
        $i++;
    }
}

func tmp_name(scalar $cg) str {
    $cg->{"tmp_count"} = $cg->{"tmp_count"} + 1;
    return "__perla_tmp_" . $cg->{"tmp_count"};
}

# Recursively scan a node (or list of nodes) for any N_SUB occurrence,
# named or anonymous. Returns 1 if found, 0 otherwise. Used by the
# bare-block DESTROY-at-exit guard: when a sub is defined inside the
# block (even nested in an expression like `*Pkg::name = sub {...}`),
# an enclosing closure may have captured a block-local slot via &v_X,
# and decref+NULL'ing those slots at block exit would corrupt it.
# Returns 1 if any N_SUB / N_ANON_SUB inside `$node` references the
# (already-renamed) variable name `$vname` via N_SCALAR_VAR /
# N_ARRAY_VAR / N_HASH_VAR. Used by the bare-block cleanup logic so
# we only skip block-exit decref for vars actually captured by an
# inner sub (the conservative "any sub at all" rule was leaving
# blessed objects alive past their block when the sub never
# touched the var — e.g. `{ package X; sub DESTROY {...}; my $o = ...; }`
# where DESTROY operates on $_[0] and doesn't refer to $o, but
# perla still pinned $o until program-exit global destruction).
func _sub_in_node_references_var(scalar $node, str $vname) int {
    if (!defined($node)) { return 0; }
    if (ref($node) eq "ARRAY") {
        my int $__svi = 0;
        while ($__svi < scalar(@{$node})) {
            if (_sub_in_node_references_var($node->[$__svi], $vname) == 1) { return 1; }
            $__svi = $__svi + 1;
        }
        return 0;
    }
    if (ref($node) ne "HASH") { return 0; }
    if (!defined($node->{"type"})) { return 0; }
    my int $__svt = $node->{"type"};
    if ($__svt == Perla::AST::N_SUB() || $__svt == Perla::AST::N_ANON_SUB()) {
        # Recurse into the sub body specifically and check for refs.
        my scalar $__body = $node->{"body"};
        if (defined($__body) && _node_references_var($__body, $vname) == 1) { return 1; }
        return 0;
    }
    # Not a sub — recurse through child keys looking for nested subs.
    my array @__svc_keys = ("init", "value", "expr", "left", "right", "cond",
                            "then", "else", "body", "var", "vars", "stmts",
                            "args", "key", "index", "hash", "array", "callee",
                            "object", "method", "target", "list", "block",
                            "coderef", "operand", "lhs", "rhs", "items",
                            "elements", "elems", "pairs", "keys_list",
                            "indices", "init_block", "update", "test", "iter",
                            "filter", "branches", "cases", "when", "default",
                            "captures", "step", "ref");
    my int $__svki = 0;
    while ($__svki < scalar(@__svc_keys)) {
        my str $__svck = $__svc_keys[$__svki];
        if (defined($node->{$__svck})) {
            if (_sub_in_node_references_var($node->{$__svck}, $vname) == 1) { return 1; }
        }
        $__svki = $__svki + 1;
    }
    return 0;
}

# Returns 1 if `$node` directly references variable `$vname` via any
# of the var-bearing AST nodes (N_SCALAR_VAR / N_ARRAY_VAR / N_HASH_VAR).
# Used by _sub_in_node_references_var to check sub bodies for captures.
func _node_references_var(scalar $node, str $vname) int {
    if (!defined($node)) { return 0; }
    if (ref($node) eq "ARRAY") {
        my int $__rvi = 0;
        while ($__rvi < scalar(@{$node})) {
            if (_node_references_var($node->[$__rvi], $vname) == 1) { return 1; }
            $__rvi = $__rvi + 1;
        }
        return 0;
    }
    if (ref($node) ne "HASH") { return 0; }
    if (!defined($node->{"type"})) { return 0; }
    my int $__rvt = $node->{"type"};
    if ($__rvt == Perla::AST::N_SCALAR_VAR()
        || $__rvt == Perla::AST::N_ARRAY_VAR()
        || $__rvt == Perla::AST::N_HASH_VAR()) {
        my str $__rvn = "" . (defined($node->{"name"}) ? $node->{"name"} : "");
        if ($__rvn eq $vname) { return 1; }
    }
    my array @__rvc_keys = ("init", "value", "expr", "left", "right", "cond",
                            "then", "else", "body", "var", "vars", "stmts",
                            "args", "key", "index", "hash", "array", "callee",
                            "object", "method", "target", "list", "block",
                            "coderef", "operand", "lhs", "rhs", "items",
                            "elements", "elems", "pairs", "keys_list",
                            "indices", "init_block", "update", "test", "iter",
                            "filter", "branches", "cases", "when", "default",
                            "captures", "step", "ref");
    my int $__rvki = 0;
    while ($__rvki < scalar(@__rvc_keys)) {
        my str $__rvck = $__rvc_keys[$__rvki];
        if (defined($node->{$__rvck})) {
            if (_node_references_var($node->{$__rvck}, $vname) == 1) { return 1; }
        }
        $__rvki = $__rvki + 1;
    }
    return 0;
}

func _node_contains_sub(scalar $node) int {
    if (!defined($node)) { return 0; }
    if (ref($node) eq "ARRAY") {
        my int $__nci = 0;
        while ($__nci < scalar(@{$node})) {
            if (_node_contains_sub($node->[$__nci]) == 1) { return 1; }
            $__nci = $__nci + 1;
        }
        return 0;
    }
    if (ref($node) ne "HASH") { return 0; }
    if (!defined($node->{"type"})) { return 0; }
    my int $__nct = $node->{"type"};
    if ($__nct == Perla::AST::N_SUB() || $__nct == Perla::AST::N_ANON_SUB()) {
        return 1;
    }
    my array @__nc_keys = ("init", "value", "expr", "left", "right", "cond",
                          "then", "else", "body", "var", "vars", "stmts",
                          "args", "key", "index", "hash", "array", "callee",
                          "object", "method", "target", "list", "block",
                          "coderef", "operand", "lhs", "rhs", "items",
                          "elements", "elems", "pairs", "keys_list",
                          "indices", "init_block", "update", "test", "iter",
                          "filter", "branches", "cases", "when", "default",
                          "captures", "step", "ref");
    my int $__ncki = 0;
    while ($__ncki < scalar(@__nc_keys)) {
        my str $__nck = $__nc_keys[$__ncki];
        if (defined($node->{$__nck})) {
            if (_node_contains_sub($node->{$__nck}) == 1) { return 1; }
        }
        $__ncki = $__ncki + 1;
    }
    return 0;
}

# Returns 1 if NAME is a plain Perl identifier ([A-Za-z_][A-Za-z0-9_:]*),
# 0 for Perl special variable names (`,`, `/`, `|`, `\`, etc.) that must
# not be auto-declared as C statics.

# Generate autovivifying hash access for lvalue context
func _gen_autoviv_hash(scalar $cg, scalar $node) void {
    my int $t = $node->{"type"};
    if ($t == Perla::AST::N_HASH_ELEM()) {
        my scalar $hkey = $node->{"key"};
        my int $hkey_type = $hkey->{"type"};
        my int $is_lit = 0;
        if ($hkey_type == Perla::AST::N_STR_LIT()) { $is_lit = 1; }
        if ($hkey_type == Perla::AST::N_INTERP_STR() && has_perl_var($hkey->{"value"}) == 0) { $is_lit = 1; }

        if ($is_lit == 1) {
            emit($cg, "strada_hv_autoviv(");
            my scalar $inner = $node->{"hash"};
            my int $inner_type = $inner->{"type"};

            if ($inner_type == 18 || $inner_type == 41) {
                _gen_autoviv_hash($cg, $inner);
            } elsif ($inner_type == Perla::AST::N_SCALAR_VAR()
                && defined($inner->{"name"}) && index($inner->{"name"}, "::") > 0) {
                my array @ihpn = _split_pkg_qual_name($inner);
                emit($cg, "perla_hash_get(\"" . $ihpn[0] . "\", \"" . $ihpn[1] . "\")");
            } elsif ($inner_type == Perla::AST::N_SCALAR_VAR()
                && defined($inner->{"name"}) && length($inner->{"name"}) > 0
                && index($inner->{"name"}, "::") < 0 && $inner->{"name"} ne "_") {
                # $foo{key} autoviv path: read from %foo slot, not $foo.
                emit($cg, c_var_h($inner->{"name"}));
            } else {
                gen_expr($cg, $inner);
            }
            emit($cg, ", \"" . Perla::CodeGen::Escape::str_node_to_c($hkey) . "\")");
        } else {
            emit($cg, "({ char *__ak = strada_to_str(");
            gen_expr($cg, $hkey);
            emit($cg, "); StradaValue *__av = strada_hv_autoviv(");
            my scalar $inner2 = $node->{"hash"};
            my int $inner2_type = $inner2->{"type"};
            if ($inner2_type == 18 || $inner2_type == 41) {
                _gen_autoviv_hash($cg, $inner2);
            } elsif ($inner2_type == Perla::AST::N_SCALAR_VAR()
                && defined($inner2->{"name"}) && index($inner2->{"name"}, "::") > 0) {
                my array @ih2pn = _split_pkg_qual_name($inner2);
                emit($cg, "perla_hash_get(\"" . $ih2pn[0] . "\", \"" . $ih2pn[1] . "\")");
            } elsif ($inner2_type == Perla::AST::N_SCALAR_VAR()
                && defined($inner2->{"name"}) && length($inner2->{"name"}) > 0
                && index($inner2->{"name"}, "::") < 0 && $inner2->{"name"} ne "_") {
                emit($cg, c_var_h($inner2->{"name"}));
            } else {
                gen_expr($cg, $inner2);
            }
            emit($cg, ", __ak); free(__ak); __av; })");
        }
    } elsif ($t == Perla::AST::N_ARROW_HASH()) {
        my scalar $akey = $node->{"key"};
        my scalar $aobj = $node->{"object"};
        my int $aobj_type = $aobj->{"type"};
        my int $akey_type = $akey->{"type"};
        my int $akey_lit = 0;
        if ($akey_type == Perla::AST::N_STR_LIT()) { $akey_lit = 1; }
        if ($akey_type == Perla::AST::N_INTERP_STR() && has_perl_var($akey->{"value"}) == 0) { $akey_lit = 1; }
        # Route to c_var_h ONLY for the sigil-hash form `$h{k}` (no arrow),
        # which is sugar for %h{k}. Arrow form `$h->{k}` autoderefs the
        # scalar — read v_h (the scalar holding a hash ref), NOT v_h__h
        # (the unrelated hash storage). Without this guard, the assignment
        # `$data->{config}{servers} = X` wrote to the wrong variable when
        # the name collided with a later `my %data` in the same scope.
        my int $is_arrow_form = 0;
        if (defined($node->{"is_explicit_arrow"}) && $node->{"is_explicit_arrow"} == 1) { $is_arrow_form = 1; }
        my int $aobj_route_h = 0;
        if ($is_arrow_form == 0
            && $aobj_type == Perla::AST::N_SCALAR_VAR()
            && defined($aobj->{"name"}) && length($aobj->{"name"}) > 0
            && index($aobj->{"name"}, "::") < 0 && $aobj->{"name"} ne "_"
            && exists($__perla_mangle_collisions{$aobj->{"name"}})) {
            $aobj_route_h = 1;
        }
        # Autoviv the outer scalar var when used like `$ret->{a}{b}{c} = X`:
        # innermost $ret needs to become a hash ref. Same logic as the
        # direct assignment fix.
        my int $aobj_autoviv_scalar = 0;
        if ($aobj_type == Perla::AST::N_SCALAR_VAR()
            && defined($aobj->{"name"}) && length($aobj->{"name"}) > 0
            && index($aobj->{"name"}, "::") < 0 && $aobj->{"name"} ne "_"
            && $aobj_route_h == 0) {
            $aobj_autoviv_scalar = 1;
        }
        # `$Pkg::Name->{k}` (or `$Pkg::Name{k}` sigil-hash) — fetch the
        # HASH slot of the stash glob; no autoviv at the leaf.
        my int $aobj_pkg = 0;
        if ($aobj_type == Perla::AST::N_SCALAR_VAR()
            && defined($aobj->{"name"}) && index($aobj->{"name"}, "::") > 0) {
            $aobj_pkg = 1;
        }
        if ($akey_lit == 1) {
            emit($cg, "strada_hv_autoviv(");
            if ($aobj_type == 18 || $aobj_type == 41) {
                _gen_autoviv_hash($cg, $aobj);
            } elsif ($aobj_pkg == 1) {
                my array @aopn = _split_pkg_qual_name($aobj);
                emit($cg, "perla_hash_get(\"" . $aopn[0] . "\", \"" . $aopn[1] . "\")");
            } elsif ($aobj_route_h == 1) {
                emit($cg, c_var_h($aobj->{"name"}));
            } elsif ($aobj_autoviv_scalar == 1) {
                my str $vc = c_var($aobj->{"name"});
                # Autoviv ONLY when the var is undef (or NULL ptr), to
                # match Perl's "autovivification triggered by undef
                # only" semantics. Don't clobber existing strings, ints,
                # or other refs — those would be runtime errors in
                # strict Perl, but the user might use them as symbolic
                # refs (`${"Pkg::Name"}->{key}`).
                emit($cg, "({ if (!" . $vc . " || STRADA_IS_TAGGED_INT(" . $vc . ") ? 0 : (" . $vc . "->type == STRADA_UNDEF)) { ");
                emit($cg, "  StradaValue *__nh = strada_new_ref_take(strada_new_hash(), '%'); ");
                emit($cg, "  if (" . $vc . ") strada_decref(" . $vc . "); ");
                emit($cg, "  " . $vc . " = __nh; ");
                emit($cg, "} else if (!" . $vc . ") { ");
                emit($cg, "  " . $vc . " = strada_new_ref_take(strada_new_hash(), '%'); ");
                emit($cg, "} " . $vc . "; })");
            } else {
                gen_expr($cg, $aobj);
            }
            emit($cg, ", \"" . Perla::CodeGen::Escape::str_node_to_c($akey) . "\")");
        } else {
            emit($cg, "({ char *__ak = strada_to_str(");
            gen_expr($cg, $akey);
            emit($cg, "); StradaValue *__av = strada_hv_autoviv(");
            if ($aobj_type == 18 || $aobj_type == 41) {
                _gen_autoviv_hash($cg, $aobj);
            } elsif ($aobj_pkg == 1) {
                my array @aopn2 = _split_pkg_qual_name($aobj);
                emit($cg, "perla_hash_get(\"" . $aopn2[0] . "\", \"" . $aopn2[1] . "\")");
            } elsif ($aobj_route_h == 1) {
                emit($cg, c_var_h($aobj->{"name"}));
            } elsif ($aobj_autoviv_scalar == 1) {
                my str $vc = c_var($aobj->{"name"});
                # Autoviv ONLY when the var is undef (or NULL ptr), to
                # match Perl's "autovivification triggered by undef
                # only" semantics. Don't clobber existing strings, ints,
                # or other refs — those would be runtime errors in
                # strict Perl, but the user might use them as symbolic
                # refs (`${"Pkg::Name"}->{key}`).
                emit($cg, "({ if (!" . $vc . " || STRADA_IS_TAGGED_INT(" . $vc . ") ? 0 : (" . $vc . "->type == STRADA_UNDEF)) { ");
                emit($cg, "  StradaValue *__nh = strada_new_ref_take(strada_new_hash(), '%'); ");
                emit($cg, "  if (" . $vc . ") strada_decref(" . $vc . "); ");
                emit($cg, "  " . $vc . " = __nh; ");
                emit($cg, "} else if (!" . $vc . ") { ");
                emit($cg, "  " . $vc . " = strada_new_ref_take(strada_new_hash(), '%'); ");
                emit($cg, "} " . $vc . "; })");
            } else {
                gen_expr($cg, $aobj);
            }
            emit($cg, ", __ak); free(__ak); __av; })");
        }
    } else {
        gen_expr($cg, $node);
    }
}

# Emit an expression that autovivifies $node to a HASHref if it's a plain
# scalar var (undef → springs into `{}`). For nested hash chains, delegates
# to `_gen_autoviv_hash`. Used when the outermost container of a chain
# `$d->{k}[i]` or `push @{$d->{k}}, ...` needs to come into being.
#
# $hash_context = 1 if this node represents a hash-sigil access (e.g. inside
# N_HASH_ELEM's "hash" field) — name collisions then route to `v_X__h` rather
# than the scalar `v_X`. Pass 0 for N_ARROW_HASH's "object" (always scalar).
func _gen_autoviv_outer_hash(scalar $cg, scalar $node, int $hash_context) void {
    my int $t = $node->{"type"};
    if ($t == Perla::AST::N_HASH_ELEM() || $t == Perla::AST::N_ARROW_HASH()) {
        _gen_autoviv_hash($cg, $node);
        return;
    }
    if ($t == Perla::AST::N_SCALAR_VAR()
        && defined($node->{"name"}) && index($node->{"name"}, "::") > 0) {
        # $Pkg::H{k} compound — fetch the HASH slot of the stash glob.
        # No autoviv needed at this level (perla_hash_get always returns
        # a real value when the slot is initialized via `our %H`).
        my array @ohpn = _split_pkg_qual_name($node);
        emit($cg, "perla_hash_get(\"" . $ohpn[0] . "\", \"" . $ohpn[1] . "\")");
        return;
    }
    if ($t == Perla::AST::N_SCALAR_VAR()
        && defined($node->{"name"}) && length($node->{"name"}) > 0
        && index($node->{"name"}, "::") < 0 && $node->{"name"} ne "_") {
        my str $vc;
        if ($hash_context == 1 && exists($__perla_mangle_collisions{$node->{"name"}})) {
            # `%foo` access where `@foo` or `$foo` also exists — the hash
            # lives in `v_foo__h`, NOT the scalar `v_foo`. Writing to v_foo
            # would diverge: the autoviv-created hashref lives in a slot
            # nobody reads from.
            $vc = c_var_h($node->{"name"});
        } else {
            $vc = c_var($node->{"name"});
        }
        emit($cg, "({ if (!" . $vc . " || (!STRADA_IS_TAGGED_INT(" . $vc . ") && " . $vc . "->type == STRADA_UNDEF)) { ");
        emit($cg, "  if (" . $vc . ") strada_decref(" . $vc . "); ");
        emit($cg, "  " . $vc . " = strada_new_ref_take(strada_new_hash(), '%'); ");
        emit($cg, "} " . $vc . "; })");
        return;
    }
    gen_expr($cg, $node);
}

# Emit an expression that autovivifies $node to an arrayref (or returns its
# existing arrayref value). Used by lvalue codegen where the array slot itself
# needs to spring into existence — e.g. `$d->{users}[0]{name} = X` needs
# `$d->{users}` to become `[]` so the [0] slot exists to set.
#
# Mirrors _gen_autoviv_hash but emits autoviv-to-ARRAY at the leaf step.
func _gen_autoviv_array_value(scalar $cg, scalar $node) void {
    my int $t = $node->{"type"};
    # `$_` as the REF of an array deref (`@{$_} = LIST`, `push @{$_}, X`) is the
    # scalar topic holding an array REFERENCE — NEVER the `@_` args array (that's
    # spelled `@_`). The old code emitted `perla_at_` here, so `@{$_} = LIST`
    # wrongly operated on @_ and dropped the write (Sub::Exporter::Progressive's
    # `@{$_} = map {...} @{$_} for \@defaults` lost the `-all` group expansion).
    #
    # We must NOT use the c_var("_")==v__ scalar-var path below either: `$_`
    # does NOT live in `v__`. Scalar assignment to `$_` writes the canonical
    # global `perla_dollar_underscore` (and the `main::_` glob slot); `v__` is
    # a vestigial local that stays NULL. Reading `v__` makes the autoviv think
    # `$_` is undef → it fabricates a throwaway array and assigns into that.
    # Use plain gen_expr (exactly what the working hash-deref path does), which
    # reads `$_` from its real storage. No autoviv-on-undef here, but `@{$_}`
    # on an undef $_ is a rare strict-refs error anyway; correct READ is what
    # matters for the for-modifier-aliased-arrayref idiom.
    if ($t == Perla::AST::N_SCALAR_VAR()
        && defined($node->{"name"}) && $node->{"name"} eq "_") {
        gen_expr($cg, $node);
        return;
    }
    if ($t == Perla::AST::N_SCALAR_VAR()
        && defined($node->{"name"}) && index($node->{"name"}, "::") > 0) {
        # $Pkg::arr access — fetch the ARRAY slot of the stash glob.
        my array @apkn = _split_pkg_qual_name($node);
        emit($cg, "perla_array_get(\"" . $apkn[0] . "\", \"" . $apkn[1] . "\")");
        return;
    }
    if ($t == Perla::AST::N_SCALAR_VAR()
        && defined($node->{"name"}) && length($node->{"name"}) > 0
        && index($node->{"name"}, "::") < 0) {
        my str $vc = c_var($node->{"name"});
        emit($cg, "({ if (!" . $vc . " || (!STRADA_IS_TAGGED_INT(" . $vc . ") && " . $vc . "->type == STRADA_UNDEF)) { ");
        emit($cg, "  if (" . $vc . ") strada_decref(" . $vc . "); ");
        emit($cg, "  " . $vc . " = strada_new_ref_take(strada_new_array(), '@'); ");
        emit($cg, "} " . $vc . "; })");
        return;
    }
    if ($t == Perla::AST::N_HASH_ELEM() || $t == Perla::AST::N_ARROW_HASH()) {
        my scalar $outer = undef;
        if ($t == Perla::AST::N_HASH_ELEM()) {
            $outer = $node->{"hash"};
        } else {
            $outer = $node->{"object"};
        }
        emit($cg, "({ StradaValue *__avx_h = ");
        my int $outer_t = $outer->{"type"};
        if ($outer_t == Perla::AST::N_HASH_ELEM() || $outer_t == Perla::AST::N_ARROW_HASH()) {
            _gen_autoviv_hash($cg, $outer);
        } elsif ($outer_t == Perla::AST::N_SCALAR_VAR()
            && defined($outer->{"name"}) && length($outer->{"name"}) > 0
            && index($outer->{"name"}, "::") < 0 && $outer->{"name"} ne "_") {
            my str $ovc = c_var($outer->{"name"});
            emit($cg, "({ if (!" . $ovc . " || (!STRADA_IS_TAGGED_INT(" . $ovc . ") && " . $ovc . "->type == STRADA_UNDEF)) { ");
            emit($cg, "  if (" . $ovc . ") strada_decref(" . $ovc . "); ");
            emit($cg, "  " . $ovc . " = strada_new_ref_take(strada_new_hash(), '%'); ");
            emit($cg, "} " . $ovc . "; })");
        } else {
            gen_expr($cg, $outer);
        }
        emit($cg, "; StradaHash *__avx_hh = strada_deref_hash(__avx_h); char *__avx_k = strada_to_str(");
        gen_expr($cg, $node->{"key"});
        emit($cg, "); StradaValue *__avx_v = __avx_hh ? strada_hash_get(__avx_hh, __avx_k) : NULL; ");
        emit($cg, "if (!__avx_v || STRADA_IS_TAGGED_INT(__avx_v) || __avx_v->type != STRADA_REF || !__avx_v->value.rv || __avx_v->value.rv->type != STRADA_ARRAY) { ");
        emit($cg, "  StradaValue *__avx_new = strada_new_ref_take(strada_new_array(), '@'); ");
        emit($cg, "  if (__avx_hh) strada_hash_set_take(__avx_hh, __avx_k, __avx_new); ");
        emit($cg, "  __avx_v = __avx_new; ");
        emit($cg, "} free(__avx_k); __avx_v; })");
        return;
    }
    # `$a[i][j] = …` with 3+ levels — inner is itself an N_ARRAY_ELEM
    # or N_ARROW_ARRAY. Autoviv the inner slot to a ref-to-array, then
    # return that arrayref so the next level can deref+set.
    if ($t == Perla::AST::N_ARRAY_ELEM() || $t == Perla::AST::N_ARROW_ARRAY()) {
        my scalar $inner_arr = undef;
        if ($t == Perla::AST::N_ARRAY_ELEM()) {
            $inner_arr = $node->{"array"};
        } else {
            $inner_arr = $node->{"object"};
        }
        emit($cg, "({ StradaArray *__avx_aa = strada_deref_array(");
        _gen_autoviv_array_value($cg, $inner_arr);  # recursive
        emit($cg, "); int __avx_ai = (int)strada_to_int(");
        gen_expr($cg, $node->{"index"});
        emit($cg, "); if (__avx_ai < 0 && __avx_aa) __avx_ai += strada_array_length(__avx_aa); ");
        emit($cg, "StradaValue *__avx_av = __avx_aa ? strada_array_get(__avx_aa, __avx_ai) : NULL; ");
        emit($cg, "if (!__avx_av || STRADA_IS_TAGGED_INT(__avx_av) || __avx_av->type != STRADA_REF || !__avx_av->value.rv || __avx_av->value.rv->type != STRADA_ARRAY) { ");
        emit($cg, "  StradaValue *__avx_new = strada_new_ref_take(strada_new_array(), '@'); ");
        emit($cg, "  if (__avx_aa) strada_array_set(__avx_aa, __avx_ai, __avx_new); ");
        emit($cg, "  __avx_av = __avx_new; ");
        emit($cg, "} __avx_av; })");
        return;
    }
    # Fallback: plain expression (no autoviv).
    gen_expr($cg, $node);
}

# Generate a condition expression as a C boolean (int), avoiding strada_to_bool wrapper
# Returns 1 if it emitted a direct C boolean, 0 if it fell back to perla_to_bool(expr)
func _gen_cond(scalar $cg, scalar $node) void {
    if (!defined($node)) { emit($cg, "0"); return; }
    my int $t = $node->{"type"};
    # Numeric comparisons: emit as direct C comparison
    if ($t == Perla::AST::N_BINOP()) {
        my str $op = $node->{"op"};
        if ($op eq "==" || $op eq "!=" || $op eq "<" || $op eq ">" || $op eq "<=" || $op eq ">=") {
            if (Perla::CodeGen::Stmt::_node_is_int($cg, $node->{"left"}) == 1 && Perla::CodeGen::Stmt::_node_is_int($cg, $node->{"right"}) == 1) {
                emit($cg, "(strada_to_int(");
                _gen_expr_scalar($cg, $node->{"left"});
                emit($cg, ") " . $op . " strada_to_int(");
                _gen_expr_scalar($cg, $node->{"right"});
                emit($cg, "))");
            } else {
                # Runtime fast path: if both are tagged ints, use int comparison.
                # If either operand is a blessed ref, try `use overload`
                # dispatch — without this, comparison in conditional
                # context (`if ($obj1 == $obj2)`) always compared the
                # ref addresses.
                my int $cl_borrowed_if = expr_is_borrowed($node->{"left"});
                my int $cr_borrowed_if = expr_is_borrowed($node->{"right"});
                emit($cg, "({ StradaValue *__cl = ");
                _gen_expr_scalar($cg, $node->{"left"});
                emit($cg, "; StradaValue *__cr = ");
                _gen_expr_scalar($cg, $node->{"right"});
                emit($cg, "; int __cres_final; ");
                # FAST PATH: two tagged integers — skip the REF/overload check
                # and the operand decrefs (tagged ints are immortal). Mirrors
                # the arithmetic fast path; this comparison runs every loop
                # iteration / recursion guard (`$n <= 1`).
                emit($cg, "if (STRADA_IS_TAGGED_INT(__cl) && STRADA_IS_TAGGED_INT(__cr)) { ");
                emit($cg, "  __cres_final = (STRADA_TAGGED_INT_VAL(__cl) " . $op . " STRADA_TAGGED_INT_VAL(__cr)); ");
                emit($cg, "} else { ");
                emit($cg, "  int __cbr_set = 0; int __cres = 0; ");
                emit($cg, "  if (((__cl && !STRADA_IS_TAGGED_INT(__cl) && __cl->type == STRADA_REF) || ");
                emit($cg, "       (__cr && !STRADA_IS_TAGGED_INT(__cr) && __cr->type == STRADA_REF))) { ");
                emit($cg, "    StradaValue *__cbr = perla_overload_binary(__cl, __cr, \"" . $op . "\"); ");
                emit($cg, "    if (__cbr) { __cres = strada_to_bool(__cbr); __cbr_set = 1; strada_decref(__cbr); } } ");
                emit($cg, "  __cres_final = __cbr_set ? __cres : ");
                emit($cg, "(STRADA_IS_TAGGED_INT(__cl) && STRADA_IS_TAGGED_INT(__cr) ? ");
                emit($cg, "(STRADA_TAGGED_INT_VAL(__cl) " . $op . " STRADA_TAGGED_INT_VAL(__cr)) : ");
                emit($cg, "(strada_to_num(__cl) " . $op . " strada_to_num(__cr))); ");
                # Decref owned operand temps so e.g. `$i == -1` doesn't
                # leak the fresh strada_new_num(-1) per call.
                if ($cl_borrowed_if == 0) {
                    emit($cg, "  if (__cl) strada_decref(__cl); ");
                }
                if ($cr_borrowed_if == 0) {
                    emit($cg, "  if (__cr) strada_decref(__cr); ");
                }
                emit($cg, "} ");
                emit($cg, "__cres_final; })");
            }
            return;
        }
        # String comparisons (fast path inside if-cond).
        # `eq`/`ne` are scalar operators — push scalar context so list
        # operators like `reverse $s` reverse the string instead of the
        # 1-element list. `$s eq reverse $s` was returning true (perla)
        # because reverse saw list context and was a no-op.
        if ($op eq "eq" || $op eq "ne") {
            # Overload dispatch on blessed refs before falling to strcmp.
            # Without this, `if ($obj eq $other)` with eq-overloaded
            # blessed refs skipped the user's sub.
            emit($cg, "({ int __sav_wl_eq = __perla_want_list; __perla_want_list = 0; ");
            emit($cg, "StradaValue *__cseql = ");
            gen_expr($cg, $node->{"left"});
            emit($cg, "; StradaValue *__cseqr = ");
            gen_expr($cg, $node->{"right"});
            emit($cg, "; __perla_want_list = __sav_wl_eq; StradaValue *__cseqov = NULL; ");
            emit($cg, "if ((__cseql && !STRADA_IS_TAGGED_INT(__cseql) && __cseql->type == STRADA_REF) || ");
            emit($cg, "    (__cseqr && !STRADA_IS_TAGGED_INT(__cseqr) && __cseqr->type == STRADA_REF)) { ");
            emit($cg, "  __cseqov = perla_overload_binary(__cseql, __cseqr, \"" . $op . "\"); } ");
            emit($cg, "int __cres; ");
            emit($cg, "if (__cseqov) { __cres = perla_to_bool(__cseqov); strada_decref(__cseqov); } ");
            emit($cg, "else { char *__cl = strada_to_str(__cseql); char *__cr = strada_to_str(__cseqr); ");
            emit($cg, "__cres = strcmp(__cl, __cr)");
            if ($op eq "eq") { emit($cg, " == 0"); }
            else { emit($cg, " != 0"); }
            emit($cg, "; free(__cl); free(__cr); } __cres; })");
            return;
        }
        # Logical operators: short-circuit
        if ($op eq "&&" || $op eq "and") {
            emit($cg, "(");
            _gen_cond($cg, $node->{"left"});
            emit($cg, " && ");
            _gen_cond($cg, $node->{"right"});
            emit($cg, ")");
            return;
        }
        if ($op eq "||" || $op eq "or") {
            emit($cg, "(");
            _gen_cond($cg, $node->{"left"});
            emit($cg, " || ");
            _gen_cond($cg, $node->{"right"});
            emit($cg, ")");
            return;
        }
    }
    # Unary not
    if ($t == Perla::AST::N_UNOP()) {
        my str $op = $node->{"op"};
        if ($op eq "!" || $op eq "not") {
            # Need to dispatch the `!` overload for blessed refs. The
            # simple `(!perla_to_bool(EXPR))` form silently skips
            # `use overload '!' => ...`. Use a statement-expression
            # that consults the overload first, then falls back to
            # the boolean of the operand (which also picks up the
            # `bool` overload via perla_to_bool).
            emit($cg, "({ StradaValue *__cnv = ");
            gen_expr($cg, $node->{"operand"});
            emit($cg, "; StradaValue *__cnr = NULL; ");
            emit($cg, "if (__cnv && !STRADA_IS_TAGGED_INT(__cnv) && __cnv->type == STRADA_REF) { ");
            emit($cg, "  __cnr = perla_overload_binary(__cnv, strada_new_undef(), \"!\"); } ");
            emit($cg, "__cnr ? perla_to_bool(__cnr) : !perla_to_bool(__cnv); })");
            return;
        }
    }
    # Regex match: $x =~ /pattern/ — emit the match result directly (returns int)
    if ($t == Perla::AST::N_REGEX_MATCH()) {
        gen_expr($cg, $node);
        emit($cg, " != 0");
        return;
    }
    # Flip-flop in boolean context (`if (/start/../end/)`, `while`, ternary,
    # &&/||). Each `..`/`...` site keeps its own persistent on/off state in a
    # function-local static. Returns int directly — no StradaValue alloc — so
    # the common per-iteration off case ("") never allocates or leaks. The
    # operands are evaluated as booleans (Perl's constant-vs-$. line-range
    # form is not emulated; regex/boolean operands are the common use).
    if ($t == Perla::AST::N_RANGE()) {
        my int $is3 = 0;
        if (defined($node->{"is_3dot"}) && $node->{"is_3dot"} == 1) { $is3 = 1; }
        emit($cg, "({ static int __ff_st = 0; int __ff_b; ");
        emit($cg, "if (!__ff_st) { if (");
        _gen_cond($cg, $node->{"from"});
        emit($cg, ") { __ff_st = 1; ");
        if ($is3 == 0) {
            emit($cg, "if (");
            _gen_cond($cg, $node->{"to"});
            emit($cg, ") { __ff_st = 0; } ");
        }
        emit($cg, "__ff_b = 1; } else { __ff_b = 0; } } ");
        emit($cg, "else { if (");
        _gen_cond($cg, $node->{"to"});
        emit($cg, ") { __ff_st = 0; } __ff_b = 1; } __ff_b; })");
        return;
    }
    # Fallback: evaluate and convert to bool. The condition is always
    # scalar context (Perl: `if (LIST)`, `LIST ? :`, etc. evaluate LIST
    # in scalar context). Without forcing scalar here, e.g.
    # `print "x: ", (1, 2, 0) ? "y" : "n";` evaluated the comma list
    # under the print's list context and got the full list (truthy)
    # instead of the comma-op last value (0, falsy).
    emit($cg, "({ int __sav_wl_cond = __perla_want_list; __perla_want_list = 0; ");
    emit($cg, "int __cv = perla_to_bool(");
    gen_expr($cg, $node);
    emit($cg, "); __perla_want_list = __sav_wl_cond; __cv; })");
}


# --- Expression generation ---
func gen_expr(scalar $cg, scalar $node) void {
    if (!defined($node)) { emit($cg, "strada_new_undef()"); return; }
    my int $type = $node->{"type"};

    if ($type == Perla::AST::N_INT_LIT()) {
        # Tagged ints store 62 bits of signed integer. Values outside
        # [-2^62, 2^62-1] would corrupt during the `(val << 1) | 1` encode
        # (e.g., 9223372036854775807 shifted left becomes -2, then ORed
        # gives -1). Emit those as heap ints via strada_new_int instead.
        my str $litv = "" . $node->{"value"};
        my int $needs_heap = 0;
        # Compare magnitude as a string vs the boundary 4611686018427387904
        my str $cmp_lit = $litv;
        my int $is_neg = 0;
        if (length($cmp_lit) > 0 && substr($cmp_lit, 0, 1) eq "-") {
            $is_neg = 1;
            $cmp_lit = substr($cmp_lit, 1, length($cmp_lit) - 1);
        }
        # Strip leading zeros
        while (length($cmp_lit) > 1 && substr($cmp_lit, 0, 1) eq "0") {
            $cmp_lit = substr($cmp_lit, 1, length($cmp_lit) - 1);
        }
        if (length($cmp_lit) > 19) {
            $needs_heap = 1;
        } elsif (length($cmp_lit) == 19) {
            # Compare against "4611686018427387903" (positive) or
            # "4611686018427387904" (allowed magnitude for negative).
            my str $bound;
            if ($is_neg == 1) { $bound = "4611686018427387904"; }
            else { $bound = "4611686018427387903"; }
            if ($cmp_lit gt $bound) { $needs_heap = 1; }
        }
        # Above the i64 range: a POSITIVE literal that still fits an
        # unsigned 64-bit (<= 18446744073709551615) becomes a UV via
        # strada_new_uint — matching Perl, which holds such values as UV
        # rather than promoting to NV. Only literals beyond UINT64_MAX (or
        # any out-of-range negative) fall back to NUM (double), since they
        # can't be represented exactly as an integer at all.
        my int $needs_num = 0;
        my int $needs_uint = 0;
        if ($is_neg == 1) {
            # Negatives can't be UV. NUM if magnitude exceeds INT64 min.
            if (length($cmp_lit) > 19) {
                $needs_num = 1;
            } elsif (length($cmp_lit) == 19 && $cmp_lit gt "9223372036854775808") {
                $needs_num = 1;
            }
        } else {
            if (length($cmp_lit) > 20) {
                $needs_num = 1;
            } elsif (length($cmp_lit) == 20) {
                if ($cmp_lit gt "18446744073709551615") { $needs_num = 1; }
                else { $needs_uint = 1; }
            } elsif (length($cmp_lit) == 19 && $cmp_lit gt "9223372036854775807") {
                $needs_uint = 1;
            }
        }
        # Under `use bigint`, a literal that doesn't fit a tagged int is carried
        # as an exact decimal string (the bignum representation) rather than
        # losing precision as a UV/double — `99999999999999999999 + 1` etc.
        if (defined($cg->{"use_bigint"}) && $cg->{"use_bigint"} == 1
            && ($needs_num == 1 || $needs_uint == 1 || $needs_heap == 1)) {
            emit($cg, "strada_new_str(\"" . $litv . "\")");
            return;
        }
        if ($needs_num == 1) {
            emit($cg, "strada_new_num(" . $litv . ".0)");
        } elsif ($needs_uint == 1) {
            emit($cg, "strada_new_uint(" . $litv . "ULL)");
        } elsif ($needs_heap == 1) {
            emit($cg, "strada_new_int((int64_t)" . $litv . "LL)");
        } else {
            emit($cg, "STRADA_MAKE_TAGGED_INT(" . $litv . ")");
        }
        return;
    }
    if ($type == Perla::AST::N_NUM_LIT()) {
        emit($cg, "strada_new_num(" . $node->{"value"} . ")");
        return;
    }
    if ($type == Perla::AST::N_STR_LIT()) {
        # Under `use utf8`, source string literals are char-oriented:
        # set SVf_UTF8 so length()/uc()/lc()/etc. count code points
        # rather than bytes. Without the pragma, perl treats source
        # as bytes (Latin-1 in 5.x); perla then emits the literal
        # byte-oriented.
        my int $__sl_utf8 = 0;
        if (defined($cg->{"use_utf8"}) && $cg->{"use_utf8"} == 1) { $__sl_utf8 = 1; }
        if (defined($node->{"is_utf8"}) && $node->{"is_utf8"} == 1) { $__sl_utf8 = 1; }
        if ($__sl_utf8 == 1) {
            my str $__sl_val = $node->{"value"};
            my str $__sl_esc = Perla::CodeGen::Escape::escape_c_str($__sl_val);
            # The length arg to strada_new_str_len_utf8 is the BYTE length of the
            # emitted C literal — NOT the codepoint count. `length()` here is
            # char-oriented (strada_length_chars_sv ignores the byte flag), so a
            # multi-byte literal got truncated to its codepoint count of bytes
            # (e.g. a `use utf8` string with `Ḩ` lost 2 bytes). Use byte length.
            emit($cg, "strada_new_str_len_utf8(\"" . $__sl_esc . "\", " . core::byte_length($__sl_val) . ")");
        } else {
            emit($cg, "strada_new_str(\"" . Perla::CodeGen::Escape::escape_c_str($node->{"value"}) . "\")");
        }
        return;
    }
    if ($type == Perla::AST::N_INTERP_STR()) {
        Perla::CodeGen::Interp::gen_interp_str($cg, $node->{"value"});
        return;
    }
    if ($type == Perla::AST::N_UNDEF()) {
        emit($cg, "strada_new_undef()");
        return;
    }
    # do { BLOCK } as expression — returns value of last statement
    if ($type == Perla::AST::N_BLOCK()) {
        my scalar $stmts = $node->{"stmts"};
        if (!defined($stmts) || scalar(@{$stmts}) == 0) {
            emit($cg, "strada_new_undef()");
            return;
        }
        # Lexical pragma save (use utf8 / use bytes / use integer) —
        # do-block-as-expression scopes the pragma to its body. Without
        # save/restore here, `do { use bytes; ... }` leaked use_bytes
        # into subsequent code.
        my int $db_save_use_integer = 0;
        if (defined($cg->{"use_integer"})) { $db_save_use_integer = $cg->{"use_integer"}; }
        my int $db_save_use_utf8 = 0;
        if (defined($cg->{"use_utf8"})) { $db_save_use_utf8 = $cg->{"use_utf8"}; }
        my int $db_save_use_bytes = 0;
        if (defined($cg->{"use_bytes"})) { $db_save_use_bytes = $cg->{"use_bytes"}; }
        # Snapshot active `local` saves so `local $X = ...` inside the
        # do block restores at block exit. Without this, `do { local $/;
        # … }` left $/ undef after the block (perla_irs stayed NULL),
        # breaking subsequent line reads.
        my scalar $bb_saved_locals = {};
        if (defined($cg->{"local_vars"})) {
            my array @bb_keys_b = keys($cg->{"local_vars"});
            my int $bb_ki = 0;
            while ($bb_ki < scalar(@bb_keys_b)) {
                my str $bb_v = "" . $cg->{"local_vars"}->{$bb_keys_b[$bb_ki]};
                if ($bb_v ne "__restored__") {
                    $bb_saved_locals->{$bb_keys_b[$bb_ki]} = 1;
                }
                $bb_ki++;
            }
        }
        my int $total = scalar(@{$stmts});
        # Skip trailing synthetic N_PACKAGE restore stmts when picking the
        # block's value-producing last statement. The parser appends a
        # restore stmt to any block that did `package X;` so the outer
        # package context is reinstated; codegen still needs to emit it
        # for runtime-side `caller()` correctness, but it must NOT be
        # treated as the do-block's value. Without this, `do { package
        # Foo; sub { 42 } }` returned undef because the synthetic restore
        # was the AST's last stmt — broke Eval::Closure's sandbox-wrapped
        # `eval q{ package Sandbox_N; sub { ... } };` (every validator
        # silently returned undef instead of a code ref).
        my int $n = $total;
        while ($n > 1 && defined($stmts->[$n - 1])
               && $stmts->[$n - 1]->{"type"} == Perla::AST::N_PACKAGE()
               && defined($stmts->[$n - 1]->{"synthetic"})
               && $stmts->[$n - 1]->{"synthetic"} == 1) {
            $n = $n - 1;
        }
        my scalar $last = $stmts->[$n - 1];
        my int $lt = defined($last) ? $last->{"type"} : 0;
        # If the last stmt is an if/unless, capture each branch's tail
        # expression so the do block returns the right list (matches Perl
        # semantics). Without this, `do { if (X) { LIST_A } else { LIST_B } }`
        # emitted the if as a void C statement and the surrounding
        # statement-expression returned an empty value. Surfaced via
        # SQL::Abstract's
        # `join(' ', do { if (...) { ($table, $as) } elsif (...) { $$x } ... })`
        # — the do block produced empty SQL fragments so the FROM clause
        # came out as `FROM   JOIN  ON 0`.
        if ($lt == Perla::AST::N_IF() || $lt == Perla::AST::N_UNLESS()) {
            emit($cg, "({ StradaValue *__bv = NULL; ");
            my int $bi = 0;
            while ($bi < $n - 1) {
                Perla::CodeGen::Stmt::gen_stmt($cg, $stmts->[$bi]);
                $bi++;
            }
            Perla::CodeGen::Stmt::gen_if_capture_return($cg, $last, "__bv");
            emit($cg, "__bv ? __bv : strada_new_undef(); })");
            return;
        }
        emit($cg, "({ ");
        # Snapshot the local-chain head at block entry. `local $X = ...`
        # inside the block pushes scalar saves on the chain; restoring at
        # block exit unwinds them. Same idea as the eval-block mark, but
        # for plain do { ... } / bare blocks.
        emit($cg, "void *__db_local_mark = __perla_local_chain; ");
        # Snapshot declared_vars / shared_cells_emitted / my_lexicals so
        # `my $X` inside this do { } block doesn't leak into a sibling
        # block. Two adjacent `do { my $x = 0; sub { ... $x ... } }`
        # blocks otherwise reused the same `v_x` and the same closure
        # cell — the second closure captured the first's slot (state
        # bleed). Concrete victim: `inc => do{my$x=0; sub{++$x}},
        # more => do{my$x=0; sub{$x+=2}}` shared $x.
        my scalar $__db_saved_dv = $cg->{"declared_vars"};
        my scalar $__db_saved_ssd = $cg->{"same_scope_decls"};
