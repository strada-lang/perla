            emit($cg, "__dr; })");
        } elsif ($argc == 0) {
            emit($cg, "({ static StradaValue *__ovr_c = NULL; static long __ovr_g = -1; if (__ovr_g != perla_code_override_gen) { __ovr_c = perla_code_get(\"" . $__qn_pkg . "\", \"" . $__qn_short . "\"); __ovr_g = perla_code_override_gen; } StradaValue *__ovr = __ovr_c; ");
            emit($cg, "(__ovr && !STRADA_IS_TAGGED_INT(__ovr) && __ovr->type != STRADA_STR) ");
            emit($cg, "  ? ({ StradaValue *__oa = strada_new_array(); StradaValue *__or = perla_call_code(__ovr, __oa); strada_decref(__oa); __or; }) ");
            emit($cg, "  : " . $fname . "(NULL); })");
        } else {
            emit($cg, "({ StradaValue *__a = strada_new_array(); StradaArray *__av = strada_deref_array(__a); ");
            _gen_push_args($cg, $args, $argc);
            # Snapshot @_'s head before the call so writeback can detect
            # whether the callee shifted/popped. shift/pop move head/tail
            # of perla_at_ (== __av), and the post-call __av[0] read would
            # otherwise return the original second arg — which then gets
            # written back to the caller's first variable, smashing it
            # (`my $f = shift; my @captured = @_; return sub { … }` did
