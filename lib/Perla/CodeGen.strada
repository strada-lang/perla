            gen_expr($cg, $node->{"left"});
            emit($cg, "); char *__rp = strada_to_str(");
            gen_expr($cg, $right);
            emit($cg, "); int __rm = strada_regex_match_with_capture(__rs, __rp, \"\"); free(__rs); free(__rp); STRADA_MAKE_TAGGED_INT(__rm); })");
        }
        if (defined($cg->{"_subst_hoist_wrap"}) && $cg->{"_subst_hoist_wrap"} == 1) { emit($cg, ")"); $cg->{"_subst_hoist_wrap"} = 0; }
        return;
    }
    if ($op eq "!~") {
        my scalar $right = $node->{"right"};
        if (defined($right) && $right->{"type"} == Perla::AST::N_REGEX()) {
            my str $pat = Perla::CodeGen::Escape::escape_c_str($right->{"pattern"});
            my str $flags = "";
            if (defined($right->{"flags"})) { $flags = $right->{"flags"}; }
            # Interpolate $var in pattern. URI::implementor's
            # `$scheme !~ /\A$scheme_re\z/o` was emitting the literal
            # "\A$scheme_re\z" as pattern — so EVERY scheme failed the
            # match and URI->new returned URI::_generic instead of
            # URI::https.
            my int $not_pat_has_var = has_perl_var($pat);
            emit($cg, "({ char *__rs = strada_to_str(");
            gen_expr($cg, $node->{"left"});
            if ($not_pat_has_var == 1) {
                emit($cg, "); char *__pat = strada_to_str(");
                Perla::CodeGen::Interp::gen_interp_c_str($cg, $right->{"pattern"});
                emit($cg, "); int __rm = !strada_regex_match_with_capture(__rs, __pat, \"" . $flags . "\"); free(__pat); free(__rs); STRADA_MAKE_TAGGED_INT(__rm); })");
            } else {
                emit($cg, "); int __rm = !strada_regex_match_with_capture(__rs, \"" . $pat . "\", \"" . $flags . "\"); free(__rs); STRADA_MAKE_TAGGED_INT(__rm); })");
            }
        } else {
            emit($cg, "({ char *__rs = strada_to_str(");
            gen_expr($cg, $node->{"left"});
            emit($cg, "); char *__rp = strada_to_str(");
            gen_expr($cg, $right);
            emit($cg, "); int __rm = !strada_regex_match_with_capture(__rs, __rp, \"\"); free(__rs); free(__rp); STRADA_MAKE_TAGGED_INT(__rm); })");
        }
        return;
    }

    # Fallback
    emit($cg, "strada_new_undef() /* TODO: binop " . $op . " */");
}

# --- Unary operations ---
func _gen_unop(scalar $cg, scalar $node) void {
    my str $op = $node->{"op"};

    # File test operators
    if ($op eq "-e" || $op eq "-f" || $op eq "-d" || $op eq "-r" || $op eq "-w" || $op eq "-x" || $op eq "-s" || $op eq "-z" || $op eq "-l" || $op eq "-T" || $op eq "-B" || $op eq "-t" || $op eq "-p" || $op eq "-S" || $op eq "-b" || $op eq "-c" || $op eq "-u" || $op eq "-g" || $op eq "-k" || $op eq "-o" || $op eq "-O" || $op eq "-R" || $op eq "-W" || $op eq "-X" || $op eq "-M" || $op eq "-A" || $op eq "-C") {
        # `-X _` reuses the previous stat. Detect bareword `_` operand
        # (parsed as N_CALL with name="_" and no args) and route through a
        # cached path. YAML::Tiny's `-e $f; -f _; -r _` idiom needs this:
        # without it, `-f _` checked a literal file named "_" which doesn't
        # exist, and YAML::Tiny falsely reported any real file as a directory.
        my int $is_stat_cache = 0;
        my scalar $op_arg = $node->{"operand"};
        if (defined($op_arg) && $op_arg->{"type"} == Perla::AST::N_CALL()
            && defined($op_arg->{"name"}) && $op_arg->{"name"} eq "_") {
            $is_stat_cache = 1;
        }
        if ($op eq "-e") {
            if ($is_stat_cache == 1) {
                emit($cg, "STRADA_MAKE_TAGGED_INT(perla_last_stat_path[0] ? strada_file_exists(perla_last_stat_path) : 0)");
            } else {
                emit($cg, "({ char *__fp = strada_to_str(");
                gen_expr($cg, $node->{"operand"});
                emit($cg, "); perla_remember_stat_path(__fp); StradaValue *__fr = STRADA_MAKE_TAGGED_INT(strada_file_exists(__fp)); free(__fp); __fr; })");
            }
        } elsif ($op eq "-f") {
            if ($is_stat_cache == 1) {
                emit($cg, "({ StradaValue *__fp = strada_new_str(perla_last_stat_path); StradaValue *__fr = strada_is_file(__fp); strada_decref(__fp); __fr; })");
            } else {
                emit($cg, "strada_is_file(");
                gen_expr($cg, $node->{"operand"});
                emit($cg, ")");
            }
        } elsif ($op eq "-d") {
            if ($is_stat_cache == 1) {
                emit($cg, "({ StradaValue *__fp = strada_new_str(perla_last_stat_path); StradaValue *__fr = strada_is_dir(__fp); strada_decref(__fp); __fr; })");
            } else {
                emit($cg, "strada_is_dir(");
                gen_expr($cg, $node->{"operand"});
                emit($cg, ")");
            }
        } elsif ($op eq "-s") {
            # Return size in bytes (or undef if file doesn't exist). The
            # `-e` fallthrough below made `-s $f` return 1/0, which broke
            # the common `read($fh, $buf, -s $f)` idiom for slurping a
            # file by its size — read(…, …, 1) returned one byte.
            if ($is_stat_cache == 1) {
                emit($cg, "({ struct stat __fs; StradaValue *__fr; if (perla_last_stat_path[0] && stat(perla_last_stat_path, &__fs) == 0) __fr = STRADA_MAKE_TAGGED_INT((int64_t)__fs.st_size); else __fr = strada_new_undef(); __fr; })");
            } else {
                emit($cg, "({ char *__fp = strada_to_str(");
                gen_expr($cg, $node->{"operand"});
                emit($cg, "); perla_remember_stat_path(__fp); struct stat __fs; StradaValue *__fr; if (stat(__fp, &__fs) == 0) __fr = STRADA_MAKE_TAGGED_INT((int64_t)__fs.st_size); else __fr = strada_new_undef(); free(__fp); __fr; })");
            }
        } elsif ($op eq "-z") {
            if ($is_stat_cache == 1) {
                emit($cg, "({ struct stat __fs; StradaValue *__fr; if (perla_last_stat_path[0] && stat(perla_last_stat_path, &__fs) == 0) __fr = STRADA_MAKE_TAGGED_INT(__fs.st_size == 0 ? 1 : 0); else __fr = strada_new_undef(); __fr; })");
            } else {
                emit($cg, "({ char *__fp = strada_to_str(");
                gen_expr($cg, $node->{"operand"});
                emit($cg, "); perla_remember_stat_path(__fp); struct stat __fs; StradaValue *__fr; if (stat(__fp, &__fs) == 0) __fr = STRADA_MAKE_TAGGED_INT(__fs.st_size == 0 ? 1 : 0); else __fr = strada_new_undef(); free(__fp); __fr; })");
            }
        } elsif ($op eq "-T" || $op eq "-B") {
            my str $fn = $op eq "-T" ? "strada_file_is_text" : "strada_file_is_binary";
            if ($is_stat_cache == 1) {
                emit($cg, "({ StradaValue *__fp = strada_new_str(perla_last_stat_path); perla_remember_stat_path(perla_last_stat_path); StradaValue *__fr = " . $fn . "(__fp); strada_decref(__fp); __fr; })");
            } else {
                emit($cg, $fn . "(");
                gen_expr($cg, $node->{"operand"});
                emit($cg, ")");
            }
        } elsif ($op eq "-l") {
            # Symlink test — uses lstat to avoid following.
            if ($is_stat_cache == 1) {
                emit($cg, "({ struct stat __fs; StradaValue *__fr; if (perla_last_stat_path[0] && lstat(perla_last_stat_path, &__fs) == 0 && S_ISLNK(__fs.st_mode)) __fr = STRADA_MAKE_TAGGED_INT(1); else __fr = STRADA_MAKE_TAGGED_INT(0); __fr; })");
            } else {
                emit($cg, "({ char *__fp = strada_to_str(");
                gen_expr($cg, $node->{"operand"});
                emit($cg, "); perla_remember_stat_path(__fp); struct stat __fs; StradaValue *__fr; if (lstat(__fp, &__fs) == 0 && S_ISLNK(__fs.st_mode)) __fr = STRADA_MAKE_TAGGED_INT(1); else __fr = STRADA_MAKE_TAGGED_INT(0); free(__fp); __fr; })");
            }
        } elsif ($op eq "-r" || $op eq "-w" || $op eq "-x") {
            # Use access(2) with appropriate mode flag.
            my str $mode = "R_OK";
            if ($op eq "-w") { $mode = "W_OK"; }
            elsif ($op eq "-x") { $mode = "X_OK"; }
            if ($is_stat_cache == 1) {
                emit($cg, "STRADA_MAKE_TAGGED_INT(perla_last_stat_path[0] ? (access(perla_last_stat_path, " . $mode . ") == 0 ? 1 : 0) : 0)");
            } else {
                emit($cg, "({ char *__fp = strada_to_str(");
                gen_expr($cg, $node->{"operand"});
                emit($cg, "); perla_remember_stat_path(__fp); StradaValue *__fr = STRADA_MAKE_TAGGED_INT(access(__fp, " . $mode . ") == 0 ? 1 : 0); free(__fp); __fr; })");
            }
        } elsif ($op eq "-t") {
            # -t FH: is filehandle a tty? Test fileno via isatty(3).
            emit($cg, "({ StradaValue *__tv = ");
            gen_expr($cg, $node->{"operand"});
            emit($cg, "; int __tfd = -1; ");
            emit($cg, "if (__tv && !STRADA_IS_TAGGED_INT(__tv) && __tv->type == STRADA_FILEHANDLE && __tv->value.fh) { __tfd = fileno(__tv->value.fh); } else if (__tv) { __tfd = (int)strada_to_int(__tv); } ");
            # Perl returns empty string for false (not 0), so use STR not int
            emit($cg, "StradaValue *__tr = (__tfd >= 0 && isatty(__tfd)) ? STRADA_MAKE_TAGGED_INT(1) : strada_new_str(\"\"); __tr; })");
        } elsif ($op eq "-p" || $op eq "-S" || $op eq "-b" || $op eq "-c") {
            # -p (FIFO), -S (socket), -b (block dev), -c (char dev)
            my str $macro = "S_ISFIFO";
            if    ($op eq "-S") { $macro = "S_ISSOCK"; }
            elsif ($op eq "-b") { $macro = "S_ISBLK"; }
            elsif ($op eq "-c") { $macro = "S_ISCHR"; }
            emit($cg, "({ char *__fp = strada_to_str(");
            gen_expr($cg, $node->{"operand"});
            emit($cg, "); perla_remember_stat_path(__fp); struct stat __fs; ");
            emit($cg, "StradaValue *__fr = (stat(__fp, &__fs) == 0 && " . $macro . "(__fs.st_mode)) ? STRADA_MAKE_TAGGED_INT(1) : strada_new_str(\"\"); free(__fp); __fr; })");
        } elsif ($op eq "-u" || $op eq "-g" || $op eq "-k") {
            # -u (setuid), -g (setgid), -k (sticky)
            my str $bit = "S_ISUID";
            if    ($op eq "-g") { $bit = "S_ISGID"; }
            elsif ($op eq "-k") { $bit = "S_ISVTX"; }
            emit($cg, "({ char *__fp = strada_to_str(");
            gen_expr($cg, $node->{"operand"});
            emit($cg, "); perla_remember_stat_path(__fp); struct stat __fs; ");
            emit($cg, "StradaValue *__fr = (stat(__fp, &__fs) == 0 && (__fs.st_mode & " . $bit . ")) ? STRADA_MAKE_TAGGED_INT(1) : strada_new_str(\"\"); free(__fp); __fr; })");
        } elsif ($op eq "-o" || $op eq "-O") {
            # -o (owned by effective uid), -O (owned by real uid)
            my str $uidfn = $op eq "-O" ? "getuid()" : "geteuid()";
            emit($cg, "({ char *__fp = strada_to_str(");
            gen_expr($cg, $node->{"operand"});
            emit($cg, "); perla_remember_stat_path(__fp); struct stat __fs; ");
            emit($cg, "StradaValue *__fr = (stat(__fp, &__fs) == 0 && __fs.st_uid == " . $uidfn . ") ? STRADA_MAKE_TAGGED_INT(1) : strada_new_str(\"\"); free(__fp); __fr; })");
        } elsif ($op eq "-R" || $op eq "-W" || $op eq "-X") {
            # Real-uid versions of -r/-w/-x. Use access(2) with AT_EACCESS
            # turned off — i.e. access() (not faccessat with effective).
            my str $accmode = "R_OK";
            if    ($op eq "-W") { $accmode = "W_OK"; }
            elsif ($op eq "-X") { $accmode = "X_OK"; }
            emit($cg, "({ char *__fp = strada_to_str(");
            gen_expr($cg, $node->{"operand"});
            emit($cg, "); StradaValue *__fr = (access(__fp, " . $accmode . ") == 0) ? STRADA_MAKE_TAGGED_INT(1) : strada_new_str(\"\"); free(__fp); __fr; })");
        } elsif ($op eq "-M" || $op eq "-A" || $op eq "-C") {
            # File age in days from script start time. -M = mtime,
            # -A = atime, -C = ctime. Returns (now - file_time) / 86400.0
            # in days as a num. Returns undef if stat fails.
            my str $field = "st_mtime";
            if    ($op eq "-A") { $field = "st_atime"; }
            elsif ($op eq "-C") { $field = "st_ctime"; }
            emit($cg, "({ char *__fp = strada_to_str(");
            gen_expr($cg, $node->{"operand"});
            emit($cg, "); perla_remember_stat_path(__fp); struct stat __fs; ");
            emit($cg, "StradaValue *__fr; if (stat(__fp, &__fs) == 0) { double __age = (double)(time(NULL) - __fs." . $field . ") / 86400.0; __fr = strada_new_num(__age); } else { __fr = strada_new_undef(); } free(__fp); __fr; })");
        } else {
            # Fallthrough: existence
            if ($is_stat_cache == 1) {
                emit($cg, "STRADA_MAKE_TAGGED_INT(perla_last_stat_path[0] ? strada_file_exists(perla_last_stat_path) : 0)");
            } else {
                emit($cg, "({ char *__fp = strada_to_str(");
                gen_expr($cg, $node->{"operand"});
                emit($cg, "); StradaValue *__fr = STRADA_MAKE_TAGGED_INT(strada_file_exists(__fp)); free(__fp); __fr; })");
            }
        }
        return;
    }

    if ($op eq "-") {
        # `-9223372036854775808` (i64 min) — the positive literal is
        # exactly INT64_MAX+1, which overflows i64 and the codegen
        # promotes it to NUM. Unary-minus-of-NUM then loses
        # integer precision (stringifies as -9.22e+18). Detect the
        # specific case and emit strada_new_int(INT64_MIN) directly.
        my scalar $umop = $node->{"operand"};
        if (defined($umop) && $umop->{"type"} == Perla::AST::N_INT_LIT()
            && defined($umop->{"value"}) && $umop->{"value"} eq "9223372036854775808") {
            emit($cg, "strada_new_int((int64_t)(-9223372036854775807LL - 1))");
            return;
        }
        # Unary minus on a blessed ref with `neg` overloaded dispatches
        # through the overload sub (perla_overload_binary with right=undef
        # is the same calling convention CPAN overload uses for unary).
        # When `neg` isn't defined, Perl falls back to `0 - $obj` which
        # fires the `-` overload with swap=1. Without that fallback,
        # classes that only define '-' (not 'neg') got the default
        # pointer-as-int garbage when negated.
        #
        # For integer operands (tagged ints or heap INT), negate as
        # integer so the result keeps integer precision and
        # stringification. Without this, `-9223372036854775807` was
        # converted to double via strada_to_num and stringified as
        # \`-9.22e+18\` instead of the exact int. Special-case
        # INT64_MIN (where -val overflows i64): promote to NUM as
        # the only safe representation.
        emit($cg, "({ StradaValue *__nv = ");
        gen_expr($cg, $node->{"operand"});
        emit($cg, "; StradaValue *__nr = NULL; ");
        emit($cg, "if (__nv && !STRADA_IS_TAGGED_INT(__nv) && __nv->type == STRADA_REF) { ");
        emit($cg, "  __nr = perla_overload_binary(__nv, strada_new_undef(), \"neg\"); ");
        emit($cg, "  if (!__nr) __nr = perla_overload_binary(STRADA_MAKE_TAGGED_INT(0), __nv, \"-\"); } ");
        emit($cg, "if (!__nr) { ");
        emit($cg, "  if (STRADA_IS_TAGGED_INT(__nv)) { ");
        emit($cg, "    int64_t __ni = STRADA_TAGGED_INT_VAL(__nv); ");
        emit($cg, "    if (__ni == INT64_MIN) { __nr = strada_new_num(-(double)__ni); } ");
        emit($cg, "    else { __nr = STRADA_MAKE_TAGGED_INT(-__ni); } ");
        emit($cg, "  } else if (__nv && __nv->type == STRADA_INT) { ");
        emit($cg, "    int64_t __ni = __nv->value.iv; ");
        emit($cg, "    if (__ni == INT64_MIN) { __nr = strada_new_num(-(double)__ni); } ");
        emit($cg, "    else { __nr = strada_new_int(-__ni); } ");
        emit($cg, "  } ");
        emit($cg, "} ");
        # Perl's \"string negation\": if the operand is a string that
        # doesn't look numeric, `-\"foo\"` returns `\"-foo\"` (prepend
        # a `-`). If it already starts with `-`, strip the `-`. If it
        # starts with `+`, replace with `-`. Numeric-looking strings
        # fall through to the numeric path below. Only kicks in when
        # __nv is a string AND strada_to_num returns 0 AND the string
        # isn't a numeric \"0\"/\"0.0\"/etc. — i.e. genuinely alpha.
        emit($cg, "if (!__nr && __nv && !STRADA_IS_TAGGED_INT(__nv) && __nv->type == STRADA_STR && __nv->value.pv) { ");
        emit($cg, "  const char *__nvs = __nv->value.pv; size_t __nvslen = strlen(__nvs); ");
        emit($cg, "  /* Skip leading whitespace for the numeric-ish check. */ ");
        emit($cg, "  const char *__nvscan = __nvs; while (*__nvscan == ' ' || *__nvscan == '\\t') __nvscan++; ");
        emit($cg, "  int __nvc = (unsigned char)*__nvscan; ");
        emit($cg, "  int __nvc_is_digit_like = (__nvc >= '0' && __nvc <= '9') || __nvc == '.' || __nvc == 'e' || __nvc == 'E'; ");
        emit($cg, "  if (!__nvc_is_digit_like) { ");
        /* Per perlop on unary minus: leading `-` becomes `+`, leading
         * `+` becomes `-`, otherwise the result is `-` prepended to
         * the identifier-like string. -\"foo\" = \"-foo\", -\"-foo\" =
         * \"+foo\", -\"+foo\" = \"-foo\". */
        emit($cg, "    if (__nvc == '-') { char *__buf = malloc(__nvslen + 1); if (__buf) { memcpy(__buf, __nvs, __nvslen + 1); __buf[0] = '+'; __nr = strada_new_str(__buf); free(__buf); } } ");
        emit($cg, "    else if (__nvc == '+') { char *__buf = malloc(__nvslen + 1); if (__buf) { memcpy(__buf, __nvs, __nvslen + 1); __buf[0] = '-'; __nr = strada_new_str(__buf); free(__buf); } } ");
        emit($cg, "    else if (__nvc != 0) { char *__buf = malloc(__nvslen + 2); if (__buf) { __buf[0] = '-'; memcpy(__buf + 1, __nvs, __nvslen + 1); __nr = strada_new_str(__buf); free(__buf); } } ");
        emit($cg, "  } ");
        emit($cg, "} ");
        emit($cg, "__nr ? __nr : strada_new_num(-strada_to_num(__nv)); })");
        return;
    }
    if ($op eq "!" || $op eq "not") {
        # Perl: !TRUTHY returns "" (defined empty), !FALSY returns "1".
        # Was emitting STRADA_MAKE_TAGGED_INT(0/1), so `print !"foo"`
        # showed "0" instead of "".
        #
        # Overload: blessed refs with `'!'` overload bypass the
        # default truthiness — the user sub gets called. Falls through
        # to the default boolean for non-refs (and refs without an
        # explicit `'!'` overload). Use a statement-expression so the
        # overload short-circuit path can early-return its value.
        emit($cg, "({ StradaValue *__nlv = ");
        gen_expr($cg, $node->{"operand"});
        emit($cg, "; StradaValue *__nlr = NULL; ");
        emit($cg, "if (__nlv && !STRADA_IS_TAGGED_INT(__nlv) && __nlv->type == STRADA_REF) { ");
        emit($cg, "  __nlr = perla_overload_binary(__nlv, strada_new_undef(), \"!\"); } ");
        emit($cg, "__nlr ? __nlr : (perla_to_bool(__nlv) ? strada_new_str(\"\") : STRADA_MAKE_TAGGED_INT(1)); })");
        return;
    }
    if ($op eq "~") {
        # Overload dispatch: `use overload '~' => sub {...}` on a blessed
        # ref fires before the default bitwise-not. Without this, `~$obj`
        # collapsed to `~strada_to_int(ref)` = `~0` = -1.
        #
        # Perl's bitwise-not on a non-negative integer uses UNSIGNED
        # 64-bit semantics: `~5` is `0xFFFFFFFFFFFFFFFA` = 18446744073709551610.
        # i.e. all-bits-flipped of the u64 value, not the signed
        # -val-1. Wrap the value as NUM since u64 max doesn't fit
        # i64; a tagged-int couldn't represent it. Negative i64 input
        # falls through to the signed path (perl's behavior is
        # symmetric there: ~(-1) = 0, ~INT_MIN = INT_MAX).
        emit($cg, "({ StradaValue *__nv = ");
        gen_expr($cg, $node->{"operand"});
        emit($cg, "; StradaValue *__ovr = NULL; ");
        emit($cg, "if (__nv && !STRADA_IS_TAGGED_INT(__nv) && __nv->type == STRADA_REF) { ");
        emit($cg, "  __ovr = perla_overload_binary(__nv, strada_undef_static(), \"~\"); } ");
        emit($cg, "StradaValue *__nrr = __ovr; ");
        emit($cg, "if (!__nrr) { int64_t __nvi = strada_to_int(__nv); ");
        emit($cg, "  if (__nvi >= 0) { uint64_t __nvu = ~(uint64_t)__nvi; ");
        emit($cg, "    if (__nvu <= (uint64_t)INT64_MAX) __nrr = STRADA_MAKE_TAGGED_INT((int64_t)__nvu); ");
        # Above INT64_MAX, the all-bits-flipped value is a true unsigned
        # 64-bit integer — store it as a UV (strada_new_uint) so it prints
        # the exact decimal AND behaves as an integer in arithmetic. (It
        # used to be stored as a decimal string to dodge the missing UV
        # type; that round-tripped through perl's string-numeric coercion
        # but lost integer typing.)
        emit($cg, "    else { __nrr = strada_new_uint(__nvu); } } ");
        emit($cg, "  else __nrr = STRADA_MAKE_TAGGED_INT(~__nvi); } __nrr; })");
        return;
    }
    # Postfix ++
    if ($op eq "++" && defined($node->{"postfix"}) && $node->{"postfix"} == 1) {
        my int $op_type = $node->{"operand"}->{"type"};
        if ($op_type == Perla::AST::N_ARROW_HASH() || $op_type == Perla::AST::N_HASH_ELEM()) {
            _gen_hash_postfix_inc_dec($cg, $node->{"operand"}, "+");
        } elsif ($op_type == Perla::AST::N_ARRAY_ELEM() || $op_type == Perla::AST::N_ARROW_ARRAY()) {
            emit($cg, "({ StradaArray *__pi_av = strada_deref_array(");
            my scalar $pi_an = ($op_type == Perla::AST::N_ARRAY_ELEM()) ? $node->{"operand"}->{"array"} : $node->{"operand"}->{"object"};
            my int $pi_is_arrow = 0;
            if (defined($node->{"operand"}->{"is_explicit_arrow"}) && $node->{"operand"}->{"is_explicit_arrow"} == 1) { $pi_is_arrow = 1; }
            if ($pi_is_arrow == 0
                && defined($pi_an) && $pi_an->{"type"} == Perla::AST::N_SCALAR_VAR()
                && defined($pi_an->{"name"}) && $pi_an->{"name"} eq "_") {
                emit($cg, "perla_at_");
            } elsif ($pi_is_arrow == 0
                && defined($pi_an) && $pi_an->{"type"} == Perla::AST::N_SCALAR_VAR()
                && defined($pi_an->{"name"}) && index($pi_an->{"name"}, "::") > 0) {
                my array @pipn = _split_pkg_qual_name($pi_an);
                emit($cg, "perla_array_get(\"" . $pipn[0] . "\", \"" . $pipn[1] . "\")");
            } else {
                gen_expr($cg, $pi_an);
            }
            emit($cg, "); int __pi_idx = (int)strada_to_int(");
            gen_expr($cg, $node->{"operand"}->{"index"});
            emit($cg, "); if (__pi_idx < 0 && __pi_av) __pi_idx += strada_array_length(__pi_av); ");
            emit($cg, "StradaValue *__pi_old = strada_array_get(__pi_av, __pi_idx); strada_incref(__pi_old); ");
            emit($cg, "StradaValue *__pi_new = STRADA_MAKE_TAGGED_INT(strada_to_int(__pi_old) + 1); ");
            emit($cg, "strada_array_set(__pi_av, __pi_idx, __pi_new); __pi_old; })");
        } elsif ($op_type == Perla::AST::N_DEREF_SCALAR()) {
            # ${EXPR}++ — eval EXPR to a scalar ref, read/write via the
            # ref's target. Two cases:
            #  - slot ref (`\$var`): write directly through the slot.
            #  - value ref: snapshot OLD value first (do not alias __tgt),
            #    then overwrite the target in place.
            # The alias bug (`__old = __tgt; ... overwrite_in_place(__tgt)`)
            # made `${$r}++` return the NEW value instead of the OLD.
            emit($cg, "({ StradaValue *__dref = ");
            gen_expr($cg, $node->{"operand"}->{"ref"});
            emit($cg, "; StradaValue *__old = NULL; ");
            emit($cg, "if (__dref && !STRADA_IS_TAGGED_INT(__dref) && __dref->type == STRADA_REF) { ");
            emit($cg, "  if (strada_is_slot_ref(__dref)) { ");
            emit($cg, "    StradaValue **__slot = (StradaValue**)__dref->value.ptr; ");
            emit($cg, "    __old = *__slot; if (__old) strada_incref(__old); ");
            emit($cg, "    StradaValue *__nv = perla_increment(__old); ");
            emit($cg, "    if (*__slot) strada_decref(*__slot); *__slot = __nv; ");
            emit($cg, "  } else if (__dref->value.rv) { ");
            emit($cg, "    StradaValue *__tgt = __dref->value.rv; ");
            emit($cg, "    __old = strada_new_undef(); strada_overwrite_in_place(__old, __tgt); ");
            emit($cg, "    StradaValue *__nv = perla_increment(__tgt); ");
            emit($cg, "    strada_overwrite_in_place(__tgt, __nv); strada_decref(__nv); ");
            emit($cg, "  } ");
            emit($cg, "} ");
            emit($cg, "if (!__old) __old = strada_new_undef(); __old; })");
        } else {
            if (_is_pkg_qualified_scalar($node->{"operand"}) == 1) {
                _emit_pkg_scalar_inc_postfix($cg, $node->{"operand"}, "+");
            } else {
                # Use perla_increment (magic string-or-number inc) to
                # match Perl's `$s = "a"; $s++` → "b" semantics. Old
                # codegen always truncated to int (so "a"++ → 1).
                # Tied-scalar dispatch: when $x is a tied SV, $x++ should
                # FETCH the pre-inc value (returned), increment it, and
                # STORE the new value through the tied object — keeping
                # the tied SV in the slot. Without this, ++ replaced
                # the tied SV with a raw value and subsequent ops missed
                # the tie entirely.
                emit($cg, "({ StradaValue *__old = ");
                gen_expr($cg, $node->{"operand"});
                emit($cg, "; if (__old) strada_incref(__old); ");
                emit($cg, "if (__builtin_expect(__old && !STRADA_IS_TAGGED_INT(__old) && __old->meta && __old->meta->is_tied, 0)) { ");
                emit($cg, "  StradaValue *__fold = strada_tied_scalar_fetch(__old); ");
                emit($cg, "  StradaValue *__inc = perla_increment(__fold); ");
                emit($cg, "  strada_tied_scalar_store(__old, __inc); strada_decref(__inc); ");
                emit($cg, "  strada_decref(__old); __old = __fold; ");
                emit($cg, "} else { ");
                gen_expr($cg, $node->{"operand"});
                emit($cg, " = perla_increment(__old)");
                _emit_our_sync($cg, $node->{"operand"});
                emit($cg, "; } __old; })");
            }
        }
        return;
    }
    # Postfix --
    if ($op eq "--" && defined($node->{"postfix"}) && $node->{"postfix"} == 1) {
        my int $op_type = $node->{"operand"}->{"type"};
        if ($op_type == Perla::AST::N_ARROW_HASH() || $op_type == Perla::AST::N_HASH_ELEM()) {
            _gen_hash_postfix_inc_dec($cg, $node->{"operand"}, "-");
        } elsif ($op_type == Perla::AST::N_ARRAY_ELEM() || $op_type == Perla::AST::N_ARROW_ARRAY()) {
            emit($cg, "({ StradaArray *__pi_av = strada_deref_array(");
            my scalar $pd_an = ($op_type == Perla::AST::N_ARRAY_ELEM()) ? $node->{"operand"}->{"array"} : $node->{"operand"}->{"object"};
            my int $pd_is_arrow = 0;
            if (defined($node->{"operand"}->{"is_explicit_arrow"}) && $node->{"operand"}->{"is_explicit_arrow"} == 1) { $pd_is_arrow = 1; }
            if ($pd_is_arrow == 0
                && defined($pd_an) && $pd_an->{"type"} == Perla::AST::N_SCALAR_VAR()
                && defined($pd_an->{"name"}) && $pd_an->{"name"} eq "_") {
                emit($cg, "perla_at_");
            } elsif ($pd_is_arrow == 0
                && defined($pd_an) && $pd_an->{"type"} == Perla::AST::N_SCALAR_VAR()
                && defined($pd_an->{"name"}) && index($pd_an->{"name"}, "::") > 0) {
                my array @pdpn = _split_pkg_qual_name($pd_an);
                emit($cg, "perla_array_get(\"" . $pdpn[0] . "\", \"" . $pdpn[1] . "\")");
            } else {
                gen_expr($cg, $pd_an);
            }
            emit($cg, "); int __pi_idx = (int)strada_to_int(");
            gen_expr($cg, $node->{"operand"}->{"index"});
            emit($cg, "); if (__pi_idx < 0 && __pi_av) __pi_idx += strada_array_length(__pi_av); ");
            emit($cg, "StradaValue *__pi_old = strada_array_get(__pi_av, __pi_idx); strada_incref(__pi_old); ");
            emit($cg, "StradaValue *__pi_new = STRADA_MAKE_TAGGED_INT(strada_to_int(__pi_old) - 1); ");
            emit($cg, "strada_array_set(__pi_av, __pi_idx, __pi_new); __pi_old; })");
        } elsif ($op_type == Perla::AST::N_DEREF_SCALAR()) {
            # ${EXPR}-- — mirrors postfix ++ DEREF_SCALAR. Return OLD value.
            emit($cg, "({ StradaValue *__dref = ");
            gen_expr($cg, $node->{"operand"}->{"ref"});
            emit($cg, "; StradaValue *__old = NULL; ");
            emit($cg, "if (__dref && !STRADA_IS_TAGGED_INT(__dref) && __dref->type == STRADA_REF) { ");
            emit($cg, "  if (strada_is_slot_ref(__dref)) { ");
            emit($cg, "    StradaValue **__slot = (StradaValue**)__dref->value.ptr; ");
            emit($cg, "    __old = *__slot; if (__old) strada_incref(__old); ");
            emit($cg, "    StradaValue *__nv = STRADA_MAKE_TAGGED_INT(strada_to_int(__old) - 1); ");
            emit($cg, "    if (*__slot) strada_decref(*__slot); *__slot = __nv; ");
            emit($cg, "  } else if (__dref->value.rv) { ");
            emit($cg, "    StradaValue *__tgt = __dref->value.rv; ");
            emit($cg, "    __old = strada_new_undef(); strada_overwrite_in_place(__old, __tgt); ");
            emit($cg, "    StradaValue *__nv = STRADA_MAKE_TAGGED_INT(strada_to_int(__tgt) - 1); ");
            emit($cg, "    strada_overwrite_in_place(__tgt, __nv); strada_decref(__nv); ");
            emit($cg, "  } ");
            emit($cg, "} ");
            emit($cg, "if (!__old) __old = strada_new_undef(); __old; })");
        } else {
            if (_is_pkg_qualified_scalar($node->{"operand"}) == 1) {
                _emit_pkg_scalar_inc_postfix($cg, $node->{"operand"}, "-");
            } else {
                # Use perla_decrement so overloaded `--` dispatches on
                # blessed refs (CPAN overload's '--' slot). Tagged ints
                # and plain numbers stay on the fast path inside the
                # helper. Tied-scalar dispatch — see postfix ++.
                emit($cg, "({ StradaValue *__old = ");
                gen_expr($cg, $node->{"operand"});
                emit($cg, "; if (__old) strada_incref(__old); ");
                emit($cg, "if (__builtin_expect(__old && !STRADA_IS_TAGGED_INT(__old) && __old->meta && __old->meta->is_tied, 0)) { ");
                emit($cg, "  StradaValue *__fold = strada_tied_scalar_fetch(__old); ");
                emit($cg, "  StradaValue *__dec = perla_decrement(__fold); ");
                emit($cg, "  strada_tied_scalar_store(__old, __dec); strada_decref(__dec); ");
                emit($cg, "  strada_decref(__old); __old = __fold; ");
                emit($cg, "} else { ");
                gen_expr($cg, $node->{"operand"});
                emit($cg, " = perla_decrement(__old)");
                _emit_our_sync($cg, $node->{"operand"});
                emit($cg, "; } __old; })");
            }
        }
        return;
    }
    # Prefix ++
    if ($op eq "++" && defined($node->{"prefix"}) && $node->{"prefix"} == 1) {
        my int $op_type = $node->{"operand"}->{"type"};
        if ($op_type == Perla::AST::N_ARROW_HASH() || $op_type == Perla::AST::N_HASH_ELEM()) {
            _gen_hash_compound_assign($cg, $node->{"operand"}, "+", Perla::AST::node_with(Perla::AST::N_INT_LIT(), "value", "1"));
        } elsif ($op_type == Perla::AST::N_ARRAY_ELEM() || $op_type == Perla::AST::N_ARROW_ARRAY()) {
            # ++$arr[i] or ++$ref->[i]: read-modify-write via array_set.
            emit($cg, "({ StradaArray *__pi_av = strada_deref_array(");
            my scalar $pre_an = ($op_type == Perla::AST::N_ARRAY_ELEM()) ? $node->{"operand"}->{"array"} : $node->{"operand"}->{"object"};
            my int $pre_is_arrow = 0;
            if (defined($node->{"operand"}->{"is_explicit_arrow"}) && $node->{"operand"}->{"is_explicit_arrow"} == 1) { $pre_is_arrow = 1; }
            if ($pre_is_arrow == 0
                && defined($pre_an) && $pre_an->{"type"} == Perla::AST::N_SCALAR_VAR()
                && defined($pre_an->{"name"}) && $pre_an->{"name"} eq "_") {
                emit($cg, "perla_at_");
            } elsif ($pre_is_arrow == 0
                && defined($pre_an) && $pre_an->{"type"} == Perla::AST::N_SCALAR_VAR()
                && defined($pre_an->{"name"}) && index($pre_an->{"name"}, "::") > 0) {
                my array @prepn = _split_pkg_qual_name($pre_an);
                emit($cg, "perla_array_get(\"" . $prepn[0] . "\", \"" . $prepn[1] . "\")");
            } else {
                gen_expr($cg, $pre_an);
            }
            emit($cg, "); int __pi_idx = (int)strada_to_int(");
            gen_expr($cg, $node->{"operand"}->{"index"});
            emit($cg, "); if (__pi_idx < 0 && __pi_av) __pi_idx += strada_array_length(__pi_av); ");
            emit($cg, "StradaValue *__pi_new = STRADA_MAKE_TAGGED_INT(strada_to_int(strada_array_get(__pi_av, __pi_idx)) + 1); ");
            emit($cg, "strada_array_set(__pi_av, __pi_idx, __pi_new); __pi_new; })");
        } elsif ($op_type == Perla::AST::N_DEREF_SCALAR()) {
            # ++${EXPR} — increment and return the NEW value.
            emit($cg, "({ StradaValue *__dref = ");
            gen_expr($cg, $node->{"operand"}->{"ref"});
            emit($cg, "; StradaValue *__ret = NULL; ");
            emit($cg, "if (__dref && !STRADA_IS_TAGGED_INT(__dref) && __dref->type == STRADA_REF) { ");
            emit($cg, "  if (strada_is_slot_ref(__dref)) { ");
            emit($cg, "    StradaValue **__slot = (StradaValue**)__dref->value.ptr; ");
            emit($cg, "    StradaValue *__nv = perla_increment(*__slot); ");
            emit($cg, "    if (*__slot) strada_decref(*__slot); *__slot = __nv; ");
            emit($cg, "    strada_incref(__nv); __ret = __nv; ");
            emit($cg, "  } else if (__dref->value.rv) { ");
            emit($cg, "    StradaValue *__tgt = __dref->value.rv; ");
            emit($cg, "    StradaValue *__nv = perla_increment(__tgt); ");
            emit($cg, "    strada_overwrite_in_place(__tgt, __nv); strada_decref(__nv); ");
            emit($cg, "    strada_incref(__tgt); __ret = __tgt; ");
            emit($cg, "  } ");
            emit($cg, "} ");
            emit($cg, "if (!__ret) __ret = strada_new_undef(); __ret; })");
        } else {
            if (_is_pkg_qualified_scalar($node->{"operand"}) == 1) {
                _emit_pkg_scalar_inc_prefix($cg, $node->{"operand"}, "+");
            } else if (_is_our_unqual_scalar($cg, $node->{"operand"}) == 1) {
                # Wrap in a statement-expression so we can sync after.
                emit($cg, "({ ");
                gen_expr($cg, $node->{"operand"});
                emit($cg, " = perla_increment(");
                gen_expr($cg, $node->{"operand"});
                emit($cg, ")");
                _emit_our_sync($cg, $node->{"operand"});
                emit($cg, "; ");
                gen_expr($cg, $node->{"operand"});
                emit($cg, "; })");
            } else {
                # Use perla_increment for magic string-or-number inc.
                # Tied-scalar dispatch (see postfix ++ for rationale):
                # ++tied fetches → increments → stores → returns new.
                emit($cg, "({ StradaValue *__tg = ");
                gen_expr($cg, $node->{"operand"});
                emit($cg, "; StradaValue *__r; ");
                emit($cg, "if (__builtin_expect(__tg && !STRADA_IS_TAGGED_INT(__tg) && __tg->meta && __tg->meta->is_tied, 0)) { ");
                emit($cg, "  StradaValue *__fold = strada_tied_scalar_fetch(__tg); ");
                emit($cg, "  StradaValue *__inc = perla_increment(__fold); ");
                emit($cg, "  strada_tied_scalar_store(__tg, __inc); ");
                emit($cg, "  strada_decref(__fold); __r = __inc; ");
                emit($cg, "} else { ");
                gen_expr($cg, $node->{"operand"});
                emit($cg, " = perla_increment(__tg); __r = ");
                gen_expr($cg, $node->{"operand"});
                emit($cg, "; } __r; })");
            }
        }
        return;
    }
    # Prefix --
    if ($op eq "--" && defined($node->{"prefix"}) && $node->{"prefix"} == 1) {
        my int $op_type = $node->{"operand"}->{"type"};
        if ($op_type == Perla::AST::N_ARROW_HASH() || $op_type == Perla::AST::N_HASH_ELEM()) {
            _gen_hash_compound_assign($cg, $node->{"operand"}, "-", Perla::AST::node_with(Perla::AST::N_INT_LIT(), "value", "1"));
        } elsif ($op_type == Perla::AST::N_ARRAY_ELEM() || $op_type == Perla::AST::N_ARROW_ARRAY()) {
            # --$arr[i] or --$ref->[i]: read-modify-write via array_set.
            emit($cg, "({ StradaArray *__pi_av = strada_deref_array(");
            my scalar $prd_an = ($op_type == Perla::AST::N_ARRAY_ELEM()) ? $node->{"operand"}->{"array"} : $node->{"operand"}->{"object"};
            my int $prd_is_arrow = 0;
            if (defined($node->{"operand"}->{"is_explicit_arrow"}) && $node->{"operand"}->{"is_explicit_arrow"} == 1) { $prd_is_arrow = 1; }
            if ($prd_is_arrow == 0
                && defined($prd_an) && $prd_an->{"type"} == Perla::AST::N_SCALAR_VAR()
                && defined($prd_an->{"name"}) && $prd_an->{"name"} eq "_") {
                emit($cg, "perla_at_");
            } elsif ($prd_is_arrow == 0
                && defined($prd_an) && $prd_an->{"type"} == Perla::AST::N_SCALAR_VAR()
                && defined($prd_an->{"name"}) && index($prd_an->{"name"}, "::") > 0) {
                my array @prdpn = _split_pkg_qual_name($prd_an);
                emit($cg, "perla_array_get(\"" . $prdpn[0] . "\", \"" . $prdpn[1] . "\")");
            } else {
                gen_expr($cg, $prd_an);
            }
            emit($cg, "); int __pi_idx = (int)strada_to_int(");
            gen_expr($cg, $node->{"operand"}->{"index"});
            emit($cg, "); if (__pi_idx < 0 && __pi_av) __pi_idx += strada_array_length(__pi_av); ");
            emit($cg, "StradaValue *__pi_new = STRADA_MAKE_TAGGED_INT(strada_to_int(strada_array_get(__pi_av, __pi_idx)) - 1); ");
            emit($cg, "strada_array_set(__pi_av, __pi_idx, __pi_new); __pi_new; })");
        } elsif ($op_type == Perla::AST::N_DEREF_SCALAR()) {
            # --${EXPR} — decrement and return the NEW value.
            emit($cg, "({ StradaValue *__dref = ");
            gen_expr($cg, $node->{"operand"}->{"ref"});
            emit($cg, "; StradaValue *__ret = NULL; ");
            emit($cg, "if (__dref && !STRADA_IS_TAGGED_INT(__dref) && __dref->type == STRADA_REF) { ");
            emit($cg, "  if (strada_is_slot_ref(__dref)) { ");
            emit($cg, "    StradaValue **__slot = (StradaValue**)__dref->value.ptr; ");
            emit($cg, "    StradaValue *__nv = STRADA_MAKE_TAGGED_INT(strada_to_int(*__slot) - 1); ");
            emit($cg, "    if (*__slot) strada_decref(*__slot); *__slot = __nv; ");
            emit($cg, "    strada_incref(__nv); __ret = __nv; ");
            emit($cg, "  } else if (__dref->value.rv) { ");
            emit($cg, "    StradaValue *__tgt = __dref->value.rv; ");
            emit($cg, "    StradaValue *__nv = STRADA_MAKE_TAGGED_INT(strada_to_int(__tgt) - 1); ");
            emit($cg, "    strada_overwrite_in_place(__tgt, __nv); strada_decref(__nv); ");
            emit($cg, "    strada_incref(__tgt); __ret = __tgt; ");
            emit($cg, "  } ");
            emit($cg, "} ");
            emit($cg, "if (!__ret) __ret = strada_new_undef(); __ret; })");
        } else {
            if (_is_pkg_qualified_scalar($node->{"operand"}) == 1) {
                _emit_pkg_scalar_inc_prefix($cg, $node->{"operand"}, "-");
            } else if (_is_our_unqual_scalar($cg, $node->{"operand"}) == 1) {
                # Use perla_decrement so blessed-ref `--` overload fires.
                # Without this, `--$obj` collapsed to
                # `$obj = STRADA_MAKE_TAGGED_INT(0 - 1)` = -1, clobbering
                # the blessed ref with a plain int.
                emit($cg, "({ ");
                gen_expr($cg, $node->{"operand"});
                emit($cg, " = perla_decrement(");
                gen_expr($cg, $node->{"operand"});
                emit($cg, ")");
                _emit_our_sync($cg, $node->{"operand"});
                emit($cg, "; ");
                gen_expr($cg, $node->{"operand"});
                emit($cg, "; })");
            } else {
                # See comment above re: perla_decrement.
                # Tied-scalar dispatch (see postfix ++ for rationale).
                emit($cg, "({ StradaValue *__tg = ");
                gen_expr($cg, $node->{"operand"});
                emit($cg, "; StradaValue *__r; ");
                emit($cg, "if (__builtin_expect(__tg && !STRADA_IS_TAGGED_INT(__tg) && __tg->meta && __tg->meta->is_tied, 0)) { ");
                emit($cg, "  StradaValue *__fold = strada_tied_scalar_fetch(__tg); ");
                emit($cg, "  StradaValue *__dec = perla_decrement(__fold); ");
                emit($cg, "  strada_tied_scalar_store(__tg, __dec); ");
                emit($cg, "  strada_decref(__fold); __r = __dec; ");
                emit($cg, "} else { ");
                gen_expr($cg, $node->{"operand"});
                emit($cg, " = perla_decrement(__tg); __r = ");
                gen_expr($cg, $node->{"operand"});
                emit($cg, "; } __r; })");
            }
        }
        return;
    }
    # Unary `+EXPR` — Perl uses this to disambiguate parsing (e.g. inside
    # a hash subscript: `$h->{+shift}` is `$h->{shift}` not the literal key
    # "shift"). Semantically a no-op in scalar context — just evaluate the
    # operand and pass through.
    if ($op eq "+") {
        gen_expr($cg, $node->{"operand"});
        return;
    }
    emit($cg, "strada_new_undef() /* TODO: unop " . $op . " */");
}

# Package-qualified scalar var? `$Pkg::Name` is read via perla_scalar_get
# (a function call, NOT an lvalue), so ++/-- can't use the standard
# `lvalue = NEW` pattern. These helpers route writes through perla_scalar_set.
func _is_pkg_qualified_scalar(scalar $node) int {
    if (!defined($node)) { return 0; }
    if ($node->{"type"} != Perla::AST::N_SCALAR_VAR()) { return 0; }
    if (!defined($node->{"name"})) { return 0; }
    if (index($node->{"name"}, "::") > 0) { return 1; }
    return 0;
}

# True when the operand is an unqualified scalar var declared `our` in
# the current package. Used to gate the stash-sync emit after a mutation
# (`$x++`, `++$x`, etc.) so external `$Pkg::x` readers see the updated
# value.
func _is_our_unqual_scalar(scalar $cg, scalar $node) int {
    if (!defined($node)) { return 0; }
    if ($node->{"type"} != Perla::AST::N_SCALAR_VAR()) { return 0; }
    if (!defined($node->{"name"})) { return 0; }
    my str $vn = $node->{"name"};
    if (index($vn, "::") >= 0) { return 0; }
    if (!defined($cg->{"our_vars"})) { return 0; }
    if (!exists($cg->{"our_vars"}->{$vn})) { return 0; }
    return 1;
}

# Emit a stash-sync call after a mutation of an unqualified our-var.
# Caller has already updated v_VNAME; this writes the same value into
# the package stash so `$Pkg::VNAME` readers stay in sync.
func _emit_our_sync(scalar $cg, scalar $node) void {
    if (_is_our_unqual_scalar($cg, $node) == 0) { return; }
    my str $vn = $node->{"name"};
    my str $pkg = $cg->{"pkg"};
    emit($cg, "; perla_scalar_set(\"" . $pkg . "\", \"" . $vn . "\", " . c_var($vn) . ")");
}

# Split "Pkg::Name" into ($pkg, $name); writes into $cg slots so caller can read.
func _split_pkg_qual_name(scalar $node) array {
    my str $qn = $node->{"name"};
    my int $li = -1;
    my int $si = 0;
    while ($si < length($qn) - 1) {
        if (substr($qn, $si, 2) eq "::") { $li = $si; }
        $si++;
    }
    my str $pkg = substr($qn, 0, $li);
    my str $name = substr($qn, $li + 2, length($qn) - $li - 2);
    my array @r = ($pkg, $name);
    return @r;
}

# Emit postfix ++/-- for $Pkg::Name as ({ __old = get; set(old+/-1); __old; }).
func _emit_pkg_scalar_inc_postfix(scalar $cg, scalar $node, str $sign) void {
    my array @pn = _split_pkg_qual_name($node);
    my str $pkg = $pn[0];
    my str $name = $pn[1];
    emit($cg, "({ StradaValue *__old = perla_scalar_get(\"" . $pkg . "\", \"" . $name . "\"); ");
    emit($cg, "perla_scalar_set(\"" . $pkg . "\", \"" . $name . "\", STRADA_MAKE_TAGGED_INT(strada_to_int(__old) " . $sign . " 1)); __old; })");
}

# Emit prefix ++/-- for $Pkg::Name as ({ __new = get+/-1; set(__new); __new; }).
func _emit_pkg_scalar_inc_prefix(scalar $cg, scalar $node, str $sign) void {
    my array @pn = _split_pkg_qual_name($node);
    my str $pkg = $pn[0];
    my str $name = $pn[1];
    emit($cg, "({ StradaValue *__new = STRADA_MAKE_TAGGED_INT(strada_to_int(perla_scalar_get(\"" . $pkg . "\", \"" . $name . "\")) " . $sign . " 1); ");
    emit($cg, "perla_scalar_set(\"" . $pkg . "\", \"" . $name . "\", __new); __new; })");
}

# Emit `$Pkg::Name OP= VALUE` compound assign via perla_scalar_set, since
# perla_scalar_get is a function call (rvalue), not a C lvalue.
# `$op` is one of "+", "-", "*", "/", "%", "**", ".".
func _emit_pkg_scalar_compound(scalar $cg, scalar $node, str $op, scalar $value) void {
    my array @pn = _split_pkg_qual_name($node);
    my str $pkg = $pn[0];
    my str $name = $pn[1];
    emit($cg, "({ StradaValue *__cur = perla_scalar_get(\"" . $pkg . "\", \"" . $name . "\"); ");
    emit($cg, "StradaValue *__rhs = ");
    gen_expr($cg, $value);
    emit($cg, "; StradaValue *__nv = ");
    if ($op eq "+") {
        emit($cg, "strada_new_num(strada_to_num(__cur) + strada_to_num(__rhs))");
    } elsif ($op eq "-") {
        emit($cg, "strada_new_num(strada_to_num(__cur) - strada_to_num(__rhs))");
    } elsif ($op eq "*") {
        emit($cg, "strada_new_num(strada_to_num(__cur) * strada_to_num(__rhs))");
    } elsif ($op eq "/") {
        emit($cg, "strada_new_num(strada_to_num(__cur) / strada_to_num(__rhs))");
    } elsif ($op eq "%") {
        emit($cg, "STRADA_MAKE_TAGGED_INT(strada_to_int(__cur) % strada_to_int(__rhs))");
    } elsif ($op eq "**") {
        emit($cg, "strada_new_num(pow(strada_to_num(__cur), strada_to_num(__rhs)))");
    } elsif ($op eq ".") {
        emit($cg, "strada_concat_sv(__cur, __rhs)");
    } else {
        emit($cg, "strada_new_undef()");
    }
    emit($cg, "; perla_scalar_set(\"" . $pkg . "\", \"" . $name . "\", __nv); __nv; })");
}

# --- Assignment ---
func _gen_assign(scalar $cg, scalar $node) void {
    my str $op = $node->{"op"};
    my scalar $target = $node->{"target"};
    my int $target_type = $target->{"type"};

    # `use bigint` — desugar arithmetic compound assignment `$x OP= $y` into
    # `$x = $x OP $y` so it flows through the arbitrary-precision binop hook in
    # _gen_binop (which the per-operator compound paths below don't use). Covers
    # the factorial idiom `$f *= $_`. (Re-evaluates the target expression; only
    # matters for targets with side effects, which are rare under use bigint.)
    if (defined($cg->{"use_bigint"}) && $cg->{"use_bigint"} == 1
        && ($op eq "+=" || $op eq "-=" || $op eq "*=" || $op eq "**="
            || $op eq "/=" || $op eq "%=")) {
        my str $bi_base = substr($op, 0, length($op) - 1);
        my scalar $bi_bin = Perla::AST::node(Perla::AST::N_BINOP());
        $bi_bin->{"op"} = $bi_base;
        $bi_bin->{"left"} = $target;
        $bi_bin->{"right"} = $node->{"value"};
        my scalar $bi_asn = Perla::AST::node(Perla::AST::N_ASSIGN());
        $bi_asn->{"op"} = "=";
        $bi_asn->{"target"} = $target;
        $bi_asn->{"value"} = $bi_bin;
        _gen_assign($cg, $bi_asn);
        return;
    }

    # `$1 = X` / `$& = X` — regex capture variables are read-only in Perl.
    # gen_expr emits `strada_capture_var(N)` (a function call, not lvalue)
    # so the standard assignment path fails to compile. Emit a runtime
    # die so the user sees a meaningful error (matching Perl behavior:
    # "Modification of a read-only value attempted") instead of a gcc
    # error. Common surfaced via `s///e` replacements that incidentally
    # produce expressions like `$1=@{[expr]}`.
    if ($target_type == Perla::AST::N_SCALAR_VAR()
        && defined($target->{"name"})) {
        my str $__ro_name = $target->{"name"};
        if ((length($__ro_name) == 1 && $__ro_name ge "1" && $__ro_name le "9")
            || $__ro_name eq "&") {
            emit($cg, "({ ");
            gen_expr($cg, $node->{"value"});
            emit($cg, "; strada_die(\"%s\", \"Modification of a read-only value attempted\"); strada_new_undef(); })");
            return;
        }
    }

    # `$#arr = N` — truncate or extend @arr so its last index becomes N.
    # `$#arr` is parsed as N_SPECIAL_VAR with value "#NAME". The rvalue
    # form returns the current last index; the lvalue form mutates the
    # array's size.
    if ($op eq "=" && $target_type == Perla::AST::N_SPECIAL_VAR()
        && defined($target->{"value"}) && substr($target->{"value"}, 0, 1) eq "#") {
        my str $lia_name = substr($target->{"value"}, 1, length($target->{"value"}) - 1);
        my str $lia_cvar = c_var_a($lia_name);
        if ($lia_name eq "_") { $lia_cvar = "perla_at_"; }
        emit($cg, "({ int __new_last = (int)strada_to_int(");
        gen_expr($cg, $node->{"value"});
        emit($cg, "); StradaArray *__lav = strada_deref_array(" . $lia_cvar . "); ");
        emit($cg, "if (__lav) { ");
        emit($cg, "int __new_sz = __new_last + 1; if (__new_sz < 0) __new_sz = 0; ");
        # Shrink: decref removed elements and reduce size.
        emit($cg, "while ((int)__lav->size > __new_sz) { StradaValue *__re = __lav->elements[__lav->head + __lav->size - 1]; if (__re) strada_decref(__re); __lav->size--; } ");
        # Extend: pad with undef.
        emit($cg, "while ((int)__lav->size < __new_sz) { strada_array_push(__lav, strada_new_undef()); } ");
        emit($cg, "} STRADA_MAKE_TAGGED_INT((int64_t)__new_last); })");
        return;
    }

    # `$0 = "name"` — assign to the program-name special. Its read-path
    # emits a NULL-check ternary which is not a C lvalue, so handle the
    # assignment directly against the underlying global.
    if ($op eq "=" && $target_type == Perla::AST::N_SCALAR_VAR()
        && defined($target->{"name"}) && $target->{"name"} eq "0") {
        emit($cg, "({ StradaValue *__d0v = ");
        gen_expr($cg, $node->{"value"});
        emit($cg, "; if (perla_dollar_zero) strada_decref(perla_dollar_zero); perla_dollar_zero = __d0v; if (perla_dollar_zero) strada_incref(perla_dollar_zero); perla_dollar_zero; })");
        return;
    }

    # `$? = N` — assign to the child-exit-status special. Read-path
    # wraps perla_dollar_question in STRADA_MAKE_TAGGED_INT(...) which
    # isn't an lvalue. Write directly to the underlying int.
    if ($op eq "=" && $target_type == Perla::AST::N_SCALAR_VAR()
        && defined($target->{"name"}) && $target->{"name"} eq "?") {
        emit($cg, "({ int64_t __dqv = strada_to_int(");
        gen_expr($cg, $node->{"value"});
        emit($cg, "); perla_dollar_question = (int)__dqv; STRADA_MAKE_TAGGED_INT(__dqv); })");
        return;
    }

    # List-destructure assignment: `(A, B, C) = RHS`. RHS is evaluated
    # once in list context; each lvalue receives the corresponding
    # element (or undef when the list is shorter). An ARRAY_VAR in the
    # lvalue list slurps remaining elements; a HASH_VAR collects
    # remaining pairs. Used by e.g. `($h->{x}, $h->{y}) = split ...`
    # (YAML::Loader) and `my ($a, $b) = @list` (the N_MY path has its
    # own handler, this is the non-my form).
    if ($op eq "=" && $target_type == Perla::AST::N_ANON_ARRAY() && defined($target->{"elems"})) {
        my scalar $lhs_elems = $target->{"elems"};
        my int $nlhs = scalar(@{$lhs_elems});
        emit($cg, "({ int __sav_wl_ld = __perla_want_list; __perla_want_list = 1; StradaValue *__ld_rhs = ");
        gen_expr($cg, $node->{"value"});
        emit($cg, "; __perla_want_list = __sav_wl_ld; StradaArray *__ld_av = strada_deref_array(__ld_rhs); ");
        emit($cg, "StradaValue *__ld_fb = NULL; ");
        # `(...) = %h` — flatten hash to (k,v,k,v,...).
        emit($cg, "if (!__ld_av && __ld_rhs && !STRADA_IS_TAGGED_INT(__ld_rhs) && __ld_rhs->type == STRADA_HASH && __ld_rhs->value.hv) { ");
        emit($cg, "  __ld_fb = strada_new_array(); StradaArray *__ldhf_av = strada_deref_array(__ld_fb); ");
        emit($cg, "  StradaArray *__ldhf_keys = strada_hash_keys(__ld_rhs->value.hv); ");
        emit($cg, "  if (__ldhf_keys) { for (size_t __ldhf_i = 0; __ldhf_i < __ldhf_keys->size; __ldhf_i++) { ");
        emit($cg, "    StradaValue *__ldhf_k = __ldhf_keys->elements[__ldhf_keys->head + __ldhf_i]; ");
        emit($cg, "    char *__ldhf_ks = strada_to_str(__ldhf_k); ");
        emit($cg, "    StradaValue *__ldhf_v = strada_hash_get(__ld_rhs->value.hv, __ldhf_ks); ");
        emit($cg, "    free(__ldhf_ks); ");
        emit($cg, "    if (__ldhf_k) strada_incref(__ldhf_k); strada_array_push(__ldhf_av, __ldhf_k); ");
        emit($cg, "    if (__ldhf_v) strada_incref(__ldhf_v); strada_array_push(__ldhf_av, __ldhf_v); ");
        emit($cg, "  } strada_free_array(__ldhf_keys); } __ld_av = __ldhf_av; ");
        emit($cg, "} else if (!__ld_av && __ld_rhs) { __ld_fb = strada_new_array(); strada_array_push(strada_deref_array(__ld_fb), __ld_rhs); __ld_av = strada_deref_array(__ld_fb); } ");
        emit($cg, "int __ld_len = __ld_av ? strada_array_length(__ld_av) : 0; ");
        my int $li = 0;
        while ($li < $nlhs) {
            my scalar $lelem = $lhs_elems->[$li];
            my int $ltype = $lelem->{"type"};
            if ($ltype == Perla::AST::N_ARRAY_VAR()) {
                # Slurp remainder into array.
                emit($cg, "{ StradaArray *__slurp_av = strada_deref_array(" . c_var_a($lelem->{"name"}) . "); ");
                emit($cg, "if (__slurp_av) { while (__slurp_av->size > 0) { StradaValue *__old = __slurp_av->elements[__slurp_av->head + __slurp_av->size - 1]; __slurp_av->size--; if (__old) strada_decref(__old); } ");
                emit($cg, "for (int __ri = " . $li . "; __ri < __ld_len; __ri++) { StradaValue *__e = strada_array_get(__ld_av, __ri); if (__e) strada_incref(__e); strada_array_push(__slurp_av, __e); } } } ");
                $li = $nlhs;
            } elsif ($ltype == Perla::AST::N_DEREF_ARRAY()) {
                # `(SCALAR, @$ref) = LIST` — slurp remainder into the array
                # ref'd by SCALAR (autoviv if undef). Used by DBIC's
                # `($sql, @$bind) = $self->sql_maker->$op(...)` and similar.
                # Without this the fallback emits the deref expression as
                # the LHS of `=`, which gcc rejects ("lvalue required").
                my scalar $ref_node = $lelem->{"ref"};
                if (defined($ref_node) && $ref_node->{"type"} == Perla::AST::N_SCALAR_VAR()) {
                    my str $rvc = c_var($ref_node->{"name"});
                    emit($cg, "{ StradaValue *__sr = " . $rvc . "; ");
                    emit($cg, "if (!__sr || STRADA_IS_TAGGED_INT(__sr) || __sr->type != STRADA_REF || !__sr->value.rv || __sr->value.rv->type != STRADA_ARRAY) { ");
                    emit($cg, "  StradaValue *__newref = strada_new_ref_take(strada_new_array(), '@'); ");
                    emit($cg, "  if (" . $rvc . ") strada_decref(" . $rvc . "); ");
                    emit($cg, "  " . $rvc . " = __newref; __sr = __newref; ");
                    emit($cg, "} StradaArray *__slurp_da = strada_deref_array(__sr); ");
                    emit($cg, "if (__slurp_da) { while (__slurp_da->size > 0) { StradaValue *__o = __slurp_da->elements[__slurp_da->head + __slurp_da->size - 1]; __slurp_da->size--; if (__o) strada_decref(__o); } ");
                    emit($cg, "for (int __ri = " . $li . "; __ri < __ld_len; __ri++) { StradaValue *__e = strada_array_get(__ld_av, __ri); if (__e) strada_incref(__e); strada_array_push(__slurp_da, __e); } } } ");
                } else {
                    # Generic case: evaluate the ref expression, deref, slurp.
                    # No autoviv for complex lvalues — caller is responsible.
                    emit($cg, "{ StradaArray *__slurp_da = strada_deref_array(");
                    gen_expr($cg, $ref_node);
                    emit($cg, "); if (__slurp_da) { while (__slurp_da->size > 0) { StradaValue *__o = __slurp_da->elements[__slurp_da->head + __slurp_da->size - 1]; __slurp_da->size--; if (__o) strada_decref(__o); } ");
                    emit($cg, "for (int __ri = " . $li . "; __ri < __ld_len; __ri++) { StradaValue *__e = strada_array_get(__ld_av, __ri); if (__e) strada_incref(__e); strada_array_push(__slurp_da, __e); } } } ");
                }
                $li = $nlhs;
            } elsif ($ltype == Perla::AST::N_HASH_VAR()) {
                # Slurp remainder into hash as key/value pairs.
                emit($cg, "{ StradaHash *__slurp_hv = strada_deref_hash(" . c_var_h($lelem->{"name"}) . "); ");
                emit($cg, "if (__slurp_hv) { for (int __ri = " . $li . "; __ri + 1 < __ld_len; __ri += 2) { ");
                emit($cg, "char *__hk = strada_to_str(strada_array_get(__ld_av, __ri)); strada_hash_set(__slurp_hv, __hk, strada_array_get(__ld_av, __ri + 1)); free(__hk); } } } ");
                $li = $nlhs;
            } elsif ($ltype == Perla::AST::N_UNDEF()) {
                # `(undef, $x) = LIST` — discard this slot, advance index.
                $li++;
            } else {
                # `my $x` (and the other sigils) appearing inline as a list
                # element — common idiom: `($attrs->{k}, my $new_order) = ...`.
                # Without this branch, the fallback _gen_expr emits the
                # auto-init pattern `(v_new_order = strada_new_undef())`,
                # which we then suffix with ` = __ld_v` — invalid C
                # ("lvalue required as left operand of assignment").
                # Treat as a plain scalar/array/hash assignment and rely on
                # the file-scope auto-decl post-pass to declare the var.
                # The N_MY node carries the var(s) under either ->{"var"}
                # (single, e.g. `my $x`) or ->{"vars"} (plural, e.g.
                # `my ($a, $b)`); both shapes can land here.
                if ($ltype == Perla::AST::N_MY()) {
                    my scalar $myvar = undef;
                    if (defined($lelem->{"var"})) {
                        $myvar = $lelem->{"var"};
                    } elsif (defined($lelem->{"vars"}) && scalar(@{$lelem->{"vars"}}) == 1) {
                        $myvar = $lelem->{"vars"}->[0];
                    }
                    if (defined($myvar)) {
                        my str $myvtype = "" . $myvar->{"type"};
                        my str $myvname = $myvar->{"value"};
                        if (length($myvtype) == 0) { $myvtype = "SCALAR_VAR"; }
                    if ($myvtype eq "SCALAR_VAR") {
                        $lelem = Perla::AST::node_with(Perla::AST::N_SCALAR_VAR(), "name", $myvname);
                        $ltype = Perla::AST::N_SCALAR_VAR();
                    } elsif ($myvtype eq "ARRAY_VAR") {
                        $lelem = Perla::AST::node_with(Perla::AST::N_ARRAY_VAR(), "name", $myvname);
                        $ltype = Perla::AST::N_ARRAY_VAR();
                        # Re-dispatch: array slurp behaves like the top-level branch.
                        # Easiest is just to re-enter the loop iteration, but we
                        # already consumed the index, so inline the slurp here.
                        emit($cg, "{ StradaArray *__slurp_av = strada_deref_array(" . c_var_a($myvname) . " ? " . c_var_a($myvname) . " : (" . c_var_a($myvname) . " = strada_new_array())); ");
                        emit($cg, "if (__slurp_av) { while (__slurp_av->size > 0) { StradaValue *__old = __slurp_av->elements[__slurp_av->head + __slurp_av->size - 1]; __slurp_av->size--; if (__old) strada_decref(__old); } ");
                        emit($cg, "for (int __ri = " . $li . "; __ri < __ld_len; __ri++) { StradaValue *__e = strada_array_get(__ld_av, __ri); if (__e) strada_incref(__e); strada_array_push(__slurp_av, __e); } } } ");
                        $li = $nlhs;
                        next;
                    }
                    # HASH_VAR slurp would mirror ARRAY_VAR; left out for now —
                    # add when an actual case appears. Falls through to the
                    # generic SCALAR_VAR path otherwise.
                    }
                }
                # Scalar lvalue at position $li. Assign from __ld_av[$li] or undef.
                my scalar $vnode = Perla::AST::node(Perla::AST::N_ASSIGN());
                $vnode->{"op"} = "=";
                $vnode->{"target"} = $lelem;
                # Wrap the get in a dummy AST node we can feed to _gen_expr.
                # Simpler: inline emit the get.
                emit($cg, "({ StradaValue *__ld_v = (" . $li . " < __ld_len) ? strada_array_get(__ld_av, " . $li . ") : strada_new_undef(); ");
                # Emit assignment target = __ld_v as statement expression.
                # We synthesize a small assignment by re-using the existing codegen paths for each lvalue kind.
                if ($ltype == Perla::AST::N_SCALAR_VAR()) {
                    emit($cg, c_var($lelem->{"name"}) . " = __ld_v; ");
                } elsif ($ltype == Perla::AST::N_ARROW_HASH()) {
                    # $ref->{key} = __ld_v
                    emit($cg, "{ char *__ahk; ");
                    my scalar $key_n = $lelem->{"key"};
                    if (defined($key_n) && ($key_n->{"type"} == Perla::AST::N_STR_LIT() || ($key_n->{"type"} == Perla::AST::N_INTERP_STR() && has_perl_var($key_n->{"value"}) == 0))) {
                        emit($cg, "__ahk = strdup(\"" . Perla::CodeGen::Escape::escape_c_str($key_n->{"value"}) . "\"); ");
                    } elsif (defined($key_n) && $key_n->{"type"} == Perla::AST::N_CALL() && defined($key_n->{"name"}) && length($key_n->{"name"}) > 0) {
                        emit($cg, "__ahk = strdup(\"" . Perla::CodeGen::Escape::escape_c_str($key_n->{"name"}) . "\"); ");
                    } else {
                        emit($cg, "__ahk = strada_to_str(");
                        if (defined($key_n)) { gen_expr($cg, $key_n); } else { emit($cg, "perla_dollar_underscore"); }
                        emit($cg, "); ");
                    }
                    emit($cg, "strada_hv_store(");
                    gen_expr($cg, $lelem->{"object"});
                    emit($cg, ", __ahk, __ld_v); free(__ahk); }");
                } elsif ($ltype == Perla::AST::N_HASH_ELEM()) {
                    emit($cg, "{ char *__ahk = strada_to_str(");
                    gen_expr($cg, $lelem->{"key"});
                    emit($cg, "); strada_hv_store(");
                    gen_expr($cg, $lelem->{"hash"});
                    emit($cg, ", __ahk, __ld_v); free(__ahk); }");
                } elsif ($ltype == Perla::AST::N_ARROW_ARRAY()) {
                    emit($cg, "{ StradaArray *__aav = strada_deref_array(");
                    gen_expr($cg, $lelem->{"object"});
                    emit($cg, "); int __aai = (int)strada_to_int(");
                    gen_expr($cg, $lelem->{"index"});
                    emit($cg, "); strada_array_set(__aav, __aai, __ld_v); }");
                } elsif ($ltype == Perla::AST::N_ARRAY_ELEM()) {
                    emit($cg, "{ StradaArray *__aav = strada_deref_array(");
                    gen_expr($cg, $lelem->{"array"});
                    emit($cg, "); int __aai = (int)strada_to_int(");
                    gen_expr($cg, $lelem->{"index"});
                    emit($cg, "); if (__aai < 0 && __aav) __aai += strada_array_length(__aav); strada_array_set(__aav, __aai, __ld_v); }");
                } elsif ($ltype == Perla::AST::N_DEREF_SCALAR()) {
                    # `($$a, $$b) = (X, Y)` — list-assign through scalar
                    # derefs. The fallback `gen_expr(lelem) = __ld_v` would
                    # emit `({ __dsv; }) = ...` (statement-expression rvalue
                    # — not a lvalue). Route through strada_deref_set so the
                    # write reaches the slot (for slot refs) or
                    # strada_overwrite_in_place (for heap refs).
                    emit($cg, "{ StradaValue *__dsref = ");
                    gen_expr($cg, $lelem->{"ref"});
                    emit($cg, "; if (__dsref && !STRADA_IS_TAGGED_INT(__dsref) && __dsref->type == STRADA_REF) { ");
                    emit($cg, "  if (strada_is_slot_ref(__dsref)) { strada_deref_set(__dsref, __ld_v); } ");
                    emit($cg, "  else if (__dsref->value.rv) { strada_overwrite_in_place(__dsref->value.rv, __ld_v); } ");
                    emit($cg, "} }");
                } else {
                    # Fallback: try plain assignment (may fail for unsupported lvalues).
                    gen_expr($cg, $lelem);
                    emit($cg, " = __ld_v; ");
                }
                emit($cg, " __ld_v; }); ");
                $li++;
            }
        }
        # In scalar context, list assignment evaluates to the number of
        # elements on the RHS (Perl semantics for `(A,B,C) = LIST` and the
        # `()= LIST` idiom: `my $n = () = LIST` is the classic count-the-list
        # idiom). The list (`__ld_rhs`) is what propagates in list context.
        emit($cg, "(__perla_want_list ? __ld_rhs : STRADA_MAKE_TAGGED_INT(__ld_len)); })");
        return;
    }

    # Ternary-target lvalue: (cond ? A : B) OP= RHS → dispatch to A or B.
    # Perl lets you write `($cond ? $a : $b) = $x` and its `||=` / `//=`
    # cousins, but C has no ternary-as-lvalue. Rewrite at codegen time into
    # a branching statement expression that delegates to the existing
    # per-op codegen on the selected side.
    if ($target_type == Perla::AST::N_TERNARY()) {
        my scalar $then_node = Perla::AST::node(Perla::AST::N_ASSIGN());
        $then_node->{"op"} = $op;
        $then_node->{"target"} = $target->{"then"};
        $then_node->{"value"} = $node->{"value"};
        my scalar $else_node = Perla::AST::node(Perla::AST::N_ASSIGN());
        $else_node->{"op"} = $op;
        $else_node->{"target"} = $target->{"else"};
        $else_node->{"value"} = $node->{"value"};
        emit($cg, "({ StradaValue *__tr; if (perla_to_bool(");
        gen_expr($cg, $target->{"cond"});
        emit($cg, ")) { __tr = ");
        _gen_assign($cg, $then_node);
        emit($cg, "; } else { __tr = ");
        _gen_assign($cg, $else_node);
        emit($cg, "; } __tr; })");
        return;
    }

    if ($op eq "=") {
        # @ISA = qw(Parent1 Parent2) — as a standalone assignment (not part
        # of `our @ISA = ...` which _gen_our already handles). Many modules
        # do `our (@ISA, @EXPORT); @ISA = qw(Exporter);` as two statements;
        # without this path we'd only set v_ISA and skip the stash ISA push.
        if ($target_type == Perla::AST::N_ARRAY_VAR() && defined($target->{"name"}) && $target->{"name"} eq "ISA") {
            my str $isa_pkg = $cg->{"pkg"};
            my scalar $iv = $node->{"value"};
            if (defined($iv) && ($iv->{"type"} == Perla::AST::N_ANON_ARRAY() || $iv->{"type"} == Perla::AST::N_QWORD())) {
                my scalar $ie = $iv->{"elems"};
                my int $ii = 0;
                while ($ii < scalar(@{$ie})) {
                    my scalar $iel = $ie->[$ii];
                    if ($iel->{"type"} == Perla::AST::N_STR_LIT() || $iel->{"type"} == Perla::AST::N_INTERP_STR()) {
                        ind($cg); emit($cg, "perla_isa_push(\"" . $isa_pkg . "\", \"" . $iel->{"value"} . "\");\n");
                    }
                    $ii++;
                }
                emit($cg, "(StradaValue*)NULL");
                return;
            }
            if (defined($iv) && ($iv->{"type"} == Perla::AST::N_STR_LIT() || $iv->{"type"} == Perla::AST::N_INTERP_STR())) {
                ind($cg); emit($cg, "perla_isa_push(\"" . $isa_pkg . "\", \"" . $iv->{"value"} . "\");\n");
                emit($cg, "(StradaValue*)NULL");
                return;
            }
            # Fall through to normal array assignment for complex RHS
        }
        # *Foo::bar = \&func or *{expr} = \&func — typeglob assignment
        if ($target_type == Perla::AST::N_GLOB_ACCESS()) {
            my scalar $gexpr = $target->{"expr"};
            if (defined($gexpr)) {
                # Dynamic: *{EXPR} = value
                emit($cg, "({ StradaValue *__gv = ");
                gen_expr($cg, $node->{"value"});
                emit($cg, "; StradaValue *__gn = ");
                gen_expr($cg, $gexpr);
                emit($cg, "; perla_glob_assign_dynamic_pkg(__gn, __gv, \"" . $cg->{"pkg"} . "\"); __gv; })");
                return;
            }
            my str $gname = $target->{"name"};
            # Split into pkg::name
            my int $sep = -1;
            my int $gi = length($gname) - 1;
            while ($gi >= 0) {
                if ($gi > 0 && substr($gname, $gi - 1, 2) eq "::") { $sep = $gi - 1; last; }
                $gi--;
            }
            my str $gpkg = $cg->{"pkg"};
            my str $gshort = $gname;
            if ($sep >= 0) {
                $gpkg = substr($gname, 0, $sep);
                $gshort = substr($gname, $sep + 2, length($gname) - $sep - 2);
            }
            # `*dst = *src` — typeglob alias. The RHS gen_expr for
            # N_GLOB_ACCESS returns only the CODE slot, so a plain
            # perla_glob_assign would copy only the code (losing scalar /
            # array / hash slots). Detect a static N_GLOB_ACCESS RHS and
            # emit perla_glob_alias to copy ALL slots. Perl idiom: alias
            # one symbol-table entry to another (see Exporter's `import`,
            # Sub::Install, and Perl 5's `*foo = *bar` pattern). Without
            # this, `$foo` reads via the alias return undef.
            my scalar $vnode = $node->{"value"};
            if (defined($vnode) && $vnode->{"type"} == Perla::AST::N_GLOB_ACCESS()
                && !defined($vnode->{"expr"}) && defined($vnode->{"name"})) {
                my str $srcname = $vnode->{"name"};
                my int $ssep = -1;
                my int $sgi = length($srcname) - 1;
                while ($sgi >= 0) {
                    if ($sgi > 0 && substr($srcname, $sgi - 1, 2) eq "::") { $ssep = $sgi - 1; last; }
                    $sgi--;
                }
                my str $spkg = $cg->{"pkg"};
                my str $sshort = $srcname;
                if ($ssep >= 0) {
                    $spkg = substr($srcname, 0, $ssep);
                    $sshort = substr($srcname, $ssep + 2, length($srcname) - $ssep - 2);
                }
                # Also mirror the source's C-static slots into the dest's
                # so unqualified reads of $dst/@dst/%dst (via v_dst, etc.)
                # see the aliased value. perla_glob_alias only copies the
                # stash slots; reads compile to `v_dst`, not a stash lookup.
                # Tied together they emulate Perl's "the symbol is now an
                # alias" semantic for both stash-qualified and unqualified
                # access paths.
                # STDIN/STDOUT/STDERR have no C-static mirror symbol (only an
                # extern decl), so syncing v_dst = v_STDOUT would reference an
                # undefined symbol and fail to link. perla_glob_alias copies
                # the source glob's slots (including IO) at the stash level,
                # which is what bareword `print DST ...` resolves through, so
                # skip the unqualified-mirror sync for these.
                my int $src_is_std = 0;
                if ($sshort eq "STDOUT" || $sshort eq "STDIN" || $sshort eq "STDERR") { $src_is_std = 1; }
                emit($cg, "({ perla_glob_alias(\"" . $gpkg . "\", \"" . $gshort . "\", \"" . $spkg . "\", \"" . $sshort . "\"); ");
                if ($src_is_std == 0) {
                    my str $dst_cvar_s = c_var($gshort);
                    my str $dst_cvar_a = c_var_a($gshort);
                    my str $dst_cvar_h = c_var_h($gshort);
                    my str $src_cvar_s = c_var($sshort);
                    my str $src_cvar_a = c_var_a($sshort);
                    my str $src_cvar_h = c_var_h($sshort);
                    emit($cg, "if (" . $dst_cvar_s . " != " . $src_cvar_s . ") { if (" . $dst_cvar_s . ") strada_decref(" . $dst_cvar_s . "); " . $dst_cvar_s . " = " . $src_cvar_s . "; if (" . $dst_cvar_s . ") strada_incref(" . $dst_cvar_s . "); } ");
                    emit($cg, "if (" . $dst_cvar_a . " != " . $src_cvar_a . ") { if (" . $dst_cvar_a . ") strada_decref(" . $dst_cvar_a . "); " . $dst_cvar_a . " = " . $src_cvar_a . "; if (" . $dst_cvar_a . ") strada_incref(" . $dst_cvar_a . "); } ");
                    emit($cg, "if (" . $dst_cvar_h . " != " . $src_cvar_h . ") { if (" . $dst_cvar_h . ") strada_decref(" . $dst_cvar_h . "); " . $dst_cvar_h . " = " . $src_cvar_h . "; if (" . $dst_cvar_h . ") strada_incref(" . $dst_cvar_h . "); } ");
                }
                # Aliasing from a standard handle: perla represents bareword
                # filehandles in the glob's SCALAR slot (open(FH,...) stores via
                # perla_scalar_set and `print FH ...` reads via perla_scalar_get),
                # so point DST's scalar slot at the libc stream. STDOUT/STDIN/
                # STDERR have no v_ mirror, hence the dedicated handling here.
                if ($src_is_std == 1) {
                    my str $stdstream = "stdout";
                    if ($sshort eq "STDIN") { $stdstream = "stdin"; }
                    if ($sshort eq "STDERR") { $stdstream = "stderr"; }
                    emit($cg, "perla_scalar_set(\"" . $gpkg . "\", \"" . $gshort . "\", strada_new_filehandle(" . $stdstream . ")); ");
                }
                emit($cg, "strada_new_undef(); })");
                return;
            }
            emit($cg, "({ StradaValue *__gv = ");
            gen_expr($cg, $node->{"value"});
            emit($cg, "; PerlGlob *__glob = perla_glob_get_or_create(perla_stash_get_or_create(\"" . $gpkg . "\"), \"" . $gshort . "\"); ");
            emit($cg, "perla_glob_assign(__glob, __gv); __gv; })");
            return;
        }
        # $$ref = value — write through scalar reference, or set the
        # named package scalar when the target is a STRING (symbolic
        # ref: `${"Pkg::NAME"} = $v`). Without the STR branch
        # Class::Accessor::Grouped's set_inherited would silently
        # store nothing, so DBIC class-data accessors install but
        # never persist their values.
        if ($target_type == Perla::AST::N_DEREF_SCALAR()) {
            # `${*$fh} = X` — store X in the filehandle glob's SCALAR
            # slot (on its meta). File::Temp->new does `${*$fh} = $path`.
            # Detect the glob-access-with-expr inner and route to the
            # per-filehandle slot setter.
            my scalar $__asref = $target->{"ref"};
            if (defined($__asref) && $__asref->{"type"} == Perla::AST::N_GLOB_ACCESS()
                && defined($__asref->{"expr"})) {
                emit($cg, "perla_fh_slot_set(");
                gen_expr($cg, $__asref->{"expr"});
                emit($cg, ", ");
                gen_expr($cg, $node->{"value"});
                emit($cg, ")");
                return;
            }
            # `$$ref = X` writes through the reference into the underlying
            # scalar's storage. Previously we replaced the ref's `rv`
            # pointer, which left the original variable's slot untouched
            # (so `$val` still saw the old value). Now we overwrite the
            # target StradaValue in place via strada_overwrite_in_place,
            # so all aliases — `$val`, `$$ref`, `\$val`, etc. — see the
            # new value.
            emit($cg, "({ StradaValue *__dref = ");
            gen_expr($cg, $target->{"ref"});
            emit($cg, "; StradaValue *__nv = ");
            gen_expr($cg, $node->{"value"});
            # Slot refs (created by `\\$var` for scalar locals or
            # \\$Pkg::var stash slots) store the address of the
            # variable's StradaValue* slot. Writing through them
            # updates the underlying C variable directly — required
            # for `$$r = X` to also update `$var` itself (Perl
            # aliasing). Use perla_scalar_deref_assign which handles
            # both slot refs AND stash-slot-→-local mirror sync (so
            # \\$Pkg::var writes propagate into pkg's compiled subs).
            emit($cg, "; if (__dref && !STRADA_IS_TAGGED_INT(__dref) && __dref->type == STRADA_REF && strada_is_slot_ref(__dref)) { ");
            emit($cg, "perla_scalar_deref_assign(__dref, __nv); } ");
            emit($cg, "else if (__dref && !STRADA_IS_TAGGED_INT(__dref) && __dref->type == STRADA_REF && __dref->value.rv && __dref->value.rv->meta && __dref->value.rv->meta->is_tied) { ");
            emit($cg, "strada_tied_scalar_store(__dref->value.rv, __nv); } ");
            emit($cg, "else if (__dref && !STRADA_IS_TAGGED_INT(__dref) && __dref->type == STRADA_REF && __dref->value.rv) { ");
            emit($cg, "strada_overwrite_in_place(__dref->value.rv, __nv); } ");
            emit($cg, "else if (__dref && !STRADA_IS_TAGGED_INT(__dref) && __dref->type == STRADA_STR && __dref->value.pv) { ");
            if (defined($cg->{"strict_refs"}) && $cg->{"strict_refs"} == 1) {
                emit($cg, "{ char __sm[512]; snprintf(__sm, sizeof(__sm), \"Can't use string (\\\"%s\\\") as a SCALAR ref while \\\"strict refs\\\" in use\", __dref->value.pv); strada_die(__sm); } ");
            } else {
                emit($cg, "strada_incref(__nv); perla_scalar_set_via_qname(__dref->value.pv, __nv); ");
            }
            emit($cg, "} __nv; })");
            return;
        }
        # Assignment to special variables
        if ($target_type == Perla::AST::N_SCALAR_VAR()) {
            my str $svname = $target->{"name"};
            # strict 'vars' — check the assignment LHS too, not just reads.
            # Without this, `use strict; $foo = 3;` only errored on a later
            # READ of $foo; writes silently auto-registered the name as
            # IMPLICIT_GLOBAL. Match Perl's behavior of erroring on the
            # first appearance — read or write — of an undeclared name.
            _strict_check_var($cg, "\$", $svname, $target->{"line"} + 0);
            if ($svname eq "/" || $svname eq "\\" || $svname eq "," || $svname eq "\""
                || $svname eq "~" || $svname eq "^" || $svname eq "="
                || $svname eq "%" || $svname eq "^A") {
                my str $cvar = "perla_irs";
                if ($svname eq "\\") { $cvar = "perla_ors"; }
                if ($svname eq ",") { $cvar = "perla_ofs"; }
                if ($svname eq "\"") { $cvar = "perla_lse"; }
                if ($svname eq "~") { $cvar = "perla_dollar_tilde"; }
                if ($svname eq "^") { $cvar = "perla_dollar_caret"; }
                if ($svname eq "=") { $cvar = "perla_dollar_equals"; }
                if ($svname eq "%") { $cvar = "perla_dollar_percent"; }
                if ($svname eq "^A") { $cvar = "perla_dollar_caret_A"; }
                # Per-handle $~ / $^ : also mirror into the currently-
                # selected handle's PerlaFmtPageState slot so a
                # `select(FH); $~ = "X"; ...` pattern carries the
                # override to FH even after a later select() swap.
                my str $perhandle_setter = "";
                if ($svname eq "~") { $perhandle_setter = "perla_format_set_selected_fmt_name"; }
                if ($svname eq "^") { $perhandle_setter = "perla_format_set_selected_top_name"; }
                emit($cg, "({ StradaValue *__nv = ");
                gen_expr($cg, $node->{"value"});
                emit($cg, "; strada_incref(__nv); if (" . $cvar . ") strada_decref(" . $cvar . "); " . $cvar . " = __nv; ");
                if (length($perhandle_setter) > 0) {
                    emit($cg, "{ char *__phs = strada_to_str(__nv); " . $perhandle_setter . "(__phs ? __phs : \"\"); if (__phs) free(__phs); } ");
                }
                emit($cg, "__nv; })");
                return;
            }
            if ($svname eq "|") {
                emit($cg, "({ __perla_autoflush = (int)strada_to_int(");
                gen_expr($cg, $node->{"value"});
                emit($cg, "); if (__perla_autoflush) setvbuf(stdout, NULL, 2 /* _IONBF */, 0); ");
                emit($cg, "STRADA_MAKE_TAGGED_INT((int64_t)__perla_autoflush); })");
                return;
            }
            # $! = N — set errno (Perl accepts numeric or string; we take the
            # integer form). Otherwise `$! = strerror(errno) = VAL` would
            # emit a non-lvalue assignment to the read-side expression.
            if ($svname eq "!") {
                emit($cg, "({ StradaValue *__nv = ");
                gen_expr($cg, $node->{"value"});
                emit($cg, "; errno = (int)strada_to_int(__nv); __nv; })");
                return;
            }
            # $. = N — input line number. Read path emits
            # STRADA_MAKE_TAGGED_INT((int64_t)perla_dollar_dot) which
            # isn't a C lvalue, so write must go through the int
            # storage directly.
            if ($svname eq ".") {
                emit($cg, "({ int64_t __nv = strada_to_int(");
                gen_expr($cg, $node->{"value"});
                emit($cg, "); perla_dollar_dot = (int)__nv; STRADA_MAKE_TAGGED_INT(__nv); })");
                return;
            }
            # $1, $2, ..., $9 — regex capture vars. Read-only in Perl;
            # assignment raises "Modification of a read-only value".
            # Without this branch, gen_expr emits `strada_capture_var(N)`
            # (a function call rvalue) which gcc rejects with "lvalue
            # required". Emit a runtime die instead so callers see the
            # same kind of failure Perl would.
            if (length($svname) == 1 && $svname ge "1" && $svname le "9") {
                emit($cg, "({ ");
                gen_expr($cg, $node->{"value"});
                emit($cg, "; strada_die(\"%s\", \"Modification of a read-only value attempted\"); strada_new_undef(); })");
                return;
            }
            # $& — same read-only constraint as $1-$9.
            if ($svname eq "&") {
                emit($cg, "({ ");
                gen_expr($cg, $node->{"value"});
                emit($cg, "; strada_die(\"%s\", \"Modification of a read-only value attempted\"); strada_new_undef(); })");
                return;
            }
        }
        # substr($s, offset, len) = value — in-place string modification.
        # If the target string is a plain scalar variable, `&v_x` works as the
        # StradaValue** that strada_substr_assign needs. For hash/array
        # accesses (or any non-lvalue expression), the naive codegen would
        # take the address of a statement-expression and fail at the C level.
        # For those, fetch into a temp, mutate it, and store back.
        # pos($sv) = N — set the SV's regex pos so the next /g match
        # resumes from offset N. Without this, `pos($s) = 0` was a
        # no-op and code like `while (pos($s) < length($s)) { ... }`
        # patterns couldn't manually steer the iterator.
        if ($target_type == Perla::AST::N_CALL() && $target->{"name"} eq "pos") {
            my scalar $pos_args = $target->{"args"};
            if (defined($pos_args) && scalar(@{$pos_args}) >= 1) {
                emit($cg, "({ StradaValue *__pos_sv = ");
                gen_expr($cg, $pos_args->[0]);
                emit($cg, "; StradaValue *__pos_v = ");
                gen_expr($cg, $node->{"value"});
                emit($cg, "; if (__pos_sv && !STRADA_IS_TAGGED_INT(__pos_sv)) { ");
                emit($cg, "StradaMetadata *__pos_meta = strada_ensure_meta(__pos_sv); ");
                # undef → reset to -1; defined → set to int value.
                emit($cg, "if (!__pos_v || (!STRADA_IS_TAGGED_INT(__pos_v) && __pos_v->type == STRADA_UNDEF)) { ");
                emit($cg, "  if (__pos_meta) __pos_meta->regex_pos = -1; ");
                emit($cg, "} else if (__pos_meta) { __pos_meta->regex_pos = (int32_t)strada_to_int(__pos_v); } ");
                emit($cg, "} __pos_v; })");
                return;
            }
        }
        if ($target_type == Perla::AST::N_CALL() && $target->{"name"} eq "substr") {
            my scalar $sub_args = $target->{"args"};
            my int $sub_argc = scalar(@{$sub_args});
            if ($sub_argc >= 2) {
                my int $str_target_type = $sub_args->[0]->{"type"};
                my int $is_simple_lvalue = 0;
                if ($str_target_type == Perla::AST::N_SCALAR_VAR()) { $is_simple_lvalue = 1; }
                if ($is_simple_lvalue == 1) {
                    emit($cg, "({ StradaValue *__sa_sv = ");
                    gen_expr($cg, $node->{"value"});
                    emit($cg, "; char *__sa_r = strada_to_str(__sa_sv); strada_substr_assign(&");
                    gen_expr($cg, $sub_args->[0]);
                    emit($cg, ", (int64_t)strada_to_int(");
                    gen_expr($cg, $sub_args->[1]);
                    emit($cg, "), ");
                    if ($sub_argc >= 3) {
                        emit($cg, "(int64_t)strada_to_int(");
                        gen_expr($cg, $sub_args->[2]);
                        emit($cg, ")");
                    } else {
                        emit($cg, "(int64_t)999999");
                    }
                    emit($cg, ", __sa_r); free(__sa_r); strada_decref(__sa_sv); (StradaValue*)NULL; })");
                } else {
                    # Non-lvalue target (hash/array access, deref, etc.).
                    # Fetch into a temp, apply substr_assign, write back
                    # through the underlying storage. This matches Perl's
                    # \`substr(\$h->{k}, 0, 3) = \"foo\"\` semantics.
                    emit($cg, "({ StradaValue *__sa_sv = ");
                    gen_expr($cg, $node->{"value"});
                    emit($cg, "; char *__sa_r = strada_to_str(__sa_sv); StradaValue *__sa_t = ");
                    gen_expr($cg, $sub_args->[0]);
                    emit($cg, "; if (__sa_t) strada_incref(__sa_t); strada_substr_assign(&__sa_t, (int64_t)strada_to_int(");
                    gen_expr($cg, $sub_args->[1]);
                    emit($cg, "), ");
                    if ($sub_argc >= 3) {
                        emit($cg, "(int64_t)strada_to_int(");
                        gen_expr($cg, $sub_args->[2]);
                        emit($cg, ")");
                    } else {
                        emit($cg, "(int64_t)999999");
                    }
                    emit($cg, ", __sa_r); free(__sa_r); strada_decref(__sa_sv); ");
                    # Store the mutated __sa_t back through the target using
                    # the subst writeback helper (handles hash elem, array
                    # elem, scalar deref, etc.)
                    Perla::CodeGen::Subst::emit_subst_writeback($cg, $sub_args->[0], "__sa_t");
                    emit($cg, "(StradaValue*)NULL; })");
                }
                return;
            }
        }
        # Array slice assignment: @arr[indices] = values. Iterate the
        # indices, assign each RHS element to the corresponding slot.
        # Without this, `@arr[1,3,5] = ("x","y","z")` built the RHS list
        # but never wrote anything back — @arr stayed empty.
        if ($target_type == Perla::AST::N_ARRAY_SLICE()) {
            emit($cg, "({ ");
            emit($cg, "int __sav_wl_as = __perla_want_list; __perla_want_list = 1; ");
            # Track whether RHS is a borrowed reference (live variable) or
            # an owned temp (function call result). The final decref at the
            # end of the slice-assign should only fire for owned values,
            # otherwise we free a live var underneath the user.
            my int $__as_rhs_borrowed = expr_is_borrowed($node->{"value"});
            emit($cg, "StradaValue *__as_rhs = ");
            gen_expr($cg, $node->{"value"});
            emit($cg, "; __perla_want_list = __sav_wl_as; ");
            # If the RHS is a bare scalar (not an array — happens when
            # the source has a single elem wrapped in parens, parsed
            # as N_STR_LIT instead of N_ANON_ARRAY), wrap it as a
            # 1-element array so the slice-assign loop can fetch
            # element 0 for the first target slot.
            emit($cg, "StradaValue *__as_rhs_tmp = NULL; ");
            emit($cg, "StradaArray *__as_rav = strada_deref_array(__as_rhs); ");
            emit($cg, "if (!__as_rav && __as_rhs) { __as_rhs_tmp = strada_new_array(); StradaArray *__rhs_one = strada_deref_array(__as_rhs_tmp); strada_incref(__as_rhs); strada_array_push_take(__rhs_one, __as_rhs); __as_rav = __rhs_one; } ");
            # Resolve the target array in LIST context. For an `@{ $ref }`
            # deref target, N_DEREF_ARRAY in scalar/void context returns the
            # array LENGTH (a tagged int), so strada_deref_array() yields NULL
            # and the slice-assign silently writes nothing. This bit
            # `@{$self}[VOL,DIR,FILE] = ...` inside a void-context method call
            # (Path::Tiny::_splitpath), so $self's fields never got set.
            emit($cg, "int __sav_wl_ast = __perla_want_list; __perla_want_list = 1; StradaArray *__as_tav = strada_deref_array(");
            # target->{"array"} is either a string (the @arr name) or
            # an AST node (for `@{$ref}[1,2,3]` etc.).
            my scalar $as_arr_ref = $target->{"array"};
            if (ref($as_arr_ref) eq "HASH") {
                gen_expr($cg, $as_arr_ref);
            } elsif (index("" . $as_arr_ref, "::") > 0) {
                # @Pkg::arr[i,j] = ... — write to ARRAY slot of stash glob.
                my str $aspn = "" . $as_arr_ref;
                my int $asli = -1;
                my int $assi = 0;
                while ($assi < length($aspn) - 1) {
                    if (substr($aspn, $assi, 2) eq "::") { $asli = $assi; }
                    $assi = $assi + 1;
                }
                my str $aspkg = substr($aspn, 0, $asli);
                my str $asname = substr($aspn, $asli + 2, length($aspn) - $asli - 2);
                emit($cg, "perla_array_get(\"" . $aspkg . "\", \"" . $asname . "\")");
            } else {
                emit($cg, c_var_a("" . $as_arr_ref));
            }
            emit($cg, "); __perla_want_list = __sav_wl_ast; ");
            emit($cg, "int __as_ri = 0; ");
            my scalar $idxs = $target->{"indices"};
            my int $ni = scalar(@{$idxs});
            my int $ii = 0;
            while ($ii < $ni) {
                my scalar $idx_node = $idxs->[$ii];
                # If the index is N_ANON_ARRAY, iterate the elems literally.
                # N_RANGE expands at runtime via perla_range_array.
                # Otherwise treat as a single integer.
                if ($idx_node->{"type"} == Perla::AST::N_ANON_ARRAY()) {
                    my scalar $ielems = $idx_node->{"elems"};
                    my int $ne = scalar(@{$ielems});
                    my int $iei = 0;
                    while ($iei < $ne) {
                        emit($cg, "{ int __as_idx = (int)strada_to_int(");
                        gen_expr($cg, $ielems->[$iei]);
                        emit($cg, "); if (__as_idx < 0 && __as_tav) __as_idx += strada_array_length(__as_tav); ");
                        emit($cg, "StradaValue *__as_v = (__as_rav && __as_ri < (int)strada_array_length(__as_rav)) ? strada_array_get(__as_rav, __as_ri) : strada_new_undef(); ");
                        emit($cg, "if (__as_v) strada_incref(__as_v); strada_array_set(__as_tav, __as_idx, __as_v); __as_ri++; } ");
                        $iei++;
                    }
                } elsif ($idx_node->{"type"} == Perla::AST::N_RANGE()
                         || $idx_node->{"type"} == Perla::AST::N_ARRAY_VAR()
                         || $idx_node->{"type"} == Perla::AST::N_DEREF_ARRAY()
                         || $idx_node->{"type"} == Perla::AST::N_ARRAY_SLICE()
                         || $idx_node->{"type"} == Perla::AST::N_HASH_SLICE()
                         || $idx_node->{"type"} == Perla::AST::N_CALL()
                         || $idx_node->{"type"} == Perla::AST::N_METHOD()
                         || $idx_node->{"type"} == Perla::AST::N_MAP()
                         || $idx_node->{"type"} == Perla::AST::N_GREP()
                         || $idx_node->{"type"} == Perla::AST::N_SORT()) {
                    # `@arr[2..4] = ...`, `@arr[@idx] = ...`, `@arr[map ...] = ...`,
                    # `@arr[reverse(1..3)] = ...` — iterate the index list and
                    # assign each. Mirrors the hash-slice index-expansion set
                    # (~line 14655) so all list-producing index forms work.
                    #
                    # Force list context around the index expression: N_RANGE's
                    # codegen branches on __perla_want_list at runtime — in
                    # scalar/void context it emits a flip-flop operator
                    # (`static int __ff_st; ...`) that returns a single bool
