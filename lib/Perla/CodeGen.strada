        emit($cg, "if (__dh && !STRADA_IS_TAGGED_INT(__dh) && (__dh->type == STRADA_CLOSURE || __dh->type == STRADA_CPOINTER)) { ");
        emit($cg, "  StradaValue *__da = strada_new_array(); strada_incref(__dv); strada_array_push(strada_deref_array(__da), __dv); ");
        emit($cg, "  /* prevent recursion: clear handler during call */ StradaValue *__dhs = strada_hash_get(v_SIG->value.hv, \"__DIE__\"); if (__dhs) strada_incref(__dhs); strada_hash_delete(v_SIG->value.hv, \"__DIE__\"); ");
        emit($cg, "  StradaValue *__dr = perla_call_code(__dh, __da); if (__dr) strada_decref(__dr); strada_decref(__da); ");
        emit($cg, "  if (__dhs) { strada_hash_set_take(v_SIG->value.hv, \"__DIE__\", __dhs); } ");
