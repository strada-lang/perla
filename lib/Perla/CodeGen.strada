        my int $route_to_stash_h = 0;
        if ($is_arrow_h == 0
            && defined($aobj2) && $aobj2->{"type"} == Perla::AST::N_SCALAR_VAR()
            && defined($aobj2->{"name"}) && index($aobj2->{"name"}, "::") > 0) {
