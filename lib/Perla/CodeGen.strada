        # Hash element assignment: $hash{key} = val
        if ($target_type == Perla::AST::N_HASH_ELEM()) {
            my scalar $inner_hash = $target->{"hash"};
            my int $inner_type = $inner_hash->{"type"};

            # `$ENV{K} = V` must also call setenv() so child processes
            # (qx, system, exec, popen) inherit the new value. Without
            # this, Perl-style "set var then shell out" patterns saw the
            # parent's hash mutated but the shell child still got the
