            emit($cg, "int __sfn_args = (int)__sav->size; ");
            emit($cg, "if (__sfn_args >= 1) __sftm.tm_sec  = (int)strada_to_int(strada_array_get(__sav, 0)); ");
            emit($cg, "if (__sfn_args >= 2) __sftm.tm_min  = (int)strada_to_int(strada_array_get(__sav, 1)); ");
            emit($cg, "if (__sfn_args >= 3) __sftm.tm_hour = (int)strada_to_int(strada_array_get(__sav, 2)); ");
            emit($cg, "if (__sfn_args >= 4) __sftm.tm_mday = (int)strada_to_int(strada_array_get(__sav, 3)); ");
            emit($cg, "if (__sfn_args >= 5) __sftm.tm_mon  = (int)strada_to_int(strada_array_get(__sav, 4)); ");
            emit($cg, "if (__sfn_args >= 6) __sftm.tm_year = (int)strada_to_int(strada_array_get(__sav, 5)); ");
            emit($cg, "if (__sfn_args >= 7) __sftm.tm_wday = (int)strada_to_int(strada_array_get(__sav, 6)); ");
            emit($cg, "if (__sfn_args >= 8) __sftm.tm_yday = (int)strada_to_int(strada_array_get(__sav, 7)); ");
            emit($cg, "__sftm.tm_isdst = __sfn_args >= 9 ? (int)strada_to_int(strada_array_get(__sav, 8)) : -1; ");
