                gen_expr($cg, $target);
                emit($cg, "); StradaArray *__ahf_keys = strada_hash_keys(__a_rhs->value.hv); ");
                emit($cg, "if (__ahf_keys) { for (size_t __ahf_i = 0; __ahf_i < __ahf_keys->size; __ahf_i++) { ");
                emit($cg, "  StradaValue *__ahf_k = __ahf_keys->elements[__ahf_keys->head + __ahf_i]; ");
                emit($cg, "  char *__ahf_ks = strada_to_str(__ahf_k); ");
