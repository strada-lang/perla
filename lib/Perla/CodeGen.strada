                    # list context so they return lists, not scalar counts.
                    # The slice-assign's outer context is statement-void (-1),
                    # so without forcing here `@arr[1..3] = LIST` silently
                    # no-op'd because strada_deref_array(scalar_bool) is NULL.
                    emit($cg, "{ int __as_iwl = __perla_want_list; __perla_want_list = 1; StradaValue *__as_idxs = ");
                    gen_expr($cg, $idx_node);
                    emit($cg, "; __perla_want_list = __as_iwl; StradaArray *__as_ixa = strada_deref_array(__as_idxs); ");
                    emit($cg, "if (__as_ixa) { for (size_t __as_ii = 0; __as_ii < __as_ixa->size; __as_ii++) { ");
                    emit($cg, "  int __as_idx = (int)strada_to_int(__as_ixa->elements[__as_ixa->head + __as_ii]); ");
                    emit($cg, "  if (__as_idx < 0 && __as_tav) __as_idx += strada_array_length(__as_tav); ");
                    emit($cg, "  StradaValue *__as_v = (__as_rav && __as_ri < (int)strada_array_length(__as_rav)) ? strada_array_get(__as_rav, __as_ri) : strada_new_undef(); ");
                    emit($cg, "  if (__as_v) strada_incref(__as_v); strada_array_set(__as_tav, __as_idx, __as_v); __as_ri++; ");
                    emit($cg, "} } } ");
                } else {
                    emit($cg, "{ int __as_idx = (int)strada_to_int(");
                    gen_expr($cg, $idx_node);
                    emit($cg, "); if (__as_idx < 0 && __as_tav) __as_idx += strada_array_length(__as_tav); ");
                    emit($cg, "StradaValue *__as_v = (__as_rav && __as_ri < (int)strada_array_length(__as_rav)) ? strada_array_get(__as_rav, __as_ri) : strada_new_undef(); ");
                    emit($cg, "if (__as_v) strada_incref(__as_v); strada_array_set(__as_tav, __as_idx, __as_v); __as_ri++; } ");
