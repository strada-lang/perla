        # code was relying on $foo and %foo sharing the v_foo C var;
        # collision-mangling would otherwise make these accesses read an
        # undeclared v_url.
        my scalar $aobj2 = $node->{"object"};
        my int $route_to_hash = 0;
        # Routing through the mangled hash variant (v_X__h) only applies to
        # `$X{key}` (no-arrow, hash-sigil sugar) — not to `$X->{key}` (explicit
        # scalar-deref). Without the is_explicit_arrow guard, a scalar holding
        # a hashref read as `$data->{k}` was misrouted to v_data__h whenever
        # `@data` also appeared somewhere in the file, even though @data and
        # $data are independent variables.
        my int $is_arrow_h = 0;
        if (defined($node->{"is_explicit_arrow"}) && $node->{"is_explicit_arrow"} == 1) { $is_arrow_h = 1; }
        if ($is_arrow_h == 0
            && defined($aobj2) && $aobj2->{"type"} == Perla::AST::N_SCALAR_VAR()
            && defined($aobj2->{"name"}) && length($aobj2->{"name"}) > 0
            && index($aobj2->{"name"}, "::") < 0 && $aobj2->{"name"} ne "_"
