# Perla CodeGen - Generates C code from the Perl 5 AST
#
# Output links against strada_runtime.c + perla_stash.c
# All package variables go through the stash; lexicals use C locals.

use Perla::AST;
use Perla::Lexer;
use Perla::Parser;
use Perla::CodeGen::Escape;
use Perla::CodeGen::FreeVars;
use Perla::CodeGen::Collect;
use Perla::CodeGen::Predicate;
use Perla::CodeGen::Eval;
use Perla::CodeGen::Subst;
use Perla::CodeGen::Interp;
use Perla::CodeGen::Subs;
use Perla::CodeGen::Call;
use Perla::CodeGen::Assign;
use Perla::CodeGen::Operator;
use Perla::CodeGen::Method;

package Perla::CodeGen;

func generate(scalar $ast) str {
    my scalar $sb = sb_new(65536);
    my hash %cg = ();
    $cg{"sb"} = $sb;
    $cg{"indent"} = 0;
    $cg{"pkg"} = "main";
    $cg{"filename"} = defined($ast->{"filename"}) ? $ast->{"filename"} : "(eval)";
    $cg{"lib_paths"} = defined($ast->{"lib_paths"}) ? $ast->{"lib_paths"} : [];
    $cg{"subs"} = {};          # name -> 1 (for forward decls)
    $cg{"anon_subs"} = [];     # collected anonymous sub nodes
    $cg{"our_vars"} = {};      # name -> 1 (our variables)
    # REPL/eval "pad" mode (experimental, default OFF). When PERLA_REPL_PAD=1,
    # top-level package/our scalars are aliased to the process-shared stash
    # registry (perla_scalar_lvalue) so their values persist across dlopen'd
    # REPL-line / eval-body .so's. OFF => byte-identical normal codegen.
    $cg{"pad_mode"} = (core::getenv("PERLA_REPL_PAD") eq "1") ? 1 : 0;
    $cg{"lexical_depth"} = 0;
    $cg{"tmp_count"} = 0;
    $cg{"label_count"} = 0;
    $cg{"label_map"} = {};      # user label -> unique C label
    $cg{"capture_vars"} = {};   # captured variable names in current closure
    $cg{"declared_vars"} = {};  # track declared C variables for loop cleanup
    $cg{"same_scope_decls"} = {};  # `my` vars declared in current scope only
                                # — used to detect "my X masks earlier
                                # declaration in same scope" warning. Reset
                                # (not copied) at every scope boundary.
    $cg{"my_lexicals"} = [];    # ordered list of in-scope `my` scalars
                                # for eval STRING lexical capture. Each entry
                                # is { name => perl_name, c_name => v_NAME,
                                # sigil => '$'|'@'|'%' }. Sub-scope save/restore
                                # mirrors declared_vars.
    $cg{"main_vars"} = [];      # track top-level variables for exit cleanup
    $cg{"file_scope_vars"} = {};  # my vars at file scope (hoisted to static)
    $cg{"moose_pkgs"} = {};     # packages using Moose (skip direct dispatch)

    # Collect all sub declarations and our variables
    Perla::CodeGen::Collect::collect_subs(\%cg, $ast);
    Perla::CodeGen::Collect::register_builtin_protos(\%cg);
    Perla::CodeGen::Collect::collect_our_vars(\%cg, $ast);
    Perla::CodeGen::Collect::collect_file_scope_vars(\%cg, $ast);
    _perla_reset_mangle_collisions();
    _collect_sigil_collisions(\%cg, $ast);
    _perla_snapshot_file_collisions();

    # Header
    emit(\%cg, "/* Generated by Perla - Perl 5 compiler */\n");
    emit(\%cg, "#include \"strada_runtime.h\"\n");
    emit(\%cg, "#include \"perla_stash.h\"\n");
    emit(\%cg, "#include \"perla_dbi.h\"\n");
    emit(\%cg, "#include <string.h>\n");
    emit(\%cg, "#include <stdio.h>\n");
    emit(\%cg, "#include <errno.h>\n");
    emit(\%cg, "#include <math.h>\n");
    emit(\%cg, "#include <stdlib.h>\n");
    emit(\%cg, "#include <stddef.h>\n");
    emit(\%cg, "#include <sys/wait.h>\n");
    emit(\%cg, "#include <sys/stat.h>\n");
    emit(\%cg, "#include <unistd.h>\n");
    emit(\%cg, "#include <time.h>\n");
    emit(\%cg, "#include <dirent.h>\n");
    emit(\%cg, "#include <sys/file.h>\n");
    emit(\%cg, "#include <sys/times.h>\n");
    emit(\%cg, "#include <fcntl.h>\n");
    emit(\%cg, "#include <utime.h>\n");
    emit(\%cg, "#include <signal.h>\n\n");
    emit(\%cg, "/* Strada runtime globals */\n");
    emit(\%cg, "extern StradaValue *v_STDIN;\n");
    emit(\%cg, "extern StradaValue *v_STDOUT;\n");
    emit(\%cg, "extern StradaValue *v_STDERR;\n\n");
    emit(\%cg, "/* Perl special variables (global for precompiled module linking) */\n");
    emit(\%cg, "StradaValue *perla_eval_error = NULL;\n");
    emit(\%cg, "StradaValue *perla_dollar_underscore = NULL;\n");
    emit(\%cg, "extern StradaValue *perla_increment(StradaValue *sv);\n");
    emit(\%cg, "extern StradaValue *perla_decrement(StradaValue *sv);\n");
    emit(\%cg, "extern StradaValue *perla_range_array(StradaValue *from, StradaValue *to);\n");
    emit(\%cg, "extern StradaValue *perla_readline_fh(StradaValue *fh);\n");
    emit(\%cg, "extern StradaValue *perla_read_all_lines_fh(StradaValue *fh);\n");
    emit(\%cg, "extern StradaValue *perla_readline_argv(StradaValue *argv);\n");
    emit(\%cg, "extern StradaValue *perla_reverse_ctx(StradaValue *sv);\n");
    emit(\%cg, "extern StradaValue *perla_overload_binary(StradaValue *left, StradaValue *right, const char *op);\n");
    emit(\%cg, "extern StradaValue *perla_overload_deref(StradaValue *sv, const char *slot_suffix);\n");
    emit(\%cg, "extern PerlGlob *perla_autoload_resolve(const char *pkg);\n");
    emit(\%cg, "extern void perla_set_autoload_var(const char *fullname);\n");
    emit(\%cg, "extern StradaValue *perla_getpwuid_list(StradaValue *uid);\n");
    emit(\%cg, "extern StradaValue *perla_getpwuid_name(StradaValue *uid);\n");
    emit(\%cg, "extern StradaValue *perla_getpwnam_list(StradaValue *name);\n");
    emit(\%cg, "extern StradaValue *perla_getpwnam_name(StradaValue *name);\n");
    emit(\%cg, "StradaValue *perla_irs = NULL;  /* $/ input record separator */\n");
    emit(\%cg, "StradaValue *perla_ors = NULL;  /* $\\ output record separator */\n");
    emit(\%cg, "StradaValue *perla_ofs = NULL;  /* $, output field separator */\n");
    emit(\%cg, "StradaValue *perla_lse = NULL;  /* $\" list-separator for array interp */\n");
    emit(\%cg, "StradaValue *perla_subsep = NULL;  /* $; subscript separator */\n");
    # Format-related specials are defined in perla_stash.c (so the
    # runtime's perla_write_format can read them); main only declares.
    emit(\%cg, "extern StradaValue *perla_dollar_tilde;   /* $~ format name */\n");
    emit(\%cg, "extern StradaValue *perla_dollar_caret;   /* $^ top-of-page name */\n");
    emit(\%cg, "extern StradaValue *perla_dollar_equals;  /* $= page length */\n");
    emit(\%cg, "extern StradaValue *perla_dollar_minus;   /* $- lines-left */\n");
    emit(\%cg, "extern StradaValue *perla_dollar_percent; /* $% page number */\n");
    emit(\%cg, "extern StradaValue *perla_dollar_caret_L; /* $^L form-feed */\n");
    emit(\%cg, "extern StradaValue *perla_dollar_caret_A; /* $^A formline accumulator */\n");
    emit(\%cg, "extern int perla_formline(const char *picture, StradaValue **values, size_t nvalues);\n");
    emit(\%cg, "extern int perla_warnings_active;  /* set by `use warnings;` */\n");
    emit(\%cg, "extern void perla_warn_non_numeric(StradaValue *sv, const char *op_long, const char *file, int line);\n");
    emit(\%cg, "extern void perla_warn_my_masks(const char *varname, const char *file, int line);\n");
    emit(\%cg, "extern void perla_warn_untie_with_refs(int nrefs, const char *file, int line);\n");
    emit(\%cg, "extern long perla_code_override_gen;\n");
    emit(\%cg, "extern void perla_register_format(const char *name, const char *body);\n");
    emit(\%cg, "extern void perla_write_format(const char *name);\n");
    emit(\%cg, "extern void perla_write_format_to_fh(StradaValue *fh_sv);\n");
    emit(\%cg, "extern void perla_register_format_sync(const char *name, void (*fn)(void));\n");
    emit(\%cg, "extern StradaValue *perla_tie_handle(const char *pkg, const char *name, const char *classname, StradaValue *args);\n");
    emit(\%cg, "extern StradaValue *perla_tied_handle_for_name(const char *pkg, const char *name);\n");
    emit(\%cg, "extern StradaValue *perla_tied_handle_get(const char *pkg, const char *name);\n");
    emit(\%cg, "extern StradaValue *perla_tied_handle_readline(const char *pkg, const char *name);\n");
    emit(\%cg, "extern StradaValue *perla_tied_handle_print(const char *pkg, const char *name, StradaValue *args);\n");
    emit(\%cg, "extern StradaValue *perla_tied_handle_printf(const char *pkg, const char *name, StradaValue *args);\n");
    emit(\%cg, "extern StradaValue *perla_tied_handle_close(const char *pkg, const char *name);\n");
    emit(\%cg, "extern void perla_set_selected_handle(const char *name);\n");
    emit(\%cg, "extern void perla_format_set_selected_fmt_name(const char *fmt_name);\n");
    emit(\%cg, "extern void perla_format_set_selected_top_name(const char *top_name);\n");
    emit(\%cg, "int __perla_autoflush = 0;      /* $| */\n");
    emit(\%cg, "int __perla_want_list = 0;\n");
    # Global fallback for wantarray at top-level scope or anywhere
    # outside a sub. Subs shadow this with a local declaration. -1 is
    # the void-context sentinel, so top-level `wantarray` returns
    # undef (matching Perl), not "" (scalar).
    emit(\%cg, "int __perla_caller_want_list = -1;\n");
    emit(\%cg, "StradaValue *v_ARGV = NULL;    /* @ARGV */\n");
    emit(\%cg, "StradaValue *v_ENV = NULL;     /* %ENV */\n");
    emit(\%cg, "StradaValue *v_ISA = NULL;     /* @ISA */\n");
    emit(\%cg, "StradaValue *v__ = NULL;      /* $_ */\n");
    emit(\%cg, "StradaValue *v_SIG = NULL;    /* %SIG */\n");
    emit(\%cg, "StradaValue *v_a = NULL;      /* $a (sort) */\n");
    emit(\%cg, "StradaValue *v_b = NULL;      /* $b (sort) */\n");
    emit(\%cg, "StradaValue *v_INC = NULL;    /* @INC */\n");
    emit(\%cg, "StradaValue *v_INC__h = NULL; /* %INC (loaded modules) */\n");
    emit(\%cg, "StradaValue *__local_save_SIG = NULL;\n");
    emit(\%cg, "StradaValue *__local_save_Data = NULL;\n");
    emit(\%cg, "StradaValue *__local_save_Data_Dumper_Maxdepth = NULL;\n");
    emit(\%cg, "StradaValue *__local_save_ = NULL;\n");
    emit(\%cg, "StradaValue *__local_save__ = NULL;\n");
    emit(\%cg, "StradaValue *__local_save__caret_W = NULL;\n");
    emit(\%cg, "StradaValue *v__caret_W = NULL; /* $^W */\n");
    emit(\%cg, "StradaValue *perla_at_ = NULL; /* @_ fallback */\n");
    emit(\%cg, "StradaValue *v__caret_O = NULL; /* $^O */\n");
    emit(\%cg, "StradaValue *v__rbrack_ = NULL; /* $] */\n");
    emit(\%cg, "StradaValue *v__caret_V = NULL; /* $^V */\n");
    emit(\%cg, "StradaValue *v__caret_X = NULL; /* $^X */\n");
    emit(\%cg, "StradaValue *v__caret_GLOBAL_PHASE = NULL; /* perl GLOBAL_PHASE */\n");
    emit(\%cg, "StradaValue *v__slash_ = NULL; /* $/ - input record separator */\n");
    emit(\%cg, "StradaValue *perla_dollar_zero = NULL; /* $0 */\n");
    emit(\%cg, "extern StradaValue *perla_current_argv;\n");
    emit(\%cg, "int perla_dollar_question = 0; /* $? -- wait status of last system/qx */\n");
    emit(\%cg, "int perla_dollar_dot = 0; /* $. -- current input line number */\n");
    emit(\%cg, "StradaValue **__perla_sort_ctx[16] = {0}; /* sort block captures (write-through slots) */\n");
    emit(\%cg, "StradaValue **__perla_cell[64] = {0}; /* shared closure cells */\n");
    # Named-comparator sort thunk: sets v_a/v_b before calling the named
    # comparator sub (which reads $a/$b as globals). Used by
    # `sort SUBNAME LIST` form. Non-reentrant via the function-pointer
    # global, same as perla_sort_qsort_cmp's g_sort_cmp_fn.
    emit(\%cg, "static StradaValue *(*__perla_sort_named_target)(StradaValue*) = NULL;\n");
    emit(\%cg, "static StradaValue *__perla_sort_named_thunk(StradaValue *args) {\n");
    emit(\%cg, "    StradaValue *__sa = v_a; StradaValue *__sb = v_b;\n");
    emit(\%cg, "    StradaArray *__av = strada_deref_array(args);\n");
    emit(\%cg, "    v_a = (__av && __av->size > 0) ? __av->elements[__av->head + 0] : NULL;\n");
    emit(\%cg, "    v_b = (__av && __av->size > 1) ? __av->elements[__av->head + 1] : NULL;\n");
    # $a/$b are package globals in Perl: also publish to the main:: stash so
    # a comparator that reads them qualified ($main::a, $::a) or from another
    # package (sort Foo::cmp) sees the values, not just the C-local v_a/v_b.
    emit(\%cg, "    if (v_a) perla_scalar_set(\"main\", \"a\", v_a); if (v_b) perla_scalar_set(\"main\", \"b\", v_b);\n");
    emit(\%cg, "    StradaValue *__r = __perla_sort_named_target ? __perla_sort_named_target(args) : NULL;\n");
    emit(\%cg, "    v_a = __sa; v_b = __sb; return __r;\n");
    emit(\%cg, "}\n");
    # Coderef sort thunk: routes through perla_call_code with v_a/v_b set.
    emit(\%cg, "static StradaValue *__perla_sort_coderef_target = NULL;\n");
    emit(\%cg, "static StradaValue *__perla_sort_coderef_thunk(StradaValue *args) {\n");
    emit(\%cg, "    StradaValue *__sa = v_a; StradaValue *__sb = v_b;\n");
    emit(\%cg, "    StradaArray *__av = strada_deref_array(args);\n");
    emit(\%cg, "    v_a = (__av && __av->size > 0) ? __av->elements[__av->head + 0] : NULL;\n");
    emit(\%cg, "    v_b = (__av && __av->size > 1) ? __av->elements[__av->head + 1] : NULL;\n");
    emit(\%cg, "    if (v_a) perla_scalar_set(\"main\", \"a\", v_a); if (v_b) perla_scalar_set(\"main\", \"b\", v_b);\n");
    emit(\%cg, "    StradaValue *__r = __perla_sort_coderef_target ? perla_call_code(__perla_sort_coderef_target, args) : NULL;\n");
    emit(\%cg, "    v_a = __sa; v_b = __sb; return __r;\n");
    emit(\%cg, "}\n");
    # Emit our (global) variable declarations
    my scalar $our_vars = $cg{"our_vars"};
    my array @our_names = keys($our_vars);
    my int $oi = 0;
    my hash %default_vars = ();
    $default_vars{"ARGV"} = 1; $default_vars{"ENV"} = 1; $default_vars{"ISA"} = 1;
    $default_vars{"_"} = 1; $default_vars{"SIG"} = 1; $default_vars{"a"} = 1;
    $default_vars{"b"} = 1; $default_vars{"INC"} = 1;
    $default_vars{"STDOUT"} = 1; $default_vars{"STDIN"} = 1; $default_vars{"STDERR"} = 1;
    my hash %__our_emitted = ();
    while ($oi < scalar(@our_names)) {
        my str $on = $our_names[$oi];
        if (!exists($default_vars{$on})) {
            my str $ot = "" . $our_vars->{$on};
            my str $cname = c_var_for_vtype($ot, $on);
            if (!defined($__our_emitted{$cname})) {
                if ($cg{"pad_mode"} == 1 && $ot eq "SCALAR_VAR") {
                    # Pad mode: alias the scalar to its shared stash slot so its
                    # value persists across REPL-line / eval-body .so loads. The
                    # macro makes every existing read/write of $cname hit the
                    # registry (perla_scalar_lvalue), no per-site changes needed.
                    my str $__pad_pkg = "" . $cg{"pkg"};
                    emit(\%cg, "#define " . $cname . " (*perla_scalar_lvalue(\"" . $__pad_pkg . "\", \"" . $on . "\"))\n");
                } else {
                    emit(\%cg, "static StradaValue *" . $cname . " = NULL;\n");
                }
                $__our_emitted{$cname} = 1;
            }
            # When a name has multiple sigils (`our $x` + `our @x` + `our %x`
            # together), our_vars stores only the last-seen type. Without
            # this fan-out, only one of v_x / v_x__a / v_x__h would be
            # declared, leaving sibling-sigil writes referencing an
            # undeclared identifier. Mirrors the file-scope my-vars fix
            # at line ~193.
            if (exists($__perla_mangle_collisions{$on})) {
                my str $sn = c_var_for_vtype("SCALAR_VAR", $on);
                my str $an = c_var_for_vtype("ARRAY_VAR", $on);
                my str $hn = c_var_for_vtype("HASH_VAR", $on);
                if (!defined($__our_emitted{$sn})) {
                    emit(\%cg, "static StradaValue *" . $sn . " = NULL;\n");
                    $__our_emitted{$sn} = 1;
                }
                if (!defined($__our_emitted{$an})) {
                    emit(\%cg, "static StradaValue *" . $an . " = NULL;\n");
                    $__our_emitted{$an} = 1;
                }
                if (!defined($__our_emitted{$hn})) {
                    emit(\%cg, "static StradaValue *" . $hn . " = NULL;\n");
                    $__our_emitted{$hn} = 1;
                }
            }
        }
        $oi++;
    }
    # Emit file-scope my variables as static (accessible from subs).
    # When a name has multiple sigils (`my $s`+`my @s` at file scope),
    # emit a declaration for EACH sigil so `v_s` (for $s), `v_s__a`
    # (for @s), `v_s__h` (for %s) all exist. Previously only the last
    # `my` win recorded; the others compiled to undeclared identifiers.
    my scalar $fs_vars = $cg{"file_scope_vars"};
    my array @fs_names = keys($fs_vars);
    my int $fi = 0;
    my hash %__fs_emitted = ();
    while ($fi < scalar(@fs_names)) {
        my str $fsn = $fs_names[$fi];
        # Don't re-declare if already an our var or a default variable
        # $/ is owned by main and declared as extern in module mode —
        # skip the static emit here so we don't collide with the extern decl.
        if (!exists($our_vars->{$fsn}) && $fsn ne "a" && $fsn ne "b" && $fsn ne "_" && $fsn ne "ISA" && $fsn ne "SIG" && $fsn ne "ARGV" && $fsn ne "ENV" && $fsn ne "INC" && $fsn ne "STDOUT" && $fsn ne "STDIN" && $fsn ne "STDERR" && $fsn ne "/") {
            my str $fst = "" . $fs_vars->{$fsn};
            my str $cname = c_var_for_vtype($fst, $fsn);
            if (!defined($__fs_emitted{$cname})) {
                emit(\%cg, "static StradaValue *" . $cname . " = NULL;\n");
                $__fs_emitted{$cname} = 1;
            }
            # If the name has multiple sigils at file scope, declare the
            # OTHER sigils too. file_scope_vars stores only one type per
            # name (the last `my` wins), so without this, `my $s` after
            # `my @s` only emitted v_s__a and v_s remained undeclared.
            if (exists($__perla_mangle_collisions{$fsn})) {
                my str $sn = c_var_for_vtype("SCALAR_VAR", $fsn);
                my str $an = c_var_for_vtype("ARRAY_VAR", $fsn);
                my str $hn = c_var_for_vtype("HASH_VAR", $fsn);
                if (!defined($__fs_emitted{$sn})) {
                    emit(\%cg, "static StradaValue *" . $sn . " = NULL;\n");
                    $__fs_emitted{$sn} = 1;
                }
                if (!defined($__fs_emitted{$an})) {
                    emit(\%cg, "static StradaValue *" . $an . " = NULL;\n");
                    $__fs_emitted{$an} = 1;
                }
                if (!defined($__fs_emitted{$hn})) {
                    emit(\%cg, "static StradaValue *" . $hn . " = NULL;\n");
                    $__fs_emitted{$hn} = 1;
                }
            }
        }
        $fi++;
    }
    emit(\%cg, "\n");

    # Emit file-scope __C__ blocks (includes, statics, typedefs)
    my scalar $stmts_pre = $ast->{"stmts"};
    my int $ci = 0;
    while ($ci < scalar(@{$stmts_pre})) {
        my scalar $cs = $stmts_pre->[$ci];
        if (defined($cs) && $cs->{"type"} == Perla::AST::N_C_BLOCK()) {
            my str $code = $cs->{"code"};
            if (index($code, "#include") >= 0 || index($code, "static ") >= 0 ||
                index($code, "typedef") >= 0 || index($code, "extern ") >= 0) {
                emit(\%cg, "/* __C__ (file scope) */\n");
                emit(\%cg, $code);
                emit(\%cg, "\n\n");
                # Mark as emitted so it's not re-emitted inside main()
                $cs->{"_emitted"} = 1;
            }
        }
        $ci++;
    }

    # Forward declarations for subs
    my scalar $subs = $cg{"subs"};
    my array @sub_names = keys($subs);
    my int $si = 0;
    while ($si < scalar(@sub_names)) {
        my str $qname = $sub_names[$si];
        my str $fname = sub_cname_q($qname);
        emit(\%cg, "StradaValue* " . $fname . "(StradaValue *perla_args);\n");
        # Forward declare direct-arg version if sub has known params
        my scalar $pinfo = $cg{"sub_params"}->{$qname};
        if (defined($pinfo)) {
            my int $arity = $pinfo->{"arity"};
            emit(\%cg, "StradaValue* " . $fname . "__direct(");
            my int $pi = 0;
            while ($pi < $arity) {
                if ($pi > 0) { emit(\%cg, ", "); }
                emit(\%cg, "StradaValue*");
                $pi++;
            }
            # Trailing perla_args_full param.
            if ($arity > 0) { emit(\%cg, ", "); }
            emit(\%cg, "StradaValue*");
            emit(\%cg, ");\n");
        }
        $si++;
    }
    if (scalar(@sub_names) > 0) { emit(\%cg, "\n"); }

    # Main function
    emit(\%cg, "int main(int argc, char **argv) {\n");
    $cg{"indent"} = 1;
    $cg{"in_main"} = 1;
    # Per-main closure-cell table — shadows the file-scope global (declared
    # at line 118) so top-level closures in main don't collide with closures
    # created by code we call (or vice-versa). See gen_sub_def for the
    # detailed rationale.
    ind(\%cg); emit(\%cg, "StradaValue **__perla_cell[64] __attribute__((unused)) = {0};\n");
    ind(\%cg); emit(\%cg, "perla_init();\n");
    ind(\%cg); emit(\%cg, "perla_dbi_init();\n");
    ind(\%cg); emit(\%cg, "strada_init_proctitle(argc, argv);\n");
    # Seed runtime `require` search paths from the compile-time
    # lib_paths (which already combined perla.conf, PERL5LIB, -I
    # flags, etc). Also include inc_roots (from `perl -V @INC` under
    # PERLA_PERL) so binaries inherit whatever Perl install they were
    # compiled against. Baking these in means the compiled binary
    # doesn't depend on /etc/perla.conf being present at runtime. If
    # PERLA_LIB is set at runtime it overrides.
    {
        my str $baked = "";
        my scalar $cg_lib_paths = $cg{"lib_paths"};
        if (defined($cg_lib_paths)) {
            my int $lpi = 0;
            while ($lpi < scalar(@{$cg_lib_paths})) {
                my str $lp = $cg_lib_paths->[$lpi];
                if (length($lp) > 0) {
                    if (length($baked) > 0) { $baked = $baked . ":"; }
                    $baked = $baked . Perla::CodeGen::Escape::escape_c_str($lp);
                }
                $lpi++;
            }
        }
        my scalar $cg_inc_roots = $ast->{"inc_roots"};
        if (defined($cg_inc_roots)) {
            my int $iri = 0;
            while ($iri < scalar(@{$cg_inc_roots})) {
                my str $ir = $cg_inc_roots->[$iri];
                if (length($ir) > 0) {
                    if (length($baked) > 0) { $baked = $baked . ":"; }
                    $baked = $baked . Perla::CodeGen::Escape::escape_c_str($ir);
                }
                $iri++;
            }
        }
        ind(\%cg); emit(\%cg, "{ const char *__rpl = getenv(\"PERLA_LIB\"); extern void perla_require_set_paths(const char *); if (__rpl && __rpl[0]) perla_require_set_paths(__rpl); else perla_require_set_paths(\"" . $baked . "\"); }\n");
    }
    # Set perla path for eval STRING runtime — try PERLA_PATH, then derive from STRADA_DIR.
    # If derivation from /proc/self/exe fails (binary in shallow path), fall
    # back to searching PATH for 'perla' so eval STRING keeps working.
    # Additionally, bake in the compile-time path to perla itself as a final fallback —
    # this guarantees eval STRING works from any directory without requiring env vars
    # or PATH setup.
    my str $baked_perla_path = "";
    my str $baked_strada_dir = "";
    # Bake in the path to the perla binary for runtime eval STRING / require
    # (which re-invoke perla). The authoritative source is /proc/self/exe — the
    # very perla compiling this program — which is correct whether perla is
    # installed, run from its build dir, or anywhere else. PERLA_PATH overrides;
    # a $STRADA_DIR/perla/perla guess is kept only as a legacy fallback for the
    # old "perla inside the strada tree" layout.
    my str $compile_perla = core::getenv("PERLA_PATH");
    if (length($compile_perla) == 0) {
        my str $cp_readlink = "";
        __C__ {
            char buf[2048];
            ssize_t len = readlink("/proc/self/exe", buf, sizeof(buf)-1);
            if (len > 0) {
                buf[len] = '\0';
                strada_decref(cp_readlink);
                cp_readlink = strada_new_str(buf);
            }
        }
        if (length($cp_readlink) > 0) { $compile_perla = $cp_readlink; }
    }
    # Legacy fallback: perla as a subdir of a Strada source tree.
    if (length($compile_perla) == 0) {
        my str $compile_sd = core::getenv("STRADA_DIR");
        if (length($compile_sd) > 0) { $compile_perla = $compile_sd . "/perla/perla"; }
    }
    # strada_dir hint passed to the child perla. The child self-detects Strada
    # (system install or its own STRADA_DIR), so this is only used when the user
    # explicitly set STRADA_DIR at compile time; otherwise leave it empty.
    $baked_strada_dir = core::getenv("STRADA_DIR");
    $baked_perla_path = Perla::CodeGen::Escape::escape_c_str($compile_perla);
    $baked_strada_dir = Perla::CodeGen::Escape::escape_c_str($baked_strada_dir);

    # Resolution order for eval STRING's perla binary + strada_dir hint:
    # 1. PERLA_PATH env var (explicit user override), if it exists.
    # 2. Compile-time baked path = the perla that built this program. Authoritative
    #    and cwd-independent; correct whether perla is installed or run in place.
    # 3. PATH walk for an installed 'perla'.
    # 4. Legacy $STRADA_DIR/perla/perla (old "perla inside the strada tree" layout).
    # 5. Literal "perla" (hope PATH picks it up at popen time).
    ind(\%cg); emit(\%cg, "{ const char *__pp = getenv(\"PERLA_PATH\"); const char *__sd = getenv(\"STRADA_DIR\");\n");
    ind(\%cg); emit(\%cg, "  char __ppbuf[1024] = \"\";\n");
    # Verify any user-supplied PERLA_PATH actually exists.
    ind(\%cg); emit(\%cg, "  if (__pp && __pp[0]) { FILE *__tp = fopen(__pp, \"r\"); if (!__tp) { __pp = NULL; } else { fclose(__tp); } }\n");
    # Baked-at-compile-time path (the perla that compiled us; works in any cwd).
    ind(\%cg); emit(\%cg, "  if (!__pp) { FILE *__bt = fopen(\"" . $baked_perla_path . "\", \"r\"); if (__bt) { fclose(__bt); __pp = \"" . $baked_perla_path . "\"; if (!__sd || !__sd[0]) __sd = \"" . $baked_strada_dir . "\"; } }\n");
    # PATH walk for an installed 'perla'.
    ind(\%cg); emit(\%cg, "  static char __path_found[1024] = \"\";\n");
    ind(\%cg); emit(\%cg, "  if (!__pp) { const char *__path = getenv(\"PATH\"); if (__path) { const char *__s = __path; while (*__s) { const char *__e = strchr(__s, ':'); size_t __ln = __e ? (size_t)(__e - __s) : strlen(__s); if (__ln > 0 && __ln < 900) { snprintf(__path_found, sizeof(__path_found), \"%.*s/perla\", (int)__ln, __s); FILE *__pt = fopen(__path_found, \"r\"); if (__pt) { fclose(__pt); __pp = __path_found; break; } } if (!__e) break; __s = __e + 1; } } }\n");
    # Legacy: perla as a subdir of $STRADA_DIR (old in-tree layout), guarded by existence.
    ind(\%cg); emit(\%cg, "  if (!__pp && __sd && __sd[0]) { snprintf(__ppbuf, sizeof(__ppbuf), \"%s/perla/perla\", __sd); FILE *__tp = fopen(__ppbuf, \"r\"); if (__tp) { fclose(__tp); __pp = __ppbuf; } }\n");
    ind(\%cg); emit(\%cg, "  perla_eval_set_paths(__pp ? __pp : \"perla\", __sd ? __sd : \".\"); }\n");
    ind(\%cg); emit(\%cg, "perla_irs = strada_new_str(\"\\n\");\n");
    # Mirror to v__slash_ so \`local \$/\` saves the actual current value
    # rather than NULL. Without this the save-and-restore correctly
    # cycled v__slash_ but perla_irs ended up NULL after restore, and
    # the next read mistook NULL for slurp-mode.
    ind(\%cg); emit(\%cg, "v__slash_ = perla_irs; if (v__slash_) strada_incref(v__slash_);\n");
    # \$\\ and \$, default to undef in Perl, not empty string. Initializing
    # to "" makes \`defined \$\\\` and \`(\$\\ // "x") eq "x"\` give wrong
    # answers. Existing print-time guards already treat NULL as no-op.
    ind(\%cg); emit(\%cg, "/* perla_ors / perla_ofs left NULL (undef) */\n");
    ind(\%cg); emit(\%cg, "perla_lse = strada_new_str(\" \");\n");
    ind(\%cg); emit(\%cg, "perla_subsep = strada_new_str(\"\\034\");\n");
    # @ARGV from command line args (skip argv[0] which is program name)
    ind(\%cg); emit(\%cg, "v_ARGV = strada_new_array();\n");
    ind(\%cg); emit(\%cg, "for (int __ai = 1; __ai < argc; __ai++) strada_array_push(strada_deref_array(v_ARGV), strada_new_str(argv[__ai]));\n");
    # %ENV from environment
    ind(\%cg); emit(\%cg, "v_ENV = strada_new_hash();\n");
    ind(\%cg); emit(\%cg, "{ extern char **environ; char **__ep = environ; while (__ep && *__ep) { char *__eq = strchr(*__ep, '='); if (__eq) { char *__k = strndup(*__ep, __eq - *__ep); strada_hv_store(v_ENV, __k, strada_new_str(__eq + 1)); free(__k); } __ep++; } }\n");
    # Clear errno so `$!` at script start reads empty (matches perl). Perla's
    # init may leave errno non-zero from a failed syscall during startup
    # (env walk, stat, etc.), making `if ($!) { ... }` truthy before any
    # user error happens.
    ind(\%cg); emit(\%cg, "errno = 0;\n\n");

    # Push main call frame for caller() support
    ind(\%cg); emit(\%cg, "perla_call_push(\"main\", \"(main)\", \"" . $cg{"filename"} . "\", 0);\n");

    # Per-call mark for `local $h->{k} = v` save records — captures the
    # current global chain head so we can unwind back to it on exit. The
    # chain itself (__perla_local_chain) is a runtime-owned global so
    # die-unwind through nested frames lands at the eval BLOCK with all
    # intermediate locals still recoverable.
    ind(\%cg); emit(\%cg, "void *__perla_local_chain_mark __attribute__((unused)) = __perla_local_chain;\n");

    # Initialize our/my hash/array variables (static vars start as NULL)
    $oi = 0;
    while ($oi < scalar(@our_names)) {
        my str $on = $our_names[$oi];
        if (!exists($default_vars{$on})) {
            my str $ot = "" . $our_vars->{$on};
            if ($ot eq "HASH_VAR") {
                ind(\%cg); emit(\%cg, "if (!" . c_var_h($on) . ") " . c_var_h($on) . " = strada_new_hash();\n");
            } elsif ($ot eq "ARRAY_VAR") {
                ind(\%cg); emit(\%cg, "if (!" . c_var_a($on) . ") " . c_var_a($on) . " = strada_new_array();\n");
            }
            # When `our $x`+`our @x`+`our %x` collide, our_vars only
            # records one type. Init the other container sigils too so
            # later assignments find a valid container.
            if (exists($__perla_mangle_collisions{$on})) {
                if ($ot ne "ARRAY_VAR") {
                    ind(\%cg); emit(\%cg, "if (!" . c_var_a($on) . ") " . c_var_a($on) . " = strada_new_array();\n");
                }
                if ($ot ne "HASH_VAR") {
                    ind(\%cg); emit(\%cg, "if (!" . c_var_h($on) . ") " . c_var_h($on) . " = strada_new_hash();\n");
                }
            }
        }
        $oi++;
    }
    # Also init file-scope my hash/array vars
    $fi = 0;
    while ($fi < scalar(@fs_names)) {
        my str $fsn = $fs_names[$fi];
        if (!exists($our_vars->{$fsn}) && !exists($default_vars{$fsn})) {
            my str $fst = "" . $fs_vars->{$fsn};
            if ($fst eq "HASH_VAR") {
                ind(\%cg); emit(\%cg, "if (!" . c_var_h($fsn) . ") " . c_var_h($fsn) . " = strada_new_hash();\n");
            } elsif ($fst eq "ARRAY_VAR") {
                ind(\%cg); emit(\%cg, "if (!" . c_var_a($fsn) . ") " . c_var_a($fsn) . " = strada_new_array();\n");
            }
        }
        $fi++;
    }

    # Initialize special variables
    ind(\%cg); emit(\%cg, "v_SIG = strada_new_hash();\n");
    # Pre-populate %SIG with all known signal names so `keys %SIG`
    # returns the same set as Perl. perla_populate_sig_hash walks the
    # libc signal-name table and stores each as undef (Perl uses
    # \"DEFAULT\" but undef matches Perl's display when print-ing).
    ind(\%cg); emit(\%cg, "{ extern void perla_populate_sig_hash(StradaValue *); perla_populate_sig_hash(v_SIG); }\n");
    ind(\%cg); emit(\%cg, "v_INC = strada_new_array();\n");
    # Populate v_INC from the runtime require paths so user code that
    # examines @INC (e.g. for module discovery) sees the same paths
    # that `use`/`require` actually search. The paths are set above by
    # `perla_require_set_paths(baked)`.
    ind(\%cg); emit(\%cg, "{ extern char **g_require_paths; extern size_t g_require_path_count; ");
    emit(\%cg, "if (g_require_paths) { StradaArray *__inca = strada_deref_array(v_INC); ");
    emit(\%cg, "for (size_t __ii = 0; __ii < g_require_path_count; __ii++) { ");
    emit(\%cg, "if (g_require_paths[__ii]) strada_array_push_take(__inca, strada_new_str(g_require_paths[__ii])); ");
    emit(\%cg, "} } }\n");
    # %INC (loaded-modules hash) — point v_INC__h at the runtime's
    # g_INC_hash so `exists \$INC{"Mod.pm"}` reflects perla_mark_loaded
    # / perla_require_module state.
    ind(\%cg); emit(\%cg, "{ extern StradaValue *g_INC_hash; if (!g_INC_hash) g_INC_hash = strada_new_hash(); v_INC__h = g_INC_hash; strada_incref(v_INC__h); }\n");
    ind(\%cg); emit(\%cg, "v_ISA = strada_new_array();\n");
    ind(\%cg); emit(\%cg, "if (!v_ARGV) v_ARGV = strada_new_array();\n");
    ind(\%cg); emit(\%cg, "v__caret_O = strada_new_str(\"linux\");\n");
    ind(\%cg); emit(\%cg, "v__rbrack_ = strada_new_str(\"5.042000\");\n");
    # $^V is Perl's v-string version. The lexer now tokenizes `N.N.N`
    # literals as a single STRING "N.N.N"; Config.pm's
    # `$^V eq 5.42.0` thus compares against the string "5.42.0".
    ind(\%cg); emit(\%cg, "v__caret_V = strada_new_str(\"5.42.0\");\n");
    # $^X is the perl binary path. Used by some boot paths; baking in a
    # reasonable default (the PERLA_PERL at compile time, else "perl").
    ind(\%cg); emit(\%cg, "{ const char *__px = getenv(\"PERLA_PERL\"); v__caret_X = strada_new_str(__px && __px[0] ? __px : \"perl\"); }\n");
    # perl GLOBAL_PHASE — phase indicator. perla doesn't track
    # phase transitions through BEGIN/CHECK/INIT, so we initialize to
    # "RUN" (the most common observed value) so that
    # `if (..GLOBAL_PHASE eq 'DESTRUCT')` guards (common in CPAN
    # modules like Variable::Magic, Devel::GlobalDestruction, DBIx::
    # Class) follow the normal path.
    ind(\%cg); emit(\%cg, "v__caret_GLOBAL_PHASE = strada_new_str(\"RUN\");\n");
    # $0 — program name. Perl sets this to the script path (e.g.
    # `/tmp/foo.pl`); the user can write to it to change the proc
    # title. perla compiles the .pl to a native binary, so argv[0]
    # is the compiled binary path (no .pl extension). Bake in the
    # source-file path so $0 matches Perl by default; if the user
    # invoked the binary directly (not via `perla script.pl`),
    # PERLA_DOLLAR_ZERO env var can override.
    my str $__src_file_lit = "";
    if (defined($cg{"filename"})) { $__src_file_lit = Perla::CodeGen::Escape::escape_c_str("" . $cg{"filename"}); }
    elsif (defined($cg{"src_file"})) { $__src_file_lit = Perla::CodeGen::Escape::escape_c_str("" . $cg{"src_file"}); }
    if (length($__src_file_lit) > 0) {
        ind(\%cg); emit(\%cg, "{ const char *__d0_env = getenv(\"PERLA_DOLLAR_ZERO\"); ");
        emit(\%cg, "perla_dollar_zero = strada_new_str(__d0_env ? __d0_env : \"" . $__src_file_lit . "\"); }\n");
    } else {
        ind(\%cg); emit(\%cg, "perla_dollar_zero = strada_new_str(argc > 0 && argv[0] ? argv[0] : \"perla\");\n");
    }

    # __DATA__ section — if the source had a `__DATA__` marker, the
    # parser stashed the post-marker content here. Open it as an
    # in-memory filehandle and set main::DATA so `<DATA>` reads it.
    if (defined($ast->{"data_section"})) {
        my str $data_lit = Perla::CodeGen::Escape::escape_c_str($ast->{"data_section"});
        ind(\%cg); emit(\%cg, "{ extern StradaValue *strada_open_str(const char *, const char *); ");
        emit(\%cg, "StradaValue *__data_fh = strada_open_str(\"" . $data_lit . "\", \"r\"); ");
        emit(\%cg, "perla_scalar_set(\"main\", \"DATA\", __data_fh); }\n");
    }

    # Register subs in the stash
    $si = 0;
    while ($si < scalar(@sub_names)) {
        my str $qname = $sub_names[$si];
        my str $fname = sub_cname_q($qname);
        # Split qname into pkg::name
        # Find LAST :: to split into package + short name
        my int $sep = -1;
        my int $si2 = 0;
        while ($si2 < length($qname) - 1) {
            if (substr($qname, $si2, 2) eq "::") { $sep = $si2; }
            $si2++;
        }
        my str $pkg = "main";
        my str $short = $qname;
        if ($sep >= 0) {
            $pkg = substr($qname, 0, $sep);
            $short = substr($qname, $sep + 2, length($qname) - $sep - 2);
        }
        # Skip registration for subs that have native C runtime implementations
        # (e.g., Exporter::import). Those C impls are installed in perla_init()
        # and the compiled .pm version is broken / incomplete (Exporter.pm uses
        # Exporter::Heavy via goto).
        if (!($pkg eq "Exporter" && $short eq "import")) {
            ind(\%cg); emit(\%cg, "perla_code_set(\"" . $pkg . "\", \"" . $short . "\", strada_new_str(\"" . $fname . "\"));\n");
        }
        $si++;
    }
    if (scalar(@sub_names) > 0) { emit(\%cg, "\n"); }

    # Register prototypes for any sub declared with `(PROTO)`. Looked up
    # at runtime via prototype("PKG::name"). Without this, Sub::Util's
    # `prototype()` always returned empty.
    if (defined($cg{"sub_protos"})) {
        my array @proto_keys = keys($cg{"sub_protos"});
        my int $pki = 0;
        while ($pki < scalar(@proto_keys)) {
            my str $pq = $proto_keys[$pki];
            my str $pv = "" . $cg{"sub_protos"}->{$pq};
            # Escape backslashes and double quotes for the C string literal.
            my str $pv_esc = "";
            my int $ei = 0;
            while ($ei < length($pv)) {
                my str $ch = substr($pv, $ei, 1);
                if ($ch eq "\\") { $pv_esc = $pv_esc . "\\\\"; }
                elsif ($ch eq "\"") { $pv_esc = $pv_esc . "\\\""; }
                else { $pv_esc = $pv_esc . $ch; }
                $ei = $ei + 1;
            }
            ind(\%cg); emit(\%cg, "perla_set_prototype(\"" . $pq . "\", \"" . $pv_esc . "\");\n");
            $pki = $pki + 1;
        }
    }

    # Emit sub-attribute registrations + MODIFY_CODE_ATTRIBUTES dispatch.
    # perla_set_attributes stores the list keyed by qname; attributes::get
    # reads it back. perla_dispatch_modify_code_attributes invokes the
    # user-defined MODIFY_CODE_ATTRIBUTES on each sub's package if
    # present (deferred after all sub registrations so the hook itself
    # is callable). Per Perl: an empty return means accept; a non-empty
    # return is the list of unaccepted attrs (which we currently warn
    # about but don't fatally reject — TODO).
    if (defined($cg{"sub_attrs"})) {
        my array @attr_keys = keys($cg{"sub_attrs"});
        my int $aki = 0;
        while ($aki < scalar(@attr_keys)) {
            my str $aq = $attr_keys[$aki];
            my scalar $alist = $cg{"sub_attrs"}->{$aq};
            my int $alen = scalar(@{$alist});
            # Pkg = portion before final "::"
            my str $apkg = "main";
            my int $lc = -1;
            my int $sx = 0;
            while ($sx < length($aq) - 1) {
                if (substr($aq, $sx, 2) eq "::") { $lc = $sx; }
                $sx = $sx + 1;
            }
            if ($lc > 0) { $apkg = substr($aq, 0, $lc); }
            ind(\%cg); emit(\%cg, "perla_set_attributes(\"" . $aq . "\", " . $alen);
            my int $aj = 0;
            while ($aj < $alen) {
                my str $av = "" . $alist->[$aj];
                my str $av_esc = "";
                my int $eei = 0;
                while ($eei < length($av)) {
                    my str $ch = substr($av, $eei, 1);
                    if ($ch eq "\\") { $av_esc = $av_esc . "\\\\"; }
                    elsif ($ch eq "\"") { $av_esc = $av_esc . "\\\""; }
                    else { $av_esc = $av_esc . $ch; }
                    $eei = $eei + 1;
                }
                emit(\%cg, ", \"" . $av_esc . "\"");
                $aj = $aj + 1;
            }
            emit(\%cg, ");\n");
            ind(\%cg);
            emit(\%cg, "perla_dispatch_modify_code_attributes(\"" . $apkg . "\", \"" . $aq . "\");\n");
            $aki = $aki + 1;
        }
    }

    # Generate top-level statements. Perl runs BEGIN blocks BEFORE the
    # rest of main code (in source order among themselves), regardless
    # of their position in the source. Without this hoist,
    # `BEGIN { ...A... } CODE BEGIN { ...B... }` ran A, then CODE, then
    # B, while Perl runs A, B, then CODE.
    my scalar $stmts = $ast->{"stmts"};
    # int type-inference (M1): compute int-eligible locals for main scope.
    _compute_int_vars(\%cg, $stmts);
    my int $i = 0;
    # Perl phase ordering: BEGIN (source order) → CHECK/UNITCHECK (reverse
    # declaration order) → INIT (source order) → main. perla runs them all at
    # program start (it compiles ahead of time), but the relative order still
    # matters — `BEGIN{}INIT{}` must print B then I. `use`/`no` are wrapped in
    # phase-less BEGINs and stay in the BEGIN pass.
    # Pass 1 — BEGIN blocks, source order.
    while ($i < scalar(@{$stmts})) {
        my scalar $stmt = $stmts->[$i];
        if (defined($stmt) && $stmt->{"type"} == Perla::AST::N_BEGIN()
            && (!defined($stmt->{"phase"}) || $stmt->{"phase"} eq "BEGIN")) {
            gen_stmt(\%cg, $stmt);
        }
        $i++;
    }
    # Pass 2 — CHECK / UNITCHECK blocks, REVERSE declaration order.
    $i = scalar(@{$stmts}) - 1;
    while ($i >= 0) {
        my scalar $stmt = $stmts->[$i];
        if (defined($stmt) && $stmt->{"type"} == Perla::AST::N_BEGIN()
            && defined($stmt->{"phase"})
            && ($stmt->{"phase"} eq "CHECK" || $stmt->{"phase"} eq "UNITCHECK")) {
            gen_stmt(\%cg, $stmt);
        }
        $i = $i - 1;
    }
    # Pass 3 — INIT blocks, source order.
    $i = 0;
    while ($i < scalar(@{$stmts})) {
        my scalar $stmt = $stmts->[$i];
        if (defined($stmt) && $stmt->{"type"} == Perla::AST::N_BEGIN()
            && defined($stmt->{"phase"}) && $stmt->{"phase"} eq "INIT") {
            gen_stmt(\%cg, $stmt);
        }
        $i++;
    }
    $i = 0;
    while ($i < scalar(@{$stmts})) {
        my scalar $stmt = $stmts->[$i];
        if (defined($stmt) && $stmt->{"type"} != Perla::AST::N_SUB()
            && $stmt->{"type"} != Perla::AST::N_BEGIN()
            && $stmt->{"type"} != Perla::AST::N_END()
            && !($stmt->{"type"} == Perla::AST::N_C_BLOCK() && $stmt->{"_emitted"} == 1)) {
            gen_stmt(\%cg, $stmt);
        }
        $i++;
    }

    emit(\%cg, "\n");
    # END blocks run in LIFO order before program exit (Perl semantics).
    # Emit them after the main body but before cleanup so they can still
    # touch package vars and lexical state.
    my array @end_blocks;
    $i = 0;
    while ($i < scalar(@{$stmts})) {
        my scalar $stmt = $stmts->[$i];
        if (defined($stmt) && $stmt->{"type"} == Perla::AST::N_END()) {
            push(@end_blocks, $stmt);
        }
        $i = $i + 1;
    }
    my int $ei = scalar(@end_blocks) - 1;
    while ($ei >= 0) {
        my scalar $eb = $end_blocks[$ei];
        ind(\%cg); emit(\%cg, "/* END block */\n");
        _gen_block(\%cg, $eb->{"body"});
        $ei = $ei - 1;
    }

    # Cleanup top-level variables
    my scalar $mv = $cg{"main_vars"};
    if (defined($mv)) {
        my int $di = 0;
        while ($di < scalar(@{$mv})) {
            my scalar $mve = $mv->[$di];
            ind(\%cg); emit(\%cg, "strada_decref(" . c_var_for_vtype($mve->{"type"}, $mve->{"name"}) . ");\n");
            $di++;
        }
    }
    ind(\%cg); emit(\%cg, "perla_cleanup();\n");
    ind(\%cg); emit(\%cg, "return 0;\n");
    emit(\%cg, "}\n\n");
    $cg{"in_main"} = 0;

    # Hoisted sub bodies must be emitted under THIS module's own strict state,
    # not whatever strict_vars an inlined dependency's `use strict` left behind
    # after the statement pass (that leak caused nondeterministic
    # "Global symbol requires explicit package name" on no-strict modules that
    # use a strict dependency). module_own_strict is set only by a top-level
    # (non-inlined) use/no strict; default off.
    my int $__mos = defined($cg{"module_own_strict"}) ? $cg{"module_own_strict"} : 0;
    $cg{"strict_vars"} = $__mos;
    $cg{"strict_subs"} = $__mos;
    $cg{"strict_refs"} = $__mos;

    # Generate sub bodies (including from nested blocks)
    Perla::CodeGen::Subs::gen_sub_bodies_from_stmts(\%cg, $stmts);

    # Generate anonymous sub bodies (collected during codegen above)
    my scalar $anon_subs = $cg{"anon_subs"};
    $i = 0;
    while ($i < scalar(@{$anon_subs})) {
        Perla::CodeGen::Subs::gen_sub_def(\%cg, $anon_subs->[$i]);
        $i++;
    }

    my str $code = sb_to_string($sb);
    # The generated C is manipulated below (and in perla.strada's fix passes)
    # with byte-offset index()/substr() surgery — e.g. the auto-declared-vars
    # post-pass splices a block at `index($code, "int main(")`. If a non-ASCII
    # string literal in the source made $code UTF-8-flagged, those offsets are
    # CODEPOINT offsets, not byte offsets, so the splice lands mid-token and
    # produces broken C (e.g. `NUL` + comment + `L` instead of `NULL`). The C
    # text is ASCII-structured (only some string-literal contents are
    # non-ASCII), so treat $code as bytes throughout the post-processing.
    __C__ {
        if (code && !STRADA_IS_TAGGED_INT(code) && code->type == STRADA_STR) {
            strada_set_utf8_flag(code, 0);
        }
    }

    # If we have anon subs, prepend their forward declarations.
    # Mark them `static` so each .pm.so keeps its own copy file-local —
    # otherwise two .so's loaded with RTLD_GLOBAL into the same process
    # both export `perla_sub_main___perla_anon_1` and the dynamic linker
    # interposes them: every closure built in the second .so points at
    # the first .so's body. Surfaced by Eval::Closure (used by
    # Params::ValidationCompiler / DateTime::TimeZone validators) where
    # all eval'd validators silently delegated to the first one.
    if (scalar(@{$anon_subs}) > 0) {
        my str $fwd = "";
        $i = 0;
        while ($i < scalar(@{$anon_subs})) {
            my scalar $asub = $anon_subs->[$i];
            my str $afname = sub_cname_q($asub->{"package"} . "::" . $asub->{"name"});
            my scalar $acaps = $asub->{"captures"};
            if (defined($acaps) && scalar(@{$acaps}) > 0) {
                $fwd = $fwd . "static StradaValue* " . $afname . "(StradaValue ***, StradaValue *);\n";
            } else {
                $fwd = $fwd . "static StradaValue* " . $afname . "(StradaValue *perla_args);\n";
            }
            $i++;
        }
        # Insert after the first occurrence of the newline after includes
        my int $insert_pos = index($code, "int main(");
        if ($insert_pos > 0) {
            $code = substr($code, 0, $insert_pos) . $fwd . "\n" . substr($code, $insert_pos);
        }
    }

    # Inject extern declarations for precompiled module init functions
    my scalar $pc_externs = $cg{"precompiled_externs"};
    if (defined($pc_externs) && scalar(@{$pc_externs}) > 0) {
        my str $ext_block = "/* Precompiled module init declarations */\n";
        my int $ei = 0;
        while ($ei < scalar(@{$pc_externs})) {
            $ext_block = $ext_block . $pc_externs->[$ei] . "\n";
            $ei++;
        }
        $ext_block = $ext_block . "\n";
        my int $main_pos2 = index($code, "int main(");
        if ($main_pos2 > 0) {
            $code = substr($code, 0, $main_pos2) . $ext_block . substr($code, $main_pos2);
        }
    }

    # Embed precompiled .o paths in a comment for the linker
    my scalar $pc_objects = $cg{"precompiled_objects"};
    if (defined($pc_objects) && scalar(@{$pc_objects}) > 0) {
        my str $obj_comment = "/* PERLA_LINK_OBJECTS:";
        my int $oi2 = 0;
        while ($oi2 < scalar(@{$pc_objects})) {
            $obj_comment = $obj_comment . " " . $pc_objects->[$oi2];
            $oi2++;
        }
        $obj_comment = $obj_comment . " */\n";
        $code = $obj_comment . $code;
    }

    # Post-process: find undeclared v_* variables and auto-declare them
    # Only do this for large programs (module code that has variable leaks)
    if (length($code) < 500) {
        return $code;
    }
    my hash %declared = ();
    my hash %used = ();
    my array @lines = split("\n", $code);
    my int $li = 0;
    while ($li < scalar(@lines)) {
        my str $ln = $lines[$li];
        # Hoist length() — a line can be a huge (529KB+) string literal; see
        # the $__fln_len note in the function-body scan below.
        my int $__ln_len = length($ln);
        # Track declarations: "static StradaValue *v_NAME" or "StradaValue *v_NAME"
        my int $dp = index($ln, "StradaValue *v_");
        while ($dp >= 0) {
            my int $vs = $dp + 13;
            my int $ve = $vs;
            while ($ve < $__ln_len) {
                my str $vc = substr($ln, $ve, 1);
                if (($vc ge "a" && $vc le "z") || ($vc ge "A" && $vc le "Z") || ($vc ge "0" && $vc le "9") || $vc eq "_") { $ve++; } else { last; }
            }
            if ($ve > $vs) { $declared{substr($ln, $vs, $ve - $vs)} = 1; }
            $dp = index($ln, "StradaValue *v_", $dp + 15);
        }
        # Track uses: any v_NAME
        my int $up = index($ln, "v_");
        while ($up >= 0) {
            my int $ue = $up + 2;
            while ($ue < $__ln_len) {
                my str $uc = substr($ln, $ue, 1);
                if (($uc ge "a" && $uc le "z") || ($uc ge "A" && $uc le "Z") || ($uc ge "0" && $uc le "9") || $uc eq "_") { $ue++; } else { last; }
            }
            if ($ue > $up + 2) { $used{substr($ln, $up, $ue - $up)} = 1; }
            $up = index($ln, "v_", $ue);
        }
        $li++;
    }
    my str $decl_block = "";
    my array @unames = keys(%used);
    # Exclude variables declared in runtime headers or as file-scope vars
    my hash %exclude = ();
    $exclude{"v_STDOUT"} = 1;
    $exclude{"v_STDIN"} = 1;
    $exclude{"v_STDERR"} = 1;
    $exclude{"v_ARGV"} = 1;
    $exclude{"v_ENV"} = 1;
    $exclude{"v_ISA"} = 1;
    $exclude{"v__"} = 1;
    $exclude{"v_SIG"} = 1;
    $exclude{"v_a"} = 1;
    $exclude{"v_b"} = 1;
    $exclude{"v_INC"} = 1;
    $exclude{"v_INC__h"} = 1;
    $exclude{"v__caret_O"} = 1;
    $exclude{"v__rbrack_"} = 1;
    $exclude{"v__caret_W"} = 1;
    $exclude{"v__caret_V"} = 1;
    $exclude{"v__caret_X"} = 1;
    $exclude{"v__caret_GLOBAL_PHASE"} = 1;
    # Also exclude anything that appears in the our_vars or file_scope_vars
    my scalar $ov = $cg{"our_vars"};
    if (defined($ov)) {
        my array @ovk = keys($ov);
        my int $ovi = 0;
        while ($ovi < scalar(@ovk)) { $exclude{"v_" . replace_all($ovk[$ovi], "::", "_")} = 1; $ovi++; }
    }
    my scalar $fv = $cg{"file_scope_vars"};
    if (defined($fv)) {
        my array @fvk = keys($fv);
        my int $fvi = 0;
        while ($fvi < scalar(@fvk)) { $exclude{"v_" . replace_all($fvk[$fvi], "::", "_")} = 1; $fvi++; }
    }
    # Only count declarations at file scope (static) or before main, not inside functions
    # A variable declared inside a function body is NOT visible in main()
    # Re-clear $code's UTF-8 flag here: an earlier concat (e.g. the anon-sub
    # forward-decl prepend) can re-flag it after the clear at assembly time, and
    # the index()/substr() splice below MUST use byte offsets — index() returns a
    # byte offset but substr() treats a flagged string's offset as a CODEPOINT
    # offset, so on a $code containing a non-ASCII string literal the splice
    # lands mid-token (`NULL` -> `NUL` + block + `L`), breaking the C.
    __C__ {
        if (code && !STRADA_IS_TAGGED_INT(code) && code->type == STRADA_STR) {
            strada_set_utf8_flag(code, 0);
        }
    }
    my hash %file_declared = ();
    my int $main_start = index($code, "int main(");
    if ($main_start < 0) { $main_start = 0; }
    my str $pre_main = substr($code, 0, $main_start);
    my int $__pre_main_len = length($pre_main);
    my int $pdp = index($pre_main, "StradaValue *v_");
    while ($pdp >= 0) {
        my int $pvs = $pdp + 13;
        my int $pve = $pvs;
        while ($pve < $__pre_main_len) {
            my str $pvc = substr($pre_main, $pve, 1);
            if (($pvc ge "a" && $pvc le "z") || ($pvc ge "A" && $pvc le "Z") || ($pvc ge "0" && $pvc le "9") || $pvc eq "_") { $pve++; } else { last; }
        }
        if ($pve > $pvs) { $file_declared{substr($pre_main, $pvs, $pve - $pvs)} = 1; }
        $pdp = index($pre_main, "StradaValue *v_", $pdp + 15);
    }
    my int $ui = 0;
    while ($ui < scalar(@unames)) {
        my str $vn = $unames[$ui];
        if (!exists($file_declared{$vn}) && !exists($exclude{$vn})) {
            $decl_block = $decl_block . "static StradaValue *" . $vn . " = NULL;\n";
        }
        $ui++;
    }
    # Also auto-declare __local_save_* variables used in the code
    # ($code is multi-MB for big programs — hoist length() out of the inner
    # scan loop; recomputing it per character is O(n^2) and hung e.pl's
    # cold-cache recompile of large modules.)
    my int $__code_len = length($code);
    my int $lsp = index($code, "__local_save_");
    while ($lsp >= 0) {
        my int $lse = $lsp + 13;
        while ($lse < $__code_len) {
            my str $lsc = substr($code, $lse, 1);
            if (($lsc ge "a" && $lsc le "z") || ($lsc ge "A" && $lsc le "Z") || ($lsc ge "0" && $lsc le "9") || $lsc eq "_") { $lse++; } else { last; }
        }
        my str $lsname = substr($code, $lsp, $lse - $lsp);
        # Length > 13 skips the bare "__local_save_" prefix itself (13 chars)
        # while still including all suffixed forms, including "__local_save__"
        # (14 chars) used for `local $_`.
        if (index($code, "StradaValue *" . $lsname) < 0 && index($decl_block, $lsname) < 0 && length($lsname) > 13) {
            $decl_block = $decl_block . "static StradaValue *" . $lsname . " = NULL;\n";
        }
        $lsp = index($code, "__local_save_", $lse);
    }

    if (length($decl_block) > 0) {
        my int $main_pos = index($code, "int main(");
        if ($main_pos > 0) {
            $code = substr($code, 0, $main_pos) . "/* auto-declared variables */\n" . $decl_block . "\n" . substr($code, $main_pos);
        }
    }

    # Auto-declare undeclared variables inside function bodies
    # Scan each function for v_* variables used but not declared
    my array @lines2 = split("\n", $code);
    my int $len2 = size(@lines2);
    my int $li2 = 0;
    my int $modified = 0;
    while ($li2 < $len2) {
        my str $ln2 = $lines2[$li2];
        # Detect function start: "StradaValue* perla_sub_...(..." or "void perla_mod_init_..."
        if ((index($ln2, "StradaValue* perla_sub_") >= 0 || index($ln2, "void perla_mod_init_") >= 0) && index($ln2, ";") < 0 && index($ln2, "{") >= 0) {
            # Find function body end (matching closing brace)
            my int $brace_depth = 1;
            my int $fn_start = $li2 + 1;
            my int $fn_end = $fn_start;
            while ($fn_end < $len2 && $brace_depth > 0) {
                my str $fl = $lines2[$fn_end];
                my int $fi2 = 0;
                my int $__fl_len = length($fl);
                while ($fi2 < $__fl_len) {
                    my str $fc = substr($fl, $fi2, 1);
                    if ($fc eq "{") { $brace_depth++; }
                    if ($fc eq "}") { $brace_depth--; }
                    $fi2++;
                }
                $fn_end++;
            }
            # Scan function body for declared and used v_* variables
            my hash %fn_declared = ();
            my hash %fn_used = ();
            my int $fli = $fn_start;
            while ($fli < $fn_end) {
                my str $fln = $lines2[$fli];
                # A single line can be huge (a 529KB string literal emitted as
                # one PERLA_NEW_STR_LIT(...) — e.g. Locale::SubCountry::Codes'
                # JSON). Hoist length() out of the per-char scan loops below;
                # recomputing it per character is O(n^2) and hung e.pl's
                # cold-cache recompile of such modules.
                my int $__fln_len = length($fln);
                # Track declarations: "StradaValue *v_NAME"
                my int $dp2 = index($fln, "StradaValue *v_");
                while ($dp2 >= 0) {
                    my int $vs2 = $dp2 + 13;
                    my int $ve2 = $vs2;
                    while ($ve2 < $__fln_len) {
                        my str $vc2 = substr($fln, $ve2, 1);
                        if (($vc2 ge "a" && $vc2 le "z") || ($vc2 ge "A" && $vc2 le "Z") || ($vc2 ge "0" && $vc2 le "9") || $vc2 eq "_") { $ve2++; } else { last; }
                    }
                    if ($ve2 > $vs2) { $fn_declared{substr($fln, $vs2, $ve2 - $vs2)} = 1; }
                    $dp2 = index($fln, "StradaValue *v_", $dp2 + 15);
                }
                # Track uses: v_NAME (only at word boundaries)
                my int $up2 = index($fln, "v_");
                while ($up2 >= 0) {
                    if ($up2 == 0 || substr($fln, $up2 - 1, 1) eq " " || substr($fln, $up2 - 1, 1) eq "(" || substr($fln, $up2 - 1, 1) eq "," || substr($fln, $up2 - 1, 1) eq "*" || substr($fln, $up2 - 1, 1) eq "!") {
                        my int $ue2 = $up2 + 2;
                        while ($ue2 < $__fln_len) {
                            my str $uc2 = substr($fln, $ue2, 1);
                            if (($uc2 ge "a" && $uc2 le "z") || ($uc2 ge "A" && $uc2 le "Z") || ($uc2 ge "0" && $uc2 le "9") || $uc2 eq "_") { $ue2++; } else { last; }
                        }
                        $fn_used{substr($fln, $up2, $ue2 - $up2)} = 1;
                        $up2 = index($fln, "v_", $ue2);
                    } else {
                        $up2 = index($fln, "v_", $up2 + 1);
                    }
                }
                $fli++;
            }
            # Also scan for __local_save_* in function body
            $fli = $fn_start;
            while ($fli < $fn_end) {
                my str $fln2 = $lines2[$fli];
                my int $lsp2 = index($fln2, "__local_save_");
                while ($lsp2 >= 0) {
                    my int $lse2 = $lsp2 + 13;
                    while ($lse2 < length($fln2)) {
                        my str $lc = substr($fln2, $lse2, 1);
                        if (($lc ge "a" && $lc le "z") || ($lc ge "A" && $lc le "Z") || ($lc ge "0" && $lc le "9") || $lc eq "_") { $lse2++; } else { last; }
                    }
                    my str $lsn = substr($fln2, $lsp2, $lse2 - $lsp2);
                    if (length($lsn) > 13) {
                        $fn_used{$lsn} = 1;
                        # Also check if it's declared
                        if (index($fln2, "StradaValue *" . $lsn) >= 0) {
                            $fn_declared{$lsn} = 1;
                        }
                    }
                    $lsp2 = index($fln2, "__local_save_", $lse2);
                }
                $fli++;
            }
            # Add declarations for undeclared variables
            my str $fn_decls = "";
            my array @fn_unames = keys(%fn_used);
            my int $fui = 0;
            while ($fui < scalar(@fn_unames)) {
                my str $fvn = $fn_unames[$fui];
                if (!exists($fn_declared{$fvn}) && !exists($exclude{$fvn})) {
                    # For __local_save_* vars, always declare locally
                    # For v_* vars, check if it's a file-scope static (don't shadow)
                    my int $is_file_scope = 0;
                    if (index($fvn, "__local_save_") != 0) {
                        # Check if this var is declared before main() (file scope)
                        my str $static_decl = "static StradaValue *" . $fvn . " = NULL;";
                        my str $global_decl = "StradaValue *" . $fvn . " = NULL;";
                        my int $main_start = index($code, "int main(");
                        if ($main_start > 0) {
                            my str $pre = substr($code, 0, $main_start);
                            if (index($pre, $static_decl) >= 0 || index($pre, $global_decl) >= 0) {
                                $is_file_scope = 1;
                            }
                        }
                    }
                    if ($is_file_scope == 0) {
                        $fn_decls = $fn_decls . "    StradaValue *" . $fvn . " = NULL;\n";
                    }
                }
                $fui++;
            }
            if (length($fn_decls) > 0) {
                $lines2[$fn_start] = $fn_decls . $lines2[$fn_start];
                $modified = 1;
            }
        }
        $li2++;
    }
    if ($modified == 1) {
        $code = join("\n", @lines2);
    }

    # Inject any format-sync helper functions BEFORE `int main(` so the
    # static defs are visible to the main body's perla_register_format_sync
    # calls. The helpers reference file-scope C vars (`v_x`) which are
    # declared earlier in the file, so the insertion point only needs to
    # precede main.
    if (defined($cg{"format_sync_defs"}) && length($cg{"format_sync_defs"}) > 0) {
        my int $__fs_main_at = index($code, "int main(");
        if ($__fs_main_at > 0) {
            $code = substr($code, 0, $__fs_main_at)
                  . $cg{"format_sync_defs"}
                  . substr($code, $__fs_main_at, length($code) - $__fs_main_at);
        }
    }

    return $code;
}

# Generate a standalone C file for a precompiled module (.o)
# Instead of main(), emits an init function: void perla_mod_init_Pkg_Name(void)
# The init function registers all subs in the stash and runs module-level code.
func generate_module(scalar $ast, str $mod_name) str {
    my scalar $sb = sb_new(65536);
    my hash %cg = ();
    $cg{"sb"} = $sb;
    $cg{"indent"} = 0;
    $cg{"pkg"} = $mod_name;
    $cg{"subs"} = {};
    $cg{"anon_subs"} = [];
    $cg{"our_vars"} = {};
    $cg{"pad_mode"} = (core::getenv("PERLA_REPL_PAD") eq "1") ? 1 : 0;
    $cg{"lexical_depth"} = 0;
    $cg{"tmp_count"} = 0;
    $cg{"label_count"} = 0;
    $cg{"label_map"} = {};
    $cg{"capture_vars"} = {};
    $cg{"declared_vars"} = {};
    $cg{"same_scope_decls"} = {};
    $cg{"my_lexicals"} = [];
    $cg{"main_vars"} = [];
    $cg{"file_scope_vars"} = {};
    $cg{"module_mode"} = 1;

    # Collect all sub declarations and our variables
    Perla::CodeGen::Collect::collect_subs(\%cg, $ast);
    Perla::CodeGen::Collect::register_builtin_protos(\%cg);
    Perla::CodeGen::Collect::collect_our_vars(\%cg, $ast);
    Perla::CodeGen::Collect::collect_file_scope_vars(\%cg, $ast);
    _perla_reset_mangle_collisions();
    _collect_sigil_collisions(\%cg, $ast);
    _perla_snapshot_file_collisions();

    # C init function name: perla_mod_init_Pkg_Name
    my str $init_name = "perla_mod_init_" . replace_all($mod_name, "::", "_");

    # Header
    emit(\%cg, "/* Precompiled Perla module: " . $mod_name . " */\n");
    emit(\%cg, "#include \"strada_runtime.h\"\n");
    emit(\%cg, "#include \"perla_stash.h\"\n");
    emit(\%cg, "#include \"perla_dbi.h\"\n");
    emit(\%cg, "#include <string.h>\n");
    emit(\%cg, "#include <stdio.h>\n");
    emit(\%cg, "#include <errno.h>\n");
    emit(\%cg, "#include <math.h>\n");
    emit(\%cg, "#include <stdlib.h>\n");
    emit(\%cg, "#include <stddef.h>\n");
    emit(\%cg, "#include <sys/wait.h>\n");
    emit(\%cg, "#include <sys/stat.h>\n");
    emit(\%cg, "#include <unistd.h>\n");
    emit(\%cg, "#include <time.h>\n");
    emit(\%cg, "#include <dirent.h>\n");
    emit(\%cg, "#include <sys/times.h>\n");
    emit(\%cg, "#include <fcntl.h>\n");
    emit(\%cg, "#include <utime.h>\n\n");

    # Perla runtime globals as extern (defined in the main program)
    emit(\%cg, "/* Strada runtime globals */\n");
    emit(\%cg, "extern StradaValue *v_STDIN;\n");
    emit(\%cg, "extern StradaValue *v_STDOUT;\n");
    emit(\%cg, "extern StradaValue *v_STDERR;\n\n");

    # Perl special variables - extern (owned by main)
    emit(\%cg, "/* Perl special variables (extern - owned by main) */\n");
    emit(\%cg, "extern StradaValue *perla_eval_error;\n");
    emit(\%cg, "extern StradaValue *perla_dollar_underscore;\n");
    emit(\%cg, "extern StradaValue *perla_increment(StradaValue *sv);\n");
    emit(\%cg, "extern StradaValue *perla_decrement(StradaValue *sv);\n");
    emit(\%cg, "extern StradaValue *perla_range_array(StradaValue *from, StradaValue *to);\n");
    emit(\%cg, "extern StradaValue *perla_readline_fh(StradaValue *fh);\n");
    emit(\%cg, "extern StradaValue *perla_read_all_lines_fh(StradaValue *fh);\n");
    emit(\%cg, "extern StradaValue *perla_readline_argv(StradaValue *argv);\n");
    emit(\%cg, "extern StradaValue *perla_reverse_ctx(StradaValue *sv);\n");
    emit(\%cg, "extern StradaValue *perla_overload_binary(StradaValue *left, StradaValue *right, const char *op);\n");
    emit(\%cg, "extern StradaValue *perla_overload_deref(StradaValue *sv, const char *slot_suffix);\n");
    emit(\%cg, "extern PerlGlob *perla_autoload_resolve(const char *pkg);\n");
    emit(\%cg, "extern void perla_set_autoload_var(const char *fullname);\n");
    emit(\%cg, "extern StradaValue *perla_getpwuid_list(StradaValue *uid);\n");
    emit(\%cg, "extern StradaValue *perla_getpwuid_name(StradaValue *uid);\n");
    emit(\%cg, "extern StradaValue *perla_getpwnam_list(StradaValue *name);\n");
    emit(\%cg, "extern StradaValue *perla_getpwnam_name(StradaValue *name);\n");
    emit(\%cg, "extern StradaValue *perla_irs;\n");
    emit(\%cg, "extern StradaValue *perla_ors;\n");
    emit(\%cg, "extern StradaValue *perla_ofs;\n");
    emit(\%cg, "extern StradaValue *perla_lse;\n");
    emit(\%cg, "extern StradaValue *perla_subsep;\n");
    emit(\%cg, "extern StradaValue *perla_dollar_tilde;\n");
    emit(\%cg, "extern StradaValue *perla_dollar_caret;\n");
    emit(\%cg, "extern StradaValue *perla_dollar_equals;\n");
    emit(\%cg, "extern StradaValue *perla_dollar_minus;\n");
    emit(\%cg, "extern StradaValue *perla_dollar_caret_L;\n");
    emit(\%cg, "extern int __perla_autoflush;\n");
    emit(\%cg, "extern int __perla_want_list;\n");
    emit(\%cg, "extern StradaValue *v_ARGV;\n");
    emit(\%cg, "extern StradaValue *v_ENV;\n");
    emit(\%cg, "extern StradaValue *v_ISA;\n");
    emit(\%cg, "extern StradaValue *v__;\n");
    emit(\%cg, "extern StradaValue *v_SIG;\n");
    emit(\%cg, "extern StradaValue *v_a;\n");
    emit(\%cg, "extern StradaValue *v_b;\n");
    emit(\%cg, "extern StradaValue *v_INC;\n");
    emit(\%cg, "extern StradaValue *v_INC__h;\n");
    emit(\%cg, "extern StradaValue *perla_at_;\n");
    emit(\%cg, "extern StradaValue *v__caret_O;\n");
    emit(\%cg, "extern StradaValue *v__rbrack_;\n");
    emit(\%cg, "extern StradaValue *v__caret_W;\n");
    emit(\%cg, "extern StradaValue *v__caret_V;\n");
    emit(\%cg, "extern StradaValue *v__caret_X;\n");
    emit(\%cg, "extern StradaValue *v__caret_GLOBAL_PHASE;\n");
    # $/ — Perl's input record separator. Owned by main; modules that
    # use `local $/ = ...` or `local $/;` (e.g. YAML.pm's slurp idiom)
    # need this declared so v__slash_ is in scope at compile time.
    emit(\%cg, "extern StradaValue *v__slash_;\n");
    emit(\%cg, "extern StradaValue *perla_dollar_zero;\n");
    emit(\%cg, "extern int perla_dollar_question;\n");
    emit(\%cg, "extern int perla_dollar_dot;\n");
    # `use warnings;` in a runtime-compiled module emits `perla_warnings_active = 1;`
    # — declare it here too (the main-program prelude already does) so the
    # module's own .c compiles instead of failing with "undeclared".
    emit(\%cg, "extern int perla_warnings_active;\n");
    # `perla_code_get` override-cache generation counter: a module body that
    # calls another sub through the override-aware fast path emits
    # `if (__cv_g != perla_code_override_gen) ...`. Declare it here too (the
    # main-program prelude already does) so the module .c compiles instead of
    # failing with "perla_code_override_gen undeclared". Surfaced by
    # Abe::Utils::crnd / get_states_hash dispatch inside Abe::DatabaseRecord.
    emit(\%cg, "extern long perla_code_override_gen;\n");
    emit(\%cg, "extern StradaValue **__perla_sort_ctx[16];\n");
    emit(\%cg, "extern StradaValue **__perla_cell[64];\n");
    # local() save variables (used by modules that do local $SIG{...} etc.)
    emit(\%cg, "extern StradaValue *__local_save_SIG;\n");
    emit(\%cg, "extern StradaValue *__local_save_Data;\n");
    emit(\%cg, "extern StradaValue *__local_save_Data_Dumper_Maxdepth;\n");
    emit(\%cg, "extern StradaValue *__local_save_;\n");
    emit(\%cg, "extern StradaValue *__local_save__;\n");
    emit(\%cg, "extern StradaValue *__local_save__caret_W;\n\n");

    # Module-scoped static variables (our vars + file-scope my vars)
    my scalar $our_vars = $cg{"our_vars"};
    my array @our_names = keys($our_vars);
    my hash %default_vars = ();
    $default_vars{"ARGV"} = 1; $default_vars{"ENV"} = 1; $default_vars{"ISA"} = 1;
    $default_vars{"_"} = 1; $default_vars{"SIG"} = 1; $default_vars{"a"} = 1;
    $default_vars{"b"} = 1; $default_vars{"INC"} = 1;
    $default_vars{"STDOUT"} = 1; $default_vars{"STDIN"} = 1; $default_vars{"STDERR"} = 1;
    # Perl special variables (extern in module mode)
    $default_vars{"_caret_O"} = 1; $default_vars{"_rbrack_"} = 1; $default_vars{"_caret_W"} = 1;
    $default_vars{"_caret_V"} = 1; $default_vars{"_caret_X"} = 1;
    # $/ — input record separator. file_scope_vars stores under the
    # raw name "/" (collect_file_scope_vars uses var->{value} which
    # for `local $/` is "/"). The C variable name is `v__slash_` after
    # safe_ident, declared extern above. Skip the static emit here so
    # we don't get a static-vs-extern conflict.
    $default_vars{"/"} = 1;
    my int $oi = 0;
    while ($oi < scalar(@our_names)) {
        my str $onm = $our_names[$oi];
        if (!exists($default_vars{$onm})) {
            my str $ot2 = "" . $our_vars->{$onm};
            emit(\%cg, "static StradaValue *" . c_var_for_vtype($ot2, $onm) . " = NULL;\n");
        }
        $oi++;
    }
    my scalar $fs_vars = $cg{"file_scope_vars"};
    my array @fs_names = keys($fs_vars);
    my int $fi = 0;
    while ($fi < scalar(@fs_names)) {
        my str $fsn = $fs_names[$fi];
        if (!exists($our_vars->{$fsn}) && !exists($default_vars{$fsn})) {
            my str $fst2 = "" . $fs_vars->{$fsn};
            emit(\%cg, "static StradaValue *" . c_var_for_vtype($fst2, $fsn) . " = NULL;\n");
        }
        $fi++;
    }
    emit(\%cg, "\n");

    # File-scope __C__ blocks
    my scalar $stmts_pre = $ast->{"stmts"};
    my int $ci = 0;
    while ($ci < scalar(@{$stmts_pre})) {
        my scalar $cs = $stmts_pre->[$ci];
        if (defined($cs) && $cs->{"type"} == Perla::AST::N_C_BLOCK()) {
            my str $c_code = $cs->{"code"};
            if (index($c_code, "#include") >= 0 || index($c_code, "static ") >= 0 ||
                index($c_code, "typedef") >= 0 || index($c_code, "extern ") >= 0) {
                emit(\%cg, "/* __C__ (file scope) */\n");
                emit(\%cg, $c_code);
                emit(\%cg, "\n\n");
                $cs->{"_emitted"} = 1;
            }
        }
        $ci++;
    }

    # Forward declarations for subs
    my scalar $subs = $cg{"subs"};
    my array @sub_names = keys($subs);
    my int $si = 0;
    while ($si < scalar(@sub_names)) {
        my str $qname = $sub_names[$si];
        my str $fname = sub_cname_q($qname);
        emit(\%cg, "StradaValue* " . $fname . "(StradaValue *perla_args);\n");
        my scalar $pinfo = $cg{"sub_params"}->{$qname};
        if (defined($pinfo)) {
            my int $arity = $pinfo->{"arity"};
            emit(\%cg, "StradaValue* " . $fname . "__direct(");
            my int $pi = 0;
            while ($pi < $arity) {
                if ($pi > 0) { emit(\%cg, ", "); }
                emit(\%cg, "StradaValue*");
                $pi++;
            }
            # Trailing perla_args_full param.
            if ($arity > 0) { emit(\%cg, ", "); }
            emit(\%cg, "StradaValue*");
            emit(\%cg, ");\n");
        }
        $si++;
    }
    if (scalar(@sub_names) > 0) { emit(\%cg, "\n"); }

    # Init function (replaces main)
    emit(\%cg, "/* Module init - registers subs and runs module-level code */\n");
    emit(\%cg, "void " . $init_name . "(void) {\n");
    # Once-guard: when modules import each other in a cycle (e.g.
    # Abe::App::Shared::SearchTable uses Abe::App::Shared::ReportViews
    # which uses SearchTable back), runtime require can re-enter this
    # init via a different path (statically linked .pm.o + dlopen'd
    # .pm.so calling each other). Without the guard the recursion is
    # unbounded and blows the stack. The static init across compilation
    # units doesn't cover this — each .pm.so has its own static — so
    # the guard fires per-translation-unit, which is exactly what we
    # want: the first entry runs the body, every re-entry is a no-op.
    emit(\%cg, "    static int __perla_init_done = 0;\n");
    emit(\%cg, "    if (__perla_init_done) return;\n");
    emit(\%cg, "    __perla_init_done = 1;\n");
    # Per-call mark for `local` save records (chain itself is a runtime global).
    emit(\%cg, "    void *__perla_local_chain_mark __attribute__((unused)) = __perla_local_chain;\n");
    # Per-module closure-cell table — shadows the file-scope global so
    # module-init closures don't collide with closures in code we call.
    # See gen_sub_def for rationale.
    emit(\%cg, "    StradaValue **__perla_cell[64] __attribute__((unused)) = {0};\n");
    # Push a call frame for the module's top-level so any code that reads
    # `perla_call_stack[depth-1].package` (perla_moose_import, the `has`
    # accessor registration path, `caller()` at file scope) sees OUR
    # package, not whatever caller invoked our init via dlopen. Without
    # this, Moo's `has`/`extends`/etc. and the `has X => (...)` calls
    # that follow register accessors in the WRONG package and `$obj->attr`
    # later misses dispatch with "Can't locate object method ... via
    # package ...". The frame is popped at end-of-init.
    emit(\%cg, "    perla_call_push(\"" . $mod_name . "\", \"(init)\", \"" . $cg{"filename"} . "\", 0);\n");
    # Mark this stash as fully inlined so a runtime `require` of this
    # module short-circuits past the compile+dlopen path. Without this,
    # require() falls back to "is the stash non-empty" — which is wrong
    # when native overrides have pre-seeded a few subs into a stash for
    # a module that hasn't actually been loaded yet.
    emit(\%cg, "    perla_stash_mark_inlined(\"" . $mod_name . "\");\n");
    $cg{"indent"} = 1;
    $cg{"in_main"} = 1;

    # Register subs in the stash
    $si = 0;
    while ($si < scalar(@sub_names)) {
        my str $qname = $sub_names[$si];
        my str $fname = sub_cname_q($qname);
        # Find LAST :: to split into package + short name
        my int $sep = -1;
        my int $si2 = 0;
        while ($si2 < length($qname) - 1) {
            if (substr($qname, $si2, 2) eq "::") { $sep = $si2; }
            $si2++;
        }
        my str $pkg = $mod_name;
        my str $short = $qname;
        if ($sep >= 0) {
            $pkg = substr($qname, 0, $sep);
            $short = substr($qname, $sep + 2, length($qname) - $sep - 2);
        }
        # Skip registration for subs that have native C runtime implementations
        # (see main codegen above for rationale).
        if (!($pkg eq "Exporter" && $short eq "import")) {
            ind(\%cg); emit(\%cg, "perla_code_set(\"" . $pkg . "\", \"" . $short . "\", strada_new_str(\"" . $fname . "\"));\n");
        }
        $si++;
    }
    if (scalar(@sub_names) > 0) { emit(\%cg, "\n"); }

    # Register prototypes for any sub declared with `(PROTO)` in this
    # module (including eval-string wrappers). Without this, an
    # `eval q{ sub myadd ($$) { ... } }` body produced a .pm.so whose
    # init registered the sub but not its prototype, so
    # prototype("myadd") returned undef. Mirrors the same block in
    # generate() above.
    if (defined($cg{"sub_protos"})) {
        my array @mod_proto_keys = keys($cg{"sub_protos"});
        my int $mpki = 0;
        while ($mpki < scalar(@mod_proto_keys)) {
            my str $mpq = $mod_proto_keys[$mpki];
            my str $mpv = "" . $cg{"sub_protos"}->{$mpq};
            my str $mpv_esc = "";
            my int $mei = 0;
            while ($mei < length($mpv)) {
                my str $mch = substr($mpv, $mei, 1);
                if ($mch eq "\\") { $mpv_esc = $mpv_esc . "\\\\"; }
                elsif ($mch eq "\"") { $mpv_esc = $mpv_esc . "\\\""; }
                else { $mpv_esc = $mpv_esc . $mch; }
                $mei = $mei + 1;
            }
            ind(\%cg); emit(\%cg, "perla_set_prototype(\"" . $mpq . "\", \"" . $mpv_esc . "\");\n");
            $mpki = $mpki + 1;
        }
        if (scalar(@mod_proto_keys) > 0) { emit(\%cg, "\n"); }
    }

    # Generate top-level statements (module-level code: package, our, has, @ISA, etc.)
    my scalar $stmts = $ast->{"stmts"};
    my int $i = 0;
    while ($i < scalar(@{$stmts})) {
        my scalar $stmt = $stmts->[$i];
        if (defined($stmt) && $stmt->{"type"} != Perla::AST::N_SUB() &&
            !($stmt->{"type"} == Perla::AST::N_C_BLOCK() && $stmt->{"_emitted"} == 1)) {
            gen_stmt(\%cg, $stmt);
        }
        $i++;
    }

    # End-of-init sync hook marker. Replaced in post-processing with
    # sync code for each file-scope `v_X` that's NOT declared `our` in
    # this module. Each .pm.o has its own `static StradaValue *v_X` for
    # every package variable it references. When `our %X` is declared,
    # codegen mirrors v_X into the stash. When %X is *imported* via
    # `use Foo` (Foo's Exporter copies its hash slot into our stash),
    # the stash has the data but our v_X stays NULL — so sub bodies that
    # reference v_X see nothing. Surfaced via Locale::Codes referencing
    # `%ALL_CODESETS` (imported from Locale::Codes::Constants); _init's
    # `! exists $ALL_CODESETS{$type}` used the NULL v_ALL_CODESETS and
    # silently failed for every type. The actual sync emission happens
    # in post-processing because the full set of file-scope vars isn't
    # known until the auto-declared-variable scan runs over the body.
    emit(\%cg, "    /* __PERLA_SYNC_HOOK__ */\n");

    # Pop the synthetic init frame pushed at the top of the function.
    emit(\%cg, "    perla_call_pop();\n");

    emit(\%cg, "}\n\n");
    $cg{"in_main"} = 0;

    # Hoisted sub bodies must be emitted under THIS module's own strict state,
    # not whatever strict_vars an inlined dependency's `use strict` left behind
    # after the statement pass (that leak caused nondeterministic
    # "Global symbol requires explicit package name" on no-strict modules that
    # use a strict dependency). module_own_strict is set only by a top-level
    # (non-inlined) use/no strict; default off.
    my int $__mos = defined($cg{"module_own_strict"}) ? $cg{"module_own_strict"} : 0;
    $cg{"strict_vars"} = $__mos;
    $cg{"strict_subs"} = $__mos;
    $cg{"strict_refs"} = $__mos;

    # Generate sub bodies (including from nested blocks)
    Perla::CodeGen::Subs::gen_sub_bodies_from_stmts(\%cg, $stmts);

    # Generate anonymous sub bodies
    my scalar $anon_subs = $cg{"anon_subs"};
    $i = 0;
    while ($i < scalar(@{$anon_subs})) {
        Perla::CodeGen::Subs::gen_sub_def(\%cg, $anon_subs->[$i]);
        $i++;
    }

    my str $code = sb_to_string($sb);

    # Prepend anon sub forward declarations if any. `static` keeps each
    # .pm.so's anon symbols file-local so RTLD_GLOBAL doesn't interpose
    # them across modules (see comment in generate()).
    if (scalar(@{$anon_subs}) > 0) {
        my str $fwd = "";
        $i = 0;
        while ($i < scalar(@{$anon_subs})) {
            my scalar $asub = $anon_subs->[$i];
            my str $afname = sub_cname_q($asub->{"package"} . "::" . $asub->{"name"});
            my scalar $acaps = $asub->{"captures"};
            if (defined($acaps) && scalar(@{$acaps}) > 0) {
                $fwd = $fwd . "static StradaValue* " . $afname . "(StradaValue ***, StradaValue *);\n";
            } else {
                $fwd = $fwd . "static StradaValue* " . $afname . "(StradaValue *perla_args);\n";
            }
            $i++;
        }
        my int $insert_pos = index($code, "void " . $init_name);
        if ($insert_pos > 0) {
            $code = substr($code, 0, $insert_pos) . $fwd . "\n" . substr($code, $insert_pos);
        }
    }

    # Auto-declare undeclared variables (same as generate()). Previously gated
    # on code size > 50000 as an optimization, but smaller modules can still
    # reference package vars (e.g. $VERSION) that need file-scope statics for
    # the resulting .c to link.
    if (length($code) > 0) {
        my hash %declared = ();
        my hash %used = ();
        my array @lines = split("\n", $code);
        my int $li = 0;
        while ($li < scalar(@lines)) {
            my str $ln = $lines[$li];
            my int $dp = index($ln, "static StradaValue *v_");
            while ($dp >= 0) {
                my int $vs = $dp + 20;
                my int $ve = $vs;
                while ($ve < length($ln) && substr($ln, $ve, 1) ne " " && substr($ln, $ve, 1) ne "=" && substr($ln, $ve, 1) ne ";") { $ve++; }
                $declared{substr($ln, $vs, $ve - $vs)} = 1;
                $dp = index($ln, "static StradaValue *v_", $ve);
            }
            my int $up = index($ln, "v_");
            while ($up >= 0) {
                # `&` prefix added: perla_local_push_scalar_slot takes the
                # ADDRESS of the var (&v_NAME). Without recognizing `&` as
                # a valid prefix, vars only used in &-form (e.g.
                # `local $Pkg::var = ...` from a *different* package)
                # were not auto-declared and the resulting .pm.c failed
                # gcc with `'v_Pkg_var' undeclared`.
                if ($up == 0 || substr($ln, $up - 1, 1) eq " " || substr($ln, $up - 1, 1) eq "(" || substr($ln, $up - 1, 1) eq "," || substr($ln, $up - 1, 1) eq "*" || substr($ln, $up - 1, 1) eq "!" || substr($ln, $up - 1, 1) eq "&") {
                    my int $ue = $up;
                    while ($ue < length($ln) && substr($ln, $ue, 1) ne " " && substr($ln, $ue, 1) ne ")" && substr($ln, $ue, 1) ne "," && substr($ln, $ue, 1) ne ";" && substr($ln, $ue, 1) ne "[" && substr($ln, $ue, 1) ne "-") { $ue++; }
                    $used{substr($ln, $up, $ue - $up)} = 1;
                    $up = index($ln, "v_", $ue);
                } else {
                    $up = index($ln, "v_", $up + 1);
                }
            }
            $li++;
        }
        my str $decl_block = "";
        my array @unames = keys(%used);
        my hash %exclude = ();
        $exclude{"v_STDOUT"} = 1; $exclude{"v_STDIN"} = 1; $exclude{"v_STDERR"} = 1;
        $exclude{"v_ARGV"} = 1; $exclude{"v_ENV"} = 1; $exclude{"v_ISA"} = 1;
        $exclude{"v__"} = 1; $exclude{"v_SIG"} = 1; $exclude{"v_a"} = 1;
        $exclude{"v_b"} = 1; $exclude{"v_INC"} = 1; $exclude{"v_INC__h"} = 1;
        $exclude{"v__caret_O"} = 1; $exclude{"v__rbrack_"} = 1; $exclude{"v__caret_W"} = 1;
        $exclude{"v__caret_V"} = 1; $exclude{"v__caret_X"} = 1;
        $exclude{"v__caret_GLOBAL_PHASE"} = 1;
        # $/ is externed via the runtime globals block above; don't
        # auto-declare a conflicting static here.
        $exclude{"v__slash_"} = 1;
        my int $ui = 0;
        while ($ui < scalar(@unames)) {
            my str $vn = $unames[$ui];
            if (!exists($declared{$vn}) && !exists($exclude{$vn})) {
                $decl_block = $decl_block . "static StradaValue *" . $vn . " = NULL;\n";
            }
            $ui++;
        }
        if (length($decl_block) > 0) {
            my int $init_pos = index($code, "void " . $init_name);
            if ($init_pos > 0) {
                $code = substr($code, 0, $init_pos) . "/* auto-declared variables */\n" . $decl_block . "\n" . substr($code, $init_pos);
            }
        }

        # Expand the end-of-init sync hook. For each used-but-not-declared
        # `v_X` (auto-declared above), emit a sync from the module's stash
        # slot. This connects Exporter-imported package vars to the file
        # static so `$X{key}` reads in sub bodies see the imported data.
        # Sigil prefix is recovered from the C var-name suffix: `_h` →
        # hash, `_a` → array, otherwise scalar (legacy v_NAME for
        # collision-free names, since we don't carry sigil through to
        # the post-pass).
        my str $sync_block = "";
        my array @snames = keys(%used);
        my int $sui = 0;
        while ($sui < scalar(@snames)) {
            my str $svn = $snames[$sui];
            if (!exists($declared{$svn}) && !exists($exclude{$svn})) {
                # Strip leading "v_"; recover sigil from suffix when present
                # (collision-mangled names get _h/_a/_s suffix).
                my str $bare = substr($svn, 2, length($svn) - 2);
                my int $blen = length($bare);
                my str $force_slot = "";
                if ($blen > 2 && substr($bare, $blen - 2, 2) eq "_h") {
                    $bare = substr($bare, 0, $blen - 2);
                    $force_slot = "PERLA_SLOT_HASH";
                } elsif ($blen > 2 && substr($bare, $blen - 2, 2) eq "_a") {
                    $bare = substr($bare, 0, $blen - 2);
                    $force_slot = "PERLA_SLOT_ARRAY";
                } elsif ($blen > 2 && substr($bare, $blen - 2, 2) eq "_s") {
                    $bare = substr($bare, 0, $blen - 2);
                    $force_slot = "PERLA_SLOT_SCALAR";
                }
                # Skip names with C-encoded special chars (e.g. _caret_O,
                # _rbrack_) — those are Perl special vars, not stashable.
                if (index($bare, "_caret_") >= 0 || index($bare, "_rbrack_") >= 0) {
                    $sui++;
                    next;
                }
                # Pad mode: our-vars are pad-managed (adopted/refilled against
                # their declared package). This sync reads the *module's* stash
                # ($mod_name) and would clobber the adopted container with the
                # module's empty slot — defeating the in-place pad refill. Skip.
                if ($cg->{"pad_mode"} == 1 && defined($cg->{"our_vars"})
                    && defined($cg->{"our_vars"}->{$bare})) {
                    $sui++;
                    next;
                }
                if (length($force_slot) > 0) {
                    # Sigil known from collision suffix: only check that one slot.
                    $sync_block = $sync_block . "    { PerlGlob *__sg = perla_glob_get(perla_stash_get_or_create(\"" . $mod_name . "\"), \"" . $bare . "\"); if (__sg && __sg->slots[" . $force_slot . "] && " . $svn . " != __sg->slots[" . $force_slot . "]) { if (" . $svn . ") strada_decref(" . $svn . "); " . $svn . " = __sg->slots[" . $force_slot . "]; strada_incref(" . $svn . "); } }\n";
                } else {
                    # Sigil unknown (legacy v_NAME without _h/_a/_s suffix): try
                    # HASH, ARRAY, SCALAR in order. The first populated slot wins.
                    # Hash is the most common for Exporter-imported data tables.
                    $sync_block = $sync_block . "    { PerlGlob *__sg = perla_glob_get(perla_stash_get_or_create(\"" . $mod_name . "\"), \"" . $bare . "\"); if (__sg) { StradaValue *__ss = NULL; if (__sg->slots[PERLA_SLOT_HASH]) __ss = __sg->slots[PERLA_SLOT_HASH]; else if (__sg->slots[PERLA_SLOT_ARRAY]) __ss = __sg->slots[PERLA_SLOT_ARRAY]; else if (__sg->slots[PERLA_SLOT_SCALAR]) __ss = __sg->slots[PERLA_SLOT_SCALAR]; if (__ss && " . $svn . " != __ss) { if (" . $svn . ") strada_decref(" . $svn . "); " . $svn . " = __ss; strada_incref(" . $svn . "); } } }\n";
                }
            }
            $sui++;
        }
        if (length($sync_block) > 0) {
            $code = replace_all($code, "    /* __PERLA_SYNC_HOOK__ */\n", "    /* sync Exporter-imported file-scope vars from stash */\n" . $sync_block);
        } else {
            $code = replace_all($code, "    /* __PERLA_SYNC_HOOK__ */\n", "");
        }
    }

    # Auto-declare __local_save_* variables used in the module but not in the
    # fixed extern preamble. Matching generate()'s scanner: any suffixed form
    # (length > 13) that the module references needs a local static so the
    # module's own `local $var` code compiles without extern-linker churn.
    my int $lsp_m = index($code, "__local_save_");
    my str $ls_decls = "";
    my hash %ls_seen = ();
    while ($lsp_m >= 0) {
        my int $lse_m = $lsp_m + 13;
        while ($lse_m < length($code)) {
            my str $lsc_m = substr($code, $lse_m, 1);
            if (($lsc_m ge "a" && $lsc_m le "z") || ($lsc_m ge "A" && $lsc_m le "Z") || ($lsc_m ge "0" && $lsc_m le "9") || $lsc_m eq "_") { $lse_m++; } else { last; }
        }
        my str $lsname_m = substr($code, $lsp_m, $lse_m - $lsp_m);
        if (length($lsname_m) > 13 && !exists($ls_seen{$lsname_m}) && index($code, "extern StradaValue *" . $lsname_m) < 0) {
            $ls_seen{$lsname_m} = 1;
            $ls_decls = $ls_decls . "static StradaValue *" . $lsname_m . " = NULL;\n";
        }
        $lsp_m = index($code, "__local_save_", $lse_m);
    }
    if (length($ls_decls) > 0) {
        my int $init_pos_ls = index($code, "void " . $init_name);
        if ($init_pos_ls > 0) {
            $code = substr($code, 0, $init_pos_ls) . "/* auto-declared local() save slots */\n" . $ls_decls . "\n" . substr($code, $init_pos_ls);
        }
    }

    # Embed dependency .o paths for the linker
    my scalar $pc_objects2 = $cg{"precompiled_objects"};
    if (defined($pc_objects2) && scalar(@{$pc_objects2}) > 0) {
        my str $obj_comment = "/* PERLA_LINK_OBJECTS:";
        my int $oi3 = 0;
        while ($oi3 < scalar(@{$pc_objects2})) {
            $obj_comment = $obj_comment . " " . $pc_objects2->[$oi3];
            $oi3++;
        }
        $obj_comment = $obj_comment . " */\n";
        $code = $obj_comment . $code;
    }

    return $code;
}

func _collect_sigil_collisions(scalar $cg, scalar $ast) void {
    _collect_sigil_collisions_stmts($cg, $ast->{"stmts"});
}

func _collect_sigil_collisions_stmts(scalar $cg, scalar $stmts) void {
    if (!defined($stmts)) { return; }
    my int $i = 0;
    while ($i < scalar(@{$stmts})) {
        my scalar $s = $stmts->[$i];
        if (defined($s)) {
            my int $t = $s->{"type"};
            # Recurse into sub bodies too: function-local `my @foo` /
            # `my $foo` collisions (e.g. Date::Manip::Base::_config_var_workdaybegend
            # which has both `my @beg` and `my $beg`) need the same
            # __h/__a mangling, otherwise the second `my` decrefs the
            # first variable and reuses its C name.
            if ($t == Perla::AST::N_SUB() || $t == Perla::AST::N_METHOD()
                || $t == Perla::AST::N_ANON_SUB()) {
                # Save file-scope collision state, recurse into sub body
                # with a fresh local view, then capture the sub's own
                # collisions and restore. This keeps function-local
                # `my @foo` / `my $foo` collisions (e.g.
                # Date::Manip::Base::_config_var_workdaybegend) mangled
                # within that sub, without leaking them into other scopes
                # where they'd cause false-positive mangling.
                # E.g. `sub make1 { my %info; ... }` shouldn't make
                # `my $info = make1()` in main route to the hash slot.
                my scalar $saved_seen = _perla_clone_hash_with_vals(\%__perla_seen_sigils);
                my scalar $saved_collisions = _perla_clone_hash(\%__perla_mangle_collisions);
                %__perla_seen_sigils = ();
                %__perla_mangle_collisions = ();
                if (defined($s->{"body"}) && defined($s->{"body"}->{"stmts"})) {
                    _collect_sigil_collisions_stmts($cg, $s->{"body"}->{"stmts"});
                } elsif (defined($s->{"body"})) {
                    _collect_sigil_collisions_stmts($cg, $s->{"body"});
                }
                # Capture sub-local collisions for named subs/methods
                # (anon subs are skipped — they fall back to file-scope only).
                if ($t == Perla::AST::N_SUB() || $t == Perla::AST::N_METHOD()) {
                    my str $sn = "";
                    if (defined($s->{"name"})) { $sn = $s->{"name"}; }
                    my str $spkg = "";
                    if (defined($s->{"package"})) { $spkg = $s->{"package"}; }
                    if (length($spkg) == 0 && defined($cg->{"pkg"})) { $spkg = $cg->{"pkg"}; }
                    if (length($sn) > 0 && scalar(keys(%__perla_mangle_collisions)) > 0) {
                        my str $qname = $spkg . "::" . $sn;
                        $__perla_sub_collisions{$qname} = _perla_clone_hash(\%__perla_mangle_collisions);
                    }
                }
                # Restore file-scope state
                _perla_restore_seen_sigils($saved_seen);
                _perla_restore_collisions_inplace($saved_collisions);
                $i++;
                next;
            }
            if ($t == Perla::AST::N_MY() || $t == Perla::AST::N_OUR() || $t == Perla::AST::N_STATE()) {
                if (defined($s->{"var"})) {
                    _perla_record_var_sigil($s->{"var"}->{"value"}, "" . $s->{"var"}->{"type"});
                }
                if (defined($s->{"vars"})) {
                    my int $vi = 0;
                    while ($vi < scalar(@{$s->{"vars"}})) {
                        _perla_record_var_sigil($s->{"vars"}->[$vi]->{"value"}, "" . $s->{"vars"}->[$vi]->{"type"});
                        $vi++;
                    }
                }
            }
            # Recurse into compound nodes with a body/stmts field.
            if (defined($s->{"stmts"})) {
                _collect_sigil_collisions_stmts($cg, $s->{"stmts"});
            }
            if (defined($s->{"body"}) && defined($s->{"body"}->{"stmts"})) {
                _collect_sigil_collisions_stmts($cg, $s->{"body"}->{"stmts"});
            }
            if (defined($s->{"then"}) && defined($s->{"then"}->{"stmts"})) {
                _collect_sigil_collisions_stmts($cg, $s->{"then"}->{"stmts"});
            }
            if (defined($s->{"else"}) && defined($s->{"else"}->{"stmts"})) {
                _collect_sigil_collisions_stmts($cg, $s->{"else"}->{"stmts"});
            }
            if (defined($s->{"init_my"})) {
                my scalar $im = $s->{"init_my"};
                if (defined($im->{"var"})) {
                    _perla_record_var_sigil($im->{"var"}->{"value"}, "" . $im->{"var"}->{"type"});
                }
                if (defined($im->{"vars"})) {
                    my int $ivi = 0;
                    while ($ivi < scalar(@{$im->{"vars"}})) {
                        _perla_record_var_sigil($im->{"vars"}->[$ivi]->{"value"}, "" . $im->{"vars"}->[$ivi]->{"type"});
                        $ivi++;
                    }
                }
            }
        }
        $i++;
    }
}

# --- Generate our variable (global) ---
# Build a plain variable-reference AST node (N_ARRAY_VAR / N_HASH_VAR /
# N_SCALAR_VAR) for the variable declared by an inner `my`/`our` decl node.
# Used to rewrite a chained `our @A = our @B = LIST` outer init into `@B`.
func _decl_var_ref(scalar $decl) scalar {
    my scalar $v = $decl->{"var"};
    my str $vt = "" . $v->{"type"};
    my scalar $ref = undef;
    if ($vt eq "ARRAY_VAR") {
        $ref = Perla::AST::node(Perla::AST::N_ARRAY_VAR());
    } elsif ($vt eq "HASH_VAR") {
        $ref = Perla::AST::node(Perla::AST::N_HASH_VAR());
    } else {
        $ref = Perla::AST::node(Perla::AST::N_SCALAR_VAR());
    }
    $ref->{"name"} = $v->{"value"};
    return $ref;
}

func _gen_our(scalar $cg, scalar $node) void {
    # Chained `our X = our Y = LIST` (e.g. Exporter's
    # `our @EXPORT = our @EXPORT_OK = qw(...)`). gen_expr can't yield a value
    # for an inner `our` declaration — it falls back to undef, so the outer
    # target came out empty. Emit the inner `our` decl as its own statement
    # first (which assigns it AND syncs its glob/stash slot), then rewrite the
    # outer init to reference the inner variable so the outer gets a proper
    # copy. Handles arbitrarily deep chains via the recursive gen_stmt call.
    if (defined($node->{"init"}) && defined($node->{"var"})
        && $node->{"init"}->{"type"} == Perla::AST::N_OUR()
        && defined($node->{"init"}->{"var"})) {
        my scalar $inner = $node->{"init"};
        gen_stmt($cg, $inner);
        $node->{"init"} = _decl_var_ref($inner);
    }
    if (defined($node->{"var"})) {
        my str $vname = $node->{"var"}->{"value"};
        my str $vtype = $node->{"var"}->{"type"};
        # Pad mode: ensure this our-var is recorded in our_vars (scalar/array/
        # hash) so the pad write-back / in-place container refill fires for it.
        # collect_our_vars doesn't descend into the eval wrapper's `my $rv = do
        # { ... }` initializer where eval-body `our` decls live, but the decl is
        # always codegen'd here before the body's assignments run.
        if ($cg->{"pad_mode"} == 1 && length($vname) > 0) {
            $cg->{"our_vars"}->{$vname} = $vtype;
        }

        # Special case: our @ISA = (...) — register inheritance
        if ($vname eq "ISA" && $vtype eq "ARRAY_VAR" && defined($node->{"init"})) {
            my scalar $init = $node->{"init"};
            my str $pkg = $cg->{"pkg"};
            # Reset @Pkg::ISA before pushing — `our @ISA = (...)` is an
            # ASSIGNMENT, not an addition. Without reset, perla's pre-
            # populated @ISA for known modules (e.g., @B::ISA pre-seeded
            # with "Exporter" for Perl's B core module) would leak into
            # user packages that happen to share the name. With reset,
            # `package B; our @ISA = ("A")` correctly yields ["A"].
            ind($cg); emit($cg, "perla_isa_reset(\"" . $pkg . "\");\n");
            if ($init->{"type"} == Perla::AST::N_ANON_ARRAY() || $init->{"type"} == Perla::AST::N_QWORD()) {
                my scalar $elems = $init->{"elems"};
                my int $ei = 0;
                while ($ei < scalar(@{$elems})) {
                    my scalar $elem = $elems->[$ei];
                    my int $et = $elem->{"type"};
                    if ($et == Perla::AST::N_STR_LIT()) {
                        ind($cg); emit($cg, "perla_isa_push(\"" . $pkg . "\", \"" . $elem->{"value"} . "\");\n");
                    } elsif ($et == Perla::AST::N_INTERP_STR()) {
                        # If the interp string has no `$var`/`@var` refs,
                        # treat as literal. Otherwise evaluate at runtime
                        # so `our @ISA = ("File::Spec::$module")` pushes the
                        # interpolated parent name (e.g., "File::Spec::Unix")
                        # rather than the literal `"File::Spec::$module"`
                        # (which perla_isa_push would then try to load as a
                        # module named with a dollar sign).
                        if (has_perl_var($elem->{"value"}) == 0) {
                            ind($cg); emit($cg, "perla_isa_push(\"" . $pkg . "\", \"" . $elem->{"value"} . "\");\n");
                        } else {
                            ind($cg); emit($cg, "{ char *__ipn = strada_to_str(");
                            gen_expr($cg, $elem);
                            emit($cg, "); perla_isa_push(\"" . $pkg . "\", __ipn); free(__ipn); }\n");
                        }
                    } else {
                        ind($cg); emit($cg, "{ char *__ipn = strada_to_str(");
                        gen_expr($cg, $elem);
                        emit($cg, "); perla_isa_push(\"" . $pkg . "\", __ipn); free(__ipn); }\n");
                    }
                    $ei++;
                }
            } elsif ($init->{"type"} == Perla::AST::N_STR_LIT()) {
                # Single string: our @ISA = ('Parent')
                ind($cg); emit($cg, "perla_isa_push(\"" . $pkg . "\", \"" . $init->{"value"} . "\");\n");
            } elsif ($init->{"type"} == Perla::AST::N_INTERP_STR()) {
                if (has_perl_var($init->{"value"}) == 0) {
                    ind($cg); emit($cg, "perla_isa_push(\"" . $pkg . "\", \"" . $init->{"value"} . "\");\n");
                } else {
                    ind($cg); emit($cg, "{ char *__ipn = strada_to_str(");
                    gen_expr($cg, $init);
                    emit($cg, "); perla_isa_push(\"" . $pkg . "\", __ipn); free(__ipn); }\n");
                }
            }
            return;
        }

        # our vars are already declared as globals — just initialize
        if ($vtype eq "HASH_VAR") {
            # Hash vars: always init as hash
            if (defined($node->{"init"}) && $node->{"init"}->{"type"} == Perla::AST::N_ANON_ARRAY()) {
                # my %h = ("k" => "v", ...) — convert from flat array
                my scalar $init_elems = $node->{"init"}->{"elems"};
                if (defined($init_elems) && scalar(@{$init_elems}) > 0) {
                    # Force list context so the N_ANON_ARRAY yields the
                    # full flat array, not the scalar-context last elem.
                    ind($cg); emit($cg, c_var_h($vname) . " = strada_hash_from_flat_array(({ int __sav_wl = __perla_want_list; __perla_want_list = 1; StradaValue *__hi = ");
                    gen_expr($cg, $node->{"init"});
                    emit($cg, "; __perla_want_list = __sav_wl; __hi; }));\n");
                } else {
                    ind($cg); emit($cg, c_var_h($vname) . " = strada_new_hash();\n");
                }
                # Mirror into the stash so `%Pkg::NAME` reads see the value.
                # Without this, `our %h = (a => 1)` populates only v_h; the
                # stash HASH slot stays empty and `%Pkg::h` reads return undef.
                ind($cg); emit($cg, "{ PerlGlob *__og = perla_glob_get_or_create(perla_stash_get_or_create(\"" . $cg->{"pkg"} . "\"), \"" . $vname . "\"); ");
                emit($cg, "if (__og->slots[PERLA_SLOT_HASH]) strada_decref(__og->slots[PERLA_SLOT_HASH]); ");
                emit($cg, "__og->slots[PERLA_SLOT_HASH] = " . c_var_h($vname) . "; if (" . c_var_h($vname) . ") strada_incref(" . c_var_h($vname) . "); }\n");
            } elsif (defined($node->{"init"})) {
                # Init from non-anon-array expr (map, function call, @list,
                # explicit hashref, etc.). When the RHS is a flat key/value
                # array (e.g. `map { $_=>length $_ } @keys` or `@kv_pairs`),
                # we need to convert to a real hash. When it's already a
                # hash (e.g. `(%other_hash)` or a hashref deref), keep it.
                ind($cg); emit($cg, c_var_h($vname) . " = ({ int __sav_wl = __perla_want_list; __perla_want_list = 1; StradaValue *__hi = ");
                gen_expr($cg, $node->{"init"});
                emit($cg, "; __perla_want_list = __sav_wl; ");
                # `our %h = %g` is a COPY, not an alias — copy entries into a
                # fresh hash so a later `$h{k}=...` doesn't leak into %g (and
                # the chained `our %h = our %g = (...)` gives independent hashes).
                emit($cg, "(__hi && !STRADA_IS_TAGGED_INT(__hi) && __hi->type == STRADA_HASH) ? ({ StradaValue *__ohcp = strada_new_hash(); StradaHash *__ohdst = strada_deref_hash(__ohcp); StradaHash *__ohsrc = strada_deref_hash(__hi); StradaArray *__ohk = __ohsrc ? strada_hash_keys(__ohsrc) : (StradaArray*)NULL; if (__ohk) { for (size_t __ohi = 0; __ohi < __ohk->size; __ohi++) { StradaValue *__ohkk = __ohk->elements[__ohk->head + __ohi]; char *__ohks = strada_to_str(__ohkk); StradaValue *__ohv = strada_hash_get(__ohsrc, __ohks); if (__ohv) strada_incref(__ohv); strada_hash_set_take(__ohdst, __ohks, __ohv); free(__ohks); } strada_free_array(__ohk); } __ohcp; }) : strada_hash_from_flat_array(__hi); });\n");
                # Mirror into the stash so `%Pkg::NAME` reads see the value.
                ind($cg); emit($cg, "{ PerlGlob *__og = perla_glob_get_or_create(perla_stash_get_or_create(\"" . $cg->{"pkg"} . "\"), \"" . $vname . "\"); ");
                emit($cg, "if (__og->slots[PERLA_SLOT_HASH]) strada_decref(__og->slots[PERLA_SLOT_HASH]); ");
                emit($cg, "__og->slots[PERLA_SLOT_HASH] = " . c_var_h($vname) . "; if (" . c_var_h($vname) . ") strada_incref(" . c_var_h($vname) . "); }\n");
            } else {
                # `our %h;` with no init — adopt any value already in the
                # HASH slot (e.g. set by BEGIN), or create a fresh one.
                ind($cg); emit($cg, "{ PerlGlob *__og = perla_glob_get_or_create(perla_stash_get_or_create(\"" . $cg->{"pkg"} . "\"), \"" . $vname . "\"); ");
                emit($cg, "if (__og->slots[PERLA_SLOT_HASH]) { ");
                emit($cg, "  if (" . c_var_h($vname) . ") strada_decref(" . c_var_h($vname) . "); ");
                emit($cg, "  " . c_var_h($vname) . " = __og->slots[PERLA_SLOT_HASH]; ");
                emit($cg, "  strada_incref(" . c_var_h($vname) . "); ");
                emit($cg, "} else { ");
                emit($cg, "  if (!" . c_var_h($vname) . ") " . c_var_h($vname) . " = strada_new_hash(); ");
                emit($cg, "  __og->slots[PERLA_SLOT_HASH] = " . c_var_h($vname) . "; strada_incref(" . c_var_h($vname) . "); ");
                emit($cg, "} }\n");
            }
        } elsif ($vtype eq "ARRAY_VAR") {
            # Array vars: always init as array
            if (defined($node->{"init"})) {
                # Wrap scalar inits into a 1-element array — `our @arr =
                # ('hello')` parses the single-element parens as just
                # the scalar 'hello', so gen_expr produces a STRADA_STR.
                # Without the wrap, the slot would hold the string and
                # @arr reads return empty. Exporter::import's @EXPORT
                # check broke for `our @EXPORT = ('name')` (single-name
                # export lists) because of this. Already-array values
                # (literals, deref'd refs, returns from map/grep/sort)
                # pass through unchanged.
                # Copy the RHS elements into a FRESH array. Perl's `our @A = @B`
                # (and the chained `our @A = our @B = LIST`) is a copy, not an
                # alias — using __ai directly made @A and @B share one backbone
                # so `push @A` leaked into @B. Mirrors the `my @x = ...` copy.
                my int $__oa_t = $node->{"init"}->{"type"};
                my int $__oa_borrowed = 0;
                if ($__oa_t == Perla::AST::N_ARRAY_VAR()
                    || $__oa_t == Perla::AST::N_HASH_VAR()
                    || $__oa_t == Perla::AST::N_SCALAR_VAR()
                    || $__oa_t == Perla::AST::N_DEREF_ARRAY()
                    || $__oa_t == Perla::AST::N_DEREF_HASH()
                    || $__oa_t == Perla::AST::N_ASSIGN()
                    || $__oa_t == Perla::AST::N_MY()
                    || $__oa_t == Perla::AST::N_OUR()) {
                    $__oa_borrowed = 1;
                }
                ind($cg); emit($cg, c_var_a($vname) . " = ({ int __sav_wl = __perla_want_list; __perla_want_list = 1; StradaValue *__ai = ");
                gen_expr($cg, $node->{"init"});
                emit($cg, "; __perla_want_list = __sav_wl; ");
                emit($cg, "StradaValue *__oacp = strada_new_array(); StradaArray *__oacpv = strada_deref_array(__oacp); ");
                emit($cg, "if (__ai && !STRADA_IS_TAGGED_INT(__ai) && __ai->type == STRADA_ARRAY) { StradaArray *__oasrc = strada_deref_array(__ai); if (__oasrc) for (int __oai = 0; __oai < (int)strada_array_length(__oasrc); __oai++) { StradaValue *__oae = strada_array_get(__oasrc, __oai); if (__oae) strada_incref(__oae); strada_array_push_take(__oacpv, __oae); } } ");
                emit($cg, "else if (__ai && !STRADA_IS_TAGGED_INT(__ai) && __ai->type == STRADA_HASH && __ai->value.hv) { StradaArray *__oahk = strada_hash_keys(__ai->value.hv); if (__oahk) { for (size_t __oahi = 0; __oahi < __oahk->size; __oahi++) { StradaValue *__oahkk = __oahk->elements[__oahk->head + __oahi]; char *__oahks = strada_to_str(__oahkk); StradaValue *__oahv = strada_hash_get(__ai->value.hv, __oahks); free(__oahks); if (__oahkk) strada_incref(__oahkk); strada_array_push_take(__oacpv, __oahkk); if (__oahv) strada_incref(__oahv); strada_array_push_take(__oacpv, __oahv); } strada_free_array(__oahk); } } ");
                emit($cg, "else if (__ai) { strada_incref(__ai); strada_array_push_take(__oacpv, __ai); } ");
                if ($__oa_borrowed == 0) {
                    emit($cg, "if (__ai) strada_decref(__ai); ");
                }
                emit($cg, "__oacp; });\n");
                # Mirror into the package stash so `@Pkg::NAME` reads (which go
                # through perla_array_get on the stash) see the `our` value.
                # Without this, `use YAML qw(Load)` → Exporter::import → reads
                # @YAML::EXPORT from the stash and finds it empty, so `Load`
                # never gets exported into main.
                ind($cg); emit($cg, "{ PerlGlob *__og = perla_glob_get_or_create(perla_stash_get_or_create(\"" . $cg->{"pkg"} . "\"), \"" . $vname . "\"); ");
                emit($cg, "if (__og->slots[PERLA_SLOT_ARRAY]) strada_decref(__og->slots[PERLA_SLOT_ARRAY]); ");
                emit($cg, "__og->slots[PERLA_SLOT_ARRAY] = " . c_var_a($vname) . "; if (" . c_var_a($vname) . ") strada_incref(" . c_var_a($vname) . "); }\n");
            } else {
                # `our @a;` with no init — adopt any value already in the
                # ARRAY slot (e.g. set by BEGIN), or create a fresh one.
                ind($cg); emit($cg, "{ PerlGlob *__og = perla_glob_get_or_create(perla_stash_get_or_create(\"" . $cg->{"pkg"} . "\"), \"" . $vname . "\"); ");
                emit($cg, "if (__og->slots[PERLA_SLOT_ARRAY]) { ");
                emit($cg, "  if (" . c_var_a($vname) . ") strada_decref(" . c_var_a($vname) . "); ");
                emit($cg, "  " . c_var_a($vname) . " = __og->slots[PERLA_SLOT_ARRAY]; ");
                emit($cg, "  strada_incref(" . c_var_a($vname) . "); ");
                emit($cg, "} else { ");
                emit($cg, "  if (!" . c_var_a($vname) . ") " . c_var_a($vname) . " = strada_new_array(); ");
                emit($cg, "  __og->slots[PERLA_SLOT_ARRAY] = " . c_var_a($vname) . "; strada_incref(" . c_var_a($vname) . "); ");
                emit($cg, "} }\n");
            }
            # Register the array file-static so typeglob array-slot writes
            # (`*alias = \@source`) propagate into the v_X mirror. Without
            # this, `our @alias_for; *alias_for = \@source` updates the
            # stash slot but compiled reads of `@alias_for` (via v_alias_for)
            # see the empty array from declaration time.
            ind($cg); emit($cg, "perla_register_our_local_array(\"" . $cg->{"pkg"} . "\", \"" . $vname . "\", &" . c_var_a($vname) . ");\n");
        } else {
            if (defined($node->{"init"})) {
                ind($cg); emit($cg, c_var($vname) . " = ");
                gen_expr($cg, $node->{"init"});
                emit($cg, ";\n");
                # Mirror init expression into the package stash so
                # `$Pkg::NAME` reads see it.
                ind($cg); emit($cg, "{ PerlGlob *__og = perla_glob_get_or_create(perla_stash_get_or_create(\"" . $cg->{"pkg"} . "\"), \"" . $vname . "\"); ");
                emit($cg, "perla_glob_store(__og, PERLA_SLOT_SCALAR, " . c_var($vname) . "); }\n");
            } else {
                # `our $x;` with no init — adopt any value already in the
                # stash SCALAR slot (e.g. set by an earlier BEGIN block).
                # Without this, the unconditional sync below would clobber
                # the BEGIN's assignment with undef.
                ind($cg); emit($cg, "{ PerlGlob *__og = perla_glob_get_or_create(perla_stash_get_or_create(\"" . $cg->{"pkg"} . "\"), \"" . $vname . "\"); ");
                emit($cg, "if (__og->slots[PERLA_SLOT_SCALAR]) { ");
                emit($cg, "  if (" . c_var($vname) . ") strada_decref(" . c_var($vname) . "); ");
                emit($cg, "  " . c_var($vname) . " = __og->slots[PERLA_SLOT_SCALAR]; ");
                emit($cg, "  strada_incref(" . c_var($vname) . "); ");
                emit($cg, "} else { ");
                emit($cg, "  if (!" . c_var($vname) . ") " . c_var($vname) . " = strada_new_undef(); ");
                emit($cg, "  perla_glob_store(__og, PERLA_SLOT_SCALAR, " . c_var($vname) . "); ");
                emit($cg, "} }\n");
            }
            # Register the file-static for stash-set sync so external
            # writes (`$Pkg::var = X` from another package) propagate
            # into compiled subs that read `v_x` directly. Without this
            # registration, subs in pkg would see the declaration-time
            # value forever.
            ind($cg); emit($cg, "perla_register_our_local(\"" . $cg->{"pkg"} . "\", \"" . $vname . "\", &" . c_var($vname) . ");\n");
            # Pad mode: ensure this our-scalar is in our_vars so the
            # expression-context assignment write-back (Path B, ~line 9063)
            # fires. collect_our_vars misses `our $x` buried in a `my $rv = do
            # { ... }` initializer (the eval-body wrapper shape), but the decl is
            # always codegen'd here before the body's assignments run.
            if ($cg->{"pad_mode"} == 1) {
                $cg->{"our_vars"}->{$vname} = "SCALAR_VAR";
            }
        }
    }
    # Multi-var form: `our (@CONSTANTS, %TBL, $X);` — parser produces
    # node->{"vars"} as a list. Emit init + stash mirror for each so
    # cross-package reads (`%Pkg::TBL`) and Exporter's @EXPORT lookups
    # find the slot. Without this, `Locale::Codes::Constants`'s
    # `our (@CONSTANTS, %ALL_CODESETS);` populated only the file-scope
    # C static, leaving the stash empty — every Locale::Codes type
    # registration ("country", "currency", …) silently failed because
    # `$ALL_CODESETS{$type}` looked up the empty stash slot in the
    # importing package. (Bare `our %TBL;` already mirrors via the
    # single-var branch above.)
    if (defined($node->{"vars"})) {
        my int $mvi = 0;
        my array @mvs = @{$node->{"vars"}};
        while ($mvi < scalar(@mvs)) {
            my scalar $mv = $mvs[$mvi];
            my str $mvname = $mv->{"value"};
            my str $mvtype = $mv->{"type"};
            if ($mvtype eq "HASH_VAR") {
                ind($cg); emit($cg, "if (!" . c_var_h($mvname) . ") " . c_var_h($mvname) . " = strada_new_hash();\n");
                ind($cg); emit($cg, "{ PerlGlob *__og = perla_glob_get_or_create(perla_stash_get_or_create(\"" . $cg->{"pkg"} . "\"), \"" . $mvname . "\"); ");
                emit($cg, "if (__og->slots[PERLA_SLOT_HASH]) strada_decref(__og->slots[PERLA_SLOT_HASH]); ");
                emit($cg, "__og->slots[PERLA_SLOT_HASH] = " . c_var_h($mvname) . "; if (" . c_var_h($mvname) . ") strada_incref(" . c_var_h($mvname) . "); }\n");
            } elsif ($mvtype eq "ARRAY_VAR") {
                ind($cg); emit($cg, "if (!" . c_var_a($mvname) . ") " . c_var_a($mvname) . " = strada_new_array();\n");
                ind($cg); emit($cg, "{ PerlGlob *__og = perla_glob_get_or_create(perla_stash_get_or_create(\"" . $cg->{"pkg"} . "\"), \"" . $mvname . "\"); ");
                emit($cg, "if (__og->slots[PERLA_SLOT_ARRAY]) strada_decref(__og->slots[PERLA_SLOT_ARRAY]); ");
                emit($cg, "__og->slots[PERLA_SLOT_ARRAY] = " . c_var_a($mvname) . "; if (" . c_var_a($mvname) . ") strada_incref(" . c_var_a($mvname) . "); }\n");
            } else {
                ind($cg); emit($cg, "if (!" . c_var($mvname) . ") " . c_var($mvname) . " = strada_new_undef();\n");
                ind($cg); emit($cg, "{ PerlGlob *__og = perla_glob_get_or_create(perla_stash_get_or_create(\"" . $cg->{"pkg"} . "\"), \"" . $mvname . "\"); ");
                emit($cg, "perla_glob_store(__og, PERLA_SLOT_SCALAR, " . c_var($mvname) . "); }\n");
            }
            $mvi++;
        }
        # `our (\$p, \$q) = LIST` — distribute init values across the
        # declared vars. Without this, `our (\$p, \$q) = (10, 20)`
        # declared the vars but left them at their pre-init values.
        # Evaluate init in list context, then assign each var from
        # index N of the result array.
        if (defined($node->{"init"})) {
            ind($cg); emit($cg, "{ int __sav_wl_ml = __perla_want_list; __perla_want_list = 1; StradaValue *__ml_rhs = ");
            gen_expr($cg, $node->{"init"});
            emit($cg, "; __perla_want_list = __sav_wl_ml; StradaArray *__ml_av = strada_deref_array(__ml_rhs); ");
            my int $oli = 0;
            while ($oli < scalar(@mvs)) {
                my scalar $omv = $mvs[$oli];
                my str $omn = $omv->{"value"};
                my str $omt = $omv->{"type"};
                if ($omt eq "SCALAR_VAR") {
                    my str $ocn = c_var($omn);
                    emit($cg, "if (__ml_av && " . $oli . " < (int)__ml_av->size) { ");
                    emit($cg, "  StradaValue *__mle = __ml_av->elements[__ml_av->head + " . $oli . "]; ");
                    emit($cg, "  if (__mle) strada_incref(__mle); ");
                    emit($cg, "  if (" . $ocn . ") strada_decref(" . $ocn . "); ");
                    emit($cg, "  " . $ocn . " = __mle ? __mle : strada_new_undef(); ");
                    emit($cg, "  { PerlGlob *__og2 = perla_glob_get_or_create(perla_stash_get_or_create(\"" . $cg->{"pkg"} . "\"), \"" . $omn . "\"); ");
                    emit($cg, "    perla_glob_store(__og2, PERLA_SLOT_SCALAR, " . $ocn . "); } } ");
                }
                $oli = $oli + 1;
            }
            emit($cg, "if (__ml_rhs) strada_decref(__ml_rhs); }\n");
        }
    }
}

# --- C name for a sub from qualified name ---
func sub_cname_q(str $qname) str {
    return "perla_sub_" . replace_all($qname, "::", "_");
}

# --- C name for a sub ---
func _sub_cname(scalar $cg, str $name) str {
    my str $pkg = $cg->{"pkg"};
    return "perla_sub_" . replace_all($pkg, "::", "_") . "_" . $name;
}

# --- Check if variable is file-scope (already declared as static) ---
func _is_file_scope(scalar $cg, str $vname) int {
    if (defined($cg->{"file_scope_vars"}) && $cg->{"in_main"} == 1) {
        return exists($cg->{"file_scope_vars"}->{$vname});
    }
    return 0;
}

# --- Variable declaration prefix: "StradaValue *" or "" for file-scope/already-declared vars ---
# Legacy signature (scalar default). Prefer _my_prefix_vt when the sigil
# is known so hash/array mangling tracks under the correct C name.
func _my_prefix(scalar $cg, str $vname) str {
    return _my_prefix_vt($cg, "SCALAR_VAR", $vname);
}

func _my_prefix_vt(scalar $cg, str $vtype, str $vname) str {
    # `use warnings;` "my X masks earlier declaration in same scope" must
    # fire BEFORE the file-scope early-return below — file-scope `my`
    # decls compile to static slots that we WANT to flag on redeclare.
    # Check same_scope_decls first; downstream code still gets to suppress
    # the C-level re-declaration via the standard declared_vars guard.
    if (defined($cg->{"same_scope_decls"})) {
        my str $__ssd_cname = c_var_for_vtype($vtype, $vname);
        if (defined($cg->{"same_scope_decls"}->{$__ssd_cname})
            && defined($cg->{"use_warnings"}) && $cg->{"use_warnings"} == 1) {
            # Perl's "my X masks earlier declaration in same scope" is a
            # compile-time warning, so emit to STDERR from perla itself
            # rather than via a runtime call in the generated C (which
            # would only fire when the enclosing sub actually runs).
            my str $__mm_sigil = "\$";
            if ($vtype eq "ARRAY_VAR") { $__mm_sigil = "@"; }
            elsif ($vtype eq "HASH_VAR") { $__mm_sigil = "%"; }
            my int $__mm_line = 0;
            if (defined($cg->{"current_my_line"})) {
                $__mm_line = $cg->{"current_my_line"} + 0;
            }
            my str $__mm_file = "" . $cg->{"filename"};
            if (length($__mm_file) == 0) { $__mm_file = "-"; }
            my str $__mm_varname = $__mm_sigil . $vname;
            if ($__mm_line == 0) {
                # Last-statement-of-sub gen_expr-safe path doesn't go
                # through _gen_my; fall back to whatever node we have.
                $__mm_line = $cg->{"current_my_line"} + 0;
            }
            say(STDERR, "\"my\" variable " . $__mm_varname . " masks earlier declaration in same scope at " . $__mm_file . " line " . $__mm_line . ".");
        }
        $cg->{"same_scope_decls"}->{$__ssd_cname} = 1;
    }
    if (_is_file_scope($cg, $vname) == 1) {
        return "";
    }
    # Track declared vars per function to avoid C redefinition errors.
    # Key by sigil-aware C name so `%foo` and `$foo` in the same scope
    # don't fight over the same `v_foo` slot.
    # Use defined() (not exists()): the foreach cleanup at end-of-loop
    # sets declared_vars[iter] = undef rather than deleting the key,
    # which left exists() returning true. A later `my %X` after a
    # `for my $X` then suppressed the local declaration and routed
    # the my-decl through the file-scope-assign branch (the bug from
    # `my %s; $s{$_}++ for ...` inside a foreach not resetting between
    # iterations — see /tmp/r2.pl). All other declared_vars readers
    # in this file already use defined() — this aligns the contract.
    my str $cname = c_var_for_vtype($vtype, $vname);
    if (defined($cg->{"declared_vars"}->{$cname})) {
        return "";
    }
    if (defined($cg->{"capture_vars"})) {
        my str $cv_check = "" . $cg->{"capture_vars"}->{$cname};
        if (length($cv_check) > 0) {
            return "";
        }
    }
    $cg->{"declared_vars"}->{$cname} = 1;
    return "StradaValue *";
}

# --- strict 'vars' check ---
# When `use strict;` (or `use strict 'vars';`) is in scope, reading or
# writing an undeclared variable is a compile-time error in real Perl.
# perla now enforces the check at codegen time. The check is called
# from the N_SCALAR_VAR / N_ARRAY_VAR / N_HASH_VAR emit sites BEFORE
# falling through to the c_var path so we abort with a Perl-style
# error message that the user expects.
#
# Exempted from the check (return true = "declared / exempt"):
#   - any name containing "::" (package-qualified)
#   - perl built-in special names (ARGV, ENV, INC, SIG, ARGVOUT,
#     STDIN/STDOUT/STDERR/__FILE__/__LINE__/__PACKAGE__/__SUB__, etc.)
#     — these are tracked at file scope by perla startup
#   - any name found in declared_vars, our_vars, file_scope_vars,
#     or capture_vars
#   - single-char punctuation names ($_, @_, $!, $@, $1-$9 etc) — these
#     all branch off earlier in the var emit; if any leaks through it
#     would be an internal bug. Allow them here so we don't fire the
#     check on weird codegen paths.
func _strict_check_var(scalar $cg, str $sigil, str $name, int $line) void {
    if (!defined($cg->{"strict_vars"}) || $cg->{"strict_vars"} != 1) {
        return;
    }
    if (length($name) == 0) { return; }
    # Package-qualified: $Pkg::name / @Pkg::names etc.
    if (index($name, "::") > 0) { return; }
    # Single-character non-alpha — punctuation special var.
    if (length($name) == 1) {
        my int $c0 = char_at($name, 0);
        my int $is_alpha = (($c0 >= 65 && $c0 <= 90) || ($c0 >= 97 && $c0 <= 122) || $c0 == 95) ? 1 : 0;
        if ($is_alpha == 0) { return; }
    }
    # Caret special vars ($^O, $^X, $^W, $^V, etc) — name is "^X" form
    # from the lexer. Also the braced form ${^NAME} (${^TAINT},
    # ${^GLOBAL_PHASE}, etc.) which the lexer emits as "^TAINT" etc.
    # All caret-prefixed names are Perl built-ins, never need declaration.
    if (length($name) >= 2 && char_at($name, 0) == 94) { return; }  # '^'
    # All-digit names ($1..$9, $10, etc) — capture vars.
    my int $__sc_all_digit = 1;
    my int $__sc_ci = 0;
    while ($__sc_ci < length($name)) {
        my int $__sc_c = char_at($name, $__sc_ci);
        if ($__sc_c < 48 || $__sc_c > 57) { $__sc_all_digit = 0; }
        $__sc_ci++;
    }
    if ($__sc_all_digit == 1) { return; }
    # Perl built-ins that should always be in scope. ARGV/ENV/INC/SIG
    # are at the array+hash sigil level (so a bare `$ENV{...}` form
    # works for hash). __PACKAGE__/__FILE__/__LINE__/__SUB__ are also
    # exempt though they read more like keyword tokens.
    if ($name eq "ARGV" || $name eq "ARGVOUT" || $name eq "ENV"
        || $name eq "INC" || $name eq "SIG" || $name eq "STDIN"
        || $name eq "STDOUT" || $name eq "STDERR" || $name eq "DATA"
        || $name eq "ARGV_PERL" || $name eq "__PACKAGE__"
        || $name eq "__FILE__" || $name eq "__LINE__"
        || $name eq "__SUB__" || $name eq "PERL_VERSION"
        || $name eq "OS_ERROR" || $name eq "SUBSCRIPT_SEPARATOR"
        || $name eq "OUTPUT_RECORD_SEPARATOR"
        || $name eq "INPUT_RECORD_SEPARATOR"
        || $name eq "LIST_SEPARATOR"
        || $name eq "OUTPUT_FIELD_SEPARATOR"
        || $name eq "PROGRAM_NAME"
        # %Config (from `use Config`) and %ENV-like external-population
        # globals are runtime-imported via Exporter — the compile-time
        # tracker doesn't see them. Exempt the standard ones so
        # `$Config{KEY}` doesn't trip strict 'vars'.
        || $name eq "Config") {
        return;
    }
    # `$a` and `$b` are special — sort/reduce block comparator vars.
    # Real Perl exempts them via strict.pm. Match that.
    if ($name eq "a" || $name eq "b") { return; }
    # `$_` / `@_` / `%_` are the implicit topic and arg array. Real Perl
    # treats these as always-in-scope (effectively predeclared at file
    # scope) and never errors on them under strict 'vars'. My single-char
    # punctuation skip earlier doesn't cover `_` (underscore is alpha)
    # so handle it explicitly here.
    if ($name eq "_") { return; }
    # Look up the declaration. The codegen scope-tracks under C-mangled
    # names — same mangling as c_var/_a/_h emits, so build the key with
    # c_var_for_vtype.
    my str $__sc_vtype = "SCALAR_VAR";
    if ($sigil eq "@") { $__sc_vtype = "ARRAY_VAR"; }
    elsif ($sigil eq "%") { $__sc_vtype = "HASH_VAR"; }
    my str $__sc_cname = c_var_for_vtype($__sc_vtype, $name);
    if (defined($cg->{"declared_vars"}) && defined($cg->{"declared_vars"}->{$__sc_cname})) {
        return;
    }
    if (defined($cg->{"capture_vars"})) {
        my str $__sc_cv = "" . $cg->{"capture_vars"}->{$__sc_cname};
        if (length($__sc_cv) > 0) { return; }
        my str $__sc_cv2 = "" . $cg->{"capture_vars"}->{$name};
        if (length($__sc_cv2) > 0) { return; }
    }
    if (defined($cg->{"state_vars"}) && defined($cg->{"state_vars"}->{$name})) {
        return;
    }
    if (defined($cg->{"our_vars"}) && defined($cg->{"our_vars"}->{$name})) {
        return;
    }
    # file_scope_vars is populated by collect_file_scope_vars_from_stmts.
    # Real `my $X` declarations get type "SCALAR_VAR" / "ARRAY_VAR" /
    # "HASH_VAR"; bare assignments at file scope (`$x = 42;` without a
    # prior `my`) get type "IMPLICIT_GLOBAL" — those are exactly the
    # ones strict 'vars' is supposed to flag.
    if (defined($cg->{"file_scope_vars"}) && defined($cg->{"file_scope_vars"}->{$name})) {
        my str $__sc_fst = "" . $cg->{"file_scope_vars"}->{$name};
        if ($__sc_fst ne "IMPLICIT_GLOBAL") { return; }
    }
    # `our` declarations sometimes get tracked in the C-mangled form
    # (v_foo / v_foo__a / v_foo__h) and sometimes in the Perl-name form.
    # Check the c_var-mangled key in our_vars too.
    if (defined($cg->{"our_vars"}) && defined($cg->{"our_vars"}->{$__sc_cname})) {
        return;
    }
    # File-wide `my` lexical: declared via `my` in SOME scope of this file
    # (collected into all_my_lexicals). perla's per-sub declared_vars is reset
    # entering each sub, so a nested sub / sort / map / grep block referencing
    # an enclosing-scope lexical would otherwise false-positive. Real Perl makes
    # enclosing lexicals visible at compile time, so treat any file-declared
    # `my` name as in scope.
    if (defined($cg->{"all_my_lexicals"}) && defined($cg->{"all_my_lexicals"}->{$name})) {
        return;
    }
    # `local $x = expr;` auto-declares the package var in real Perl, but
    # only under strict if it was already declared. We don't track that
    # specifically — defer to file/our scope.
    # Not declared — emit the canonical Perl strict error.
    my str $__sc_loc = "";
    if ($line > 0) {
        $__sc_loc = " at " . $cg->{"src_file"} . " line " . $line . ".";
    }
    die("Global symbol \"" . $sigil . $name . "\" requires explicit package name (did you forget to declare \"my " . $sigil . $name . "\"?)" . $__sc_loc);
}

# --- Emit helpers ---

# Classify an expression node as "borrowed" (the caller does not own a
# fresh ref — gen_expr returns a pointer aliasing a longer-lived value)
# or "owned" (gen_expr returns a freshly-allocated value with rc=1 that
# the caller must release).
#
# Borrowed: scalar/array/hash variables, array element subscripts.
# Owned: everything else (literals, refs, anon constructors, calls,
# concats, regex results, hash element fetches via hv_fetch_owned, etc).
#
# Used by codegen sites that capture gen_expr result into a temp and
# need to decide whether to decref the temp. Conservative: when in doubt,
# return 0 (owned) so we decref; double-frees only happen if we'd
# decref a borrowed value, which is the dangerous direction.
func expr_is_borrowed(scalar $node) int {
    if (!defined($node)) { return 0; }
    my int $t = $node->{"type"};
    if ($t == Perla::AST::N_SCALAR_VAR()) {
        # Match/capture vars ($1..$9, $&, $`, $', $+) read as OWNED values —
        # strada_capture_var / strada_prematch / strada_postmatch /
        # strada_last_paren_match all incref before returning. Treating them
        # as borrowed makes consumers either over-incref (incref-to-keep) or
        # skip the release (use-without-cleanup); both leak one ref per read
        # (e.g. `$sum += $1` in a loop). All other scalar vars are borrowed.
        if (defined($node->{"name"})) {
            my str $cvn = "" . $node->{"name"};
            if (length($cvn) == 1
                && (($cvn ge "1" && $cvn le "9") || $cvn eq "&" || $cvn eq "\`" || $cvn eq "'" || $cvn eq "+")) {
                return 0;
            }
        }
        return 1;
    }
    if ($t == Perla::AST::N_ARRAY_VAR()) { return 1; }
    if ($t == Perla::AST::N_HASH_VAR()) { return 1; }
    if ($t == Perla::AST::N_ARRAY_ELEM()) { return 1; }
    # Deref of a reference produces a borrowed view of the inner value.
    # The deref codegen returns `__dr->value.rv` without incref, so
    # callers must NOT decref afterward — otherwise the inner ARRAY/
    # HASH/SCALAR gets freed underneath the owning REF, dangling the
    # pointer for any subsequent access. Caused recursive `find_r`
    # crashes where `if (\$idx >= @\$arr)` decref'd \$arr's inner array.
    if ($t == Perla::AST::N_DEREF_ARRAY()) { return 1; }
    if ($t == Perla::AST::N_DEREF_HASH()) { return 1; }
    if ($t == Perla::AST::N_DEREF_SCALAR()) { return 1; }
    # Assignment returns the RHS value as the expression result. If
    # the RHS is itself borrowed (a sub-local `my` scalar), then the
    # whole assignment is borrowed. Without this, `sub { my $v = $_[1];
    # $h{$_[0]} = $v; }` as a closure's implicit-return-last-expr
    # path skipped the incref of __ret_val — the subsequent sub-local
    # decref of $v made the caller's received pointer dangle, and the
    # hash slot's value (which strada_hash_set incref'd from the same
    # storage) read 0 on subsequent fetches because the underlying
    # value had been pool-recycled.
    if ($t == Perla::AST::N_ASSIGN() && defined($node->{"value"})) {
        return expr_is_borrowed($node->{"value"});
    }
    # bless($x, "C") returns its first argument unchanged (perla_bless does not
    # incref — same in-place semantics as strada_bless). The bless result's
    # borrowed-ness therefore mirrors its first arg's. Without this, any caller
    # that uses expr_is_borrowed to decide cleanup would unconditionally treat
    # `bless($var, "C")` as owned and decref it, killing $var's only ref ->
    # premature DESTROY / use-after-free. A handful of call sites (e.g. the
    # named-sub return path) already special-case bless explicitly; recursing
    # here makes those redundant but harmless and covers every other caller.
    if ($t == Perla::AST::N_CALL() && defined($node->{"name"})) {
        my str $__bname = $node->{"name"};
        if ($__bname eq "bless" || $__bname eq "CORE::bless") {
            my scalar $__bargs = $node->{"args"};
            if (defined($__bargs) && scalar(@{$__bargs}) >= 1) {
                return expr_is_borrowed($__bargs->[0]);
            }
            return 0;
        }
    }
    # Ternary `COND ? A : B` yields one of its branches. If EITHER branch is
    # borrowed (a sub-local `my` scalar, a deref view, …), the whole result may
    # be borrowed, so callers that decide incref-on-keep (notably the `return`
    # path) must treat it as borrowed and incref — otherwise sub-exit cleanup
    # decrefs the local and the returned pointer dangles. Concrete victim:
    # Type::Tiny::inline_check's `return @r == 1 ? $r : "($r)"` returned a
    # freed string, so Eval::TypeTiny compiled a garbled
    # `<freed>lar::Util::blessed(...)` check ("Scalar" → garbage) and DBIx::Class
    # type checks died "Undefined subroutine &lar::Util::blessed".
    if ($t == Perla::AST::N_TERNARY()) {
        if (defined($node->{"then"}) && expr_is_borrowed($node->{"then"}) == 1) { return 1; }
        if (defined($node->{"else"}) && expr_is_borrowed($node->{"else"}) == 1) { return 1; }
        return 0;
    }
    return 0;
}

# === Central operand capture/release (refcount discipline) ============
# perla's integer/builtin codegens historically captured operand SVs and
# managed their refcounts INLINE, per op — easy to forget, and the source
# of the UV (heap-integer) leaks. These helpers centralize the ONE
# error-prone decision: an OWNED operand (a fresh temp — literal, call
# result, arithmetic) must be decref'd after use; a BORROWED operand (a
# variable / deref view) must not. The body between capture and release
# uses the temp and yields an INDEPENDENT result (incref-on-return or a
# fresh value), so it never touches operand refcounts itself.
#
# Usage (the op body must compute an independent/owned result):
#   my array @sc = ();
#   emit($cg, "({ ");
#   op_capture($cg, \@sc, "__a", $node, 1);     # 1 = evaluate in scalar ctx
#   emit($cg, "StradaValue *__res = "); ...body using __a...; emit($cg, "; ");
#   op_release($cg, \@sc);
#   emit($cg, "__res; })");
func op_capture(scalar $cg, scalar $rec, str $cvar, scalar $node, int $scalar_ctx) void {
    emit($cg, "StradaValue *" . $cvar . " = ");
    if ($scalar_ctx == 1) {
        emit($cg, "({ int __ocwl = __perla_want_list; __perla_want_list = 0; StradaValue *__ocv = ");
        gen_expr($cg, $node);
        emit($cg, "; __perla_want_list = __ocwl; __ocv; })");
    } else {
        gen_expr($cg, $node);
    }
    emit($cg, "; ");
    my int $owned = 0;
    if (expr_is_borrowed($node) == 0) { $owned = 1; }
    push(@{$rec}, { "cvar" => $cvar, "owned" => $owned });
}

# Capture a raw C expression (e.g. perla_dollar_underscore) as a BORROWED
# operand — never released. Used for the no-arg `$_` default.
func op_capture_c(scalar $cg, scalar $rec, str $cvar, str $cexpr) void {
    emit($cg, "StradaValue *" . $cvar . " = " . $cexpr . "; ");
    push(@{$rec}, { "cvar" => $cvar, "owned" => 0 });
}

# Emit `if (cv) strada_decref(cv);` for each OWNED captured operand.
func op_release(scalar $cg, scalar $rec) void {
    my int $i = 0;
    while ($i < scalar(@{$rec})) {
        my scalar $e = $rec->[$i];
        if ($e->{"owned"} == 1) {
            emit($cg, "if (" . $e->{"cvar"} . ") strada_decref(" . $e->{"cvar"} . "); ");
        }
        $i = $i + 1;
    }
}

func emit(scalar $cg, str $s) void {
    sb_append($cg->{"sb"}, $s);
}

func ind(scalar $cg) void {
    my int $i = 0;
    while ($i < $cg->{"indent"}) {
        sb_append($cg->{"sb"}, "    ");
        $i++;
    }
}

func tmp_name(scalar $cg) str {
    $cg->{"tmp_count"} = $cg->{"tmp_count"} + 1;
    return "__perla_tmp_" . $cg->{"tmp_count"};
}

# Recursively scan a node (or list of nodes) for any N_SUB occurrence,
# named or anonymous. Returns 1 if found, 0 otherwise. Used by the
# bare-block DESTROY-at-exit guard: when a sub is defined inside the
# block (even nested in an expression like `*Pkg::name = sub {...}`),
# an enclosing closure may have captured a block-local slot via &v_X,
# and decref+NULL'ing those slots at block exit would corrupt it.
# Returns 1 if any N_SUB / N_ANON_SUB inside `$node` references the
# (already-renamed) variable name `$vname` via N_SCALAR_VAR /
# N_ARRAY_VAR / N_HASH_VAR. Used by the bare-block cleanup logic so
# we only skip block-exit decref for vars actually captured by an
# inner sub (the conservative "any sub at all" rule was leaving
# blessed objects alive past their block when the sub never
# touched the var — e.g. `{ package X; sub DESTROY {...}; my $o = ...; }`
# where DESTROY operates on $_[0] and doesn't refer to $o, but
# perla still pinned $o until program-exit global destruction).
func _sub_in_node_references_var(scalar $node, str $vname) int {
    if (!defined($node)) { return 0; }
    if (ref($node) eq "ARRAY") {
        my int $__svi = 0;
        while ($__svi < scalar(@{$node})) {
            if (_sub_in_node_references_var($node->[$__svi], $vname) == 1) { return 1; }
            $__svi = $__svi + 1;
        }
        return 0;
    }
    if (ref($node) ne "HASH") { return 0; }
    if (!defined($node->{"type"})) { return 0; }
    my int $__svt = $node->{"type"};
    if ($__svt == Perla::AST::N_SUB() || $__svt == Perla::AST::N_ANON_SUB()) {
        # Recurse into the sub body specifically and check for refs.
        my scalar $__body = $node->{"body"};
        if (defined($__body) && _node_references_var($__body, $vname) == 1) { return 1; }
        return 0;
    }
    # Not a sub — recurse through child keys looking for nested subs.
    my array @__svc_keys = ("init", "value", "expr", "left", "right", "cond",
                            "then", "else", "body", "var", "vars", "stmts",
                            "args", "key", "index", "hash", "array", "callee",
                            "object", "method", "target", "list", "block",
                            "coderef", "operand", "lhs", "rhs", "items",
                            "elements", "elems", "pairs", "keys_list",
                            "indices", "init_block", "update", "test", "iter",
                            "filter", "branches", "cases", "when", "default",
                            "captures", "step", "ref");
    my int $__svki = 0;
    while ($__svki < scalar(@__svc_keys)) {
        my str $__svck = $__svc_keys[$__svki];
        if (defined($node->{$__svck})) {
            if (_sub_in_node_references_var($node->{$__svck}, $vname) == 1) { return 1; }
        }
        $__svki = $__svki + 1;
    }
    return 0;
}

# Returns 1 if `$node` directly references variable `$vname` via any
# of the var-bearing AST nodes (N_SCALAR_VAR / N_ARRAY_VAR / N_HASH_VAR).
# Used by _sub_in_node_references_var to check sub bodies for captures.
func _node_references_var(scalar $node, str $vname) int {
    if (!defined($node)) { return 0; }
    if (ref($node) eq "ARRAY") {
        my int $__rvi = 0;
        while ($__rvi < scalar(@{$node})) {
            if (_node_references_var($node->[$__rvi], $vname) == 1) { return 1; }
            $__rvi = $__rvi + 1;
        }
        return 0;
    }
    if (ref($node) ne "HASH") { return 0; }
    if (!defined($node->{"type"})) { return 0; }
    my int $__rvt = $node->{"type"};
    if ($__rvt == Perla::AST::N_SCALAR_VAR()
        || $__rvt == Perla::AST::N_ARRAY_VAR()
        || $__rvt == Perla::AST::N_HASH_VAR()) {
        my str $__rvn = "" . (defined($node->{"name"}) ? $node->{"name"} : "");
        if ($__rvn eq $vname) { return 1; }
    }
    my array @__rvc_keys = ("init", "value", "expr", "left", "right", "cond",
                            "then", "else", "body", "var", "vars", "stmts",
                            "args", "key", "index", "hash", "array", "callee",
                            "object", "method", "target", "list", "block",
                            "coderef", "operand", "lhs", "rhs", "items",
                            "elements", "elems", "pairs", "keys_list",
                            "indices", "init_block", "update", "test", "iter",
                            "filter", "branches", "cases", "when", "default",
                            "captures", "step", "ref");
    my int $__rvki = 0;
    while ($__rvki < scalar(@__rvc_keys)) {
        my str $__rvck = $__rvc_keys[$__rvki];
        if (defined($node->{$__rvck})) {
            if (_node_references_var($node->{$__rvck}, $vname) == 1) { return 1; }
        }
        $__rvki = $__rvki + 1;
    }
    return 0;
}

func _node_contains_sub(scalar $node) int {
    if (!defined($node)) { return 0; }
    if (ref($node) eq "ARRAY") {
        my int $__nci = 0;
        while ($__nci < scalar(@{$node})) {
            if (_node_contains_sub($node->[$__nci]) == 1) { return 1; }
            $__nci = $__nci + 1;
        }
        return 0;
    }
    if (ref($node) ne "HASH") { return 0; }
    if (!defined($node->{"type"})) { return 0; }
    my int $__nct = $node->{"type"};
    if ($__nct == Perla::AST::N_SUB() || $__nct == Perla::AST::N_ANON_SUB()) {
        return 1;
    }
    my array @__nc_keys = ("init", "value", "expr", "left", "right", "cond",
                          "then", "else", "body", "var", "vars", "stmts",
                          "args", "key", "index", "hash", "array", "callee",
                          "object", "method", "target", "list", "block",
                          "coderef", "operand", "lhs", "rhs", "items",
                          "elements", "elems", "pairs", "keys_list",
                          "indices", "init_block", "update", "test", "iter",
                          "filter", "branches", "cases", "when", "default",
                          "captures", "step", "ref");
    my int $__ncki = 0;
    while ($__ncki < scalar(@__nc_keys)) {
        my str $__nck = $__nc_keys[$__ncki];
        if (defined($node->{$__nck})) {
            if (_node_contains_sub($node->{$__nck}) == 1) { return 1; }
        }
        $__ncki = $__ncki + 1;
    }
    return 0;
}

# Returns 1 if NAME is a plain Perl identifier ([A-Za-z_][A-Za-z0-9_:]*),
# 0 for Perl special variable names (`,`, `/`, `|`, `\`, etc.) that must
# not be auto-declared as C statics.

# Generate autovivifying hash access for lvalue context
func _gen_autoviv_hash(scalar $cg, scalar $node) void {
    my int $t = $node->{"type"};
    if ($t == Perla::AST::N_HASH_ELEM()) {
        my scalar $hkey = $node->{"key"};
        my int $hkey_type = $hkey->{"type"};
        my int $is_lit = 0;
        if ($hkey_type == Perla::AST::N_STR_LIT()) { $is_lit = 1; }
        if ($hkey_type == Perla::AST::N_INTERP_STR() && has_perl_var($hkey->{"value"}) == 0) { $is_lit = 1; }

        if ($is_lit == 1) {
            emit($cg, "strada_hv_autoviv(");
            my scalar $inner = $node->{"hash"};
            my int $inner_type = $inner->{"type"};

            if ($inner_type == 18 || $inner_type == 41) {
                _gen_autoviv_hash($cg, $inner);
            } elsif ($inner_type == Perla::AST::N_SCALAR_VAR()
                && defined($inner->{"name"}) && index($inner->{"name"}, "::") > 0) {
                my array @ihpn = _split_pkg_qual_name($inner);
                emit($cg, "perla_hash_get(\"" . $ihpn[0] . "\", \"" . $ihpn[1] . "\")");
            } elsif ($inner_type == Perla::AST::N_SCALAR_VAR()
                && defined($inner->{"name"}) && length($inner->{"name"}) > 0
                && index($inner->{"name"}, "::") < 0 && $inner->{"name"} ne "_") {
                # $foo{key} autoviv path: read from %foo slot, not $foo.
                emit($cg, c_var_h($inner->{"name"}));
            } else {
                gen_expr($cg, $inner);
            }
            emit($cg, ", \"" . Perla::CodeGen::Escape::str_node_to_c($hkey) . "\")");
        } else {
            emit($cg, "({ char *__ak = strada_to_str(");
            gen_expr($cg, $hkey);
            emit($cg, "); StradaValue *__av = strada_hv_autoviv(");
            my scalar $inner2 = $node->{"hash"};
            my int $inner2_type = $inner2->{"type"};
            if ($inner2_type == 18 || $inner2_type == 41) {
                _gen_autoviv_hash($cg, $inner2);
            } elsif ($inner2_type == Perla::AST::N_SCALAR_VAR()
                && defined($inner2->{"name"}) && index($inner2->{"name"}, "::") > 0) {
                my array @ih2pn = _split_pkg_qual_name($inner2);
                emit($cg, "perla_hash_get(\"" . $ih2pn[0] . "\", \"" . $ih2pn[1] . "\")");
            } elsif ($inner2_type == Perla::AST::N_SCALAR_VAR()
                && defined($inner2->{"name"}) && length($inner2->{"name"}) > 0
                && index($inner2->{"name"}, "::") < 0 && $inner2->{"name"} ne "_") {
                emit($cg, c_var_h($inner2->{"name"}));
            } else {
                gen_expr($cg, $inner2);
            }
            emit($cg, ", __ak); free(__ak); __av; })");
        }
    } elsif ($t == Perla::AST::N_ARROW_HASH()) {
        my scalar $akey = $node->{"key"};
        my scalar $aobj = $node->{"object"};
        my int $aobj_type = $aobj->{"type"};
        my int $akey_type = $akey->{"type"};
        my int $akey_lit = 0;
        if ($akey_type == Perla::AST::N_STR_LIT()) { $akey_lit = 1; }
        if ($akey_type == Perla::AST::N_INTERP_STR() && has_perl_var($akey->{"value"}) == 0) { $akey_lit = 1; }
        # Route to c_var_h ONLY for the sigil-hash form `$h{k}` (no arrow),
        # which is sugar for %h{k}. Arrow form `$h->{k}` autoderefs the
        # scalar — read v_h (the scalar holding a hash ref), NOT v_h__h
        # (the unrelated hash storage). Without this guard, the assignment
        # `$data->{config}{servers} = X` wrote to the wrong variable when
        # the name collided with a later `my %data` in the same scope.
        my int $is_arrow_form = 0;
        if (defined($node->{"is_explicit_arrow"}) && $node->{"is_explicit_arrow"} == 1) { $is_arrow_form = 1; }
        my int $aobj_route_h = 0;
        if ($is_arrow_form == 0
            && $aobj_type == Perla::AST::N_SCALAR_VAR()
            && defined($aobj->{"name"}) && length($aobj->{"name"}) > 0
            && index($aobj->{"name"}, "::") < 0 && $aobj->{"name"} ne "_"
            && exists($__perla_mangle_collisions{$aobj->{"name"}})) {
            $aobj_route_h = 1;
        }
        # Autoviv the outer scalar var when used like `$ret->{a}{b}{c} = X`:
        # innermost $ret needs to become a hash ref. Same logic as the
        # direct assignment fix.
        my int $aobj_autoviv_scalar = 0;
        if ($aobj_type == Perla::AST::N_SCALAR_VAR()
            && defined($aobj->{"name"}) && length($aobj->{"name"}) > 0
            && index($aobj->{"name"}, "::") < 0 && $aobj->{"name"} ne "_"
            && $aobj_route_h == 0) {
            $aobj_autoviv_scalar = 1;
        }
        # `$Pkg::Name->{k}` (or `$Pkg::Name{k}` sigil-hash) — fetch the
        # HASH slot of the stash glob; no autoviv at the leaf.
        my int $aobj_pkg = 0;
        if ($aobj_type == Perla::AST::N_SCALAR_VAR()
            && defined($aobj->{"name"}) && index($aobj->{"name"}, "::") > 0) {
            $aobj_pkg = 1;
        }
        if ($akey_lit == 1) {
            emit($cg, "strada_hv_autoviv(");
            if ($aobj_type == 18 || $aobj_type == 41) {
                _gen_autoviv_hash($cg, $aobj);
            } elsif ($aobj_pkg == 1) {
                my array @aopn = _split_pkg_qual_name($aobj);
                emit($cg, "perla_hash_get(\"" . $aopn[0] . "\", \"" . $aopn[1] . "\")");
            } elsif ($aobj_route_h == 1) {
                emit($cg, c_var_h($aobj->{"name"}));
            } elsif ($aobj_autoviv_scalar == 1) {
                my str $vc = c_var($aobj->{"name"});
                # Autoviv ONLY when the var is undef (or NULL ptr), to
                # match Perl's "autovivification triggered by undef
                # only" semantics. Don't clobber existing strings, ints,
                # or other refs — those would be runtime errors in
                # strict Perl, but the user might use them as symbolic
                # refs (`${"Pkg::Name"}->{key}`).
                emit($cg, "({ if (!" . $vc . " || STRADA_IS_TAGGED_INT(" . $vc . ") ? 0 : (" . $vc . "->type == STRADA_UNDEF)) { ");
                emit($cg, "  StradaValue *__nh = strada_new_ref_take(strada_new_hash(), '%'); ");
                emit($cg, "  if (" . $vc . ") strada_decref(" . $vc . "); ");
                emit($cg, "  " . $vc . " = __nh; ");
                emit($cg, "} else if (!" . $vc . ") { ");
                emit($cg, "  " . $vc . " = strada_new_ref_take(strada_new_hash(), '%'); ");
                emit($cg, "} " . $vc . "; })");
            } else {
                gen_expr($cg, $aobj);
            }
            emit($cg, ", \"" . Perla::CodeGen::Escape::str_node_to_c($akey) . "\")");
        } else {
            emit($cg, "({ char *__ak = strada_to_str(");
            gen_expr($cg, $akey);
            emit($cg, "); StradaValue *__av = strada_hv_autoviv(");
            if ($aobj_type == 18 || $aobj_type == 41) {
                _gen_autoviv_hash($cg, $aobj);
            } elsif ($aobj_pkg == 1) {
                my array @aopn2 = _split_pkg_qual_name($aobj);
                emit($cg, "perla_hash_get(\"" . $aopn2[0] . "\", \"" . $aopn2[1] . "\")");
            } elsif ($aobj_route_h == 1) {
                emit($cg, c_var_h($aobj->{"name"}));
            } elsif ($aobj_autoviv_scalar == 1) {
                my str $vc = c_var($aobj->{"name"});
                # Autoviv ONLY when the var is undef (or NULL ptr), to
                # match Perl's "autovivification triggered by undef
                # only" semantics. Don't clobber existing strings, ints,
                # or other refs — those would be runtime errors in
                # strict Perl, but the user might use them as symbolic
                # refs (`${"Pkg::Name"}->{key}`).
                emit($cg, "({ if (!" . $vc . " || STRADA_IS_TAGGED_INT(" . $vc . ") ? 0 : (" . $vc . "->type == STRADA_UNDEF)) { ");
                emit($cg, "  StradaValue *__nh = strada_new_ref_take(strada_new_hash(), '%'); ");
                emit($cg, "  if (" . $vc . ") strada_decref(" . $vc . "); ");
                emit($cg, "  " . $vc . " = __nh; ");
                emit($cg, "} else if (!" . $vc . ") { ");
                emit($cg, "  " . $vc . " = strada_new_ref_take(strada_new_hash(), '%'); ");
                emit($cg, "} " . $vc . "; })");
            } else {
                gen_expr($cg, $aobj);
            }
            emit($cg, ", __ak); free(__ak); __av; })");
        }
    } else {
        gen_expr($cg, $node);
    }
}

# Emit an expression that autovivifies $node to a HASHref if it's a plain
# scalar var (undef → springs into `{}`). For nested hash chains, delegates
# to `_gen_autoviv_hash`. Used when the outermost container of a chain
# `$d->{k}[i]` or `push @{$d->{k}}, ...` needs to come into being.
#
# $hash_context = 1 if this node represents a hash-sigil access (e.g. inside
# N_HASH_ELEM's "hash" field) — name collisions then route to `v_X__h` rather
# than the scalar `v_X`. Pass 0 for N_ARROW_HASH's "object" (always scalar).
func _gen_autoviv_outer_hash(scalar $cg, scalar $node, int $hash_context) void {
    my int $t = $node->{"type"};
    if ($t == Perla::AST::N_HASH_ELEM() || $t == Perla::AST::N_ARROW_HASH()) {
        _gen_autoviv_hash($cg, $node);
        return;
    }
    if ($t == Perla::AST::N_SCALAR_VAR()
        && defined($node->{"name"}) && index($node->{"name"}, "::") > 0) {
        # $Pkg::H{k} compound — fetch the HASH slot of the stash glob.
        # No autoviv needed at this level (perla_hash_get always returns
        # a real value when the slot is initialized via `our %H`).
        my array @ohpn = _split_pkg_qual_name($node);
        emit($cg, "perla_hash_get(\"" . $ohpn[0] . "\", \"" . $ohpn[1] . "\")");
        return;
    }
    if ($t == Perla::AST::N_SCALAR_VAR()
        && defined($node->{"name"}) && length($node->{"name"}) > 0
        && index($node->{"name"}, "::") < 0 && $node->{"name"} ne "_") {
        my str $vc;
        if ($hash_context == 1 && exists($__perla_mangle_collisions{$node->{"name"}})) {
            # `%foo` access where `@foo` or `$foo` also exists — the hash
            # lives in `v_foo__h`, NOT the scalar `v_foo`. Writing to v_foo
            # would diverge: the autoviv-created hashref lives in a slot
            # nobody reads from.
            $vc = c_var_h($node->{"name"});
        } else {
            $vc = c_var($node->{"name"});
        }
        emit($cg, "({ if (!" . $vc . " || (!STRADA_IS_TAGGED_INT(" . $vc . ") && " . $vc . "->type == STRADA_UNDEF)) { ");
        emit($cg, "  if (" . $vc . ") strada_decref(" . $vc . "); ");
        emit($cg, "  " . $vc . " = strada_new_ref_take(strada_new_hash(), '%'); ");
        emit($cg, "} " . $vc . "; })");
        return;
    }
    gen_expr($cg, $node);
}

# Emit an expression that autovivifies $node to an arrayref (or returns its
# existing arrayref value). Used by lvalue codegen where the array slot itself
# needs to spring into existence — e.g. `$d->{users}[0]{name} = X` needs
# `$d->{users}` to become `[]` so the [0] slot exists to set.
#
# Mirrors _gen_autoviv_hash but emits autoviv-to-ARRAY at the leaf step.
func _gen_autoviv_array_value(scalar $cg, scalar $node) void {
    my int $t = $node->{"type"};
    # `$_` as the REF of an array deref (`@{$_} = LIST`, `push @{$_}, X`) is the
    # scalar topic holding an array REFERENCE — NEVER the `@_` args array (that's
    # spelled `@_`). The old code emitted `perla_at_` here, so `@{$_} = LIST`
    # wrongly operated on @_ and dropped the write (Sub::Exporter::Progressive's
    # `@{$_} = map {...} @{$_} for \@defaults` lost the `-all` group expansion).
    #
    # We must NOT use the c_var("_")==v__ scalar-var path below either: `$_`
    # does NOT live in `v__`. Scalar assignment to `$_` writes the canonical
    # global `perla_dollar_underscore` (and the `main::_` glob slot); `v__` is
    # a vestigial local that stays NULL. Reading `v__` makes the autoviv think
    # `$_` is undef → it fabricates a throwaway array and assigns into that.
    # Use plain gen_expr (exactly what the working hash-deref path does), which
    # reads `$_` from its real storage. No autoviv-on-undef here, but `@{$_}`
    # on an undef $_ is a rare strict-refs error anyway; correct READ is what
    # matters for the for-modifier-aliased-arrayref idiom.
    if ($t == Perla::AST::N_SCALAR_VAR()
        && defined($node->{"name"}) && $node->{"name"} eq "_") {
        gen_expr($cg, $node);
        return;
    }
    if ($t == Perla::AST::N_SCALAR_VAR()
        && defined($node->{"name"}) && index($node->{"name"}, "::") > 0) {
        # $Pkg::arr access — fetch the ARRAY slot of the stash glob.
        my array @apkn = _split_pkg_qual_name($node);
        emit($cg, "perla_array_get(\"" . $apkn[0] . "\", \"" . $apkn[1] . "\")");
        return;
    }
    if ($t == Perla::AST::N_SCALAR_VAR()
        && defined($node->{"name"}) && length($node->{"name"}) > 0
        && index($node->{"name"}, "::") < 0) {
        my str $vc = c_var($node->{"name"});
        emit($cg, "({ if (!" . $vc . " || (!STRADA_IS_TAGGED_INT(" . $vc . ") && " . $vc . "->type == STRADA_UNDEF)) { ");
        emit($cg, "  if (" . $vc . ") strada_decref(" . $vc . "); ");
        emit($cg, "  " . $vc . " = strada_new_ref_take(strada_new_array(), '@'); ");
        emit($cg, "} " . $vc . "; })");
        return;
    }
    if ($t == Perla::AST::N_HASH_ELEM() || $t == Perla::AST::N_ARROW_HASH()) {
        my scalar $outer = undef;
        if ($t == Perla::AST::N_HASH_ELEM()) {
            $outer = $node->{"hash"};
        } else {
            $outer = $node->{"object"};
        }
        emit($cg, "({ StradaValue *__avx_h = ");
        my int $outer_t = $outer->{"type"};
        if ($outer_t == Perla::AST::N_HASH_ELEM() || $outer_t == Perla::AST::N_ARROW_HASH()) {
            _gen_autoviv_hash($cg, $outer);
        } elsif ($outer_t == Perla::AST::N_SCALAR_VAR()
            && defined($outer->{"name"}) && length($outer->{"name"}) > 0
            && index($outer->{"name"}, "::") < 0 && $outer->{"name"} ne "_") {
            my str $ovc = c_var($outer->{"name"});
            emit($cg, "({ if (!" . $ovc . " || (!STRADA_IS_TAGGED_INT(" . $ovc . ") && " . $ovc . "->type == STRADA_UNDEF)) { ");
            emit($cg, "  if (" . $ovc . ") strada_decref(" . $ovc . "); ");
            emit($cg, "  " . $ovc . " = strada_new_ref_take(strada_new_hash(), '%'); ");
            emit($cg, "} " . $ovc . "; })");
        } else {
            gen_expr($cg, $outer);
        }
        emit($cg, "; StradaHash *__avx_hh = strada_deref_hash(__avx_h); char *__avx_k = strada_to_str(");
        gen_expr($cg, $node->{"key"});
        emit($cg, "); StradaValue *__avx_v = __avx_hh ? strada_hash_get(__avx_hh, __avx_k) : NULL; ");
        emit($cg, "if (!__avx_v || STRADA_IS_TAGGED_INT(__avx_v) || __avx_v->type != STRADA_REF || !__avx_v->value.rv || __avx_v->value.rv->type != STRADA_ARRAY) { ");
        emit($cg, "  StradaValue *__avx_new = strada_new_ref_take(strada_new_array(), '@'); ");
        emit($cg, "  if (__avx_hh) strada_hash_set_take(__avx_hh, __avx_k, __avx_new); ");
        emit($cg, "  __avx_v = __avx_new; ");
        emit($cg, "} free(__avx_k); __avx_v; })");
        return;
    }
    # `$a[i][j] = …` with 3+ levels — inner is itself an N_ARRAY_ELEM
    # or N_ARROW_ARRAY. Autoviv the inner slot to a ref-to-array, then
    # return that arrayref so the next level can deref+set.
    if ($t == Perla::AST::N_ARRAY_ELEM() || $t == Perla::AST::N_ARROW_ARRAY()) {
        my scalar $inner_arr = undef;
        if ($t == Perla::AST::N_ARRAY_ELEM()) {
            $inner_arr = $node->{"array"};
        } else {
            $inner_arr = $node->{"object"};
        }
        emit($cg, "({ StradaArray *__avx_aa = strada_deref_array(");
        _gen_autoviv_array_value($cg, $inner_arr);  # recursive
        emit($cg, "); int __avx_ai = (int)strada_to_int(");
        gen_expr($cg, $node->{"index"});
        emit($cg, "); if (__avx_ai < 0 && __avx_aa) __avx_ai += strada_array_length(__avx_aa); ");
        emit($cg, "StradaValue *__avx_av = __avx_aa ? strada_array_get(__avx_aa, __avx_ai) : NULL; ");
        emit($cg, "if (!__avx_av || STRADA_IS_TAGGED_INT(__avx_av) || __avx_av->type != STRADA_REF || !__avx_av->value.rv || __avx_av->value.rv->type != STRADA_ARRAY) { ");
        emit($cg, "  StradaValue *__avx_new = strada_new_ref_take(strada_new_array(), '@'); ");
        emit($cg, "  if (__avx_aa) strada_array_set(__avx_aa, __avx_ai, __avx_new); ");
        emit($cg, "  __avx_av = __avx_new; ");
        emit($cg, "} __avx_av; })");
        return;
    }
    # Fallback: plain expression (no autoviv).
    gen_expr($cg, $node);
}

# Generate a condition expression as a C boolean (int), avoiding strada_to_bool wrapper
# Returns 1 if it emitted a direct C boolean, 0 if it fell back to perla_to_bool(expr)
func _gen_cond(scalar $cg, scalar $node) void {
    if (!defined($node)) { emit($cg, "0"); return; }
    my int $t = $node->{"type"};
    # Numeric comparisons: emit as direct C comparison
    if ($t == Perla::AST::N_BINOP()) {
        my str $op = $node->{"op"};
        if ($op eq "==" || $op eq "!=" || $op eq "<" || $op eq ">" || $op eq "<=" || $op eq ">=") {
            if (_node_is_int($cg, $node->{"left"}) == 1 && _node_is_int($cg, $node->{"right"}) == 1) {
                emit($cg, "(strada_to_int(");
                _gen_expr_scalar($cg, $node->{"left"});
                emit($cg, ") " . $op . " strada_to_int(");
                _gen_expr_scalar($cg, $node->{"right"});
                emit($cg, "))");
            } else {
                # Runtime fast path: if both are tagged ints, use int comparison.
                # If either operand is a blessed ref, try `use overload`
                # dispatch — without this, comparison in conditional
                # context (`if ($obj1 == $obj2)`) always compared the
                # ref addresses.
                my int $cl_borrowed_if = expr_is_borrowed($node->{"left"});
                my int $cr_borrowed_if = expr_is_borrowed($node->{"right"});
                emit($cg, "({ StradaValue *__cl = ");
                _gen_expr_scalar($cg, $node->{"left"});
                emit($cg, "; StradaValue *__cr = ");
                _gen_expr_scalar($cg, $node->{"right"});
                emit($cg, "; int __cres_final; ");
                # FAST PATH: two tagged integers — skip the REF/overload check
                # and the operand decrefs (tagged ints are immortal). Mirrors
                # the arithmetic fast path; this comparison runs every loop
                # iteration / recursion guard (`$n <= 1`).
                emit($cg, "if (STRADA_IS_TAGGED_INT(__cl) && STRADA_IS_TAGGED_INT(__cr)) { ");
                emit($cg, "  __cres_final = (STRADA_TAGGED_INT_VAL(__cl) " . $op . " STRADA_TAGGED_INT_VAL(__cr)); ");
                emit($cg, "} else { ");
                emit($cg, "  int __cbr_set = 0; int __cres = 0; ");
                emit($cg, "  if (((__cl && !STRADA_IS_TAGGED_INT(__cl) && __cl->type == STRADA_REF) || ");
                emit($cg, "       (__cr && !STRADA_IS_TAGGED_INT(__cr) && __cr->type == STRADA_REF))) { ");
                emit($cg, "    StradaValue *__cbr = perla_overload_binary(__cl, __cr, \"" . $op . "\"); ");
                emit($cg, "    if (__cbr) { __cres = strada_to_bool(__cbr); __cbr_set = 1; strada_decref(__cbr); } } ");
                emit($cg, "  __cres_final = __cbr_set ? __cres : ");
                emit($cg, "(STRADA_IS_TAGGED_INT(__cl) && STRADA_IS_TAGGED_INT(__cr) ? ");
                emit($cg, "(STRADA_TAGGED_INT_VAL(__cl) " . $op . " STRADA_TAGGED_INT_VAL(__cr)) : ");
                emit($cg, "(strada_to_num(__cl) " . $op . " strada_to_num(__cr))); ");
                # Decref owned operand temps so e.g. `$i == -1` doesn't
                # leak the fresh strada_new_num(-1) per call.
                if ($cl_borrowed_if == 0) {
                    emit($cg, "  if (__cl) strada_decref(__cl); ");
                }
                if ($cr_borrowed_if == 0) {
                    emit($cg, "  if (__cr) strada_decref(__cr); ");
                }
                emit($cg, "} ");
                emit($cg, "__cres_final; })");
            }
            return;
        }
        # String comparisons (fast path inside if-cond).
        # `eq`/`ne` are scalar operators — push scalar context so list
        # operators like `reverse $s` reverse the string instead of the
        # 1-element list. `$s eq reverse $s` was returning true (perla)
        # because reverse saw list context and was a no-op.
        if ($op eq "eq" || $op eq "ne") {
            # Overload dispatch on blessed refs before falling to strcmp.
            # Without this, `if ($obj eq $other)` with eq-overloaded
            # blessed refs skipped the user's sub.
            emit($cg, "({ int __sav_wl_eq = __perla_want_list; __perla_want_list = 0; ");
            emit($cg, "StradaValue *__cseql = ");
            gen_expr($cg, $node->{"left"});
            emit($cg, "; StradaValue *__cseqr = ");
            gen_expr($cg, $node->{"right"});
            emit($cg, "; __perla_want_list = __sav_wl_eq; StradaValue *__cseqov = NULL; ");
            emit($cg, "if ((__cseql && !STRADA_IS_TAGGED_INT(__cseql) && __cseql->type == STRADA_REF) || ");
            emit($cg, "    (__cseqr && !STRADA_IS_TAGGED_INT(__cseqr) && __cseqr->type == STRADA_REF)) { ");
            emit($cg, "  __cseqov = perla_overload_binary(__cseql, __cseqr, \"" . $op . "\"); } ");
            emit($cg, "int __cres; ");
            emit($cg, "if (__cseqov) { __cres = perla_to_bool(__cseqov); strada_decref(__cseqov); } ");
            emit($cg, "else { char *__cl = strada_to_str(__cseql); char *__cr = strada_to_str(__cseqr); ");
            emit($cg, "__cres = strcmp(__cl, __cr)");
            if ($op eq "eq") { emit($cg, " == 0"); }
            else { emit($cg, " != 0"); }
            emit($cg, "; free(__cl); free(__cr); } __cres; })");
            return;
        }
        # Logical operators: short-circuit
        if ($op eq "&&" || $op eq "and") {
            emit($cg, "(");
            _gen_cond($cg, $node->{"left"});
            emit($cg, " && ");
            _gen_cond($cg, $node->{"right"});
            emit($cg, ")");
            return;
        }
        if ($op eq "||" || $op eq "or") {
            emit($cg, "(");
            _gen_cond($cg, $node->{"left"});
            emit($cg, " || ");
            _gen_cond($cg, $node->{"right"});
            emit($cg, ")");
            return;
        }
    }
    # Unary not
    if ($t == Perla::AST::N_UNOP()) {
        my str $op = $node->{"op"};
        if ($op eq "!" || $op eq "not") {
            # Need to dispatch the `!` overload for blessed refs. The
            # simple `(!perla_to_bool(EXPR))` form silently skips
            # `use overload '!' => ...`. Use a statement-expression
            # that consults the overload first, then falls back to
            # the boolean of the operand (which also picks up the
            # `bool` overload via perla_to_bool).
            emit($cg, "({ StradaValue *__cnv = ");
            gen_expr($cg, $node->{"operand"});
            emit($cg, "; StradaValue *__cnr = NULL; ");
            emit($cg, "if (__cnv && !STRADA_IS_TAGGED_INT(__cnv) && __cnv->type == STRADA_REF) { ");
            emit($cg, "  __cnr = perla_overload_binary(__cnv, strada_new_undef(), \"!\"); } ");
            emit($cg, "__cnr ? perla_to_bool(__cnr) : !perla_to_bool(__cnv); })");
            return;
        }
    }
    # Regex match: $x =~ /pattern/ — emit the match result directly (returns int)
    if ($t == Perla::AST::N_REGEX_MATCH()) {
        gen_expr($cg, $node);
        emit($cg, " != 0");
        return;
    }
    # Flip-flop in boolean context (`if (/start/../end/)`, `while`, ternary,
    # &&/||). Each `..`/`...` site keeps its own persistent on/off state in a
    # function-local static. Returns int directly — no StradaValue alloc — so
    # the common per-iteration off case ("") never allocates or leaks. The
    # operands are evaluated as booleans (Perl's constant-vs-$. line-range
    # form is not emulated; regex/boolean operands are the common use).
    if ($t == Perla::AST::N_RANGE()) {
        my int $is3 = 0;
        if (defined($node->{"is_3dot"}) && $node->{"is_3dot"} == 1) { $is3 = 1; }
        emit($cg, "({ static int __ff_st = 0; int __ff_b; ");
        emit($cg, "if (!__ff_st) { if (");
        _gen_cond($cg, $node->{"from"});
        emit($cg, ") { __ff_st = 1; ");
        if ($is3 == 0) {
            emit($cg, "if (");
            _gen_cond($cg, $node->{"to"});
            emit($cg, ") { __ff_st = 0; } ");
        }
        emit($cg, "__ff_b = 1; } else { __ff_b = 0; } } ");
        emit($cg, "else { if (");
        _gen_cond($cg, $node->{"to"});
        emit($cg, ") { __ff_st = 0; } __ff_b = 1; } __ff_b; })");
        return;
    }
    # Fallback: evaluate and convert to bool. The condition is always
    # scalar context (Perl: `if (LIST)`, `LIST ? :`, etc. evaluate LIST
    # in scalar context). Without forcing scalar here, e.g.
    # `print "x: ", (1, 2, 0) ? "y" : "n";` evaluated the comma list
    # under the print's list context and got the full list (truthy)
    # instead of the comma-op last value (0, falsy).
    emit($cg, "({ int __sav_wl_cond = __perla_want_list; __perla_want_list = 0; ");
    emit($cg, "int __cv = perla_to_bool(");
    gen_expr($cg, $node);
    emit($cg, "); __perla_want_list = __sav_wl_cond; __cv; })");
}

# --- Statement generation ---
func gen_stmt(scalar $cg, scalar $node) void {
    my int $type = $node->{"type"};

    # Statement-context pre-declaration for an inline `my` buried in a
    # list-destructure assignment LHS: `($h->{k}, my $x) = LIST;`. _gen_assign
    # rewrites the inline N_MY to a plain scalar/array/hash assignment but never
    # emits the C declaration or registers the var, so a later reference trips
    # strict 'vars' and the C variable is undeclared. At file scope the static
    # file_scope_vars pass covers this; inside a sub we emit the local decl here
    # (statement context — safe to prepend declarations). Surfaced by DBIC
    # ResultSet: `($attrs->{group_by}, my $new_order) = $source->storage->...`.
    if ($type == Perla::AST::N_ASSIGN() && defined($node->{"op"}) && $node->{"op"} eq "="
        && defined($node->{"target"}) && $node->{"target"}->{"type"} == Perla::AST::N_ANON_ARRAY()
        && defined($node->{"target"}->{"elems"})
        && (!defined($cg->{"in_main"}) || $cg->{"in_main"} != 1)) {
        my scalar $__lae = $node->{"target"}->{"elems"};
        my int $__lai = 0;
        while ($__lai < scalar(@{$__lae})) {
            my scalar $__lael = $__lae->[$__lai];
            if (defined($__lael) && $__lael->{"type"} == Perla::AST::N_MY()) {
                my array @__lavars = ();
                if (defined($__lael->{"vars"})) { @__lavars = @{$__lael->{"vars"}}; }
                elsif (defined($__lael->{"var"})) { push(@__lavars, $__lael->{"var"}); }
                my int $__lavi = 0;
                while ($__lavi < scalar(@__lavars)) {
                    my scalar $__lav = $__lavars[$__lavi];
                    my str $__lavt = "" . $__lav->{"type"};
                    if (length($__lavt) == 0) { $__lavt = "SCALAR_VAR"; }
                    my str $__lavcn = c_var_for_vtype($__lavt, $__lav->{"value"});
                    if (!defined($cg->{"declared_vars"}->{$__lavcn})) {
                        my str $__lavinit = "NULL";
                        if ($__lavt eq "ARRAY_VAR") { $__lavinit = "strada_new_array()"; }
                        elsif ($__lavt eq "HASH_VAR") { $__lavinit = "strada_new_hash()"; }
                        ind($cg); emit($cg, "StradaValue *" . $__lavcn . " = " . $__lavinit . ";\n");
                        $cg->{"declared_vars"}->{$__lavcn} = 1;
                    }
                    $__lavi = $__lavi + 1;
                }
            }
            $__lai = $__lai + 1;
        }
    }

    # Labeled bare block: LABEL: { ... }
    # Emits a C block with goto targets at both ends, so `last LABEL` jumps
    # out and `redo LABEL` restarts the block. Without a label this case
    # would normally fall through to the expression form (`({ ... })`),
    # which doesn't permit break/goto.
    if ($type == Perla::AST::N_BLOCK() && defined($node->{"label"})) {
        my str $user_label = "" . $node->{"label"};
        $cg->{"label_count"} = $cg->{"label_count"} + 1;
        my str $ll = $user_label . "_" . $cg->{"label_count"};
        my scalar $saved_lm = $cg->{"label_map"};
        if (!defined($saved_lm)) { $saved_lm = {}; $cg->{"label_map"} = $saved_lm; }
        my str $prev_mapped = "" . $saved_lm->{$user_label};
        $saved_lm->{$user_label} = $ll;
        ind($cg); emit($cg, "__perla_redo_" . $ll . ": ;\n");
        ind($cg); emit($cg, "do {\n");
        $cg->{"indent"} = $cg->{"indent"} + 1;
        gen_block_stmts($cg, $node);
        $cg->{"indent"} = $cg->{"indent"} - 1;
        ind($cg); emit($cg, "} while (0);\n");
        ind($cg); emit($cg, "__perla_end_" . $ll . ": ;\n");
        # Test::More SKIP: { skip "msg", 2 if cond; ... } — perla
        # emulates `last SKIP` (the Perl idiom inside skip) by having
        # skip() set a thread-local "in skip" flag that suppresses
        # subsequent ok/is/like. Reset the flag at block exit so
        # tests after the SKIP block run normally.
        if ($user_label eq "SKIP") {
            ind($cg); emit($cg, "{ extern __thread int perla_tm_in_skip_block; perla_tm_in_skip_block = 0; }\n");
        }
        # Restore label map entry
        if (length($prev_mapped) > 0) { $saved_lm->{$user_label} = $prev_mapped; }
        return;
    }

    # Unlabeled bare `{ ... }` at statement level. In Perl this is a
    # loop-once construct — `redo` re-enters, `last`/`next` exit.
    # Emit goto labels around `do { ... } while (0)` and set
    # cg->{redo_label} so the inner N_REDO codegen can target them.
    # Common in Carp.pm:long_error_loc, namespace::clean's
    # accessor-builders, and many CPAN modules using bare blocks for
    # restartable lookups.
    if ($type == Perla::AST::N_BLOCK()) {
        $cg->{"label_count"} = $cg->{"label_count"} + 1;
        my str $ll = "bare_" . $cg->{"label_count"};
        my str $prev_redo = "" . $cg->{"redo_label"};
        my str $prev_in_loop = "" . $cg->{"in_loop"};
        $cg->{"redo_label"} = "__perla_redo_" . $ll;
        $cg->{"in_loop"} = 1;
        # Save lexical-pragma flags so `use integer;` inside the block
        # doesn't leak past its closing brace. Perl pragmas are lexically
        # scoped via $^H; we mirror that by save/restore around blocks.
        my int $bb_save_use_integer = 0;
        if (defined($cg->{"use_integer"})) { $bb_save_use_integer = $cg->{"use_integer"}; }
        my int $bb_save_use_utf8 = 0;
        if (defined($cg->{"use_utf8"})) { $bb_save_use_utf8 = $cg->{"use_utf8"}; }
        my int $bb_save_use_bytes = 0;
        if (defined($cg->{"use_bytes"})) { $bb_save_use_bytes = $cg->{"use_bytes"}; }
        # Snapshot local-vars for block-scoped `local $g` restoration.
        # Only track keys with an ACTIVE local (value != "__restored__").
        # An earlier block may have left "\\" marked as __restored__ —
        # treating that as a saved key would suppress the restore for a
        # NEW `local $\` declared inside this block.
        my scalar $bb_saved_locals = {};
        if (defined($cg->{"local_vars"})) {
            my array @bb_keys_b = keys($cg->{"local_vars"});
            my int $bb_ki = 0;
            while ($bb_ki < scalar(@bb_keys_b)) {
                my str $bb_v = "" . $cg->{"local_vars"}->{$bb_keys_b[$bb_ki]};
                if ($bb_v ne "__restored__") {
                    $bb_saved_locals->{$bb_keys_b[$bb_ki]} = 1;
                }
                $bb_ki++;
            }
        }
        # Lexical-shadow save/restore: a top-level `my $x` in this block that
        # SHADOWS an outer in-scope lexical of the same C slot (sub param or
        # sub-local) reuses v_x via `decref(v_x); v_x=new` — with no save the
        # block permanently clobbers the outer var. (`sub f{ my($x)=@_;
        # { my $x={%$x}; $x->{c}=3 } return [keys %$x] }` returned [a b c],
        # not [a b].) Most block my-vars are renamed to __blk slots by Collect
        # and don't collide; a same-name shadow that escapes renaming lands
        # here. Save the outer pointer (incref to compensate for the body's
        # reassignment-decref), let the body run — its RHS self-reference
        # `{%$x}` still reads the intact outer slot — then at block exit decref
        # the shadow and restore the outer. Saved BEFORE the redo label so the
        # save runs once; $ll in the save-var name avoids sibling collisions.
        my array @__bb_shadows = _block_shadow_cnames($cg, $node);
        my int $__bsv_i = 0;
        while ($__bsv_i < scalar(@__bb_shadows)) {
            my str $__bsv_cn = $__bb_shadows[$__bsv_i];
            ind($cg); emit($cg, "StradaValue *__shadowsav_" . $ll . "_" . $__bsv_cn . " = " . $__bsv_cn . "; if (" . $__bsv_cn . ") strada_incref(" . $__bsv_cn . ");\n");
            $__bsv_i = $__bsv_i + 1;
        }
        ind($cg); emit($cg, "__perla_redo_" . $ll . ": ;\n");
        # Capture local-chain head so `local $h{k} = v` inside this block
        # restores at block exit (Perl `local` is dynamic-block-scoped).
        ind($cg); emit($cg, "void *__bb_local_mark_" . $ll . " = __perla_local_chain;\n");
        # Collect renamed (__blk<N> suffixed) my-decls so we can decref
        # them at block exit. The Collect pass renames every `my X` in
        # the block to a unique synthetic name; decref'ing here drops
        # the refcount of any blessed obj held by the lexical, firing
        # DESTROY at block exit (Perl semantics).
        #
        # SKIP this for blocks that contain `sub` definitions — closure-
        # style `{ my $i = 0; sub next { $i++ } }` relies on the sub
        # body's references to the renamed slot continuing to work
        # AFTER the block closes. Decref'ing at exit would make the
        # sub's reads return undef. Without subs inside, the renamed
        # var is genuinely block-local and safe to decref.
        my array @__bb_blk_vars = ();
        # Walk top-level my-decls in the block and collect their renamed
        # (__blk<N> suffixed) names — these are the block-private lexicals
        # whose decref-at-block-exit fires DESTROY for blessed values, etc.
        #
        # Per-var capture filter: an enclosing closure may have captured
        # one of our block-local slots via &v_X, and decref+NULL'ing the
        # slot at block exit would corrupt the closure. We used to skip
        # ALL cleanup when ANY sub appeared in the block, but that left
        # plenty of unreferenced vars pinned past their scope — including
        # blessed objects whose DESTROY then only fired at process exit.
        # Instead we now check each var individually via
        # _sub_in_node_references_var; if no sub in the block references
        # that specific var, we can safely decref+NULL it at block exit.
        # Surface that motivated this: `{ package X; sub DESTROY {...};
        # my $o = bless {}, "X"; }` — DESTROY never refers to $o, so $o
        # should decref at block close and fire DESTROY there (matches
        # perl). Conversely `{ my $i = 0; sub next { $i++ } }` keeps the
        # original behaviour because `next` references $i.
        if (defined($node->{"stmts"})) {
            my scalar $__bb_stmts = $node->{"stmts"};
            my int $__bb_si = 0;
            while ($__bb_si < scalar(@{$__bb_stmts})) {
                my scalar $__bb_ss = $__bb_stmts->[$__bb_si];
                if (defined($__bb_ss) && $__bb_ss->{"type"} == Perla::AST::N_MY()) {
                    if (defined($__bb_ss->{"var"})) {
                        my str $__bb_vn = $__bb_ss->{"var"}->{"value"};
                        my str $__bb_vt = "" . $__bb_ss->{"var"}->{"type"};
                        if (length($__bb_vt) == 0) { $__bb_vt = "SCALAR_VAR"; }
                        if (($__bb_vt eq "SCALAR_VAR" || $__bb_vt eq "ARRAY_VAR" || $__bb_vt eq "HASH_VAR")
                            && index($__bb_vn, "__blk") >= 0
                            && _sub_in_node_references_var($node->{"stmts"}, $__bb_vn) == 0) {
                            push(@__bb_blk_vars, c_var($__bb_vn));
                        }
                    }
                    if (defined($__bb_ss->{"vars"})) {
                        my int $__bb_dvi = 0;
                        while ($__bb_dvi < scalar(@{$__bb_ss->{"vars"}})) {
                            my scalar $__bb_dv = $__bb_ss->{"vars"}->[$__bb_dvi];
                            my str $__bb_dvn = $__bb_dv->{"value"};
                            my str $__bb_dvt = "" . $__bb_dv->{"type"};
                            if (length($__bb_dvt) == 0) { $__bb_dvt = "SCALAR_VAR"; }
                            if (($__bb_dvt eq "SCALAR_VAR" || $__bb_dvt eq "ARRAY_VAR" || $__bb_dvt eq "HASH_VAR")
                                && index($__bb_dvn, "__blk") >= 0
                                && _sub_in_node_references_var($node->{"stmts"}, $__bb_dvn) == 0) {
                                push(@__bb_blk_vars, c_var($__bb_dvn));
                            }
                            $__bb_dvi = $__bb_dvi + 1;
                        }
                    }
                }
                $__bb_si = $__bb_si + 1;
            }
        }
        ind($cg); emit($cg, "do {\n");
        $cg->{"indent"} = $cg->{"indent"} + 1;
        gen_block_stmts($cg, $node);
        # Restore any `local $g` saves created inside this block.
        if (defined($cg->{"local_vars"})) {
            my array @bb_keys_a = keys($cg->{"local_vars"});
            my int $bb_kj = 0;
            while ($bb_kj < scalar(@bb_keys_a)) {
                my str $bb_kn = $bb_keys_a[$bb_kj];
                if (!defined($bb_saved_locals->{$bb_kn})) {
                    my str $bb_kvt = "" . $cg->{"local_vars"}->{$bb_kn};
                    if (length($bb_kvt) == 0 || $bb_kvt eq "1" || $bb_kvt eq "__restored__") { $bb_kvt = "SCALAR_VAR"; }
                    ind($cg); emit($cg, c_var_for_vtype($bb_kvt, $bb_kn) . " = __local_save_" . safe_ident($bb_kn) . ";\n");
                    # Mirror special $/, $\, $, into perla_irs/_ors/_ofs.
                    if ($bb_kn eq "/") { ind($cg); emit($cg, "perla_irs = __local_save_" . safe_ident($bb_kn) . ";\n"); }
                    elsif ($bb_kn eq "\\") { ind($cg); emit($cg, "perla_ors = __local_save_" . safe_ident($bb_kn) . ";\n"); }
                    elsif ($bb_kn eq ",") { ind($cg); emit($cg, "perla_ofs = __local_save_" . safe_ident($bb_kn) . ";\n"); }
                    elsif ($bb_kn eq "\"") { ind($cg); emit($cg, "perla_lse = __local_save_" . safe_ident($bb_kn) . ";\n"); }
                    $cg->{"local_vars"}->{$bb_kn} = "__restored__";
                }
                $bb_kj++;
            }
        }
        $cg->{"indent"} = $cg->{"indent"} - 1;
        ind($cg); emit($cg, "} while (0);\n");
        ind($cg); emit($cg, "__perla_end_" . $ll . ": ;\n");
        # Unwind hash-element locals pushed inside the block.
        ind($cg); emit($cg, "if (__perla_local_chain != __bb_local_mark_" . $ll . ") { perla_local_chain_restore_to(__perla_local_chain, __bb_local_mark_" . $ll . "); __perla_local_chain = __bb_local_mark_" . $ll . "; }\n");
        # Decref block-private my-lexicals so blessed objs fire DESTROY
        # at block exit (Perl semantics for `{ my $o = Obj->new; }`).
        # Iterate in REVERSE declaration order: Perl destroys lexicals at
        # scope exit LIFO, so `{ my $a=Obj->new(1); my $b=Obj->new(2); }`
        # fires DESTROY(2) before DESTROY(1).
        my int $__bb_di = scalar(@__bb_blk_vars) - 1;
        while ($__bb_di >= 0) {
            my str $__bb_dv = $__bb_blk_vars[$__bb_di];
            ind($cg); emit($cg, "if (" . $__bb_dv . ") { strada_decref(" . $__bb_dv . "); " . $__bb_dv . " = NULL; }\n");
            $__bb_di = $__bb_di - 1;
        }
        # Restore lexical shadows (reverse declaration order). decref whatever
        # the body left in the slot (the shadow value), then point the slot
        # back at the saved outer pointer (its refcount was pre-incref'd, and
        # the body's reassignment-decref consumed exactly that incref).
        my int $__bsr_i = scalar(@__bb_shadows) - 1;
        while ($__bsr_i >= 0) {
            my str $__bsr_cn = $__bb_shadows[$__bsr_i];
            ind($cg); emit($cg, "if (" . $__bsr_cn . " != __shadowsav_" . $ll . "_" . $__bsr_cn . ") { if (" . $__bsr_cn . ") strada_decref(" . $__bsr_cn . "); } " . $__bsr_cn . " = __shadowsav_" . $ll . "_" . $__bsr_cn . ";\n");
            $__bsr_i = $__bsr_i - 1;
        }
        $cg->{"redo_label"} = $prev_redo;
        $cg->{"in_loop"} = $prev_in_loop;
        # Restore lexical pragmas (use integer/utf8/bytes) at block exit.
        $cg->{"use_integer"} = $bb_save_use_integer;
        $cg->{"use_utf8"} = $bb_save_use_utf8;
        $cg->{"use_bytes"} = $bb_save_use_bytes;
        return;
    }

    if ($type == Perla::AST::N_MY()) {
        _gen_my($cg, $node);
        return;
    }
    if ($type == Perla::AST::N_STATE()) {
        _gen_state($cg, $node);
        return;
    }
    if ($type == Perla::AST::N_LOCAL()) {
        # local $var = expr — save old value, set new
        # For our variables, save the old value and set the new one.
        # Restoration happens at function exit OR eval BLOCK exit via the
        # local-chain. For scalar vars we also push to chain so eval-block
        # die-unwind can restore (the static __local_save_* slot only fires
        # at sub exit, not at eval block exit).
        #
        # `local (\$a, \$b) = (5, 10)` — list-form. Each var gets pushed
        # on the local-chain individually; the RHS is evaluated once
        # (list context) and elements distributed. Without this branch,
        # the list form silently did nothing because the codegen only
        # checked for `var` (single) or `target` (lvalue) — never `vars`.
        if (defined($node->{"vars"}) && !defined($node->{"var"})) {
            my scalar $vars = $node->{"vars"};
            my int $vn = scalar(@{$vars});
            if (defined($node->{"init"})) {
                emit($cg, "{ int __sav_wl_lloc = __perla_want_list; __perla_want_list = 1; StradaValue *__lloc_rhs = ");
                gen_expr($cg, $node->{"init"});
                emit($cg, "; __perla_want_list = __sav_wl_lloc; StradaArray *__lloc_av = strada_deref_array(__lloc_rhs); ");
                my int $li = 0;
                while ($li < $vn) {
                    my scalar $vt = $vars->[$li];
                    my str $vn1 = $vt->{"value"};
                    my str $vtype = "" . $vt->{"type"};
                    if (length($vtype) == 0) { $vtype = "SCALAR_VAR"; }
                    if ($vtype eq "SCALAR_VAR") {
                        my str $lcv1 = c_var($vn1);
                        emit($cg, "__perla_local_chain = perla_local_push_scalar_slot(__perla_local_chain, &" . $lcv1 . ", ");
                        emit($cg, "(__lloc_av && " . $li . " < (int)__lloc_av->size) ? ({ StradaValue *__lv = __lloc_av->elements[__lloc_av->head + " . $li . "]; if (__lv) strada_incref(__lv); __lv ? __lv : strada_new_undef(); }) : strada_new_undef()");
                        emit($cg, "); ");
                    }
                    $li = $li + 1;
                }
                emit($cg, "if (__lloc_rhs) strada_decref(__lloc_rhs); }\n");
            } else {
                my int $li = 0;
                while ($li < $vn) {
                    my scalar $vt = $vars->[$li];
                    my str $vn1 = $vt->{"value"};
                    my str $vtype = "" . $vt->{"type"};
                    if (length($vtype) == 0) { $vtype = "SCALAR_VAR"; }
                    if ($vtype eq "SCALAR_VAR") {
                        my str $lcv1 = c_var($vn1);
                        ind($cg); emit($cg, "__perla_local_chain = perla_local_push_scalar_slot(__perla_local_chain, &" . $lcv1 . ", strada_new_undef());\n");
                    }
                    $li = $li + 1;
                }
            }
            return;
        }
        if (defined($node->{"var"})) {
            my str $vname = $node->{"var"}->{"value"};
            my str $lvtype = "" . $node->{"var"}->{"type"};
            if (length($lvtype) == 0) { $lvtype = "SCALAR_VAR"; }
            my str $safe_vname = safe_ident($vname);
            my str $lcv = c_var_for_vtype($lvtype, $vname);
            # `local $/` must mirror into perla_irs (the IRS the I/O
            # routines actually read). Otherwise the slurp idiom
            # `do { local $/; <\$fh> }` modifies v__slash_ but not
            # perla_irs, and the read still uses "\n".
            # Scalar-only special globals — only apply when the local is
            # on the scalar sigil. `local @_` (array) must NOT alias into
            # perla_dollar_underscore (which is the $_ scalar storage).
            my str $mirror_global = "";
            if ($lvtype eq "SCALAR_VAR") {
                if ($vname eq "/") { $mirror_global = "perla_irs"; }
                elsif ($vname eq "\\") { $mirror_global = "perla_ors"; }
                elsif ($vname eq ",") { $mirror_global = "perla_ofs"; }
                elsif ($vname eq "\"") { $mirror_global = "perla_lse"; }
                # Format-control special vars — mirrored so the
                # write runtime can consult them at write-time.
                elsif ($vname eq "~") { $mirror_global = "perla_dollar_tilde"; }
                elsif ($vname eq "=") { $mirror_global = "perla_dollar_equals"; }
                # `local $_` — the canonical $_ storage is
                # perla_dollar_underscore (used by loops, map, grep, sort,
                # bare-scalar interp, etc.). v__ is the legacy mirror.
                # Localize the canonical and mirror to v__ so any code still
                # reading v__ stays in sync.
                elsif ($vname eq "_") {
                    $lcv = "perla_dollar_underscore";
                    $mirror_global = "v__";
                }
                # `local $@` — backed by perla_eval_error global, not v__at_.
                # DBIx::Class::ResultSource line 2339 uses `local $@; eval{...}`
                # to suppress die during weaken; without this special case
                # _c_var maps `@` → `v__at_` (a name nothing declares) and
                # the .pm.so fails to compile.
                elsif ($vname eq "@") {
                    $lcv = "perla_eval_error";
                }
                # `local $0` — backed by perla_dollar_zero (the program
                # name). The default c_var_for_vtype maps "0" to v_0
                # which nothing reads; the read codegen and assignment
                # both go through perla_dollar_zero.
                elsif ($vname eq "0") {
                    $lcv = "perla_dollar_zero";
                }
            }
            # `local @_ = (LIST)` — Perl's @_ is the sub's argument array.
            # perla stores it in perla_at_ (function-local var, not a
            # static). Override $lcv to perla_at_ so the array
            # assignment writes the real @_ slot, then the array path
            # below handles it.
            if ($lvtype eq "ARRAY_VAR" && $vname eq "_") {
                $lcv = "perla_at_";
            }
            # For scalar vars: use chain-based local. The push helper
            # captures *&lcv → old, then installs new (with proper
            # refcount transfer). Chain restore at eval/block/sub exit
            # walks the chain and writes old back, so `eval { local $X
            # = "in"; die }` correctly restores $X to outer after die.
            if ($lvtype eq "SCALAR_VAR") {
                # `local $Pkg::var` — push on the stash slot, not on a
                # fake `v_Pkg__col_col_var` static. The runtime auto-
                # discovers a registered local mirror (v_var in Pkg's
                # compiled subs) via perla_find_local_by_stash_slot so
                # `local` is visible to those subs. Without this, the
                # push affected an unrelated static and Pkg::sub() kept
                # seeing the old value.
                if (length($mirror_global) == 0 && index($vname, "::") > 0) {
                    my int $lqi = -1;
                    my int $lsi = 0;
                    while ($lsi < length($vname) - 1) {
                        if (substr($vname, $lsi, 2) eq "::") { $lqi = $lsi; }
                        $lsi = $lsi + 1;
                    }
                    my str $lpkg = substr($vname, 0, $lqi);
                    my str $lname = substr($vname, $lqi + 2, length($vname) - $lqi - 2);
                    ind($cg); emit($cg, "__perla_local_chain = perla_local_push_scalar_slot(__perla_local_chain, &perla_glob_get_or_create(perla_stash_get_or_create(\"" . $lpkg . "\"), \"" . $lname . "\")->slots[PERLA_SLOT_SCALAR], ");
                    if (defined($node->{"init"})) {
                        gen_expr($cg, $node->{"init"});
                    } else {
                        emit($cg, "strada_new_undef()");
                    }
                    emit($cg, ");\n");
                    return;
                }
                if (length($mirror_global) > 0) {
                    ind($cg); emit($cg, "__perla_local_chain = perla_local_push_scalar_slot_m(__perla_local_chain, &" . $lcv . ", ");
                    if (defined($node->{"init"})) {
                        gen_expr($cg, $node->{"init"});
                    } else {
                        emit($cg, "strada_new_undef()");
                    }
                    emit($cg, ", &" . $mirror_global . ");\n");
                } else {
                    ind($cg); emit($cg, "__perla_local_chain = perla_local_push_scalar_slot(__perla_local_chain, &" . $lcv . ", ");
                    if (defined($node->{"init"})) {
                        gen_expr($cg, $node->{"init"});
                    } else {
                        emit($cg, "strada_new_undef()");
                    }
                    emit($cg, ");\n");
                }
                return;
            }
            # Non-scalar (array/hash) `local` — keep the static save path
            # for now; eval-block restore for arrays/hashes is rarer.
            ind($cg); emit($cg, "/* local " . $vname . " */ __local_save_" . $safe_vname . " = " . $lcv . ";\n");
            ind($cg); emit($cg, "if (__local_save_" . $safe_vname . ") strada_incref(__local_save_" . $safe_vname . ");\n");
            # Set new value
            if (defined($node->{"init"})) {
                # `local %h = (k=>v, ...)` should convert flat list → hash
                # (same as `our %h = (...)`); without this the C var was bound
                # to the raw flat array and downstream reads as a hash returned
                # nothing.
                my int $init_t = $node->{"init"}->{"type"};
                if ($lvtype eq "HASH_VAR" && $init_t == Perla::AST::N_ANON_ARRAY()) {
                    ind($cg); emit($cg, $lcv . " = strada_hash_from_flat_array(({ int __sav_wl_lha = __perla_want_list; __perla_want_list = 1; StradaValue *__lha_v = ");
                    gen_expr($cg, $node->{"init"});
                    emit($cg, "; __perla_want_list = __sav_wl_lha; __lha_v; }));\n");
                } elsif ($lvtype eq "ARRAY_VAR" || $lvtype eq "HASH_VAR") {
                    # Force list context around the RHS so `local @arr =
                    # (10, 20, 30)` actually gets the array, not the
                    # comma-operator's last-element collapse that happens
                    # when __perla_want_list==0 (the default at block
                    # scope). For single-value RHS like `local @arr = (10)`,
                    # parser strips the parens and emits N_INT_LIT — we
                    # need to wrap in a fresh 1-elem array.
                    ind($cg); emit($cg, $lcv . " = ({ int __sav_wl_la = __perla_want_list; __perla_want_list = 1; StradaValue *__la_v = ");
                    gen_expr($cg, $node->{"init"});
                    emit($cg, "; __perla_want_list = __sav_wl_la; ");
                    if ($lvtype eq "ARRAY_VAR") {
                        emit($cg, "if (__la_v && (STRADA_IS_TAGGED_INT(__la_v) || __la_v->type != STRADA_ARRAY)) { ");
                        emit($cg, "  StradaValue *__la_wrap = strada_new_array(); if (__la_v) strada_incref(__la_v); strada_array_push_take(strada_deref_array(__la_wrap), __la_v); __la_v = __la_wrap; ");
                        emit($cg, "} ");
                    }
                    emit($cg, "__la_v; });\n");
                } else {
                    ind($cg); emit($cg, $lcv . " = ");
                    gen_expr($cg, $node->{"init"});
                    emit($cg, ";\n");
                }
            } else {
                # `local $/;` with no value clears to undef
                ind($cg); emit($cg, $lcv . " = strada_new_undef();\n");
            }
            if (length($mirror_global) > 0) {
                ind($cg); emit($cg, $mirror_global . " = " . $lcv . ";\n");
            }
            # Register for cleanup — track that this function needs local restore.
            # Store {name, type} so restore code picks the sigil-aware C name.
            if (!defined($cg->{"local_vars"})) { $cg->{"local_vars"} = {}; }
            $cg->{"local_vars"}->{$vname} = $lvtype;
        } elsif (defined($node->{"target"})) {
            # `local $h->{k} = v` — push a save record into the
            # per-function-call chain (`__perla_local_chain`) and install
            # the new value. The chain is walked at function exit by
            # `perla_local_chain_restore_all`. Forward-declared at the
            # function entry so it's visible from any nested block.
            my scalar $tgt = $node->{"target"};
            my int $tt = $tgt->{"type"};
            if ($tt == Perla::AST::N_ARROW_HASH() || $tt == Perla::AST::N_HASH_ELEM()) {
                my scalar $hash = ($tt == Perla::AST::N_ARROW_HASH()) ? $tgt->{"object"} : $tgt->{"hash"};
                # `local $ENV{KEY} = V` must also call setenv() so child
                # processes (qx, system, exec, popen) spawned inside the
                # local scope inherit the new value. Without this, the
                # hash entry was set in v_ENV but the C-side env was
                # untouched and shell children saw the parent's value.
                # Restore-side unsetenv on scope exit is a TODO; the
                # common pattern is "set, run cmd, end scope" so the
                # value not being unset matters less.
                my int $is_env_local = 0;
                if (defined($hash) && defined($hash->{"type"})
                    && ($hash->{"type"} == Perla::AST::N_SCALAR_VAR()
                        || $hash->{"type"} == Perla::AST::N_HASH_VAR())
                    && defined($hash->{"name"}) && $hash->{"name"} eq "ENV") {
                    $is_env_local = 1;
                }
                # `local $SIG{NAME} = sub{...}` — install C signal handler
                # for the duration of the local scope. Restore-side reset
                # at scope exit is a TODO (the chain restores the hash
                # value but the kernel-registered handler still points at
                # the perla wrapper which then calls a now-stale closure).
                # The "set, kill, wait, end scope" pattern in tests works
                # because the signal fires within the local lifetime.
                my int $is_sig_local = 0;
                if (defined($hash) && defined($hash->{"type"})
                    && ($hash->{"type"} == Perla::AST::N_SCALAR_VAR()
                        || $hash->{"type"} == Perla::AST::N_HASH_VAR())
                    && defined($hash->{"name"}) && $hash->{"name"} eq "SIG") {
                    $is_sig_local = 1;
                }
                ind($cg); emit($cg, "__perla_local_chain = perla_local_push_hash_elem(__perla_local_chain, ");
                # `local $Pkg::h{key}` — gen_expr on the qualified
                # N_HASH_VAR / N_SCALAR_VAR (the AST shape depends on
                # whether the sigil was $ or %) emits perla_scalar_get
                # which returns NULL (the stash holds %h in
                # PERLA_SLOT_HASH, not SCALAR). Resolve directly from
                # the stash slot instead.
                my int $emitted_pkg_hash = 0;
                my str $hqn = "";
                if (defined($hash) && defined($hash->{"type"})
                    && ($hash->{"type"} == Perla::AST::N_HASH_VAR()
                        || $hash->{"type"} == Perla::AST::N_SCALAR_VAR())) {
                    if (defined($hash->{"name"})) {
                        $hqn = "" . $hash->{"name"};
                    } elsif (defined($hash->{"value"})) {
                        $hqn = "" . $hash->{"value"};
                    }
                }
                if (length($hqn) > 0 && index($hqn, "::") > 0) {
                    my int $hqi = -1; my int $hsi = 0;
                    while ($hsi < length($hqn) - 1) {
                        if (substr($hqn, $hsi, 2) eq "::") { $hqi = $hsi; }
                        $hsi = $hsi + 1;
                    }
                    my str $hpkg = substr($hqn, 0, $hqi);
                    my str $hnm = substr($hqn, $hqi + 2, length($hqn) - $hqi - 2);
                    emit($cg, "perla_glob_get_or_create(perla_stash_get_or_create(\"" . $hpkg . "\"), \"" . $hnm . "\")->slots[PERLA_SLOT_HASH]");
                    $emitted_pkg_hash = 1;
                }
                if ($emitted_pkg_hash == 0) {
                    gen_expr($cg, $hash);
                }
                emit($cg, ", ");
                gen_expr($cg, $tgt->{"key"});
                emit($cg, ", ");
                if (defined($node->{"init"})) {
                    gen_expr($cg, $node->{"init"});
                } else {
                    emit($cg, "strada_new_undef()");
                }
                emit($cg, ");\n");
                # Mirror to the C-side env so child processes see the
                # new value during the local scope.
                if ($is_env_local == 1) {
                    ind($cg); emit($cg, "{ char *__envk = strada_to_str(");
                    gen_expr($cg, $tgt->{"key"});
                    emit($cg, "); char *__envv = strada_to_str(");
                    if (defined($node->{"init"})) {
                        gen_expr($cg, $node->{"init"});
                    } else {
                        emit($cg, "strada_new_str(\"\")");
                    }
                    emit($cg, "); if (__envk && __envv) setenv(__envk, __envv, 1); ");
                    emit($cg, "if (__envk) free(__envk); if (__envv) free(__envv); }\n");
                }
                if ($is_sig_local == 1) {
                    # Re-fetch the just-installed value from v_SIG rather
                    # than re-evaluating init (which for `sub {...}` would
                    # build a second closure with the same captures).
                    ind($cg); emit($cg, "{ char *__sigk = strada_to_str(");
                    gen_expr($cg, $tgt->{"key"});
                    emit($cg, "); if (__sigk) { ");
                    emit($cg, "StradaValue *__sigv = (v_SIG && !STRADA_IS_TAGGED_INT(v_SIG) && v_SIG->type == STRADA_HASH) ? strada_hash_get(v_SIG->value.hv, __sigk) : NULL; ");
                    emit($cg, "if (__sigv) perla_install_signal(__sigk, __sigv); free(__sigk); } }\n");
                }
                $cg->{"local_chain_used"} = 1;
            } elsif ($tt == Perla::AST::N_ARROW_ARRAY() || $tt == Perla::AST::N_ARRAY_ELEM()) {
                # `local $arr[$i] = N` / `local $ref->[$i] = N` — push
                # array-elem save record onto the local-chain. Restore at
                # block/sub exit writes the original element back.
                my scalar $arr = ($tt == Perla::AST::N_ARROW_ARRAY()) ? $tgt->{"object"} : $tgt->{"array"};
                ind($cg); emit($cg, "__perla_local_chain = perla_local_push_array_elem(__perla_local_chain, ");
                gen_expr($cg, $arr);
                emit($cg, ", (int)strada_to_int(");
                gen_expr($cg, $tgt->{"index"});
                emit($cg, "), ");
                if (defined($node->{"init"})) {
                    gen_expr($cg, $node->{"init"});
                } else {
                    emit($cg, "strada_new_undef()");
                }
                emit($cg, ");\n");
                $cg->{"local_chain_used"} = 1;
            } elsif ($tt == Perla::AST::N_GLOB_ACCESS() && !defined($tgt->{"expr"})) {
                # `local *Pkg::fn = sub { ... }` — save current CODE slot,
                # install new sub. Used for test mocking (a la Test::MockObject
                # patterns). Restoration walks the local-chain at scope exit.
                my str $gname = $tgt->{"name"};
                my int $sep = -1;
                my int $gi = length($gname) - 1;
                while ($gi >= 0) {
                    if ($gi > 0 && substr($gname, $gi - 1, 2) eq "::") { $sep = $gi - 1; last; }
                    $gi--;
                }
                my str $gpkg = $cg->{"pkg"};
                my str $gshort = $gname;
                if ($sep >= 0) {
                    $gpkg = substr($gname, 0, $sep);
                    $gshort = substr($gname, $sep + 2, length($gname) - $sep - 2);
                }
                # get_or_create (not get): `local *c = sub {...}` on a name
                # that was never defined (no `sub c`) must still install the
                # localized CODE slot so a later bareword `c()` resolves it.
                # perla_glob_get returned NULL there, so the local-push (and
                # thus the override) was silently skipped.
                ind($cg); emit($cg, "{ PerlGlob *__lg = perla_glob_get_or_create(perla_stash_get_or_create(\"" . $gpkg . "\"), \"" . $gshort . "\"); ");
                emit($cg, "if (__lg) { __perla_local_chain = perla_local_push_scalar_slot(__perla_local_chain, &__lg->slots[PERLA_SLOT_CODE], ");
                if (defined($node->{"init"})) {
                    gen_expr($cg, $node->{"init"});
                } else {
                    emit($cg, "strada_new_undef()");
                }
                emit($cg, "); } }\n");
                $cg->{"local_chain_used"} = 1;
            } elsif ($tt == Perla::AST::N_HASH_SLICE()) {
                # `local @h{qw(a b)} = (10, 20)` — save+restore N keys of
                # a hash. Reuse the existing N_HASH_SLICE expr codegen to
                # materialise the keys as a value array (handles range,
                # @keys, literal-list, qw, etc.), then pair with the
                # init values list and push per-key save records.
                #
                # Trick: a "read" of N_HASH_SLICE returns the VALUES at
                # those keys, not the keys themselves. To get keys-only,
                # synthesise an anon-array node from keys_list and emit
                # that as the key source.
                my scalar $hsl_hash = $tgt->{"hash"};
                my scalar $hsl_keys = $tgt->{"keys_list"};
                emit($cg, "{ ");
                # Resolve the hash StradaValue* (mirror the gen path in
                # N_HASH_SLICE rvalue codegen).
                emit($cg, "StradaValue *__lhs_h = ");
                if (defined($hsl_hash) && ref($hsl_hash) eq "HASH") {
                    if ($hsl_hash->{"type"} == Perla::AST::N_DEREF_ARRAY() && defined($hsl_hash->{"ref"})) {
                        gen_expr($cg, $hsl_hash->{"ref"});
                    } else {
                        gen_expr($cg, $hsl_hash);
                    }
                } elsif (defined($hsl_hash) && length("" . $hsl_hash) > 1 && substr("" . $hsl_hash, 0, 1) eq "\$") {
                    my str $rv = substr("" . $hsl_hash, 1, length("" . $hsl_hash) - 1);
                    emit($cg, c_var($rv));
                } else {
                    emit($cg, c_var_h("" . $hsl_hash));
                }
                emit($cg, "; ");
                # Materialise the key list. Each element may be a
                # literal, scalar var, range, or @arr — let gen_expr do
                # the work for each and collect into a fresh array.
                emit($cg, "StradaValue *__lhs_kv = strada_new_array(); ");
                emit($cg, "StradaArray *__lhs_ka = strada_deref_array(__lhs_kv); ");
                emit($cg, "int __sav_wl_lhs = __perla_want_list; __perla_want_list = 1; ");
                my int $hsk_i = 0;
                my int $hsk_n = scalar(@{$hsl_keys});
                while ($hsk_i < $hsk_n) {
                    my scalar $kelem = $hsl_keys->[$hsk_i];
                    emit($cg, "{ StradaValue *__hke = ");
                    gen_expr($cg, $kelem);
                    emit($cg, "; if (__hke && !STRADA_IS_TAGGED_INT(__hke) && __hke->type == STRADA_ARRAY) { ");
                    emit($cg, "  StradaArray *__hkea = strada_deref_array(__hke); ");
                    emit($cg, "  if (__hkea) for (size_t __hki = 0; __hki < __hkea->size; __hki++) { ");
                    emit($cg, "    StradaValue *__hkev = __hkea->elements[__hkea->head + __hki]; ");
                    emit($cg, "    if (__hkev) strada_incref(__hkev); strada_array_push_take(__lhs_ka, __hkev); ");
                    emit($cg, "  } strada_decref(__hke); ");
                    emit($cg, "} else { strada_array_push_take(__lhs_ka, __hke ? __hke : strada_new_undef()); } }\n");
                    $hsk_i = $hsk_i + 1;
                }
                emit($cg, "StradaValue *__lhs_vv = ");
                if (defined($node->{"init"})) {
                    gen_expr($cg, $node->{"init"});
                } else {
                    emit($cg, "strada_new_array()");
                }
                emit($cg, "; StradaArray *__lhs_va = strada_deref_array(__lhs_vv); ");
                emit($cg, "__perla_want_list = __sav_wl_lhs; ");
                emit($cg, "int __lhs_n = (int)__lhs_ka->size; ");
                emit($cg, "for (int __lhs_i = 0; __lhs_i < __lhs_n; __lhs_i++) { ");
                emit($cg, "  StradaValue *__lhs_k = __lhs_ka->elements[__lhs_ka->head + __lhs_i]; ");
                emit($cg, "  StradaValue *__lhs_v = (__lhs_va && __lhs_i < (int)__lhs_va->size) ");
                emit($cg, "    ? ({ StradaValue *__lvv = __lhs_va->elements[__lhs_va->head + __lhs_i]; if (__lvv) strada_incref(__lvv); __lvv ? __lvv : strada_new_undef(); }) ");
                emit($cg, "    : strada_new_undef(); ");
                emit($cg, "  __perla_local_chain = perla_local_push_hash_elem(__perla_local_chain, __lhs_h, __lhs_k, __lhs_v); ");
                emit($cg, "} ");
                emit($cg, "strada_decref(__lhs_kv); ");
                emit($cg, "if (__lhs_vv) strada_decref(__lhs_vv); ");
                emit($cg, "}\n");
                $cg->{"local_chain_used"} = 1;
            } elsif ($tt == Perla::AST::N_ARRAY_SLICE()) {
                # `local @arr[1, 3] = (10, 30)` — symmetric to hash slice.
                # Indices list each element is an AST (may be literal,
                # range, or @arr) — materialise into a flat index array
                # via per-element gen_expr.
                my scalar $asl_arr  = $tgt->{"array"};
                my scalar $asl_idxs = $tgt->{"indices"};
                emit($cg, "{ ");
                # Resolve array StradaValue* (mirror N_ARRAY_SLICE rvalue).
                emit($cg, "StradaValue *__las_a = ");
                if (defined($asl_arr) && ref($asl_arr) eq "HASH") {
                    gen_expr($cg, $asl_arr);
                } elsif (defined($asl_arr) && ("" . $asl_arr) eq "_") {
                    emit($cg, "perla_at_");
                } else {
                    emit($cg, c_var_a("" . $asl_arr));
                }
                emit($cg, "; ");
                emit($cg, "StradaValue *__las_iv = strada_new_array(); ");
                emit($cg, "StradaArray *__las_ia = strada_deref_array(__las_iv); ");
                emit($cg, "int __sav_wl_las = __perla_want_list; __perla_want_list = 1; ");
                my int $asi_i = 0;
                my int $asi_n = scalar(@{$asl_idxs});
                while ($asi_i < $asi_n) {
                    my scalar $ielem = $asl_idxs->[$asi_i];
                    if (defined($ielem) && $ielem->{"type"} == Perla::AST::N_RANGE()) {
                        emit($cg, "{ int __rf = (int)strada_to_num(");
                        gen_expr($cg, $ielem->{"from"});
                        emit($cg, "); int __rt = (int)strada_to_num(");
                        gen_expr($cg, $ielem->{"to"});
                        emit($cg, "); for (int __ri = __rf; __ri <= __rt; __ri++) strada_array_push_take(__las_ia, STRADA_MAKE_TAGGED_INT((int64_t)__ri)); }\n");
                    } else {
                        emit($cg, "{ StradaValue *__iev = ");
                        gen_expr($cg, $ielem);
                        emit($cg, "; if (__iev && !STRADA_IS_TAGGED_INT(__iev) && __iev->type == STRADA_ARRAY) { ");
                        emit($cg, "  StradaArray *__iea = strada_deref_array(__iev); ");
                        emit($cg, "  if (__iea) for (size_t __ii = 0; __ii < __iea->size; __ii++) { ");
                        emit($cg, "    StradaValue *__iel = __iea->elements[__iea->head + __ii]; ");
                        emit($cg, "    if (__iel) strada_incref(__iel); strada_array_push_take(__las_ia, __iel ? __iel : strada_new_undef()); ");
                        emit($cg, "  } strada_decref(__iev); ");
                        emit($cg, "} else { strada_array_push_take(__las_ia, __iev ? __iev : strada_new_undef()); } }\n");
                    }
                    $asi_i = $asi_i + 1;
                }
                emit($cg, "StradaValue *__las_vv = ");
                if (defined($node->{"init"})) {
                    gen_expr($cg, $node->{"init"});
                } else {
                    emit($cg, "strada_new_array()");
                }
                emit($cg, "; StradaArray *__las_va = strada_deref_array(__las_vv); ");
                emit($cg, "__perla_want_list = __sav_wl_las; ");
                emit($cg, "int __las_n = (int)__las_ia->size; ");
                emit($cg, "for (int __las_i = 0; __las_i < __las_n; __las_i++) { ");
                emit($cg, "  int __las_idx = (int)strada_to_int(__las_ia->elements[__las_ia->head + __las_i]); ");
                emit($cg, "  StradaValue *__las_v = (__las_va && __las_i < (int)__las_va->size) ");
                emit($cg, "    ? ({ StradaValue *__lvv = __las_va->elements[__las_va->head + __las_i]; if (__lvv) strada_incref(__lvv); __lvv ? __lvv : strada_new_undef(); }) ");
                emit($cg, "    : strada_new_undef(); ");
                emit($cg, "  __perla_local_chain = perla_local_push_array_elem(__perla_local_chain, __las_a, __las_idx, __las_v); ");
                emit($cg, "} ");
                emit($cg, "strada_decref(__las_iv); ");
                emit($cg, "if (__las_vv) strada_decref(__las_vv); ");
                emit($cg, "}\n");
                $cg->{"local_chain_used"} = 1;
            }
            # Other complex lvalue types (scalar deref) fall through —
            # not yet implemented; should be rare in real code.
        }
        return;
    }
    if ($type == Perla::AST::N_OUR()) {
        _gen_our($cg, $node);
        return;
    }
    if ($type == Perla::AST::N_PACKAGE()) {
        $cg->{"pkg"} = $node->{"name"};
        ind($cg); emit($cg, "/* package " . $node->{"name"} . " */\n");
        ind($cg); emit($cg, "perla_stash_get_or_create(\"" . $node->{"name"} . "\");\n");
        # Update call stack frame's package so `caller()`, perla_moose_import,
        # and the `has` accessor registration path see THIS package. In
        # module_mode the init pushes a synthetic top frame at entry (see
        # generate_module), so this writes into our own frame. In script
        # mode the top frame is also ours.
        ind($cg); emit($cg, "if (perla_call_depth > 0) perla_call_stack[perla_call_depth-1].package = \"" . $node->{"name"} . "\";\n");
        return;
    }
    if ($type == Perla::AST::N_USE()) {
        my str $mod = $node->{"module"};
        # Pragma-scope markers bracketing an inlined use'd module's statements
        # (see Parser.strada). Save the lexical-pragma flags before the inlined
        # block and restore them after, so the dependency's `use strict` /
        # `use warnings` / etc. don't leak into the consuming file.
        if (defined($mod) && $mod eq "__pragma_save__") {
            if (!defined($cg->{"pragma_stack"})) { $cg->{"pragma_stack"} = []; }
            my hash %__psnap = ();
            $__psnap{"strict_vars"} = defined($cg->{"strict_vars"}) ? $cg->{"strict_vars"} : 0;
            $__psnap{"strict_refs"} = defined($cg->{"strict_refs"}) ? $cg->{"strict_refs"} : 0;
            $__psnap{"strict_subs"} = defined($cg->{"strict_subs"}) ? $cg->{"strict_subs"} : 0;
            $__psnap{"use_warnings"} = defined($cg->{"use_warnings"}) ? $cg->{"use_warnings"} : 0;
            $__psnap{"use_integer"} = defined($cg->{"use_integer"}) ? $cg->{"use_integer"} : 0;
            $__psnap{"use_utf8"} = defined($cg->{"use_utf8"}) ? $cg->{"use_utf8"} : 0;
            push(@{$cg->{"pragma_stack"}}, \%__psnap);
            return;
        }
        if (defined($mod) && $mod eq "__pragma_restore__") {
            if (defined($cg->{"pragma_stack"}) && scalar(@{$cg->{"pragma_stack"}}) > 0) {
                my scalar $__psnap = pop(@{$cg->{"pragma_stack"}});
                $cg->{"strict_vars"} = $__psnap->{"strict_vars"};
                $cg->{"strict_refs"} = $__psnap->{"strict_refs"};
                $cg->{"strict_subs"} = $__psnap->{"strict_subs"};
                $cg->{"use_warnings"} = $__psnap->{"use_warnings"};
                $cg->{"use_integer"} = $__psnap->{"use_integer"};
                $cg->{"use_utf8"} = $__psnap->{"use_utf8"};
            }
            return;
        }
        # `use vars qw(...)` is a compile-time pragma — its only effect is
        # registering the package-var names (done in Collect → our_vars).
        # It must NOT emit a runtime perla_require_module, which would
        # load/compile the real vars.pm at run time and hang init (Carp.pm's
        # `use vars` blocked the warnings-runtime path on a cold cache).
        if (defined($mod) && $mod eq "vars") {
            return;
        }
        # Register the package as "imported" so perla_code_get_walking
        # can prefer it for unqualified bareword sub calls. This makes
        # `use Encode; encode(...)` resolve to Encode::encode instead
        # of colliding with JSON::PP::encode etc.
        if (defined($mod) && length($mod) > 0
            && (!defined($node->{"is_no"}) || $node->{"is_no"} != 1)
            && $mod ne "integer" && $mod ne "strict" && $mod ne "warnings"
            && $mod ne "utf8" && $mod ne "feature" && $mod ne "lib"
            && $mod ne "constant" && $mod ne "vars" && $mod ne "subs"
            && $mod ne "overload" && $mod ne "base" && $mod ne "parent"
            && $mod ne "__isa__") {
            ind($cg); emit($cg, "perla_register_imported(\"" . $mod . "\");\n");
        }
        # `use integer` — Perl lexical pragma that switches `/` and a few
        # other ops to integer-truncating arithmetic. Perla doesn't track
        # the lexical scope, but flipping a `$cg->{"use_integer"}` flag at
        # the file scope is enough for the actually-affected modules
        # (DateTime::PP's _rd2ymd / _time_as_seconds / friends use it
        # heavily; without the flag, year/month/day come back fractional).
        if (defined($mod) && $mod eq "integer") {
            # `no integer;` toggles the flag back off; `use integer;` sets it.
            if (defined($node->{"is_no"}) && $node->{"is_no"} == 1) {
                $cg->{"use_integer"} = 0;
                ind($cg); emit($cg, "/* no integer; */\n");
            } else {
                $cg->{"use_integer"} = 1;
                ind($cg); emit($cg, "/* use integer; */\n");
            }
            return;
        }
        # `use bigint` / `no bigint` — route integer arithmetic through the
        # arbitrary-precision runtime (file-scope flag, same approach as
        # `use integer`; perla doesn't track the lexical scope).
        if (defined($mod) && ($mod eq "bigint" || $mod eq "bignum")) {
            if (defined($node->{"is_no"}) && $node->{"is_no"} == 1) {
                $cg->{"use_bigint"} = 0;
                ind($cg); emit($cg, "/* no bigint; */\n");
            } else {
                $cg->{"use_bigint"} = 1;
                ind($cg); emit($cg, "/* use bigint; */\n");
            }
            return;
        }
        # `use utf8;` — treat source string literals as char-oriented
        # (set SVf_UTF8 on each STR_LIT emit). Same file-scope-flag
        # pattern as `use integer`. Not strictly lexical, but covers
        # the typical "file header" usage. `use bytes;` clears the flag
        # to force byte-oriented ops on subsequent literals.
        if (defined($mod) && $mod eq "utf8") {
            if (defined($node->{"is_no"}) && $node->{"is_no"} == 1) {
                $cg->{"use_utf8"} = 0;
                ind($cg); emit($cg, "/* no utf8; */\n");
            } else {
                $cg->{"use_utf8"} = 1;
                ind($cg); emit($cg, "/* use utf8; */\n");
            }
            return;
        }
        if (defined($mod) && $mod eq "bytes") {
            if (defined($node->{"is_no"}) && $node->{"is_no"} == 1) {
                $cg->{"use_bytes"} = 0;
                ind($cg); emit($cg, "/* no bytes; */\n");
            } else {
                $cg->{"use_bytes"} = 1;
                ind($cg); emit($cg, "/* use bytes; */\n");
            }
            return;
        }
        # `use warnings;` — flip the runtime warning flag so the
        # `Argument "X" isn't numeric in OP (op)`, `"my" variable masks`,
        # and `untie attempted while N refs` emitters in perla_stash.c
        # actually print. `no warnings;` flips it back off. Subcategory
        # forms (`use warnings 'numeric';`) are accepted but treated as
        # global enable for now — perla doesn't track per-category state.
        if (defined($mod) && $mod eq "warnings") {
            if (defined($node->{"is_no"}) && $node->{"is_no"} == 1) {
                $cg->{"use_warnings"} = 0;
                ind($cg); emit($cg, "perla_warnings_active = 0;\n");
            } else {
                $cg->{"use_warnings"} = 1;
                ind($cg); emit($cg, "perla_warnings_active = 1;\n");
            }
            return;
        }
        # `use strict;` / `use strict 'vars';` / `use strict 'subs';` /
        # `use strict 'refs';` — flip the matching codegen flags.
        # Granular args are swallowed by the parser; we enforce all
        # three subsets when `use strict;` is in scope (the most
        # common case). `no strict;` toggles all three back off.
        if (defined($mod) && $mod eq "strict") {
            # Is this `use strict` the FILE's own (pragma-stack empty), or an
            # inlined dependency's (inside a __pragma_save__ bracket)? Only the
            # file's own determines the strict state for this module's hoisted
            # sub bodies (emitted after all statements). Inlined deps' strict
            # is restored by the brackets, but the LAST inlined `use strict`
            # before a bracket boundary can transiently leak into the final
            # strict_vars; sub bodies are emitted under that final value, which
            # caused nondeterministic "Global symbol $x requires explicit
            # package name" on no-strict modules that use a strict dependency.
            my int $__ps_depth = 0;
            if (defined($cg->{"pragma_stack"})) { $__ps_depth = scalar(@{$cg->{"pragma_stack"}}); }
            if (defined($node->{"is_no"}) && $node->{"is_no"} == 1) {
                $cg->{"strict_vars"} = 0;
                $cg->{"strict_subs"} = 0;
                $cg->{"strict_refs"} = 0;
                if ($__ps_depth == 0) { $cg->{"module_own_strict"} = 0; }
                ind($cg); emit($cg, "/* no strict; */\n");
            } else {
                $cg->{"strict_vars"} = 1;
                $cg->{"strict_subs"} = 1;
                $cg->{"strict_refs"} = 1;
                if ($__ps_depth == 0) { $cg->{"module_own_strict"} = 1; }
                ind($cg); emit($cg, "/* use strict; */\n");
            }
            return;
        }
        # `no MODULE [LIST];` — Perl semantics: BEGIN { require MODULE;
        # MODULE->unimport(LIST); }. The require side-effect is critical
        # — YAML::Mo's `extends` sub uses `eval "no $parent()"` as the
        # idiomatic way to load the parent class before assigning @ISA.
        # Treating `no MODULE` as a pure no-op left YAML::Loader::Base
        # unloaded, so YAML::Loader inherited from a phantom parent and
        # its `has`-installed accessors failed. We don't actually call
        # MODULE->unimport (most modules' unimport is a no-op for us
        # and calling it can trigger downstream load issues), but we
        # do need the require. perla_require_module short-circuits via
        # %INC if the module's already loaded, so this is a cheap probe.
        if (defined($node->{"is_no"}) && $node->{"is_no"} == 1) {
            if (length($mod) > 0) {
                ind($cg); emit($cg, "/* no " . $mod . "; */\n");
                ind($cg); emit($cg, "{ StradaValue *__nrm = strada_new_str(\"" . $mod . "\"); ");
                emit($cg, "StradaValue *__nrr = perla_require_module(__nrm); ");
                emit($cg, "if (__nrr) strada_decref(__nrr); strada_decref(__nrm); }\n");
            }
            return;
        }
        # `use mro 'c3'` / `use mro::c3` — switch the current package's
        # method resolution order to C3 (Dylan/Python). The flag lives
        # on the PerlStash and is consulted by perla_method_resolve.
        # The parser wraps this N_USE in a BEGIN so it hoists to file
        # init time (matching Perl's compile-time pragma semantic);
        # the package is captured at parse time on the node itself.
        if (defined($mod) && ($mod eq "mro" || $mod eq "mro::c3")) {
            my str $algo = "dfs";
            if ($mod eq "mro::c3") { $algo = "c3"; }
            if (defined($node->{"imports"})) {
                my scalar $imps = $node->{"imports"};
                if (ref($imps) eq "ARRAY") {
                    my int $ii = 0;
                    while ($ii < scalar(@{$imps})) {
                        my str $imp = "" . $imps->[$ii];
                        if ($imp eq "c3") { $algo = "c3"; }
                        elsif ($imp eq "dfs") { $algo = "dfs"; }
                        $ii++;
                    }
                }
            }
            my str $cur_pkg = "" . $cg->{"pkg"};
            if (defined($node->{"mro_pkg"})) { $cur_pkg = "" . $node->{"mro_pkg"}; }
            ind($cg); emit($cg, "perla_set_mro(\"" . $cur_pkg . "\", \"" . $algo . "\");\n");
            return;
        }
        # `use Time::HiRes` — flag so `time`/`sleep` codegen emits the
        # high-resolution variants (clock_gettime / nanosleep) when called
        # bare. Perl semantics: `use Time::HiRes qw(time sleep)` imports
        # subs that shadow built-ins for the rest of the file.
        if (defined($mod) && $mod eq "Time::HiRes") {
            $cg->{"use_hires"} = 1;
            # Don't return — fall through so the use statement still loads
            # the module (export list etc.). But codegen also notes the
            # flag for `time`/`sleep` dispatch below.
        }
        if (defined($mod) && $mod eq "__isa__") {
            # Generate @ISA push: perla_isa_push(pkg, parent).
            # `use base 'X'` / `use parent 'X'` semantics in Perl include
            # require X — without that, X's init never runs and the
            # parent's methods aren't in its stash. Then a method call
            # walks @ISA, finds X, looks up M in X's stash, gets NULL,
            # and dies "Can't locate object method M via package PKG".
            # Emit a perla_require_module fallback in addition to the
            # ISA push so the parent class is actually loaded.
            my str $isa_pkg = $node->{"pkg"};
            my str $isa_parent = $node->{"parent"};
            if (defined($isa_pkg) && defined($isa_parent)) {
                ind($cg); emit($cg, "perla_isa_push(\"" . $isa_pkg . "\", \"" . $isa_parent . "\");\n");
                # Allowlist of parent classes that need a runtime require
                # because the consumer relies on `use base` to also load
                # them (no separate `use X`). Broad fallback regressed
                # bizowie cold-cache build by triggering 64+ extra loads.
                my int $isa_needs_load = 0;
                if ($isa_parent eq "DateTime") { $isa_needs_load = 1; }
                if ($isa_needs_load == 1) {
                    ind($cg); emit($cg, "if (!perla_can(\"" . $isa_parent . "\", \"new\")) { ");
                    emit($cg, "StradaValue *__urm = strada_new_str(\"" . $isa_parent . "\"); ");
                    emit($cg, "StradaValue *__urr = perla_require_module(__urm); ");
                    emit($cg, "if (__urr) strada_decref(__urr); strada_decref(__urm); }\n");
                }
            }
        } else {
            if (defined($mod) && length($mod) > 0) {
                ind($cg); emit($cg, "/* use " . $mod . "; */\n");
                # Only mark %INC if the module was actually loaded at
                # compile time (inlined source OR precompiled .pm.o
                # statically linked). If we deferred to runtime require,
                # don't pre-mark %INC — runtime require's short-circuit
                # would skip the actual load.
                my int $loaded = 0;
                if (defined($node->{"loaded_at_compile"})) { $loaded = $node->{"loaded_at_compile"}; }
                if ($loaded == 1) {
                    ind($cg); emit($cg, "perla_mark_loaded(\"" . $mod . "\");\n");
                }
                # Call Moose->import() for every package that uses Moose
                my int $special = 0;
                if ($mod eq "Moose" || $mod eq "Any::Moose" || $mod eq "Mouse") {
                    # Any::Moose / Mouse — perla treats both as Moose
                    # synonyms (the runtime registers Any::Moose::import
                    # and Mouse::import as aliases for perla_moose_import).
                    # Without this synonym handling at compile time, Moose
                    # stubs (make_immutable, etc.) wouldn't be installed
                    # for packages using `use Any::Moose`. Surfaced via
                    # Business::Shipping which uses Any::Moose to be
                    # compatible with both Moose and Mouse environments.
                    ind($cg); emit($cg, "perla_init_moose_stubs();\n");
                    ind($cg); emit($cg, "perla_moose_import(NULL);\n");
                    # Track this package as a Moose class (skip direct dispatch)
                    $cg->{"moose_pkgs"}->{$cg->{"pkg"}} = 1;
                    $special = 1;
                }
                # `use Moose::Util::TypeConstraints` — export the type DSL
                # sugar (coerce/from/via/subtype/class_type/...) as no-op stubs
                # into the calling package so barewords like `from 'HashRef'`
                # don't fall through to an unrelated same-named sub. perla
                # neither enforces type constraints nor runs coercions.
                if ($mod eq "Moose::Util::TypeConstraints" || $mod eq "MooseX::Types::Moose"
                    || $mod eq "Mouse::Util::TypeConstraints") {
                    ind($cg); emit($cg, "perla_init_moose_stubs();\n");
                    ind($cg); emit($cg, "perla_moose_typeconstraints_import(NULL);\n");
                    $special = 1;
                }
                if ($mod eq "Moose::Role" || $mod eq "Any::Moose::Role" || $mod eq "Mouse::Role") {
                    ind($cg); emit($cg, "perla_init_moose_stubs();\n");
                    ind($cg); emit($cg, "perla_moose_role_import(NULL);\n");
                    $cg->{"moose_pkgs"}->{$cg->{"pkg"}} = 1;
                    $special = 1;
                }
                # Moo / Moo::Role — when the real Moo.pm.so is in the
                # search path, its own `import` overrides perla's
                # registered Moo::import (= perla_moose_import). Real
                # Moo's import drives Sub::Defer + _getglob + glob
                # assignment, which doesn't fully wire up accessors in
                # perla yet — `has X => (writer => 'Y')` for example
                # leaves `Y` un-installed. perla_moose_native_has handles
                # the same DSL surface (including writer/clearer/reader/
                # predicate as of 2026-05-06) directly. Always use
                # perla_moose_import for `use Moo` so the DSL works
                # consistently regardless of whether Moo.pm.so was
                # found and loaded as a transitive dep.
                if ($mod eq "Moo") {
                    ind($cg); emit($cg, "perla_init_moose_stubs();\n");
                    ind($cg); emit($cg, "perla_moose_import(NULL);\n");
                    $cg->{"moose_pkgs"}->{$cg->{"pkg"}} = 1;
                    $special = 1;
                }
                if ($mod eq "Moo::Role") {
                    ind($cg); emit($cg, "perla_init_moose_stubs();\n");
                    ind($cg); emit($cg, "perla_moose_role_import(NULL);\n");
                    $cg->{"moose_pkgs"}->{$cg->{"pkg"}} = 1;
                    $special = 1;
                }
                # Universal: emit Module->import($class, @args) dispatch so
                # import() subs actually run (e.g., Drogo::Dispatch injecting
                # @ISA and handler methods into the caller). Guarded by
                # perla_can so modules without import() don't warn. Skipped
                # for modules handled above and when the user wrote `use
                # Module ();` (explicit suppression).
                my int $suppress = 0;
                if (defined($node->{"suppress_import"}) && $node->{"suppress_import"} == 1) { $suppress = 1; }
                # `use Module ()` (with empty parens) suppresses the
                # import() call but MUST still require the module so its
                # init function runs (populating package variables and
                # registering subs). Without this, `use DBI::Const::GetInfoType ();`
                # would never load GetInfoType.pm — perla_hash_get for
                # %GetInfoType returns an empty stash slot, and DBIC's
                # _dbh_get_info croaks "Info type '...' not provided".
                if ($special == 0 && $suppress == 1 && $cg->{"module_mode"} == 0) {
                    ind($cg); emit($cg, "{ StradaValue *__urm = strada_new_str(\"" . $mod . "\"); ");
                    emit($cg, "StradaValue *__urr = perla_require_module(__urm); ");
                    emit($cg, "if (__urr) strada_decref(__urr); strada_decref(__urm); }\n");
                }
                if ($special == 0 && $suppress == 0) {
                    my scalar $import_args = $node->{"import_args"};
                    # Main-program-only: ensure the module is loaded
                    # before checking can("import"). When the .pm.o for
                    # M wasn't statically linked into the binary, M's
                    # init never ran and its import() isn't registered,
                    # so perla_can returns false and we silently skip
                    # the import — losing things like @ISA wiring from
                    # `use Drogo::Dispatch` in Abe::App.
                    #
                    # Skipped in module_mode (when compiling a .pm to
                    # .pm.so) because the generated init already calls
                    # dependency inits via dlsym/perla_require_module
                    # fallback (CodeGen line ~2287). Adding a
                    # require_module per use inside .pm.so init also
                    # triggers more transitive module loads at runtime
                    # which surface latent bugs in those modules.
                    if ($cg->{"module_mode"} == 0) {
                        ind($cg); emit($cg, "if (!perla_can(\"" . $mod . "\", \"import\")) { ");
                        emit($cg, "StradaValue *__urm = strada_new_str(\"" . $mod . "\"); ");
                        emit($cg, "StradaValue *__urr = perla_require_module(__urm); ");
                        emit($cg, "if (__urr) strada_decref(__urr); strada_decref(__urm); }\n");
                    } else {
                        # Module-mode allowlist: deps that have *no*
                        # precompiled .pm.o in the search path and whose
                        # init must run for the consuming .pm.so to work.
                        # Without these, transitive `use M` is silently
                        # skipped (perla_can returns false → import dispatch
                        # is gated false → require never happens), leaving
                        # M's package vars empty.
                        my int $needs_load = 0;
                        if ($mod eq "DateTime::Locale::Data") { $needs_load = 1; }
                        if ($mod eq "overload") { $needs_load = 1; }
                        # Drogo::Dispatch::import injects @ISA wiring +
                        # handler subs into the consumer; without
                        # require_module fallback at .pm.so init, it
                        # never runs and Abe::App's `r()` etc. fail.
                        if ($mod eq "Drogo::Dispatch") { $needs_load = 1; }
                        # YAML — Abe::App::Load uses `use YAML;` and calls
                        # YAML::Load(scalar) on a config file. Without the
                        # require fallback, YAML::Load isn't installed and
                        # config('dev') returns undef → DB creds default
                        # to OS user 'mflickin' (no password) → MySQL
                        # connect fails. With the fallback, MySQL connects
                        # using the bizowie_dev creds from conf/dev.conf.
                        if ($mod eq "YAML") { $needs_load = 1; }
                        # URI::Escape — exported as Exporter-based qw(uri_unescape).
                        # URI::_server's `use URI::Escape qw(uri_unescape);` needs
                        # URI::Escape loaded before the import-dispatch check, or
                        # uri_unescape never makes it into URI::_server's stash
                        # and `$u->host` returns undef (LWP/URI HTTP/HTTPS chain
                        # all blocked on this).
                        if ($mod eq "URI::Escape") { $needs_load = 1; }
                        if ($needs_load == 1) {
                            ind($cg); emit($cg, "if (!perla_can(\"" . $mod . "\", \"import\")) { ");
                            emit($cg, "StradaValue *__urm = strada_new_str(\"" . $mod . "\"); ");
                            emit($cg, "StradaValue *__urr = perla_require_module(__urm); ");
                            emit($cg, "if (__urr) strada_decref(__urr); strada_decref(__urm); }\n");
                        }
                    }
                    # Sub::Quote — re-register native quotify BEFORE the
                    # import dispatch runs, so when Sub::Quote's import
                    # copies `quotify` into the caller's stash, it copies
                    # OUR native impl instead of Sub::Quote's broken one.
                    if ($mod eq "Sub::Quote") {
                        ind($cg); emit($cg, "{ extern StradaValue *perla_sub_quote_quotify(StradaValue*); ");
                        emit($cg, "perla_code_set(\"Sub::Quote\", \"quotify\", strada_cpointer_new((void*)perla_sub_quote_quotify)); }\n");
                    }
                    # Build the import-args array and run the import
                    # UNCONDITIONALLY: if the module has its own `import`,
                    # dispatch it; otherwise (perla's native builtin shims
                    # — Carp, Data::Dumper, … register subs in their own
                    # stash but have no Exporter wiring) fall back to
                    # perla_exporter_import_pub, which copies the requested
                    # names into the caller's stash so `defined &main::NAME`
                    # / `->can` work, not just the cross-package call walk.
                    ind($cg); emit($cg, "{\n");
                    $cg->{"indent"} = $cg->{"indent"} + 1;
                    ind($cg); emit($cg, "StradaValue *__ia = strada_new_array();\n");
                    ind($cg); emit($cg, "StradaArray *__iav = strada_deref_array(__ia);\n");
                    ind($cg); emit($cg, "strada_array_push_take(__iav, strada_new_str(\"" . $mod . "\"));\n");
                    if (defined($import_args)) {
                        my int $ai = 0;
                        while ($ai < scalar(@{$import_args})) {
                            my scalar $iarg = $import_args->[$ai];
                            my int $iatype = $iarg->{"type"};
                            # qw(...), anon-array refs, and list-returning
                            # calls yield arrays that must be FLATTENED.
                            # Pushing them as single elements gives
                            # Exporter an arg list like ("YAML", [Load, Dump])
                            # instead of ("YAML", "Load", "Dump"), and
                            # Exporter then treats the array ref as one
                            # wanted symbol — ignoring Load/Dump entirely
                            # and leaving `use YAML qw(Load)` without an
                            # imported Load in main.
                            if ($iatype == Perla::AST::N_QWORD()
                                || $iatype == Perla::AST::N_ANON_ARRAY()
                                || $iatype == Perla::AST::N_CALL()
                                || $iatype == Perla::AST::N_METHOD()
                                || $iatype == Perla::AST::N_GREP()
                                || $iatype == Perla::AST::N_MAP()
                                || $iatype == Perla::AST::N_SORT()) {
                                # Import args are list context — set
                                # __perla_want_list=1 so parenthesized
                                # list expressions yield the full list,
                                # not just the last value (scalar context).
                                ind($cg); emit($cg, "{ int __sav_wl_iav = __perla_want_list; __perla_want_list = 1; StradaValue *__iav_v = ");
                                gen_expr($cg, $iarg);
                                emit($cg, "; __perla_want_list = __sav_wl_iav; ");
                                emit($cg, "if (__iav_v && !STRADA_IS_TAGGED_INT(__iav_v) && __iav_v->type == STRADA_ARRAY) { ");
                                emit($cg, "StradaArray *__iav_fa = __iav_v->value.av; ");
                                emit($cg, "for (size_t __iav_fi = 0; __iav_fi < __iav_fa->size; __iav_fi++) { StradaValue *__iav_e = __iav_fa->elements[__iav_fa->head + __iav_fi]; if (__iav_e) strada_incref(__iav_e); strada_array_push_take(__iav, __iav_e); } strada_decref(__iav_v); } ");
                                emit($cg, "else { strada_array_push_take(__iav, __iav_v); } }\n");
                            } else {
                                ind($cg); emit($cg, "strada_array_push_take(__iav, ");
                                gen_expr($cg, $iarg);
                                emit($cg, ");\n");
                            }
                            $ai++;
                        }
                    }
                    # Exporter::Tiny `-base` / `-extends` convention: `use
                    # SomeLib -base` makes the calling package inherit from
                    # SomeLib (Type::Library, Type::Tiny libraries, and many
                    # Exporter::Tiny consumers rely on this to get `meta`,
                    # `add_type`, etc.). perla's import dispatch doesn't wire
                    # this @ISA up on its own, so do it here. Real-world:
                    # `package Types::Standard; use Type::Library -base;` —
                    # without the @ISA push, `Types::Standard->meta` is
                    # unresolvable (undef), breaking every Type::Tiny library.
                    ind($cg); emit($cg, "for (size_t __bi = 0; __iav && __bi < __iav->size; __bi++) { StradaValue *__be = __iav->elements[__iav->head + __bi]; char *__bs = strada_to_str(__be); if (__bs && (strcmp(__bs, \"-base\") == 0 || strcmp(__bs, \"-extends\") == 0)) { perla_isa_push(\"" . $cg->{"pkg"} . "\", \"" . $mod . "\"); } if (__bs) free(__bs); }\n");
                    ind($cg); emit($cg, "StradaValue *__icls = strada_new_str(\"" . $mod . "\");\n");
                    # Set perla_use_caller_pkg so import handlers like
                    # perla_overload_import can find the right caller
                    # package even when call_stack is empty (module init
                    # context). Already routed correctly for Exporter via
                    # exporter_import; doing the same here is uniform.
                    #
                    # Also temporarily reset perla_call_depth to 0 across
                    # the dispatch. The .pm.so init runs without pushing
                    # its own frame, so the "current top" of the stack
                    # belongs to whatever subroutine triggered the
                    # dlopen → init chain — `caller()` inside import
                    # would return that subroutine's package instead of
                    # the consuming module's. Forcing depth=0 makes
                    # perla_caller(0) fall through to perla_use_caller_pkg
                    # (which we set to the consuming pkg), which matches
                    # Perl's `caller` semantics for `use Module`.
                    ind($cg); emit($cg, "extern const char *perla_use_caller_pkg;\n");
                    ind($cg); emit($cg, "extern int perla_call_depth;\n");
                    ind($cg); emit($cg, "const char *__sav_ucp = perla_use_caller_pkg;\n");
                    ind($cg); emit($cg, "int __sav_cd = perla_call_depth;\n");
                    # Forcing perla_call_depth=0 (below) makes the import's own
                    # perla_call_push calls (e.g. Sub::Exporter's
                    # default_installer chain) OVERWRITE the existing call-stack
                    # slots — including THIS module's own (init) frame. Restoring
                    # only the depth afterwards leaves those slots holding the
                    # import's stale frames, so a later `caller()` in this
                    # module's top-level code reads the wrong package (e.g.
                    # "Sub::Exporter" instead of the consuming module). Snapshot
                    # the soon-to-be-clobbered slots [0,__sav_cd) and restore
                    # their contents after the dispatch.
                    ind($cg); emit($cg, "PerlaCallFrame __sav_cf[256]; int __sav_nf = (__sav_cd < 256) ? __sav_cd : 256;\n");
                    ind($cg); emit($cg, "for (int __cfi = 0; __cfi < __sav_nf; __cfi++) __sav_cf[__cfi] = perla_call_stack[__cfi];\n");
                    ind($cg); emit($cg, "perla_use_caller_pkg = \"" . $cg->{"pkg"} . "\";\n");
                    ind($cg); emit($cg, "perla_call_depth = 0;\n");
                    ind($cg); emit($cg, "StradaValue *__ir = NULL;\n");
                    ind($cg); emit($cg, "if (perla_can(\"" . $mod . "\", \"import\")) {\n");
                    $cg->{"indent"} = $cg->{"indent"} + 1;
                    if ($cg->{"module_mode"} == 1) {
                        # In module_mode: wrap the import dispatch in eval.
                        # A CPAN module's import can die on conditions perla
                        # doesn't fully emulate (e.g. Sub::Exporter::Progressive
                        # croaks during DBIx::Class::ResultSource init). Without
                        # this guard the die propagates out of the .pm.so init
                        # function and the rest of init (including
                        # mk_group_accessors that installs class accessors)
                        # never runs.
                        ind($cg); emit($cg, "{ int __use_sav_wl = __perla_want_list; jmp_buf *__use_jb = STRADA_TRY_PUSH(); if (__use_jb && setjmp(*__use_jb) == 0) { __ir = perla_method_dispatch(__icls, \"import\", __ia); STRADA_TRY_POP(); } else { STRADA_TRY_POP(); __perla_want_list = __use_sav_wl; if (getenv(\"PERLA_TRACE_USE_DIE\")) fprintf(stderr, \"[use-import-die] " . $cg->{"pkg"} . " caught\\n\"); } }\n");
                    } else {
                        ind($cg); emit($cg, "__ir = perla_method_dispatch(__icls, \"import\", __ia);\n");
                    }
                    $cg->{"indent"} = $cg->{"indent"} - 1;
                    # No `import` of its own: promote the requested names
                    # from the module's own stash into the caller (covers
                    # native builtin shims with no Exporter wiring).
                    ind($cg); emit($cg, "} else {\n");
                    $cg->{"indent"} = $cg->{"indent"} + 1;
                    ind($cg); emit($cg, "extern StradaValue *perla_exporter_import_pub(StradaValue*);\n");
                    ind($cg); emit($cg, "__ir = perla_exporter_import_pub(__ia);\n");
                    $cg->{"indent"} = $cg->{"indent"} - 1;
                    ind($cg); emit($cg, "}\n");
                    ind($cg); emit($cg, "perla_call_depth = __sav_cd;\n");
                    ind($cg); emit($cg, "for (int __cfi2 = 0; __cfi2 < __sav_nf; __cfi2++) perla_call_stack[__cfi2] = __sav_cf[__cfi2];\n");
                    ind($cg); emit($cg, "perla_use_caller_pkg = __sav_ucp;\n");
                    ind($cg); emit($cg, "if (__ir) strada_decref(__ir);\n");
                    ind($cg); emit($cg, "strada_decref(__icls);\n");
                    ind($cg); emit($cg, "strada_decref(__ia);\n");
                    $cg->{"indent"} = $cg->{"indent"} - 1;
                    ind($cg); emit($cg, "}\n");
                }
            }
            # Sub::Quote — after the real Sub::Quote.pm.so has run its
            # init (which registers a buggy `quotify` whose ternary
            # classifier returns 'undef()' for non-undef strings under
            # perla), re-register `quotify` with our native impl. The
            # native version is registered in perla_init too but gets
            # overwritten when Sub::Quote.pm.so loads.
        }
        return;
    }
    if ($type == Perla::AST::N_PRECOMPILED_MOD()) {
        my str $init_func = $node->{"init_func"};
        my str $o_path = $node->{"o_path"};
        my str $so_path = defined($node->{"so_path"}) ? $node->{"so_path"} : ($o_path . ".so");
        my str $mod = $node->{"module"};
        my int $use_shared = defined($node->{"use_shared"}) ? $node->{"use_shared"} : 0;

        if ($use_shared == 1) {
            # --shared mode: dlopen the .pm.so at program startup and
            # invoke its init func via dlsym. Skips static linking of
            # the sibling .pm.o — smaller binary, dynamic loading.
            ind($cg); emit($cg, "/* precompiled (shared): " . $mod . " (" . $so_path . ") */\n");
            ind($cg); emit($cg, "{ void *__h = dlopen(\"" . Perla::CodeGen::Escape::escape_c_str($so_path) . "\", RTLD_NOW | RTLD_GLOBAL); ");
            emit($cg, "if (__h) { void (*__init)(void) = (void(*)(void))dlsym(__h, \"" . $init_func . "\"); if (__init) __init(); } ");
            emit($cg, "else if (perla_debug_mode()) fprintf(stderr, \"[shared] dlopen failed for %s: %s\\n\", \"" . Perla::CodeGen::Escape::escape_c_str($so_path) . "\", dlerror()); }\n");
            # Do NOT push $o_path to precompiled_objects — the .pm.so
            # is self-contained at runtime.
            return;
        }

        ind($cg); emit($cg, "/* precompiled: " . $mod . " (" . $o_path . ") */\n");

        if ($cg->{"module_mode"} == 1) {
            # Inside a module compilation: use dlsym to resolve the dependency init
            # at runtime, so we don't need link-time resolution between .o files.
            # If dlsym returns NULL (symbol not in the main binary because the
            # module graph wasn't statically linked — e.g. when this .pm.o is
            # loaded via runtime require under a `perla` binary rather than a
            # compiled-exe main program), fall back to perla_require_module so
            # the dependency still gets loaded. Without the fallback,
            # e.g. Drogo::Dispatch's init can't reach Drogo::Dispatcher, which
            # means e.g. Drogo::Dispatcher::r is never registered and
            # consuming apps fail at runtime with a missing method.
            ind($cg); emit($cg, "{ void (*__dep_init)(void) = (void(*)(void))dlsym(RTLD_DEFAULT, \"" . $init_func . "\"); ");
            emit($cg, "if (__dep_init) { __dep_init(); } ");
            emit($cg, "else { StradaValue *__m = strada_new_str(\"" . $mod . "\"); StradaValue *__r = perla_require_module(__m); if (__r) strada_decref(__r); strada_decref(__m); } }\n");
        } else {
            # Main program: direct call (will be resolved by linking the .o)
            ind($cg); emit($cg, $init_func . "();\n");
            # Track extern declaration needed
            if (!defined($cg->{"precompiled_externs"})) {
                $cg->{"precompiled_externs"} = [];
            }
            push(@{$cg->{"precompiled_externs"}}, "extern void " . $init_func . "(void);");
        }

        # Track the .o file for linking (both module and main program modes)
        if (!defined($cg->{"precompiled_objects"})) {
            $cg->{"precompiled_objects"} = [];
        }
        push(@{$cg->{"precompiled_objects"}}, $o_path);
        return;
    }
    if ($type == Perla::AST::N_IF() || $type == Perla::AST::N_UNLESS()) {
        _gen_if($cg, $node);
        return;
    }
    if ($type == Perla::AST::N_WHILE() || $type == Perla::AST::N_UNTIL()) {
        _gen_while($cg, $node);
        return;
    }
    if ($type == Perla::AST::N_FOREACH()) {
        _gen_foreach($cg, $node);
        return;
    }
    if ($type == Perla::AST::N_DO_WHILE()) {
        # Mark `in_loop` while generating the body so unlabeled
        # `last`/`next` inside emit `break;`/`continue;` and target the
        # C do-while. Real Perl errors out — "Can't 'last' outside a
        # loop block" — but perla previously fell to the warn-and-noop
        # branch and looped forever (the condition stayed truthy and the
        # warning-only `last` left the body running). Treating do-while
        # as a loop is a useful deviation from Perl and matches the
        # user's clear intent of breaking out.
        my int $__old_in_loop_dw = 0;
        if (defined($cg->{"in_loop"})) { $__old_in_loop_dw = $cg->{"in_loop"}; }
        $cg->{"in_loop"} = 1;
        # Detect body's top-level `my X` decls that shadow file-scope
        # vars; emit save before body, restore after. Mirror of the
        # eval-block / do-block / if-my fixes.
        my array @__dw_shadowed = ();
        if (defined($node->{"body"}) && defined($node->{"body"}->{"stmts"})) {
            my scalar $__dw_bstmts = $node->{"body"}->{"stmts"};
            my int $__dw_bsi = 0;
            while ($__dw_bsi < scalar(@{$__dw_bstmts})) {
                my scalar $__dw_bs = $__dw_bstmts->[$__dw_bsi];
                if (defined($__dw_bs) && $__dw_bs->{"type"} == Perla::AST::N_MY()) {
                    if (defined($__dw_bs->{"var"})) {
                        my str $__dw_vn = $__dw_bs->{"var"}->{"value"};
                        if (_is_file_scope($cg, $__dw_vn) == 1) {
                            my str $__dw_vt = "" . $__dw_bs->{"var"}->{"type"};
                            if (length($__dw_vt) == 0) { $__dw_vt = "SCALAR_VAR"; }
                            push(@__dw_shadowed, c_var_for_vtype($__dw_vt, $__dw_vn));
                        }
                    }
                    if (defined($__dw_bs->{"vars"})) {
                        my int $__dw_dvi = 0;
                        while ($__dw_dvi < scalar(@{$__dw_bs->{"vars"}})) {
                            my scalar $__dw_dv = $__dw_bs->{"vars"}->[$__dw_dvi];
                            my str $__dw_dvn = $__dw_dv->{"value"};
                            if (_is_file_scope($cg, $__dw_dvn) == 1) {
                                my str $__dw_dvt = "" . $__dw_dv->{"type"};
                                if (length($__dw_dvt) == 0) { $__dw_dvt = "SCALAR_VAR"; }
                                push(@__dw_shadowed, c_var_for_vtype($__dw_dvt, $__dw_dvn));
                            }
                            $__dw_dvi = $__dw_dvi + 1;
                        }
                    }
                }
                $__dw_bsi = $__dw_bsi + 1;
            }
        }
        if (scalar(@__dw_shadowed) > 0) {
            ind($cg); emit($cg, "{\n");
            $cg->{"indent"} = $cg->{"indent"} + 1;
            my int $__dw_shi = 0;
            while ($__dw_shi < scalar(@__dw_shadowed)) {
                my str $__dw_shc = $__dw_shadowed[$__dw_shi];
                ind($cg); emit($cg, "StradaValue *__dw_sav_" . $__dw_shc . " = " . $__dw_shc . "; " . $__dw_shc . " = NULL;\n");
                $__dw_shi = $__dw_shi + 1;
            }
        }
        ind($cg); emit($cg, "do {\n");
        $cg->{"indent"} = $cg->{"indent"} + 1;
        gen_block_stmts($cg, $node->{"body"});
        $cg->{"indent"} = $cg->{"indent"} - 1;
        ind($cg);
        if (defined($node->{"negate"}) && $node->{"negate"} == 1) {
            emit($cg, "} while (!(");
            _gen_cond($cg, $node->{"cond"});
            emit($cg, "));\n");
        } else {
            emit($cg, "} while (");
            _gen_cond($cg, $node->{"cond"});
            emit($cg, ");\n");
        }
        # Close do-while shadow wrap (mirror of the open above).
        if (scalar(@__dw_shadowed) > 0) {
            my int $__dw_rsi = 0;
            while ($__dw_rsi < scalar(@__dw_shadowed)) {
                my str $__dw_rsc = $__dw_shadowed[$__dw_rsi];
                ind($cg); emit($cg, "if (" . $__dw_rsc . ") strada_decref(" . $__dw_rsc . "); " . $__dw_rsc . " = __dw_sav_" . $__dw_rsc . ";\n");
                $__dw_rsi = $__dw_rsi + 1;
            }
            $cg->{"indent"} = $cg->{"indent"} - 1;
            ind($cg); emit($cg, "}\n");
        }
        $cg->{"in_loop"} = $__old_in_loop_dw;
        return;
    }
    if ($type == Perla::AST::N_FOR_C()) {
        _gen_for_c($cg, $node);
        return;
    }
    if ($type == Perla::AST::N_GOTO_LABEL()) {
        # `goto LABEL` — bareword label jump. Emit a C goto to the
        # synthesized C label that N_LABEL_STMT introduces. C goto
        # has function-local scope only; perl's goto across-sub jumps
        # aren't supported (rare and a hack even in perl).
        my str $lbl = "" . $node->{"label"};
        ind($cg); emit($cg, "goto __perla_label_" . safe_ident($lbl) . ";\n");
        return;
    }
    if ($type == Perla::AST::N_LABEL_STMT()) {
        # Free-standing `LABEL:` — emit as a C label followed by a
        # no-op statement (C requires a statement after a label).
        my str $lbl2 = "" . $node->{"label"};
        ind($cg); emit($cg, "__perla_label_" . safe_ident($lbl2) . ": (void)0;\n");
        return;
    }
    if ($type == Perla::AST::N_FORMAT()) {
        # format NAME = ... . — register the format body with the
        # runtime so `write [HANDLE]` can interpret it. Picture
        # interpretation happens at write-time.
        #
        # Lexical bridge: file-scope `my $x` references in value lines
        # can't be reached by the runtime (which uses perla_scalar_get
        # → stash lookup). To bridge them, we (1) scan value lines for
        # `$IDENT` references, (2) rewrite each lexical reference to a
        # mangled name (`$__perla_lex_NAME`), (3) emit a static sync
        # function that copies the C-side `v_NAME` into the stash under
        # the mangled name before each write, and (4) register that
        # sync function with the runtime so it fires on every write
        # (including $~-overridden formats with the same name).
        my str $fnm = "" . $node->{"name"};
        my str $fbody = "" . $node->{"body"};
        # Collect both file/block-scope lex refs (handled by the
        # static sync helper) AND sub-local lex refs (handled by
        # inline sync emitted at the write call-site).
        my array @fmt_lex_refs = Perla::CodeGen::Method::_collect_format_lex_refs($cg, $fbody);
        my array @fmt_sub_lex_refs = Perla::CodeGen::Method::_collect_format_sub_lex_refs($cg, $fbody);
        my array @fmt_all_refs = (@fmt_lex_refs);
        my int $sri = 0;
        while ($sri < scalar(@fmt_sub_lex_refs)) {
            push(@fmt_all_refs, $fmt_sub_lex_refs[$sri]);
            $sri = $sri + 1;
        }
        my str $rewritten = Perla::CodeGen::Method::_rewrite_format_body_for_lex($fbody, \@fmt_all_refs);
        my str $fbody_esc = Perla::CodeGen::Escape::escape_c_str($rewritten);
        my int $nrefs = scalar(@fmt_lex_refs);
        my int $nsub_refs = scalar(@fmt_sub_lex_refs);
        # Sub-local refs need inline sync at every write site (the
        # vars are on the C stack; can't be `extern`'d from a file-
        # scope helper). Record the ref list keyed by format name.
        if ($nsub_refs > 0) {
            if (!defined($cg->{"format_sub_lex_refs"})) { $cg->{"format_sub_lex_refs"} = {}; }
            $cg->{"format_sub_lex_refs"}->{$fnm} = \@fmt_sub_lex_refs;
        }
        if ($nrefs > 0) {
            my str $sync_name = "__perla_fmt_sync_" . safe_ident($fnm);
            # Emit the static sync function. Hoist into a deferred buffer
            # so the static-def appears at file scope (not inside main()).
            if (!defined($cg->{"format_sync_defs"})) {
                $cg->{"format_sync_defs"} = "";
            }
            $cg->{"format_sync_defs"} = $cg->{"format_sync_defs"}
                . "static void " . $sync_name . "(void) {\n";
            my int $li = 0;
            while ($li < $nrefs) {
                my str $lname = "" . $fmt_lex_refs[$li];
                my str $cvar = "v_" . safe_ident($lname);
                $cg->{"format_sync_defs"} = $cg->{"format_sync_defs"}
                    . "    if (" . $cvar . ") perla_scalar_set(\"main\", \"__perla_lex_"
                    . $lname . "\", " . $cvar . ");\n";
                $li = $li + 1;
            }
            $cg->{"format_sync_defs"} = $cg->{"format_sync_defs"} . "}\n";
            ind($cg); emit($cg, "perla_register_format(\"" . $fnm . "\", \"" . $fbody_esc . "\");\n");
            ind($cg); emit($cg, "perla_register_format_sync(\"" . $fnm . "\", " . $sync_name . ");\n");
        } else {
            ind($cg); emit($cg, "perla_register_format(\"" . $fnm . "\", \"" . $fbody_esc . "\");\n");
        }
        return;
    }
    if ($type == Perla::AST::N_WRITE()) {
        my str $whn = "" . $node->{"handle"};
        # Inline sync for sub-local lex refs captured by formats — the
        # file-scope sync helper can't `extern` stack-allocated lexicals,
        # so each write site copies the current scope's `v_NAME` value
        # into the mangled stash slot before the runtime reads it. The
        # name lookup is keyed on the static `write FH` handle name; $~
        # overrides won't pick up the inline-synced values, but the
        # static helper still fires from inside perla_write_format for
        # file-scope refs in that case.
        if (defined($cg->{"format_sub_lex_refs"})
            && defined($cg->{"format_sub_lex_refs"}->{$whn})) {
            my scalar $subrefs = $cg->{"format_sub_lex_refs"}->{$whn};
            my int $sli = 0;
            while ($sli < scalar(@{$subrefs})) {
                my str $lname = "" . $subrefs->[$sli];
                my str $cvar = "v_" . safe_ident($lname);
                ind($cg); emit($cg, "if (" . $cvar . ") perla_scalar_set(\"main\", \"__perla_lex_" . $lname . "\", " . $cvar . ");\n");
                $sli = $sli + 1;
            }
        }
        # `write $fh;` — scalar-var holding a filehandle. Route to the
        # _to_fh variant so the runtime picks up the FH directly
        # without going through stash lookup by name.
        if (defined($node->{"fh_expr"})) {
            ind($cg); emit($cg, "perla_write_format_to_fh(");
            gen_expr($cg, $node->{"fh_expr"});
            emit($cg, ");\n");
            return;
        }
        ind($cg); emit($cg, "perla_write_format(\"" . $whn . "\");\n");
        return;
    }
    if ($type == Perla::AST::N_GOTO_SUB()) {
        # goto &EXPR — tail call that replaces the current call frame so
        # caller() inside EXPR sees the invoker of the current sub, not
        # the sub itself. Emit: pop the current call frame, then call EXPR
        # with the current @_, and return its result. Semantically
        # equivalent to Perl's goto &sub for the common "goto at end of
        # wrapper" idiom. Not a true stack-frame swap, but matches the
        # observable behavior of caller() and the return value.
        ind($cg); emit($cg, "{\n");
        $cg->{"indent"} = $cg->{"indent"} + 1;
        ind($cg); emit($cg, "StradaValue *__gt_fn = ");
        gen_expr($cg, $node->{"target"});
        emit($cg, ";\n");
        # `goto &$name` where $name is a bareword: Perl resolves the
        # name relative to the CURRENT package (i.e., AUTOLOAD's package
        # for the typical install-then-goto pattern). We must look up
        # the sub BEFORE perla_call_pop drops this frame — afterward,
        # `caller_pkg` is the invoker, not us.
        ind($cg); emit($cg, "if (__gt_fn && !STRADA_IS_TAGGED_INT(__gt_fn) && __gt_fn->type == STRADA_STR && __gt_fn->value.pv && !strstr(__gt_fn->value.pv, \"::\")) { ");
        emit($cg, "StradaValue *__gt_resolved = perla_code_get(\"" . $cg->{"pkg"} . "\", __gt_fn->value.pv); ");
        emit($cg, "if (__gt_resolved && !STRADA_IS_TAGGED_INT(__gt_resolved)) { strada_incref(__gt_resolved); strada_decref(__gt_fn); __gt_fn = __gt_resolved; } }\n");
        ind($cg); emit($cg, "if (__perla_local_chain != __perla_local_chain_mark) { perla_local_chain_restore_to(__perla_local_chain, __perla_local_chain_mark); __perla_local_chain = __perla_local_chain_mark; }\n");
        ind($cg); emit($cg, "perla_call_pop();  /* goto &: drop current frame so caller() reports invoker */\n");
        ind($cg); emit($cg, "StradaValue *__gt_ret = perla_call_code(__gt_fn, perla_at_);\n");
        # Drain ONLY this frame's cleanup entries (those pushed since entry).
        # A bare strada_cleanup_drain() drains the WHOLE stack to 0, which
        # decrefs the CALLER's still-live locals — e.g. `$self` in a method
        # that tail-calls `goto &other` (Path::Tiny::_path -> goto &_pathify
        # over-decref'd the invocant, freeing it out from under the caller).
        ind($cg); emit($cg, "strada_cleanup_drain_to(__perla_cleanup_mark);\n");
        ind($cg); emit($cg, "return __gt_ret;\n");
        $cg->{"indent"} = $cg->{"indent"} - 1;
        ind($cg); emit($cg, "}\n");
        return;
    }
    if ($type == Perla::AST::N_RETURN()) {
        # `return EXPR` inside `eval { ... }` or `try { ... }` returns
        # from that block (setting its value) rather than from the
        # enclosing sub. The wrapper sets eval_block_expr_active=1 and
        # emits a do { ... } while(0) around the body so we can break.
        # The result-var name lives in `eval_block_result_var` (defaults
        # to "__ev_val" for eval, overridden to "__try_result" for try).
        if (defined($cg->{"eval_block_expr_active"}) && $cg->{"eval_block_expr_active"} >= 1) {
            my str $resv = "__ev_val";
            if (defined($cg->{"eval_block_result_var"}) && length("" . $cg->{"eval_block_result_var"}) > 0) {
                $resv = "" . $cg->{"eval_block_result_var"};
            }
            # Use a labeled goto (set by the eval-block wrapper) so `last`/
            # `next` inside the eval still target the enclosing loop. `break`
            # would otherwise be caught by the do-while(0) and never reach
            # the outer loop. Fall back to `break` only when no label set —
            # try/catch and the older expression-form eval still use that.
            my str $ev_label = "";
            if (defined($cg->{"eval_block_return_label"})) { $ev_label = "" . $cg->{"eval_block_return_label"}; }
            my str $exit_stmt = length($ev_label) > 0 ? ("goto " . $ev_label . ";") : "break;";
            ind($cg);
            if (defined($node->{"value"})) {
                emit($cg, "{ " . $resv . " = ");
                gen_expr($cg, $node->{"value"});
                emit($cg, "; if (" . $resv . ") strada_incref(" . $resv . "); " . $exit_stmt . " }\n");
            } else {
                emit($cg, "{ " . $resv . " = NULL; " . $exit_stmt . " }\n");
            }
            return;
        }
        # Skip return at module init level (leaked sub body)
        if ($cg->{"in_sub"} != 1) {
            ind($cg); emit($cg, "/* skipped: return at module init level */\n");
            return;
        }
        # Detect the shape of the return expression so we can reduce to a
        # Perl-correct scalar value when the caller is in scalar context.
        # In Perl:
        #   return (1, 2, 99);  in scalar = 99 (comma op last-value)
        #   return @arr;        in scalar = scalar(@arr) (size)
        # Without this, my $s = func() always saw the whole array, which
        # broke YAML::Load's scalar-context semantics.
        my int $reduce_last = 0;   # AST is a list literal — take last element
        my int $reduce_size = 0;   # AST is an @array — take size
        if (defined($node->{"value"})) {
            my int $vt = $node->{"value"}->{"type"};
            if ($vt == Perla::AST::N_ANON_ARRAY()) {
                my int $isref = 0;
                if (defined($node->{"value"}->{"is_ref"})) {
                    $isref = $node->{"value"}->{"is_ref"};
                }
                if ($isref == 0) { $reduce_last = 1; }
            } elsif ($vt == Perla::AST::N_ARRAY_VAR()) {
                $reduce_size = 1;
            }
        }
        # caller() line propagation for `return EXPR` where EXPR is a
        # call/method — set perla_pending_call_line so the callee's
        # perla_call_push records the call-site line for caller(0).
        if (defined($node->{"value"})) {
            my int $__rv_type = $node->{"value"}->{"type"};
            if ($__rv_type == Perla::AST::N_CALL() || $__rv_type == Perla::AST::N_METHOD()) {
                my int $__rv_line = $node->{"value"}->{"line"} + 0;
                if ($__rv_line > 0) {
                    ind($cg); emit($cg, "perla_pending_call_line = " . $__rv_line . ";\n");
                }
            }
        }
        # If we have local vars, eval return expr, restore locals, then return
        if (defined($cg->{"local_vars"}) && scalar(keys(%{$cg->{"local_vars"}})) > 0) {
            # Restore caller's wantarray context before evaluating EXPR.
            # Perl: `return EXPR` evaluates EXPR in the caller's context, but
            # perla's intermediate code in the function body may have left
            # __perla_want_list mutated (e.g., a save/restore that's outdated).
            # Without resetting, chained method calls (e.g. `return $self->method(...)`)
            # see the WRONG context. Concrete failure: YAML::Loader::_parse's
            # `return wantarray ? @docs : $docs[-1]` picks list branch in
            # bizowie's deep call chain, returning an arrayref instead of last doc.
            ind($cg); emit($cg, "__perla_want_list = __perla_caller_want_list;\n");
            # Skip the return-value incref when the return EXPR is already
            # owned (literal, call result, anon constructor, etc.). The
            # incref is only needed for borrowed reads (variables, array
            # elements) where param/local cleanup below would otherwise
            # decref the value to 0 before the caller sees it. Matches
            # strada's return_needs_incref pattern; without this every
            # chained method call doubled the result's refcount.
            my int $__rv_needs_incref = 1;
            if (defined($node->{"value"})) {
                $__rv_needs_incref = expr_is_borrowed($node->{"value"});
                # `return bless $self, $class`: bless is transparent
                # (rc+0), so the returned ref shares the refcount of its
                # first arg. If that arg is a borrowed value (variable
                # whose scope-cleanup decref is about to fire), the
                # caller's copy will be freed underneath them. Mirror
                # the arg's borrowed-ness to bless itself. If the bless
                # arg is a fresh literal / anon constructor (rc=1 owned),
                # leave $__rv_needs_incref at 0 — adding incref here
                # would leak a permanent ref past DESTROY-at-scope-exit.
                if ($__rv_needs_incref == 0
                    && $node->{"value"}->{"type"} == Perla::AST::N_CALL()
                    && defined($node->{"value"}->{"name"})
                    && ($node->{"value"}->{"name"} eq "bless"
                        || $node->{"value"}->{"name"} eq "CORE::bless")) {
                    my scalar $__rv_bless_args = $node->{"value"}->{"args"};
                    if (defined($__rv_bless_args)
                        && scalar(@{$__rv_bless_args}) >= 1
                        && expr_is_borrowed($__rv_bless_args->[0]) == 1) {
                        $__rv_needs_incref = 1;
                    }
                }
            } else {
                $__rv_needs_incref = 0;
            }
            ind($cg); emit($cg, "{ StradaValue *__ret_val = ");
            if (defined($node->{"value"})) {
                gen_expr($cg, $node->{"value"});
            } else {
                # `return;` context-sensitive — see other branch.
                emit($cg, "(__perla_caller_want_list ? strada_new_array() : strada_new_undef())");
            }
            emit($cg, ";\n");
            # Incref BEFORE the scalar-conversion checks. When the return
            # value is a borrowed variable (e.g. `return @list` where
            # @list is a file-scope my), the conversion's
            # `strada_decref(__ret_val); __ret_val = TAGGED_INT(size)`
            # would drop the variable's refcount to 0 and free it. The
            # caller's count was correct but the file-scope @list was
            # destroyed — subsequent calls returned a dangling pointer.
            # With the incref moved up, the conversion's decref balances
            # the extra ref instead of consuming the variable's last
            # one.
            if ($__rv_needs_incref == 1) {
                ind($cg); emit($cg, "if (__ret_val) strada_incref(__ret_val);\n");
            }
            if ($reduce_last == 1) {
                ind($cg); emit($cg, "if (!__perla_caller_want_list && __ret_val && !STRADA_IS_TAGGED_INT(__ret_val) && __ret_val->type == STRADA_ARRAY) { StradaArray *__rrav = strada_deref_array(__ret_val); StradaValue *__rrlast = (__rrav && __rrav->size > 0) ? __rrav->elements[__rrav->head + __rrav->size - 1] : strada_new_undef(); strada_incref(__rrlast); strada_decref(__ret_val); __ret_val = __rrlast; }\n");
            } elsif ($reduce_size == 1) {
                ind($cg); emit($cg, "if (!__perla_caller_want_list && __ret_val && !STRADA_IS_TAGGED_INT(__ret_val) && __ret_val->type == STRADA_ARRAY) { StradaArray *__rrav = strada_deref_array(__ret_val); int64_t __rrsz = __rrav ? (int64_t)__rrav->size : 0; strada_decref(__ret_val); __ret_val = STRADA_MAKE_TAGGED_INT(__rrsz); }\n");
            }
            # Scalar-context return of a HASH → entry count. Perl's
            # `return %h` in scalar context yields keycount (or "k/n"
            # historical form). Without this `my $y = func()` got the
            # full hash StradaValue, printed as ARRAY-stringification.
            ind($cg); emit($cg, "if (!__perla_caller_want_list && __ret_val && !STRADA_IS_TAGGED_INT(__ret_val) && __ret_val->type == STRADA_HASH) { StradaHash *__rrhv = strada_deref_hash(__ret_val); int64_t __rrhn = __rrhv ? (int64_t)__rrhv->num_entries : 0; strada_decref(__ret_val); __ret_val = STRADA_MAKE_TAGGED_INT(__rrhn); }\n");
            my array @lv = keys(%{$cg->{"local_vars"}});
            my int $li = 0;
            while ($li < scalar(@lv)) {
                my str $lvt = "" . $cg->{"local_vars"}->{$lv[$li]};
                if (length($lvt) == 0 || $lvt eq "1") { $lvt = "SCALAR_VAR"; }
                ind($cg); emit($cg, c_var_for_vtype($lvt, $lv[$li]) . " = __local_save_" . safe_ident($lv[$li]) . ";\n");
                $li++;
            }
            ind($cg);
            emit($cg, "strada_cleanup_drain_to(__perla_cleanup_mark); ");
            # Sub-local scalar `my` cleanup at explicit return — fires
            # DESTROY for blessed objs that would otherwise persist in
            # the file-scope C static across calls. List is collected
            # in gen_sub_def (see Subs.strada).
            if (defined($cg->{"sub_local_scalars"})) {
                my scalar $__rsl_arr = $cg->{"sub_local_scalars"};
                my int $__rsl_i = 0;
                while ($__rsl_i < scalar(@{$__rsl_arr})) {
                    my str $__rsl_vn = c_var($__rsl_arr->[$__rsl_i]);
                    emit($cg, "if (" . $__rsl_vn . ") { strada_decref(" . $__rsl_vn . "); " . $__rsl_vn . " = NULL; } ");
                    $__rsl_i = $__rsl_i + 1;
                }
            }
            Perla::CodeGen::Subs::emit_sub_local_agg_cleanup($cg, $cg->{"sub_local_aggregates"});
            emit($cg, "if (__perla_local_chain != __perla_local_chain_mark) { perla_local_chain_restore_to(__perla_local_chain, __perla_local_chain_mark); __perla_local_chain = __perla_local_chain_mark; } perla_call_pop(); return __ret_val; }\n");
        } else {
            # Same expr_is_borrowed check as the local-vars branch above.
            my int $__rv_needs_incref2 = 1;
            if (defined($node->{"value"})) {
                $__rv_needs_incref2 = expr_is_borrowed($node->{"value"});
                # bless special case — see comment in the local-vars branch.
                if ($__rv_needs_incref2 == 0
                    && $node->{"value"}->{"type"} == Perla::AST::N_CALL()
                    && defined($node->{"value"}->{"name"})
                    && ($node->{"value"}->{"name"} eq "bless"
                        || $node->{"value"}->{"name"} eq "CORE::bless")) {
                    my scalar $__rv_bless_args2 = $node->{"value"}->{"args"};
                    if (defined($__rv_bless_args2)
                        && scalar(@{$__rv_bless_args2}) >= 1
                        && expr_is_borrowed($__rv_bless_args2->[0]) == 1) {
                        $__rv_needs_incref2 = 1;
                    }
                }
            } else {
                $__rv_needs_incref2 = 0;
            }
            # Restore caller's wantarray context — see comment in the
            # local-vars branch above.
            ind($cg); emit($cg, "__perla_want_list = __perla_caller_want_list;\n");
            ind($cg); emit($cg, "{ StradaValue *__ret_val = ");
            if (defined($node->{"value"})) {
                gen_expr($cg, $node->{"value"});
            } else {
                # `return;` in list context returns empty list (); in
                # scalar context returns undef. Use caller's want-list
                # to pick. Without this, `my @r = bare_return_sub()`
                # got @r=(undef) — one element — instead of @r=().
                emit($cg, "(__perla_caller_want_list ? strada_new_array() : strada_new_undef())");
            }
            emit($cg, ";");
            # Incref BEFORE the scalar-conversion checks (see comment
            # in the parallel local-vars branch above). For borrowed
            # values like file-scope @list, the conversion's decref
            # would drop the variable's refcount to 0 otherwise.
            if ($__rv_needs_incref2 == 1) {
                emit($cg, " if (__ret_val) strada_incref(__ret_val);");
            }
            if ($reduce_last == 1) {
                emit($cg, " if (!__perla_caller_want_list && __ret_val && !STRADA_IS_TAGGED_INT(__ret_val) && __ret_val->type == STRADA_ARRAY) { StradaArray *__rrav = strada_deref_array(__ret_val); StradaValue *__rrlast = (__rrav && __rrav->size > 0) ? __rrav->elements[__rrav->head + __rrav->size - 1] : strada_new_undef(); strada_incref(__rrlast); strada_decref(__ret_val); __ret_val = __rrlast; }");
            } elsif ($reduce_size == 1) {
                emit($cg, " if (!__perla_caller_want_list && __ret_val && !STRADA_IS_TAGGED_INT(__ret_val) && __ret_val->type == STRADA_ARRAY) { StradaArray *__rrav = strada_deref_array(__ret_val); int64_t __rrsz = __rrav ? (int64_t)__rrav->size : 0; strada_decref(__ret_val); __ret_val = STRADA_MAKE_TAGGED_INT(__rrsz); }");
            }
            # Scalar-context return of HASH → entry count (see comment
            # in the local-vars branch above).
            emit($cg, " if (!__perla_caller_want_list && __ret_val && !STRADA_IS_TAGGED_INT(__ret_val) && __ret_val->type == STRADA_HASH) { StradaHash *__rrhv = strada_deref_hash(__ret_val); int64_t __rrhn = __rrhv ? (int64_t)__rrhv->num_entries : 0; strada_decref(__ret_val); __ret_val = STRADA_MAKE_TAGGED_INT(__rrhn); }");
            emit($cg, " strada_cleanup_drain_to(__perla_cleanup_mark);");
            # Sub-local scalar cleanup (no-local-vars branch — see
            # parallel branch above).
            if (defined($cg->{"sub_local_scalars"})) {
                my scalar $__rsl2_arr = $cg->{"sub_local_scalars"};
                my int $__rsl2_i = 0;
                while ($__rsl2_i < scalar(@{$__rsl2_arr})) {
                    my str $__rsl2_vn = c_var($__rsl2_arr->[$__rsl2_i]);
                    emit($cg, " if (" . $__rsl2_vn . ") { strada_decref(" . $__rsl2_vn . "); " . $__rsl2_vn . " = NULL; }");
                    $__rsl2_i = $__rsl2_i + 1;
                }
            }
            emit($cg, " "); Perla::CodeGen::Subs::emit_sub_local_agg_cleanup($cg, $cg->{"sub_local_aggregates"});
            emit($cg, " if (__perla_local_chain != __perla_local_chain_mark) { perla_local_chain_restore_to(__perla_local_chain, __perla_local_chain_mark); __perla_local_chain = __perla_local_chain_mark; } perla_call_pop(); return __ret_val; }\n");
        }
        return;
    }
    if ($type == Perla::AST::N_LAST()) {
        my int $_in_loop = 0;
        if (defined($cg->{"in_loop"}) && $cg->{"in_loop"} == 1) { $_in_loop = 1; }
        if (defined($node->{"label"})) {
            my str $ul = $cg->{"label_map"}->{$node->{"label"}};
            if (length($ul) > 0) {
                ind($cg); emit($cg, "goto __perla_end_" . $ul . ";\n");
            } elsif ($_in_loop == 1) {
                ind($cg); emit($cg, "break; /* last " . $node->{"label"} . " */\n");
            } else {
                # Match Perl: `last LABEL` with no matching loop dies.
                ind($cg); emit($cg, "strada_die(\"%s\", \"Label not found for \\\"last " . $node->{"label"} . "\\\"\");\n");
            }
        } elsif ($_in_loop == 1) {
            ind($cg); emit($cg, "break;\n");
        } else {
            # Lexical analysis says no enclosing loop, but the sub may be
            # called from inside a loop dynamically (Perl's `last` does
            # propagate up the call stack). Without a runtime loop-frame
            # tracking system we can't safely break, but dying here is
            # too aggressive — Perl programs commonly use this pattern.
            # Compromise: warn once at runtime and treat as no-op so
            # execution continues.
            ind($cg); emit($cg, "fprintf(stderr, \"Warning: \\\"last\\\" outside a loop block (perla: treated as no-op)\\n\");\n");
        }
        return;
    }
    if ($type == Perla::AST::N_NEXT()) {
        my int $_in_loop_n = 0;
        if (defined($cg->{"in_loop"}) && $cg->{"in_loop"} == 1) { $_in_loop_n = 1; }
        if (defined($node->{"label"})) {
            my str $ul = $cg->{"label_map"}->{$node->{"label"}};
            if (length($ul) > 0) {
                ind($cg); emit($cg, "goto __perla_next_" . $ul . ";\n");
            } elsif ($_in_loop_n == 1) {
                # Label not in map — fall back to continue (innermost loop)
                ind($cg); emit($cg, "continue; /* next " . $node->{"label"} . " */\n");
            } else {
                ind($cg); emit($cg, "strada_die(\"%s\", \"Label not found for \\\"next " . $node->{"label"} . "\\\"\");\n");
            }
        } elsif ($cg->{"in_for_c"} == 1) {
            ind($cg); emit($cg, "goto " . $cg->{"for_step_label"} . ";\n");
        } elsif ($_in_loop_n == 1) {
            # If the enclosing loop has a perla continue block, use the
            # synthetic next-label so we run that block before the next
            # iteration. Otherwise plain C continue is fine.
            my str $__nx_lbl = "";
            if (defined($cg->{"current_next_label"})) { $__nx_lbl = "" . $cg->{"current_next_label"}; }
            if (length($__nx_lbl) > 0) {
                ind($cg); emit($cg, "goto " . $__nx_lbl . ";\n");
            } else {
                ind($cg); emit($cg, "continue;\n");
            }
        } else {
            # See N_LAST comment — warn-and-noop instead of die.
            ind($cg); emit($cg, "fprintf(stderr, \"Warning: \\\"next\\\" outside a loop block (perla: treated as no-op)\\n\");\n");
        }
        return;
    }
    if ($type == Perla::AST::N_REDO()) {
        if (defined($node->{"label"})) {
            my str $ul = $cg->{"label_map"}->{$node->{"label"}};
            if (length($ul) == 0) {
                ind($cg); emit($cg, "strada_die(\"%s\", \"Label not found for \\\"redo " . $node->{"label"} . "\\\"\");\n");
            } else {
                ind($cg); emit($cg, "goto __perla_redo_" . $ul . ";\n");
            }
        } else {
            my str $rl = "";
            if (defined($cg->{"redo_label"})) { $rl = "" . $cg->{"redo_label"}; }
            if (length($rl) > 0) {
                ind($cg); emit($cg, "goto " . $rl . ";\n");
            } else {
                # See N_LAST comment — warn-and-noop instead of die.
                ind($cg); emit($cg, "fprintf(stderr, \"Warning: \\\"redo\\\" outside a loop block (perla: treated as no-op)\\n\");\n");
            }
        }
        return;
    }
    if ($type == Perla::AST::N_SUB()) {
        # Skip — handled separately
        return;
    }
    if ($type == Perla::AST::N_BEGIN()) {
        ind($cg); emit($cg, "/* BEGIN block */\n");
        _gen_block($cg, $node->{"body"});
        return;
    }

    # __STRADA__ { Strada code } — parse as Perl statements and codegen normally
    if ($type == Perla::AST::N_STRADA_BLOCK()) {
        my str $code = $node->{"code"};
        # Parse the __STRADA__ block content as Perl statements using Perla's own parser
        my array @tokens = Perla::Lexer::lex($code);
        my scalar $block_ast = Perla::Parser::parse(@tokens);
        # Generate C for each statement in the block
        ind($cg); emit($cg, "/* __STRADA__ block */\n");
        if (defined($block_ast) && defined($block_ast->{"stmts"})) {
            my scalar $stmts = $block_ast->{"stmts"};
            my int $si = 0;
            while ($si < scalar(@{$stmts})) {
                my scalar $stmt = $stmts->[$si];
                if (defined($stmt)) {
                    gen_stmt($cg, $stmt);
                }
                $si++;
            }
        }
        return;
    }

    # __C__ { raw C code }
    if ($type == Perla::AST::N_C_BLOCK()) {
        ind($cg); emit($cg, "/* __C__ block */\n");
        ind($cg); emit($cg, "{\n");
        emit($cg, $node->{"code"});
        emit($cg, "\n");
        ind($cg); emit($cg, "}\n");
        return;
    }

    # eval { BLOCK }
    if ($type == Perla::AST::N_EVAL_STRING()) {
        Perla::CodeGen::Eval::emit_eval_string_with_caps($cg, $node, 0);
        return;
    }
    if ($type == Perla::AST::N_REQUIRE()) {
        my str $mod = $node->{"module"};
        if (defined($mod) && length($mod) > 0) {
            ind($cg); emit($cg, "perla_require_module(strada_new_str(\"" . $mod . "\"));\n");
        } else if (defined($node->{"expr"})) {
            ind($cg); emit($cg, "perla_require_module(");
            gen_expr($cg, $node->{"expr"});
            emit($cg, ");\n");
        }
        return;
    }
    if ($type == Perla::AST::N_EVAL_BLOCK()) {
        ind($cg); emit($cg, "if (perla_eval_error) strada_decref(perla_eval_error);\n");
        ind($cg); emit($cg, "perla_eval_error = strada_new_str(\"\");\n");
        ind($cg); emit($cg, "{ jmp_buf *__jb = STRADA_TRY_PUSH();\n");
        # Capture the local-chain head so `local` inside this eval gets
        # unwound when die fires (longjmp would otherwise skip the
        # function-exit `perla_local_chain_restore_all`).
        ind($cg); emit($cg, "  void *__eval_local_mark = __perla_local_chain;\n");
        # Save perla_call_depth so any frames pushed inside the eval body
        # by sub calls that die'd get unwound on catch. Without this, a
        # die from inside an eval-wrapped sub leaves the sub's frame in
        # the call stack, so later caller() walks pick up that stale
        # frame's file/line.
        ind($cg); emit($cg, "  int __eval_sav_depth = perla_call_depth;\n");
        # Push a synthetic "(eval)" frame so Carp::confess's longmess walk
        # includes an "eval {...} called at FILE line N" line at the bottom
        # of the trace (perl's behaviour). Captured AFTER __eval_sav_depth
        # so the die-path unwind `while (depth > sav_depth) pop` pops it
        # automatically; the success path adds an explicit pop below.
        my int $__ev_pln_stmt = 0;
        if (defined($node->{"line"})) { $__ev_pln_stmt = $node->{"line"} + 0; }
        my str $__ev_pkg_stmt = "main";
        if (defined($cg->{"pkg"})) { $__ev_pkg_stmt = "" . $cg->{"pkg"}; }
        ind($cg); emit($cg, "  perla_pending_call_line = " . $__ev_pln_stmt . ";\n");
        ind($cg); emit($cg, "  perla_call_push(\"" . $__ev_pkg_stmt . "\", \"(eval)\", \"" . $cg->{"filename"} . "\", 0);\n");
        # Save want_list. die's longjmp bypasses the per-statement save/restore
        # inside the body, so without this the void-context (-1) set around an
        # inner statement leaks out and corrupts later list-vs-scalar dispatch
        # (e.g., readline <$fh> sees want_list=-1 → list-context infinite loop).
        ind($cg); emit($cg, "  int __eval_sav_wl = __perla_want_list;\n");
        # Detect `my X` decls in the eval body that shadow file-scope
        # vars. perla stores file-scope my-vars as C statics; without
        # save/restore, the body's `my $x = "inner"` reassigns the
        # outer static and decrefs the outer's value at body exit,
        # leaving the outer pointing into freed memory. Save the outer
        # pointer before the body and restore after, in both the
        # normal-exit and die-catch branches. The save decls live in
        # the outer block (not inside the if/else) so the catch branch
        # can see them.
        my array @__ev_shadowed = ();
        if (defined($node->{"body"}) && defined($node->{"body"}->{"stmts"})) {
            my scalar $__ev_bstmts = $node->{"body"}->{"stmts"};
            my int $__ev_bsi = 0;
            while ($__ev_bsi < scalar(@{$__ev_bstmts})) {
                my scalar $__ev_bs = $__ev_bstmts->[$__ev_bsi];
                if (defined($__ev_bs) && $__ev_bs->{"type"} == Perla::AST::N_MY()) {
                    if (defined($__ev_bs->{"var"})) {
                        my str $__ev_vn = $__ev_bs->{"var"}->{"value"};
                        if (_is_file_scope($cg, $__ev_vn) == 1) {
                            my str $__ev_vt = "" . $__ev_bs->{"var"}->{"type"};
                            if (length($__ev_vt) == 0) { $__ev_vt = "SCALAR_VAR"; }
                            push(@__ev_shadowed, {"cname" => c_var_for_vtype($__ev_vt, $__ev_vn), "vtype" => $__ev_vt});
                        }
                    }
                    if (defined($__ev_bs->{"vars"})) {
                        my int $__ev_dvi = 0;
                        while ($__ev_dvi < scalar(@{$__ev_bs->{"vars"}})) {
                            my scalar $__ev_dv = $__ev_bs->{"vars"}->[$__ev_dvi];
                            my str $__ev_dvn = $__ev_dv->{"value"};
                            if (_is_file_scope($cg, $__ev_dvn) == 1) {
                                my str $__ev_dvt = "" . $__ev_dv->{"type"};
                                if (length($__ev_dvt) == 0) { $__ev_dvt = "SCALAR_VAR"; }
                                push(@__ev_shadowed, {"cname" => c_var_for_vtype($__ev_dvt, $__ev_dvn), "vtype" => $__ev_dvt});
                            }
                            $__ev_dvi = $__ev_dvi + 1;
                        }
                    }
                }
                $__ev_bsi = $__ev_bsi + 1;
            }
        }
        my int $__ev_shi = 0;
        while ($__ev_shi < scalar(@__ev_shadowed)) {
            my str $__ev_shc = $__ev_shadowed[$__ev_shi]->{"cname"};
            ind($cg); emit($cg, "  StradaValue *__ev_sav_" . $__ev_shc . " = " . $__ev_shc . "; " . $__ev_shc . " = NULL;\n");
            $__ev_shi = $__ev_shi + 1;
        }
        ind($cg); emit($cg, "  if (__jb && setjmp(*__jb) == 0) {\n");
        # Route `return EXPR` inside the body to a labeled goto that exits
        # the eval block, leaving the enclosing sub intact (Perl semantics:
        # `return` inside `eval BLOCK` returns from the eval, not the sub).
        # Using a labeled goto instead of do-while(0) keeps `last`/`next`/
        # `break;` targeting the outer for/while loop — do-while(0) would
        # catch those and stop them from reaching the real loop.
        my int $__ev_label_id_stmt = 0;
        if (defined($cg->{"eval_label_counter"})) { $__ev_label_id_stmt = $cg->{"eval_label_counter"}; }
        $cg->{"eval_label_counter"} = $__ev_label_id_stmt + 1;
        ind($cg); emit($cg, "    StradaValue *__ev_val = NULL;\n");
        # Hoist my-vars inside the eval body so they can be decref'd at
        # scope exit. Without this, `eval { my $x = EXPR; }` left v_x's
        # value stranded in the C local when the eval block ended —
        # matches the for-loop hoisting pattern.
        my scalar $__ev_saved_hoisted = $cg->{"hoisted_loop_vars"};
        my scalar $__ev_saved_declared = $cg->{"declared_vars"};
        my scalar $__ev_saved_ssd = $cg->{"same_scope_decls"};
        $cg->{"same_scope_decls"} = {};
        # Also snapshot hoisted_shadows so the eval body's _hoist_loop_vars
        # calls don't leak file-scope shadow markers to the enclosing
        # scope (eval has its own shadow save/restore mechanism — the
        # outer's restore would reference __hsv_<cn> that was declared
        # inside the eval's body block, which would be a C undeclared-
        # ident error).
        my scalar $__ev_saved_shadows = $cg->{"hoisted_shadows"};
        $cg->{"hoisted_loop_vars"} = [];
        $cg->{"hoisted_shadows"} = [];
        $cg->{"declared_vars"} = {};
        my array @__ev_sd_keys = keys($__ev_saved_declared);
        my int $__ev_sdi = 0;
        while ($__ev_sdi < scalar(@__ev_sd_keys)) {
            $cg->{"declared_vars"}->{$__ev_sd_keys[$__ev_sdi]} = 1;
            $__ev_sdi++;
        }
        $cg->{"indent"} = $cg->{"indent"} + 2;
        _hoist_loop_vars($cg, $node->{"body"});
        my scalar $__ev_this_hoisted = $cg->{"hoisted_loop_vars"};
        $cg->{"indent"} = $cg->{"indent"} - 2;
        my int $__save_eb_stmt = 0;
        if (defined($cg->{"eval_block_expr_active"})) { $__save_eb_stmt = $cg->{"eval_block_expr_active"}; }
        $cg->{"eval_block_expr_active"} = $__save_eb_stmt + 1;
        my str $__save_resv_stmt = "";
        if (defined($cg->{"eval_block_return_label"})) { $__save_resv_stmt = "" . $cg->{"eval_block_return_label"}; }
        $cg->{"eval_block_return_label"} = "__ev_end_" . $__ev_label_id_stmt;
        $cg->{"indent"} = $cg->{"indent"} + 2;
        gen_block_stmts($cg, $node->{"body"});
        $cg->{"indent"} = $cg->{"indent"} - 2;
        $cg->{"eval_block_expr_active"} = $__save_eb_stmt;
        $cg->{"eval_block_return_label"} = $__save_resv_stmt;
        ind($cg); emit($cg, "    __ev_end_" . $__ev_label_id_stmt . ": ;\n");
        ind($cg); emit($cg, "    if (__ev_val) strada_decref(__ev_val);\n");
        # Decref hoisted my-vars before leaving the eval block. The
        # `if (__jb && setjmp == 0)` branch is the no-die path, so these
        # never get freed by die's longjmp side.
        my int $__ev_hi = 0;
        while ($__ev_hi < scalar(@{$__ev_this_hoisted})) {
            ind($cg); emit($cg, "    strada_decref(" . $__ev_this_hoisted->[$__ev_hi] . ");\n");
            $__ev_hi = $__ev_hi + 1;
        }
        # Restore shadowed file-scope vars saved before the body. The
        # hoist decref already cleared the inner value; now point the
        # static back at the outer pointer we saved.
        my int $__ev_rsi = 0;
        while ($__ev_rsi < scalar(@__ev_shadowed)) {
            my str $__ev_rsc = $__ev_shadowed[$__ev_rsi]->{"cname"};
            ind($cg); emit($cg, "    " . $__ev_rsc . " = __ev_sav_" . $__ev_rsc . ";\n");
            $__ev_rsi = $__ev_rsi + 1;
        }
        $cg->{"hoisted_loop_vars"} = $__ev_saved_hoisted;
        $cg->{"hoisted_shadows"} = $__ev_saved_shadows;
        $cg->{"declared_vars"} = $__ev_saved_declared;
        $cg->{"same_scope_decls"} = $__ev_saved_ssd;
        ind($cg); emit($cg, "    STRADA_TRY_POP();\n");
        ind($cg); emit($cg, "    if (__perla_local_chain != __eval_local_mark) { perla_local_chain_restore_to(__perla_local_chain, __eval_local_mark); __perla_local_chain = __eval_local_mark; }\n");
        ind($cg); emit($cg, "    if (perla_eval_error) strada_decref(perla_eval_error);\n");
        ind($cg); emit($cg, "    perla_eval_error = strada_new_str(\"\");\n");
        ind($cg); emit($cg, "    perla_call_pop();\n");
        ind($cg); emit($cg, "  } else {\n");
        ind($cg); emit($cg, "    STRADA_TRY_POP();\n");
        ind($cg); emit($cg, "    __perla_want_list = __eval_sav_wl;\n");
        ind($cg); emit($cg, "    while (perla_call_depth > __eval_sav_depth) perla_call_pop();\n");
        ind($cg); emit($cg, "    if (__perla_local_chain != __eval_local_mark) { perla_local_chain_restore_to(__perla_local_chain, __eval_local_mark); __perla_local_chain = __eval_local_mark; }\n");
        # Die path: any partial inner-shadow value must be freed and
        # the outer pointer restored. The hoist's normal-exit decref
        # never runs on this branch (longjmp jumps past it).
        my int $__ev_csi = 0;
        while ($__ev_csi < scalar(@__ev_shadowed)) {
            my str $__ev_csc = $__ev_shadowed[$__ev_csi]->{"cname"};
            ind($cg); emit($cg, "    if (" . $__ev_csc . ") strada_decref(" . $__ev_csc . "); " . $__ev_csc . " = __ev_sav_" . $__ev_csc . ";\n");
            $__ev_csi = $__ev_csi + 1;
        }
        # If die set perla_eval_error to a ref, keep it; otherwise use exception_msg
        ind($cg); emit($cg, "    if (!perla_eval_error || !STRADA_IS_TAGGED_INT(perla_eval_error) && perla_eval_error->type == STRADA_STR && perla_eval_error->value.pv && strlen(perla_eval_error->value.pv) == 0) {\n");
        ind($cg); emit($cg, "      if (perla_eval_error) strada_decref(perla_eval_error);\n");
        # Prefer strada_exception_value (preserves blessed refs) over the stringified message
        ind($cg); emit($cg, "      if (strada_exception_value) { perla_eval_error = strada_exception_value; strada_incref(perla_eval_error); }\n");
        ind($cg); emit($cg, "      else { perla_eval_error = strada_exception_msg ? strada_new_str(strada_exception_msg) : strada_new_str(\"Unknown error\"); }\n");
        ind($cg); emit($cg, "    }\n");
        # PERLA_TRACE_CATCH=1 prints each caught exception to stderr.
        # Diagnostic aid for silently-swallowed errors that Try::Tiny /
        # eval BLOCK consumers swallow (Bootstrap's
        # `catch { $drogo_obj=undef }` is the canonical case where the
        # downstream symptom — `$server->app` returning undef — gives
        # no clue what the actual exception was).
        ind($cg); emit($cg, "    if (getenv(\"PERLA_TRACE_CATCH\")) { char *__tc = strada_to_str(perla_eval_error); fprintf(stderr, \"[catch] %s\\n\", __tc ? __tc : \"(empty)\"); free(__tc); }\n");
        ind($cg); emit($cg, "  }\n");
        ind($cg); emit($cg, "}\n");
        return;
    }

    # Postfix if
    if ($type == Perla::AST::N_POSTFIX_IF()) {
        my scalar $inner = $node->{"expr"};
        my int $inner_type = $inner->{"type"};
        ind($cg); emit($cg, "if (");
        _gen_cond($cg, $node->{"cond"});
        emit($cg, ") { ");
        if ($inner_type == Perla::AST::N_LAST() || $inner_type == Perla::AST::N_NEXT() || $inner_type == Perla::AST::N_REDO() || $inner_type == Perla::AST::N_RETURN() || $inner_type == Perla::AST::N_GOTO_LABEL()) {
            gen_stmt($cg, $inner);
        } elsif ($inner_type == Perla::AST::N_ANON_ARRAY() && defined($inner->{"elems"})
                 && (!defined($inner->{"is_ref"}) || $inner->{"is_ref"} == 0)) {
            # Comma sequence (e.g. `$f = $x, last if cond`) — iterate the
            # elements and emit each as a statement. Without this, an
            # element like `last`/`next`/`return` was emitted as an
            # expression (which is a no-op) and the loop never broke.
            my scalar $__pi_elems = $inner->{"elems"};
            my int $__pi_n = scalar(@{$__pi_elems});
            my int $__pi_i = 0;
            while ($__pi_i < $__pi_n) {
                my scalar $__pi_e = $__pi_elems->[$__pi_i];
                my int $__pi_et = $__pi_e->{"type"};
                if ($__pi_et == Perla::AST::N_LAST() || $__pi_et == Perla::AST::N_NEXT()
                    || $__pi_et == Perla::AST::N_REDO() || $__pi_et == Perla::AST::N_RETURN()) {
                    gen_stmt($cg, $__pi_e);
                } else {
                    gen_expr($cg, $__pi_e);
                    emit($cg, "; ");
                }
                $__pi_i++;
            }
        } else {
            gen_expr($cg, $inner);
            emit($cg, "; ");
        }
        emit($cg, "}\n");
        return;
    }
    # Postfix unless
    if ($type == Perla::AST::N_POSTFIX_UNLESS()) {
        my scalar $inner = $node->{"expr"};
        my int $inner_type = $inner->{"type"};
        ind($cg); emit($cg, "if (!(");
        _gen_cond($cg, $node->{"cond"});
        emit($cg, ")) { ");
        if ($inner_type == Perla::AST::N_LAST() || $inner_type == Perla::AST::N_NEXT() || $inner_type == Perla::AST::N_REDO() || $inner_type == Perla::AST::N_RETURN() || $inner_type == Perla::AST::N_GOTO_LABEL()) {
            gen_stmt($cg, $inner);
        } elsif ($inner_type == Perla::AST::N_ANON_ARRAY() && defined($inner->{"elems"})
                 && (!defined($inner->{"is_ref"}) || $inner->{"is_ref"} == 0)) {
            # Same comma-sequence handling as postfix-if.
            my scalar $__pi_elems = $inner->{"elems"};
            my int $__pi_n = scalar(@{$__pi_elems});
            my int $__pi_i = 0;
            while ($__pi_i < $__pi_n) {
                my scalar $__pi_e = $__pi_elems->[$__pi_i];
                my int $__pi_et = $__pi_e->{"type"};
                if ($__pi_et == Perla::AST::N_LAST() || $__pi_et == Perla::AST::N_NEXT()
                    || $__pi_et == Perla::AST::N_REDO() || $__pi_et == Perla::AST::N_RETURN()) {
                    gen_stmt($cg, $__pi_e);
                } else {
                    gen_expr($cg, $__pi_e);
                    emit($cg, "; ");
                }
                $__pi_i++;
            }
        } else {
            gen_expr($cg, $inner);
            emit($cg, "; ");
        }
        emit($cg, "}\n");
        return;
    }
    # Postfix while
    if ($type == Perla::AST::N_POSTFIX_WHILE()) {
        # If the cond is a /g regex match, allocate a position-tracking
        # var so the match advances between iterations. Without this,
        # `\$count++ while \$s =~ /\\w+/g` always matched at pos 0 and
        # infinite-looped.
        my str $saved_g_pos_pw = "";
        my int $set_g_pos_pw = 0;
        if (defined($cg->{"regex_g_pos_var"})) { $saved_g_pos_pw = $cg->{"regex_g_pos_var"}; }
        my scalar $cond_pw = $node->{"cond"};
        if (defined($cond_pw) && $cond_pw->{"type"} == Perla::AST::N_BINOP() && $cond_pw->{"op"} eq "=~") {
            my scalar $rr_pw = $cond_pw->{"right"};
            if (defined($rr_pw) && $rr_pw->{"type"} == Perla::AST::N_REGEX() && defined($rr_pw->{"flags"}) && index($rr_pw->{"flags"}, "g") >= 0) {
                if (!defined($cg->{"regex_g_id"})) { $cg->{"regex_g_id"} = 0; }
                my str $pos_var_pw = "__perla_gpos_" . $cg->{"regex_g_id"};
                $cg->{"regex_g_id"} = $cg->{"regex_g_id"} + 1;
                ind($cg); emit($cg, "{ size_t " . $pos_var_pw . " = 0; ");
                $cg->{"regex_g_pos_var"} = $pos_var_pw;
                $set_g_pos_pw = 1;
            }
        }
        ind($cg); emit($cg, "while (");
        _gen_cond($cg, $node->{"cond"});
        emit($cg, ") ");
        gen_expr($cg, $node->{"expr"});
        emit($cg, ";\n");
        if ($set_g_pos_pw == 1) {
            ind($cg); emit($cg, "}\n");
            $cg->{"regex_g_pos_var"} = $saved_g_pos_pw;
        }
        return;
    }

    # Postfix until
    if ($type == Perla::AST::N_POSTFIX_UNTIL()) {
        ind($cg); emit($cg, "while (!(");
        _gen_cond($cg, $node->{"cond"});
        emit($cg, ")) ");
        gen_expr($cg, $node->{"expr"});
        emit($cg, ";\n");
        return;
    }

    # Postfix for: expr for LIST. The list expression must be evaluated
    # in list context — `for keys %h` returns the count in scalar context,
    # which then deref'd as an array yields nothing.
    if ($type == Perla::AST::N_POSTFIX_FOR()) {
        my int $pf_list_borrowed = expr_is_borrowed($node->{"list"});
        # `STMT for values %h` — alias $_ to each hash value slot so the body
        # writes back into the hash (see _gen_foreach for the block-form twin).
        my int $pf_values_alias = 0;
        my scalar $pf_values_hash = undef;
        if (defined($node->{"list"}) && $node->{"list"}->{"type"} == Perla::AST::N_CALL()
            && defined($node->{"list"}->{"name"})
            && ($node->{"list"}->{"name"} eq "values" || $node->{"list"}->{"name"} eq "CORE::values")
            && defined($node->{"list"}->{"args"}) && scalar(@{$node->{"list"}->{"args"}}) == 1) {
            my scalar $pvarg = $node->{"list"}->{"args"}->[0];
            my int $pvat = $pvarg->{"type"};
            if ($pvat == Perla::AST::N_HASH_VAR() || $pvat == Perla::AST::N_DEREF_HASH()) {
                $pf_values_alias = 1;
                $pf_values_hash = $pvarg;
            }
        }
        ind($cg); emit($cg, "{ int __sav_wl_pf = __perla_want_list; __perla_want_list = 1; ");
        emit($cg, "StradaValue *__pf_vhash = NULL; StradaArray *__pf_vkeys = NULL; ");
        if ($pf_values_alias == 1) {
            emit($cg, "__pf_vhash = ");
            gen_expr($cg, $pf_values_hash);
            emit($cg, "; if (__pf_vhash && !STRADA_IS_TAGGED_INT(__pf_vhash) && __pf_vhash->type == STRADA_REF) __pf_vhash = __pf_vhash->value.rv; ");
            emit($cg, "__pf_vkeys = __pf_vhash ? strada_hash_keys_sv(__pf_vhash) : NULL; ");
            emit($cg, "StradaValue *__pf_list = strada_new_array(); ");
            emit($cg, "{ StradaArray *__pf_vva = strada_deref_array(__pf_list); if (__pf_vkeys) for (size_t __pf_vi = 0; __pf_vi < __pf_vkeys->size; __pf_vi++) { StradaValue *__pf_vk = __pf_vkeys->elements[__pf_vkeys->head + __pf_vi]; char *__pf_vks = strada_to_str(__pf_vk); StradaValue *__pf_vv = strada_hv_fetch_owned(__pf_vhash, __pf_vks ? __pf_vks : \"\"); if (__pf_vks) free(__pf_vks); strada_array_push_take(__pf_vva, __pf_vv ? __pf_vv : strada_new_undef()); } } ");
        } else {
            emit($cg, "StradaValue *__pf_list = ");
            gen_expr($cg, $node->{"list"});
            emit($cg, "; ");
        }
        emit($cg, "__perla_want_list = __sav_wl_pf; StradaArray *__pf_av = strada_deref_array(__pf_list); ");
        # Single-scalar `for SCALAR` (e.g. `STMT for 1` or `STMT for (5)`):
        # Perl semantics — iterate once with $_ bound to that value. Without
        # this fallback, strada_deref_array of a tagged int / non-array
        # returns NULL and the loop body never runs.
        emit($cg, "StradaValue *__pf_fbarr = NULL; ");
        emit($cg, "if (!__pf_av && __pf_list) { __pf_fbarr = strada_new_array(); strada_array_push(strada_deref_array(__pf_fbarr), __pf_list); __pf_av = strada_deref_array(__pf_fbarr); } ");
        emit($cg, "int __pf_len = __pf_av ? strada_array_length(__pf_av) : 0; ");
        emit($cg, "StradaValue *__pf_prev_du = perla_dollar_underscore; ");
        emit($cg, "for (int __pf_i = 0; __pf_i < __pf_len; __pf_i++) { ");
        emit($cg, "perla_dollar_underscore = strada_array_get(__pf_av, __pf_i); ");
        emit($cg, "StradaValue *__orig_pf_du = perla_dollar_underscore; ");
        # When the body is a bare CALL or METHOD, it's in void context —
        # capture and decref the return value (just like the regular
        # expression-statement path below). Without this, calls that
        # return owned values (e.g. a closure returning a captured
        # array) leak one ref per iteration; in long loops this drives
        # perla_call_depth past the recursion limit and trips a "stack
        # overflow" abort at runtime.
        my int $__pf_expr_type = $node->{"expr"}->{"type"};
        my int $__pf_is_call = ($__pf_expr_type == Perla::AST::N_CALL()
                              || $__pf_expr_type == Perla::AST::N_METHOD()) ? 1 : 0;
        if ($__pf_is_call == 1) {
            emit($cg, "{ int __sav_wl_pfv = __perla_want_list; __perla_want_list = -1; StradaValue *__pf_void_rv = ");
            gen_expr($cg, $node->{"expr"});
            emit($cg, "; if (__pf_void_rv) strada_decref(__pf_void_rv); __perla_want_list = __sav_wl_pfv; }");
        } else {
            gen_expr($cg, $node->{"expr"});
        }
        # Aliasing writeback: `$_ = expr for @arr` modifies the array element.
        # DBIC uses this in ResultSet::_construct_results line 1497.
        emit($cg, "; if (perla_dollar_underscore != __orig_pf_du) { strada_incref(perla_dollar_underscore); strada_array_set(__pf_av, __pf_i, perla_dollar_underscore); }");
        if ($pf_values_alias == 1) {
            emit($cg, " if (__pf_vkeys && __pf_i < (int)__pf_vkeys->size) { StradaValue *__pf_wk = __pf_vkeys->elements[__pf_vkeys->head + __pf_i]; char *__pf_wks = strada_to_str(__pf_wk); strada_hv_store(__pf_vhash, __pf_wks ? __pf_wks : \"\", perla_dollar_underscore); if (__pf_wks) free(__pf_wks); }");
        }
        emit($cg, " } perla_dollar_underscore = __pf_prev_du; ");
        emit($cg, "if (__pf_fbarr) strada_decref(__pf_fbarr); ");
        if ($pf_values_alias == 1) {
            emit($cg, "if (__pf_vkeys) strada_free_array(__pf_vkeys); ");
        }
        # Decref __pf_list when the list expression was owned (e.g. a range
        # `1..5` produces a fresh perla_range_array). Borrowed forms keep
        # the source alive via the caller's variable.
        if ($pf_list_borrowed == 0) {
            emit($cg, "if (__pf_list) strada_decref(__pf_list); ");
        }
        emit($cg, "}\n");
        return;
    }

    # Expression statement.
    # When the expression is a bare CALL or METHOD at statement level,
    # the result is discarded — that's Perl's "void context". Set
    # __perla_want_list = -1 around the call so the callee can detect
    # void via `wantarray` returning undef. Other expressions skip the
    # set/restore (no behavior change).
    my int $__es_type = $node->{"type"};
    my int $__es_is_call = ($__es_type == Perla::AST::N_CALL()
                            || $__es_type == Perla::AST::N_METHOD()) ? 1 : 0;
    # Detect bare `bless ..., "C";` at statement level. perla_bless is
    # transparent (no incref) — the returned ref shares its refcount with
    # the FIRST ARGUMENT. So the void cleanup needed mirrors that arg's
    # ownership:
    #   - `bless $var, "C";`  -> arg is borrowed; usual decref would kill
    #     $var's only ref and fire DESTROY prematurely. Skip the wrap.
    #   - `bless {...}, "C";` -> arg is an owned anon temp; we must decref
    #     the result or the anon hash leaks (was: 0 DESTROYs fired).
    # Driven by expr_is_borrowed, which already recurses through bless.
    my int $__es_is_bless = 0;
    my int $__es_bless_borrowed = 0;
    if ($__es_type == Perla::AST::N_CALL() && defined($node->{"name"})) {
        my str $__es_nm = $node->{"name"};
        if ($__es_nm eq "bless" || $__es_nm eq "CORE::bless") {
            $__es_is_bless = 1;
            $__es_bless_borrowed = expr_is_borrowed($node);
        }
    }
    if ($__es_is_call == 1 && $__es_is_bless == 0) {
        ind($cg); emit($cg, "{ int __sav_wl_void = __perla_want_list; __perla_want_list = -1; ");
        # Set the call's source line so the callee's perla_call_push
        # records it in the new frame's `line` — that's what caller(0)
        # inside the callee reads via perla_caller.
        my int $__es_line = $node->{"line"} + 0;
        if ($__es_line > 0) {
            emit($cg, "perla_pending_call_line = " . $__es_line . "; ");
        }
        # Capture the return value into __void_rv and decref it. Callees
        # always `strada_incref(__ret_val); return __ret_val;` so the
        # caller is expected to consume one ref. Statement-level (void
        # context) discards the result — without this decref the extra
        # ref leaks once per call. Visible as the per-iter leak in
        # bless_create / func_call.
        emit($cg, "StradaValue *__void_rv = ");
        gen_expr($cg, $node);
        emit($cg, "; if (__void_rv) strada_decref(__void_rv); __perla_want_list = __sav_wl_void; }\n");
    } elsif ($__es_is_bless == 1 && $__es_bless_borrowed == 1) {
        # Borrowed-arg bless: the result shares the var's refcount, so a
        # decref would kill the var. Just evaluate and drop.
        ind($cg);
        gen_expr($cg, $node);
        emit($cg, ";\n");
    } elsif ($__es_is_bless == 1) {
        # Owned-arg bless (e.g. `bless {...}, "C";`): the anon temp needs
        # cleanup or the object leaks (DESTROY never fires). Capture and
        # decref. No __perla_want_list dance — bless isn't a Perl sub.
        ind($cg); emit($cg, "{ StradaValue *__void_bless_rv = ");
        gen_expr($cg, $node);
        emit($cg, "; if (__void_bless_rv) strada_decref(__void_bless_rv); }\n");
    } elsif ($__es_type == Perla::AST::N_ASSIGN() && defined($node->{"op"}) && $node->{"op"} eq "="
             && defined($node->{"target"}) && defined($node->{"value"})
             && ($node->{"target"}->{"type"} == Perla::AST::N_ARRAY_ELEM()
                 || $node->{"target"}->{"type"} == Perla::AST::N_ARROW_ARRAY()
                 || $node->{"target"}->{"type"} == Perla::AST::N_HASH_ELEM()
                 || $node->{"target"}->{"type"} == Perla::AST::N_ARROW_HASH())
             && expr_is_borrowed($node->{"value"}) == 0
             && $node->{"value"}->{"type"} != Perla::AST::N_STR_LIT()
             && $node->{"value"}->{"type"} != Perla::AST::N_INT_LIT()
             && $node->{"value"}->{"type"} != Perla::AST::N_NUM_LIT()
             && $node->{"value"}->{"type"} != Perla::AST::N_INTERP_STR()) {
        # `\$arr[N] = EXPR;` / `\$h{k} = EXPR;` at statement level —
        # array_set / hash_set incref the stored value, and the assign
        # expression returns the value (also held by the slot). In void
        # context the returned ref is leaked, leaving blessed values at
        # rc=2 — so DESTROY only fires at program exit instead of
        # whenever the slot's last reference goes (perl semantics).
        # Skip for borrowed values (variables, deref'd refs) and plain
        # literals — those don't have an extra owned ref to drop. Only
        # decref for owned expressions (function calls, anon ctors, etc.)
        # where the slot's incref is the second ref.
        ind($cg); emit($cg, "{ StradaValue *__void_rv_as = ");
        gen_expr($cg, $node);
        emit($cg, "; if (__void_rv_as) strada_decref(__void_rv_as); }\n");
    } elsif ($__es_type == Perla::AST::N_ASSIGN() && defined($node->{"op"})
             && $node->{"op"} ne "=" && $node->{"op"} ne "//=" && $node->{"op"} ne "||="
             && defined($node->{"target"})
             && ($node->{"op"} eq ".="
                 || $node->{"target"}->{"type"} == Perla::AST::N_ARRAY_ELEM()
                 || $node->{"target"}->{"type"} == Perla::AST::N_ARROW_ARRAY()
                 || $node->{"target"}->{"type"} == Perla::AST::N_HASH_ELEM()
                 || $node->{"target"}->{"type"} == Perla::AST::N_ARROW_HASH()
                 || $node->{"target"}->{"type"} == Perla::AST::N_DEREF_SCALAR())) {
        # Compound assignments whose codegen yields an OWNED ref at statement
        # (void) level must decref it or it leaks one heap StradaValue per
        # statement. Two families yield owned: scalar `.=` (incref's its
        # result so consumers — my-init, assign, return — can take ownership)
        # and array/hash-element / `$$ref OP=` (the helpers yield the fresh
        # value alongside the slot's own incref). Scalar arithmetic compounds
        # (`$x += …`) yield a BORROWED view of the target and fall through to
        # the plain-emit else below — decref'ing those would free the var.
        # `//=`/`||=` are excluded: they may yield the existing value (already
        # balanced by their decref+store), so a void decref would over-free.
        # Integer element compounds yield an immortal tagged int, so the
        # decref is a harmless no-op there.
        ind($cg); emit($cg, "{ StradaValue *__void_cmpd = ");
        gen_expr($cg, $node);
        emit($cg, "; if (__void_cmpd) strada_decref(__void_cmpd); }\n");
    } else {
        ind($cg);
        gen_expr($cg, $node);
        emit($cg, ";\n");
    }
}

# --- Variable declaration ---
func _gen_my(scalar $cg, scalar $node) void {
    # Stash the my-statement's source line so _my_prefix_vt (called via
    # several intermediaries) can quote it in the "masks earlier declaration"
    # warning. Cleared on return so unrelated declarations elsewhere don't
    # pick up a stale value.
    my int $__cmy_saved_line = 0;
    if (defined($cg->{"current_my_line"})) {
        $__cmy_saved_line = $cg->{"current_my_line"} + 0;
    }
    if (defined($node->{"line"})) {
        $cg->{"current_my_line"} = $node->{"line"} + 0;
    }
    # caller() line propagation for `my $x = call()` / `my $x = $obj->method()`.
    # The init expression's call must record the my-statement's line so
    # caller(0) inside the callee returns the right source location.
    # Without this, `my $r = callme();` at file scope read perla_pending_call_line
    # left over from prior code (commonly 0), and caller(0) returned line 0.
    if (defined($node->{"init"})) {
        my int $__mi_type = $node->{"init"}->{"type"};
        if ($__mi_type == Perla::AST::N_CALL() || $__mi_type == Perla::AST::N_METHOD()) {
            my int $__mi_line = $node->{"init"}->{"line"} + 0;
            if ($__mi_line > 0) {
                ind($cg); emit($cg, "perla_pending_call_line = " . $__mi_line . ";\n");
            }
        }
    }
    # Track variables for main-scope cleanup (only at top indent level).
    # Store {name, type} hashes so cleanup can pick the right sigil-aware
    # C var name.
    if (defined($cg->{"main_vars"}) && $cg->{"indent"} == 1) {
        if (defined($node->{"vars"})) {
            my int $mvi = 0;
            while ($mvi < scalar(@{$node->{"vars"}})) {
                my scalar $mvn = $node->{"vars"}->[$mvi];
                push(@{$cg->{"main_vars"}}, {"name" => $mvn->{"value"}, "type" => $mvn->{"type"}});
                $mvi++;
            }
        } elsif (defined($node->{"var"})) {
            push(@{$cg->{"main_vars"}}, {"name" => $node->{"var"}->{"value"}, "type" => $node->{"var"}->{"type"}});
        }
    }
    # Defer tracking scalar `my $x` decls until AFTER the init expression
    # is generated. Perl's `my $x = expr` evaluates `expr` *without* $x in
    # scope — so if `expr` is an `eval "..."`, the eval should NOT capture
    # a $x that hasn't been declared yet. The previous order pushed v_x to
    # my_lexicals first, the eval-with-caps emitter then read uninitialized
    # v_x to populate its lexical-caps hash, and the resulting `if (v_x)`
    # in the generated C dereferenced stack garbage → segfault.
    #
    # Collect the entries to push now (so we know which to push at the end)
    # but don't push until the init expression is gen'd. Subsequent
    # statements still see the var in scope as expected.
    my array @__pending_lex = ();
    if (defined($cg->{"my_lexicals"})) {
        if (defined($node->{"vars"})) {
            my int $mxi = 0;
            while ($mxi < scalar(@{$node->{"vars"}})) {
                my scalar $mxv = $node->{"vars"}->[$mxi];
                # Push array/hash vars too so inner closures can capture
                # `my @q` / `my %h`. Sigil determines which C name the
                # cell init uses; without this push, free-var analysis
                # couldn't see the var and the inner sub was emitted as
                # a plain CPOINTER instead of a closure.
                if ($mxv->{"type"} eq "SCALAR_VAR"
                    || $mxv->{"type"} eq "ARRAY_VAR"
                    || $mxv->{"type"} eq "HASH_VAR") {
                    my scalar $mxe = {};
                    $mxe->{"name"} = $mxv->{"value"};
                    my str $__s = "\$";
                    if ($mxv->{"type"} eq "ARRAY_VAR") { $__s = "@"; }
                    if ($mxv->{"type"} eq "HASH_VAR") { $__s = "%"; }
                    if ($__s eq "@") { $mxe->{"c_name"} = c_var_a($mxv->{"value"}); }
                    elsif ($__s eq "%") { $mxe->{"c_name"} = c_var_h($mxv->{"value"}); }
                    else { $mxe->{"c_name"} = c_var($mxv->{"value"}); }
                    $mxe->{"sigil"} = $__s;
                    push(@__pending_lex, $mxe);
                }
                $mxi++;
            }
        } elsif (defined($node->{"var"})) {
            my scalar $mxv = $node->{"var"};
            if ($mxv->{"type"} eq "SCALAR_VAR"
                || $mxv->{"type"} eq "ARRAY_VAR"
                || $mxv->{"type"} eq "HASH_VAR") {
                my scalar $mxe = {};
                $mxe->{"name"} = $mxv->{"value"};
                my str $__s = "\$";
                if ($mxv->{"type"} eq "ARRAY_VAR") { $__s = "@"; }
                if ($mxv->{"type"} eq "HASH_VAR") { $__s = "%"; }
                if ($__s eq "@") { $mxe->{"c_name"} = c_var_a($mxv->{"value"}); }
                elsif ($__s eq "%") { $mxe->{"c_name"} = c_var_h($mxv->{"value"}); }
                else { $mxe->{"c_name"} = c_var($mxv->{"value"}); }
                $mxe->{"sigil"} = $__s;
                push(@__pending_lex, $mxe);
            }
        }
    }
    # Stash on $cg so the end-of-_gen_my flush can pick them up. Push
    # immediately after the init expression has been emitted.
    $cg->{"__pending_lex"} = \@__pending_lex;
    if (defined($node->{"vars"})) {
        # Destructuring: my ($a, $b, %h) = @_;
        my scalar $vars = $node->{"vars"};
        my int $nv = scalar(@{$vars});
        my int $vi = 0;
        my int $is_at_init = 0;
        if (defined($node->{"init"})) {
            my scalar $init_node = $node->{"init"};
            if (defined($init_node) && $init_node->{"type"} == Perla::AST::N_ARRAY_VAR() && $init_node->{"name"} eq "_") {
                $is_at_init = 1;
            }
        }
        while ($vi < $nv) {
            my scalar $var = $vars->[$vi];
            my str $vname = $var->{"value"};
            my str $vtype = $var->{"type"};

            # `my (%h) = LIST` — single-element parenthesized hash decl
            # with non-@_ init. Treat like `my %h = LIST` (flatten the
            # list into k/v pairs). Without this special case, perla
            # stored the array literal in v_h and `keys %h` returned
            # nothing.
            if ($nv == 1 && $vtype eq "HASH_VAR" && $is_at_init == 0 && defined($node->{"init"})) {
                # Build a synthetic single-var N_MY node and recurse via
                # the regular my-hash path.
                my scalar $single = {};
                $single->{"type"} = Perla::AST::N_MY();
                $single->{"var"} = $var;
                $single->{"init"} = $node->{"init"};
                gen_stmt($cg, $single);
                $vi++;
                next;
            }
            # Same treatment for `my (@a) = LIST` (single array decl).
            if ($nv == 1 && $vtype eq "ARRAY_VAR" && $is_at_init == 0 && defined($node->{"init"})) {
                my scalar $single_a = {};
                $single_a->{"type"} = Perla::AST::N_MY();
                $single_a->{"var"} = $var;
                $single_a->{"init"} = $node->{"init"};
                gen_stmt($cg, $single_a);
                $vi++;
                next;
            }
            if ($vtype eq "HASH_VAR" && $is_at_init == 1) {
                # Hash slurp: my (%h) — collect remaining @_ pairs into hash
                ind($cg); emit($cg, _my_prefix_vt($cg, "HASH_VAR", $vname) . c_var_h($vname) . " = strada_new_hash();\n");
                ind($cg); emit($cg, "{ StradaArray *__av = strada_deref_array(perla_at_); int __alen = __av ? strada_array_length(__av) : 0;\n");
                ind($cg); emit($cg, "  for (int __hi = " . $vi . "; __hi + 1 < __alen; __hi += 2) {\n");
                ind($cg); emit($cg, "    char *__k = strada_to_str(strada_array_get(__av, __hi));\n");
                ind($cg); emit($cg, "    strada_hv_store(" . c_var_h($vname) . ", __k, strada_array_get(__av, __hi + 1));\n");
                ind($cg); emit($cg, "    free(__k);\n");
                ind($cg); emit($cg, "  }\n");
                ind($cg); emit($cg, "}\n");
            } elsif ($vtype eq "ARRAY_VAR" && $is_at_init == 1) {
                # Array slurp: my (@arr) — collect remaining @_ into array
                ind($cg); emit($cg, _my_prefix_vt($cg, "ARRAY_VAR", $vname) . c_var_a($vname) . " = strada_new_array();\n");
                ind($cg); emit($cg, "{ StradaArray *__av = strada_deref_array(perla_at_); int __alen = __av ? strada_array_length(__av) : 0;\n");
                ind($cg); emit($cg, "  for (int __ai = " . $vi . "; __ai < __alen; __ai++)\n");
                ind($cg); emit($cg, "    strada_array_push(strada_deref_array(" . c_var_a($vname) . "), strada_array_get(__av, __ai));\n");
                ind($cg); emit($cg, "}\n");
            } else {
                if ($is_at_init == 1) {
                    ind($cg); emit($cg, _my_prefix_vt($cg, $vtype, $vname) . c_var_for_vtype($vtype, $vname) . " = ");
                    emit($cg, "(" . $vi . " < strada_array_length(strada_deref_array(perla_at_)) ? strada_array_get(strada_deref_array(perla_at_), " . $vi . ") : strada_new_undef());\n");
                } elsif (defined($node->{"init"}) && $nv >= 1 && $vi == 0
                         && $vars->[0]->{"type"} ne "ARRAY_VAR"
                         && $vars->[0]->{"type"} ne "HASH_VAR") {
                    # `my ($x) = list_func()` is list-context assignment: $x
                    # binds to the FIRST element of the returned list, not
                    # the last (perla used to emit `v_x = list_func()` which
                    # collapsed the list to its trailing scalar — DBI's
                    # `my ($cnt) = $dbh->selectrow_array(...)` returned the
                    # last column instead of the first, and on a 1-column
                    # SELECT (like SELECT COUNT(*)) where the list-as-scalar
                    # collapse produced an empty value, $cnt came out undef.
                    # Use the same destructure path as multi-var; it already
                    # handles ARRAY/HASH RHS and one-element-list fallback.
                    # Multiple vars from one init — declare/decref, then assign from init.
                    # Always call _my_prefix_vt (even when already declared) so the
                    # use-warnings mask check fires; the empty-string return
                    # selects the decref+reassign branch.
                    my int $di = 0;
                    while ($di < $nv) {
                        my str $dname = $vars->[$di]->{"value"};
                        my str $dtype = $vars->[$di]->{"type"};
                        my str $__dmp = _my_prefix_vt($cg, $dtype, $dname);
                        if (length($__dmp) == 0) {
                            # Already hoisted — decref old value (will be reassigned below)
                            ind($cg); emit($cg, "strada_decref(" . c_var_for_vtype($dtype, $dname) . "); ");
                            if ($dtype eq "ARRAY_VAR") {
                                emit($cg, c_var_a($dname) . " = strada_new_array();\n");
                            } elsif ($dtype eq "HASH_VAR") {
                                emit($cg, c_var_h($dname) . " = strada_new_hash();\n");
                            } else {
                                emit($cg, c_var($dname) . " = NULL;\n");
                            }
                        } else {
                            if ($dtype eq "ARRAY_VAR") {
                                ind($cg); emit($cg, $__dmp . c_var_a($dname) . " = strada_new_array();\n");
                            } elsif ($dtype eq "HASH_VAR") {
                                ind($cg); emit($cg, $__dmp . c_var_h($dname) . " = strada_new_hash();\n");
                            } else {
                                ind($cg); emit($cg, $__dmp . c_var($dname) . " = NULL;\n");
                            }
                        }
                        $di++;
                    }
                    # Then assign from the init result (list context for wantarray).
                    # If the RHS turns out to be a scalar (not an array), Perl
                    # treats it as a one-element list: `my ($a, $b) = "foo"`
                    # gives $a = "foo", $b = undef. Perla's destructure used
                    # to turn NULL __da into length 0, assigning undef to
                    # EVERY lvalue — seen in Mo::Inline's
                    # `my ($P, %e, %o) = caller . '::';` where $P silently
                    # ended up undef and `@{$P.ISA} = ...` hit a bogus
                    # symbol.
                    # `shift`/`pop` return a SINGLE SCALAR — never a list — so
                    # `my ($x) = shift` must bind that one scalar to $x, even
                    # when it's an arrayref. Deref-flattening it (the array path
                    # below) wrongly spreads an arrayref's elements, so
                    # `my ($opt_list) = shift` got element 0 instead of the
                    # arrayref. Concrete victim: Data::OptList::mkopt (used by
                    # Sub::Exporter / Moose::Exporter). Generate the op in scalar
                    # context and wrap its result as a one-element list.
                    my int $di_is_scalar_op = 0;
                    my scalar $di_init = $node->{"init"};
                    if (defined($di_init) && $di_init->{"type"} == Perla::AST::N_CALL()
                        && defined($di_init->{"name"})
                        && ($di_init->{"name"} eq "shift" || $di_init->{"name"} eq "pop")) {
                        $di_is_scalar_op = 1;
                    }
                    if ($di_is_scalar_op == 1) {
                        ind($cg); emit($cg, "{ int __sav_wl_dl = __perla_want_list; __perla_want_list = 0; StradaValue *__dl = ");
                        gen_expr($cg, $node->{"init"});
                        emit($cg, "; __perla_want_list = __sav_wl_dl; StradaValue *__dl_fallback = strada_new_array(); { StradaArray *__sf = strada_deref_array(__dl_fallback); if (__dl) { strada_incref(__dl); strada_array_push(__sf, __dl); } } StradaArray *__da = strada_deref_array(__dl_fallback); ");
                        emit($cg, "int __dlen = __da ? strada_array_length(__da) : 0;\n");
                    } else {
                    ind($cg); emit($cg, "{ int __sav_wl_dl = __perla_want_list; __perla_want_list = 1; StradaValue *__dl = ");
                    gen_expr($cg, $node->{"init"});
                    emit($cg, "; __perla_want_list = __sav_wl_dl; StradaArray *__da = strada_deref_array(__dl); ");
                    emit($cg, "StradaValue *__dl_fallback = NULL; ");
                    # `my (...) = %h` — RHS is a hash; flatten to (k,v,k,v,...)
                    # so `my ($k, $v) = %h` and `my @a = %h` work like Perl.
                    emit($cg, "if (!__da && __dl && !STRADA_IS_TAGGED_INT(__dl) && __dl->type == STRADA_HASH && __dl->value.hv) { ");
                    emit($cg, "  __dl_fallback = strada_new_array(); StradaArray *__hf_av = strada_deref_array(__dl_fallback); ");
                    emit($cg, "  StradaArray *__hf_keys = strada_hash_keys(__dl->value.hv); ");
                    emit($cg, "  if (__hf_keys) { for (size_t __hf_i = 0; __hf_i < __hf_keys->size; __hf_i++) { ");
                    emit($cg, "    StradaValue *__hf_k = __hf_keys->elements[__hf_keys->head + __hf_i]; ");
                    emit($cg, "    char *__hf_ks = strada_to_str(__hf_k); ");
                    emit($cg, "    StradaValue *__hf_v = strada_hash_get(__dl->value.hv, __hf_ks); ");
                    emit($cg, "    free(__hf_ks); ");
                    emit($cg, "    if (__hf_k) strada_incref(__hf_k); strada_array_push(__hf_av, __hf_k); ");
                    emit($cg, "    if (__hf_v) strada_incref(__hf_v); strada_array_push(__hf_av, __hf_v); ");
                    emit($cg, "  } strada_free_array(__hf_keys); } __da = __hf_av; ");
                    emit($cg, "} else if (!__da && __dl) { __dl_fallback = strada_new_array(); strada_array_push(strada_deref_array(__dl_fallback), __dl); __da = strada_deref_array(__dl_fallback); } ");
                    emit($cg, "int __dlen = __da ? strada_array_length(__da) : 0;\n");
                    }
                    $di = 0;
                    while ($di < $nv) {
                        my str $dname = $vars->[$di]->{"value"};
                        my str $dtype = $vars->[$di]->{"type"};
                        if ($dtype eq "ARRAY_VAR") {
                            # Slurp remaining elements into array
                            ind($cg); emit($cg, "{ StradaArray *__rav = strada_deref_array(" . c_var_a($dname) . ");\n");
                            ind($cg); emit($cg, "  for (int __ri = " . $di . "; __ri < __dlen; __ri++) strada_array_push(__rav, strada_array_get(__da, __ri)); }\n");
                            $di = $nv;  # done
                        } elsif ($dtype eq "HASH_VAR") {
                            # Slurp remaining elements into hash as key/value pairs.
                            # Perl lets you interleave %hash with other lvalues:
                            # `my ($P, %e, %o) = LIST` binds %e to the remainder
                            # and leaves later hashes/arrays empty. Without this,
                            # Mo::Inline's `my ($P,%e,%o) = caller.'::';` would
                            # leave %e as undef so `\%e` then derefs nothing.
                            ind($cg); emit($cg, "{ StradaHash *__rhv = strada_deref_hash(" . c_var_h($dname) . ");\n");
                            ind($cg); emit($cg, "  for (int __ri = " . $di . "; __ri + 1 < __dlen; __ri += 2) {\n");
                            ind($cg); emit($cg, "    char *__rhk = strada_to_str(strada_array_get(__da, __ri));\n");
                            ind($cg); emit($cg, "    strada_hash_set(__rhv, __rhk, strada_array_get(__da, __ri + 1));\n");
                            ind($cg); emit($cg, "    free(__rhk);\n");
                            ind($cg); emit($cg, "  } }\n");
                            $di = $nv;  # done
                        } else {
                            ind($cg); emit($cg, c_var($dname) . " = (" . $di . " < __dlen ? strada_array_get(__da, " . $di . ") : strada_new_undef());\n");
                            $di++;
                        }
                    }
                    ind($cg); emit($cg, "}\n");
                    $vi = $nv;  # skip rest
                    next;
                } elsif (defined($node->{"init"})) {
                    # Always route through _my_prefix_vt so the use-warnings
                    # "my X masks earlier declaration" check sees both first
                    # and subsequent decls in the same scope. Result string
                    # is "" if the C var was already declared (decref+reassign
                    # path) and "StradaValue *" otherwise (fresh declaration).
                    my str $__mpr_init = _my_prefix_vt($cg, $vtype, $vname);
                    if (length($__mpr_init) == 0) {
                        # Variable already declared (e.g. inside a loop) — decref old and reassign
                        ind($cg); emit($cg, "strada_decref(" . c_var_for_vtype($vtype, $vname) . "); ");
                        emit($cg, c_var_for_vtype($vtype, $vname) . " = ");
                        gen_expr($cg, $node->{"init"});
                        emit($cg, ";\n");
                    } else {
                        ind($cg); emit($cg, $__mpr_init . c_var_for_vtype($vtype, $vname) . " = ");
                        gen_expr($cg, $node->{"init"});
                        emit($cg, ";\n");
                    }
                } else {
                    # Init-less declaration in multi-var `my (...)`. Pick the
                    # right empty value per sigil — `my @arr` is `()`, `my %h`
                    # is `{}`, scalars are undef. Was always emitting undef,
                    # which broke patterns like `my (@arr); $arr[0] = 1;`
                    # (strada_deref_array(undef) is NULL, strada_array_set is a
                    # no-op). Surfaced via DBIC's
                    # `my ($self, $cond, @res_args, $rel_name); (...) = @_;`
                    # in `_resolve_condition`, where the indexed lvalues into
                    # @res_args silently dropped their values.
                    my str $init_expr = "strada_new_undef()";
                    if ($vtype eq "ARRAY_VAR") { $init_expr = "strada_new_array()"; }
                    elsif ($vtype eq "HASH_VAR") { $init_expr = "strada_new_hash()"; }
                    # Route through _my_prefix_vt for the use-warnings mask
                    # detection (see comment in the init'd branch above).
                    my str $__mpr_noinit = _my_prefix_vt($cg, $vtype, $vname);
                    if (length($__mpr_noinit) == 0) {
                        ind($cg); emit($cg, "strada_decref(" . c_var_for_vtype($vtype, $vname) . "); ");
                        emit($cg, c_var_for_vtype($vtype, $vname) . " = " . $init_expr . ";\n");
                    } else {
                        ind($cg); emit($cg, $__mpr_noinit . c_var_for_vtype($vtype, $vname) . " = " . $init_expr . ";\n");
                    }
                }
            }
            $vi++;
        }
        # Flush pending_lex BEFORE the early return so destructure decls
        # actually land in my_lexicals. Without this, `my ($a, $b)` inside
        # a sub didn't add $a/$b to the enclosing-sub lexical set, so the
        # closure free-var scan missed them and the closure body read
        # file-scope statics instead of capturing.
        if (defined($cg->{"__pending_lex"}) && defined($cg->{"my_lexicals"})) {
            my scalar $__pl_dr = $cg->{"__pending_lex"};
            my int $__pli_dr = 0;
            while ($__pli_dr < scalar(@{$__pl_dr})) {
                push(@{$cg->{"my_lexicals"}}, $__pl_dr->[$__pli_dr]);
                $__pli_dr++;
            }
            $cg->{"__pending_lex"} = undef;
        }
        return;
    }
    if (defined($node->{"var"})) {
        my str $vtype = $node->{"var"}->{"type"};
        my str $vname = $node->{"var"}->{"value"};

        if ($vtype eq "HASH_VAR" && defined($node->{"init"})) {
            # my %hash = (key => val, ...); — build hash from flat list
            my scalar $init = $node->{"init"};
            # If any element of the list literal is a hash/array/slice
            # that needs runtime flattening, fall through to the dynamic
            # path. Otherwise `my %m = (%a, %b)` would try to use %a as a
            # single key and %b as its value, mangling the merge.
            my int $hh_has_flatten = 0;
            if ($init->{"type"} == Perla::AST::N_ANON_ARRAY()) {
                my scalar $hh_elems = $init->{"elems"};
                if (defined($hh_elems)) {
                    my int $hh_ei = 0;
                    while ($hh_ei < scalar(@{$hh_elems})) {
                        my int $hh_et = $hh_elems->[$hh_ei]->{"type"};
                        # Whole containers must run through the runtime
                        # flatten path so their elements interleave with
                        # the explicit pairs.
                        if ($hh_et == Perla::AST::N_HASH_VAR()
                            || $hh_et == Perla::AST::N_ARRAY_VAR()
                            || $hh_et == Perla::AST::N_DEREF_ARRAY()
                            || $hh_et == Perla::AST::N_DEREF_HASH()
                            || $hh_et == Perla::AST::N_HASH_SLICE()
                            || $hh_et == Perla::AST::N_ARRAY_SLICE()) {
                            $hh_has_flatten = 1;
                            last;
                        }
                        # Ternary, list-returning operators, calls — each
                        # may yield 0 or more values at runtime so the
                        # static pair-walk can't reason about pairing.
                        # \`(\$cond ? ("k" => "v") : ())\` inside a hash
                        # literal must flatten or the trailing pair is
                        # silently dropped (and any odd-arity element
                        # mis-keys the remaining pairs).
                        if ($hh_et == Perla::AST::N_TERNARY()
                            || $hh_et == Perla::AST::N_CALL()
                            || $hh_et == Perla::AST::N_METHOD()
                            || $hh_et == Perla::AST::N_RANGE()
                            || $hh_et == Perla::AST::N_MAP()
                            || $hh_et == Perla::AST::N_GREP()
                            || $hh_et == Perla::AST::N_SORT()) {
                            $hh_has_flatten = 1;
                            last;
                        }
                        $hh_ei++;
                    }
                }
            }
            if (($init->{"type"} == Perla::AST::N_ANON_ARRAY() || $init->{"type"} == Perla::AST::N_QWORD())
                && $hh_has_flatten == 0) {
                # Known list literal — generate hash directly
                my scalar $elems = $init->{"elems"};
                my int $ne = scalar(@{$elems});
                my str $cv = c_var_h($vname);
                my str $mp = _my_prefix_vt($cg, "HASH_VAR", $vname);
                # Decref old value before reassignment (prevents leak in loops)
                if (length($mp) == 0) {
                    ind($cg); emit($cg, "if (" . $cv . ") strada_decref(" . $cv . ");\n");
                }
                ind($cg); emit($cg, $mp . $cv . " = strada_new_hash();\n");
                my int $ei = 0;
                while ($ei + 1 < $ne) {
                    my scalar $key_node = $elems->[$ei];
                    my int $key_type = $key_node->{"type"};
                    # Pick hv_store vs hv_store_take based on whether the RHS
                    # is a fresh allocation. Same rationale as the hash-literal
                    # codegen path (see _value_is_borrowed): fresh values must
                    # use `_take` or they leak (refcount=1 going in, store
                    # increfs to 2, hash holds one ref, caller never drops
                    # the other); borrowed values need `store` so the hash
                    # gets its own ref, independent of the source.
                    my str $hstore = "strada_hv_store_take";
                    if (Perla::CodeGen::Predicate::value_is_borrowed($cg, $elems->[$ei + 1]) == 1) {
                        $hstore = "strada_hv_store";
                    }
                    if ($key_type == Perla::AST::N_STR_LIT() || $key_type == Perla::AST::N_INT_LIT()) {
                        # Static key: use strdup directly (avoids StradaValue
                        # allocation). Must C-escape — a literal backslash
                        # key (e.g. YAML::Loader's `'\\' => '\\'` unescape
                        # table) has value "\" (one char) which would emit
                        # `"\""` unescaped, producing a C string containing
                        # only a \-escaped quote and no terminating "`.
                        my str $key_val = Perla::CodeGen::Escape::escape_c_str($key_node->{"value"});
                        # Hash assignment is LIST context — wantarray() in a
                        # called sub here should report 1, not the outer
                        # want_list. Without the wrap, `my %h = (k=>ctx())`
                        # inside a scalar-context caller saw scalar context.
                        ind($cg); emit($cg, $hstore . "(" . c_var_h($vname) . ", \"" . $key_val . "\", ({ int __sav_wl_hkv = __perla_want_list; __perla_want_list = 1; StradaValue *__hkv = ");
                        gen_expr($cg, $elems->[$ei + 1]);
                        emit($cg, "; __perla_want_list = __sav_wl_hkv; __hkv; }));\n");
                    } else {
                        ind($cg); emit($cg, "{ int __sav_wl_hk = __perla_want_list; __perla_want_list = 1; char *__k = strada_to_str(");
                        gen_expr($cg, $key_node);
                        emit($cg, "); " . $hstore . "(" . c_var_h($vname) . ", __k, ");
                        gen_expr($cg, $elems->[$ei + 1]);
                        emit($cg, "); free(__k); __perla_want_list = __sav_wl_hk; }\n");
                    }
                    $ei = $ei + 2;
                }
            } else {
                # Dynamic init — check if result is already a hash, otherwise convert flat array.
                # Force list context on the RHS so callees that vary their
                # return shape (`return %hash` is a hash ref in scalar
                # context, kv-list in list context — what PVC's validator
                # subref returns) hand back the kv-list shape that this
                # code expects. Without this, `my %p = $validator->(@_)`
                # inside DateTime::TimeZone::new received the validator's
                # scalar-context result, %p was empty, $p{name} was undef,
                # and TimeZone fell through to OffsetOnly with ''.
                ind($cg); emit($cg, _my_prefix_vt($cg, "HASH_VAR", $vname) . c_var_h($vname) . " = strada_new_hash();\n");
                # Track whether the RHS is a borrowed value (eg @_ ==
                # perla_at_, or a variable). Borrowed → must NOT
                # decref __init at the end (would damage the caller's
                # storage). Owned → decref to release intermediate
                # blessed values for prompt DESTROY.
                my int $__mh_init_borrowed = expr_is_borrowed($init);
                ind($cg); emit($cg, "{ int __sav_wl_mh = __perla_want_list; __perla_want_list = 1; StradaValue *__init = ");
                gen_expr($cg, $init);
                emit($cg, "; __perla_want_list = __sav_wl_mh; ");
                # When the RHS is a hash, COPY entries into the new
                # hash. The previous code aliased __init directly, so
                # `my %h2 = %h; delete \$h2{k}` also deleted from %h.
                # Real Perl: hash assignment is always a copy.
                emit($cg, "if (__init && !STRADA_IS_TAGGED_INT(__init) && __init->type == STRADA_HASH && __init->value.hv) { ");
                emit($cg, "  StradaArray *__hck = strada_hash_keys(__init->value.hv); ");
                emit($cg, "  if (__hck) { for (size_t __hci = 0; __hci < __hck->size; __hci++) { ");
                emit($cg, "    StradaValue *__hcv = __hck->elements[__hck->head + __hci]; ");
                emit($cg, "    char *__hck_s = strada_to_str(__hcv); ");
                emit($cg, "    StradaValue *__hcvv = strada_hash_get(__init->value.hv, __hck_s); ");
                emit($cg, "    strada_hv_store(" . c_var_h($vname) . ", __hck_s, __hcvv); ");
                emit($cg, "    free(__hck_s); ");
                emit($cg, "  } strada_free_array(__hck); } ");
                emit($cg, "} else { StradaArray *__ia = strada_deref_array(__init); ");
                emit($cg, "if (__ia) for (int __ii = 0; __ii + 1 < (int)strada_array_length(__ia); __ii += 2) { ");
                emit($cg, "char *__k = strada_to_str(strada_array_get(__ia, __ii)); ");
                emit($cg, "strada_hv_store(" . c_var_h($vname) . ", __k, strada_array_get(__ia, __ii + 1)); free(__k); } } ");
                # Decref __init now that its entries have been copied
                # into the target hash — but only when __init is an
                # owned temp (literal list, fresh expression). For
                # borrowed RHS (\@_, %other_hash, etc.) decref would
                # damage the caller's storage. expr_is_borrowed
                # filters these cases out.
                if ($__mh_init_borrowed == 0) {
                    emit($cg, "if (__init) strada_decref(__init); }\n");
                } else {
                    emit($cg, "}\n");
                }
            }
        } else {
            # Track whether the my-decl reduces to a plain file-scope
            # assignment (no `StradaValue *` prefix). When it does, a
            # no-init `my @arr` should preserve any pushes BEGIN
            # blocks made into the file-scope v_arr — see the no-init
            # branch below. EXCEPT for the second (and later) `my @arr`
            # at file scope: re-declaration always resets.
            my int $is_file_scope_assign = 0;
            my int $is_repeat_file_my = 0;
            my str $__my_file_key = c_var_for_vtype($vtype, $vname);
            if (defined($cg->{"declared_vars"}->{$__my_file_key})) {
                # Re-declaration in the same C scope. Trigger the
                # use-warnings "my X masks earlier declaration" check by
                # consulting same_scope_decls directly (the warning emit
                # also lives inside _my_prefix_vt but the path that calls
                # it is taken only for fresh decls — for re-decls we
                # short-circuit to decref+reassign).
                if (defined($cg->{"same_scope_decls"})
                    && defined($cg->{"same_scope_decls"}->{$__my_file_key})
                    && defined($cg->{"use_warnings"}) && $cg->{"use_warnings"} == 1) {
                    my str $__mm_s = "\$";
                    if ($vtype eq "ARRAY_VAR") { $__mm_s = "@"; }
                    elsif ($vtype eq "HASH_VAR") { $__mm_s = "%"; }
                    my int $__mm_l = 0;
                    if (defined($cg->{"current_my_line"})) {
                        $__mm_l = $cg->{"current_my_line"} + 0;
                    }
                    my str $__mm_f = "" . $cg->{"filename"};
                    if (length($__mm_f) == 0) { $__mm_f = "-"; }
                    say(STDERR, "\"my\" variable " . $__mm_s . $vname . " masks earlier declaration in same scope at " . $__mm_f . " line " . $__mm_l . ".");
                }
                if (defined($cg->{"same_scope_decls"})) {
                    $cg->{"same_scope_decls"}->{$__my_file_key} = 1;
                }
                ind($cg); emit($cg, "strada_decref(" . $__my_file_key . "); " . $__my_file_key . " = ");
            } else {
                my str $__mp = _my_prefix_vt($cg, $vtype, $vname);
                if (length($__mp) == 0) { $is_file_scope_assign = 1; }
                ind($cg); emit($cg, $__mp . $__my_file_key . " = ");
            }
            # Track first-vs-subsequent `my @arr` at file scope so the
            # no-init "preserve BEGIN value" ternary only fires on the
            # FIRST decl. Second+ uses of the same name re-declare a
            # fresh, empty array (Perl `my` semantics — each `my` makes
            # a new lexical, not aliasing the previous).
            if ($is_file_scope_assign == 1) {
                if (!defined($cg->{"__my_file_emitted"})) { $cg->{"__my_file_emitted"} = {}; }
                if (defined($cg->{"__my_file_emitted"}->{$__my_file_key})) {
                    $is_repeat_file_my = 1;
                }
                $cg->{"__my_file_emitted"}->{$__my_file_key} = 1;
            }
            if (defined($node->{"init"})) {
                if ($vtype eq "ARRAY_VAR") {
                    # Set list context and ensure result is always an array.
                    # CRITICAL: copy elements into a fresh array so mutations
                    # to the new @arr don't bleed back into the source. Real
                    # Perl: `my @x = @{$ref}` is a copy. Without the copy,
                    # `my @copy = @{$h->{from}}; shift @copy;` mutated
                    # $h->{from} (since both aliased the same StradaArray) —
                    # broke DBIC's `_resolved_attrs` collapse-detection
                    # `while (@fromlist) { my $t = shift @fromlist; ... }`,
                    # which silently shifted the root HASH off $attrs->{from}
                    # so the real query saw `[JOIN1, JOIN2]` instead of
                    # `[ROOT_HASH, JOIN1, JOIN2]` and emitted `FROM JOIN ON 0`.
                    emit($cg, "({ int __sav_wl_wv = __perla_want_list; __perla_want_list = 1; StradaValue *__wv = ");
                    gen_expr($cg, $node->{"init"});
                    emit($cg, "; __perla_want_list = __sav_wl_wv; ");
                    emit($cg, "StradaValue *__cparr = strada_new_array(); StradaArray *__cpav = strada_deref_array(__cparr); ");
                    emit($cg, "if (__wv && !STRADA_IS_TAGGED_INT(__wv) && __wv->type == STRADA_ARRAY) { ");
                    emit($cg, "  StradaArray *__src = strada_deref_array(__wv); ");
                    emit($cg, "  if (__src) for (int __cpi = 0; __cpi < (int)strada_array_length(__src); __cpi++) { ");
                    # push() already increfs; the prior `incref(); push()` pair
                    # double-incref'd each element. Use push_take with an explicit
                    # incref so the dest gets exactly one owned ref while the
                    # source (__wv's array) retains its own.
                    emit($cg, "    StradaValue *__cpe = strada_array_get(__src, __cpi); if (__cpe) strada_incref(__cpe); strada_array_push_take(__cpav, __cpe); } ");
                    emit($cg, "} else if (__wv && !STRADA_IS_TAGGED_INT(__wv) && __wv->type == STRADA_HASH && __wv->value.hv) { ");
                    # `my @arr = %h` — flatten hash to (k,v,k,v,...).
                    emit($cg, "  StradaArray *__hf_keys = strada_hash_keys(__wv->value.hv); ");
                    emit($cg, "  if (__hf_keys) { for (size_t __hf_i = 0; __hf_i < __hf_keys->size; __hf_i++) { ");
                    emit($cg, "    StradaValue *__hf_k = __hf_keys->elements[__hf_keys->head + __hf_i]; ");
                    emit($cg, "    char *__hf_ks = strada_to_str(__hf_k); ");
                    emit($cg, "    StradaValue *__hf_v = strada_hash_get(__wv->value.hv, __hf_ks); ");
                    emit($cg, "    free(__hf_ks); ");
                    emit($cg, "    if (__hf_k) strada_incref(__hf_k); strada_array_push_take(__cpav, __hf_k); ");
                    emit($cg, "    if (__hf_v) strada_incref(__hf_v); strada_array_push_take(__cpav, __hf_v); ");
                    emit($cg, "  } strada_free_array(__hf_keys); } ");
                    emit($cg, "} else if (__wv) { strada_incref(__wv); strada_array_push_take(__cpav, __wv); } ");
                    # Decref __wv if it was a temporary (anon-list literal). Borrowed
                    # forms (@var, %h, scalar var, derefs) keep __wv alive via the
                    # caller — never decref those or we'd free their backing.
                    my int $__ima_t = -1;
                    if (defined($node->{"init"})) { $__ima_t = $node->{"init"}->{"type"}; }
                    my int $__ima_borrowed = 0;
                    if ($__ima_t == Perla::AST::N_ARRAY_VAR()
                        || $__ima_t == Perla::AST::N_HASH_VAR()
                        || $__ima_t == Perla::AST::N_SCALAR_VAR()
                        || $__ima_t == Perla::AST::N_DEREF_ARRAY()
                        || $__ima_t == Perla::AST::N_DEREF_HASH()
                        || $__ima_t == Perla::AST::N_ASSIGN()
                        || $__ima_t == Perla::AST::N_MY()
                        || $__ima_t == Perla::AST::N_OUR()) {
                        # An assignment / declaration used as the init expression
                        # (chained: `my @A = my @B = LIST` or `my @A = @B = LIST`)
                        # yields the *target's* container, which the target owns.
                        # Decref'ing __wv there would free it out from under the
                        # inner variable, leaving it empty. Treat as borrowed.
                        $__ima_borrowed = 1;
                    }
                    if ($__ima_borrowed == 0) {
                        emit($cg, "if (__wv) strada_decref(__wv); ");
                    }
                    emit($cg, "__cparr; })");
                } else {
                    # Scalar-var assignment: force scalar context for the init
                    # so chained calls (e.g. `my $x = YAML::Load($s)`) see
                    # __perla_want_list = 0 even if intermediate code left it
                    # mutated. Without this, Load → loader_object → load →
                    # _parse cascaded with wantarray=1 in bizowie's deep call
                    # chain — returned the docs ARRAY instead of last-doc HASH.
                    # If RHS is a borrowed variable ref (scalar var), incref —
                    # else `my $b = $a; $a = ...` decref's the shared value
                    # and leaves $b dangling. Only true VAR forms — hash/array
                    # access already returns owned via strada_hv_fetch_owned.
                    my int $imby_borrowed = 0;
                    my scalar $imby_init = $node->{"init"};
                    my int $imby_scalarize_hash = 0;
                    my int $imby_scalarize_array = 0;
                    if (defined($imby_init)) {
                        my int $imby_t = $imby_init->{"type"};
                        if ($imby_t == Perla::AST::N_SCALAR_VAR() ||
                            $imby_t == Perla::AST::N_ARRAY_VAR() ||
                            $imby_t == Perla::AST::N_HASH_VAR()) {
                            $imby_borrowed = 1;
                        }
                        # `my $s = %h` — scalar context of a hash is its
                        # entry count, NOT a copy of the hash StradaValue.
                        if ($imby_t == Perla::AST::N_HASH_VAR()
                            && defined($imby_init->{"name"})
                            && index($imby_init->{"name"}, "::") < 0) {
                            $imby_scalarize_hash = 1;
                            $imby_borrowed = 0;
                        }
                        # `my $s = @a` — scalar context of an array is its
                        # length. Skip `@_` (handled by perla_at_ runtime).
                        if ($imby_t == Perla::AST::N_ARRAY_VAR()
                            && defined($imby_init->{"name"})
                            && index($imby_init->{"name"}, "::") < 0
                            && $imby_init->{"name"} ne "_") {
                            $imby_scalarize_array = 1;
                            $imby_borrowed = 0;
                        }
                    }
                    emit($cg, "({ int __sav_wl_my = __perla_want_list; __perla_want_list = 0; StradaValue *__init_my = ");
                    if ($imby_scalarize_hash == 1) {
                        my str $__rhs_cv = c_var_h($imby_init->{"name"});
                        emit($cg, "({ StradaHash *__shv = strada_deref_hash(" . $__rhs_cv . "); STRADA_MAKE_TAGGED_INT((int64_t)(__shv ? __shv->num_entries : 0)); })");
                    } elsif ($imby_scalarize_array == 1) {
                        my str $__rhs_cv = c_var_a($imby_init->{"name"});
                        emit($cg, "STRADA_MAKE_TAGGED_INT((int64_t)strada_array_length(strada_deref_array(" . $__rhs_cv . ")))");
                    } else {
                        gen_expr($cg, $node->{"init"});
                    }
                    if ($imby_borrowed == 1) {
                        # $1..$9 / $& / capture vars are actually OWNED — strada_capture_var()
                        # incref's before returning. Adding another incref here gave the var
                        # rc+2 for a single owner, leaking once per capture read (e.g. inside
                        # a regex-match if-block).
                        my int $__imby_cap = 0;
                        if (defined($imby_init) && $imby_init->{"type"} == Perla::AST::N_SCALAR_VAR()) {
                            my str $__imby_n = "" . $imby_init->{"name"};
                            if ((length($__imby_n) == 1 && $__imby_n ge "1" && $__imby_n le "9")
                                || $__imby_n eq "&") {
                                $__imby_cap = 1;
                            }
                        }
                        if ($__imby_cap == 0) {
                            # Tied scalar dispatch: `my $v = $tied` must call
                            # FETCH at the read site so the tied object's log
                            # records the read (and the binding sees the FETCH
                            # result, not the tied SV placeholder). FETCH
                            # returns owned, replacing the incref. Limited to
                            # SCALAR_VAR init so we don't pay the meta probe
                            # for hash-access / array-access RHS (those return
                            # owned anyway and already dispatch FETCH at the
                            # access site).
                            my int $__imby_sv = 0;
                            if (defined($imby_init) && $imby_init->{"type"} == Perla::AST::N_SCALAR_VAR()) {
                                $__imby_sv = 1;
                            }
                            if ($__imby_sv == 1) {
                                emit($cg, "; if (__init_my && !STRADA_IS_TAGGED_INT(__init_my) && __init_my->meta && __init_my->meta->is_tied) { __init_my = strada_tied_scalar_fetch(__init_my); } else if (__init_my) { strada_incref(__init_my); }");
                            } else {
                                emit($cg, "; if (__init_my) strada_incref(__init_my)");
                            }
                        }
                    }
                    emit($cg, "; __perla_want_list = __sav_wl_my; __init_my; })");
                }
            } else {
                # No-init `my @arr` / `my %h`. When this reduces to a
                # plain file-scope assignment (no new local declared),
                # preserve any prior value the BEGIN-hoist (or perla's
                # pre-main auto-init) placed in v_X. Use a ternary so
                # we don't clobber it: `v_X = v_X ? v_X : new()`. The
                # local-shadow case (decl form) must stay unguarded —
                # the var being declared is in scope inside its
                # initializer, so reading it reads indeterminate
                # memory. EXCEPT: if this is the second+ `my @arr` at
                # file scope, always reset — Perl's `my` re-declares
                # a fresh lexical, not aliasing the previous.
                if ($vtype eq "ARRAY_VAR") {
                    if ($is_file_scope_assign == 1 && $is_repeat_file_my == 0) {
                        my str $__cvn = c_var_a($vname);
                        emit($cg, $__cvn . " ? " . $__cvn . " : strada_new_array()");
                    } else {
                        emit($cg, "strada_new_array()");
                    }
                } elsif ($vtype eq "HASH_VAR") {
                    if ($is_file_scope_assign == 1 && $is_repeat_file_my == 0) {
                        my str $__cvn = c_var_h($vname);
                        emit($cg, $__cvn . " ? " . $__cvn . " : strada_new_hash()");
                    } else {
                        emit($cg, "strada_new_hash()");
                    }
                } else {
                    # Same "preserve BEGIN value" pattern for scalars:
                    # `my $x; BEGIN { $x = ... }; print $x` should see the
                    # BEGIN's assignment. Without the ternary, the file-
                    # scope `v_x = strada_new_undef()` runs after the
                    # BEGIN block at module init and clobbers it.
                    # Re-declarations (second `my $x`) reset as before.
                    if ($is_file_scope_assign == 1 && $is_repeat_file_my == 0) {
                        my str $__cvn = c_var($vname);
                        emit($cg, $__cvn . " ? " . $__cvn . " : strada_new_undef()");
                    } else {
                        emit($cg, "strada_new_undef()");
                    }
                }
            }
            emit($cg, ";\n");
        }
    }
    # Flush pending lexicals NOW that the init expression has been emitted.
    # This makes the newly-declared var visible to subsequent statements'
    # eval STRING captures without exposing it to its own init expression
    # (where reading the still-uninitialised C variable would segfault).
    if (defined($cg->{"__pending_lex"}) && defined($cg->{"my_lexicals"})) {
        my scalar $__pl = $cg->{"__pending_lex"};
        my int $__pli = 0;
        while ($__pli < scalar(@{$__pl})) {
            push(@{$cg->{"my_lexicals"}}, $__pl->[$__pli]);
            $__pli++;
        }
        $cg->{"__pending_lex"} = undef;
    }
    # Restore the my-line counter so the next decl sees its own line, not
    # this one's value (stashed at function entry).
    $cg->{"current_my_line"} = $__cmy_saved_line;
}
# --- State variable (persists across calls) ---
func _gen_state(scalar $cg, scalar $node) void {
    if (defined($node->{"var"})) {
        my str $vname = $node->{"var"}->{"value"};
        my str $vtype = "" . $node->{"var"}->{"type"};
        if (length($vtype) == 0) { $vtype = "SCALAR_VAR"; }
        # Sigil-aware C var name + sigil-appropriate empty-init. Without
        # this, `state @history` and `state %seen` reused v_<name> (the
        # scalar slot) and initialized to undef — so `push @history,
        # $_` saw a non-array each invocation and dropped data.
        my str $cvar = c_var_for_vtype($vtype, $vname);
        my str $empty_init = "strada_new_undef()";
        if ($vtype eq "ARRAY_VAR") { $empty_init = "strada_new_array()"; }
        elsif ($vtype eq "HASH_VAR") { $empty_init = "strada_new_hash()"; }
        # Per-closure-instance state: if this anon sub was emitted with
        # a state-var pad slot for $vname (find_state_vars added it
        # to captures, create site allocated a fresh refcount cell),
        # the body's `#define v_NAME (*captures[K])` macro is already
        # in scope. Just emit the lazy-init check using the macro.
        # Each closure instance starts with cell->slot = NULL; first
        # call fills it. Sibling closures created at the same scope
        # each get their own cell, matching perl's CV-pad-per-instance.
        my int $is_anon_state = 0;
        if (defined($cg->{"anon_state_capture"})
            && exists($cg->{"anon_state_capture"}->{$vname})) {
            $is_anon_state = 1;
        }
        if ($is_anon_state == 1) {
            # Pad-slot init: INIT expression returns an owned ref
            # (refcount=1). Cell takes ownership directly. No extra
            # incref — strada_cell_decref at closure teardown decrefs
            # the value when the cell's refcount hits 0.
            if (defined($node->{"init"})) {
                ind($cg); emit($cg, "if (!" . $cvar . ") { " . $cvar . " = ");
                gen_expr($cg, $node->{"init"});
                emit($cg, "; }\n");
            } else {
                ind($cg); emit($cg, "if (!" . $cvar . ") { " . $cvar . " = " . $empty_init . "; }\n");
            }
            return;
        }
        $cg->{"tmp_count"} = $cg->{"tmp_count"} + 1;
        my str $flag = "__state_init_" . $cg->{"tmp_count"};
        ind($cg); emit($cg, "static StradaValue *" . $cvar . " = NULL;\n");
        ind($cg); emit($cg, "static int " . $flag . " = 0;\n");
        if (defined($node->{"init"})) {
            ind($cg); emit($cg, "if (!" . $flag . ") { " . $flag . " = 1; " . $cvar . " = ");
            gen_expr($cg, $node->{"init"});
            emit($cg, "; strada_incref(" . $cvar . "); }\n");
        } else {
            ind($cg); emit($cg, "if (!" . $flag . ") { " . $flag . " = 1; " . $cvar . " = " . $empty_init . "; }\n");
        }
        # Track state var so closures returned from this sub capture
        # &v_X (the static) rather than malloc a fresh cell-copy. Per
        # Perl semantics for state declared in NAMED subs: shared
        # across all invocations of the enclosing sub AND across any
        # closures that escape it. For state declared inside an anon
        # sub, the anon_state_capture path above handles per-instance
        # semantics.
        if (!defined($cg->{"state_vars"})) {
            $cg->{"state_vars"} = {};
        }
        $cg->{"state_vars"}->{$vname} = $vtype;
    }
}

# --- Sub definition ---
# Return the C-slot names of top-level `my $X` declarations in this block
# that SHADOW an already-declared in-scope lexical of the same slot. These
# need save/restore around the block (see _gen_block). Order = declaration
# order; deduped. Only same-slot shadows (declared_vars already has the
# cname) qualify — a fresh decl gets a new slot and needs no save.
func _block_shadow_cnames(scalar $cg, scalar $node) array {
    my array @out = ();
    my scalar $stmts = $node->{"stmts"};
    if (!defined($stmts)) { return @out; }
    my scalar $seen = {};
    my int $i = 0;
    while ($i < scalar(@{$stmts})) {
        my scalar $s = $stmts->[$i];
        if (defined($s) && $s->{"type"} == Perla::AST::N_MY()) {
            if (defined($s->{"var"})) {
                my str $vn = $s->{"var"}->{"value"};
                my str $vt = "" . $s->{"var"}->{"type"};
                if (length($vt) == 0) { $vt = "SCALAR_VAR"; }
                my str $cn = c_var_for_vtype($vt, $vn);
                if (defined($cg->{"declared_vars"}->{$cn}) && !defined($seen->{$cn})) {
                    $seen->{$cn} = 1;
                    push(@out, $cn);
                }
            }
            if (defined($s->{"vars"})) {
                my scalar $vars = $s->{"vars"};
                my int $vi = 0;
                while ($vi < scalar(@{$vars})) {
                    my str $vn2 = $vars->[$vi]->{"value"};
                    my str $vt2 = "" . $vars->[$vi]->{"type"};
                    if (length($vt2) == 0) { $vt2 = "SCALAR_VAR"; }
                    my str $cn2 = c_var_for_vtype($vt2, $vn2);
                    if (defined($cg->{"declared_vars"}->{$cn2}) && !defined($seen->{$cn2})) {
                        $seen->{$cn2} = 1;
                        push(@out, $cn2);
                    }
                    $vi = $vi + 1;
                }
            }
        }
        $i = $i + 1;
    }
    return @out;
}

func _gen_block(scalar $cg, scalar $node) void {
    ind($cg); emit($cg, "{\n");
    $cg->{"indent"} = $cg->{"indent"} + 1;
    # Snapshot the local_vars set on block entry. Any new entries added
    # while generating the block body are scoped to THIS block — restore
    # them when the block closes (Perl `local` semantics: restoration at
    # end of enclosing scope, not at function exit).
    my scalar $saved_locals = {};
    if (defined($cg->{"local_vars"})) {
        my array @keys_before = keys($cg->{"local_vars"});
        my int $ki = 0;
        while ($ki < scalar(@keys_before)) {
            $saved_locals->{$keys_before[$ki]} = 1;
            $ki++;
        }
    }
    # Bare-block is a new lexical scope — reset same_scope_decls so any
    # `my $x` declared inside doesn't trigger the masks-earlier warning
    # against an outer-scope `my $x`.
    my scalar $__bb_saved_ssd = $cg->{"same_scope_decls"};
    $cg->{"same_scope_decls"} = {};
    # Lexical-shadow save/restore for `my $x` decls that SHADOW an outer
    # in-scope lexical (sub param or sub-local) of the same C slot. perla
    # reuses the C slot v_x for the shadow, emitting `decref(v_x); v_x=new`
    # with no save — so the block permanently clobbers the outer var
    # (`sub f{ my($x)=@_; { my $x={%$x}; $x->{c}=3 } return [keys %$x] }`
    # returned [a b c] instead of [a b]). Save the outer pointer (incref to
    # compensate for the body's reassignment-decref), let the body run — its
    # RHS self-reference `{%$x}` still reads the intact outer slot — then at
    # block exit decref whatever the shadow left and restore the outer.
    # File-scope shadows are handled separately (do-while/eval paths); this
    # covers the bare-block sub-local/param case.
    my array @__bb_shadows = _block_shadow_cnames($cg, $node);
    my int $__bs_i = 0;
    while ($__bs_i < scalar(@__bb_shadows)) {
        my str $__bs_cn = $__bb_shadows[$__bs_i];
        ind($cg); emit($cg, "StradaValue *__shadowsav_" . $__bs_cn . " = " . $__bs_cn . "; if (" . $__bs_cn . ") strada_incref(" . $__bs_cn . ");\n");
        $__bs_i = $__bs_i + 1;
    }
    gen_block_stmts($cg, $node);
    # Restore shadows in reverse declaration order.
    my int $__br_i = scalar(@__bb_shadows) - 1;
    while ($__br_i >= 0) {
        my str $__br_cn = $__bb_shadows[$__br_i];
        ind($cg); emit($cg, "if (" . $__br_cn . " != __shadowsav_" . $__br_cn . ") { if (" . $__br_cn . ") strada_decref(" . $__br_cn . "); } " . $__br_cn . " = __shadowsav_" . $__br_cn . ";\n");
        $__br_i = $__br_i - 1;
    }
    $cg->{"same_scope_decls"} = $__bb_saved_ssd;
    # Restore any `local $g = ...` whose save record was created in this
    # block (not present on entry). The save var __local_save_NAME was
    # written at the local stmt; we re-assign back here.
    if (defined($cg->{"local_vars"})) {
        my array @keys_after = keys($cg->{"local_vars"});
        my int $kj = 0;
        while ($kj < scalar(@keys_after)) {
            my str $kname = $keys_after[$kj];
            if (!defined($saved_locals->{$kname})) {
                my str $kvt = "" . $cg->{"local_vars"}->{$kname};
                if (length($kvt) == 0 || $kvt eq "1") { $kvt = "SCALAR_VAR"; }
                ind($cg); emit($cg, c_var_for_vtype($kvt, $kname) . " = __local_save_" . safe_ident($kname) . ";\n");
                # Mirror globals like perla_irs / perla_ors / perla_ofs / perla_lse
                # are synced at local-set time; resync them at block exit so
                # \`{ local \$/; ... }\` actually restores the input record
                # separator instead of leaving the I/O layer slurping forever.
                if ($kname eq "/") { ind($cg); emit($cg, "perla_irs = __local_save_" . safe_ident($kname) . ";\n"); }
                elsif ($kname eq "\\") { ind($cg); emit($cg, "perla_ors = __local_save_" . safe_ident($kname) . ";\n"); }
                elsif ($kname eq ",") { ind($cg); emit($cg, "perla_ofs = __local_save_" . safe_ident($kname) . ";\n"); }
                elsif ($kname eq "\"") { ind($cg); emit($cg, "perla_lse = __local_save_" . safe_ident($kname) . ";\n"); }
                $cg->{"local_vars"}->{$kname} = "__restored__";
            }
            $kj++;
        }
    }
    $cg->{"indent"} = $cg->{"indent"} - 1;
    ind($cg); emit($cg, "}\n");
}

# int type-inference (M1 wiring): collect `my $x = <int>` single-scalar decls
# anywhere in the subtree into $out as [name, init] pairs.
func _collect_my_scalar_decls(scalar $node, scalar $out) void {
    if (!defined($node)) { return; }
    if (ref($node) eq "ARRAY") {
        my int $ai = 0;
        while ($ai < scalar(@{$node})) { _collect_my_scalar_decls($node->[$ai], $out); $ai = $ai + 1; }
        return;
    }
    if (ref($node) ne "HASH") { return; }
    if ($node->{"type"} == Perla::AST::N_MY() && defined($node->{"init"})) {
        my str $nm = "";
        if (defined($node->{"vars"}) && scalar(@{$node->{"vars"}}) == 1) {
            my scalar $v = $node->{"vars"}->[0];
            if (defined($v) && ref($v) eq "HASH" && defined($v->{"type"})
                && ("" . $v->{"type"}) eq "SCALAR_VAR" && defined($v->{"value"})) {
                $nm = "" . $v->{"value"};
            }
        } elsif (defined($node->{"var"}) && ref($node->{"var"}) eq "HASH"
                 && defined($node->{"var"}->{"type"}) && ("" . $node->{"var"}->{"type"}) eq "SCALAR_VAR"
                 && defined($node->{"var"}->{"value"})) {
            $nm = "" . $node->{"var"}->{"value"};
        }
        if (length($nm) > 0) { push(@{$out}, [$nm, $node->{"init"}]); }
    }
    my array @cf = ("body", "stmts", "then", "else", "init", "cond", "step",
                    "expr", "value", "target", "block", "args", "elems", "list",
                    "true_branch", "false_branch");
    my int $fi = 0;
    while ($fi < scalar(@cf)) {
        my str $fn = $cf[$fi];
        if (exists($node->{$fn})) { _collect_my_scalar_decls($node->{$fn}, $out); }
        $fi = $fi + 1;
    }
}

# Compute the set of int-eligible local scalars for a function body and store
# it in $cg->{"int_vars"} (name => 1). Called fresh per function scope.
func _compute_int_vars(scalar $cg, scalar $stmts) void {
    $cg->{"int_vars"} = {};
    if (!defined($stmts) || ref($stmts) ne "ARRAY") { return; }
    my array @cands = ();
    _collect_my_scalar_decls($stmts, \@cands);
    # Shadowing guard: a name declared with `my` more than once in this scope
    # could refer to different (possibly non-int) variables — exclude it.
    my hash %__decl_count = ();
    my int $ci = 0;
    while ($ci < scalar(@cands)) {
        my str $cn = "" . $cands[$ci]->[0];
        $__decl_count{$cn} = (defined($__decl_count{$cn}) ? $__decl_count{$cn} : 0) + 1;
        $ci = $ci + 1;
    }
    my int $i = 0;
    while ($i < scalar(@cands)) {
        my str $nm = "" . $cands[$i]->[0];
        if ($__decl_count{$nm} == 1 && !defined($cg->{"int_vars"}->{$nm})
            && Perla::CodeGen::Predicate::local_int_eligible($stmts, $nm, $cands[$i]->[1]) == 1) {
            $cg->{"int_vars"}->{$nm} = 1;
        }
        $i = $i + 1;
    }
}

# int-var-aware variant of Predicate::expr_is_int: an N_SCALAR_VAR that the
# analysis proved int-eligible counts as int, and that flows through nested
# arithmetic. Everything else delegates to the pure predicate.
func _node_is_int(scalar $cg, scalar $node) int {
    if (!defined($node)) { return 0; }
    my int $t = $node->{"type"};
    if ($t == Perla::AST::N_SCALAR_VAR()) {
        if (defined($cg->{"int_vars"}) && defined($node->{"name"})
            && defined($cg->{"int_vars"}->{"" . $node->{"name"}})) { return 1; }
        return 0;
    }
    if ($t == Perla::AST::N_BINOP()) {
        my str $op = "" . $node->{"op"};
        if ($op eq "==" || $op eq "!=" || $op eq "<" || $op eq ">" || $op eq "<=" || $op eq ">="
            || $op eq "<=>" || $op eq "%"
            || $op eq "&" || $op eq "|" || $op eq "^" || $op eq "<<" || $op eq ">>") { return 1; }
        if ($op eq "+" || $op eq "-" || $op eq "*") {
            if (_node_is_int($cg, $node->{"left"}) == 1 && _node_is_int($cg, $node->{"right"}) == 1) { return 1; }
            return 0;
        }
        return 0;
    }
    if ($t == Perla::AST::N_UNOP()) {
        my str $op = "" . $node->{"op"};
        if ($op eq "!" || $op eq "not" || $op eq "++" || $op eq "--") { return 1; }
        return 0;
    }
    return Perla::CodeGen::Predicate::expr_is_int($node);
}

func gen_block_stmts(scalar $cg, scalar $node) void {
    my scalar $stmts = $node->{"stmts"};
    if (!defined($stmts)) { return; }
    my int $i = 0;
    while ($i < scalar(@{$stmts})) {
        my scalar $s = $stmts->[$i];
        if (defined($s)) { gen_stmt($cg, $s); }
        $i++;
    }
}

# Hoist `my` variable declarations from a loop body before the loop
# Emits `StradaValue *v_name = NULL;` for each scalar variable declared with `my` in the body
# and marks them as declared so the `my` inside the loop just does decref+assign
func _hoist_loop_vars(scalar $cg, scalar $node) void {
    if (!defined($node)) { return; }
    my scalar $stmts = $node->{"stmts"};
    if (!defined($stmts)) { return; }
    # Track hoisted C names so _gen_for_c can decref them at scope exit.
    # Without this, `my $obj` inside `for (my $i; ...) { ... }` holds the
    # last iter's value past the block; the C local goes out of scope and
    # the ref leaks. Caller resets/reads $cg->{"hoisted_loop_vars"}.
    if (!defined($cg->{"hoisted_loop_vars"})) { $cg->{"hoisted_loop_vars"} = []; }
    # For file-scope-tracked vars, the hoist's normal `v_X = NULL;` would
    # clobber the outer lexical that owns that static slot. Instead emit
    # `StradaValue *__hsv_<cname> = <cname>; <cname> = NULL;` to save
    # the outer pointer, and record the cname in `hoisted_shadows` so the
    # caller can emit the corresponding `<cname> = __hsv_<cname>;` restore
    # after the body's hoisted-vars decref runs.
    if (!defined($cg->{"hoisted_shadows"})) { $cg->{"hoisted_shadows"} = []; }
    my int $i = 0;
    while ($i < scalar(@{$stmts})) {
        my scalar $s = $stmts->[$i];
        if (defined($s) && $s->{"type"} == Perla::AST::N_MY()) {
            if (defined($s->{"var"})) {
                my str $vname = $s->{"var"}->{"value"};
                my str $hvt = "" . $s->{"var"}->{"type"};
                if (length($hvt) == 0) { $hvt = "SCALAR_VAR"; }
                my str $hcn = c_var_for_vtype($hvt, $vname);
                if (!defined($cg->{"declared_vars"}->{$hcn})) {
                    if (_is_file_scope($cg, $vname) == 1) {
                        ind($cg); emit($cg, "StradaValue *__hsv_" . $hcn . " = " . $hcn . "; " . $hcn . " = NULL;\n");
                        push(@{$cg->{"hoisted_shadows"}}, $hcn);
                    } else {
                        ind($cg); emit($cg, _my_prefix_vt($cg, $hvt, $vname) . $hcn . " = NULL;\n");
                    }
                    $cg->{"declared_vars"}->{$hcn} = 1;
                    push(@{$cg->{"hoisted_loop_vars"}}, $hcn);
                }
            }
            if (defined($s->{"vars"})) {
                my scalar $vars = $s->{"vars"};
                my int $vi = 0;
                while ($vi < scalar(@{$vars})) {
                    my str $vname = $vars->[$vi]->{"value"};
                    my str $hvt2 = "" . $vars->[$vi]->{"type"};
                    if (length($hvt2) == 0) { $hvt2 = "SCALAR_VAR"; }
                    my str $hcn2 = c_var_for_vtype($hvt2, $vname);
                    if (!defined($cg->{"declared_vars"}->{$hcn2})) {
                        if (_is_file_scope($cg, $vname) == 1) {
                            ind($cg); emit($cg, "StradaValue *__hsv_" . $hcn2 . " = " . $hcn2 . "; " . $hcn2 . " = NULL;\n");
                            push(@{$cg->{"hoisted_shadows"}}, $hcn2);
                        } else {
                            ind($cg); emit($cg, _my_prefix_vt($cg, $hvt2, $vname) . $hcn2 . " = NULL;\n");
                        }
                        $cg->{"declared_vars"}->{$hcn2} = 1;
                        push(@{$cg->{"hoisted_loop_vars"}}, $hcn2);
                    }
                    $vi++;
                }
            }
        }
        $i++;
    }
}

# Shallow-copy a hashref (values are scalars/ints). Returns a fresh hashref;
# undef in -> empty hashref out. Used to give if/else/do branches their own
# copy of cell-tracking maps so in-branch mutations don't leak across
# branches, and the pre-branch state is restored afterward.
func _cg_copy_int_hash(scalar $h) scalar {
    my hash %c = ();
    if (defined($h)) {
        my array @k = keys($h);
        my int $i = 0;
        while ($i < scalar(@k)) { $c{$k[$i]} = $h->{$k[$i]}; $i = $i + 1; }
    }
    return \%c;
}

# --- If/Unless ---
func _gen_if(scalar $cg, scalar $node) void {
    # `if (my $X = expr)` — the my-decl in the condition writes to the
    # file-scope-static v_X slot, which would corrupt outer $X for the
    # rest of the program. Detect that pattern, wrap the whole if/elsif/
    # else chain in a C block, save outer v_X, and restore after.
    my array @__if_shadowed = ();
    my scalar $__if_cond_node = $node->{"cond"};
    if (defined($__if_cond_node) && $__if_cond_node->{"type"} == Perla::AST::N_MY()) {
        my scalar $__if_my = $__if_cond_node;
        if (defined($__if_my->{"var"})) {
            my str $__if_vn = $__if_my->{"var"}->{"value"};
            if (_is_file_scope($cg, $__if_vn) == 1) {
                my str $__if_vt = "" . $__if_my->{"var"}->{"type"};
                if (length($__if_vt) == 0) { $__if_vt = "SCALAR_VAR"; }
                push(@__if_shadowed, c_var_for_vtype($__if_vt, $__if_vn));
            }
        }
        if (defined($__if_my->{"vars"})) {
            my int $__if_dvi = 0;
            while ($__if_dvi < scalar(@{$__if_my->{"vars"}})) {
                my scalar $__if_dv = $__if_my->{"vars"}->[$__if_dvi];
                my str $__if_dvn = $__if_dv->{"value"};
                if (_is_file_scope($cg, $__if_dvn) == 1) {
                    my str $__if_dvt = "" . $__if_dv->{"type"};
                    if (length($__if_dvt) == 0) { $__if_dvt = "SCALAR_VAR"; }
                    push(@__if_shadowed, c_var_for_vtype($__if_dvt, $__if_dvn));
                }
                $__if_dvi = $__if_dvi + 1;
            }
        }
    }
    if (scalar(@__if_shadowed) > 0) {
        ind($cg); emit($cg, "{\n");
        $cg->{"indent"} = $cg->{"indent"} + 1;
        my int $__if_shi = 0;
        while ($__if_shi < scalar(@__if_shadowed)) {
            my str $__if_shc = $__if_shadowed[$__if_shi];
            ind($cg); emit($cg, "StradaValue *__if_sav_" . $__if_shc . " = " . $__if_shc . "; " . $__if_shc . " = NULL;\n");
            $__if_shi = $__if_shi + 1;
        }
    }
    ind($cg);
    if ($node->{"type"} == Perla::AST::N_UNLESS()) {
        emit($cg, "if (!(");
        _gen_cond($cg, $node->{"cond"});
        emit($cg, "))");
    } else {
        emit($cg, "if (");
        _gen_cond($cg, $node->{"cond"});
        emit($cg, ")");
    }
    emit($cg, " {\n");
    $cg->{"indent"} = $cg->{"indent"} + 1;
    my str $body_key = "then";
    if ($node->{"type"} == Perla::AST::N_UNLESS()) { $body_key = "body"; }
    # Snapshot declared_vars: each C `{...}` is its own scope, so a `my $x`
    # declared in the if branch is NOT visible in the else branch's C
    # scope. Without restoring, the else branch sees `v_x` in declared_vars
    # and emits `strada_decref(v_x); v_x = NULL;` instead of
    # `StradaValue *v_x = NULL;` — leaving v_x undeclared in C.
    # Surfaced via Abe::Plugin::Excel::_write_field with two elsif branches
    # both doing `my ($month, $day, $year) = ...`.
    my scalar $__if_saved_dv = $cg->{"declared_vars"};
    my scalar $__if_saved_ssd = $cg->{"same_scope_decls"};
    # Also snapshot shared_cells_emitted / closure_cell_mirror — two
    # mutually-exclusive if branches that each build a closure capturing
    # the same var must each emit their own cell allocation. Without
    # reset, branch 2 sees branch 1's cell as "already emitted" and skips
    # the malloc — the closure's captures[N] then points at an
    # uninitialized __perla_cell entry and segfaults on first invocation.
    my scalar $__if_saved_sc = $cg->{"shared_cells_emitted"};
    my scalar $__if_saved_cm = $cg->{"closure_cell_mirror"};
    # cells_malloc_d must move in lockstep with shared_cells_emitted: the
    # reuse-incref decision keys on cells_malloc_d[var]==1, so if it desyncs
    # (branch sets it then the branch is restored while cells_malloc_d isn't)
    # a later closure reusing the cell skips its incref -> double-free.
    my scalar $__if_saved_cmd = $cg->{"cells_malloc_d"};
    my hash %__if_branch_dv = ();
    my array @__if_dvk = keys($__if_saved_dv);
    my int $__if_dvi = 0;
    while ($__if_dvi < scalar(@__if_dvk)) {
        $__if_branch_dv{$__if_dvk[$__if_dvi]} = $__if_saved_dv->{$__if_dvk[$__if_dvi]};
        $__if_dvi++;
    }
    $cg->{"declared_vars"} = \%__if_branch_dv;
    $cg->{"same_scope_decls"} = {};
    if (defined($__if_saved_sc)) {
        my hash %__if_branch_sc = ();
        my array @__if_sck = keys($__if_saved_sc);
        my int $__if_sci = 0;
        while ($__if_sci < scalar(@__if_sck)) {
            $__if_branch_sc{$__if_sck[$__if_sci]} = $__if_saved_sc->{$__if_sck[$__if_sci]};
            $__if_sci++;
        }
        $cg->{"shared_cells_emitted"} = \%__if_branch_sc;
    }
    if (defined($__if_saved_cm)) {
        my hash %__if_branch_cm = ();
        my array @__if_cmk = keys($__if_saved_cm);
        my int $__if_cmi = 0;
        while ($__if_cmi < scalar(@__if_cmk)) {
            $__if_branch_cm{$__if_cmk[$__if_cmi]} = $__if_saved_cm->{$__if_cmk[$__if_cmi]};
            $__if_cmi++;
        }
        $cg->{"closure_cell_mirror"} = \%__if_branch_cm;
    }
    if (defined($__if_saved_cmd)) { $cg->{"cells_malloc_d"} = _cg_copy_int_hash($__if_saved_cmd); }
    # Hoist body's my-vars and decref at branch exit. Without this,
    # `if (COND) { my $w = $1; ...; }` left v_w's value stranded in the
    # C scope when the if-block ended, leaking once per evaluation.
    my scalar $__if_saved_hoisted = $cg->{"hoisted_loop_vars"};
    my scalar $__if_saved_shadows = $cg->{"hoisted_shadows"};
    $cg->{"hoisted_loop_vars"} = [];
    $cg->{"hoisted_shadows"} = [];
    _hoist_loop_vars($cg, $node->{$body_key});
    my scalar $__if_this_hoisted = $cg->{"hoisted_loop_vars"};
    my scalar $__if_this_shadows = $cg->{"hoisted_shadows"};
    # Collect top-level scalar `my $x` decls in the if-branch body so
    # we can decref + NULL them at branch close — matches Perl's
    # block-scoped DESTROY: `if (cond) { my $g = Guard->new; ... }`
    # fires DESTROY at the if-block's close. Same pattern as the
    # sub-local cleanup (Subs.strada); just narrower scope.
    #
    # Two paths: (1) the branch falls through normally — emit decref
    # at the end of the branch body. (2) a `return` inside the body
    # exits early — N_RETURN's cleanup walk handles it via the
    # extended sub_local_scalars list (push our locals, restore after).
    my array @__if_then_locals = ();
    if (defined($node->{$body_key}) && defined($node->{$body_key}->{"stmts"})) {
        my scalar $__ifts = $node->{$body_key}->{"stmts"};
        my int $__ifti = 0;
        while ($__ifti < scalar(@{$__ifts})) {
            my scalar $__iftss = $__ifts->[$__ifti];
            if (defined($__iftss) && $__iftss->{"type"} == Perla::AST::N_MY()
                && defined($__iftss->{"var"})) {
                my str $__iftvt = "" . $__iftss->{"var"}->{"type"};
                if (length($__iftvt) == 0) { $__iftvt = "SCALAR_VAR"; }
                if ($__iftvt eq "SCALAR_VAR") {
                    push(@__if_then_locals, $__iftss->{"var"}->{"value"});
                }
            }
            $__ifti = $__ifti + 1;
        }
    }
    # Extend sub_local_scalars so any nested N_RETURN cleans up these
    # if-branch locals before exiting the sub. Restore the original
    # list after gen_block_stmts returns.
    my scalar $__if_t_sls_saved = $cg->{"sub_local_scalars"};
    if (scalar(@__if_then_locals) > 0) {
        my array @__if_t_sls_ext = ();
        if (defined($__if_t_sls_saved)) {
            my int $__sse_i = 0;
            while ($__sse_i < scalar(@{$__if_t_sls_saved})) {
                push(@__if_t_sls_ext, $__if_t_sls_saved->[$__sse_i]);
                $__sse_i = $__sse_i + 1;
            }
        }
        my int $__add_i = 0;
        while ($__add_i < scalar(@__if_then_locals)) {
            push(@__if_t_sls_ext, $__if_then_locals[$__add_i]);
            $__add_i = $__add_i + 1;
        }
        $cg->{"sub_local_scalars"} = \@__if_t_sls_ext;
    }
    gen_block_stmts($cg, $node->{$body_key});
    $cg->{"sub_local_scalars"} = $__if_t_sls_saved;
    my int $__if_hi = 0;
    while ($__if_hi < scalar(@{$__if_this_hoisted})) {
        ind($cg); emit($cg, "strada_decref(" . $__if_this_hoisted->[$__if_hi] . ");\n");
        $__if_hi = $__if_hi + 1;
    }
    # Emit decref+NULL for collected then-body my-decls at branch end
    # (covers the fall-through path; the return path was handled by the
    # sub_local_scalars extension above).
    my int $__iftl_i = 0;
    while ($__iftl_i < scalar(@__if_then_locals)) {
        my str $__iftl_cv = c_var($__if_then_locals[$__iftl_i]);
        ind($cg); emit($cg, "if (" . $__iftl_cv . ") { strada_decref(" . $__iftl_cv . "); " . $__iftl_cv . " = NULL; }\n");
        $__iftl_i = $__iftl_i + 1;
    }
    # Restore file-scope shadows: outer pointer was saved into __hsv_<cn>
    # at hoist time; the decref above freed the inner value, now point
    # the static slot back at the outer.
    my int $__if_sri = 0;
    while ($__if_sri < scalar(@{$__if_this_shadows})) {
        my str $__if_src = $__if_this_shadows->[$__if_sri];
        ind($cg); emit($cg, $__if_src . " = __hsv_" . $__if_src . ";\n");
        $__if_sri = $__if_sri + 1;
    }
    $cg->{"hoisted_loop_vars"} = $__if_saved_hoisted;
    $cg->{"hoisted_shadows"} = $__if_saved_shadows;
    $cg->{"declared_vars"} = $__if_saved_dv;
    $cg->{"same_scope_decls"} = $__if_saved_ssd;
    $cg->{"shared_cells_emitted"} = $__if_saved_sc;
    $cg->{"closure_cell_mirror"} = $__if_saved_cm;
    $cg->{"cells_malloc_d"} = $__if_saved_cmd;
    $cg->{"indent"} = $cg->{"indent"} - 1;
    ind($cg); emit($cg, "}");
    if (defined($node->{"else"})) {
        emit($cg, " else ");
        if ($node->{"else"}->{"type"} == Perla::AST::N_IF()) {
            _gen_if($cg, $node->{"else"});
            # Emit the if-my close+restore BEFORE the early return so the
            # outermost call's wrap is properly terminated. Inner calls
            # have empty @__if_shadowed and emit nothing here.
            if (scalar(@__if_shadowed) > 0) {
                my int $__if_rsi = 0;
                while ($__if_rsi < scalar(@__if_shadowed)) {
                    my str $__if_rsc = $__if_shadowed[$__if_rsi];
                    ind($cg); emit($cg, "if (" . $__if_rsc . ") strada_decref(" . $__if_rsc . "); " . $__if_rsc . " = __if_sav_" . $__if_rsc . ";\n");
                    $__if_rsi = $__if_rsi + 1;
                }
                $cg->{"indent"} = $cg->{"indent"} - 1;
                ind($cg); emit($cg, "}\n");
            }
            return;
        }
        emit($cg, "{\n");
        $cg->{"indent"} = $cg->{"indent"} + 1;
        # Same scope-restore for the else branch.
        my hash %__if_else_dv = ();
        my array @__if_e_dvk = keys($__if_saved_dv);
        my int $__if_e_dvi = 0;
        while ($__if_e_dvi < scalar(@__if_e_dvk)) {
            $__if_else_dv{$__if_e_dvk[$__if_e_dvi]} = $__if_saved_dv->{$__if_e_dvk[$__if_e_dvi]};
            $__if_e_dvi++;
        }
        $cg->{"declared_vars"} = \%__if_else_dv;
        $cg->{"same_scope_decls"} = {};
        if (defined($__if_saved_sc)) {
            my hash %__if_else_sc = ();
            my array @__if_e_sck = keys($__if_saved_sc);
            my int $__if_e_sci = 0;
            while ($__if_e_sci < scalar(@__if_e_sck)) {
                $__if_else_sc{$__if_e_sck[$__if_e_sci]} = $__if_saved_sc->{$__if_e_sck[$__if_e_sci]};
                $__if_e_sci++;
            }
            $cg->{"shared_cells_emitted"} = \%__if_else_sc;
        }
        if (defined($__if_saved_cm)) {
            my hash %__if_else_cm = ();
            my array @__if_e_cmk = keys($__if_saved_cm);
            my int $__if_e_cmi = 0;
            while ($__if_e_cmi < scalar(@__if_e_cmk)) {
                $__if_else_cm{$__if_e_cmk[$__if_e_cmi]} = $__if_saved_cm->{$__if_e_cmk[$__if_e_cmi]};
                $__if_e_cmi++;
            }
            $cg->{"closure_cell_mirror"} = \%__if_else_cm;
        }
        if (defined($__if_saved_cmd)) { $cg->{"cells_malloc_d"} = _cg_copy_int_hash($__if_saved_cmd); }
        # Same hoist + shadow handling as the then-branch.
        my scalar $__if_e_saved_hoisted = $cg->{"hoisted_loop_vars"};
        my scalar $__if_e_saved_shadows = $cg->{"hoisted_shadows"};
        $cg->{"hoisted_loop_vars"} = [];
        $cg->{"hoisted_shadows"} = [];
        _hoist_loop_vars($cg, $node->{"else"});
        my scalar $__if_e_this_hoisted = $cg->{"hoisted_loop_vars"};
        my scalar $__if_e_this_shadows = $cg->{"hoisted_shadows"};
        # Collect top-level scalar my-decls in else-body (see then-body
        # comment above).
        my array @__if_else_locals = ();
        if (defined($node->{"else"}) && defined($node->{"else"}->{"stmts"})) {
            my scalar $__ifes = $node->{"else"}->{"stmts"};
            my int $__ifei = 0;
            while ($__ifei < scalar(@{$__ifes})) {
                my scalar $__ifess = $__ifes->[$__ifei];
                if (defined($__ifess) && $__ifess->{"type"} == Perla::AST::N_MY()
                    && defined($__ifess->{"var"})) {
                    my str $__ifevt = "" . $__ifess->{"var"}->{"type"};
                    if (length($__ifevt) == 0) { $__ifevt = "SCALAR_VAR"; }
                    if ($__ifevt eq "SCALAR_VAR") {
                        push(@__if_else_locals, $__ifess->{"var"}->{"value"});
                    }
                }
                $__ifei = $__ifei + 1;
            }
        }
        # Extend sub_local_scalars (see then-branch comment).
        my scalar $__if_e_sls_saved = $cg->{"sub_local_scalars"};
        if (scalar(@__if_else_locals) > 0) {
            my array @__if_e_sls_ext = ();
            if (defined($__if_e_sls_saved)) {
                my int $__esse_i = 0;
                while ($__esse_i < scalar(@{$__if_e_sls_saved})) {
                    push(@__if_e_sls_ext, $__if_e_sls_saved->[$__esse_i]);
                    $__esse_i = $__esse_i + 1;
                }
            }
            my int $__eadd_i = 0;
            while ($__eadd_i < scalar(@__if_else_locals)) {
                push(@__if_e_sls_ext, $__if_else_locals[$__eadd_i]);
                $__eadd_i = $__eadd_i + 1;
            }
            $cg->{"sub_local_scalars"} = \@__if_e_sls_ext;
        }
        gen_block_stmts($cg, $node->{"else"});
        $cg->{"sub_local_scalars"} = $__if_e_sls_saved;
        my int $__if_e_hi = 0;
        while ($__if_e_hi < scalar(@{$__if_e_this_hoisted})) {
            ind($cg); emit($cg, "strada_decref(" . $__if_e_this_hoisted->[$__if_e_hi] . ");\n");
            $__if_e_hi = $__if_e_hi + 1;
        }
        # Emit decref+NULL for else-body my-decls.
        my int $__ifel_i = 0;
        while ($__ifel_i < scalar(@__if_else_locals)) {
            my str $__ifel_cv = c_var($__if_else_locals[$__ifel_i]);
            ind($cg); emit($cg, "if (" . $__ifel_cv . ") { strada_decref(" . $__ifel_cv . "); " . $__ifel_cv . " = NULL; }\n");
            $__ifel_i = $__ifel_i + 1;
        }
        my int $__if_e_sri = 0;
        while ($__if_e_sri < scalar(@{$__if_e_this_shadows})) {
            my str $__if_e_src = $__if_e_this_shadows->[$__if_e_sri];
            ind($cg); emit($cg, $__if_e_src . " = __hsv_" . $__if_e_src . ";\n");
            $__if_e_sri = $__if_e_sri + 1;
        }
        $cg->{"hoisted_loop_vars"} = $__if_e_saved_hoisted;
        $cg->{"hoisted_shadows"} = $__if_e_saved_shadows;
        $cg->{"declared_vars"} = $__if_saved_dv;
        $cg->{"same_scope_decls"} = $__if_saved_ssd;
        $cg->{"shared_cells_emitted"} = $__if_saved_sc;
        $cg->{"closure_cell_mirror"} = $__if_saved_cm;
        $cg->{"cells_malloc_d"} = $__if_saved_cmd;
        $cg->{"indent"} = $cg->{"indent"} - 1;
        ind($cg); emit($cg, "}");
    }
    emit($cg, "\n");
    # Emit the if-my close+restore for the case where this _gen_if call
    # is the chain terminus (no elsif beyond this point).
    if (scalar(@__if_shadowed) > 0) {
        my int $__if_rsi2 = 0;
        while ($__if_rsi2 < scalar(@__if_shadowed)) {
            my str $__if_rsc2 = $__if_shadowed[$__if_rsi2];
            ind($cg); emit($cg, "if (" . $__if_rsc2 . ") strada_decref(" . $__if_rsc2 . "); " . $__if_rsc2 . " = __if_sav_" . $__if_rsc2 . ";\n");
            $__if_rsi2 = $__if_rsi2 + 1;
        }
        $cg->{"indent"} = $cg->{"indent"} - 1;
        ind($cg); emit($cg, "}\n");
    }
}

# As _gen_if, but each branch's last statement (if it's an expression) is
# captured into $ret_var, mirroring Perl's implicit-return-from-if semantics
# at the tail of a sub or do{} block:
#
#   sub schema {
#     if (...) { 5 }
#     else    { 10 }   # the function returns 5 or 10
#   }
#
# Without this, perla's sub-body codegen treats N_IF as a bare statement and
# always falls through to `return strada_undef_static();`. Surfaced via
# DBIC's `sub schema { if (@_>1) {...} else { $self->{schema} || do {...} } }`
# where the schema accessor silently returned undef even when the slot was
# populated, breaking storage()/relname_to_table_alias()/_resolve_join().
func gen_if_capture_return(scalar $cg, scalar $node, str $ret_var) void {
    # Same if-my shadow wrap as _gen_if (see comment there).
    my array @__icr_shadowed = ();
    my scalar $__icr_cond_node = $node->{"cond"};
    if (defined($__icr_cond_node) && $__icr_cond_node->{"type"} == Perla::AST::N_MY()) {
        my scalar $__icr_my = $__icr_cond_node;
        if (defined($__icr_my->{"var"})) {
            my str $__icr_vn = $__icr_my->{"var"}->{"value"};
            if (_is_file_scope($cg, $__icr_vn) == 1) {
                my str $__icr_vt = "" . $__icr_my->{"var"}->{"type"};
                if (length($__icr_vt) == 0) { $__icr_vt = "SCALAR_VAR"; }
                push(@__icr_shadowed, c_var_for_vtype($__icr_vt, $__icr_vn));
            }
        }
        if (defined($__icr_my->{"vars"})) {
            my int $__icr_dvi = 0;
            while ($__icr_dvi < scalar(@{$__icr_my->{"vars"}})) {
                my scalar $__icr_dv = $__icr_my->{"vars"}->[$__icr_dvi];
                my str $__icr_dvn = $__icr_dv->{"value"};
                if (_is_file_scope($cg, $__icr_dvn) == 1) {
                    my str $__icr_dvt = "" . $__icr_dv->{"type"};
                    if (length($__icr_dvt) == 0) { $__icr_dvt = "SCALAR_VAR"; }
                    push(@__icr_shadowed, c_var_for_vtype($__icr_dvt, $__icr_dvn));
                }
                $__icr_dvi = $__icr_dvi + 1;
            }
        }
    }
    if (scalar(@__icr_shadowed) > 0) {
        ind($cg); emit($cg, "{\n");
        $cg->{"indent"} = $cg->{"indent"} + 1;
        my int $__icr_shi = 0;
        while ($__icr_shi < scalar(@__icr_shadowed)) {
            my str $__icr_shc = $__icr_shadowed[$__icr_shi];
            ind($cg); emit($cg, "StradaValue *__icr_sav_" . $__icr_shc . " = " . $__icr_shc . "; " . $__icr_shc . " = NULL;\n");
            $__icr_shi = $__icr_shi + 1;
        }
    }
    ind($cg);
    if ($node->{"type"} == Perla::AST::N_UNLESS()) {
        emit($cg, "if (!(");
        _gen_cond($cg, $node->{"cond"});
        emit($cg, "))");
    } else {
        emit($cg, "if (");
        _gen_cond($cg, $node->{"cond"});
        emit($cg, ")");
    }
    emit($cg, " {\n");
    $cg->{"indent"} = $cg->{"indent"} + 1;
    my str $body_key = "then";
    if ($node->{"type"} == Perla::AST::N_UNLESS()) { $body_key = "body"; }
    # Snapshot/restore declared_vars per branch (see _gen_if comment).
    my scalar $__icr_saved = $cg->{"declared_vars"};
    my scalar $__icr_saved_ssd = $cg->{"same_scope_decls"};
    # Snapshot shared_cells_emitted per branch — without this, two
    # mutually-exclusive branches that each build a closure capturing the
    # same var share state: the second branch sees the first's cell as
    # already-emitted and SKIPS its own malloc, then the closure's
    # captures[N] = NULL → segfault when invoked.
    my scalar $__icr_saved_sc = $cg->{"shared_cells_emitted"};
    my scalar $__icr_saved_cm = $cg->{"closure_cell_mirror"};
    my scalar $__icr_saved_cmd = $cg->{"cells_malloc_d"};
    my hash %__icr_b1 = ();
    my array @__icr_k1 = keys($__icr_saved);
    my int $__icr_i1 = 0;
    while ($__icr_i1 < scalar(@__icr_k1)) {
        $__icr_b1{$__icr_k1[$__icr_i1]} = $__icr_saved->{$__icr_k1[$__icr_i1]};
        $__icr_i1++;
    }
    $cg->{"declared_vars"} = \%__icr_b1;
    $cg->{"same_scope_decls"} = {};
    # Reset shared cells state to pre-if snapshot (clone, not alias).
    if (defined($__icr_saved_sc)) {
        my hash %__icr_b1_sc = ();
        my array @__sc_k1 = keys($__icr_saved_sc);
        my int $__sc_i1 = 0;
        while ($__sc_i1 < scalar(@__sc_k1)) {
            $__icr_b1_sc{$__sc_k1[$__sc_i1]} = $__icr_saved_sc->{$__sc_k1[$__sc_i1]};
            $__sc_i1++;
        }
        $cg->{"shared_cells_emitted"} = \%__icr_b1_sc;
    }
    if (defined($__icr_saved_cm)) {
        my hash %__icr_b1_cm = ();
        my array @__cm_k1 = keys($__icr_saved_cm);
        my int $__cm_i1 = 0;
        while ($__cm_i1 < scalar(@__cm_k1)) {
            $__icr_b1_cm{$__cm_k1[$__cm_i1]} = $__icr_saved_cm->{$__cm_k1[$__cm_i1]};
            $__cm_i1++;
        }
        $cg->{"closure_cell_mirror"} = \%__icr_b1_cm;
    }
    if (defined($__icr_saved_cmd)) { $cg->{"cells_malloc_d"} = _cg_copy_int_hash($__icr_saved_cmd); }
    _gen_block_stmts_capture_return($cg, $node->{$body_key}, $ret_var);
    $cg->{"declared_vars"} = $__icr_saved;
    $cg->{"same_scope_decls"} = $__icr_saved_ssd;
    $cg->{"shared_cells_emitted"} = $__icr_saved_sc;
    $cg->{"closure_cell_mirror"} = $__icr_saved_cm;
    $cg->{"cells_malloc_d"} = $__icr_saved_cmd;
    $cg->{"indent"} = $cg->{"indent"} - 1;
    ind($cg); emit($cg, "}");
    if (defined($node->{"else"})) {
        emit($cg, " else ");
        if ($node->{"else"}->{"type"} == Perla::AST::N_IF()) {
            gen_if_capture_return($cg, $node->{"else"}, $ret_var);
            # if-my close+restore for outer call (see _gen_if).
            if (scalar(@__icr_shadowed) > 0) {
                my int $__icr_rsi = 0;
                while ($__icr_rsi < scalar(@__icr_shadowed)) {
                    my str $__icr_rsc = $__icr_shadowed[$__icr_rsi];
                    ind($cg); emit($cg, "if (" . $__icr_rsc . ") strada_decref(" . $__icr_rsc . "); " . $__icr_rsc . " = __icr_sav_" . $__icr_rsc . ";\n");
                    $__icr_rsi = $__icr_rsi + 1;
                }
                $cg->{"indent"} = $cg->{"indent"} - 1;
                ind($cg); emit($cg, "}\n");
            }
            return;
        }
        emit($cg, "{\n");
        $cg->{"indent"} = $cg->{"indent"} + 1;
        my hash %__icr_b2 = ();
        my array @__icr_k2 = keys($__icr_saved);
        my int $__icr_i2 = 0;
        while ($__icr_i2 < scalar(@__icr_k2)) {
            $__icr_b2{$__icr_k2[$__icr_i2]} = $__icr_saved->{$__icr_k2[$__icr_i2]};
            $__icr_i2++;
        }
        $cg->{"declared_vars"} = \%__icr_b2;
        $cg->{"same_scope_decls"} = {};
        if (defined($__icr_saved_sc)) {
            my hash %__icr_b2_sc = ();
            my array @__sc_k2 = keys($__icr_saved_sc);
            my int $__sc_i2 = 0;
            while ($__sc_i2 < scalar(@__sc_k2)) {
                $__icr_b2_sc{$__sc_k2[$__sc_i2]} = $__icr_saved_sc->{$__sc_k2[$__sc_i2]};
                $__sc_i2++;
            }
            $cg->{"shared_cells_emitted"} = \%__icr_b2_sc;
        }
        if (defined($__icr_saved_cm)) {
            my hash %__icr_b2_cm = ();
            my array @__cm_k2 = keys($__icr_saved_cm);
            my int $__cm_i2 = 0;
            while ($__cm_i2 < scalar(@__cm_k2)) {
                $__icr_b2_cm{$__cm_k2[$__cm_i2]} = $__icr_saved_cm->{$__cm_k2[$__cm_i2]};
                $__cm_i2++;
            }
            $cg->{"closure_cell_mirror"} = \%__icr_b2_cm;
        }
        if (defined($__icr_saved_cmd)) { $cg->{"cells_malloc_d"} = _cg_copy_int_hash($__icr_saved_cmd); }
        _gen_block_stmts_capture_return($cg, $node->{"else"}, $ret_var);
        $cg->{"declared_vars"} = $__icr_saved;
        $cg->{"same_scope_decls"} = $__icr_saved_ssd;
        $cg->{"shared_cells_emitted"} = $__icr_saved_sc;
        $cg->{"closure_cell_mirror"} = $__icr_saved_cm;
        $cg->{"cells_malloc_d"} = $__icr_saved_cmd;
        $cg->{"indent"} = $cg->{"indent"} - 1;
        ind($cg); emit($cg, "}");
    }
    emit($cg, "\n");
    # if-my close+restore — chain terminus.
    if (scalar(@__icr_shadowed) > 0) {
        my int $__icr_rsi2 = 0;
        while ($__icr_rsi2 < scalar(@__icr_shadowed)) {
            my str $__icr_rsc2 = $__icr_shadowed[$__icr_rsi2];
            ind($cg); emit($cg, "if (" . $__icr_rsc2 . ") strada_decref(" . $__icr_rsc2 . "); " . $__icr_rsc2 . " = __icr_sav_" . $__icr_rsc2 . ";\n");
            $__icr_rsi2 = $__icr_rsi2 + 1;
        }
        $cg->{"indent"} = $cg->{"indent"} - 1;
        ind($cg); emit($cg, "}\n");
    }
}

# Emit a block-node's stmts where the last stmt — if it's an expression —
# is captured into $ret_var. If the last stmt is itself an if/unless, recurse
# so each branch's tail also captures. Other control-flow stmts (return,
# while, for, etc.) are emitted as-is and don't update $ret_var.
# Mirrors gen_block_stmts: takes a node and reads its "stmts" array.
func _gen_block_stmts_capture_return(scalar $cg, scalar $node, str $ret_var) void {
    if (!defined($node)) { return; }
    my scalar $stmts = $node->{"stmts"};
    if (!defined($stmts)) { return; }
    my int $n = scalar(@{$stmts});
    if ($n == 0) { return; }
    my int $i = 0;
    while ($i < $n - 1) {
        gen_stmt($cg, $stmts->[$i]);
        $i++;
    }
    my scalar $last = $stmts->[$n - 1];
    if (!defined($last)) { return; }
    my int $lt = $last->{"type"};
    if ($lt == Perla::AST::N_IF() || $lt == Perla::AST::N_UNLESS()) {
        gen_if_capture_return($cg, $last, $ret_var);
    } elsif ($lt == Perla::AST::N_SUB() && !defined($last->{"name"})) {
        # Anonymous sub { ... } as the last statement of a branch is an
        # expression (closure literal). Capture it as the return value;
        # otherwise the closure is emitted as a statement and the if/else
        # branches yield nothing, breaking `if ... { sub {...} } else { sub {...} }`
        # idioms — common when building dispatch tables conditionally.
        ind($cg); emit($cg, "{ StradaValue *__cap = ");
        gen_expr_safe($cg, $last);
        emit($cg, "; if (__cap) strada_incref(__cap); if (" . $ret_var . ") strada_decref(" . $ret_var . "); " . $ret_var . " = __cap; }\n");
    } elsif ($lt == Perla::AST::N_RETURN() || $lt == Perla::AST::N_WHILE()
             || $lt == Perla::AST::N_UNTIL() || $lt == Perla::AST::N_FOR_C()
             || $lt == Perla::AST::N_FOREACH() || $lt == Perla::AST::N_SUB()
             || $lt == Perla::AST::N_PACKAGE() || $lt == Perla::AST::N_USE()
             || $lt == Perla::AST::N_BEGIN() || $lt == Perla::AST::N_END()
             || $lt == Perla::AST::N_GOTO_SUB()) {
        gen_stmt($cg, $last);
    } else {
        ind($cg); emit($cg, "{ StradaValue *__cap = ");
        gen_expr_safe($cg, $last);
        emit($cg, "; if (__cap) strada_incref(__cap); if (" . $ret_var . ") strada_decref(" . $ret_var . "); " . $ret_var . " = __cap; }\n");
    }
}

# --- While/Until ---
# Track whether we're inside any kind of C loop so bare last/next/redo can
# decide whether a plain break/continue/goto is safe. Set to 1 on entry to
# _gen_while / _gen_foreach / _gen_for_c and restored on exit.
func _gen_while(scalar $cg, scalar $node) void {
    my int $__old_in_loop = 0;
    if (defined($cg->{"in_loop"})) { $__old_in_loop = $cg->{"in_loop"}; }
    $cg->{"in_loop"} = 1;
    _gen_while_inner($cg, $node);
    $cg->{"in_loop"} = $__old_in_loop;
}

func _gen_while_inner(scalar $cg, scalar $node) void {
    my str $label = "";
    my str $user_label = "";
    if (defined($node->{"label"})) {
        $user_label = $node->{"label"};
        $cg->{"label_count"} = $cg->{"label_count"} + 1;
        $label = $user_label . "_" . $cg->{"label_count"};
        $cg->{"label_map"}->{$user_label} = $label;
    }
    if (length($label) > 0) {
        ind($cg); emit($cg, "__perla_redo_" . $label . ":\n");
    }
    # Handle: while (my $var = <$fh>) { ... }
    if (defined($node->{"init_my"})) {
        # Wrap in a block for the declared variable's scope
        ind($cg); emit($cg, "{\n");
        $cg->{"indent"} = $cg->{"indent"} + 1;
        # Declare the variable (without init — loop body does the assignment)
        my scalar $init_my_node = $node->{"init_my"};
        if (defined($init_my_node->{"var"})) {
            my str $imv = $init_my_node->{"var"}->{"value"};
            my str $imvt = "" . $init_my_node->{"var"}->{"type"};
            if (length($imvt) == 0) { $imvt = "SCALAR_VAR"; }
            my str $imcn = c_var_for_vtype($imvt, $imv);
            my str $wh_prefix = "StradaValue *";
            # Check if this is a closure capture
            if (defined($cg->{"capture_vars"})) {
                my str $cv_check = "" . $cg->{"capture_vars"}->{$imcn};
                if (length($cv_check) > 0) { $wh_prefix = ""; }
            }
            # Track the declaration so strict-vars and de-dupe checks see it.
            if (defined($cg->{"declared_vars"})) {
                $cg->{"declared_vars"}->{$imcn} = 1;
            }
            ind($cg); emit($cg, $wh_prefix . $imcn . " = strada_new_undef();\n");
        } elsif (defined($init_my_node->{"vars"})) {
            # Plural destructuring: while (my ($k, $v) = each %h) — declare each as NULL
            my scalar $plvars = $init_my_node->{"vars"};
            my int $pvi = 0;
            while ($pvi < scalar(@{$plvars})) {
                my str $pvn = $plvars->[$pvi]->{"value"};
                my str $pvt = "" . $plvars->[$pvi]->{"type"};
                if (length($pvt) == 0) { $pvt = "SCALAR_VAR"; }
                my str $pvcn = c_var_for_vtype($pvt, $pvn);
                my str $pwh_prefix = "StradaValue *";
                if (defined($cg->{"capture_vars"})) {
                    my str $cv_check2 = "" . $cg->{"capture_vars"}->{$pvcn};
                    if (length($cv_check2) > 0) { $pwh_prefix = ""; }
                }
                if (defined($cg->{"declared_vars"})) {
                    $cg->{"declared_vars"}->{$pvcn} = 1;
                }
                ind($cg); emit($cg, $pwh_prefix . $pvcn . " = NULL;\n");
                $pvi++;
            }
        }
        # Generate while loop — condition re-assigns and checks defined
        ind($cg); emit($cg, "while (1) {\n");
        $cg->{"indent"} = $cg->{"indent"} + 1;
        # Per-iteration local-chain snapshot.
        ind($cg); emit($cg, "void *__w_local_mark_im = __perla_local_chain;\n");
        # Re-assign: $var = <$fh>
        my scalar $init_my = $node->{"init_my"};
        if (defined($init_my->{"var"}) && defined($init_my->{"init"})) {
            my str $imv2 = $init_my->{"var"}->{"value"};
            my str $imvt2 = "" . $init_my->{"var"}->{"type"};
            if (length($imvt2) == 0) { $imvt2 = "SCALAR_VAR"; }
            my str $vname = c_var_for_vtype($imvt2, $imv2);
            # Force list context for ARRAY_VAR / HASH_VAR targets so the
            # RHS doesn't collapse to last-element / entry-count when
            # __perla_want_list is 0 at the surrounding block scope.
            my int $is_listy = ($imvt2 eq "ARRAY_VAR" || $imvt2 eq "HASH_VAR") ? 1 : 0;
            if ($is_listy == 1) {
                ind($cg); emit($cg, $vname . " = ({ int __sav_wl_wm = __perla_want_list; __perla_want_list = 1; StradaValue *__wm_v = ");
                gen_expr($cg, $init_my->{"init"});
                emit($cg, "; __perla_want_list = __sav_wl_wm; __wm_v; });\n");
                # Array/hash boolean: non-empty is true, empty is false.
                # `defined_bool` on a freshly-allocated empty array still
                # returns true, so `while (my @c = splice(...))` looped
                # forever — splice returned an empty array, the loop
                # never broke. Check size > 0 instead.
                if ($imvt2 eq "ARRAY_VAR") {
                    ind($cg); emit($cg, "{ StradaArray *__wm_av = strada_deref_array(" . $vname . "); if (!__wm_av || __wm_av->size == 0) break; }\n");
                } else {
                    ind($cg); emit($cg, "{ StradaHash *__wm_hv = strada_deref_hash(" . $vname . "); if (!__wm_hv || __wm_hv->num_entries == 0) break; }\n");
                }
            } else {
                ind($cg); emit($cg, $vname . " = ");
                gen_expr($cg, $init_my->{"init"});
                emit($cg, ";\n");
                # Perl's `while (my $v = EXPR)` rule: when EXPR is
                # readline-like (<FH>, readline, m//g), auto-wrap in
                # defined() so empty-string lines/zero captures keep
                # the loop running. For other expressions, use plain
                # truthiness — `while (my $v = expr)` with expr
                # returning 0 / "" / undef should exit the loop.
                # Previously this path always used strada_defined_bool,
                # which kept the loop running for `my $v = 0` (`0` is
                # defined!) — an infinite loop for `while (my $v =
                # (cond ? "X" : 0))`.
                my int $imv_use_defined = 0;
                my scalar $imv_init = $init_my->{"init"};
                if (defined($imv_init)) {
                    my int $imv_init_t = $imv_init->{"type"};
                    if ($imv_init_t == Perla::AST::N_READLINE()) {
                        $imv_use_defined = 1;
                    }
                }
                if ($imv_use_defined == 1) {
                    ind($cg); emit($cg, "if (!strada_defined_bool(" . $vname . ")) break;\n");
                } else {
                    ind($cg); emit($cg, "if (!strada_to_bool(" . $vname . ")) break;\n");
                }
            }
        } elsif (defined($init_my->{"vars"}) && defined($init_my->{"init"})) {
            # Plural destructuring: eval in list context, break if empty list, destructure
            my scalar $dvars = $init_my->{"vars"};
            ind($cg); emit($cg, "{\n");
            $cg->{"indent"} = $cg->{"indent"} + 1;
            ind($cg); emit($cg, "int __sav_wl_wf = __perla_want_list; __perla_want_list = 1;\n");
            ind($cg); emit($cg, "StradaValue *__wl = ");
            gen_expr($cg, $init_my->{"init"});
            emit($cg, ";\n");
            ind($cg); emit($cg, "__perla_want_list = __sav_wl_wf;\n");
            ind($cg); emit($cg, "StradaArray *__wa = strada_deref_array(__wl);\n");
            ind($cg); emit($cg, "int __wlen = __wa ? strada_array_length(__wa) : 0;\n");
            ind($cg); emit($cg, "if (__wlen == 0) { strada_decref(__wl); break; }\n");
            my int $dvi = 0;
            while ($dvi < scalar(@{$dvars})) {
                my str $dvt3 = "" . $dvars->[$dvi]->{"type"};
                if (length($dvt3) == 0) { $dvt3 = "SCALAR_VAR"; }
                my str $dvn = c_var_for_vtype($dvt3, $dvars->[$dvi]->{"value"});
                ind($cg); emit($cg, "strada_decref(" . $dvn . "); ");
                emit($cg, $dvn . " = (" . $dvi . " < __wlen ? strada_array_get(__wa, " . $dvi . ") : strada_new_undef());\n");
                ind($cg); emit($cg, "if (" . $dvn . ") strada_incref(" . $dvn . ");\n");
                $dvi++;
            }
            ind($cg); emit($cg, "strada_decref(__wl);\n");
            $cg->{"indent"} = $cg->{"indent"} - 1;
            ind($cg); emit($cg, "}\n");
        }
        gen_block_stmts($cg, $node->{"body"});
        if (length($label) > 0) {
            ind($cg); emit($cg, "__perla_next_" . $label . ": ;\n");
        }
        if (defined($node->{"continue"})) {
            gen_block_stmts($cg, $node->{"continue"});
        }
        ind($cg); emit($cg, "if (__perla_local_chain != __w_local_mark_im) { perla_local_chain_restore_to(__perla_local_chain, __w_local_mark_im); __perla_local_chain = __w_local_mark_im; }\n");
        $cg->{"indent"} = $cg->{"indent"} - 1;
        ind($cg); emit($cg, "}\n");
        if (length($label) > 0) {
            ind($cg); emit($cg, "__perla_end_" . $label . ": ;\n");
        }
        $cg->{"indent"} = $cg->{"indent"} - 1;
        ind($cg); emit($cg, "}\n");
        return;
    }

    # Hoist loop body variable declarations before the loop
    ind($cg); emit($cg, "{\n");
    $cg->{"indent"} = $cg->{"indent"} + 1;
    my scalar $saved_declared = $cg->{"declared_vars"};
    my scalar $__w_saved_ssd = $cg->{"same_scope_decls"};
    $cg->{"declared_vars"} = {};
    $cg->{"same_scope_decls"} = {};
    # Copy parent declared vars so we don't re-hoist them
    my array @sdk = keys($saved_declared);
    my int $sdi = 0;
    while ($sdi < scalar(@sdk)) {
        $cg->{"declared_vars"}->{$sdk[$sdi]} = 1;
        $sdi++;
    }
    my scalar $__w_saved_shadows = $cg->{"hoisted_shadows"};
    $cg->{"hoisted_shadows"} = [];
    _hoist_loop_vars($cg, $node->{"body"});
    my scalar $__w_this_shadows = $cg->{"hoisted_shadows"};
    # Check if condition is a /g regex match — emit position variable
    # so the match advances between iterations. Handles both forms:
    # explicit `while (\$s =~ /pat/g)` (N_BINOP with op =~) and implicit
    # `while (/pat/g)` (standalone N_REGEX against \$_). Without the
    # standalone branch, implicit /g loops infinite-matched at pos 0.
    my str $saved_g_pos = "";
    if (defined($cg->{"regex_g_pos_var"})) { $saved_g_pos = $cg->{"regex_g_pos_var"}; }
    my scalar $cond = $node->{"cond"};
    my int $has_g = 0;
    if (defined($cond) && $cond->{"type"} == Perla::AST::N_BINOP() && $cond->{"op"} eq "=~") {
        my scalar $rr = $cond->{"right"};
        if (defined($rr) && $rr->{"type"} == Perla::AST::N_REGEX() && defined($rr->{"flags"}) && index($rr->{"flags"}, "g") >= 0) {
            $has_g = 1;
        }
    } elsif (defined($cond) && $cond->{"type"} == Perla::AST::N_REGEX() && defined($cond->{"flags"}) && index($cond->{"flags"}, "g") >= 0) {
        $has_g = 1;
    }
    if ($has_g == 1) {
        if (!defined($cg->{"regex_g_id"})) { $cg->{"regex_g_id"} = 0; }
        my str $pos_var = "__perla_gpos_" . $cg->{"regex_g_id"};
        $cg->{"regex_g_id"} = $cg->{"regex_g_id"} + 1;
        ind($cg); emit($cg, "size_t " . $pos_var . " = 0;\n");
        $cg->{"regex_g_pos_var"} = $pos_var;
    }
    # `while/until (my $x = expr)` shadow protection (mirror if-my fix).
    # Detect N_MY in cond targeting file-scope vars; save+null outer
    # before the loop, restore after. Only applies to the regular cond
    # path, not the `init_my` path which already handles its own scope.
    my array @__wl_shadowed = ();
    my scalar $__wl_cond_node = $node->{"cond"};
    if (defined($__wl_cond_node) && $__wl_cond_node->{"type"} == Perla::AST::N_MY()) {
        my scalar $__wl_my = $__wl_cond_node;
        if (defined($__wl_my->{"var"})) {
            my str $__wl_vn = $__wl_my->{"var"}->{"value"};
            if (_is_file_scope($cg, $__wl_vn) == 1) {
                my str $__wl_vt = "" . $__wl_my->{"var"}->{"type"};
                if (length($__wl_vt) == 0) { $__wl_vt = "SCALAR_VAR"; }
                push(@__wl_shadowed, c_var_for_vtype($__wl_vt, $__wl_vn));
            }
        }
        if (defined($__wl_my->{"vars"})) {
            my int $__wl_dvi = 0;
            while ($__wl_dvi < scalar(@{$__wl_my->{"vars"}})) {
                my scalar $__wl_dv = $__wl_my->{"vars"}->[$__wl_dvi];
                my str $__wl_dvn = $__wl_dv->{"value"};
                if (_is_file_scope($cg, $__wl_dvn) == 1) {
                    my str $__wl_dvt = "" . $__wl_dv->{"type"};
                    if (length($__wl_dvt) == 0) { $__wl_dvt = "SCALAR_VAR"; }
                    push(@__wl_shadowed, c_var_for_vtype($__wl_dvt, $__wl_dvn));
                }
                $__wl_dvi = $__wl_dvi + 1;
            }
        }
    }
    if (scalar(@__wl_shadowed) > 0) {
        ind($cg); emit($cg, "{\n");
        $cg->{"indent"} = $cg->{"indent"} + 1;
        my int $__wl_shi = 0;
        while ($__wl_shi < scalar(@__wl_shadowed)) {
            my str $__wl_shc = $__wl_shadowed[$__wl_shi];
            ind($cg); emit($cg, "StradaValue *__wl_sav_" . $__wl_shc . " = " . $__wl_shc . "; " . $__wl_shc . " = NULL;\n");
            $__wl_shi = $__wl_shi + 1;
        }
    }
    ind($cg);
    if ($node->{"type"} == Perla::AST::N_UNTIL()) {
        emit($cg, "while (!(");
        _gen_cond($cg, $node->{"cond"});
        emit($cg, "))");
    } else {
        emit($cg, "while (");
        _gen_cond($cg, $node->{"cond"});
        emit($cg, ")");
    }
    emit($cg, " {\n");
    $cg->{"indent"} = $cg->{"indent"} + 1;
    # Per-iteration local-chain snapshot so `local $x = ...` in the body
    # is restored at iteration end (Perl per-iteration scope semantics).
    ind($cg); emit($cg, "void *__w_local_mark = __perla_local_chain;\n");
    # redo label for bare `redo;` inside this loop.
    if (!defined($cg->{"loop_label_counter"})) { $cg->{"loop_label_counter"} = 0; }
    my int $__lcw = $cg->{"loop_label_counter"} + 1;
    $cg->{"loop_label_counter"} = $__lcw;
    my str $__wredo = "__perla_redo_w_" . $__lcw;
    ind($cg); emit($cg, $__wredo . ": ;\n");
    my str $saved_redo_label_w = "" . $cg->{"redo_label"};
    # Stash synthetic next-label for bare `next` when continue block
    # exists — see _gen_foreach for rationale.
    my str $saved_next_label_w = "";
    if (defined($cg->{"current_next_label"})) { $saved_next_label_w = "" . $cg->{"current_next_label"}; }
    if (defined($node->{"continue"}) && length($label) == 0) {
        $cg->{"current_next_label"} = "__perla_next_anon_" . $__lcw;
    } elsif (length($label) > 0) {
        $cg->{"current_next_label"} = "__perla_next_" . $label;
    } else {
        $cg->{"current_next_label"} = "";
    }
    $cg->{"redo_label"} = $__wredo;
    # Collect top-level scalar my-decls in body for per-iter DESTROY.
    # Without this, the last iter's blessed obj defers to program exit
    # (intermediate iters' values are freed by slot-reassignment on the
    # next iter's `my $x = ...`).
    my array @__w_body_locals = ();
    if (defined($node->{"body"}) && defined($node->{"body"}->{"stmts"})) {
        my scalar $__wbs = $node->{"body"}->{"stmts"};
        my int $__wbi = 0;
        while ($__wbi < scalar(@{$__wbs})) {
            my scalar $__wbss = $__wbs->[$__wbi];
            if (defined($__wbss) && $__wbss->{"type"} == Perla::AST::N_MY()
                && defined($__wbss->{"var"})) {
                my str $__wbvt = "" . $__wbss->{"var"}->{"type"};
                if (length($__wbvt) == 0) { $__wbvt = "SCALAR_VAR"; }
                if ($__wbvt eq "SCALAR_VAR") {
                    push(@__w_body_locals, $__wbss->{"var"}->{"value"});
                }
            }
            $__wbi = $__wbi + 1;
        }
    }
    # Extend sub_local_scalars so a `return` inside the loop body
    # cleans up the iter's locals before exiting the sub (mirrors
    # if-branch handling).
    my scalar $__w_sls_saved = $cg->{"sub_local_scalars"};
    if (scalar(@__w_body_locals) > 0) {
        my array @__w_sls_ext = ();
        if (defined($__w_sls_saved)) {
            my int $__wse_i = 0;
            while ($__wse_i < scalar(@{$__w_sls_saved})) {
                push(@__w_sls_ext, $__w_sls_saved->[$__wse_i]);
                $__wse_i = $__wse_i + 1;
            }
        }
        my int $__wadd_i = 0;
        while ($__wadd_i < scalar(@__w_body_locals)) {
            push(@__w_sls_ext, $__w_body_locals[$__wadd_i]);
            $__wadd_i = $__wadd_i + 1;
        }
        $cg->{"sub_local_scalars"} = \@__w_sls_ext;
    }
    gen_block_stmts($cg, $node->{"body"});
    $cg->{"sub_local_scalars"} = $__w_sls_saved;
    # Per-iter decref+NULL so DESTROY fires at end of EACH iter (not
    # just intermediate iters via the next iter's slot-reassign).
    my int $__wbl_i = 0;
    while ($__wbl_i < scalar(@__w_body_locals)) {
        my str $__wbl_cv = c_var($__w_body_locals[$__wbl_i]);
        ind($cg); emit($cg, "if (" . $__wbl_cv . ") { strada_decref(" . $__wbl_cv . "); " . $__wbl_cv . " = NULL; }\n");
        $__wbl_i = $__wbl_i + 1;
    }
    $cg->{"redo_label"} = $saved_redo_label_w;
    $cg->{"current_next_label"} = $saved_next_label_w;
    if (length($label) > 0) {
        ind($cg); emit($cg, "__perla_next_" . $label . ": ;\n");
    } elsif (defined($node->{"continue"})) {
        # Synthetic next-label for unlabeled while-with-continue.
        ind($cg); emit($cg, "__perla_next_anon_" . $__lcw . ": ;\n");
    }
    # `while (...) { BODY } continue { CONT }` — emit the continue
    # block here so it runs after the body AND after any `next` jump
    # (which lands at __perla_next_LABEL above).
    if (defined($node->{"continue"})) {
        gen_block_stmts($cg, $node->{"continue"});
    }
    ind($cg); emit($cg, "if (__perla_local_chain != __w_local_mark) { perla_local_chain_restore_to(__perla_local_chain, __w_local_mark); __perla_local_chain = __w_local_mark; }\n");
    $cg->{"indent"} = $cg->{"indent"} - 1;
    ind($cg); emit($cg, "}\n");
    if (length($label) > 0) {
        ind($cg); emit($cg, "__perla_end_" . $label . ": ;\n");
    }
    # Close hoisted vars block and restore declared_vars scope
    $cg->{"declared_vars"} = $saved_declared;
    $cg->{"same_scope_decls"} = $__w_saved_ssd;
    $cg->{"regex_g_pos_var"} = $saved_g_pos;
    # Decref + restore hoisted body-shadowed file-scope vars. The body's
    # last-iter `my $x` is still pointing at the inner value; we free it
    # and restore the outer pointer from __hsv_<cn> saved at hoist time.
    my int $__w_sri = 0;
    while ($__w_sri < scalar(@{$__w_this_shadows})) {
        my str $__w_src = $__w_this_shadows->[$__w_sri];
        ind($cg); emit($cg, "if (" . $__w_src . ") strada_decref(" . $__w_src . "); " . $__w_src . " = __hsv_" . $__w_src . ";\n");
        $__w_sri = $__w_sri + 1;
    }
    $cg->{"hoisted_shadows"} = $__w_saved_shadows;
    # Emit while/until-my shadow restore BEFORE closing the wrap block
    # (the save var was declared inside this block; once we emit `}`
    # the C local goes out of scope).
    if (scalar(@__wl_shadowed) > 0) {
        my int $__wl_rsi = 0;
        while ($__wl_rsi < scalar(@__wl_shadowed)) {
            my str $__wl_rsc = $__wl_shadowed[$__wl_rsi];
            ind($cg); emit($cg, "if (" . $__wl_rsc . ") strada_decref(" . $__wl_rsc . "); " . $__wl_rsc . " = __wl_sav_" . $__wl_rsc . ";\n");
            $__wl_rsi = $__wl_rsi + 1;
        }
    }
    $cg->{"indent"} = $cg->{"indent"} - 1;
    ind($cg); emit($cg, "}\n");
    if (scalar(@__wl_shadowed) > 0) {
        $cg->{"indent"} = $cg->{"indent"} - 1;
        ind($cg); emit($cg, "}\n");
    }
}

# --- Foreach ---
func _gen_foreach(scalar $cg, scalar $node) void {
    my int $__old_in_loop_fe = 0;
    if (defined($cg->{"in_loop"})) { $__old_in_loop_fe = $cg->{"in_loop"}; }
    $cg->{"in_loop"} = 1;
    _gen_foreach_inner($cg, $node);
    $cg->{"in_loop"} = $__old_in_loop_fe;
}

func _gen_foreach_inner(scalar $cg, scalar $node) void {
    my str $label = "";
    if (defined($node->{"label"})) {
        my str $user_label = $node->{"label"};
        $cg->{"label_count"} = $cg->{"label_count"} + 1;
        $label = $user_label . "_" . $cg->{"label_count"};
        $cg->{"label_map"}->{$user_label} = $label;
    }
    ind($cg); emit($cg, "/* foreach */\n");
    ind($cg); emit($cg, "{\n");
    $cg->{"indent"} = $cg->{"indent"} + 1;
    # `for ( grep { COND } $a, $b, ... ) { BODY }` (default $_) — Perl's grep
    # returns ALIASES to the source elements, so `$_ = X` in BODY writes back to
    # the originals. perla materializes the grep result as a value copy, losing
    # the writeback. Rewrite to iterate the grep's SOURCE list directly (reusing
    # the literal-lvalue-list aliasing/writeback below, which already writes back
    # to source lexicals) and guard BODY with the grep block. Restricted to the
    # implicit-$_ form over a literal list of plain scalar lvalues — exactly the
    # `for ( grep { !ref } $to_class, $trait ) { $_ = ...->initialize($_) }`
    # idiom in Class::MOP::MiniTrait::apply that blocks `use Moose`. (map is NOT
    # handled: map returns the block's values, not source aliases.)
    my int $fe_grep_lvalue = 0;
    my scalar $fe_grep_block = undef;
    if (!defined($node->{"var"})
        && defined($node->{"list"}) && $node->{"list"}->{"type"} == Perla::AST::N_GREP()
        && defined($node->{"list"}->{"list"})
        && $node->{"list"}->{"list"}->{"type"} == Perla::AST::N_ANON_ARRAY()
        && (!defined($node->{"list"}->{"list"}->{"is_ref"}) || $node->{"list"}->{"list"}->{"is_ref"} != 1)
        && defined($node->{"list"}->{"list"}->{"elems"})
        && defined($node->{"list"}->{"block"})) {
        my scalar $fgsrc = $node->{"list"}->{"list"};
        my scalar $fgelems = $fgsrc->{"elems"};
        my int $fg_all_lv = 1;
        my int $fg_i = 0;
        while ($fg_i < scalar(@{$fgelems})) {
            my scalar $fge = $fgelems->[$fg_i];
            my int $fg_ok = 0;
            if (defined($fge) && $fge->{"type"} == Perla::AST::N_SCALAR_VAR()
                && defined($fge->{"name"}) && length($fge->{"name"}) > 0
                && index($fge->{"name"}, "::") < 0 && $fge->{"name"} ne "_") {
                my str $fgc0 = substr($fge->{"name"}, 0, 1);
                if (!($fgc0 ge "0" && $fgc0 le "9")
                    && !(defined($cg->{"our_vars"}) && exists($cg->{"our_vars"}->{$fge->{"name"}}))) {
                    $fg_ok = 1;
                }
            }
            if ($fg_ok == 0) { $fg_all_lv = 0; last; }
            $fg_i = $fg_i + 1;
        }
        if ($fg_all_lv == 1 && scalar(@{$fgelems}) > 0) {
            $fe_grep_lvalue = 1;
            $fe_grep_block = $node->{"list"}->{"block"};
            $node->{"list"} = $fgsrc;   # iterate the source; lvalue-list path writes back to the vars
        }
    }
    # `for (values %h)` / `for (values %$ref)` — Perl aliases the loop var to
    # each hash value slot, so `$_ *= 2` / `$v = X` inside the body writes
    # back into the hash. Detect it here; the list is then iterated key-by-key
    # with a writeback to the hash at the end of each iteration (see below).
    # Gated entirely on $fe_values_alias — normal foreach is unaffected.
    my int $fe_values_alias = 0;
    my scalar $fe_values_hash = undef;
    if (defined($node->{"list"}) && $node->{"list"}->{"type"} == Perla::AST::N_CALL()
        && defined($node->{"list"}->{"name"})
        && ($node->{"list"}->{"name"} eq "values" || $node->{"list"}->{"name"} eq "CORE::values")
        && defined($node->{"list"}->{"args"}) && scalar(@{$node->{"list"}->{"args"}}) == 1) {
        my scalar $varg = $node->{"list"}->{"args"}->[0];
        my int $vat = $varg->{"type"};
        if ($vat == Perla::AST::N_HASH_VAR() || $vat == Perla::AST::N_DEREF_HASH()) {
            $fe_values_alias = 1;
            $fe_values_hash = $varg;
        }
    }
    # Literal-list aliasing: `for my $x ($a, $b) { $x = ... }` — Perl aliases
    # the loop var to each list element, so assigning $x mutates the original
    # lvalue. perla materializes the list into a temp array and writes back
    # into THAT (not the source vars). Detect a literal scalar-lvalue list and
    # write each (possibly reassigned) loop value back to its source lexical at
    # iteration end. Restricted to plain `my` scalars (not our/file-scope/
    # special, where the write would also need glob mirroring) and 1:1
    # index-to-element mapping (no array flattening). Real-world: DBIx::Class
    # ::Schema::load_namespaces' `for my $arg ($result_namespace,
    # $resultset_namespace) { $arg = [ $arg ] if ... }`.
    my int $fe_lvalue_list = 0;
    my scalar $fe_lvalue_elems = undef;
    if (defined($node->{"list"}) && $node->{"list"}->{"type"} == Perla::AST::N_ANON_ARRAY()
        && (!defined($node->{"list"}->{"is_ref"}) || $node->{"list"}->{"is_ref"} != 1)
        && defined($node->{"list"}->{"elems"})) {
        my scalar $fe_els = $node->{"list"}->{"elems"};
        my int $fe_all_lv = 1;
        my int $fe_ei = 0;
        while ($fe_ei < scalar(@{$fe_els})) {
            my scalar $fe_el = $fe_els->[$fe_ei];
            my int $fe_ok = 0;
            if (defined($fe_el) && $fe_el->{"type"} == Perla::AST::N_SCALAR_VAR()
                && defined($fe_el->{"name"}) && length($fe_el->{"name"}) > 0
                && index($fe_el->{"name"}, "::") < 0) {
                my str $fe_en = $fe_el->{"name"};
                my str $fe_ec0 = substr($fe_en, 0, 1);
                if (!($fe_ec0 ge "0" && $fe_ec0 le "9") && $fe_en ne "_"
                    && !(defined($cg->{"our_vars"}) && exists($cg->{"our_vars"}->{$fe_en}))) {
                    $fe_ok = 1;
                }
            }
            if ($fe_ok == 0) { $fe_all_lv = 0; last; }
            $fe_ei = $fe_ei + 1;
        }
        if ($fe_all_lv == 1 && scalar(@{$fe_els}) > 0) {
            $fe_lvalue_list = 1;
            $fe_lvalue_elems = $fe_els;
        }
    }
    # Save perla_dollar_underscore around `for (LIST) { ... }` (default $_)
    # so an outer map/sort/grep iter var isn't clobbered. Perl semantics:
    # the for-loop's $_ is an alias to each list element, and after the
    # loop exits $_ is restored to its outer binding. Without this,
    # `map { ...; for (@inner) { ... }; $_->[1] }` reads $_->[1] from
    # the LAST element of @inner instead of the map's iter var. DBIC's
    # `_resolve_column_info` (called from a closure inside DBIC's
    # `_resolve_bindattrs` map) does this internally — so the bind value
    # came out as the wrong array's [1] slot, and the WHERE clause
    # substituted `'HASH(0x…)'` instead of the real column value.
    ind($cg); emit($cg, "StradaValue *__sav_du_fe = perla_dollar_underscore;\n");
    ind($cg); emit($cg, "int __sav_wl_fe = __perla_want_list; __perla_want_list = 1;\n");
    # __fe_vhash / __fe_vkeys are declared unconditionally (NULL for the
    # non-values case) so the writeback emit can reference them safely.
    ind($cg); emit($cg, "StradaValue *__fe_vhash = NULL; StradaArray *__fe_vkeys = NULL;\n");
    if ($fe_values_alias == 1) {
        # Capture the hash and a STABLE key array, then build the values list
        # parallel to those keys. The writeback at iteration end stores the
        # (possibly reassigned) loop var back into the hash under its key.
        ind($cg); emit($cg, "__fe_vhash = ");
        gen_expr($cg, $fe_values_hash);
        emit($cg, ";\n");
        ind($cg); emit($cg, "if (__fe_vhash && !STRADA_IS_TAGGED_INT(__fe_vhash) && __fe_vhash->type == STRADA_REF) __fe_vhash = __fe_vhash->value.rv;\n");
        ind($cg); emit($cg, "__fe_vkeys = __fe_vhash ? strada_hash_keys_sv(__fe_vhash) : NULL;\n");
        ind($cg); emit($cg, "StradaValue *__fe_arr = strada_new_array();\n");
        ind($cg); emit($cg, "{ StradaArray *__fe_vva = strada_deref_array(__fe_arr); if (__fe_vkeys) for (size_t __fe_vi = 0; __fe_vi < __fe_vkeys->size; __fe_vi++) { StradaValue *__fe_vk = __fe_vkeys->elements[__fe_vkeys->head + __fe_vi]; char *__fe_vks = strada_to_str(__fe_vk); StradaValue *__fe_vv = strada_hv_fetch_owned(__fe_vhash, __fe_vks ? __fe_vks : \"\"); if (__fe_vks) free(__fe_vks); strada_array_push_take(__fe_vva, __fe_vv ? __fe_vv : strada_new_undef()); } }\n");
        ind($cg); emit($cg, "__perla_want_list = __sav_wl_fe;\n");
    } else {
        ind($cg); emit($cg, "StradaValue *__fe_arr = ");
        gen_expr($cg, $node->{"list"});
        emit($cg, ";\n");
        ind($cg); emit($cg, "__perla_want_list = __sav_wl_fe;\n");
    }
    # `for (\@arr)` / `for (\%h)` / `for (\$x)` — the list expression
    # evaluates to a single reference value, so the loop iterates once
    # with $_ bound to the ref (Perl list semantics: `\@arr` is one
    # element). Without this special case, the generic deref_array path
    # below would unwrap the REF→ARRAY and iterate the underlying array.
    #
    # Same shape for `for ($aref)` (scalar holding a ref) and `for
    # (CALL())` when the call returns a single arrayref: Perl treats
    # those as 1-element lists. We can't distinguish at codegen time
    # whether a CALL result is "I returned the array" vs "I returned a
    # ref to one", so the rule is: only iterate over the contents when
    # __fe_arr is *directly* an ARRAY value (not a REF→ARRAY).
    my int $list_is_ref = 0;
    if (defined($node->{"list"}) && $node->{"list"}->{"type"} == Perla::AST::N_REF()) {
        $list_is_ref = 1;
    }
    if ($list_is_ref == 1) {
        ind($cg); emit($cg, "StradaArray *__fe_av = NULL;\n");
    } else {
        # Iterate only when the value is directly ARRAY. REF→ARRAY is a
        # 1-element list. Without this, `for my $x ($aref) { }` iterated
        # over the underlying array instead of the ref itself, and
        # `for (CALL_RETURNING_REF()) { }` did the same.
        ind($cg); emit($cg, "StradaArray *__fe_av = (__fe_arr && !STRADA_IS_TAGGED_INT(__fe_arr) && __fe_arr->type == STRADA_ARRAY) ? __fe_arr->value.av : NULL;\n");
    }
    # `for $x (%h)` — Perl flattens the hash to (k1,v1,k2,v2,...) and
    # iterates each scalar. For tied hashes, route through
    # strada_hash_keys_sv (which uses FIRSTKEY/NEXTKEY) and FETCH on
    # each key. Without this, `for (%h)` iterated once with $x = the
    # hash ref / undef.
    ind($cg); emit($cg, "StradaValue *__fe_fb = NULL; ");
    ind($cg); emit($cg, "if (!__fe_av && __fe_arr && !STRADA_IS_TAGGED_INT(__fe_arr) && __fe_arr->type == STRADA_HASH) { ");
    emit($cg, "  __fe_fb = strada_new_array(); StradaArray *__fe_fba = strada_deref_array(__fe_fb); ");
    emit($cg, "  StradaArray *__fe_hk = strada_hash_keys_sv(__fe_arr); ");
    emit($cg, "  if (__fe_hk) for (size_t __fe_hi = 0; __fe_hi < __fe_hk->size; __fe_hi++) { ");
    emit($cg, "    StradaValue *__fe_kv = __fe_hk->elements[__fe_hk->head + __fe_hi]; ");
    emit($cg, "    char *__fe_kstr = strada_to_str(__fe_kv); ");
    emit($cg, "    if (__fe_kv) strada_incref(__fe_kv); strada_array_push_take(__fe_fba, __fe_kv); ");
    emit($cg, "    StradaValue *__fe_vv = strada_hv_fetch_owned(__fe_arr, __fe_kstr ? __fe_kstr : \"\"); ");
    emit($cg, "    if (__fe_kstr) free(__fe_kstr); strada_array_push_take(__fe_fba, __fe_vv ? __fe_vv : strada_new_undef()); ");
    emit($cg, "  } if (__fe_hk) strada_free_array(__fe_hk); ");
    emit($cg, "  __fe_av = __fe_fba; ");
    emit($cg, "} ");
    # `for $k ("col")` — single-elem list parses as a scalar (parens
    # grouping). Wrap into a 1-elem array so the loop iterates once.
    # (`for $k ()` — empty list — leaves __fe_av=NULL with len=0, correct.)
    # `for (undef)` / `for ($x)` where $x is undef iterates once with
    # $_=undef per Perl — wrap the undef value into a 1-elem array too.
    # The 1-element scalar wrap is ONLY for genuinely scalar list exprs
    # (`for ($x)`, `for (CALL())`). For an EXPLICIT array expr (`@arr`, `@$ref`,
    # `@{EXPR}`), an undef/empty deref means ZERO iterations, not one over a
    # phantom undef. Without this guard, `for my $a (@$undef)` iterated once
    # (Perl: zero) — e.g. Moose::Exporter::_parse_trait_aliases' `for my $alias
    # (@$aliases)` with undef trait_aliases produced a bogus empty export name.
    my int $fe_is_array_list = 0;
    if (defined($node->{"list"})) {
        my int $felt = $node->{"list"}->{"type"};
        if ($felt == Perla::AST::N_ARRAY_VAR() || $felt == Perla::AST::N_DEREF_ARRAY()) {
            $fe_is_array_list = 1;
        }
    }
    if ($fe_is_array_list == 0) {
        ind($cg); emit($cg, "if (!__fe_av && __fe_arr && !STRADA_IS_TAGGED_INT(__fe_arr)) { ");
        emit($cg, "__fe_fb = strada_new_array(); strada_array_push(strada_deref_array(__fe_fb), __fe_arr); __fe_av = strada_deref_array(__fe_fb); ");
        emit($cg, "} else if (!__fe_av && STRADA_IS_TAGGED_INT(__fe_arr)) { __fe_fb = strada_new_array(); strada_array_push(strada_deref_array(__fe_fb), __fe_arr); __fe_av = strada_deref_array(__fe_fb); }\n");
    }
    ind($cg); emit($cg, "int __fe_len = __fe_av ? strada_array_length(__fe_av) : 0;\n");
    # Outer local-chain mark so `last` / `break` (which skip the
    # per-iteration restore at the bottom of the body) still unwinds
    # locals pushed in the current iteration. The per-iteration restore
    # at the body's tail is still emitted; this outer restore catches
    # the break / labeled-last paths.
    ind($cg); emit($cg, "void *__fe_outer_local_mark = __perla_local_chain;\n");
    # Hoist body's my-decls so file-scope shadows get save/restore
    # (same mechanism as if/while). The hoist emits at this point
    # (inside foreach's outer wrap, before the for loop) so the save
    # var is in scope for the restore after the loop.
    my scalar $__fe_saved_shadows = $cg->{"hoisted_shadows"};
    my scalar $__fe_saved_hoisted_lv = $cg->{"hoisted_loop_vars"};
    $cg->{"hoisted_shadows"} = [];
    $cg->{"hoisted_loop_vars"} = [];
    _hoist_loop_vars($cg, $node->{"body"});
    my scalar $__fe_this_shadows = $cg->{"hoisted_shadows"};
    my scalar $__fe_this_hoisted = $cg->{"hoisted_loop_vars"};
    if (length($label) > 0) {
        ind($cg); emit($cg, "__perla_redo_" . $label . ":\n");
    }
    ind($cg); emit($cg, "for (int __fe_i = 0; __fe_i < __fe_len; __fe_i++) {\n");
    $cg->{"indent"} = $cg->{"indent"} + 1;
    # Snapshot the local-chain head at the START of each iteration so
    # `local $x = ...` inside the body is restored at iteration end
    # (Perl per-iteration scope semantics).
    ind($cg); emit($cg, "void *__fe_local_mark = __perla_local_chain;\n");
    my str $vname = $node->{"var"}->{"value"};
    my str $cvar = c_var($vname);
    my str $fe_prefix = "StradaValue *";
    if ($vname eq "" || $vname eq "_") {
        $cvar = "perla_dollar_underscore";
        $fe_prefix = "";  # perla_dollar_underscore is a global, don't redeclare
    }
    # Check if this is a closure capture (#define'd variable)
    if (defined($cg->{"capture_vars"})) {
        my str $cv_check = "" . $cg->{"capture_vars"}->{$cvar};
        if (length($cv_check) > 0) {
            $fe_prefix = "";  # Captured var — don't redeclare
        }
    }
    ind($cg); emit($cg, $fe_prefix . $cvar . " = strada_array_get(__fe_av, __fe_i);\n");
    # Perl-style for-loop aliasing: body-side `$r = expr` writes through to
    # the array element. Snapshot the original pointer; if the body changed
    # it, write the new value back. Required by DBIC's _construct_results
    # `for my $r (@$rows) { $r = $inflator->(...); }` row inflation pattern.
    # incref before strada_array_set because set takes ownership without
    # increfing — safe for both fresh allocations and aliased existing
    # values. (For fresh allocations we leak 1 ref per reassigned iteration
    # — same magnitude as the pre-existing leak when v_r is reassigned with
    # no writeback.)
    ind($cg); emit($cg, "StradaValue *__orig_" . $cvar . " = " . $cvar . ";\n");
    # Mark the loop variable as declared in this scope so inner `my $same_name`
    # doesn't emit a C redeclaration (Perl allows shadowing; C doesn't in the
    # same block). Restored after the body.
    my int $saved_fe_declared = 0;
    if (defined($cg->{"declared_vars"}->{$cvar})) { $saved_fe_declared = 1; }
    $cg->{"declared_vars"}->{$cvar} = 1;
    if (!defined($cg->{"loop_label_counter"})) { $cg->{"loop_label_counter"} = 0; }
    my int $__lcf = $cg->{"loop_label_counter"} + 1;
    $cg->{"loop_label_counter"} = $__lcf;
    my str $__fredo = "__perla_redo_f_" . $__lcf;
    ind($cg); emit($cg, $__fredo . ": ;\n");
    my str $saved_redo_label_f = "" . $cg->{"redo_label"};
    $cg->{"redo_label"} = $__fredo;
    # If continue block exists, stash a synthetic next-label so bare
    # `next` jumps to it instead of using C `continue` (which skips
    # the perla-continue block).
    my str $saved_next_label_f = "";
    if (defined($cg->{"current_next_label"})) { $saved_next_label_f = "" . $cg->{"current_next_label"}; }
    if (defined($node->{"continue"}) && length($label) == 0) {
        $cg->{"current_next_label"} = "__perla_next_anon_" . $__lcf;
    } elsif (length($label) > 0) {
        $cg->{"current_next_label"} = "__perla_next_" . $label;
    } else {
        $cg->{"current_next_label"} = "";
    }
    # Push the iter var onto my_lexicals so closures inside the body
    # capture this iteration's slot (not the file-scope static of the
    # same name). Without this, `my $n = 99; for my $n (1..3) { push
    # @subs, sub { $n } }` had the closure read file-scope v_n (== 99)
    # because find_free_vars saw `n` in file_scope_vars and skipped
    # it — every closure returned 99 / 0 instead of the iter value.
    # Only applies to `for my $X` (not `for $X` over a pre-existing X).
    # Tag the entry with from_foreach=1 so closure-cell-init can tell
    # this is a per-iteration shadow that needs malloc, NOT a regular
    # my-decl that should share storage with outer file-scope.
    my int $__fe_pushed_lex = 0;
    if (defined($node->{"my"}) && $node->{"my"} == 1
        && length($vname) > 0 && $vname ne "_"
        && defined($cg->{"my_lexicals"})) {
        my scalar $__fe_lex_entry = {};
        $__fe_lex_entry->{"name"} = $vname;
        $__fe_lex_entry->{"c_name"} = $cvar;
        $__fe_lex_entry->{"sigil"} = "\$";
        $__fe_lex_entry->{"from_foreach"} = 1;
        push(@{$cg->{"my_lexicals"}}, $__fe_lex_entry);
        $__fe_pushed_lex = 1;
    }
    # Collect body my-decls for per-iter DESTROY (mirrors while-body fix).
    my array @__fe_body_locals = ();
    if (defined($node->{"body"}) && defined($node->{"body"}->{"stmts"})) {
        my scalar $__febs = $node->{"body"}->{"stmts"};
        my int $__febi = 0;
        while ($__febi < scalar(@{$__febs})) {
            my scalar $__febss = $__febs->[$__febi];
            if (defined($__febss) && $__febss->{"type"} == Perla::AST::N_MY()
                && defined($__febss->{"var"})) {
                my str $__febvt = "" . $__febss->{"var"}->{"type"};
                if (length($__febvt) == 0) { $__febvt = "SCALAR_VAR"; }
                if ($__febvt eq "SCALAR_VAR") {
                    push(@__fe_body_locals, $__febss->{"var"}->{"value"});
                }
            }
            $__febi = $__febi + 1;
        }
    }
    my scalar $__fe_sls_saved = $cg->{"sub_local_scalars"};
    if (scalar(@__fe_body_locals) > 0) {
        my array @__fe_sls_ext = ();
        if (defined($__fe_sls_saved)) {
            my int $__fese_i = 0;
            while ($__fese_i < scalar(@{$__fe_sls_saved})) {
                push(@__fe_sls_ext, $__fe_sls_saved->[$__fese_i]);
                $__fese_i = $__fese_i + 1;
            }
        }
        my int $__feadd_i = 0;
        while ($__feadd_i < scalar(@__fe_body_locals)) {
            push(@__fe_sls_ext, $__fe_body_locals[$__feadd_i]);
            $__feadd_i = $__feadd_i + 1;
        }
        $cg->{"sub_local_scalars"} = \@__fe_sls_ext;
    }
    # Foreach body is a new lexical scope — reset same_scope_decls so a `my $x`
    # in the body doesn't trigger "masks earlier declaration" against an
    # outer `my $x`.
    my scalar $__fe_saved_ssd = $cg->{"same_scope_decls"};
    $cg->{"same_scope_decls"} = {};
    # grep-source rewrite (see top of function): only run BODY for elements the
    # grep block keeps. $_ is already the current source element here, so the
    # block's `ref`/etc. checks see the right value; non-kept elements leave $_
    # unchanged so the lvalue writeback below is a no-op for them.
    if ($fe_grep_lvalue == 1) {
        ind($cg); emit($cg, "if (perla_to_bool(");
        _gen_map_block($cg, $fe_grep_block);
        emit($cg, ")) {\n");
        $cg->{"indent"} = $cg->{"indent"} + 1;
    }
    # Snapshot the closure-cell counter before the body so we can invalidate
    # any cells the body's closures allocate. __perla_cell[] caches a non-owning
    # pointer to each capture cell; when a closure that captured the cell dies at
    # iteration end (its my-decl is decref'd below), strada_cell_decref frees the
    # cell — but the cache pointer lingers. The next iteration's cell-init check
    # (`*__perla_cell[N] != v_x`) would then DEREFERENCE that freed cell — a
    # use-after-free that corrupts the heap (seen crashing DBIx::Class::Core's
    # load via Class::C3::Componentised::inject_base's `for my $comp` closure).
    # Resetting the slots to NULL at iteration end makes the next iteration
    # allocate fresh cells instead of reading freed memory; intra-iteration cell
    # sharing (two closures, same var, same iteration) is unaffected.
    my int $__fe_cell_snap = 0;
    if (defined($cg->{"cell_idx"})) { $__fe_cell_snap = $cg->{"cell_idx"}; }
    gen_block_stmts($cg, $node->{"body"});
    if ($fe_grep_lvalue == 1) {
        $cg->{"indent"} = $cg->{"indent"} - 1;
        ind($cg); emit($cg, "}\n");
    }
    $cg->{"same_scope_decls"} = $__fe_saved_ssd;
    $cg->{"sub_local_scalars"} = $__fe_sls_saved;
    # Per-iter decref+NULL of body my-decls.
    my int $__febl_i = 0;
    while ($__febl_i < scalar(@__fe_body_locals)) {
        my str $__febl_cv = c_var($__fe_body_locals[$__febl_i]);
        ind($cg); emit($cg, "if (" . $__febl_cv . ") { strada_decref(" . $__febl_cv . "); " . $__febl_cv . " = NULL; }\n");
        $__febl_i = $__febl_i + 1;
    }
    # Invalidate body-allocated closure-cell cache slots (see snapshot above).
    # NULL only — the cells were already freed when their capturing closures
    # were decref'd, so this drops a dangling pointer, never a live ref.
    my int $__fe_cell_now = 0;
    if (defined($cg->{"cell_idx"})) { $__fe_cell_now = $cg->{"cell_idx"}; }
    my int $__fe_ci = $__fe_cell_snap;
    while ($__fe_ci < $__fe_cell_now) {
        ind($cg); emit($cg, "__perla_cell[" . $__fe_ci . "] = (StradaValue**)0;\n");
        $__fe_ci = $__fe_ci + 1;
    }
    if ($__fe_pushed_lex == 1) {
        pop(@{$cg->{"my_lexicals"}});
        # Clear the shared-cells-emitted marker for this iter var so a
        # subsequent `for my $SAME (...)` block at the same scope level
        # emits a fresh per-iteration malloc instead of skipping cell
        # init and reusing whatever __perla_cell[N] last pointed at.
        # Without this, the second loop's closures all read the FIRST
        # loop's final $i value (or worse, freed memory).
        if (defined($cg->{"shared_cells_emitted"})
            && defined($cg->{"shared_cells_emitted"}->{$vname})) {
            $cg->{"shared_cells_emitted"}->{$vname} = undef;
        }
        if (defined($cg->{"closure_cell_mirror"})
            && defined($cg->{"closure_cell_mirror"}->{$vname})) {
            $cg->{"closure_cell_mirror"}->{$vname} = undef;
        }
        if (defined($cg->{"cells_malloc_d"})
            && defined($cg->{"cells_malloc_d"}->{$vname})) {
            $cg->{"cells_malloc_d"}->{$vname} = undef;
        }
    }
    $cg->{"redo_label"} = $saved_redo_label_f;
    $cg->{"current_next_label"} = $saved_next_label_f;
    if ($saved_fe_declared == 0) {
        $cg->{"declared_vars"}->{$cvar} = undef;
    }
    if (length($label) > 0) {
        ind($cg); emit($cg, "__perla_next_" . $label . ": ;\n");
    } elsif (defined($node->{"continue"})) {
        # No user label, but a continue block exists — emit a synthetic
        # next-label so unlabeled `next` jumps to it (and then runs
        # the continue block). Without this, bare `next` becomes
        # C `continue` which SKIPS the continue block (it sits below
        # the next site in the C for-body), missing iter's continue.
        ind($cg); emit($cg, "__perla_next_anon_" . $__lcf . ": ;\n");
    }
    # `foreach my $x (...) { ... } continue { ... }` — continue block
    # runs after the body and after `next` jumps to __perla_next_LABEL.
    if (defined($node->{"continue"})) {
        gen_block_stmts($cg, $node->{"continue"});
    }
    # Aliasing writeback (placed after the next-label so `next LABEL` jumps
    # also flow through the writeback path).
    if ($fe_lvalue_list == 1) {
        # Literal scalar-lvalue list aliasing: write the (possibly reassigned)
        # loop value straight back to its source lexical, keyed on the iteration
        # index. We do NOT route through __fe_av here (the generic array_set
        # path below): when the new value references the old element — e.g.
        # `$arg = [ $arg ]` — array_set decref's the old slot value, freeing the
        # element the new ref still points at (UAF). Writing the source lexical
        # directly keeps the temp array's original element alive (still ref'd by
        # __fe_av until loop teardown), so the new ref's contents stay valid.
        ind($cg); emit($cg, "if (" . $cvar . " != __orig_" . $cvar . ") {\n");
        $cg->{"indent"} = $cg->{"indent"} + 1;
        my int $fe_wi = 0;
        while ($fe_wi < scalar(@{$fe_lvalue_elems})) {
            my str $fe_wcn = c_var($fe_lvalue_elems->[$fe_wi]->{"name"});
            ind($cg); emit($cg, "if (__fe_i == " . $fe_wi . ") { StradaValue *__fe_ov = " . $fe_wcn . "; if (" . $cvar . ") strada_incref(" . $cvar . "); " . $fe_wcn . " = " . $cvar . "; if (__fe_ov && __fe_ov != " . $cvar . ") strada_decref(__fe_ov); }\n");
            $fe_wi = $fe_wi + 1;
        }
        $cg->{"indent"} = $cg->{"indent"} - 1;
        ind($cg); emit($cg, "}\n");
    } else {
        ind($cg); emit($cg, "if (" . $cvar . " != __orig_" . $cvar . ") { strada_incref(" . $cvar . "); strada_array_set(__fe_av, __fe_i, " . $cvar . "); }\n");
    }
    # `for (values %h)` aliasing: store the (possibly reassigned) loop var
    # back into the hash under this iteration's key.
    if ($fe_values_alias == 1) {
        ind($cg); emit($cg, "if (__fe_vkeys && __fe_i < (int)__fe_vkeys->size) { StradaValue *__fe_wk = __fe_vkeys->elements[__fe_vkeys->head + __fe_i]; char *__fe_wks = strada_to_str(__fe_wk); strada_hv_store(__fe_vhash, __fe_wks ? __fe_wks : \"\", " . $cvar . "); if (__fe_wks) free(__fe_wks); }\n");
    }
    # Per-iteration local-chain restore — unwind any `local $x = ...`
    # that the body pushed.
    ind($cg); emit($cg, "if (__perla_local_chain != __fe_local_mark) { perla_local_chain_restore_to(__perla_local_chain, __fe_local_mark); __perla_local_chain = __fe_local_mark; }\n");
    $cg->{"indent"} = $cg->{"indent"} - 1;
    ind($cg); emit($cg, "}\n");
    # `for (values %h)` cleanup: free the stable key array and the temp values
    # list built for the iteration (mirrors the %h-flatten cleanup above).
    if ($fe_values_alias == 1) {
        ind($cg); emit($cg, "if (__fe_vkeys) strada_free_array(__fe_vkeys);\n");
        ind($cg); emit($cg, "if (__fe_arr) strada_decref(__fe_arr);\n");
    }
    if (length($label) > 0) {
        ind($cg); emit($cg, "__perla_end_" . $label . ": ;\n");
    }
    # Outer chain unwind: catches `last` / `break` paths where the
    # per-iteration restore at body's tail didn't run. Idempotent on
    # the natural-exit path (chain == outer mark already).
    ind($cg); emit($cg, "if (__perla_local_chain != __fe_outer_local_mark) { perla_local_chain_restore_to(__perla_local_chain, __fe_outer_local_mark); __perla_local_chain = __fe_outer_local_mark; }\n");
    # Decref and restore body's hoisted shadows (file-scope shadowing
    # vars). Last-iter value freed; static slot pointed back at outer
    # via __hsv_<cn>.
    my int $__fe_sri = 0;
    while ($__fe_sri < scalar(@{$__fe_this_shadows})) {
        my str $__fe_src = $__fe_this_shadows->[$__fe_sri];
        ind($cg); emit($cg, "if (" . $__fe_src . ") strada_decref(" . $__fe_src . "); " . $__fe_src . " = __hsv_" . $__fe_src . ";\n");
        $__fe_sri = $__fe_sri + 1;
    }
    $cg->{"hoisted_shadows"} = $__fe_saved_shadows;
    $cg->{"hoisted_loop_vars"} = $__fe_saved_hoisted_lv;
    # Restore perla_dollar_underscore (only matters when the loop's iter
    # var was the default $_; if it had a `my $x` form the assignment
    # was to a different cell anyway, but the restore is harmless).
    if ($vname eq "" || $vname eq "_") {
        ind($cg); emit($cg, "perla_dollar_underscore = __sav_du_fe;\n");
    }
    $cg->{"indent"} = $cg->{"indent"} - 1;
    ind($cg); emit($cg, "}\n");
}

# --- C-style for ---
func _gen_for_c(scalar $cg, scalar $node) void {
    my int $__old_in_loop_fc = 0;
    if (defined($cg->{"in_loop"})) { $__old_in_loop_fc = $cg->{"in_loop"}; }
    $cg->{"in_loop"} = 1;
    _gen_for_c_inner($cg, $node);
    $cg->{"in_loop"} = $__old_in_loop_fc;
}

func _gen_for_c_inner(scalar $cg, scalar $node) void {
    my scalar $init = $node->{"init"};
    # Unique ID for this for loop (supports nesting)
    if (!defined($cg->{"for_c_id"})) { $cg->{"for_c_id"} = 0; }
    my int $for_id = $cg->{"for_c_id"};
    $cg->{"for_c_id"} = $for_id + 1;
    my str $step_label = "__perla_for_step_" . $for_id;
    # If init is a my declaration, emit it before the for and use the variable
    if (defined($init) && $init->{"type"} == Perla::AST::N_MY()) {
        # `for (my $x = ...; ...)` where outer $x is file-scope-tracked
        # — same shadow protection as if-my. Save outer pointer before
        # the my-decl reassigns the static slot, restore after the loop.
        my array @__fc_shadowed = ();
        if (defined($init->{"var"})) {
            my str $__fc_vn = $init->{"var"}->{"value"};
            if (_is_file_scope($cg, $__fc_vn) == 1) {
                my str $__fc_vt = "" . $init->{"var"}->{"type"};
                if (length($__fc_vt) == 0) { $__fc_vt = "SCALAR_VAR"; }
                push(@__fc_shadowed, c_var_for_vtype($__fc_vt, $__fc_vn));
            }
        }
        if (defined($init->{"vars"})) {
            my int $__fc_dvi = 0;
            while ($__fc_dvi < scalar(@{$init->{"vars"}})) {
                my scalar $__fc_dv = $init->{"vars"}->[$__fc_dvi];
                my str $__fc_dvn = $__fc_dv->{"value"};
                if (_is_file_scope($cg, $__fc_dvn) == 1) {
                    my str $__fc_dvt = "" . $__fc_dv->{"type"};
                    if (length($__fc_dvt) == 0) { $__fc_dvt = "SCALAR_VAR"; }
                    push(@__fc_shadowed, c_var_for_vtype($__fc_dvt, $__fc_dvn));
                }
                $__fc_dvi = $__fc_dvi + 1;
            }
        }
        ind($cg); emit($cg, "{\n");
        $cg->{"indent"} = $cg->{"indent"} + 1;
        my int $__fc_shi = 0;
        while ($__fc_shi < scalar(@__fc_shadowed)) {
            my str $__fc_shc = $__fc_shadowed[$__fc_shi];
            ind($cg); emit($cg, "StradaValue *__fc_sav_" . $__fc_shc . " = " . $__fc_shc . "; " . $__fc_shc . " = NULL;\n");
            $__fc_shi = $__fc_shi + 1;
        }
        _gen_my($cg, $init);
        my scalar $saved_declared_fc = $cg->{"declared_vars"};
        my scalar $__fc_saved_ssd = $cg->{"same_scope_decls"};
        $cg->{"declared_vars"} = {};
        $cg->{"same_scope_decls"} = {};
        my array @sdk2 = keys($saved_declared_fc);
        my int $sdi2 = 0;
        while ($sdi2 < scalar(@sdk2)) {
            $cg->{"declared_vars"}->{$sdk2[$sdi2]} = 1;
            $sdi2++;
        }
        my scalar $saved_hoisted = $cg->{"hoisted_loop_vars"};
        my scalar $__fcb_saved_shadows = $cg->{"hoisted_shadows"};
        $cg->{"hoisted_loop_vars"} = [];
        $cg->{"hoisted_shadows"} = [];
        _hoist_loop_vars($cg, $node->{"body"});
        my scalar $this_hoisted = $cg->{"hoisted_loop_vars"};
        my scalar $__fcb_this_shadows = $cg->{"hoisted_shadows"};
        ind($cg); emit($cg, "while (");
        if (defined($node->{"cond"})) {
            _gen_cond($cg, $node->{"cond"});
        } else {
            emit($cg, "1");
        }
        emit($cg, ") {\n");
        $cg->{"indent"} = $cg->{"indent"} + 1;
        ind($cg); emit($cg, "void *__fc_local_mark = __perla_local_chain;\n");
        my str $redo_label = "__perla_redo_" . $for_id;
        ind($cg); emit($cg, $redo_label . ": ;\n");
        my int $saved_in_for_c = $cg->{"in_for_c"};
        my str $saved_step_label = "" . $cg->{"for_step_label"};
        my str $saved_redo_label = "" . $cg->{"redo_label"};
        $cg->{"in_for_c"} = 1;
        $cg->{"for_step_label"} = $step_label;
        $cg->{"redo_label"} = $redo_label;
        gen_block_stmts($cg, $node->{"body"});
        $cg->{"in_for_c"} = $saved_in_for_c;
        $cg->{"for_step_label"} = $saved_step_label;
        $cg->{"redo_label"} = $saved_redo_label;
        # Step expression — placed at unique label so next can reach it
        ind($cg); emit($cg, $step_label . ": ");
        if (defined($node->{"steps"})) {
            # Comma-separated step list (`$i++, $j--`): emit as a single
            # C statement with each expr inside an evaluated (cast)(void)
            # wrapper so values are discarded but side effects run.
            my int $__ssi = 0;
            my scalar $__ss_arr = $node->{"steps"};
            while ($__ssi < scalar(@{$__ss_arr})) {
                if ($__ssi > 0) { emit($cg, ", "); }
                emit($cg, "(void)(");
                gen_expr($cg, $__ss_arr->[$__ssi]);
                emit($cg, ")");
                $__ssi = $__ssi + 1;
            }
        } elsif (defined($node->{"step"})) {
            gen_expr($cg, $node->{"step"});
        } else {
            emit($cg, "(void)0");
        }
        emit($cg, ";\n");
        ind($cg); emit($cg, "if (__perla_local_chain != __fc_local_mark) { perla_local_chain_restore_to(__perla_local_chain, __fc_local_mark); __perla_local_chain = __fc_local_mark; }\n");
        $cg->{"indent"} = $cg->{"indent"} - 1;
        ind($cg); emit($cg, "}\n");
        # Decref hoisted my-vars at end of loop block — without this the
        # final iter's value is held by the block-local C var until scope
        # exit and never freed (the file-scope static was shadowed).
        # Visible as the bless_create / func_call per-iter leak.
        my int $hi = 0;
        while ($hi < scalar(@{$this_hoisted})) {
            ind($cg); emit($cg, "strada_decref(" . $this_hoisted->[$hi] . ");\n");
            $hi = $hi + 1;
        }
        # Restore body shadows (file-scope hoisted in body).
        my int $__fcb_sri = 0;
        while ($__fcb_sri < scalar(@{$__fcb_this_shadows})) {
            my str $__fcb_src = $__fcb_this_shadows->[$__fcb_sri];
            ind($cg); emit($cg, "if (" . $__fcb_src . ") strada_decref(" . $__fcb_src . "); " . $__fcb_src . " = __hsv_" . $__fcb_src . ";\n");
            $__fcb_sri = $__fcb_sri + 1;
        }
        $cg->{"hoisted_loop_vars"} = $saved_hoisted;
        $cg->{"hoisted_shadows"} = $__fcb_saved_shadows;
        $cg->{"declared_vars"} = $saved_declared_fc;
        $cg->{"same_scope_decls"} = $__fc_saved_ssd;
        # Restore shadowed file-scope vars at end of for-loop block
        # (from for-c init my-decl).
        my int $__fc_rsi = 0;
        while ($__fc_rsi < scalar(@__fc_shadowed)) {
            my str $__fc_rsc = $__fc_shadowed[$__fc_rsi];
            ind($cg); emit($cg, "if (" . $__fc_rsc . ") strada_decref(" . $__fc_rsc . "); " . $__fc_rsc . " = __fc_sav_" . $__fc_rsc . ";\n");
            $__fc_rsi = $__fc_rsi + 1;
        }
        $cg->{"indent"} = $cg->{"indent"} - 1;
        ind($cg); emit($cg, "}\n");
    } else {
        ind($cg); emit($cg, "for (");
        if (defined($init)) {
            gen_expr($cg, $init);
        }
        emit($cg, "; ");
        if (defined($node->{"cond"})) {
            _gen_cond($cg, $node->{"cond"});
        } else {
            emit($cg, "1");
        }
        emit($cg, "; ");
        if (defined($node->{"steps"})) {
            my int $__ssi2 = 0;
            my scalar $__ss_arr2 = $node->{"steps"};
            while ($__ssi2 < scalar(@{$__ss_arr2})) {
                if ($__ssi2 > 0) { emit($cg, ", "); }
                emit($cg, "(void)(");
                gen_expr($cg, $__ss_arr2->[$__ssi2]);
                emit($cg, ")");
                $__ssi2 = $__ssi2 + 1;
            }
        } elsif (defined($node->{"step"})) {
            gen_expr($cg, $node->{"step"});
        }
        emit($cg, ") {\n");
        $cg->{"indent"} = $cg->{"indent"} + 1;
        ind($cg); emit($cg, "void *__fc_local_mark2 = __perla_local_chain;\n");
        my str $redo_label2 = "__perla_redo_" . $for_id;
        ind($cg); emit($cg, $redo_label2 . ": ;\n");
        my str $saved_redo_label2 = "" . $cg->{"redo_label"};
        $cg->{"redo_label"} = $redo_label2;
        gen_block_stmts($cg, $node->{"body"});
        $cg->{"redo_label"} = $saved_redo_label2;
        ind($cg); emit($cg, "if (__perla_local_chain != __fc_local_mark2) { perla_local_chain_restore_to(__perla_local_chain, __fc_local_mark2); __perla_local_chain = __fc_local_mark2; }\n");
        $cg->{"indent"} = $cg->{"indent"} - 1;
        ind($cg); emit($cg, "}\n");
    }
}

# --- Expression generation ---
func gen_expr(scalar $cg, scalar $node) void {
    if (!defined($node)) { emit($cg, "strada_new_undef()"); return; }
    my int $type = $node->{"type"};

    if ($type == Perla::AST::N_INT_LIT()) {
        # Tagged ints store 62 bits of signed integer. Values outside
        # [-2^62, 2^62-1] would corrupt during the `(val << 1) | 1` encode
        # (e.g., 9223372036854775807 shifted left becomes -2, then ORed
        # gives -1). Emit those as heap ints via strada_new_int instead.
        my str $litv = "" . $node->{"value"};
        my int $needs_heap = 0;
        # Compare magnitude as a string vs the boundary 4611686018427387904
        my str $cmp_lit = $litv;
        my int $is_neg = 0;
        if (length($cmp_lit) > 0 && substr($cmp_lit, 0, 1) eq "-") {
            $is_neg = 1;
            $cmp_lit = substr($cmp_lit, 1, length($cmp_lit) - 1);
        }
        # Strip leading zeros
        while (length($cmp_lit) > 1 && substr($cmp_lit, 0, 1) eq "0") {
            $cmp_lit = substr($cmp_lit, 1, length($cmp_lit) - 1);
        }
        if (length($cmp_lit) > 19) {
            $needs_heap = 1;
        } elsif (length($cmp_lit) == 19) {
            # Compare against "4611686018427387903" (positive) or
            # "4611686018427387904" (allowed magnitude for negative).
            my str $bound;
            if ($is_neg == 1) { $bound = "4611686018427387904"; }
            else { $bound = "4611686018427387903"; }
            if ($cmp_lit gt $bound) { $needs_heap = 1; }
        }
        # Above the i64 range: a POSITIVE literal that still fits an
        # unsigned 64-bit (<= 18446744073709551615) becomes a UV via
        # strada_new_uint — matching Perl, which holds such values as UV
        # rather than promoting to NV. Only literals beyond UINT64_MAX (or
        # any out-of-range negative) fall back to NUM (double), since they
        # can't be represented exactly as an integer at all.
        my int $needs_num = 0;
        my int $needs_uint = 0;
        if ($is_neg == 1) {
            # Negatives can't be UV. NUM if magnitude exceeds INT64 min.
            if (length($cmp_lit) > 19) {
                $needs_num = 1;
            } elsif (length($cmp_lit) == 19 && $cmp_lit gt "9223372036854775808") {
                $needs_num = 1;
            }
        } else {
            if (length($cmp_lit) > 20) {
                $needs_num = 1;
            } elsif (length($cmp_lit) == 20) {
                if ($cmp_lit gt "18446744073709551615") { $needs_num = 1; }
                else { $needs_uint = 1; }
            } elsif (length($cmp_lit) == 19 && $cmp_lit gt "9223372036854775807") {
                $needs_uint = 1;
            }
        }
        # Under `use bigint`, a literal that doesn't fit a tagged int is carried
        # as an exact decimal string (the bignum representation) rather than
        # losing precision as a UV/double — `99999999999999999999 + 1` etc.
        if (defined($cg->{"use_bigint"}) && $cg->{"use_bigint"} == 1
            && ($needs_num == 1 || $needs_uint == 1 || $needs_heap == 1)) {
            emit($cg, "strada_new_str(\"" . $litv . "\")");
            return;
        }
        if ($needs_num == 1) {
            emit($cg, "strada_new_num(" . $litv . ".0)");
        } elsif ($needs_uint == 1) {
            emit($cg, "strada_new_uint(" . $litv . "ULL)");
        } elsif ($needs_heap == 1) {
            emit($cg, "strada_new_int((int64_t)" . $litv . "LL)");
        } else {
            emit($cg, "STRADA_MAKE_TAGGED_INT(" . $litv . ")");
        }
        return;
    }
    if ($type == Perla::AST::N_NUM_LIT()) {
        emit($cg, "strada_new_num(" . $node->{"value"} . ")");
        return;
    }
    if ($type == Perla::AST::N_STR_LIT()) {
        # Under `use utf8`, source string literals are char-oriented:
        # set SVf_UTF8 so length()/uc()/lc()/etc. count code points
        # rather than bytes. Without the pragma, perl treats source
        # as bytes (Latin-1 in 5.x); perla then emits the literal
        # byte-oriented.
        my int $__sl_utf8 = 0;
        if (defined($cg->{"use_utf8"}) && $cg->{"use_utf8"} == 1) { $__sl_utf8 = 1; }
        if (defined($node->{"is_utf8"}) && $node->{"is_utf8"} == 1) { $__sl_utf8 = 1; }
        if ($__sl_utf8 == 1) {
            my str $__sl_val = $node->{"value"};
            my str $__sl_esc = Perla::CodeGen::Escape::escape_c_str($__sl_val);
            # The length arg to strada_new_str_len_utf8 is the BYTE length of the
            # emitted C literal — NOT the codepoint count. `length()` here is
            # char-oriented (strada_length_chars_sv ignores the byte flag), so a
            # multi-byte literal got truncated to its codepoint count of bytes
            # (e.g. a `use utf8` string with `Ḩ` lost 2 bytes). Use byte length.
            emit($cg, "strada_new_str_len_utf8(\"" . $__sl_esc . "\", " . core::byte_length($__sl_val) . ")");
        } else {
            emit($cg, "strada_new_str(\"" . Perla::CodeGen::Escape::escape_c_str($node->{"value"}) . "\")");
        }
        return;
    }
    if ($type == Perla::AST::N_INTERP_STR()) {
        Perla::CodeGen::Interp::gen_interp_str($cg, $node->{"value"});
        return;
    }
    if ($type == Perla::AST::N_UNDEF()) {
        emit($cg, "strada_new_undef()");
        return;
    }
    # do { BLOCK } as expression — returns value of last statement
    if ($type == Perla::AST::N_BLOCK()) {
        my scalar $stmts = $node->{"stmts"};
        if (!defined($stmts) || scalar(@{$stmts}) == 0) {
            emit($cg, "strada_new_undef()");
            return;
        }
        # Lexical pragma save (use utf8 / use bytes / use integer) —
        # do-block-as-expression scopes the pragma to its body. Without
        # save/restore here, `do { use bytes; ... }` leaked use_bytes
        # into subsequent code.
        my int $db_save_use_integer = 0;
        if (defined($cg->{"use_integer"})) { $db_save_use_integer = $cg->{"use_integer"}; }
        my int $db_save_use_utf8 = 0;
        if (defined($cg->{"use_utf8"})) { $db_save_use_utf8 = $cg->{"use_utf8"}; }
        my int $db_save_use_bytes = 0;
        if (defined($cg->{"use_bytes"})) { $db_save_use_bytes = $cg->{"use_bytes"}; }
        # Snapshot active `local` saves so `local $X = ...` inside the
        # do block restores at block exit. Without this, `do { local $/;
        # … }` left $/ undef after the block (perla_irs stayed NULL),
        # breaking subsequent line reads.
        my scalar $bb_saved_locals = {};
        if (defined($cg->{"local_vars"})) {
            my array @bb_keys_b = keys($cg->{"local_vars"});
            my int $bb_ki = 0;
            while ($bb_ki < scalar(@bb_keys_b)) {
                my str $bb_v = "" . $cg->{"local_vars"}->{$bb_keys_b[$bb_ki]};
                if ($bb_v ne "__restored__") {
                    $bb_saved_locals->{$bb_keys_b[$bb_ki]} = 1;
                }
                $bb_ki++;
            }
        }
        my int $total = scalar(@{$stmts});
        # Skip trailing synthetic N_PACKAGE restore stmts when picking the
        # block's value-producing last statement. The parser appends a
        # restore stmt to any block that did `package X;` so the outer
        # package context is reinstated; codegen still needs to emit it
        # for runtime-side `caller()` correctness, but it must NOT be
        # treated as the do-block's value. Without this, `do { package
        # Foo; sub { 42 } }` returned undef because the synthetic restore
        # was the AST's last stmt — broke Eval::Closure's sandbox-wrapped
        # `eval q{ package Sandbox_N; sub { ... } };` (every validator
        # silently returned undef instead of a code ref).
        my int $n = $total;
        while ($n > 1 && defined($stmts->[$n - 1])
               && $stmts->[$n - 1]->{"type"} == Perla::AST::N_PACKAGE()
               && defined($stmts->[$n - 1]->{"synthetic"})
               && $stmts->[$n - 1]->{"synthetic"} == 1) {
            $n = $n - 1;
        }
        my scalar $last = $stmts->[$n - 1];
        my int $lt = defined($last) ? $last->{"type"} : 0;
        # If the last stmt is an if/unless, capture each branch's tail
        # expression so the do block returns the right list (matches Perl
        # semantics). Without this, `do { if (X) { LIST_A } else { LIST_B } }`
        # emitted the if as a void C statement and the surrounding
        # statement-expression returned an empty value. Surfaced via
        # SQL::Abstract's
        # `join(' ', do { if (...) { ($table, $as) } elsif (...) { $$x } ... })`
        # — the do block produced empty SQL fragments so the FROM clause
        # came out as `FROM   JOIN  ON 0`.
        if ($lt == Perla::AST::N_IF() || $lt == Perla::AST::N_UNLESS()) {
            emit($cg, "({ StradaValue *__bv = NULL; ");
            my int $bi = 0;
            while ($bi < $n - 1) {
                gen_stmt($cg, $stmts->[$bi]);
                $bi++;
            }
            gen_if_capture_return($cg, $last, "__bv");
            emit($cg, "__bv ? __bv : strada_new_undef(); })");
            return;
        }
        emit($cg, "({ ");
        # Snapshot the local-chain head at block entry. `local $X = ...`
        # inside the block pushes scalar saves on the chain; restoring at
        # block exit unwinds them. Same idea as the eval-block mark, but
        # for plain do { ... } / bare blocks.
        emit($cg, "void *__db_local_mark = __perla_local_chain; ");
        # Snapshot declared_vars / shared_cells_emitted / my_lexicals so
        # `my $X` inside this do { } block doesn't leak into a sibling
        # block. Two adjacent `do { my $x = 0; sub { ... $x ... } }`
        # blocks otherwise reused the same `v_x` and the same closure
        # cell — the second closure captured the first's slot (state
        # bleed). Concrete victim: `inc => do{my$x=0; sub{++$x}},
        # more => do{my$x=0; sub{$x+=2}}` shared $x.
        my scalar $__db_saved_dv = $cg->{"declared_vars"};
        my scalar $__db_saved_ssd = $cg->{"same_scope_decls"};
        my scalar $__db_saved_sc = $cg->{"shared_cells_emitted"};
        my scalar $__db_saved_cmd = $cg->{"cells_malloc_d"};
        my scalar $__db_saved_ml = $cg->{"my_lexicals"};
        my hash %__db_branch_dv = ();
        if (defined($__db_saved_dv)) {
            my array @__db_dvk = keys($__db_saved_dv);
            my int $__db_dvi = 0;
            while ($__db_dvi < scalar(@__db_dvk)) {
                $__db_branch_dv{$__db_dvk[$__db_dvi]} = $__db_saved_dv->{$__db_dvk[$__db_dvi]};
                $__db_dvi = $__db_dvi + 1;
            }
        }
        $cg->{"declared_vars"} = \%__db_branch_dv;
        $cg->{"same_scope_decls"} = {};
        my hash %__db_branch_sc = ();
        if (defined($__db_saved_sc)) {
            my array @__db_sck = keys($__db_saved_sc);
            my int $__db_sci = 0;
            while ($__db_sci < scalar(@__db_sck)) {
                $__db_branch_sc{$__db_sck[$__db_sci]} = $__db_saved_sc->{$__db_sck[$__db_sci]};
                $__db_sci = $__db_sci + 1;
            }
        }
        $cg->{"shared_cells_emitted"} = \%__db_branch_sc;
        if (defined($__db_saved_cmd)) { $cg->{"cells_malloc_d"} = _cg_copy_int_hash($__db_saved_cmd); }
        my array @__db_branch_ml = ();
        if (defined($__db_saved_ml)) {
            my int $__db_mli = 0;
            while ($__db_mli < scalar(@{$__db_saved_ml})) {
                push(@__db_branch_ml, $__db_saved_ml->[$__db_mli]);
                $__db_mli = $__db_mli + 1;
            }
        }
        $cg->{"my_lexicals"} = \@__db_branch_ml;
        # Detect `my X` decls in the do-block body that shadow file-
        # scope vars (same pattern as eval BLOCK). Without save/restore,
        # inner `my $x = "inner"` decrefs outer's value and leaves the
        # outer static pointing into freed memory. We use a chain of
        # comma operators inside the statement expression so the saves
        # are visible to the restores.
        my array @__db_shadowed = ();
        my int $__db_si = 0;
        while ($__db_si < $n) {
            my scalar $__db_ss = $stmts->[$__db_si];
            if (defined($__db_ss) && $__db_ss->{"type"} == Perla::AST::N_MY()) {
                if (defined($__db_ss->{"var"})) {
                    my str $__db_vn = $__db_ss->{"var"}->{"value"};
                    if (_is_file_scope($cg, $__db_vn) == 1) {
                        my str $__db_vt = "" . $__db_ss->{"var"}->{"type"};
                        if (length($__db_vt) == 0) { $__db_vt = "SCALAR_VAR"; }
                        push(@__db_shadowed, c_var_for_vtype($__db_vt, $__db_vn));
                    }
                }
                if (defined($__db_ss->{"vars"})) {
                    my int $__db_dvi = 0;
                    while ($__db_dvi < scalar(@{$__db_ss->{"vars"}})) {
                        my scalar $__db_dv = $__db_ss->{"vars"}->[$__db_dvi];
                        my str $__db_dvn = $__db_dv->{"value"};
                        if (_is_file_scope($cg, $__db_dvn) == 1) {
                            my str $__db_dvt = "" . $__db_dv->{"type"};
                            if (length($__db_dvt) == 0) { $__db_dvt = "SCALAR_VAR"; }
                            push(@__db_shadowed, c_var_for_vtype($__db_dvt, $__db_dvn));
                        }
                        $__db_dvi = $__db_dvi + 1;
                    }
                }
            }
            $__db_si = $__db_si + 1;
        }
        my int $__db_si2 = 0;
        while ($__db_si2 < scalar(@__db_shadowed)) {
            my str $__db_sc = $__db_shadowed[$__db_si2];
            emit($cg, "StradaValue *__db_sav_" . $__db_sc . " = " . $__db_sc . "; " . $__db_sc . " = NULL; ");
            $__db_si2 = $__db_si2 + 1;
        }
        my int $bi = 0;
        while ($bi < $n - 1) {
            gen_stmt($cg, $stmts->[$bi]);
            $bi++;
        }
        # Last statement is the return value. Capture it first, then
        # emit local-restores and synthetic package restores, then yield
        # the captured value. Without the local-restore here, `do {
        # local $X = ...; }` left $X mutated past the do block.
        # Loop forms (for/while) aren't valid expressions; emit them as
        # statements first, then yield undef. Without this branch
        # gen_expr_safe falls through to gen_expr's TODO emit and the
        # loop body is silently skipped.
        my int $__db_last_t = defined($last) ? $last->{"type"} : -1;
        if ($__db_last_t == Perla::AST::N_FOREACH()
            || $__db_last_t == Perla::AST::N_FOR_C()
            || $__db_last_t == Perla::AST::N_WHILE()
            || $__db_last_t == Perla::AST::N_UNTIL()) {
            gen_stmt($cg, $last);
            emit($cg, "StradaValue *__db_rv = strada_new_undef(); ");
        } else {
            emit($cg, "StradaValue *__db_rv = ({ ");
            gen_expr_safe($cg, $last);
            emit($cg, "; }); ");
        }
        # Restore any `local $X` saves created inside this do block.
        if (defined($cg->{"local_vars"})) {
            my array @bb_keys_a = keys($cg->{"local_vars"});
            my int $bb_kj = 0;
            while ($bb_kj < scalar(@bb_keys_a)) {
                my str $bb_kn = $bb_keys_a[$bb_kj];
                if (!defined($bb_saved_locals->{$bb_kn})) {
                    my str $bb_kvt = "" . $cg->{"local_vars"}->{$bb_kn};
                    if (length($bb_kvt) == 0 || $bb_kvt eq "1" || $bb_kvt eq "__restored__") { $bb_kvt = "SCALAR_VAR"; }
                    emit($cg, c_var_for_vtype($bb_kvt, $bb_kn) . " = __local_save_" . safe_ident($bb_kn) . "; ");
                    # Mirror special vars into perla_irs/_ors/_ofs/_lse.
                    if ($bb_kn eq "/") { emit($cg, "perla_irs = __local_save_" . safe_ident($bb_kn) . "; "); }
                    elsif ($bb_kn eq "\\") { emit($cg, "perla_ors = __local_save_" . safe_ident($bb_kn) . "; "); }
                    elsif ($bb_kn eq ",") { emit($cg, "perla_ofs = __local_save_" . safe_ident($bb_kn) . "; "); }
                    elsif ($bb_kn eq "\"") { emit($cg, "perla_lse = __local_save_" . safe_ident($bb_kn) . "; "); }
                    $cg->{"local_vars"}->{$bb_kn} = "__restored__";
                }
                $bb_kj++;
            }
        }
        # Chain restore for scalar locals pushed inside the block.
        # The push helper records the mirror slot (perla_irs etc.) when
        # the local targets a special I/O var, so restore_to fixes the
        # mirror globally too.
        emit($cg, "if (__perla_local_chain != __db_local_mark) { perla_local_chain_restore_to(__perla_local_chain, __db_local_mark); __perla_local_chain = __db_local_mark; } ");
        # Synthetic N_PACKAGE restores (if any).
        if ($n < $total) {
            my int $ti = $n;
            while ($ti < $total) {
                gen_stmt($cg, $stmts->[$ti]);
                $ti++;
            }
        }
        # Restore shadowed file-scope vars. The inner `my $x = "inner"`
        # assigned to v_x's static slot; before yielding __db_rv we
        # must point the slot back at the outer pointer that was saved
        # at block entry. The inner ref's lifetime now transfers to
        # __db_rv (which the caller will own/decref). Incref __db_rv
        # before re-pointing the slot so the static-slot decref pattern
        # downstream stays consistent — without the incref, the only
        # owned reference would dangle once the body's auto-cleanup
        # decremented the slot count.
        my int $__db_si3 = 0;
        while ($__db_si3 < scalar(@__db_shadowed)) {
            my str $__db_sc3 = $__db_shadowed[$__db_si3];
            emit($cg, $__db_sc3 . " = __db_sav_" . $__db_sc3 . "; ");
            $__db_si3 = $__db_si3 + 1;
        }
        # Restore declared_vars / shared_cells_emitted / my_lexicals.
        $cg->{"declared_vars"} = $__db_saved_dv;
        $cg->{"same_scope_decls"} = $__db_saved_ssd;
        $cg->{"shared_cells_emitted"} = $__db_saved_sc;
        $cg->{"cells_malloc_d"} = $__db_saved_cmd;
        $cg->{"my_lexicals"} = $__db_saved_ml;
        # Restore lexical pragmas (use integer/utf8/bytes) at do-block exit.
        $cg->{"use_integer"} = $db_save_use_integer;
        $cg->{"use_utf8"} = $db_save_use_utf8;
        $cg->{"use_bytes"} = $db_save_use_bytes;
        emit($cg, "__db_rv; })");
        return;
    }

    if ($type == Perla::AST::N_GLOB_ACCESS()) {
        my scalar $gexpr = $node->{"expr"};
        if (defined($gexpr)) {
            # Dynamic: *{EXPR} / &{EXPR} — EXPR may already be a code ref
            # (CLOSURE / CPOINTER) when the caller did `&{\$sub}(args)`.
            # Try that first; if EXPR resolves to a string, fall through to
            # the stash lookup so `&{"main::foo"}()` still works.
            emit($cg, "({ StradaValue *__ge = ");
            gen_expr_safe($cg, $gexpr);
            emit($cg, "; StradaValue *__gv = NULL; ");
            emit($cg, "if (__ge && !STRADA_IS_TAGGED_INT(__ge) && (__ge->type == STRADA_CLOSURE || __ge->type == STRADA_CPOINTER)) { __gv = __ge; } ");
            emit($cg, "else { char *__gn = strada_to_str(__ge); char *__ls = NULL; for (char *__p = __gn; *__p; __p++) if (__p[0]==':'&&__p[1]==':') __ls=__p; ");
            emit($cg, "char *__gpkg = \"" . $cg->{"pkg"} . "\"; char *__gshort = __gn; char *__gpb = NULL; ");
            emit($cg, "if (__ls) { __gpb = strndup(__gn, __ls-__gn); __gpkg = __gpb; __gshort = __ls+2; } ");
            emit($cg, "PerlGlob *__g = perla_glob_get(perla_stash_get_or_create(__gpkg), __gshort); ");
            emit($cg, "__gv = strada_new_undef(); ");
            emit($cg, "if (__g && __g->slots[PERLA_SLOT_CODE]) { ");
            emit($cg, "  StradaValue *__csv = __g->slots[PERLA_SLOT_CODE]; ");
            emit($cg, "  if (__csv && !STRADA_IS_TAGGED_INT(__csv) && (__csv->type == STRADA_CLOSURE || __csv->type == STRADA_CPOINTER || __csv->type == STRADA_REF)) { __gv = __csv; } ");
            emit($cg, "  else if (__csv && !STRADA_IS_TAGGED_INT(__csv) && __csv->type == STRADA_STR) { ");
            emit($cg, "    char *__fn = strada_to_str(__csv); void *__fp = dlsym(RTLD_DEFAULT, __fn); ");
            emit($cg, "    if (__fp) __gv = strada_cpointer_new(__fp); free(__fn); } } ");
            emit($cg, "if (__gpb) free(__gpb); free(__gn); } __gv; })");
        } else {
            # Static: *Foo::bar
            my str $gname = $node->{"name"};
            my int $sep = -1;
            my int $gi = length($gname) - 1;
            while ($gi >= 0) {
                if ($gi > 0 && substr($gname, $gi - 1, 2) eq "::") { $sep = $gi - 1; last; }
                $gi--;
            }
            my str $gpkg = $cg->{"pkg"};
            my str $gshort = $gname;
            if ($sep >= 0) {
                $gpkg = substr($gname, 0, $sep);
                $gshort = substr($gname, $sep + 2, length($gname) - $sep - 2);
            }
            # Typeglob slot accessor: *NAME{CODE/SCALAR/ARRAY/HASH/IO}.
            # Returns a ref to the named slot's value (or undef if empty).
            my str $__sslot = "";
            if (defined($node->{"slot"})) { $__sslot = "" . $node->{"slot"}; }
            if ($__sslot eq "CODE") {
                # *NAME{CODE} → ref to the sub. perla stores subs as
                # CPOINTER (native) or STRADA_STR (C-symbol-name). Return
                # the CODE slot directly; ref() reports "CODE".
                emit($cg, "({ PerlGlob *__g = perla_glob_get(perla_stash_get_or_create(\"" . $gpkg . "\"), \"" . $gshort . "\"); ");
                emit($cg, "StradaValue *__cs = (__g && __g->slots[PERLA_SLOT_CODE]) ? __g->slots[PERLA_SLOT_CODE] : NULL; ");
                emit($cg, "if (__cs && !STRADA_IS_TAGGED_INT(__cs) && __cs->type == STRADA_STR && __cs->value.pv) { ");
                emit($cg, "  void *__fp = dlsym(RTLD_DEFAULT, __cs->value.pv); ");
                emit($cg, "  if (__fp) __cs = strada_cpointer_new(__fp); ");
                emit($cg, "} ");
                emit($cg, "(__cs ? ({ strada_incref(__cs); __cs; }) : strada_new_undef()); })");
            } elsif ($__sslot eq "SCALAR") {
                emit($cg, "({ StradaValue *__sv = perla_scalar_get(\"" . $gpkg . "\", \"" . $gshort . "\"); ");
                emit($cg, "if (!__sv) __sv = strada_new_undef(); ");
                emit($cg, "strada_new_ref_take(__sv, '\$'); })");
            } elsif ($__sslot eq "ARRAY") {
                emit($cg, "({ StradaValue *__av = perla_array_get(\"" . $gpkg . "\", \"" . $gshort . "\"); ");
                emit($cg, "if (!__av) __av = strada_new_array(); else strada_incref(__av); ");
                emit($cg, "strada_new_ref_take(__av, '@'); })");
            } elsif ($__sslot eq "HASH") {
                emit($cg, "({ StradaValue *__hv = perla_hash_get(\"" . $gpkg . "\", \"" . $gshort . "\"); ");
                emit($cg, "if (!__hv) __hv = strada_new_hash(); else strada_incref(__hv); ");
                emit($cg, "strada_new_ref_take(__hv, '%'); })");
            } elsif ($__sslot eq "NAME") {
                emit($cg, "strada_new_str(\"" . $gshort . "\")");
            } elsif ($__sslot eq "PACKAGE") {
                emit($cg, "strada_new_str(\"" . $gpkg . "\")");
            } else {
                # No slot (or unknown slot) → return CODE slot for back-compat.
                emit($cg, "({ PerlGlob *__g = perla_glob_get(perla_stash_get_or_create(\"" . $gpkg . "\"), \"" . $gshort . "\"); ");
                emit($cg, "__g ? __g->slots[PERLA_SLOT_CODE] : strada_new_undef(); })");
            }
        }
        return;
    }
    if ($type == Perla::AST::N_EVAL_STRING()) {
        Perla::CodeGen::Eval::emit_eval_string_with_caps($cg, $node, 1);
        return;
    }
    # eval { BLOCK } in expression context: evaluate the block and
    # yield its last expression's value (like Perl — eval returns
    # what the block's last statement evaluates to, or undef on die).
    # The statement-form N_EVAL_BLOCK (_gen_stmt) just runs the block
    # and discards the result; in expression context we need the value.
    if ($type == Perla::AST::N_EVAL_BLOCK()) {
        # Lexical pragma save — eval BLOCK is a lexical scope.
        # `eval { use bytes; ... }` should not leak use_bytes past
        # the eval. Mirrored from do-block / bare-block handlers.
        my int $eb_save_use_integer = 0;
        if (defined($cg->{"use_integer"})) { $eb_save_use_integer = $cg->{"use_integer"}; }
        my int $eb_save_use_utf8 = 0;
        if (defined($cg->{"use_utf8"})) { $eb_save_use_utf8 = $cg->{"use_utf8"}; }
        my int $eb_save_use_bytes = 0;
        if (defined($cg->{"use_bytes"})) { $eb_save_use_bytes = $cg->{"use_bytes"}; }
        emit($cg, "({ StradaValue *__ev_val = NULL; ");
        # Shadow caller_want_list so wantarray inside the eval body
        # reflects the context the eval expression itself is in
        # (`my @x = eval { ... }` → list; `my $x = eval { ... }` →
        # scalar). Without this, wantarray reads the file-scope global
        # which is always 0.
        emit($cg, "int __perla_caller_want_list = __perla_want_list; ");
        # Capture local-chain head so any `local` pushed during the eval
        # body (including in nested function calls) is restored on both
        # normal exit AND die (longjmp would otherwise skip per-function
        # exit handlers).
        emit($cg, "void *__perla_local_chain_mark = __perla_local_chain; ");
        # Save call-stack depth so frames pushed by dying sub calls
        # inside the eval body get unwound on catch (otherwise stale
        # frames pollute later caller() walks).
        emit($cg, "int __eval_sav_depth = perla_call_depth; ");
        # Synthetic "(eval)" frame for Carp::confess (mirrors statement-form
        # eval block above). Pushed after __eval_sav_depth so die-unwind
        # pops it; success path adds explicit pop before the `} else {`.
        my int $__ev_pln_expr = 0;
        if (defined($node->{"line"})) { $__ev_pln_expr = $node->{"line"} + 0; }
        my str $__ev_pkg_expr = "main";
        if (defined($cg->{"pkg"})) { $__ev_pkg_expr = "" . $cg->{"pkg"}; }
        emit($cg, "perla_pending_call_line = " . $__ev_pln_expr . "; ");
        emit($cg, "perla_call_push(\"" . $__ev_pkg_expr . "\", \"(eval)\", \"" . $cg->{"filename"} . "\", 0); ");
        emit($cg, "if (perla_eval_error) strada_decref(perla_eval_error); ");
        emit($cg, "perla_eval_error = strada_new_str(\"\"); ");
        emit($cg, "jmp_buf *__ev_jb = STRADA_TRY_PUSH(); ");
        emit($cg, "if (__ev_jb && setjmp(*__ev_jb) == 0) { do { ");
        # Track depth so a `return` inside the body emits a `break`
        # that exits the do-while(0) instead of returning from the
        # enclosing sub. Stacks naturally via integer increment.
        my int $__save_eb = 0;
        if (defined($cg->{"eval_block_expr_active"})) { $__save_eb = $cg->{"eval_block_expr_active"}; }
        $cg->{"eval_block_expr_active"} = $__save_eb + 1;
        # Emit block's stmts; track the last and capture its value.
        my scalar $ev_body = $node->{"body"};
        my scalar $ev_stmts = defined($ev_body) ? $ev_body->{"stmts"} : undef;
        if (defined($ev_stmts)) {
            my int $ev_n = scalar(@{$ev_stmts});
            my int $ev_i = 0;
            while ($ev_i < $ev_n - 1) {
                # Regular statement — emit normally.
                my scalar $ev_s = $ev_stmts->[$ev_i];
                if (defined($ev_s)) {
                    gen_stmt($cg, $ev_s);
                }
                $ev_i++;
            }
            # Capture the last stmt's value if it's an expression-bearing form.
            if ($ev_n > 0) {
                my scalar $ev_last = $ev_stmts->[$ev_n - 1];
                my int $ev_last_t = defined($ev_last) ? $ev_last->{"type"} : 0;
                # If last stmt is a bare expression, capture. Else emit
                # statement and leave __ev_val = NULL (same as Perl
                # returning undef from a block whose last stmt is
                # control-flow).
                # `return EXPR` inside an eval block should yield EXPR
                # as the eval's value, NOT return from the enclosing sub.
                # Rewrite to a __ev_val capture.
                if ($ev_last_t == Perla::AST::N_RETURN()) {
                    if (defined($ev_last->{"value"})) {
                        emit($cg, "__ev_val = ");
                        gen_expr($cg, $ev_last->{"value"});
                        emit($cg, "; if (__ev_val) strada_incref(__ev_val); ");
                    }
                } elsif ($ev_last_t == Perla::AST::N_LAST()
                    || $ev_last_t == Perla::AST::N_NEXT()
                    || $ev_last_t == Perla::AST::N_REDO()
                    || $ev_last_t == Perla::AST::N_IF()
                    || $ev_last_t == Perla::AST::N_UNLESS()
                    || $ev_last_t == Perla::AST::N_WHILE()
                    || $ev_last_t == Perla::AST::N_UNTIL()
                    || $ev_last_t == Perla::AST::N_FOR_C()
                    || $ev_last_t == Perla::AST::N_FOREACH()) {
                    if (defined($ev_last)) {
                        gen_stmt($cg, $ev_last);
                    }
                } elsif ($ev_last_t == Perla::AST::N_MY()
                      || $ev_last_t == Perla::AST::N_OUR()) {
                    # `eval { my $x = EXPR }` should return EXPR, not undef.
                    # Treating N_MY as a statement leaves __ev_val = NULL,
                    # so eval returns undef even though Perl returns the
                    # assigned value. Capture via the expression form.
                    if (defined($ev_last)) {
                        emit($cg, "__ev_val = ");
                        gen_expr($cg, $ev_last);
                        emit($cg, "; if (__ev_val) strada_incref(__ev_val); ");
                    }
                } else {
                    emit($cg, "__ev_val = ");
                    gen_expr($cg, $ev_last);
                    emit($cg, "; if (__ev_val) strada_incref(__ev_val); ");
                }
            }
        }
        # Close do-while loop and restore eval-block flag.
        $cg->{"eval_block_expr_active"} = $__save_eb;
        emit($cg, " } while (0); ");
        emit($cg, "if (__perla_local_chain != __perla_local_chain_mark) { perla_local_chain_restore_to(__perla_local_chain, __perla_local_chain_mark); __perla_local_chain = __perla_local_chain_mark; } ");
        emit($cg, "STRADA_TRY_POP(); ");
        emit($cg, "if (perla_eval_error) strada_decref(perla_eval_error); ");
        emit($cg, "perla_eval_error = strada_new_str(\"\"); ");
        emit($cg, "perla_call_pop(); ");
        emit($cg, "} else { ");
        # Restore want_list. die's longjmp bypasses inner per-statement save/restore,
        # so the void-context (-1) set around a dying call leaks out otherwise.
        # __perla_caller_want_list was saved from __perla_want_list above (line ~4376).
        emit($cg, "__perla_want_list = __perla_caller_want_list; ");
        emit($cg, "while (perla_call_depth > __eval_sav_depth) perla_call_pop(); ");
        emit($cg, "if (__perla_local_chain != __perla_local_chain_mark) { perla_local_chain_restore_to(__perla_local_chain, __perla_local_chain_mark); __perla_local_chain = __perla_local_chain_mark; } ");
        emit($cg, "STRADA_TRY_POP(); ");
        emit($cg, "if (!perla_eval_error || (!STRADA_IS_TAGGED_INT(perla_eval_error) && perla_eval_error->type == STRADA_STR && perla_eval_error->value.pv && strlen(perla_eval_error->value.pv) == 0)) { ");
        emit($cg, "if (perla_eval_error) strada_decref(perla_eval_error); ");
        # Prefer strada_exception_value (preserves blessed refs) over the stringified message
        emit($cg, "if (strada_exception_value) { perla_eval_error = strada_exception_value; strada_incref(perla_eval_error); } ");
        emit($cg, "else { perla_eval_error = strada_exception_msg ? strada_new_str(strada_exception_msg) : strada_new_str(\"Unknown error\"); } ");
        emit($cg, "} if (getenv(\"PERLA_TRACE_CATCH\")) { char *__tc = strada_to_str(perla_eval_error); fprintf(stderr, \"[catch-expr] %s\\n\", __tc ? __tc : \"(empty)\"); free(__tc); } __ev_val = NULL; } ");
        # In list context, an eval that died returns the empty list,
        # not undef (Perl: `my @r = eval { die }` → 0-element array).
        emit($cg, "__ev_val ? __ev_val : (__perla_caller_want_list ? strada_new_array() : strada_new_undef()); })");
        # Restore lexical pragmas at eval-block exit.
        $cg->{"use_integer"} = $eb_save_use_integer;
        $cg->{"use_utf8"} = $eb_save_use_utf8;
        $cg->{"use_bytes"} = $eb_save_use_bytes;
        return;
    }
    if ($type == Perla::AST::N_REQUIRE()) {
        my str $mod = $node->{"module"};
        if (defined($mod) && length($mod) > 0) {
            emit($cg, "perla_require_module(strada_new_str(\"" . $mod . "\"))");
        } else if (defined($node->{"expr"})) {
            emit($cg, "perla_require_module(");
            gen_expr($cg, $node->{"expr"});
            emit($cg, ")");
        } else {
            emit($cg, "strada_new_undef()");
        }
        return;
    }
    if ($type == Perla::AST::N_SCALAR_VAR()) {
        my str $name = $node->{"name"};
        # Special variables
        if ($name eq "_") {
            emit($cg, "perla_dollar_underscore");
            return;
        }
        if ($name eq "@") {
            # `$@` reads default to the empty string (not undef) in perl —
            # `defined($@)` at startup is true. The global starts NULL until
            # the first die/eval, so lazy-init on first read so user code
            # checking `defined($@)` doesn't see undef. Matches the
            # eval-success refcount pattern (rc=2 after init so external
            # decrefs don't free the slot).
            emit($cg, "({ if (!perla_eval_error) { perla_eval_error = strada_new_str(\"\"); strada_incref(perla_eval_error); } perla_eval_error; })");
            return;
        }
        if ($name eq "AUTOLOAD") {
            emit($cg, "perla_get_autoload_var()");
            return;
        }
        # $a and $b — sort comparator variables (only inside sort blocks)
        # These are always mapped to @_[0] and @_[1] in sort comparator subs
        # since the sub receives the pair as arguments
        if ($name eq "!") {
            # $! is a dualvar — string form is strerror(errno), numeric
            # form is errno itself. `$! + 0` must return the errno number,
            # not 0 (which strerror's string parses to). When errno is 0
            # (no error pending), emit "" — not strerror(0)'s "Success" /
            # "Unknown error 0" string, which made `if ($!)` truthy at
            # startup and `$! eq ""` always false. perl's documented
            # convention is that $! is empty when no error is set.
            emit($cg, "strada_new_dualvar((int64_t)errno, errno ? strerror(errno) : \"\")");
            return;
        }
        # $1-$9 capture variables
        if ($name ge "1" && $name le "9") {
            emit($cg, "strada_capture_var(" . $name . ")");
            return;
        }
        # $& — whole match (same as $0 capture in PCRE2)
        if ($name eq "&") {
            emit($cg, "strada_capture_var(0)");
            return;
        }
        # $` — prematch
        if ($name eq "`") {
            emit($cg, "strada_prematch()");
            return;
        }
        # $' — postmatch
        if ($name eq "'") {
            emit($cg, "strada_postmatch()");
            return;
        }
        # $0 — program name (from argv[0] at main() startup, mutable).
        if ($name eq "0") {
            emit($cg, "(perla_dollar_zero ? ({ strada_incref(perla_dollar_zero); perla_dollar_zero; }) : strada_new_str(\"perla\"))");
            return;
        }
        # \$ARGV — current filename during \`while (<>)\` reads. Set by
        # perla_readline_argv on each file boundary. perla_current_argv
        # is a runtime global; falls back to undef when no diamond read
        # has fired (matching Perl).
        if ($name eq "ARGV") {
            emit($cg, "(perla_current_argv ? ({ strada_incref(perla_current_argv); perla_current_argv; }) : strada_new_undef())");
            return;
        }
        # $+ — last paren match value (last successful capture).
        if ($name eq "+") {
            emit($cg, "strada_last_paren_match()");
            return;
        }
        # $$ — process ID
        if ($name eq "$") {
            emit($cg, "STRADA_MAKE_TAGGED_INT((int64_t)getpid())");
            return;
        }
        # $? — wait status of last system()/qx (raw waitpid status).
        if ($name eq "?") {
            emit($cg, "STRADA_MAKE_TAGGED_INT((int64_t)perla_dollar_question)");
            return;
        }
        # $. — current input line number (from last <FH> read).
        if ($name eq ".") {
            emit($cg, "STRADA_MAKE_TAGGED_INT((int64_t)perla_dollar_dot)");
            return;
        }
        # $/ — input record separator
        if ($name eq "/") {
            emit($cg, "perla_irs");
            return;
        }
        # $~ — current format name (default = handle name)
        if ($name eq "~") {
            emit($cg, "(perla_dollar_tilde ? perla_dollar_tilde : strada_new_undef())");
            return;
        }
        # $^ — top-of-page format name
        if ($name eq "^") {
            emit($cg, "(perla_dollar_caret ? perla_dollar_caret : strada_new_undef())");
            return;
        }
        # $= — current page length
        if ($name eq "=") {
            emit($cg, "(perla_dollar_equals ? perla_dollar_equals : STRADA_MAKE_TAGGED_INT(60))");
            return;
        }
        # $% — current page number (write-incremented by format_TOP)
        if ($name eq "%") {
            emit($cg, "(perla_dollar_percent ? perla_dollar_percent : STRADA_MAKE_TAGGED_INT(0))");
            return;
        }
        # $^A — formline accumulator
        if ($name eq "^A") {
            emit($cg, "(perla_dollar_caret_A ? perla_dollar_caret_A : strada_new_str(\"\"))");
            return;
        }
        # $\ — output record separator
        if ($name eq "\\") {
            emit($cg, "perla_ors");
            return;
        }
        # $, — output field separator
        if ($name eq ",") {
            emit($cg, "perla_ofs");
            return;
        }
        # $" — list separator for array interpolation
        if ($name eq "\"") {
            emit($cg, "perla_lse");
            return;
        }
        # $| — output autoflush
        if ($name eq "|") {
            emit($cg, "STRADA_MAKE_TAGGED_INT((int64_t)__perla_autoflush)");
            return;
        }
        # $; — subscript separator (real variable so `$; = "..."` is an
        # lvalue; default is "\034" set in main init).
        if ($name eq ";") {
            emit($cg, "perla_subsep");
            return;
        }
        # $< / $> — real / effective UID. Without this, `$<` parsed as
        # N_SCALAR_VAR name="<" then fell through to perla_scalar_get
        # which returned undef; common idiom `if ($< == 0) { root }`
        # always failed.
        if ($name eq "<") {
            emit($cg, "STRADA_MAKE_TAGGED_INT((int64_t)getuid())");
            return;
        }
        if ($name eq ">") {
            emit($cg, "STRADA_MAKE_TAGGED_INT((int64_t)geteuid())");
            return;
        }
        # $( / $) — real / effective GID.
        if ($name eq "(") {
            emit($cg, "STRADA_MAKE_TAGGED_INT((int64_t)getgid())");
            return;
        }
        if ($name eq ")") {
            emit($cg, "STRADA_MAKE_TAGGED_INT((int64_t)getegid())");
            return;
        }
        # Package-qualified $Pkg::Name reads go through the stash so
        # cross-package access sees any package's `our $VAR` (or file-scope
        # `my $VAR` we publish at startup). Without this the fully-qualified
        # form resolves to a file-static never updated from other packages.
        if (index($name, "::") > 0) {
            my int $li = -1;
            my int $si = 0;
            while ($si < length($name) - 1) {
                if (substr($name, $si, 2) eq "::") { $li = $si; }
                $si++;
            }
            my str $spkg = substr($name, 0, $li);
            my str $sname = substr($name, $li + 2, length($name) - $li - 2);
            emit($cg, "perla_scalar_get(\"" . $spkg . "\", \"" . $sname . "\")");
            return;
        }
        # Scalars stay on plain _c_var — no mangle suffix.
        _strict_check_var($cg, "\$", $name, $node->{"line"} + 0);
        emit($cg, c_var($name));
        return;
    }
    if ($type == Perla::AST::N_ARRAY_VAR()) {
        my str $name = $node->{"name"};
        if ($name eq "_") {
            emit($cg, "perla_at_");
            return;
        }
        # `@-` and `@+` — regex match offset arrays. Without these,
        # whole-array access of @- / @+ fell back to the generic
        # c_var_a path (v__minus_ / v__plus_) which was never
        # populated. Element access ($-[N] / $+[N]) already routes
        # correctly via the N_ARRAY_ELEM codegen; only whole-array
        # was broken.
        if ($name eq "-") {
            emit($cg, "strada_match_starts()");
            return;
        }
        if ($name eq "+") {
            emit($cg, "strada_match_ends()");
            return;
        }
        # Package-qualified @Pkg::Name reads go through the stash so
        # runtime assignments like `@{"Pkg::ISA"}=Parent` (which write to
        # the stash via perla_isa_assign) are visible here. Without this,
        # perla_isa_assign writes to stash->isa but the compiled access
        # reads a separate static C global that was never updated.
        if (index($name, "::") > 0) {
            my int $li = -1;
            my int $si = 0;
            while ($si < length($name) - 1) {
                if (substr($name, $si, 2) eq "::") { $li = $si; }
                $si++;
            }
            my str $apkg = substr($name, 0, $li);
            my str $aname = substr($name, $li + 2, length($name) - $li - 2);
            emit($cg, "perla_array_get(\"" . $apkg . "\", \"" . $aname . "\")");
            return;
        }
        _strict_check_var($cg, "@", $name, $node->{"line"} + 0);
        emit($cg, c_var_a($name));
        return;
    }
    if ($type == Perla::AST::N_HASH_VAR()) {
        my str $hvname = $node->{"name"};
        # `%+` — named regex captures hash. Route to strada_named_captures()
        # so `%parsed = %+` and friends iterate the actual captures.
        # Without this, c_var_h returned v__plus (a never-initialized
        # global) and %+ behaved as empty.
        if ($hvname eq "+") {
            emit($cg, "strada_named_captures()");
            return;
        }
        # `%Pkg::` (trailing `::` and no name after) — Perl's stash-as-hash
        # form. `keys %Mine::` returns the package's defined symbol names;
        # `each %Mine::` iterates them. perla_stash_as_hash snapshots the
        # current stash entries into a fresh HASH (value = "*Pkg::name"
        # matching Perl's typeglob stringification). Snapshot semantics
        # are sufficient for the common `keys`/`each`/`exists` patterns.
        if (length($hvname) >= 2 && substr($hvname, length($hvname) - 2, 2) eq "::") {
            my str $sn = substr($hvname, 0, length($hvname) - 2);
            emit($cg, "perla_stash_as_hash(\"" . $sn . "\")");
            return;
        }
        # Package-qualified %Pkg::Name reads go through the stash so a
        # package's `our %H` (published to its glob) and a cross-package
        # `$Pkg::H{$k}` read see the same hash. Without this the
        # fully-qualified form resolves to a distinct file-static that's
        # never linked to v_H.
        if (index($hvname, "::") > 0) {
            my int $li = -1;
            my int $si = 0;
            while ($si < length($hvname) - 1) {
                if (substr($hvname, $si, 2) eq "::") { $li = $si; }
                $si++;
            }
            my str $hpkg = substr($hvname, 0, $li);
            my str $hname = substr($hvname, $li + 2, length($hvname) - $li - 2);
            emit($cg, "perla_hash_get(\"" . $hpkg . "\", \"" . $hname . "\")");
            return;
        }
        _strict_check_var($cg, "%", $hvname, $node->{"line"} + 0);
        emit($cg, c_var_h($hvname));
        return;
    }

    if ($type == Perla::AST::N_RAW_C()) {
        # Codegen-internal placeholder: emit a raw C expression
        # already constructed by the caller. Used by N_CHAIN_CMP to
        # delegate sub-binop emission back into _gen_binop without
        # re-evaluating each operand.
        emit($cg, $node->{"text"});
        return;
    }
    if ($type == Perla::AST::N_BINOP()) {
        Perla::CodeGen::Operator::_gen_binop($cg, $node);
        return;
    }
    if ($type == Perla::AST::N_CHAIN_CMP()) {
        # Perl 5.32+ chained comparison: A op1 B op2 C op3 D ...
        # ≡ (A op1 B) && (B op2 C) && (C op3 D), with each operand
        # evaluated exactly once. Short-circuits on the first false
        # link. Materialise by capturing each operand into a fresh
        # __cc_NN slot and chaining ternary ANDs.
        my scalar $ops = $node->{"ops"};
        my scalar $operands = $node->{"operands"};
        my int $n_op = scalar(@{$ops});
        # Cache operands as __cc_0 .. __cc_n.
        emit($cg, "({ ");
        my int $ci = 0;
        while ($ci <= $n_op) {
            emit($cg, "StradaValue *__cc_" . $ci . " = ");
            gen_expr($cg, $operands->[$ci]);
            emit($cg, "; ");
            $ci++;
        }
        # Build the comparison chain. Each link is a single binop on
        # the two cached operands; we synthesise an N_BINOP node and
        # delegate to the existing _gen_binop emit. Tier-3 (=~/!~/~~)
        # is rejected by the parser before getting here, so all ops
        # are pure numeric or string comparisons whose codegen yields
        # a perl-truthy StradaValue (tagged-int 1 or strada_new_str("")).
        emit($cg, "int __cc_pass = 1; ");
        my int $li = 0;
        while ($li < $n_op) {
            emit($cg, "if (__cc_pass) { StradaValue *__cc_lr = ");
            my scalar $link = Perla::AST::node(Perla::AST::N_BINOP());
            $link->{"op"} = $ops->[$li];
            my scalar $lvar = Perla::AST::node(Perla::AST::N_RAW_C());
            $lvar->{"text"} = "__cc_" . $li;
            my scalar $rvar = Perla::AST::node(Perla::AST::N_RAW_C());
            $rvar->{"text"} = "__cc_" . ($li + 1);
            $link->{"left"} = $lvar;
            $link->{"right"} = $rvar;
            gen_expr($cg, $link);
            emit($cg, "; if (!perla_to_bool(__cc_lr)) __cc_pass = 0; ");
            emit($cg, "if (__cc_lr) strada_decref(__cc_lr); } ");
            $li++;
        }
        # Decref captured operands.
        my int $di = 0;
        while ($di <= $n_op) {
            emit($cg, "if (__cc_" . $di . ") strada_decref(__cc_" . $di . "); ");
            $di++;
        }
        emit($cg, "__cc_pass ? STRADA_MAKE_TAGGED_INT(1) : strada_new_str(\"\"); })");
        return;
    }
    if ($type == Perla::AST::N_UNOP()) {
        Perla::CodeGen::Operator::_gen_unop($cg, $node);
        return;
    }
    if ($type == Perla::AST::N_ASSIGN()) {
        # In expression context, plain `=` on a simple scalar/array/hash var
        # must use `(target = value)` form — the statement-level path would
        # emit `strada_decref(target); target = value` which is invalid when
        # embedded inside another expression (e.g. `__try_result = ASSIGN`).
        if (defined($node->{"op"}) && $node->{"op"} eq "=") {
            my scalar $atarget = $node->{"target"};
            # `vec(EXPR, OFFSET, BITS) = VALUE` — perl's bit-vector
            # lvalue. The target N_CALL("vec") isn't a real lvalue;
            # route through strada_vec_set which writes into EXPR's
            # underlying string. Returns VALUE (matching perl's
            # assignment-expression value).
            if (defined($atarget) && $atarget->{"type"} == Perla::AST::N_CALL()
                && defined($atarget->{"name"}) && $atarget->{"name"} eq "vec"
                && defined($atarget->{"args"}) && scalar(@{$atarget->{"args"}}) == 3) {
                emit($cg, "({ StradaValue *__vec_sv = ");
                gen_expr($cg, $atarget->{"args"}->[0]);
                emit($cg, "; int64_t __vec_off = strada_to_int(");
                gen_expr($cg, $atarget->{"args"}->[1]);
                emit($cg, "); int __vec_bits = (int)strada_to_int(");
                gen_expr($cg, $atarget->{"args"}->[2]);
                emit($cg, "); int64_t __vec_val = strada_to_int(");
                gen_expr($cg, $node->{"value"});
                emit($cg, "); strada_vec_set(__vec_sv, __vec_off, __vec_bits, __vec_val); STRADA_MAKE_TAGGED_INT(__vec_val); })");
                return;
            }
            if (defined($atarget)) {
                my int $attype = $atarget->{"type"};
                # Perl special scalars ($!, $/, $\, $,, $|) don't have real
                # lvalues — the read form expands to a function call (e.g.
                # strerror(errno)) so `(target = value)` fails at the C
                # level. Hand these off to _gen_assign which has per-var
                # statement-expression emitters that side-effect the
                # underlying C state correctly.
                if ($attype == Perla::AST::N_SCALAR_VAR()) {
                    my str $asvname = $atarget->{"name"};
                    if ($asvname eq "!" || $asvname eq "/" || $asvname eq "\\"
                        || $asvname eq "," || $asvname eq "|" || $asvname eq "0"
                        || $asvname eq "?" || $asvname eq "~" || $asvname eq "^"
                        || $asvname eq "=" || $asvname eq "%" || $asvname eq "^A") {
                        Perla::CodeGen::Assign::_gen_assign($cg, $node);
                        return;
                    }
                    # $AUTOLOAD reads emit perla_get_autoload_var() (non-lvalue);
                    # route writes through the setter helper.
                    if ($asvname eq "AUTOLOAD") {
                        emit($cg, "({ StradaValue *__al_v = ");
                        gen_expr($cg, $node->{"value"});
                        emit($cg, "; perla_set_autoload_var_sv(__al_v); strada_incref(__al_v); __al_v; })");
                        return;
                    }
                }
                # `$#arr = N` — N_SPECIAL_VAR with "#NAME" — route to
                # _gen_assign for the truncate/extend semantics.
                if ($attype == Perla::AST::N_SPECIAL_VAR()
                    && defined($atarget->{"value"})
                    && substr($atarget->{"value"}, 0, 1) eq "#") {
                    Perla::CodeGen::Assign::_gen_assign($cg, $node);
                    return;
                }
                # HASH_VAR = LIST needs the list-to-hash conversion, not a
                # plain `(target = value)` — otherwise `%h = ()` or
                # `%h = (k, v, ...)` assigns an array to the hash slot and
                # later strada_hv_store silently fails. Delegate to the
                # statement-level path which has the conversion logic.
                if ($attype == Perla::AST::N_HASH_VAR()) {
                    Perla::CodeGen::Assign::_gen_assign($cg, $node);
                    return;
                }
                # ARRAY_VAR = RHS needs list-context evaluation of RHS.
                # Without delegating, `@arr = func()` reduces func's return
                # to scalar (last elem). Delegate to _gen_assign which has
                # the list-context branch.
                if ($attype == Perla::AST::N_ARRAY_VAR()
                    && (!defined($atarget->{"name"})
                        || index($atarget->{"name"}, "::") < 0)) {
                    Perla::CodeGen::Assign::_gen_assign($cg, $node);
                    return;
                }
                # Package-qualified @Pkg::Name = ... — the read form uses
                # perla_array_get (which returns an rvalue), so the plain
                # `(target = value)` form would try to assign to a function
                # return. Delegate to _gen_assign which has a stash-aware
                # path (perla_isa_assign for ISA, perla_glob_store
                # otherwise).
                if ($attype == Perla::AST::N_ARRAY_VAR()
                    && defined($atarget->{"name"})
                    && index($atarget->{"name"}, "::") > 0) {
                    Perla::CodeGen::Assign::_gen_assign($cg, $node);
                    return;
                }
                # Package-qualified $Pkg::Name = ... — same reason
                # (perla_scalar_get is non-lvalue). Delegate to _gen_assign
                # which routes through perla_scalar_set.
                if ($attype == Perla::AST::N_SCALAR_VAR()
                    && defined($atarget->{"name"})
                    && index($atarget->{"name"}, "::") > 0) {
                    Perla::CodeGen::Assign::_gen_assign($cg, $node);
                    return;
                }
                # $1, ..., $9, $& — read-only regex capture vars. The
                # gen_expr path below would emit `strada_capture_var(N) =`
                # which gcc rejects. Delegate to _gen_assign which has a
                # runtime-die path for these.
                if ($attype == Perla::AST::N_SCALAR_VAR()
                    && defined($atarget->{"name"})
                    && ((length($atarget->{"name"}) == 1
                         && $atarget->{"name"} ge "1"
                         && $atarget->{"name"} le "9")
                        || $atarget->{"name"} eq "&")) {
                    Perla::CodeGen::Assign::_gen_assign($cg, $node);
                    return;
                }
                if ($attype == Perla::AST::N_SCALAR_VAR() || $attype == Perla::AST::N_ARRAY_VAR() || $attype == Perla::AST::N_HASH_VAR()) {
                    # strict 'vars' on the WRITE side. Without this, `use
                    # strict; $foo = 3;` silently registered $foo as
                    # IMPLICIT_GLOBAL and the error only surfaced on the
                    # next READ. Real Perl errors on both first read AND
                    # first write — match that here.
                    my str $__sw2_sigil = "\$";
                    if ($attype == Perla::AST::N_ARRAY_VAR()) { $__sw2_sigil = "@"; }
                    elsif ($attype == Perla::AST::N_HASH_VAR()) { $__sw2_sigil = "%"; }
                    _strict_check_var($cg, $__sw2_sigil, "" . $atarget->{"name"}, $atarget->{"line"} + 0);
                    # Mirror unqualified our/file-scope scalar writes to the
                    # package stash so cross-package `$Pkg::NAME` reads see
                    # them. (Qualified targets already dispatched above.)
                    my int $exp_mirror = 0;
                    my str $exp_mname = "";
                    if ($attype == Perla::AST::N_SCALAR_VAR()
                        && defined($atarget->{"name"})
                        && index($atarget->{"name"}, "::") < 0
                        && length($atarget->{"name"}) > 0) {
                        $exp_mname = $atarget->{"name"};
                        if (defined($cg->{"our_vars"}) && exists($cg->{"our_vars"}->{$exp_mname})) {
                            $exp_mirror = 1;
                        }
                        if ($exp_mirror == 0
                            && defined($cg->{"file_scope_vars"}) && exists($cg->{"file_scope_vars"}->{$exp_mname})) {
                            $exp_mirror = 1;
                        }
                    }
                    if ($exp_mirror == 1) {
                        # Decref the previous C-slot value before
                        # overwriting; without this, `$x = undef` leaked
                        # blessed refs and DESTROY never fired.
                        # Special case for `$_`: the read path emits
                        # `perla_dollar_underscore`, so we must use that
                        # same lvalue for the assignment and return —
                        # otherwise the assignment hits perla_dollar_underscore
                        # but the returned value is the unmodified file-scope
                        # `v__`, breaking `while ($_ = shift @data)`.
                        my str $slot_var = c_var($exp_mname);
                        if ($exp_mname eq "_") { $slot_var = "perla_dollar_underscore"; }
                        # Scalar-context of array/hash var → count, not container.
                        my int $__mir_scalarize_h = 0;
                        my int $__mir_scalarize_a = 0;
                        my int $__mir_rhs_t = $node->{"value"}->{"type"};
                        if ($__mir_rhs_t == Perla::AST::N_HASH_VAR()
                            && defined($node->{"value"}->{"name"})
                            && index($node->{"value"}->{"name"}, "::") < 0) {
                            $__mir_scalarize_h = 1;
                        }
                        if ($__mir_rhs_t == Perla::AST::N_ARRAY_VAR()
                            && defined($node->{"value"}->{"name"})
                            && index($node->{"value"}->{"name"}, "::") < 0
                            && $node->{"value"}->{"name"} ne "_") {
                            $__mir_scalarize_a = 1;
                        }
                        # Tie-aware scalar assignment. Capture the new value
                        # first, then if the current slot is a tied scalar,
                        # dispatch STORE and keep the tied SV in the slot.
                        # Otherwise do the normal slot replacement + stash
                        # sync. Predict-not-taken branch — tied SVs are rare.
                        # Scalar assignment puts RHS in SCALAR context so
                        # `our $x = sub_call()` inside a void-context caller
                        # sees scalar (0) via wantarray, not void (-1).
                        emit($cg, "({ StradaValue *__old_sv = " . $slot_var . "; ");
                        emit($cg, "int __sav_wl_sa3 = __perla_want_list; __perla_want_list = 0; ");
                        emit($cg, "StradaValue *__new_sv = ");
                        if ($__mir_scalarize_h == 1) {
                            my str $__rhs_cv = c_var_h($node->{"value"}->{"name"});
                            emit($cg, "({ StradaHash *__sh = strada_deref_hash(" . $__rhs_cv . "); STRADA_MAKE_TAGGED_INT((int64_t)(__sh ? __sh->num_entries : 0)); })");
                        } elsif ($__mir_scalarize_a == 1) {
                            my str $__rhs_cv = c_var_a($node->{"value"}->{"name"});
                            emit($cg, "STRADA_MAKE_TAGGED_INT((int64_t)strada_array_length(strada_deref_array(" . $__rhs_cv . ")))");
                        } else {
                            gen_expr($cg, $node->{"value"});
                        }
                        emit($cg, "; __perla_want_list = __sav_wl_sa3; ");
                        # Borrowed RHS (variable read / array slot) needs
                        # an explicit incref before assignment — gen_expr
                        # didn't bump the refcount, and the destination's
                        # stash mirror + old-slot decref otherwise drops
                        # the underlying SV's last ref. Concretely:
                        # `for my $w (@arr) { $longest = $w if cond }` —
                        # each iter the stash[SCALAR] decref of the prior
                        # iter's value (which was @arr[$i]) freed @arr[$i]
                        # while @arr[0..size-1] still held pointers,
                        # leaving the array with dangling slots.
                        my int $__rhs_borrowed = 0;
                        if ($__mir_scalarize_h == 0 && $__mir_scalarize_a == 0) {
                            $__rhs_borrowed = expr_is_borrowed($node->{"value"});
                        }
                        if ($__rhs_borrowed == 1) {
                            emit($cg, "if (__new_sv && !STRADA_IS_TAGGED_INT(__new_sv)) strada_incref(__new_sv); ");
                        }
                        emit($cg, "if (__builtin_expect(__old_sv && !STRADA_IS_TAGGED_INT(__old_sv) && __old_sv->meta && __old_sv->meta->is_tied, 0)) { ");
                        emit($cg, "strada_tied_scalar_store(__old_sv, __new_sv); if (__new_sv) strada_decref(__new_sv); ");
                        emit($cg, "} else { ");
                        emit($cg, $slot_var . " = __new_sv; ");
                        emit($cg, "if (__old_sv != " . $slot_var . ") strada_decref(__old_sv); ");
                        # Cache the stash-mirror glob: perla_glob_get_or_create
                        # (perla_stash_get_or_create(pkg), name) returns the SAME
                        # glob every time, so re-looking it up on every write was
                        # two hash lookups per assignment — pathological for a
                        # file-scope var written in a tight loop (`$c=$i` over
                        # 200M iters: 22.5s -> fast). The block-static is looked
                        # up once and reused.
                        emit($cg, "{ static PerlGlob *__ogc = (PerlGlob*)0; if (__builtin_expect(!__ogc, 0)) __ogc = perla_glob_get_or_create(perla_stash_get_or_create(\"" . $cg->{"pkg"} . "\"), \"" . $exp_mname . "\"); ");
                        emit($cg, "perla_glob_store(__ogc, PERLA_SLOT_SCALAR, " . $slot_var . "); } ");
                        emit($cg, "} ");
                        # If a closure has already captured this var, also
                        # write the new value through to the capture cell
                        # so the closure body sees the up-to-date value.
                        # Required for self-reference patterns:
                        #   my $f; $f = sub { ... $f->(...) };
                        # The closure was created BEFORE the assignment, so
                        # its cell still holds the pre-assignment v_f (= undef).
                        # Skip when the cell already holds the same pointer
                        # (assignment originated inside the closure body —
                        # *captures[N] already updated). Incref-first to
                        # avoid use-after-free when refcounts overlap.
                        if (defined($cg->{"closure_cell_mirror"})
                            && defined($cg->{"closure_cell_mirror"}->{$exp_mname})) {
                            my int $__cci = $cg->{"closure_cell_mirror"}->{$exp_mname};
                            emit($cg, "if (__perla_cell[" . $__cci . "] && *__perla_cell[" . $__cci . "] != " . $slot_var . ") { ");
                            emit($cg, "StradaValue *__cell_old = *__perla_cell[" . $__cci . "]; ");
                            emit($cg, "*__perla_cell[" . $__cci . "] = " . $slot_var . "; ");
                            emit($cg, "if (" . $slot_var . ") strada_incref(" . $slot_var . "); ");
                            emit($cg, "if (__cell_old) strada_decref(__cell_old); } ");
                        }
                        emit($cg, $slot_var . "; })");
                        return;
                    }
                    # Non-mirror path: simple `(v_X = expr)`. If the RHS
                    # creates a closure that captures this var, mirror the
                    # new value into the closure cell after the assignment
                    # so self-reference patterns inside subs work too. We
                    # don't know which cells will be touched until after
                    # the RHS is gen'd, so wrap in a statement expression
                    # and check the closure_cell_mirror table afterwards.
                    if ($attype == Perla::AST::N_SCALAR_VAR()
                        && defined($atarget->{"name"})) {
                        my str $__assn_name = $atarget->{"name"};
                        # \$. = N — input line number. Read path emits
                        # STRADA_MAKE_TAGGED_INT((int64_t)perla_dollar_dot)
                        # which isn't a C lvalue, so write goes directly
                        # to the int storage. Needed by IO::Handle's
                        # `\$. = \$_[1] if @_ > 1` in input_line_number.
                        if ($__assn_name eq ".") {
                            emit($cg, "({ int64_t __nv = strada_to_int(");
                            gen_expr($cg, $node->{"value"});
                            emit($cg, "); perla_dollar_dot = (int)__nv; STRADA_MAKE_TAGGED_INT(__nv); })");
                            return;
                        }
                        # `$@ = …` — the N_SCALAR_VAR{name="@"} read path
                        # emits a lazy-init statement expression that is not
                        # a C lvalue, so the default `gen_expr($atarget) = …`
                        # below would emit `({ … perla_eval_error; }) = …`
                        # and gcc'd refuse to compile. Route writes directly
                        # to the global, releasing the old value first.
                        # Surfaced by DBI.pm's `$@ ||= "…"` (which expands
                        # through the same plain-assign path after the ||=
                        # special-case above).
                        if ($__assn_name eq "@") {
                            emit($cg, "({ StradaValue *__ae_new = ");
                            gen_expr($cg, $node->{"value"});
                            emit($cg, "; if (perla_eval_error) strada_decref(perla_eval_error); perla_eval_error = __ae_new; __ae_new; })");
                            return;
                        }
                        # Scalar-context of array/hash var produces a count,
                        # not the underlying container. Without this special
                        # case `my \$s = %h` would copy the hash StradaValue
                        # itself, and \$s printed as empty/stringified-hash
                        # instead of the entry count.
                        my int $__rhs_t = $node->{"value"}->{"type"};
                        if ($__rhs_t == Perla::AST::N_HASH_VAR()
                            && defined($node->{"value"}->{"name"})
                            && index($node->{"value"}->{"name"}, "::") < 0) {
                            my str $__rhs_cv = c_var_h($node->{"value"}->{"name"});
                            emit($cg, "({ ");
                            gen_expr($cg, $atarget);
                            emit($cg, " = ({ StradaHash *__sh = strada_deref_hash(" . $__rhs_cv . "); STRADA_MAKE_TAGGED_INT((int64_t)(__sh ? __sh->num_entries : 0)); }); ");
                            gen_expr($cg, $atarget);
                            emit($cg, "; })");
                            return;
                        }
                        if ($__rhs_t == Perla::AST::N_ARRAY_VAR()
                            && defined($node->{"value"}->{"name"})
                            && index($node->{"value"}->{"name"}, "::") < 0
                            && $node->{"value"}->{"name"} ne "_") {
                            my str $__rhs_cv = c_var_a($node->{"value"}->{"name"});
                            emit($cg, "({ ");
                            gen_expr($cg, $atarget);
                            emit($cg, " = STRADA_MAKE_TAGGED_INT((int64_t)strada_array_length(strada_deref_array(" . $__rhs_cv . "))); ");
                            gen_expr($cg, $atarget);
                            emit($cg, "; })");
                            return;
                        }
                        # Tied-scalar dispatch for plain `\$x = …` (my-scoped,
                        # not stash-mirrored). If v_x is a tied SV, replacing
                        # the slot pointer would drop the tied state and lose
                        # the STORE. Capture new value, then if old is tied,
                        # dispatch strada_tied_scalar_store and keep the tied
                        # SV in the slot. Predict-not-taken — non-tied vars
                        # pay just one meta-pointer load.
                        # Scalar re-assignment refcount discipline:
                        # `$x = EXPR` for a my-scoped scalar. The sub's
                        # cleanup at exit does `strada_decref(v_x)` —
                        # treating v_x as owned. So after this assign:
                        # v_x must own a reference to __asn_new, and the
                        # old reference (if any) must be released. The
                        # bare `v_x = __asn_new` emit dropped the old
                        # reference (leak) and didn't incref the new
                        # reference for borrowed RHS — when the borrowed
                        # source was later decref'd, v_x dangled and the
                        # cleanup-time decref freed memory that storage
                        # elsewhere still pointed at.
                        #
                        # Concrete victim: `$cur = $next` inside a list
                        # constructor — $cur stored in a hash via
                        # `$cur->{next} = $next` but only the bare ptr
                        # assign-through happened. Sub-exit decref'd $cur
                        # to 0 and the hash's stored pointer dangled,
                        # surfacing as `$list->{next}->{value}` returning
                        # undef one frame later.
                        my int $__asn_rhs_borrowed = expr_is_borrowed($node->{"value"});
                        emit($cg, "({ int __sav_wl_asn = __perla_want_list; __perla_want_list = 0; ");
                        emit($cg, "StradaValue *__asn_new = ");
                        gen_expr($cg, $node->{"value"});
                        emit($cg, "; __perla_want_list = __sav_wl_asn; ");
                        emit($cg, "StradaValue *__asn_old = ");
                        gen_expr($cg, $atarget);
                        emit($cg, "; if (__builtin_expect(__asn_old && !STRADA_IS_TAGGED_INT(__asn_old) && __asn_old->meta && __asn_old->meta->is_tied, 0)) { ");
                        emit($cg, "  strada_tied_scalar_store(__asn_old, __asn_new); if (__asn_new) strada_decref(__asn_new); ");
                        emit($cg, "} else { ");
                        if ($__asn_rhs_borrowed == 1) {
                            # Borrowed RHS — take our own reference before
                            # storing. Owned RHS (call result, fresh literal)
                            # already came with rc=1 from gen_expr, so no
                            # extra incref needed.
                            emit($cg, "  if (__asn_new) strada_incref(__asn_new); ");
                        }
                        gen_expr($cg, $atarget);
                        emit($cg, " = __asn_new; ");
                        # Release the previous v_x value. Safe even when
                        # __asn_old == __asn_new: the conditional incref
                        # above bumped rc to N+1, and this decref brings
                        # it back to N. Without this decref a chain of
                        # `$x = $y; $x = ...` leaked each old reference.
                        emit($cg, "if (__asn_old && __asn_old != __asn_new) strada_decref(__asn_old); ");
                        # Pad mode: sync an our/package scalar's new value into its
                        # shared stash slot, mirroring the statement-context path
                        # (~line 8920). This expression-context path otherwise omits
                        # the write-back, so eval-body / REPL-line `our $x` writes
                        # never reach the registry. Keyed on the declared package
                        # ($cg->{"pkg"}), correct here during statement processing
                        # (eval bodies run in `package main`).
                        if ($cg->{"pad_mode"} == 1
                            && defined($atarget) && $atarget->{"type"} == Perla::AST::N_SCALAR_VAR()
                            && defined($atarget->{"name"})
                            && defined($cg->{"our_vars"})
                            && defined($cg->{"our_vars"}->{$atarget->{"name"}})) {
                            emit($cg, "{ PerlGlob *__pad_og = perla_glob_get_or_create(perla_stash_get_or_create(\"" . $cg->{"pkg"} . "\"), \"" . $atarget->{"name"} . "\"); perla_glob_store(__pad_og, PERLA_SLOT_SCALAR, ");
                            gen_expr($cg, $atarget);
                            emit($cg, "); } ");
                        }
                        emit($cg, "} ");
                        if (defined($cg->{"closure_cell_mirror"})
                            && defined($cg->{"closure_cell_mirror"}->{$__assn_name})) {
                            my int $__assn_mci = $cg->{"closure_cell_mirror"}->{$__assn_name};
                            # Skip the mirror when the assignment target IS
                            # the cell itself (i.e., the LHS resolves to
                            # `*__captures[N]` inside a closure body). The
                            # macro-driven assignment already wrote through
                            # the cell, and decrefing then re-incref'ing the
                            # same pointer can free-and-reread the value if
                            # the old refcount was 1. Mirror only when the
                            # cell is genuinely separate storage from the
                            # LHS slot — incref-first/decref-old to avoid
                            # use-after-free when values coincide.
                            emit($cg, "if (__perla_cell[" . $__assn_mci . "] && *__perla_cell[" . $__assn_mci . "] != ");
                            gen_expr($cg, $atarget);
                            emit($cg, ") { ");
                            emit($cg, "StradaValue *__cell_old = *__perla_cell[" . $__assn_mci . "]; ");
                            emit($cg, "*__perla_cell[" . $__assn_mci . "] = ");
                            gen_expr($cg, $atarget);
                            emit($cg, "; if (");
                            gen_expr($cg, $atarget);
                            emit($cg, ") strada_incref(");
                            gen_expr($cg, $atarget);
                            emit($cg, "); if (__cell_old) strada_decref(__cell_old); } ");
                        }
                        gen_expr($cg, $atarget);
                        emit($cg, "; })");
                        return;
                    }
                    emit($cg, "(");
                    gen_expr($cg, $atarget);
                    emit($cg, " = ");
                    gen_expr($cg, $node->{"value"});
                    emit($cg, ")");
                    return;
                }
            }
        }
        Perla::CodeGen::Assign::_gen_assign($cg, $node);
        return;
    }

    if ($type == Perla::AST::N_CALL()) {
        Perla::CodeGen::Call::_gen_call($cg, $node);
        return;
    }
    if ($type == Perla::AST::N_METHOD()) {
        Perla::CodeGen::Method::_gen_method_call($cg, $node);
        return;
    }

    if ($type == Perla::AST::N_HASH_ELEM()) {
        # Check for $+{key} — named regex captures
        my scalar $hash_node = $node->{"hash"};
        if (defined($hash_node) && $hash_node->{"type"} == Perla::AST::N_SCALAR_VAR() && $hash_node->{"name"} eq "+") {
            my scalar $hkey = $node->{"key"};
            emit($cg, "({ StradaValue *__nc = strada_named_captures(); StradaValue *__v = strada_hv_fetch_owned(__nc, ");
            if (defined($hkey) && ($hkey->{"type"} == Perla::AST::N_STR_LIT() || ($hkey->{"type"} == Perla::AST::N_INTERP_STR() && has_perl_var($hkey->{"value"}) == 0))) {
                emit($cg, "\"" . Perla::CodeGen::Escape::str_node_to_c($hkey) . "\"");
            } else {
                emit($cg, "strada_to_str(");
                gen_expr($cg, $hkey);
                emit($cg, ")");
            }
            emit($cg, "); strada_decref(__nc); __v; })");
            return;
        }
        my scalar $hkey = $node->{"key"};
        # $foo{key} actually reads from %foo — when hash_node is a plain
        # SCALAR_VAR with a simple name, emit the hash-sigil C var directly.
        my scalar $hash_obj = $node->{"hash"};
        my int $use_hash_sigil = 0;
        if (defined($hash_obj) && $hash_obj->{"type"} == Perla::AST::N_SCALAR_VAR()
            && defined($hash_obj->{"name"}) && length($hash_obj->{"name"}) > 0
            && index($hash_obj->{"name"}, "::") < 0 && $hash_obj->{"name"} ne "_") {
            $use_hash_sigil = 1;
        }
        # Package-qualified `$Pkg::Name{key}` reads the HASH slot of the
        # stash glob (not perla_scalar_get, which reads SCALAR slot).
        # Without this, `$Pkg::H{k}` for a hash-typed `our %H` would fall
        # back to perla_scalar_get and the lookup would silently fail.
        my int $he_route_stash = 0;
        my str $he_pkg = "";
        my str $he_name = "";
        if (defined($hash_obj) && $hash_obj->{"type"} == Perla::AST::N_SCALAR_VAR()
            && defined($hash_obj->{"name"}) && index($hash_obj->{"name"}, "::") > 0) {
            $he_route_stash = 1;
            my str $hen = $hash_obj->{"name"};
            my int $heli = -1;
            my int $hesi = 0;
            while ($hesi < length($hen) - 1) {
                if (substr($hen, $hesi, 2) eq "::") { $heli = $hesi; }
                $hesi++;
            }
            $he_pkg = substr($hen, 0, $heli);
            $he_name = substr($hen, $heli + 2, length($hen) - $heli - 2);
        }
        # Autoviv-on-read: when the inner $hash_obj is itself a chained
        # hash/array access (e.g. $h{a}{b} or $h{a}->{b}), reading the
        # inner must create the intermediate hashref if missing — Perl
        # semantics: `my $v = $h{a}{b}` leaves $h{a}={} even though $v
        # is undef. Use _gen_autoviv_hash for that inner emit, which
        # walks the chain and stores back empty hashrefs at each level.
        my int $inner_is_chained = 0;
        if (defined($hash_obj)) {
            my int $hot = $hash_obj->{"type"};
            if ($hot == Perla::AST::N_HASH_ELEM() || $hot == Perla::AST::N_ARROW_HASH()) {
                $inner_is_chained = 1;
            }
        }
        if (defined($hkey) && ($hkey->{"type"} == Perla::AST::N_STR_LIT() || ($hkey->{"type"} == Perla::AST::N_INTERP_STR() && has_perl_var($hkey->{"value"}) == 0))) {
            emit($cg, "({ StradaValue *__h = ");
            if ($use_hash_sigil == 1) { emit($cg, c_var_h($hash_obj->{"name"})); }
            elsif ($he_route_stash == 1) { emit($cg, "perla_hash_get(\"" . $he_pkg . "\", \"" . $he_name . "\")"); }
            elsif ($inner_is_chained == 1) { _gen_autoviv_hash($cg, $hash_obj); }
            else { gen_expr($cg, $hash_obj); }
            emit($cg, "; StradaValue *__v = strada_hv_fetch_owned(__h, \"" . Perla::CodeGen::Escape::str_node_to_c($hkey) . "\"); __v; })");
        } else {
            emit($cg, "({ StradaValue *__h = ");
            if ($use_hash_sigil == 1) { emit($cg, c_var_h($hash_obj->{"name"})); }
            elsif ($he_route_stash == 1) { emit($cg, "perla_hash_get(\"" . $he_pkg . "\", \"" . $he_name . "\")"); }
            elsif ($inner_is_chained == 1) { _gen_autoviv_hash($cg, $hash_obj); }
            else { gen_expr($cg, $hash_obj); }
            emit($cg, "; char *__k = strada_to_str(");
            gen_expr($cg, $hkey);
            emit($cg, "); StradaValue *__v = strada_hv_fetch_owned(__h, __k); free(__k); __v; })");
        }
        return;
    }

    if ($type == Perla::AST::N_ARRAY_ELEM()) {
        # $_[N] means @_[N] in Perl — access element of @_
        my scalar $arr = $node->{"array"};
        my scalar $aidx = $node->{"index"};
        # Detect list-shaped index: range, qword, or anon-array-non-ref.
        # These should produce a SLICE, not a single element. Without
        # this, `(LIST)[0..5]` collapsed to a single strada_array_get
        # at index = strada_to_int(range_array) (whatever that comes
        # out as — usually 0), so DateTime::from_epoch's
        #   @args{qw(...)} = (gmtime($epoch))[0..5]
        # populated %args with one value (or junk) instead of the 6
        # gmtime fields, leading to year=-1+1900=1899.
        my int $is_slice = 0;
        if (defined($aidx)) {
            my int $ait = $aidx->{"type"};
            if ($ait == Perla::AST::N_RANGE() || $ait == Perla::AST::N_QWORD()) {
                $is_slice = 1;
            } elsif ($ait == Perla::AST::N_ANON_ARRAY()) {
                my int $isref = 0;
                if (defined($aidx->{"is_ref"})) { $isref = $aidx->{"is_ref"}; }
                if ($isref == 0) { $is_slice = 1; }
            }
        }
        if ($is_slice == 1) {
            emit($cg, "({ StradaArray *__ae_av = strada_deref_array(");
            if ($arr->{"type"} == Perla::AST::N_SCALAR_VAR() && $arr->{"name"} eq "_") {
                emit($cg, "perla_at_");
            } elsif ($arr->{"type"} == Perla::AST::N_SCALAR_VAR() && $arr->{"name"} eq "-") {
                # `$-[N]` / `@-[a..b]` — regex match start offsets
                emit($cg, "strada_match_starts()");
            } elsif ($arr->{"type"} == Perla::AST::N_SCALAR_VAR() && $arr->{"name"} eq "+") {
                # `$+[N]` / `@+[a..b]` — regex match end offsets
                emit($cg, "strada_match_ends()");
            } elsif ($arr->{"type"} == Perla::AST::N_SCALAR_VAR() && index($arr->{"name"}, "::") < 0) {
                emit($cg, c_var_a($arr->{"name"}));
            } elsif ($arr->{"type"} == Perla::AST::N_SCALAR_VAR() && index($arr->{"name"}, "::") > 0) {
                my str $__pa_full = $arr->{"name"};
                my int $__pai = 0;
                my int $__pa_last = -1;
                while ($__pai < length($__pa_full) - 1) {
                    if (substr($__pa_full, $__pai, 2) eq "::") { $__pa_last = $__pai; }
                    $__pai = $__pai + 1;
                }
                my str $__pa_pkg = substr($__pa_full, 0, $__pa_last);
                my str $__pa_name = substr($__pa_full, $__pa_last + 2, length($__pa_full) - $__pa_last - 2);
                emit($cg, "perla_array_get(\"" . $__pa_pkg . "\", \"" . $__pa_name . "\")");
            } else {
                gen_expr($cg, $arr);
            }
            emit($cg, "); int __ae_len = __ae_av ? (int)strada_array_length(__ae_av) : 0; ");
            emit($cg, "StradaArray *__ae_idxs = strada_deref_array(({ int __sav_wl_sl = __perla_want_list; __perla_want_list = 1; StradaValue *__slv = ");
            gen_expr($cg, $aidx);
            emit($cg, "; __perla_want_list = __sav_wl_sl; __slv; })); ");
            emit($cg, "StradaValue *__ae_out = strada_new_array(); StradaArray *__ae_oa = strada_deref_array(__ae_out); ");
            emit($cg, "if (__ae_idxs) for (int __aei = 0; __aei < (int)strada_array_length(__ae_idxs); __aei++) { ");
            emit($cg, "int __idx = (int)strada_to_int(strada_array_get(__ae_idxs, __aei)); ");
            emit($cg, "if (__idx < 0 && __ae_av) __idx += __ae_len; ");
            emit($cg, "StradaValue *__ev = strada_array_get(__ae_av, __idx); ");
            emit($cg, "if (__ev) strada_incref(__ev); strada_array_push(__ae_oa, __ev); } ");
            emit($cg, "__ae_out; })");
            return;
        }
        my str $av_expr = "";
        if ($arr->{"type"} == Perla::AST::N_SCALAR_VAR() && $arr->{"name"} eq "_") {
            $av_expr = "strada_deref_array(perla_at_)";
        } else {
            $av_expr = "__ae_av";
        }
        # Handle negative indices: -1 = last, -2 = second to last
        # Tied-array element fetch: when the source is a simple lexical
        # array var, capture the SV so we can route through
        # strada_av_fetch_sv (which checks meta->is_tied and dispatches
        # FETCH on the tied obj). Without this, perla's read of $a[N]
        # for a tied @a returned the underlying StradaArray's element
        # (always undef or stale) without invoking FETCH.
        if ($arr->{"type"} == Perla::AST::N_SCALAR_VAR() && index($arr->{"name"}, "::") < 0
            && $arr->{"name"} ne "_" && $arr->{"name"} ne "-" && $arr->{"name"} ne "+") {
            emit($cg, "({ StradaValue *__ae_sv = " . c_var_a($arr->{"name"}) . "; ");
            if (defined($aidx) && $aidx->{"type"} == Perla::AST::N_INT_LIT()) {
                emit($cg, "int __ae_idx = " . $aidx->{"value"});
            } else {
                emit($cg, "int __ae_idx = (int)strada_to_int(");
                gen_expr($cg, $aidx);
                emit($cg, ")");
            }
            emit($cg, "; strada_av_fetch_sv(__ae_sv, __ae_idx); })");
            return;
        }
        emit($cg, "({ StradaArray *__ae_av = strada_deref_array(");
        if ($arr->{"type"} == Perla::AST::N_SCALAR_VAR() && $arr->{"name"} eq "_") {
            emit($cg, "perla_at_");
        } elsif ($arr->{"type"} == Perla::AST::N_SCALAR_VAR() && $arr->{"name"} eq "-") {
            # `$-[N]` — regex match start offsets array
            emit($cg, "strada_match_starts()");
        } elsif ($arr->{"type"} == Perla::AST::N_SCALAR_VAR() && $arr->{"name"} eq "+") {
            # `$+[N]` — regex match end offsets array
            emit($cg, "strada_match_ends()");
        } elsif ($arr->{"type"} == Perla::AST::N_SCALAR_VAR() && index($arr->{"name"}, "::") < 0) {
            # $foo[N] really indexes @foo — use the array-sigil C name.
            emit($cg, c_var_a($arr->{"name"}));
        } elsif ($arr->{"type"} == Perla::AST::N_SCALAR_VAR() && index($arr->{"name"}, "::") > 0) {
            # $Pkg::arr[N] — pkg-qualified scalar var indexed as @Pkg::arr.
            # Route to perla_array_get(pkg, name) directly; without this,
            # _gen_expr emits perla_scalar_get which reads SLOT_SCALAR
            # (always empty) instead of SLOT_ARRAY.
            my str $__pa_full = $arr->{"name"};
            my int $__pai = 0;
            my int $__pa_last = -1;
            while ($__pai < length($__pa_full) - 1) {
                if (substr($__pa_full, $__pai, 2) eq "::") { $__pa_last = $__pai; }
                $__pai = $__pai + 1;
            }
            my str $__pa_pkg = substr($__pa_full, 0, $__pa_last);
            my str $__pa_name = substr($__pa_full, $__pa_last + 2, length($__pa_full) - $__pa_last - 2);
            emit($cg, "perla_array_get(\"" . $__pa_pkg . "\", \"" . $__pa_name . "\")");
        } elsif ($arr->{"type"} == Perla::AST::N_ANON_ARRAY()
                 && (!defined($arr->{"is_ref"}) || $arr->{"is_ref"} != 1)) {
            # `(1,2,3,4,5)[N]` — list-slice on a paren-list. The anon
            # array codegen otherwise consults the surrounding
            # __perla_want_list (which is 0 for `my \$x = ...`) and
            # collapses to the last element, so `(1..5)[2]` returned
            # 5 then undef-after-slice. Force list context for the
            # inner array.
            emit($cg, "({ int __sav_wl_sl = __perla_want_list; __perla_want_list = 1; StradaValue *__sl_av = ");
            gen_expr($cg, $arr);
            emit($cg, "; __perla_want_list = __sav_wl_sl; __sl_av; })");
        } else {
            gen_expr($cg, $arr);
        }
        if (defined($aidx) && $aidx->{"type"} == Perla::AST::N_INT_LIT()) {
            emit($cg, "); int __ae_idx = " . $aidx->{"value"});
        } else {
            emit($cg, "); int __ae_idx = (int)strada_to_int(");
            gen_expr($cg, $aidx);
            emit($cg, ")");
        }
        # Let strada_array_get handle the negative-index adjustment so a
        # too-far-negative index (e.g. \$arr[-100] on a 5-elem array)
        # correctly returns undef rather than wrapping to a positive
        # in-range slot. The runtime checks idx<-size after adjustment.
        emit($cg, "; ");
        # Incref the fetched element. `strada_array_get` returns a BORROWED
        # ref; without this, repeated `my $x = $arr[$i]` reassignments
        # decref'd the borrowed and freed underlying elements after 2 visits.
        emit($cg, "StradaValue *__ae_v = strada_array_get(__ae_av, __ae_idx); if (__ae_v) strada_incref(__ae_v); __ae_v; })");
        return;
    }

    if ($type == Perla::AST::N_ARROW_HASH()) {
        # Check for $+{key} — named regex captures
        my scalar $obj_node = $node->{"object"};
        if (defined($obj_node) && $obj_node->{"type"} == Perla::AST::N_SCALAR_VAR() && $obj_node->{"name"} eq "+") {
            my scalar $nckey = $node->{"key"};
            emit($cg, "({ StradaValue *__nc = strada_named_captures(); StradaValue *__v = strada_hv_fetch_owned(__nc, ");
            if (defined($nckey) && ($nckey->{"type"} == Perla::AST::N_STR_LIT() || ($nckey->{"type"} == Perla::AST::N_INTERP_STR() && has_perl_var($nckey->{"value"}) == 0))) {
                emit($cg, "\"" . Perla::CodeGen::Escape::str_node_to_c($nckey) . "\"");
            } else {
                emit($cg, "({ char *__nck = strada_to_str(");
                gen_expr($cg, $nckey);
                emit($cg, "); __nck; })");
            }
            emit($cg, "); strada_decref(__nc); __v; })");
            return;
        }
        my scalar $akey = $node->{"key"};
        # When object is a SCALAR_VAR whose name has a collision with a
        # hash declaration (e.g., `my %url; $url->{"path"}`), route to
        # the hash slot so mangled-hash storage is visible. Legacy Perla
        # code was relying on $foo and %foo sharing the v_foo C var;
        # collision-mangling would otherwise make these accesses read an
        # undeclared v_url.
        my scalar $aobj2 = $node->{"object"};
        my int $route_to_hash = 0;
        # Routing through the mangled hash variant (v_X__h) only applies to
        # `$X{key}` (no-arrow, hash-sigil sugar) — not to `$X->{key}` (explicit
        # scalar-deref). Without the is_explicit_arrow guard, a scalar holding
        # a hashref read as `$data->{k}` was misrouted to v_data__h whenever
        # `@data` also appeared somewhere in the file, even though @data and
        # $data are independent variables.
        my int $is_arrow_h = 0;
        if (defined($node->{"is_explicit_arrow"}) && $node->{"is_explicit_arrow"} == 1) { $is_arrow_h = 1; }
        if ($is_arrow_h == 0
            && defined($aobj2) && $aobj2->{"type"} == Perla::AST::N_SCALAR_VAR()
            && defined($aobj2->{"name"}) && length($aobj2->{"name"}) > 0
            && index($aobj2->{"name"}, "::") < 0 && $aobj2->{"name"} ne "_"
            && (exists($__perla_mangle_collisions{$aobj2->{"name"}})
                || $aobj2->{"name"} eq "INC")) {
            # %INC is a built-in dual with @INC: both names live at file
            # scope but in different sigil slots, so reads of `$INC{key}`
            # must go through v_INC__h (c_var_h promotes for "INC"), not
            # gen_expr which emits v_INC (the array). Treated like a
            # collision even when no user `my %INC` is in the file.
            $route_to_hash = 1;
        }
        # Package-qualified `$Pkg::Name{key}` (no arrow) reads the hash
        # slot of the stash-resident glob, not a file-static. Without
        # this, a package's `our %H` (published to its glob) and a cross-
        # package `$Pkg::H{$k}` read see distinct file-static copies.
        # When the access uses an explicit arrow (`$Pkg::href->{k}`),
        # treat it as scalar-then-deref instead: $Pkg::href is a SCALAR
        # holding a hashref. Without the arrow guard, perla looked up
        # the HASH slot (empty for a scalar-typed `our`) and returned
        # undef.
        my int $route_to_stash_h = 0;
        if ($is_arrow_h == 0
            && defined($aobj2) && $aobj2->{"type"} == Perla::AST::N_SCALAR_VAR()
            && defined($aobj2->{"name"}) && index($aobj2->{"name"}, "::") > 0) {
            $route_to_stash_h = 1;
        }
        my str $__sh_pkg = "";
        my str $__sh_name = "";
        if ($route_to_stash_h == 1) {
            my str $__shn = $aobj2->{"name"};
            my int $__shl = -1;
            my int $__shs = 0;
            while ($__shs < length($__shn) - 1) {
                if (substr($__shn, $__shs, 2) eq "::") { $__shl = $__shs; }
                $__shs++;
            }
            $__sh_pkg = substr($__shn, 0, $__shl);
            $__sh_name = substr($__shn, $__shl + 2, length($__shn) - $__shl - 2);
        }
        # Stash fallback for runtime-imported simple-name hashes like
        # %Config: when no other routing applies and the var has no
        # `::`, also try perla_hash_get(name, name) if v_NAME is empty.
        # Mirrors the existing interpolation-time fallback so that
        # `my $val = $Config{KEY}` (non-interp assignment) finds the
        # hash that `use Config` populated. Without this, the assignment
        # path read NULL/empty and returned undef.
        my int $route_simple_fallback = 0;
        my str $__sf_name = "";
        if ($is_arrow_h == 0 && $route_to_hash == 0 && $route_to_stash_h == 0
            && defined($aobj2) && $aobj2->{"type"} == Perla::AST::N_SCALAR_VAR()
            && defined($aobj2->{"name"}) && length($aobj2->{"name"}) > 0
            && index($aobj2->{"name"}, "::") < 0
            && $aobj2->{"name"} ne "_") {
            $route_simple_fallback = 1;
            $__sf_name = $aobj2->{"name"};
        }
        # Helper sub-emit: fallback to stash hash slot when v_NAME is
        # empty. Tied hashes have an empty underlying StradaHash but
        # data lives in tied_obj — skip the fallback in that case so
        # tied-hash iteration / fetch keeps working.
        my str $__fallback_emit = "";
        if ($route_simple_fallback == 1) {
            $__fallback_emit = "; if (!__o || (!STRADA_IS_TAGGED_INT(__o) && __o->type == STRADA_HASH && __o->value.hv && __o->value.hv->num_entries == 0 && !(__o->meta && __o->meta->is_tied))) { StradaValue *__o_sh = perla_hash_get(\"" . $__sf_name . "\", \"" . $__sf_name . "\"); if (__o_sh) __o = __o_sh; }";
        }
        # Symbolic-ref fallback for `\${\$name}{key}` and `\$\$name{key}`:
        # when the object is N_DEREF_SCALAR (`\${EXPR}` or `\$\$var`),
        # bypass the SCALAR-slot path (perla_scalar_via_qname returns the
        # scalar slot, not the hash we want) and look up the HASH by name
        # directly. Common idiom under `no strict 'refs'`.
        my int $__hsr_is_symref = 0;
        if (defined($aobj2) && $aobj2->{"type"} == Perla::AST::N_DEREF_SCALAR()
            && defined($aobj2->{"ref"})) {
            $__hsr_is_symref = 1;
        }
        # Track whether the object expression returns an OWNED (incref'd)
        # temp so we can decref __o after the fetch. N_ARRAY_ELEM and
        # friends incref the fetched element (their codegen ends with
        # `strada_incref(__ae_v); __ae_v;`) — without a balancing decref
        # here, the underlying object leaks one ref per `$arr[N]->{key}`
        # access. That kept blessed invocants alive past their `my` scope
        # and silently suppressed DESTROY. expr_is_borrowed mis-labels
        # N_ARRAY_ELEM as borrowed (the label predates the
        # safety-incref); we use the AST type directly to track ownership.
        # Inner-object ownership for the outer `$X->{...}` decref dance.
        #
        # N_ARRAY_ELEM and N_ARROW_ARRAY emit a safety-incref before
        # returning (see aa4d4a29 / bc3e22e7 — fixed an OOP invocant
        # leak), so the outer access must balance that with a decref.
        # N_CALL / N_METHOD also return owned values.
        #
        # N_HASH_ELEM / N_ARROW_HASH are routed through _gen_autoviv_hash
        # which emits `strada_hv_autoviv(...)`. That returns a BORROWED
        # pointer to a hash stored in the outer container — decref'ing
        # it pulls a refcount out from under the storage and after a
        # handful of accesses the hash gets freed mid-program. Surfaced
        # as `Service->run("greet"); Service->run("add")` returning
        # "unknown: add" because the second `$self->{actions}` lookup
        # found the actions hash already torn down by the first call's
        # over-decref.
        my int $__ahx_obj_owned = 0;
        if (defined($aobj2)) {
            my int $__ahx_aot = $aobj2->{"type"};
            if ($__ahx_aot == Perla::AST::N_ARRAY_ELEM()
                || $__ahx_aot == Perla::AST::N_ARROW_ARRAY()
                || $__ahx_aot == Perla::AST::N_CALL()
                || $__ahx_aot == Perla::AST::N_METHOD()) {
                $__ahx_obj_owned = 1;
            }
        }
        if (defined($akey) && $akey->{"type"} == Perla::AST::N_STR_LIT()) {
            emit($cg, "({ StradaValue *__o = ");
            if ($route_to_stash_h == 1) { emit($cg, "perla_hash_get(\"" . $__sh_pkg . "\", \"" . $__sh_name . "\")"); }
            else if ($route_to_hash == 1) { emit($cg, c_var_h($aobj2->{"name"})); }
            elsif ($__hsr_is_symref == 1) {
                emit($cg, "({ StradaValue *__sym = ");
                gen_expr($cg, $aobj2->{"ref"});
                emit($cg, "; (__sym && !STRADA_IS_TAGGED_INT(__sym) && __sym->type == STRADA_STR && __sym->value.pv) ? perla_hash_via_qname(__sym->value.pv) : ((__sym && !STRADA_IS_TAGGED_INT(__sym) && __sym->type == STRADA_REF) ? __sym->value.rv : __sym); })");
            }
            elsif (defined($aobj2) && ($aobj2->{"type"} == Perla::AST::N_HASH_ELEM() || $aobj2->{"type"} == Perla::AST::N_ARROW_HASH())) {
                # Autoviv-on-read: chained `$h{a}->{b}` / `$h->{a}{b}`
                # must spring the intermediate slot into a hashref so
                # subsequent reads see it. Without this, perl prints
                # `exists $h{a}` as true after `my $v = $h{a}{b}`; perla
                # left $h{a} undefined.
                _gen_autoviv_hash($cg, $aobj2);
            }
            else { gen_expr($cg, $node->{"object"}); }
            emit($cg, $__fallback_emit);
            emit($cg, "; StradaValue *__o_orig = __o; StradaValue *__hov = (__o && !STRADA_IS_TAGGED_INT(__o) && __o->type == STRADA_REF) ? perla_overload_deref(__o, \"\%{}\") : NULL; if (__hov) __o = __hov; ");
            emit($cg, "StradaValue *__v = strada_hv_fetch_owned(__o, \"" . Perla::CodeGen::Escape::escape_c_str($akey->{"value"}) . "\"); ");
            if ($__ahx_obj_owned == 1) {
                emit($cg, "strada_decref(__o_orig); ");
            }
            emit($cg, "if (__hov) strada_decref(__hov); __v; })");
        } elsif (defined($akey) && $akey->{"type"} == Perla::AST::N_INTERP_STR() && has_perl_var($akey->{"value"}) == 0) {
            # Interpolated string with no variables — treat as literal
            emit($cg, "({ StradaValue *__o = ");
            if ($route_to_stash_h == 1) { emit($cg, "perla_hash_get(\"" . $__sh_pkg . "\", \"" . $__sh_name . "\")"); }
            else if ($route_to_hash == 1) { emit($cg, c_var_h($aobj2->{"name"})); }
            elsif ($__hsr_is_symref == 1) {
                emit($cg, "({ StradaValue *__sym = ");
                gen_expr($cg, $aobj2->{"ref"});
                emit($cg, "; (__sym && !STRADA_IS_TAGGED_INT(__sym) && __sym->type == STRADA_STR && __sym->value.pv) ? perla_hash_via_qname(__sym->value.pv) : ((__sym && !STRADA_IS_TAGGED_INT(__sym) && __sym->type == STRADA_REF) ? __sym->value.rv : __sym); })");
            }
            elsif (defined($aobj2) && ($aobj2->{"type"} == Perla::AST::N_HASH_ELEM() || $aobj2->{"type"} == Perla::AST::N_ARROW_HASH())) {
                # Autoviv-on-read: chained `$h{a}->{b}` / `$h->{a}{b}`
                # must spring the intermediate slot into a hashref so
                # subsequent reads see it. Without this, perl prints
                # `exists $h{a}` as true after `my $v = $h{a}{b}`; perla
                # left $h{a} undefined.
                _gen_autoviv_hash($cg, $aobj2);
            }
            else { gen_expr($cg, $node->{"object"}); }
            emit($cg, $__fallback_emit);
            emit($cg, "; StradaValue *__o_orig = __o; StradaValue *__hov = (__o && !STRADA_IS_TAGGED_INT(__o) && __o->type == STRADA_REF) ? perla_overload_deref(__o, \"\%{}\") : NULL; if (__hov) __o = __hov; ");
            emit($cg, "StradaValue *__v = strada_hv_fetch_owned(__o, \"" . Perla::CodeGen::Escape::perl_interp_literal_to_c($akey->{"value"}) . "\"); ");
            if ($__ahx_obj_owned == 1) { emit($cg, "strada_decref(__o_orig); "); }
            emit($cg, "if (__hov) strada_decref(__hov); __v; })");
        } elsif (defined($akey) && $akey->{"type"} == Perla::AST::N_CALL() && defined($akey->{"name"}) && length($akey->{"name"}) > 0 && (!defined($akey->{"args"}) || scalar(@{$akey->{"args"}}) == 0) && (!defined($akey->{"has_parens"}) || $akey->{"has_parens"} == 0)) {
            # Bareword hash key: `$h{foo}` autoquotes to "foo". Only when
            # the call has no explicit parens — `$h{foo()}` IS a function
            # call (has_parens=1), not a bareword. Without this guard,
            # the codegen treated both forms as bareword and emitted a
            # literal string key, so `$h{get_key()}` looked up "get_key"
            # instead of calling get_key() and using its return value.
            emit($cg, "({ StradaValue *__o = ");
            if ($route_to_stash_h == 1) { emit($cg, "perla_hash_get(\"" . $__sh_pkg . "\", \"" . $__sh_name . "\")"); }
            else if ($route_to_hash == 1) { emit($cg, c_var_h($aobj2->{"name"})); }
            elsif ($__hsr_is_symref == 1) {
                emit($cg, "({ StradaValue *__sym = ");
                gen_expr($cg, $aobj2->{"ref"});
                emit($cg, "; (__sym && !STRADA_IS_TAGGED_INT(__sym) && __sym->type == STRADA_STR && __sym->value.pv) ? perla_hash_via_qname(__sym->value.pv) : ((__sym && !STRADA_IS_TAGGED_INT(__sym) && __sym->type == STRADA_REF) ? __sym->value.rv : __sym); })");
            }
            elsif (defined($aobj2) && ($aobj2->{"type"} == Perla::AST::N_HASH_ELEM() || $aobj2->{"type"} == Perla::AST::N_ARROW_HASH())) {
                # Autoviv-on-read: chained `$h{a}->{b}` / `$h->{a}{b}`
                # must spring the intermediate slot into a hashref so
                # subsequent reads see it. Without this, perl prints
                # `exists $h{a}` as true after `my $v = $h{a}{b}`; perla
                # left $h{a} undefined.
                _gen_autoviv_hash($cg, $aobj2);
            }
            else { gen_expr($cg, $node->{"object"}); }
            emit($cg, $__fallback_emit);
            emit($cg, "; StradaValue *__o_orig = __o; StradaValue *__hov = (__o && !STRADA_IS_TAGGED_INT(__o) && __o->type == STRADA_REF) ? perla_overload_deref(__o, \"\%{}\") : NULL; if (__hov) __o = __hov; ");
            emit($cg, "StradaValue *__v = strada_hv_fetch_owned(__o, \"" . Perla::CodeGen::Escape::escape_c_str($akey->{"name"}) . "\"); ");
            if ($__ahx_obj_owned == 1) { emit($cg, "strada_decref(__o_orig); "); }
            emit($cg, "if (__hov) strada_decref(__hov); __v; })");
        } else {
            emit($cg, "({ StradaValue *__o = ");
            if ($route_to_stash_h == 1) { emit($cg, "perla_hash_get(\"" . $__sh_pkg . "\", \"" . $__sh_name . "\")"); }
            else if ($route_to_hash == 1) { emit($cg, c_var_h($aobj2->{"name"})); }
            elsif ($__hsr_is_symref == 1) {
                emit($cg, "({ StradaValue *__sym = ");
                gen_expr($cg, $aobj2->{"ref"});
                emit($cg, "; (__sym && !STRADA_IS_TAGGED_INT(__sym) && __sym->type == STRADA_STR && __sym->value.pv) ? perla_hash_via_qname(__sym->value.pv) : ((__sym && !STRADA_IS_TAGGED_INT(__sym) && __sym->type == STRADA_REF) ? __sym->value.rv : __sym); })");
            }
            elsif (defined($aobj2) && ($aobj2->{"type"} == Perla::AST::N_HASH_ELEM() || $aobj2->{"type"} == Perla::AST::N_ARROW_HASH())) {
                # Autoviv-on-read: chained `$h{a}->{b}` / `$h->{a}{b}`
                # must spring the intermediate slot into a hashref so
                # subsequent reads see it. Without this, perl prints
                # `exists $h{a}` as true after `my $v = $h{a}{b}`; perla
                # left $h{a} undefined.
                _gen_autoviv_hash($cg, $aobj2);
            }
            else { gen_expr($cg, $node->{"object"}); }
            emit($cg, $__fallback_emit);
            emit($cg, "; StradaValue *__o_orig = __o; StradaValue *__hov = (__o && !STRADA_IS_TAGGED_INT(__o) && __o->type == STRADA_REF) ? perla_overload_deref(__o, \"\%{}\") : NULL; if (__hov) __o = __hov; ");
