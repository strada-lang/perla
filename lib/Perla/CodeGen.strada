                    emit($cg, "if (__og->slots[PERLA_SLOT_ARRAY]) strada_decref(__og->slots[PERLA_SLOT_ARRAY]); ");
                    emit($cg, "__og->slots[PERLA_SLOT_ARRAY] = " . c_var_a($a_mirror_name) . "; if (" . c_var_a($a_mirror_name) . ") strada_incref(" . c_var_a($a_mirror_name) . "); } ");
