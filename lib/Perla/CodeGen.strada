        if (defined($obj_node) && $obj_node->{"type"} == Perla::AST::N_SCALAR_VAR() && $obj_node->{"name"} eq "+") {
            my scalar $nckey = $node->{"key"};
            emit($cg, "({ StradaValue *__nc = strada_named_captures(); StradaValue *__v = strada_hv_fetch_owned(__nc, ");
            if (defined($nckey) && ($nckey->{"type"} == Perla::AST::N_STR_LIT() || ($nckey->{"type"} == Perla::AST::N_INTERP_STR() && has_perl_var($nckey->{"value"}) == 0))) {
                emit($cg, "\"" . Perla::CodeGen::Escape::str_node_to_c($nckey) . "\"");
            } else {
