                # corrupted @prev because they shared the same StradaArray.
                gen_expr($cg, $target);
                emit($cg, " = strada_new_array(); StradaArray *__a_cp_dst = strada_deref_array(");
                gen_expr($cg, $target);
                emit($cg, "); StradaArray *__a_cp_src = __a_rhs->value.av; ");
                emit($cg, "if (__a_cp_src) for (size_t __a_cp_i = 0; __a_cp_i < __a_cp_src->size; __a_cp_i++) { ");
                emit($cg, "  StradaValue *__a_cp_e = __a_cp_src->elements[__a_cp_src->head + __a_cp_i]; ");
                emit($cg, "  if (__a_cp_e) strada_incref(__a_cp_e); strada_array_push_take(__a_cp_dst, __a_cp_e ? __a_cp_e : strada_new_undef()); ");
                emit($cg, "} } ");
                emit($cg, "else if (__a_rhs && !STRADA_IS_TAGGED_INT(__a_rhs) && __a_rhs->type == STRADA_HASH && __a_rhs->value.hv) { ");
                gen_expr($cg, $target);
