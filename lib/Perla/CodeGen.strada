            # timezone-free calendar normalizer that ALWAYS recomputes
            # tm_wday/tm_yday from year/mon/mday (ignoring any supplied
            # wday/yday) and normalizes out-of-range fields (mday=32 -> next
            # month). Mirror it with timegm (UTC, no TZ/DST hour shifts) so
            # %A/%a/%w/%j and overflowed dates match Perl rather than trusting
            # the input wday (which defaulted to 0 = Sunday).
            emit($cg, "{ int __sf_isdst = __sftm.tm_isdst; struct tm __sftmp = __sftm; if (timegm(&__sftmp) != (time_t)-1) { __sftmp.tm_isdst = __sf_isdst; __sftm = __sftmp; } } ");
