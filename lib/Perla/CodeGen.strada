            emit($cg, "StradaValue *__hs_keys = strada_new_array(); StradaArray *__hs_kav = strada_deref_array(__hs_keys); ");
            my int $hsi = 0;
            my int $hsn = scalar(@{$keys_list_hs});
            while ($hsi < $hsn) {
                my scalar $hkn = $keys_list_hs->[$hsi];
                my int $hkt = $hkn->{"type"};
                if ($hkt == Perla::AST::N_QWORD() || $hkt == Perla::AST::N_ANON_ARRAY()) {
                    my scalar $hke = $hkn->{"elems"};
                    my int $hej = 0;
                    while ($hej < scalar(@{$hke})) {
                        emit($cg, "{ StradaValue *__hsk_v = ");
                        gen_expr($cg, $hke->[$hej]);
                        emit($cg, "; strada_array_push(__hs_kav, __hsk_v); } ");
