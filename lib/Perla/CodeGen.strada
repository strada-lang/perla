                # Autovivify when target is `@{$h->{k}}` and slot is undef
                # — same pattern as the (paren-list) and (single-arg) paths.
                my scalar $ma_arr = $args->[0];
                my int $ma_t = $ma_arr->{"type"};
                my int $ma_av = 0;
                if ($ma_t == Perla::AST::N_DEREF_ARRAY() && defined($ma_arr->{"ref"})) {
                    my scalar $ma_inner = $ma_arr->{"ref"};
                    my int $ma_it = $ma_inner->{"type"};
                    if ($ma_it == Perla::AST::N_ARROW_HASH() || $ma_it == Perla::AST::N_HASH_ELEM()) {
