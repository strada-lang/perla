        my int $eb_save_use_integer = 0;
        if (defined($cg->{"use_integer"})) { $eb_save_use_integer = $cg->{"use_integer"}; }
        my int $eb_save_use_utf8 = 0;
        if (defined($cg->{"use_utf8"})) { $eb_save_use_utf8 = $cg->{"use_utf8"}; }
        my int $eb_save_use_bytes = 0;
        if (defined($cg->{"use_bytes"})) { $eb_save_use_bytes = $cg->{"use_bytes"}; }
