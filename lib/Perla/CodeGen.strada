            emit($cg, "static StradaValue *__cv_c = NULL; static long __cv_g = -1; if (__cv_g != perla_code_override_gen) { __cv_c = perla_code_get(\"" . $__qn_pkg . "\", \"" . $__qn_short . "\"); __cv_g = perla_code_override_gen; } StradaValue *__cv_ovr = __cv_c; ");
            emit($cg, "StradaValue *__fr = (__cv_ovr && !STRADA_IS_TAGGED_INT(__cv_ovr) && __cv_ovr->type != STRADA_STR) ");
            emit($cg, "  ? perla_call_code(__cv_ovr, __a) ");
