        # ref; without this, repeated `my $x = $arr[$i]` reassignments
        # decref'd the borrowed and freed underlying elements after 2 visits.
        # If the `$ref->[N]` path captured an owned __ae_obj (via
        # __aa_obj_owned_pending), decref it after fetching — mirrors the
        # ARROW_HASH owned-object cleanup.
        emit($cg, "StradaValue *__ae_v = strada_array_get(__ae_av, __ae_idx); if (__ae_v) strada_incref(__ae_v); ");
        if (defined($cg->{"__aa_obj_owned_pending"}) && $cg->{"__aa_obj_owned_pending"} == 1) {
            emit($cg, "if (__ae_ov) strada_decref(__ae_ov); strada_decref(__ae_obj); ");
        }
