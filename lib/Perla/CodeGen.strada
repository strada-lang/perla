            emit($cg, "size_t __b64i = 0, __b64j = 0; while (__b64i < __b64l) { ");
            emit($cg, "size_t __b64c = (__b64l - __b64i > 76) ? 76 : (__b64l - __b64i); ");
            emit($cg, "memcpy(__b64r + __b64j, __b64s + __b64i, __b64c); __b64j += __b64c; ");
            emit($cg, "__b64r[__b64j++] = '\\n'; __b64i += __b64c; } __b64r[__b64j] = 0; ");
            emit($cg, "free(__b64s); StradaValue *__b64f = strada_new_str(__b64r); free(__b64r); __b64f; ");
        } else {
            # Explicit EOL: when empty, bypass wrapping; otherwise insert
            # after every 76 chars.
            emit($cg, "char *__b64eol = strada_to_str(");
            gen_expr($cg, $args->[1]);
            emit($cg, "); size_t __b64el = strlen(__b64eol); ");
            emit($cg, "StradaValue *__b64f; ");
            emit($cg, "if (__b64el == 0) { free(__b64eol); __b64f = __b64v; } else { ");
            emit($cg, "char *__b64s = strada_to_str(__b64v); strada_decref(__b64v); ");
            emit($cg, "size_t __b64l = strlen(__b64s); size_t __b64n = (__b64l + 75) / 76; ");
            emit($cg, "size_t __b64o = __b64l + __b64n * __b64el; char *__b64r = malloc(__b64o + 1); ");
            emit($cg, "size_t __b64i = 0, __b64j = 0; while (__b64i < __b64l) { ");
            emit($cg, "size_t __b64c = (__b64l - __b64i > 76) ? 76 : (__b64l - __b64i); ");
            emit($cg, "memcpy(__b64r + __b64j, __b64s + __b64i, __b64c); __b64j += __b64c; ");
            emit($cg, "memcpy(__b64r + __b64j, __b64eol, __b64el); __b64j += __b64el; __b64i += __b64c; } ");
            emit($cg, "__b64r[__b64j] = 0; free(__b64s); free(__b64eol); ");
            emit($cg, "__b64f = strada_new_str(__b64r); free(__b64r); } __b64f; ");
        }
        emit($cg, "})");
        return;
    }
    if ($name eq "decode_base64" || $name eq "MIME::Base64::decode_base64") {
        if ($argc > 0) {
            emit($cg, "strada_base64_decode(");
            gen_expr($cg, $args->[0]);
            emit($cg, ")");
        } else {
            emit($cg, "strada_new_str(\"\")");
        }
        return;
    }

    # quotemeta($str)
    if ($name eq "quotemeta") {
        emit($cg, "({ char *__qs = strada_to_str(");
        if ($argc > 0) { gen_expr($cg, $args->[0]); }
        else { emit($cg, "perla_dollar_underscore ? perla_dollar_underscore : strada_new_str(\"\")"); }
        emit($cg, "); size_t __ql = strlen(__qs); char *__qr = malloc(__ql * 2 + 1); size_t __qi = 0, __qo = 0; ");
        emit($cg, "while (__qi < __ql) { unsigned char __qc = __qs[__qi]; ");
        emit($cg, "if (!(__qc >= 'a' && __qc <= 'z') && !(__qc >= 'A' && __qc <= 'Z') && !(__qc >= '0' && __qc <= '9') && __qc != '_') ");
        emit($cg, "{ __qr[__qo++] = '\\\\'; } __qr[__qo++] = __qc; __qi++; } __qr[__qo] = 0; ");
        emit($cg, "StradaValue *__qv = strada_new_str(__qr); free(__qr); free(__qs); __qv; })");
        return;
    }

    # abs
    if ($name eq "abs") {
        # Perl: `abs($obj)` dispatches `use overload 'abs'` for blessed
        # refs. Falls back to native fabs() for non-refs and refs
        # without the overload. Imposes scalar context — without it,
        # `abs(returns_list())` in print args ran the sub in list
        # context and operated on the empty-array result instead of
        # the comma-op last value.
        # Central operand wrapper: capture the arg (scalar ctx, owned-
        # tracked), compute an INDEPENDENT result, release the owned arg.
        # The body never touches operand refcounts — a UV is returned via
        # incref (independent), a non-UV via a fresh fabs() num; op_release
        # frees the owned arg. (Was inline owned/borrowed branching that
        # leaked a heap UV per call.)
        my array @__abs_sc = ();
        emit($cg, "({ ");
        if ($argc > 0) { op_capture($cg, \@__abs_sc, "__av", $args->[0], 1); }
        else { op_capture_c($cg, \@__abs_sc, "__av", "perla_dollar_underscore"); }
        emit($cg, "StradaValue *__ar = NULL; ");
        emit($cg, "if (__av && !STRADA_IS_TAGGED_INT(__av) && __av->type == STRADA_REF) __ar = perla_overload_binary(__av, strada_undef_static(), \"abs\"); ");
        emit($cg, "if (!__ar && STRADA_INT_IS_UV(__av)) { __ar = __av; strada_incref(__ar); } ");
        emit($cg, "if (!__ar) __ar = strada_new_num(fabs(strada_to_num(__av))); ");
        op_release($cg, \@__abs_sc);
        emit($cg, "__ar; })");
        return;
    }
    # sqrt/sin/cos/log/exp — Perl builtins. All dispatch their named
    # overload on blessed refs (e.g. `use overload 'sqrt' => sub { ... }`).
    # Scalar context on arg — see abs above for rationale.
    if ($name eq "sqrt" || $name eq "sin" || $name eq "cos" || $name eq "log" || $name eq "exp") {
        emit($cg, "({ int __sav_wl_uf = __perla_want_list; __perla_want_list = 0; StradaValue *__ufv = ");
        if ($argc > 0) { gen_expr($cg, $args->[0]); }
        else { emit($cg, "perla_dollar_underscore"); }
        emit($cg, "; __perla_want_list = __sav_wl_uf; StradaValue *__ufr = NULL; ");
        emit($cg, "if (__ufv && !STRADA_IS_TAGGED_INT(__ufv) && __ufv->type == STRADA_REF) { ");
        emit($cg, "  __ufr = perla_overload_binary(__ufv, strada_new_undef(), \"" . $name . "\"); } ");
        emit($cg, "__ufr ? __ufr : strada_new_num(" . $name . "(strada_to_num(__ufv))); })");
        return;
    }
    if ($name eq "atan2") {
        if ($argc >= 2) {
            emit($cg, "strada_new_num(atan2(strada_to_num(");
            gen_expr($cg, $args->[0]);
            emit($cg, "), strada_to_num(");
            gen_expr($cg, $args->[1]);
            emit($cg, ")))");
        }
        return;
    }

    # int (truncate). Also dispatches `use overload 'int' => sub {...}`
    # for blessed refs — used by classes that wrap numeric values.
    # Scalar context on arg.
    if ($name eq "int") {
        # Central operand wrapper (see abs above): capture, compute an
        # INDEPENDENT result, release the owned arg.
        my array @__int_sc = ();
        emit($cg, "({ ");
        if ($argc > 0) { op_capture($cg, \@__int_sc, "__iv", $args->[0], 1); }
        else { op_capture_c($cg, \@__int_sc, "__iv", "perla_dollar_underscore"); }
        emit($cg, "StradaValue *__ir = NULL; ");
        emit($cg, "if (__iv && !STRADA_IS_TAGGED_INT(__iv) && __iv->type == STRADA_REF) __ir = perla_overload_binary(__iv, strada_undef_static(), \"int\"); ");
        # A UV is already an integer — return it unchanged (incref → an
        # independent owned ref; op_release frees the owned arg) rather
        # than numifying through a lossy double (`int(18446744073709551615)`).
        emit($cg, "if (!__ir && STRADA_INT_IS_UV(__iv)) { __ir = __iv; strada_incref(__ir); } ");
        # For floats outside the i64 range, casting to int64_t is
        # undefined behavior and produces 0 or INT64_MIN on most
        # platforms. Match Perl: when the truncated value can't fit
        # i64, return the truncated double as a NUM. trunc() rounds
        # toward zero, matching int()'s semantics.
        emit($cg, "if (!__ir) { double __id = strada_to_num(__iv); ");
        emit($cg, "  if (__id >= (double)INT64_MIN && __id <= (double)INT64_MAX) { __ir = STRADA_MAKE_TAGGED_INT((int64_t)__id); } ");
        emit($cg, "  else { double __trunc = (__id > 0) ? floor(__id) : ceil(__id); __ir = strada_new_num(__trunc); } ");
        emit($cg, "} ");
        op_release($cg, \@__int_sc);
        emit($cg, "__ir; })");
        return;
    }

    # hex
    if ($name eq "hex") {
        # Scalar context — without it, `hex(returns_nothing())` in print
        # args got an empty STRADA_ARRAY whose stringification "array(0x...)"
        # parses as hex "a" = 10. Now passes undef → 0.
        # Capture the arg SV so an owned temp (e.g. a string literal) is
        # released — strada_to_str only copies the bytes, so the SV itself
        # leaked otherwise.
        # Central operand wrapper. strtoull (not strtol) + strada_new_uint so
        # a full-width hex value like "ffffffffffffffff" yields UV_MAX, not a
        # clamped/overflowed signed long. strada_to_str only copies the bytes,
        # so the SV itself is released by op_release (owned arg).
        my array @__hex_sc = ();
        emit($cg, "({ ");
        if ($argc > 0) { op_capture($cg, \@__hex_sc, "__hsv", $args->[0], 1); }
        else { op_capture_c($cg, \@__hex_sc, "__hsv", "perla_dollar_underscore"); }
        emit($cg, "char *__hs = strada_to_str(__hsv); StradaValue *__hr = strada_new_uint((uint64_t)strtoull(__hs, NULL, 16)); free(__hs); ");
        op_release($cg, \@__hex_sc);
        emit($cg, "__hr; })");
        return;
    }

    # oct
    if ($name eq "oct") {
        # Central operand wrapper. strtoull + strada_new_uint so a full-width
        # octal/hex/binary value yields a UV instead of a clamped/wrapped
        # signed long; op_release frees the owned arg (strada_to_str copies).
        my array @__oct_sc = ();
        emit($cg, "({ ");
        if ($argc > 0) { op_capture($cg, \@__oct_sc, "__osv", $args->[0], 0); }
        else { op_capture_c($cg, \@__oct_sc, "__osv", "perla_dollar_underscore"); }
        emit($cg, "char *__os = strada_to_str(__osv); uint64_t __ov; ");
        emit($cg, "if (__os[0]=='0' && (__os[1]=='x'||__os[1]=='X')) __ov = strtoull(__os+2, NULL, 16); ");
        emit($cg, "else if (__os[0]=='0' && (__os[1]=='b'||__os[1]=='B')) __ov = strtoull(__os+2, NULL, 2); ");
        # Perl 5.34+ explicit-octal prefix `0o` / `0O`. Without this,
        # `oct(\"0o10\")` returned 0 because strtoull(base=8) chokes on the
        # non-digit \"o\" character after the leading 0.
        emit($cg, "else if (__os[0]=='0' && (__os[1]=='o'||__os[1]=='O')) __ov = strtoull(__os+2, NULL, 8); ");
        emit($cg, "else __ov = strtoull(__os, NULL, 8); ");
        emit($cg, "free(__os); StradaValue *__or = strada_new_uint(__ov); ");
        op_release($cg, \@__oct_sc);
        emit($cg, "__or; })");
        return;
    }

    # Perl's wantarray — check calling context. Reads the SNAPSHOT
    # `__perla_caller_want_list` taken at function entry, NOT the
    # global `__perla_want_list` which gets toggled during inner
    # expression eval (e.g. `my @x = func()` sets want_list=1 for
    # the call then back to 0 — by the time the function body
    # later evaluates `wantarray`, the global reads 0 even when
    # the caller wanted a list).
    if ($name eq "wantarray") {
        # Perl: wantarray returns undef in void, "" (defined false) in
        # scalar, 1 (true) in list. Encode void as caller_want_list == -1,
        # scalar as 0, list as 1. The scalar case must yield the empty
        # string (not the int 0), otherwise `print wantarray, "\n"`
        # prints "0" instead of "" — and some idioms compare it via
        # `defined wantarray && !wantarray` which still works either way
        # but the print/stringify path was visibly wrong.
        emit($cg, "(__perla_caller_want_list == -1 ? strada_new_undef() : __perla_caller_want_list ? STRADA_MAKE_TAGGED_INT(1) : strada_new_str(\"\"))");
        return;
    }

    # caller — read from the perla call stack
    if ($name eq "caller") {
        if ($argc > 0) {
            emit($cg, "perla_caller(strada_to_int(");
            gen_expr($cg, $args->[0]);
            emit($cg, "))");
        } else {
            # Bare `caller` returns only (package, file, line). With an
            # explicit arg, returns the extended 11-tuple. Trim the
            # full result to 3 elements in list context for the no-arg
            # form. Scalar context already returns just the package.
            emit($cg, "({ StradaValue *__cr = perla_caller(0); if (__perla_want_list && __cr && !STRADA_IS_TAGGED_INT(__cr) && __cr->type == STRADA_ARRAY) { StradaArray *__cra = strada_deref_array(__cr); if (__cra && __cra->size > 3) { for (size_t __ci = 3; __ci < __cra->size; __ci++) { if (__cra->elements[__cra->head + __ci]) strada_decref(__cra->elements[__cra->head + __ci]); } __cra->size = 3; } } __cr; })");
        }
        return;
    }

    # splice(@arr, offset, length, @repl) — Perl: in list context, return
    # ALL removed elements; in scalar context, return only the LAST one
    # (or undef if nothing was removed). Wrap the runtime call so that
    # `my $picked = splice(@a, $i, 1)` binds the removed element, not
    # the count.
    if ($name eq "splice") {
        emit($cg, "({ StradaValue *__sp_res = ");
        if ($argc >= 3) {
            emit($cg, "strada_array_splice_sv(");
            gen_expr($cg, $args->[0]);
            emit($cg, ", (int64_t)strada_to_num(");
            gen_expr($cg, $args->[1]);
            emit($cg, "), (int64_t)strada_to_num(");
            gen_expr($cg, $args->[2]);
            emit($cg, "), ");
            if ($argc >= 4) {
                # Build replacement array. Flatten list-context exprs
                # (range, array var, slice, map/grep/sort, call) so
                # `splice(@a, 2, 0, 10..12)` inserts 3 elements instead
                # of one range-array element.
                emit($cg, "({ StradaValue *__sp = strada_new_array(); ");
                my int $si = 3;
                while ($si < $argc) {
                    my int $st = $args->[$si]->{"type"};
                    if ($st == Perla::AST::N_RANGE()
                        || $st == Perla::AST::N_ARRAY_VAR()
                        || $st == Perla::AST::N_DEREF_ARRAY()
                        || $st == Perla::AST::N_ARRAY_SLICE()
                        || $st == Perla::AST::N_HASH_SLICE()
                        || $st == Perla::AST::N_CALL()
                        || $st == Perla::AST::N_METHOD()
                        || $st == Perla::AST::N_GREP()
                        || $st == Perla::AST::N_MAP()
                        || $st == Perla::AST::N_SORT()) {
                        emit($cg, "{ StradaValue *__sv = ");
                        gen_expr($cg, $args->[$si]);
                        emit($cg, "; if (__sv && !STRADA_IS_TAGGED_INT(__sv) && __sv->type == STRADA_ARRAY) { ");
                        emit($cg, "StradaArray *__sfa = __sv->value.av; ");
                        emit($cg, "for (size_t __sfi = 0; __sfi < __sfa->size; __sfi++) strada_array_push(strada_deref_array(__sp), __sfa->elements[__sfa->head + __sfi]); ");
                        emit($cg, "} else { strada_array_push(strada_deref_array(__sp), __sv); } } ");
                    } else {
                        emit($cg, "strada_array_push(strada_deref_array(__sp), ");
                        gen_expr($cg, $args->[$si]);
                        emit($cg, "); ");
                    }
                    $si++;
                }
                emit($cg, "__sp; })");
            } else {
                emit($cg, "strada_new_undef()");
            }
            emit($cg, ")");
        } elsif ($argc >= 2) {
            # splice without length — remove to end
            emit($cg, "strada_array_splice_sv(");
            gen_expr($cg, $args->[0]);
            emit($cg, ", (int64_t)strada_to_num(");
            gen_expr($cg, $args->[1]);
            emit($cg, "), (int64_t)9999999, strada_new_undef())");
        } elsif ($argc == 1) {
            # `splice(@arr)` — remove everything from offset 0, return all
            emit($cg, "strada_array_splice_sv(");
            gen_expr($cg, $args->[0]);
            emit($cg, ", (int64_t)0, (int64_t)9999999, strada_new_undef())");
        }
        # Scalar context: return last removed element (or undef). The
        # void marker -1 falls through with the full array.
        emit($cg, "; if (__perla_want_list == 0 && __sp_res && !STRADA_IS_TAGGED_INT(__sp_res) && __sp_res->type == STRADA_ARRAY) { ");
        emit($cg, "  StradaArray *__sp_rav = __sp_res->value.av; ");
        emit($cg, "  StradaValue *__sp_last = (__sp_rav && __sp_rav->size > 0) ? __sp_rav->elements[__sp_rav->head + __sp_rav->size - 1] : NULL; ");
        emit($cg, "  if (__sp_last) strada_incref(__sp_last); ");
        emit($cg, "  strada_decref(__sp_res); ");
        emit($cg, "  __sp_res = __sp_last ? __sp_last : strada_new_undef(); ");
        emit($cg, "} __sp_res; })");
        return;
    }

    # exit($code) — wrap in a statement-expression that yields undef
    # so callers using it as an expression (e.g. `my $x = eval { exit 7 }`)
    # compile. exit() in C is void; without the wrapper, codegen that
    # tries to capture the result emits `... = exit(...)` and gcc errors.
    if ($name eq "exit") {
        emit($cg, "({ exit((int)strada_to_num(");
        if ($argc > 0) { gen_expr($cg, $args->[0]); }
        else { emit($cg, "STRADA_MAKE_TAGGED_INT(0)"); }
        emit($cg, ")); strada_new_undef(); })");
        return;
    }

    # system($cmd)
    if ($name eq "system") {
        # Perl's `system` returns the raw wait status (high byte = exit
        # code, low byte = signal info). Callers commonly do `$rc >> 8`
        # to extract the exit code. Previously perla returned the
        # extracted code directly, so `system("false") >> 8` gave 0.
        # Also stores the wait status in `$?` so subsequent reads see it.
        # Multi-arg form `system($cmd, @args)` — Perl runs EXEC directly
        # without a shell, so args containing whitespace, quotes, etc.
        # don't get re-tokenized. Use fork+execvp+waitpid so the child
        # sees the args literally. Previously perla joined the args
        # with spaces and went through /bin/sh -c, which mishandled
        # `system("sh", "-c", "exit 42")` (became `sh -c "sh -c exit 42"`
        # and sh-tokenized — exit's argument silently dropped).
        if ($argc > 1) {
            emit($cg, "({ char *__sa_argv[" . ($argc + 1) . "]; ");
            my int $sai = 0;
            while ($sai < $argc) {
                emit($cg, "__sa_argv[" . $sai . "] = strada_to_str(");
                gen_expr($cg, $args->[$sai]);
                emit($cg, "); ");
                $sai = $sai + 1;
            }
            emit($cg, "__sa_argv[" . $argc . "] = NULL; ");
            emit($cg, "int __sa_status = 0; fflush(NULL); pid_t __sa_pid = fork(); ");
            emit($cg, "if (__sa_pid == 0) { execvp(__sa_argv[0], __sa_argv); _exit(127); } ");
            emit($cg, "else if (__sa_pid > 0) { waitpid(__sa_pid, &__sa_status, 0); } ");
            emit($cg, "else { __sa_status = -1; } ");
            my int $sfi = 0;
            while ($sfi < $argc) {
                emit($cg, "free(__sa_argv[" . $sfi . "]); ");
                $sfi = $sfi + 1;
            }
            emit($cg, "perla_dollar_question = __sa_status; STRADA_MAKE_TAGGED_INT(__sa_status); })");
            return;
        }
        emit($cg, "({ char *__cmd = strada_to_str(");
        gen_expr($cg, $args->[0]);
        emit($cg, "); int __sr = system(__cmd); free(__cmd); perla_dollar_question = __sr; STRADA_MAKE_TAGGED_INT(__sr); })");
        return;
    }

    # time() — current epoch seconds. With `use Time::HiRes`, returns
    # a float with sub-second resolution; otherwise integer seconds.
    if ($name eq "time") {
        if (defined($cg->{"use_hires"}) && $cg->{"use_hires"} == 1) {
            emit($cg, "({ struct timespec __ts; clock_gettime(CLOCK_REALTIME, &__ts); strada_new_num((double)__ts.tv_sec + (double)__ts.tv_nsec / 1e9); })");
        } else {
            emit($cg, "STRADA_MAKE_TAGGED_INT((int64_t)time(NULL))");
        }
        return;
    }
    # Strada memory-management controls exposed to Perl source. The cycle
    # collector reclaims Perl reference cycles automatically (no need for
    # Scalar::Util::weaken); these allow explicit control/tuning. They map to
    # the shared runtime, which provides no-op stubs when a feature is configured
    # out, so the calls always compile.
    if ($name eq "Strada::gc_collect") {
        emit($cg, "({ strada_gc_collect(); STRADA_MAKE_TAGGED_INT(0); })");
        return;
    }
    if ($name eq "Strada::gc_enable") {
        emit($cg, "({ strada_gc_set_enabled(1); STRADA_MAKE_TAGGED_INT(0); })");
        return;
    }
    if ($name eq "Strada::gc_disable") {
        emit($cg, "({ strada_gc_set_enabled(0); STRADA_MAKE_TAGGED_INT(0); })");
        return;
    }
    if ($name eq "Strada::gc_collections") {
        emit($cg, "strada_new_int((int64_t)strada_gc_collections())");
        return;
    }
    if ($name eq "Strada::gc_freed") {
        emit($cg, "strada_new_int((int64_t)strada_gc_objects_freed())");
        return;
    }
    if ($name eq "Strada::gc_threshold") {
        emit($cg, "({ strada_gc_set_threshold((long)strada_to_int(");
        if ($argc > 0) { gen_expr($cg, $args->[0]); } else { emit($cg, "STRADA_MAKE_TAGGED_INT(10000)"); }
        emit($cg, ")); STRADA_MAKE_TAGGED_INT(0); })");
        return;
    }
    if ($name eq "Strada::arena_begin") {
        emit($cg, "({ strada_arena_begin(); STRADA_MAKE_TAGGED_INT(0); })");
        return;
    }
    if ($name eq "Strada::arena_end") {
        emit($cg, "({ strada_arena_end(); STRADA_MAKE_TAGGED_INT(0); })");
        return;
    }
    if ($name eq "Strada::arena_active") {
        emit($cg, "strada_new_int((int64_t)strada_arena_active())");
        return;
    }
    # Time::HiRes::time — current epoch as float (sub-second resolution)
    if ($name eq "Time::HiRes::time") {
        emit($cg, "({ struct timespec __ts; clock_gettime(CLOCK_REALTIME, &__ts); strada_new_num((double)__ts.tv_sec + (double)__ts.tv_nsec / 1e9); })");
        return;
    }
    # Time::HiRes::sleep / Time::HiRes::usleep — high-resolution sleep.
    # Bare `usleep` (and bare `nanosleep`) after `use Time::HiRes qw(usleep)`
    # was falling through to the walking-stash lookup which couldn't find
    # it (no perla_code_set binding), so it returned undef and effectively
    # didn't sleep. Treat the bare names as aliases here.
    if ($name eq "Time::HiRes::sleep") {
        emit($cg, "({ double __hs = strada_to_num(");
        if ($argc > 0) { gen_expr($cg, $args->[0]); }
        else { emit($cg, "STRADA_MAKE_TAGGED_INT(0)"); }
        emit($cg, "); struct timespec __hts = { (time_t)__hs, (long)((__hs - (long)__hs) * 1e9) }; nanosleep(&__hts, NULL); STRADA_MAKE_TAGGED_INT(0); })");
        return;
    }
    if ($name eq "Time::HiRes::usleep" || $name eq "usleep") {
        emit($cg, "({ unsigned int __us = (unsigned int)strada_to_int(");
        if ($argc > 0) { gen_expr($cg, $args->[0]); }
        else { emit($cg, "STRADA_MAKE_TAGGED_INT(0)"); }
        emit($cg, "); usleep(__us); STRADA_MAKE_TAGGED_INT(__us); })");
        return;
    }
    if ($name eq "Time::HiRes::nanosleep" || $name eq "nanosleep") {
        emit($cg, "({ int64_t __ns = strada_to_int(");
        if ($argc > 0) { gen_expr($cg, $args->[0]); }
        else { emit($cg, "STRADA_MAKE_TAGGED_INT(0)"); }
        emit($cg, "); struct timespec __nts = { (time_t)(__ns / 1000000000LL), (long)(__ns % 1000000000LL) }; nanosleep(&__nts, NULL); STRADA_MAKE_TAGGED_INT(__ns); })");
        return;
    }
    # Imported as `use Time::HiRes qw(gettimeofday)` — handle the
    # unqualified form when the flag is set. Without this, `gettimeofday`
    # at call site falls through to the generic bareword path which
    # treats it as a literal string "gettimeofday".
    if ($name eq "Time::HiRes::gettimeofday"
        || ($name eq "gettimeofday" && defined($cg->{"use_hires"}) && $cg->{"use_hires"} == 1)) {
        emit($cg, "({ struct timespec __ts; clock_gettime(CLOCK_REALTIME, &__ts); StradaValue *__gtres; ");
        emit($cg, "if (__perla_want_list) { ");
        emit($cg, "StradaValue *__a = strada_new_array(); StradaArray *__av = strada_deref_array(__a); ");
        emit($cg, "strada_array_push(__av, STRADA_MAKE_TAGGED_INT((int64_t)__ts.tv_sec)); ");
        emit($cg, "strada_array_push(__av, STRADA_MAKE_TAGGED_INT((int64_t)(__ts.tv_nsec / 1000))); __gtres = __a; ");
        emit($cg, "} else { __gtres = strada_new_num((double)__ts.tv_sec + (double)__ts.tv_nsec / 1e9); } __gtres; })");
        return;
    }
    # sleep($n) — handles both integer and fractional sleeps. When
    # Time::HiRes is imported, `sleep(0.5)` works without explicit
    # `Time::HiRes::sleep`. Plain `sleep(N)` is unchanged: integer
    # seconds, returns seconds slept.
    if ($name eq "sleep") {
        emit($cg, "({ double __ss = strada_to_num(");
        if ($argc > 0) { gen_expr($cg, $args->[0]); }
        else { emit($cg, "STRADA_MAKE_TAGGED_INT(0)"); }
        emit($cg, "); struct timespec __sts = { (time_t)__ss, (long)((__ss - (time_t)__ss) * 1e9) }; ");
