        return;
    }
    if ($name eq "uc" && $argc == 0) {
        emit($cg, "({ char *__s = strada_to_str(perla_dollar_underscore ? perla_dollar_underscore : strada_new_str(\"\")); char *__r = strada_uc(__s); StradaValue *__rv = strada_new_str(__r); free(__r); free(__s); __rv; })");
        return;
    }
    if ($name eq "length" && $argc == 0) {
        emit($cg, "({ char *__s = strada_to_str(perla_dollar_underscore ? perla_dollar_underscore : strada_new_str(\"\")); int64_t __len = (int64_t)strlen(__s); free(__s); STRADA_MAKE_TAGGED_INT(__len); })");
        return;
