                         || $hkt == Perla::AST::N_ARRAY_SLICE() || $hkt == Perla::AST::N_HASH_SLICE()
                         || $hkt == Perla::AST::N_CALL() || $hkt == Perla::AST::N_METHOD()
                         || $hkt == Perla::AST::N_MAP() || $hkt == Perla::AST::N_GREP()
                         || $hkt == Perla::AST::N_SORT() || $hkt == Perla::AST::N_RANGE()) {
