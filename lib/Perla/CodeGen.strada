                # report whatever context the enclosing call had, not the
                # `$x = sub_call()`-expected scalar.
                emit($cg, "({ StradaValue *__old_sv = " . c_var($mirror_name) . "; ");
                emit($cg, "int __sav_wl_sa1 = __perla_want_list; __perla_want_list = 0; ");
                gen_expr($cg, $target);
                emit($cg, " = ");
                gen_expr($cg, $node->{"value"});
                emit($cg, "; __perla_want_list = __sav_wl_sa1; ");
                emit($cg, "if (__old_sv != " . c_var($mirror_name) . ") strada_decref(__old_sv); ");
                emit($cg, "{ PerlGlob *__og = perla_glob_get_or_create(perla_stash_get_or_create(\"" . $cg->{"pkg"} . "\"), \"" . $mirror_name . "\"); ");
                emit($cg, "perla_glob_store(__og, PERLA_SLOT_SCALAR, " . c_var($mirror_name) . "); } ");
