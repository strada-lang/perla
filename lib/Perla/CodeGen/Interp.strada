# Perla::CodeGen::Interp - String interpolation codegen.
#
# Compiles Perl's `"...$var..."` and `"...@arr..."` interpolations to
# concatenated C runtime calls. Three entry points used by the rest of
# CodeGen:
#
#   emit_interp_part(cg, p)
#     Heart of the interp engine. Walks a "part" token (one segment of
#     an interpolated string after the parser broke it apart) and emits
#     the right runtime call: simple `$var`, `@arr`, array slices, hash
#     accesses ($h{k}), capture vars ($1), arrow derefs, and the dozen
#     other interpolation shapes Perl supports.
#
#   gen_interp_str(cg, raw)
#     Top-level interp dispatcher. Splits the raw `"..."` source into
#     parts, then funnels each through emit_interp_part. Handles the
#     boundary cases (single-var → borrow optimization, no-var literal
#     → fast path, multi-part → concat chain).
#
#   gen_interp_c_str(cg, s) + emit_interpc_var(cg, vn)
#     Regex-pattern variant of the above. Used when a `$var` inside a
#     regex literal or substitution pattern needs runtime interpolation
#     before pcre2_compile sees the final pattern.
#
# Plus four internal helpers (find_interp_h_sep, strip_quoted_key,
# has_dollar_digit, has_perl_var_repl) that the entry points lean on.
#
# Cross-module calls back into main Perla::CodeGen (emit, ind, gen_expr,
# c_var, c_var_a, c_var_h, has_perl_var) use the qualified form. Calls
# to already-extracted Perla::CodeGen::Escape stay as before.

use Perla::AST;
use Perla::Lexer;
use Perla::Parser;
use Perla::CodeGen::Escape;

package Perla::CodeGen::Interp;

# Forward decls for Perla::CodeGen helpers we call inline.
# We can't `use Perla::CodeGen;` because CodeGen.strada `use`s us (cycle), so
# we declare the cross-module entry points natively. The Strada compiler
# accepts body-less `extern func Pkg::name(...) ret;` as a cross-module
# forward decl: it emits the extern with StradaValue* args/ret, registers
# the function in $cg->{"functions"} under the mangled symbol (Perla_CodeGen_*),
# and call sites use the ordinary Strada calling convention. That last bit
# is what closes the loop -- `needs_temp_cleanup` now recognises owned
# returns from these helpers, so a direct-pass `emit($cg, c_var($vn))`
# is safe (the temp wrapper around the owned char return wins).
extern func Perla::CodeGen::emit(scalar $cg, str $s) void;
extern func Perla::CodeGen::gen_expr(scalar $cg, scalar $node) void;
extern func Perla::CodeGen::c_var(str $name) str;
extern func Perla::CodeGen::c_var_a(str $name) str;
extern func Perla::CodeGen::c_var_h(str $name) str;
extern func Perla::CodeGen::has_perl_var(str $s) int;

func emit_interp_part(scalar $cg, str $p) void {
    # `QV:` — variable interpolation inside `\Q...\E`. Wrap the var's
    # value with strada_quotemeta() so the runtime string includes the
    # escaped form. Routed via this prefix rather than embedding the
    # wrap at _gen_interp_str's emit-time keeps the var-resolution
    # logic in one place (see the V: handler below).
    if (substr($p, 0, 3) eq "QV:") {
        my str $vn = substr($p, 3, length($p) - 3);
        Perla::CodeGen::emit($cg, "({ StradaValue *__qmv = " . Perla::CodeGen::c_var($vn) . "; strada_quotemeta(__qmv); })");
        return;
    }
    if (substr($p, 0, 2) eq "S:") {
        # The S: content already has C-compatible escapes like \n/\t/\r/\\
        # left in source form (dumped directly into the C string literal).
        # But some Perl-only escapes (\u, \L, \E, \Q, \l, \U) would be parsed
        # by C as malformed universal-character-names or warnings. Double the
        # backslash for those so C sees literal backslash+letter instead.
        # PERLA_NEW_STR_LIT uses sizeof(literal)-1 so embedded NULs
        # (`"\x00""ABC"` after adjacent-literal concat) keep their length.
        # `use utf8` switches the literal to char-oriented (SVf_UTF8) so
        # length()/uc()/lc() etc. count code points rather than bytes.
        my str $__s_payload = substr($p, 2, length($p) - 2);
        my str $__s_esc = Perla::CodeGen::Escape::escape_perl_only_bslash($__s_payload);
        if (defined($cg->{"use_utf8"}) && $cg->{"use_utf8"} == 1) {
            Perla::CodeGen::emit($cg, "PERLA_NEW_STR_LIT_UTF8(\"" . $__s_esc . "\")");
        } else {
            Perla::CodeGen::emit($cg, "PERLA_NEW_STR_LIT(\"" . $__s_esc . "\")");
        }
    } elsif (substr($p, 0, 3) eq "HQ:") {
        # Quoted-key hash access: `$h{'a-b'}` / `$h{"x/y"}`. The key is
        # a literal string with no parse/bareword interpretation —
        # skip the H: path's complex-key parser (which would have
        # parsed "a-b" as subtraction) and emit a direct fetch.
        my str $hqpart = substr($p, 3, length($p) - 3);
        my int $hqcol = find_interp_h_sep($hqpart);
        if ($hqcol < 0) { $hqcol = index($hqpart, ":"); }
        my str $hqvar = substr($hqpart, 0, $hqcol);
        my str $hqkey = substr($hqpart, $hqcol + 1, length($hqpart) - $hqcol - 1);
        my int $hq_qual = index($hqvar, "::") > 0 ? 1 : 0;
        my str $hq_esc = Perla::CodeGen::Escape::escape_c_str($hqkey);
        if ($hq_qual == 1) {
            my int $hqi = 0; my int $hqli = -1;
            while ($hqi < length($hqvar) - 1) {
                if (substr($hqvar, $hqi, 2) eq "::") { $hqli = $hqi; }
                $hqi = $hqi + 1;
            }
            my str $hq_pkg = substr($hqvar, 0, $hqli);
            my str $hq_name = substr($hqvar, $hqli + 2, length($hqvar) - $hqli - 2);
            Perla::CodeGen::emit($cg, "strada_hv_fetch_owned(perla_hash_get(\"" . $hq_pkg . "\", \"" . $hq_name . "\"), \"" . $hq_esc . "\")");
        } else {
            Perla::CodeGen::emit($cg, "strada_hv_fetch_owned(" . Perla::CodeGen::c_var_h($hqvar) . ", \"" . $hq_esc . "\")");
        }
    } elsif (substr($p, 0, 2) eq "H:") {
        my str $hpart = substr($p, 2, length($p) - 2);
        # Find separator skipping past `::` in package-qualified vars
        # ($Foo::h{a} → "Foo::h:a", separator at index 6, not 3).
        my int $col = find_interp_h_sep($hpart);
        if ($col < 0) { $col = index($hpart, ":"); }
        my str $hvar = substr($hpart, 0, $col);
        my str $hkey = substr($hpart, $col + 1, length($hpart) - $col - 1);
        # Detect variable key: `$h{$k}` should look up by the value of $k,
        # not by the literal string "$k". Without this, `"$h{$k}"` always
        # returned empty in interpolation context (DBIC's
        # `map { "$_=$args{$_}" }` was a long-running blocker — every
        # validator's "@extra" and PVC default-handling depended on
        # variable-keyed hash access via interpolation).
        my str $hkey_c = "";
        # Check whether the key is a simple form we can fast-path. Anything
        # else routes through the inline-parse fallback below.
        my int $hk_simple = 0;
        if (length($hkey) > 1 && substr($hkey, 0, 1) eq "$") {
            my str $hkn = substr($hkey, 1, length($hkey) - 1);
            # `$h{$a[N]}` and `$h{$a{K}}` — key is a chained access. Use the
            # array-element / hash-element accessor instead of looking up
            # `v_a[0]` (which is the C compiler's pointer-index of v_a).
            my int $hk_lb = index($hkn, "[");
            my int $hk_rb = index($hkn, "{");
            if ($hk_lb > 0 && substr($hkn, length($hkn) - 1, 1) eq "]") {
                my str $hkn_v = substr($hkn, 0, $hk_lb);
                my str $hkn_i = substr($hkn, $hk_lb + 1, length($hkn) - $hk_lb - 2);
                # If the index is a simple integer literal or `$var`, use
                # the fast path; if it's an expression (`$i+1`, function
                # call), drop to the inline-parse fallback below.
                my int $hkn_i_simple = 1;
                my int $hknii = 0;
                while ($hknii < length($hkn_i)) {
                    my str $hkic = substr($hkn_i, $hknii, 1);
                    if (!(($hkic ge "0" && $hkic le "9") || ($hknii == 0 && ($hkic eq "-" || $hkic eq "\$"))
                          || ($hknii > 0 && (($hkic ge "a" && $hkic le "z") || ($hkic ge "A" && $hkic le "Z")
                                             || ($hkic ge "0" && $hkic le "9") || $hkic eq "_")))) {
                        $hkn_i_simple = 0;
                        last;
                    }
                    $hknii++;
                }
                if ($hkn_i_simple == 1) {
                    my str $hkn_i_c = $hkn_i;
                    if (length($hkn_i) > 0 && substr($hkn_i, 0, 1) eq "\$") {
                        my str $hkn_iv = substr($hkn_i, 1, length($hkn_i) - 1);
                        $hkn_i_c = "strada_to_int(" . Perla::CodeGen::c_var($hkn_iv) . ")";
                    }
                    $hkey_c = "strada_to_str(strada_array_get(strada_deref_array(" . Perla::CodeGen::c_var_a($hkn_v) . "), " . $hkn_i_c . "))";
                    $hk_simple = 1;
                }
            } elsif ($hk_rb > 0 && substr($hkn, length($hkn) - 1, 1) eq "}") {
                my str $hkn_v = substr($hkn, 0, $hk_rb);
                my str $hkn_k = strip_quoted_key(substr($hkn, $hk_rb + 1, length($hkn) - $hk_rb - 2));
                $hkey_c = "strada_to_str(strada_hv_fetch_owned(" . Perla::CodeGen::c_var_h($hkn_v) . ", \"" . $hkn_k . "\"))";
                $hk_simple = 1;
            } elsif ($hkn eq "_") {
                $hkey_c = "strada_to_str(perla_dollar_underscore)";
                $hk_simple = 1;
            } elsif (length($hkn) == 1 && $hkn ge "1" && $hkn le "9") {
                # `$h{$1}` — key is a regex capture variable. Without this,
                # the codegen tried to read `v_1` (nonexistent) and emitted
                # an empty key, so the lookup always missed.
                $hkey_c = "strada_to_str(strada_capture_var(" . $hkn . "))";
                $hk_simple = 1;
            } else {
                # Simple identifier: `$varname`. Anything with operators
                # falls through to the inline-parse path.
                my int $hkn_id_only = 1;
                my int $hknj = 0;
                while ($hknj < length($hkn)) {
                    my str $hkic2 = substr($hkn, $hknj, 1);
                    if (!(($hkic2 ge "a" && $hkic2 le "z") || ($hkic2 ge "A" && $hkic2 le "Z")
                          || ($hkic2 ge "0" && $hkic2 le "9") || $hkic2 eq "_")) {
                        $hkn_id_only = 0;
                        last;
                    }
                    $hknj++;
                }
                if ($hkn_id_only == 1) {
                    # `$_` is the loop-local perla_dollar_underscore, not v__.
                    if ($hkn eq "_") {
                        $hkey_c = "strada_to_str(perla_dollar_underscore)";
                    } else {
                        $hkey_c = "strada_to_str(" . Perla::CodeGen::c_var($hkn) . ")";
                    }
                    $hk_simple = 1;
                }
            }
        }
        # Bareword auto-quote: `$h{IDENT}` is `$h{"IDENT"}` in Perl. This
        # path is hit for keys like `$h{x}`, `$h{name}` etc. — they must
        # NOT be parsed as expressions (or `x` would parse as the repeat
        # operator and produce undef).
        if ($hk_simple == 0 && length($hkey) > 0) {
            my int $__hk_bw = 1;
            my int $__hk_bj = 0;
            my str $__hk_c0 = substr($hkey, 0, 1);
            if (!(($__hk_c0 ge "a" && $__hk_c0 le "z") || ($__hk_c0 ge "A" && $__hk_c0 le "Z") || $__hk_c0 eq "_")) {
                $__hk_bw = 0;
            }
            while ($__hk_bw == 1 && $__hk_bj < length($hkey)) {
                my str $__hkc = substr($hkey, $__hk_bj, 1);
                if (!(($__hkc ge "a" && $__hkc le "z") || ($__hkc ge "A" && $__hkc le "Z")
                      || ($__hkc ge "0" && $__hkc le "9") || $__hkc eq "_")) {
                    $__hk_bw = 0;
                }
                $__hk_bj++;
            }
            if ($__hk_bw == 1) {
                # Direct bareword key — bypass the inline-parse path
                # entirely. Falls through to the static-key emit below.
                $hkey_c = "";
                $hk_simple = 1;
            }
        }
        # Multi-key subscript in interpolation: `"$h{$a, $b}"` is the
        # `$;`-joined compound key `$h{join($;, $a, $b)}`, the same as
        # the non-interp parser builds (see _parse_hash_key). The inline
        # parse below would otherwise lex `$a, $b` as a list expression
        # and stringify it without the separator, so the fetch key
        # ("ab") never matched the stored key ("a\034b"). Rewrite a
        # top-level comma into the `(p0).$;.(p1)...` concat form so the
        # inline parser produces the same joined key. Top-level = not
        # inside (), [], {}, or quotes.
        if ($hk_simple == 0 && length($hkey) > 0) {
            my int $__mk_depth = 0;
            my int $__mk_has_comma = 0;
            my int $__mk_q = 0;       # 0 none, 1 single, 2 double
            my int $__mk_i = 0;
            while ($__mk_i < length($hkey)) {
                my str $__mkc = substr($hkey, $__mk_i, 1);
                if ($__mk_q == 1) {
                    if ($__mkc eq "'") { $__mk_q = 0; }
                } elsif ($__mk_q == 2) {
                    if ($__mkc eq "\"") { $__mk_q = 0; }
                } elsif ($__mkc eq "'") { $__mk_q = 1; }
                elsif ($__mkc eq "\"") { $__mk_q = 2; }
                elsif ($__mkc eq "(" || $__mkc eq "[" || $__mkc eq "{") { $__mk_depth = $__mk_depth + 1; }
                elsif ($__mkc eq ")" || $__mkc eq "]" || $__mkc eq "}") { $__mk_depth = $__mk_depth - 1; }
                elsif ($__mkc eq "," && $__mk_depth == 0) { $__mk_has_comma = 1; }
                $__mk_i = $__mk_i + 1;
            }
            if ($__mk_has_comma == 1) {
                # Split on top-level commas and rejoin with `.$;.`,
                # wrapping each piece in parens so its own operators
                # bind tighter than the concat.
                my str $__mk_out = "";
                my int $__mk_ps = 0;
                $__mk_depth = 0;
                $__mk_q = 0;
                $__mk_i = 0;
                while ($__mk_i <= length($hkey)) {
                    my str $__mkc2 = "";
                    if ($__mk_i < length($hkey)) { $__mkc2 = substr($hkey, $__mk_i, 1); }
                    my int $__mk_cut = 0;
                    if ($__mk_i == length($hkey)) {
                        $__mk_cut = 1;
                    } elsif ($__mk_q == 1) {
                        if ($__mkc2 eq "'") { $__mk_q = 0; }
                    } elsif ($__mk_q == 2) {
                        if ($__mkc2 eq "\"") { $__mk_q = 0; }
                    } elsif ($__mkc2 eq "'") { $__mk_q = 1; }
                    elsif ($__mkc2 eq "\"") { $__mk_q = 2; }
                    elsif ($__mkc2 eq "(" || $__mkc2 eq "[" || $__mkc2 eq "{") { $__mk_depth = $__mk_depth + 1; }
                    elsif ($__mkc2 eq ")" || $__mkc2 eq "]" || $__mkc2 eq "}") { $__mk_depth = $__mk_depth - 1; }
                    elsif ($__mkc2 eq "," && $__mk_depth == 0) { $__mk_cut = 1; }
                    if ($__mk_cut == 1) {
                        my str $__mk_piece = substr($hkey, $__mk_ps, $__mk_i - $__mk_ps);
                        if (length($__mk_out) > 0) { $__mk_out = $__mk_out . " . \$; . "; }
                        $__mk_out = $__mk_out . "(" . $__mk_piece . ")";
                        $__mk_ps = $__mk_i + 1;
                    }
                    $__mk_i = $__mk_i + 1;
                }
                $hkey = $__mk_out;
            }
        }
        if ($hk_simple == 0 && length($hkey) > 0) {
            # Complex key expression — lex+parse and emit inline. Handles
            # `$h{$arr[$i+1]}`, `$h{func()}`, `$h{$x . "_suffix"}`, etc.
            my array @__hx_toks = Perla::Lexer::lex($hkey . ";");
            my scalar $__hx_ast = Perla::Parser::parse(@__hx_toks);
            my scalar $__hx_node = undef;
            if (defined($__hx_ast) && defined($__hx_ast->{"stmts"})) {
                my scalar $__hx_stmts = $__hx_ast->{"stmts"};
                if (scalar(@{$__hx_stmts}) >= 1) {
                    $__hx_node = $__hx_stmts->[0];
                }
            }
            if (defined($__hx_node)) {
                $hkey_c = "({ StradaValue *__hxv = ";
                # We need a temporary buffer to capture the gen_expr output.
                # We can't easily compose this as a string, so emit straight
                # to $cg and skip the $hkey_c indirection. Use a flag to
                # signal "emit inline" to the printer below.
            }
            # Package-qualified `$Foo::h{key}` interp: read directly from
            # the stash via perla_hash_get(pkg, name) — there's no
            # file-scope v_Foo__c_h variable for an external package's
            # hash. (Same handling applied to the non-parsed-key path
            # below.)
            my int $__hv_qual = index($hvar, "::") > 0 ? 1 : 0;
            my str $__hv_pkg = "";
            my str $__hv_name = "";
            if ($__hv_qual == 1) {
                my int $__qi = 0;
                my int $__last_qq = -1;
                while ($__qi < length($hvar) - 1) {
                    if (substr($hvar, $__qi, 2) eq "::") { $__last_qq = $__qi; }
                    $__qi = $__qi + 1;
                }
                $__hv_pkg = substr($hvar, 0, $__last_qq);
                $__hv_name = substr($hvar, $__last_qq + 2, length($hvar) - $__last_qq - 2);
            }
            # We'll branch below based on whether $__hx_node is defined.
            if (defined($__hx_node)) {
                # Emit the whole H: result inline using the parsed node.
                if ($__hv_qual == 1) {
                    Perla::CodeGen::emit($cg, "({ StradaValue *__ih = perla_hash_get(\"" . $__hv_pkg . "\", \"" . $__hv_name . "\"); ");
                } else {
                    Perla::CodeGen::emit($cg, "({ StradaValue *__ih = " . Perla::CodeGen::c_var_h($hvar) . "; ");
                    Perla::CodeGen::emit($cg, "if (!__ih || (!STRADA_IS_TAGGED_INT(__ih) && __ih->type == STRADA_HASH && __ih->value.hv && __ih->value.hv->num_entries == 0 && !(__ih->meta && __ih->meta->is_tied))) { ");
                    Perla::CodeGen::emit($cg, "StradaValue *__hsv = perla_hash_get(\"" . $hvar . "\", \"" . $hvar . "\"); if (__hsv) __ih = __hsv; } ");
                }
                Perla::CodeGen::emit($cg, "char *__hk = strada_to_str(");
                Perla::CodeGen::gen_expr($cg, $__hx_node);
                Perla::CodeGen::emit($cg, "); StradaValue *__iv = strada_hv_fetch_owned(__ih, __hk); free(__hk); __iv; })");
                return;
            }
        }
        # Fall back to the package stash when the module-local hash is
        # empty. Handles imported hashes: `use Config;` in package Errno
        # declares a module-local v_Config that's never populated; the
        # tie shim in Config.pm stores into the Config stash so that
        # `"$Config{archname}"` in Errno can still resolve.
        my int $__hv_qual2 = index($hvar, "::") > 0 ? 1 : 0;
        if ($__hv_qual2 == 1) {
            my int $__qi2 = 0;
            my int $__last_qq2 = -1;
            while ($__qi2 < length($hvar) - 1) {
                if (substr($hvar, $__qi2, 2) eq "::") { $__last_qq2 = $__qi2; }
                $__qi2 = $__qi2 + 1;
            }
            my str $__hv_pkg2 = substr($hvar, 0, $__last_qq2);
            my str $__hv_name2 = substr($hvar, $__last_qq2 + 2, length($hvar) - $__last_qq2 - 2);
            Perla::CodeGen::emit($cg, "({ StradaValue *__ih = perla_hash_get(\"" . $__hv_pkg2 . "\", \"" . $__hv_name2 . "\"); ");
        } else {
            Perla::CodeGen::emit($cg, "({ StradaValue *__ih = " . Perla::CodeGen::c_var_h($hvar) . "; ");
            Perla::CodeGen::emit($cg, "if (!__ih || (!STRADA_IS_TAGGED_INT(__ih) && __ih->type == STRADA_HASH && __ih->value.hv && __ih->value.hv->num_entries == 0 && !(__ih->meta && __ih->meta->is_tied))) { ");
            Perla::CodeGen::emit($cg, "StradaValue *__hsv = perla_hash_get(\"" . $hvar . "\", \"" . $hvar . "\"); if (__hsv) __ih = __hsv; } ");
        }
        if (length($hkey_c) > 0) {
            Perla::CodeGen::emit($cg, "char *__hk = " . $hkey_c . "; ");
            Perla::CodeGen::emit($cg, "StradaValue *__iv = strada_hv_fetch_owned(__ih, __hk); free(__hk); __iv; })");
        } else {
            Perla::CodeGen::emit($cg, "StradaValue *__iv = strada_hv_fetch_owned(__ih, \"" . $hkey . "\"); __iv; })");
        }
    } elsif (substr($p, 0, 2) eq "A:") {
        my str $apart = substr($p, 2, length($p) - 2);
        # `::` handling for package-qualified array vars ($Foo::a[0]).
        my int $col = find_interp_h_sep($apart);
        if ($col < 0) { $col = index($apart, ":"); }
        my str $avar = substr($apart, 0, $col);
        my str $aidx = substr($apart, $col + 1, length($apart) - $col - 1);
        my int $is_num = 1;
        my int $ai = 0;
        if (length($aidx) == 0) { $is_num = 0; }
        while ($ai < length($aidx)) {
            my str $ac = substr($aidx, $ai, 1);
            if (!(($ac ge "0" && $ac le "9") || ($ai == 0 && $ac eq "-"))) { $is_num = 0; last; }
            $ai++;
        }
        # Detect "simple scalar var" index: `$` followed by a bareword,
        # optionally a `::` package qualifier. Anything else (binop,
        # function call, fancy form) goes through the inline-parse path.
        my int $is_simple_var = 0;
        if ($is_num == 0 && length($aidx) > 1 && substr($aidx, 0, 1) eq "$") {
            $is_simple_var = 1;
            my int $sci = 1;
            while ($sci < length($aidx)) {
                my str $scc = substr($aidx, $sci, 1);
                if (($scc ge "a" && $scc le "z") || ($scc ge "A" && $scc le "Z")
                    || ($scc ge "0" && $scc le "9") || $scc eq "_") {
                    $sci++;
                } else { $is_simple_var = 0; last; }
            }
        }
        # `$_[N]` in Perl source is scalar indexing of @_ (the args array).
        # Generate perla_at_ instead of v__ so the interpolation reads the
        # actual arg, not a dereferenced $_ scalar.
        my str $cname = Perla::CodeGen::c_var_a($avar);
        if ($avar eq "_") { $cname = "perla_at_"; }
        # `$Pkg::arr[N]` — pkg-qualified scalar var indexed as @Pkg::arr.
        # Route to perla_array_get(pkg, name) since there's no
        # file-scope v_FOO__c_arr for an external pkg's array.
        if (index($avar, "::") > 0) {
            my int $__ai_q = 0;
            my int $__ai_last = -1;
            while ($__ai_q < length($avar) - 1) {
                if (substr($avar, $__ai_q, 2) eq "::") { $__ai_last = $__ai_q; }
                $__ai_q = $__ai_q + 1;
            }
            my str $__ai_pkg = substr($avar, 0, $__ai_last);
