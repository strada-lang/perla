            # in the array. A later push then sees corruption like
            # 'a logging c' → 'a features c'.
            if ($step_kind eq "h") {
                # Variable-key form: ${$var}, $var, etc. — emit a dynamic
                # lookup. Otherwise treat as a literal key string.
                if (length($step_key) > 0 && substr($step_key, 0, 1) eq "$") {
                    my str $kvar_name = substr($step_key, 1, length($step_key) - 1);
                    my str $kvar_c = ($kvar_name eq "_") ? "perla_dollar_underscore" : Perla::CodeGen::c_var($kvar_name);
                    Perla::CodeGen::emit($cg, "{ char *__hk = strada_to_str(" . $kvar_c . "); StradaValue *__nt = strada_hv_fetch_owned(__t, __hk); free(__hk); if (__t_owned && __t) strada_decref(__t); __t = __nt; __t_owned = 1; } ");
                } else {
                    Perla::CodeGen::emit($cg, "{ StradaValue *__nt = strada_hv_fetch_owned(__t, \"" . $step_key . "\"); if (__t_owned && __t) strada_decref(__t); __t = __nt; __t_owned = 1; } ");
                }
            } else {
                # array idx
                my int $is_num_s = 1;
                if (length($step_key) == 0) { $is_num_s = 0; }
                my int $asj = 0;
                while ($asj < length($step_key)) {
                    my str $acs = substr($step_key, $asj, 1);
                    if (!(($acs ge "0" && $acs le "9") || ($asj == 0 && $acs eq "-"))) { $is_num_s = 0; last; }
                    $asj++;
                }
                if ($is_num_s == 1) {
                    Perla::CodeGen::emit($cg, "{ StradaValue *__nt = strada_array_get(strada_deref_array(__t), " . $step_key . "); if (__nt) strada_incref(__nt); if (__t_owned && __t) strada_decref(__t); __t = __nt; __t_owned = 1; } ");
                } elsif (length($step_key) > 0 && substr($step_key, 0, 1) eq "$") {
                    # Variable index: `[$x]` in a chain. Without this the
                    # fallback used index 0, so `"$ref->[a][\$b][\$c]"`
                    # read $ref->[a][0][0] for every $b/$c value.
                    my str $sxk_name = substr($step_key, 1, length($step_key) - 1);
                    my str $sxk_c = ($sxk_name eq "_") ? "perla_dollar_underscore" : Perla::CodeGen::c_var($sxk_name);
                    Perla::CodeGen::emit($cg, "{ StradaArray *__nta = strada_deref_array(__t); int __nti = (int)strada_to_int(" . $sxk_c . "); if (__nti < 0 && __nta) __nti += strada_array_length(__nta); StradaValue *__nt = strada_array_get(__nta, __nti); if (__nt) strada_incref(__nt); if (__t_owned && __t) strada_decref(__t); __t = __nt; __t_owned = 1; } ");
                } else {
                    Perla::CodeGen::emit($cg, "{ StradaValue *__nt = strada_array_get(strada_deref_array(__t), 0); if (__nt) strada_incref(__nt); if (__t_owned && __t) strada_decref(__t); __t = __nt; __t_owned = 1; } ");
                }
            }
            $sj++;
        }
        # If seed was borrowed and never went through a chain step,
        # incref so caller's decref balances.
        Perla::CodeGen::emit($cg, "if (!__t_owned && __t) strada_incref(__t); __t; })");
    } elsif (substr($p, 0, 2) eq "X:") {
        # `${\EXPR}` and `@{[EXPR]}` — inline-compile the expression so
        # it has natural access to lexicals (the old runtime-eval path
        # couldn't see `my` vars and returned undef/0 for them, breaking
        # Sub::Quote-shaped templates that interpolate `${\$x}` etc.).
        #
        # Stored body is `\EXPR` (from `${\EXPR}`) or `[EXPR]` (from
        # `@{[EXPR]}`). Strip the wrapper, parse the inner expression
        # with Perla's own lexer+parser, then emit it inline via
        # `_gen_expr`. Array-typed results get joined with $" so the
        # interp embedding produces "a b c" rather than the array count.
        my str $xexpr = substr($p, 2, length($p) - 2);
        # Trim leading and trailing whitespace so `${ \$x }` strips to
        # the same form as `${\$x}` and the backslash detection below works.
        my int $xs = 0;
        my int $xe = length($xexpr);
        while ($xs < $xe) {
            my str $xc = substr($xexpr, $xs, 1);
            if ($xc eq " " || $xc eq "\t" || $xc eq "\n") { $xs = $xs + 1; }
            else { last; }
        }
        while ($xe > $xs) {
            my str $xc = substr($xexpr, $xe - 1, 1);
            if ($xc eq " " || $xc eq "\t" || $xc eq "\n") { $xe = $xe - 1; }
            else { last; }
        }
        $xexpr = substr($xexpr, $xs, $xe - $xs);
        my int $xlen = length($xexpr);
        my str $inner = "";
        my int $is_array_form = 0;
        if ($xlen >= 1 && substr($xexpr, 0, 1) eq "\\") {
            # ${\EXPR}: strip one leading backslash. If wrapped in parens,
            # let the parser handle them (they group; no need to strip).
            $inner = substr($xexpr, 1, $xlen - 1);
        } elsif ($xlen >= 2 && substr($xexpr, 0, 1) eq "[" && substr($xexpr, $xlen - 1, 1) eq "]") {
            # @{[EXPR]}: strip wrapping `[...]`.
            $inner = substr($xexpr, 1, $xlen - 2);
            $is_array_form = 1;
        } else {
            $inner = $xexpr;
        }
        # Try to lex+parse the inner expression. Wrap in `(EXPR);` so the
        # parser produces a single statement we can extract.
        my array @__xs_toks = Perla::Lexer::lex($inner . ";");
        my scalar $__xs_ast = Perla::Parser::parse(@__xs_toks);
        my scalar $__xs_expr_node = undef;
        if (defined($__xs_ast) && defined($__xs_ast->{"stmts"})) {
            my scalar $__xs_stmts = $__xs_ast->{"stmts"};
            if (scalar(@{$__xs_stmts}) >= 1) {
                $__xs_expr_node = $__xs_stmts->[0];
            }
        }
        if (defined($__xs_expr_node)) {
            # `@{[EXPR]}` is Perl's list-context interpolation idiom:
            # bare `[EXPR]` is an anon-arrayref and `@{...}` derefs it,
            # so EXPR must be evaluated in LIST context. Without saving
            # /setting __perla_want_list=1 the inner inherits the
            # surrounding scalar interp context, so `map BLOCK @arr`
            # returned the count, and `'a','b','c'` collapsed to 'c'.
            # `${\EXPR}` (scalar form) is a single scalar expression
            # so its context is fine inherited.
            if ($is_array_form == 1) {
                Perla::CodeGen::emit($cg, "({ int __xs_sav_wl = __perla_want_list; __perla_want_list = 1; StradaValue *__xs_r = ");
            } else {
                Perla::CodeGen::emit($cg, "({ StradaValue *__xs_r = ");
            }
            Perla::CodeGen::gen_expr($cg, $__xs_expr_node);
            if ($is_array_form == 1) {
                Perla::CodeGen::emit($cg, "; __perla_want_list = __xs_sav_wl; if (!__xs_r) __xs_r = strada_new_str(\"\"); ");
            } else {
                Perla::CodeGen::emit($cg, "; if (!__xs_r) __xs_r = strada_new_str(\"\"); ");
            }
            # If result is an array-ref/array, join with $" (perl interp default).
            Perla::CodeGen::emit($cg, "if (__xs_r && !STRADA_IS_TAGGED_INT(__xs_r) && (__xs_r->type == STRADA_ARRAY || (__xs_r->type == STRADA_REF && __xs_r->value.rv && __xs_r->value.rv->type == STRADA_ARRAY))) { ");
            Perla::CodeGen::emit($cg, "  const char *__lse = (perla_lse && !STRADA_IS_TAGGED_INT(perla_lse) && perla_lse->type == STRADA_STR && perla_lse->value.pv) ? perla_lse->value.pv : \" \"; ");
            Perla::CodeGen::emit($cg, "  StradaValue *__xs_arr = __xs_r; if (__xs_r->type == STRADA_REF) __xs_arr = __xs_r->value.rv; ");
            Perla::CodeGen::emit($cg, "  char *__js = strada_join(__lse, strada_deref_array(__xs_arr)); ");
            # The inner expression's array is decref'd only when we OWN it
            # (e.g. `map`/`grep`/a list literal produce a fresh array). When
            # the inner is a borrowed aggregate — a bare `@arr`, `@$ref`, `%h`
            # — gen_expr hands back the variable's own backbone WITHOUT an
            # incref, so decref'ing it here drops its last ref and frees it,
            # emptying the source. `@{[ @arr ]}` printed correctly but left
            # @arr (and @$ref / %h) empty afterward.
            if (Perla::CodeGen::expr_is_borrowed($__xs_expr_node) == 1) {
                Perla::CodeGen::emit($cg, "  __xs_r = strada_new_str(__js); free(__js); ");
            } else {
                Perla::CodeGen::emit($cg, "  strada_decref(__xs_r); __xs_r = strada_new_str(__js); free(__js); ");
            }
            Perla::CodeGen::emit($cg, "} __xs_r; })");
        } else {
            # Parser failed — fall back to runtime eval (with lexicals if
            # we have any). Mirrors the original code path so qsub etc.
            # still see a runtime eval if the inline parse can't make
            # sense of the source.
            my str $xescaped = Perla::CodeGen::Escape::escape_c_str($xexpr);
            Perla::CodeGen::emit($cg, "({ StradaValue *__xs_src = strada_new_str(\"" . $xescaped . "\"); ");
            Perla::CodeGen::emit($cg, "StradaValue *__xs_r = perla_eval_string_with_args(__xs_src, \"" . $cg->{"pkg"} . "\", perla_at_); strada_decref(__xs_src); ");
            Perla::CodeGen::emit($cg, "if (!__xs_r) __xs_r = strada_new_str(\"\"); ");
            Perla::CodeGen::emit($cg, "if (__xs_r && !STRADA_IS_TAGGED_INT(__xs_r) && (__xs_r->type == STRADA_ARRAY || (__xs_r->type == STRADA_REF && __xs_r->value.rv && __xs_r->value.rv->type == STRADA_ARRAY))) { ");
            Perla::CodeGen::emit($cg, "  const char *__lse = (perla_lse && !STRADA_IS_TAGGED_INT(perla_lse) && perla_lse->type == STRADA_STR && perla_lse->value.pv) ? perla_lse->value.pv : \" \"; ");
            Perla::CodeGen::emit($cg, "  char *__js = strada_join(__lse, strada_deref_array(__xs_r)); ");
            Perla::CodeGen::emit($cg, "  strada_decref(__xs_r); __xs_r = strada_new_str(__js); free(__js); ");
            Perla::CodeGen::emit($cg, "} __xs_r; })");
        }
    } else {
        my str $vn = substr($p, 2, length($p) - 2);
        if ($vn eq "AUTOLOAD") { Perla::CodeGen::emit($cg, "perla_get_autoload_var()"); }
        elsif ($vn eq "@") { Perla::CodeGen::emit($cg, "perla_eval_error"); }
        elsif ($vn eq "!") { Perla::CodeGen::emit($cg, "strada_new_str(errno ? strerror(errno) : \"\")"); }
        elsif ($vn eq "0") { Perla::CodeGen::emit($cg, "(perla_dollar_zero ? ({ strada_incref(perla_dollar_zero); perla_dollar_zero; }) : strada_new_str(\"perla\"))"); }
        # \$ARGV — current filename during bare-diamond reads (set by
        # perla_readline_argv). Match N_SCALAR_VAR rule: read
        # perla_current_argv, fall back to undef when no diamond fired.
        elsif ($vn eq "ARGV") { Perla::CodeGen::emit($cg, "(perla_current_argv ? ({ strada_incref(perla_current_argv); perla_current_argv; }) : strada_new_undef())"); }
        elsif ($vn eq "?") { Perla::CodeGen::emit($cg, "STRADA_MAKE_TAGGED_INT((int64_t)perla_dollar_question)"); }
        elsif ($vn eq ".") { Perla::CodeGen::emit($cg, "STRADA_MAKE_TAGGED_INT((int64_t)perla_dollar_dot)"); }
        elsif ($vn eq "\$") { Perla::CodeGen::emit($cg, "STRADA_MAKE_TAGGED_INT((int64_t)getpid())"); }
        # `$_` interpolation must read perla_dollar_underscore (the
        # symbol used by loops, sort, grep, map, and the bare-scalar
        # codegen path). Perla::CodeGen::c_var("_") would emit v__ — a file-scope
        # global that loops *don't* update, so `"$_"` inside `map { … }`
        # silently substituted nothing in earlier rounds and broke
        # things like Class::C3::Componentised's
        # `map { "${class}::$_" } @comps` accessor expansion.
        elsif ($vn eq "_") { Perla::CodeGen::emit($cg, "perla_dollar_underscore"); }
        elsif ($vn eq "&") { Perla::CodeGen::emit($cg, "strada_capture_var(0)"); }
        elsif ($vn eq "`") { Perla::CodeGen::emit($cg, "strada_prematch()"); }
        elsif ($vn eq "'") { Perla::CodeGen::emit($cg, "strada_postmatch()"); }
        elsif ($vn eq "+") { Perla::CodeGen::emit($cg, "strada_last_paren_match()"); }
        elsif (length($vn) == 2 && substr($vn, 0, 1) eq "^") {
            # Caret-special-var: ^O, ^W, etc. Map to v__caret_X global.
            # $^A is the format accumulator — owned by perla_stash.c, so
            # route it to its public global rather than the file-static
            # v__caret_A which would be undefined.
            my str $caret_ch = substr($vn, 1, 1);
            if ($caret_ch eq "A") {
                Perla::CodeGen::emit($cg, "(perla_dollar_caret_A ? perla_dollar_caret_A : strada_new_str(\"\"))");
            } else {
                Perla::CodeGen::emit($cg, "v__caret_" . $caret_ch);
            }
        }
        elsif (length($vn) == 1 && ($vn eq "/" || $vn eq "\\" || $vn eq "," || $vn eq ";" || $vn eq "\"" || $vn eq "|" || $vn eq "+" || $vn eq "~" || $vn eq "=" || $vn eq "%" || $vn eq "-")) {
            # Read from the global directly so localized values (e.g.
            # `local $\ = "X"`) are seen. Without this, perla_special_get
            # looked up the stash which doesn't track local-scope changes
            # to the I/O specials, so `"$\\"` after `local $\ = "X"`
            # returned empty. Also fixes the C-escape bug for `$\`
            # which previously emitted `perla_special_get("\")` (an
            # unterminated string literal).
            if ($vn eq "\\") { Perla::CodeGen::emit($cg, "perla_ors"); }
            elsif ($vn eq "/") { Perla::CodeGen::emit($cg, "perla_irs"); }
            elsif ($vn eq ",") { Perla::CodeGen::emit($cg, "perla_ofs"); }
            elsif ($vn eq "\"") { Perla::CodeGen::emit($cg, "perla_lse"); }
            elsif ($vn eq "~") { Perla::CodeGen::emit($cg, "(perla_dollar_tilde ? perla_dollar_tilde : strada_new_str(\"\"))"); }
            elsif ($vn eq "=") { Perla::CodeGen::emit($cg, "(perla_dollar_equals ? perla_dollar_equals : STRADA_MAKE_TAGGED_INT(60))"); }
            elsif ($vn eq "%") { Perla::CodeGen::emit($cg, "(perla_dollar_percent ? perla_dollar_percent : STRADA_MAKE_TAGGED_INT(0))"); }
            elsif ($vn eq "-") { Perla::CodeGen::emit($cg, "(perla_dollar_minus ? perla_dollar_minus : STRADA_MAKE_TAGGED_INT(0))"); }
            elsif ($vn eq "|") {
                # $| in interp: __perla_autoflush is a C int, not a stash
                # entry. Without this special-case, perla_special_get("|")
                # returned NULL and "$|" interpolated to empty.
                Perla::CodeGen::emit($cg, "STRADA_MAKE_TAGGED_INT((int64_t)(__perla_autoflush ? 1 : 0))");
            }
            else {
                # ; + still go via perla_special_get (no localized global).
                my str $esc_vn = $vn;
                if ($esc_vn eq "\"") { $esc_vn = "\\\""; }
                Perla::CodeGen::emit($cg, "perla_special_get(\"" . $esc_vn . "\")");
            }
        }
        elsif ($vn eq "<" || $vn eq ">" || $vn eq "(" || $vn eq ")") {
            # $< / $> / $( / $) — UID/GID specials. perla_special_get
            # looks them up in main:: stash which is unpopulated, so
            # interpolation returned empty. Emit direct C calls.
            if ($vn eq "<") {
                Perla::CodeGen::emit($cg, "STRADA_MAKE_TAGGED_INT((int64_t)getuid())");
            } elsif ($vn eq ">") {
                Perla::CodeGen::emit($cg, "STRADA_MAKE_TAGGED_INT((int64_t)geteuid())");
            } elsif ($vn eq "(") {
                Perla::CodeGen::emit($cg, "STRADA_MAKE_TAGGED_INT((int64_t)getgid())");
            } else {
                Perla::CodeGen::emit($cg, "STRADA_MAKE_TAGGED_INT((int64_t)getegid())");
            }
        }
        elsif (index($vn, "::") > 0) {
            # Package-qualified scalar `$Pkg::Name` reads must go through
            # perla_scalar_get to see runtime stash updates (cross-package
            # `our $x` writes, perla_scalar_set, etc.). Without this, the
            # fallback `Perla::CodeGen::c_var(...)` emitted a sanitized identifier (`v_Pkg__Name`)
            # that referenced a different file-static, so interpolation
            # silently returned empty.
            my int $li = -1;
            my int $si = 0;
            while ($si < length($vn) - 1) {
                if (substr($vn, $si, 2) eq "::") { $li = $si; }
                $si++;
            }
            my str $vpkg = substr($vn, 0, $li);
            my str $vname = substr($vn, $li + 2, length($vn) - $li - 2);
            Perla::CodeGen::emit($cg, "perla_scalar_get(\"" . $vpkg . "\", \"" . $vname . "\")");
        }
        else {
            Perla::CodeGen::_strict_check_var($cg, "\$", $vn, 0);
            # Capture into a local so the owned return from cross-module c_var()
            # is released by scope-exit cleanup. Passing it directly to emit()
            # would skip the predicate-driven cleanup wrapper because
            # Perla::CodeGen::c_var is unknown to Interp's needs_temp_cleanup
            # (cycle prevents `use` -- see the __C__ extern header above).
            my str $__cv_v = Perla::CodeGen::c_var($vn);
            Perla::CodeGen::emit($cg, $__cv_v);
        }
    }
}

# --- String interpolation ---
# Strip matching single- or double-quotes around a hash key inside
# an interpolation: `$h{'a'}` → key "a", `$h{"a"}` → key "a",
# `$h{a}` → key "a". Perl permits quoted keys inside interpolation;
# without stripping, Perla was using the literal key "'a'" (with the
# quotes), so lookups against bareword-keyed hashes missed.
## Find the separator `:` between VARNAME and KEY in encoded interp
## parts like `H:VARNAME:KEY` / `D:VARNAME:KEY`. The VARNAME may itself
## contain `::` for package qualifiers ($Foo::h{a} encodes as
## "H:Foo::h:a"), so a plain index(":") splits at the wrong spot.
## Scan past consecutive `::` until we hit a standalone `:`, which is
## the actual separator.
func find_interp_h_sep(str $s) int {
    my int $i = 0;
    my int $n = length($s);
    while ($i < $n) {
        my str $c = substr($s, $i, 1);
        if ($c eq ":") {
            if ($i + 1 < $n && substr($s, $i + 1, 1) eq ":") {
                $i = $i + 2;
            } else {
                return $i;
            }
        } else {
            $i = $i + 1;
        }
    }
    return -1;
}

func strip_quoted_key(str $k) str {
    my int $klen = length($k);
    if ($klen >= 2) {
        my str $first = substr($k, 0, 1);
        my str $last = substr($k, $klen - 1, 1);
        if (($first eq "'" && $last eq "'") || ($first eq "\"" && $last eq "\"")) {
            return substr($k, 1, $klen - 2);
        }
    }
    return $k;
}

# Process Perl double-quote escapes in a hash-key string. Used for
# interp `"$h{\"a\nb\"}"` where the inner `\n` should become a real
# newline (perl DQ semantics) before being passed to escape_c_str.
# Handles the common escapes: \n \t \r \\ \" \' \0 \a \b \f \e
# and \xHH / \x{HHHH}. Unknown escapes drop the backslash (Perl rule).
func process_perl_dq_escapes(str $s) str {
    my str $out = "";
    my int $i = 0;
    my int $len = length($s);
    while ($i < $len) {
        my str $ch = substr($s, $i, 1);
        if ($ch eq "\\" && $i + 1 < $len) {
            my str $next = substr($s, $i + 1, 1);
            if ($next eq "n") { $out = $out . "\n"; $i = $i + 2; next; }
            if ($next eq "t") { $out = $out . "\t"; $i = $i + 2; next; }
            if ($next eq "r") { $out = $out . "\r"; $i = $i + 2; next; }
            if ($next eq "\\") { $out = $out . "\\"; $i = $i + 2; next; }
            if ($next eq "\"") { $out = $out . "\""; $i = $i + 2; next; }
            if ($next eq "'") { $out = $out . "'"; $i = $i + 2; next; }
            if ($next eq "0") { $out = $out . chr(0); $i = $i + 2; next; }
            if ($next eq "a") { $out = $out . chr(7); $i = $i + 2; next; }
            if ($next eq "b") { $out = $out . chr(8); $i = $i + 2; next; }
            if ($next eq "f") { $out = $out . chr(12); $i = $i + 2; next; }
            if ($next eq "e") { $out = $out . chr(27); $i = $i + 2; next; }
            # Unknown escape — drop the backslash, keep the char.
            $out = $out . $next;
            $i = $i + 2;
            next;
        }
        $out = $out . $ch;
        $i = $i + 1;
    }
    return $out;
}

# Scan from $start to find the matching close bracket. Caller has
# already consumed the opening bracket; $start points to the first char
# inside. Honors nested [ and ] (or { and }) — increments depth on
# every open bracket encountered, decrements on close, stops when depth
# drops to -1 (the matching close). Without this, `"$a[$b[0]]"` stopped
# at the inner `]` and left a literal `]` in the output, then the
# subscript lex-parse choked on the unbalanced `$b[0`.
func scan_balanced(str $raw, int $start, str $open, str $close) int {
    my int $rlen = length($raw);
    my int $k = $start;
    my int $depth = 0;
    while ($k < $rlen) {
        my str $c = substr($raw, $k, 1);
        if ($c eq $close) {
            if ($depth == 0) { return $k; }
            $depth--;
        } elsif ($c eq $open) {
            $depth++;
        }
        $k++;
    }
    return $rlen;
}

# Consume a trailing interpolation subscript chain starting at $pos: zero or
# more of `(->)? [ BALANCED ]` or `(->)? { BALANCED }`. Returns a 2-element
# array [chain_text, new_pos]. chain_text normalizes every element to an
# explicit `->` (e.g. "->[0]->{b}->[1]") so the runtime-eval (X:) path parses
# it as an ordinary deref chain. Empty string + unchanged pos if none follow.
# Perl interpolates a full subscript chain after a `${...}[i]` / `$$ref[i]`
# leading element; perla previously stopped after the first subscript, leaving
# the rest as literal text (`"${$c->{a}}[0]->{b}->[1]"` printed the hashref
# then `->{b}->[1]` verbatim). A trailing `->` not followed by a subscript
# (e.g. `->method`) is left unconsumed, matching Perl (no method calls in
# interpolation).
func interp_scan_chain(str $raw, int $pos, int $len) array {
    my str $chain = "";
    my int $i = $pos;
    while ($i < $len) {
        my int $j = $i;
        if ($j + 1 < $len && substr($raw, $j, 2) eq "->") { $j = $j + 2; }
        if ($j >= $len) { last; }
        my str $cc = substr($raw, $j, 1);
        if ($cc ne "[" && $cc ne "{") { last; }
        my str $clc = "]";
        if ($cc eq "{") { $clc = "}"; }
        my int $cs = $j + 1;
        my int $ce = scan_balanced($raw, $cs, $cc, $clc);
        if ($ce >= $len) { last; }
        $chain = $chain . "->" . $cc . substr($raw, $cs, $ce - $cs) . $clc;
        $i = $ce + 1;
    }
    my array @res = ($chain, $i);
    return @res;
}

# Filter out _CU/_CL/_C1U/_C1L/_CE case markers from parts, build a
# parallel wrap-state array, and emit each remaining part wrapped with
# strada_uc/strada_lc as the markers indicate. Used by gen_interp_str
# when `\U`/`\L`/`\u`/`\l`/`\E` were seen.
func emit_parts_with_case_wrap(scalar $cg, scalar $parts_ref) void {
    my array @clean = ();
    my array @wrap = ();
    my str $sticky = "";
    my str $oneshot = "";
    my int $i = 0;
    my array @parts_local = @$parts_ref;
    my int $n = scalar(@parts_local);
    while ($i < $n) {
        my str $p = $parts_local[$i];
        if (substr($p, 0, 3) eq "_CU") { $sticky = "U"; $i = $i + 1; next; }
        if (substr($p, 0, 3) eq "_CL") { $sticky = "L"; $i = $i + 1; next; }
        if (substr($p, 0, 3) eq "_CE") { $sticky = ""; $oneshot = ""; $i = $i + 1; next; }
        if (substr($p, 0, 4) eq "_C1U") { $oneshot = "U"; $i = $i + 1; next; }
        if (substr($p, 0, 4) eq "_C1L") { $oneshot = "L"; $i = $i + 1; next; }
        my str $eff = "";
        if (length($oneshot) > 0) {
            # One-shot from \u / \l — ucfirst / lcfirst only.
            $eff = "1" . $oneshot;
        } elsif (length($sticky) > 0) {
            $eff = $sticky;
        }
        # Literal S: parts already had case applied at scan time.
        if (substr($p, 0, 2) eq "S:") { $eff = ""; }
        push(@clean, $p);
        push(@wrap, $eff);
        if (length($oneshot) > 0) { $oneshot = ""; }
        $i = $i + 1;
    }
    my int $cn = scalar(@clean);
    if ($cn == 0) {
        Perla::CodeGen::emit($cg, "strada_new_str(\"\")");
        return;
    }
    # Emit as a multi-part concat chain; wrap each part per @wrap.
    Perla::CodeGen::emit($cg, "({ StradaValue *__cwip = ");
    emit_one_wrapped($cg, $clean[0], $wrap[0]);
    Perla::CodeGen::emit($cg, "; ");
    my int $pi = 1;
    while ($pi < $cn) {
        Perla::CodeGen::emit($cg, "__cwip = strada_concat_sv(__cwip, ");
        emit_one_wrapped($cg, $clean[$pi], $wrap[$pi]);
        Perla::CodeGen::emit($cg, "); ");
        $pi = $pi + 1;
    }
    Perla::CodeGen::emit($cg, "__cwip; })");
}

func emit_one_wrapped(scalar $cg, str $part, str $wrap_mode) void {
    if (length($wrap_mode) == 0) {
        emit_interp_part($cg, $part);
        return;
    }
    # \u / \l one-shot — ucfirst/lcfirst only.
    # Sticky U/L — fold all letters.
    my str $fn;
    if ($wrap_mode eq "U") { $fn = "strada_uc"; }
    elsif ($wrap_mode eq "L") { $fn = "strada_lc"; }
    elsif ($wrap_mode eq "1U") { $fn = "strada_ucfirst"; }
    elsif ($wrap_mode eq "1L") { $fn = "strada_lcfirst"; }
    else { $fn = "strada_uc"; }
    # V:/R:/A: are borrowed references (variable reads, array elems,
    # ref-deref array elems). Decrefing them would underflow the
    # backing variable's refcount and corrupt later reads. All other
    # part shapes (H:, Z:, S:, N:, etc.) return owned refs.
    my str $p2 = substr($part, 0, 2);
    my int $is_borrowed = ($p2 eq "V:" || $p2 eq "R:" || $p2 eq "A:") ? 1 : 0;
    Perla::CodeGen::emit($cg, "({ StradaValue *__cwv = ");
    emit_interp_part($cg, $part);
    if ($is_borrowed == 1) {
        Perla::CodeGen::emit($cg, "; char *__cws = strada_to_str(__cwv); char *__cwr = " . $fn . "(__cws); free(__cws); strada_new_str_take(__cwr); })");
    } else {
        Perla::CodeGen::emit($cg, "; char *__cws = strada_to_str(__cwv); strada_decref(__cwv); char *__cwr = " . $fn . "(__cws); free(__cws); strada_new_str_take(__cwr); })");
    }
}

func gen_interp_str(scalar $cg, str $raw) void {
    # The raw string may contain escape sequences and $var references
    # For now, handle common escapes and $var interpolation
    my int $len = length($raw);
    my int $i = 0;
    my array @parts = ();
    my str $buf = "";
    # Track whether any `\x{HEX}` / `\N{U+HEX}` / `\xHH` (>= 0x80) escape
    # expanded to multi-byte UTF-8 bytes. perl's behavior: a DQ string
    # containing a high-codepoint escape produces a SV with SVf_UTF8 set
    # regardless of `use utf8`. Without this flag, Encode::encode("cp1252",
    # "\x{201C}") treats the 3 UTF-8 bytes as Latin-1 codepoints and
    # produces garbage. Tracked here, applied at the final emit below.
    my int $has_high_escape = 0;
    # Inside a `\Q...\E` quote-meta region, literal non-alnum chars
    # get backslash-escaped (`*` → `\*`, ` ` → `\ `, etc.) and any
    # variable interpolation is wrapped at runtime with
    # `strada_quotemeta()`. URI's `$unreserved = "A-Za-z0-9\Q$mark\E"`
    # depends on this — without it, `\Q` and `\E` got emitted as
    # literal Q/E, the URI regex pattern was wrong, every URL char
    # got escaped, and URI->new corrupted every URL.
    my int $qm = 0;
    # \U / \L / \u / \l / \E case-modification regions. case_mode is
    # "" (none), "U" (upper), or "L" (lower). \u and \l are one-shot
    # (apply to next char only) — case_pending = 1 for those.
    # Without this, `"\Uhello \E"` came out as the literal "Uhello "
    # (backslash dropped per the unknown-escape fallback).
    my str $case_mode = "";
    my str $case_pending = "";

    while ($i < $len) {
        my str $ch = substr($raw, $i, 1);

        # Backslash escapes
        if ($ch eq "\\" && $i + 1 < $len) {
            my str $next = substr($raw, $i + 1, 1);
            # \Q / \E — quotemeta region delimiters.
            if ($next eq "Q") { $qm = 1; $i = $i + 2; next; }
            if ($next eq "E") {
                $qm = 0;
                if (length($case_mode) > 0) {
                    if (length($buf) > 0) { push(@parts, "S:" . $buf); $buf = ""; }
                    push(@parts, "_CE:");
                }
                $case_mode = "";
                $i = $i + 2; next;
            }
            # \U / \L — case-modification regions, terminated by \E.
            # \u / \l — one-shot uppercase/lowercase next char only.
            # Push marker parts so the emit code can wrap subsequent
            # variable parts with strada_uc/strada_lc.
            if ($next eq "U") {
                if (length($buf) > 0) { push(@parts, "S:" . $buf); $buf = ""; }
                push(@parts, "_CU:");
                $case_mode = "U"; $i = $i + 2; next;
            }
            if ($next eq "L") {
                if (length($buf) > 0) { push(@parts, "S:" . $buf); $buf = ""; }
                push(@parts, "_CL:");
                $case_mode = "L"; $i = $i + 2; next;
            }
            if ($next eq "u") {
                if (length($buf) > 0) { push(@parts, "S:" . $buf); $buf = ""; }
                push(@parts, "_C1U:");
                $case_pending = "U"; $i = $i + 2; next;
            }
            if ($next eq "l") {
                if (length($buf) > 0) { push(@parts, "S:" . $buf); $buf = ""; }
                push(@parts, "_C1L:");
                $case_pending = "L"; $i = $i + 2; next;
            }
            if ($next eq "n") { $buf = $buf . "\\n"; $i = $i + 2; next; }
            if ($next eq "t") { $buf = $buf . "\\t"; $i = $i + 2; next; }
            if ($next eq "r") { $buf = $buf . "\\r"; $i = $i + 2; next; }
            if ($next eq "\\") { $buf = $buf . "\\\\"; $i = $i + 2; next; }
            if ($next eq "\"") { $buf = $buf . "\\\""; $i = $i + 2; next; }
            if ($next eq "'") { $buf = $buf . "'"; $i = $i + 2; next; }
            if ($next eq "$") { $buf = $buf . "$"; $i = $i + 2; next; }
            if ($next eq "@") { $buf = $buf . "@"; $i = $i + 2; next; }
            # `\NNN` — octal byte escape (1-3 octal digits). Without
            # this branch, `"\101"` came out as the literal `101` text.
            # Emit as 3-digit C octal `\NNN` (well-defined boundary,
            # unlike `\xNN` which keeps consuming hex digits and can
            # absorb a trailing digit into the byte value).
            if ($next ge "0" && $next le "7") {
                my int $od_count = 1;
                my int $od_val = char_at($next, 0) - 48;
                while ($od_count < 3 && $i + 1 + $od_count < $len) {
                    my str $oc = substr($raw, $i + 1 + $od_count, 1);
                    if ($oc ge "0" && $oc le "7") {
                        $od_val = $od_val * 8 + (char_at($oc, 0) - 48);
                        $od_count = $od_count + 1;
                    } else { last; }
                }
                # Build 3-digit octal so the C compiler can't absorb the
                # next char into the escape.
                my str $d1 = "" . (($od_val / 64) % 8);
                my str $d2 = "" . (($od_val / 8) % 8);
                my str $d3 = "" . ($od_val % 8);
                $buf = $buf . "\\" . $d1 . $d2 . $d3;
                $i = $i + 1 + $od_count;
                next;
            }
            if ($next eq "a") { $buf = $buf . "\\a"; $i = $i + 2; next; }
            if ($next eq "b") { $buf = $buf . "\\b"; $i = $i + 2; next; }
            if ($next eq "e") { $buf = $buf . "\\033"; $i = $i + 2; next; }
            if ($next eq "f") { $buf = $buf . "\\f"; $i = $i + 2; next; }
            if ($next eq "v") { $buf = $buf . "\\v"; $i = $i + 2; next; }
            # \cX — control character (e.g. \cA = 0x01, \cZ = 0x1A). Perl
            # convention: lowercase the letter, then XOR with 0x40 to get
            # the control char. Emit as 3-digit C octal so adjacent chars
            # don't confuse the C compiler.
            if ($next eq "c" && $i + 2 < $len) {
                my str $cc = substr($raw, $i + 2, 1);
                my int $code = char_at($cc, 0);
                # uppercase letter → 0x40 XOR; lowercase → uppercase first.
                if ($code >= 97 && $code <= 122) { $code = $code - 32; }
                $code = $code ^ 64;
                my str $d1 = "" . (($code / 64) % 8);
                my str $d2 = "" . (($code / 8) % 8);
                my str $d3 = "" . ($code % 8);
                $buf = $buf . "\\" . $d1 . $d2 . $d3;
                $i = $i + 3;
                next;
            }
            # \N{U+HEX} — Unicode named character escape, decode to UTF-8
            if ($next eq "N" && $i + 2 < $len && substr($raw, $i + 2, 1) eq "{") {
                my int $brace_end = $i + 3;
                $brace_end = scan_balanced($raw, $brace_end, "{", "}");
                if ($brace_end < $len) {
                    my str $inner = substr($raw, $i + 3, $brace_end - ($i + 3));
                    # Expect "U+HEX"
                    if (length($inner) > 2 && substr($inner, 0, 2) eq "U+") {
                        my str $hex = substr($inner, 2, length($inner) - 2);
                        my int $cp = Perla::CodeGen::Escape::parse_hex($hex);
                        if ($cp >= 128) { $has_high_escape = 1; }
                        $buf = $buf . Perla::CodeGen::Escape::utf8_c_escape($cp);
                        $i = $brace_end + 1;
                        next;
                    }
                    # Otherwise, drop the escape (we don't support named chars by name)
                    $i = $brace_end + 1;
                    next;
                }
            }
            # \x{HEX} or \xHH — hex character escape
            if ($next eq "x") {
                if ($i + 2 < $len && substr($raw, $i + 2, 1) eq "{") {
                    my int $brace_end = $i + 3;
                    $brace_end = scan_balanced($raw, $brace_end, "{", "}");
                    if ($brace_end < $len) {
                        my str $hex = substr($raw, $i + 3, $brace_end - ($i + 3));
                        my int $cp = Perla::CodeGen::Escape::parse_hex($hex);
                        if ($cp >= 128) { $has_high_escape = 1; }
                        $buf = $buf . Perla::CodeGen::Escape::utf8_c_escape($cp);
                        $i = $brace_end + 1;
                        next;
                    }
                }
                # \xHH form — up to 2 hex digits. Perl semantics: in a
                # byte (non-utf8) string, `\xHH` is the single byte 0xHH,
                # not the UTF-8 encoding of codepoint U+00HH. DBIC's
                # RowParser uses `\xFF` as a placeholder delimiter and
                # later does `s/ \' \xFF__VALPOS__(\d+)__\xFF \' /…/gex`
                # — the regex pattern's `\xFF` is also a single byte, so
                # the substitution only matches if the source's `\xFF`
                # was emitted as a single byte too. Previously we routed
                # through `_utf8_c_escape` and `\xFF` became `\xC3\xBF`
                # (UTF-8 for U+00FF), so the regex never matched and the
                # parser source emerged with un-substituted placeholders.
                my int $hx = $i + 2;
                my int $hend = $hx;
                while ($hend < $len && $hend - $hx < 2 && Perla::CodeGen::Escape::is_hex_digit(substr($raw, $hend, 1))) { $hend++; }
                if ($hend > $hx) {
                    my str $hex = substr($raw, $hx, $hend - $hx);
                    my int $cp = Perla::CodeGen::Escape::parse_hex($hex);
                    if ($cp >= 0 && $cp < 256) {
                        # Single byte — emit as `\xHH""` C escape. The trailing
                        # "" breaks the greedy `\x` escape so a following hex
                        # digit doesn't get folded into the same escape.
                        # `\xHH` is intentionally a single-byte (not UTF-8)
                        # in perl when there's no `{...}` — see RowParser
                        # comment above — so DON'T set $has_high_escape here.
                        $buf = $buf . "\\x" . Perla::CodeGen::Escape::byte_hex($cp) . "\"\"";
                    } else {
                        $has_high_escape = 1;
                        $buf = $buf . Perla::CodeGen::Escape::utf8_c_escape($cp);
                    }
                    $i = $hend;
                    next;
                }
            }
            # Unknown escape: drop the backslash, keep the next char
            # (Perl silently allows many, gcc would error on them)
            $buf = $buf . $next;
            $i = $i + 2;
            next;
        }

        # Variable interpolation: $name, ${name}, $name{key}, $name->{key}
        if ($ch eq "$" && $i + 1 < $len) {
            my str $nc = substr($raw, $i + 1, 1);
            # `$#NAME` — last index of @NAME. Without this branch the
            # literal `$#arr` made it through to the output instead of
            # being replaced by the array's last index.
            if ($nc eq "#" && $i + 2 < $len) {
                my str $nc2 = substr($raw, $i + 2, 1);
                if (($nc2 ge "a" && $nc2 le "z") || ($nc2 ge "A" && $nc2 le "Z") || $nc2 eq "_") {
                    my int $vs_lh = $i + 2;
                    my int $ve_lh = $vs_lh;
                    while ($ve_lh < $len) {
                        my str $vc_lh = substr($raw, $ve_lh, 1);
                        if (($vc_lh ge "a" && $vc_lh le "z") || ($vc_lh ge "A" && $vc_lh le "Z") || ($vc_lh ge "0" && $vc_lh le "9") || $vc_lh eq "_") {
                            $ve_lh++;
                        } else { last; }
                    }
                    # Accept `::` segments for package-qualified array
                    # last-index in string interp: "$#Pkg::arr".
                    while ($ve_lh + 1 < $len && substr($raw, $ve_lh, 2) eq "::") {
                        $ve_lh = $ve_lh + 2;
                        while ($ve_lh < $len) {
                            my str $vc_lh2 = substr($raw, $ve_lh, 1);
                            if (($vc_lh2 ge "a" && $vc_lh2 le "z") || ($vc_lh2 ge "A" && $vc_lh2 le "Z") || ($vc_lh2 ge "0" && $vc_lh2 le "9") || $vc_lh2 eq "_") {
                                $ve_lh = $ve_lh + 1;
                            } else { last; }
                        }
                    }
                    if (length($buf) > 0) { push(@parts, "S:" . $buf); $buf = ""; }
                    push(@parts, "LH:" . substr($raw, $vs_lh, $ve_lh - $vs_lh));
                    $i = $ve_lh;
                    next;
                }
                # `$#$ref` — last index of dereferenced array. Without
                # this branch the interp parser would treat `$#` as
                # literal and then `$ref` as a scalar var, producing
                # "$#ARRAY(0x…)" garbage in the output.
                if ($nc2 eq "\$" && $i + 3 < $len) {
                    my str $nc3 = substr($raw, $i + 3, 1);
                    if (($nc3 ge "a" && $nc3 le "z") || ($nc3 ge "A" && $nc3 le "Z") || $nc3 eq "_") {
                        my int $vs_ld = $i + 3;
                        my int $ve_ld = $vs_ld;
                        while ($ve_ld < $len) {
                            my str $vc_ld = substr($raw, $ve_ld, 1);
                            if (($vc_ld ge "a" && $vc_ld le "z") || ($vc_ld ge "A" && $vc_ld le "Z") || ($vc_ld ge "0" && $vc_ld le "9") || $vc_ld eq "_") {
                                $ve_ld++;
                            } else { last; }
                        }
                        if (length($buf) > 0) { push(@parts, "S:" . $buf); $buf = ""; }
                        push(@parts, "LD:" . substr($raw, $vs_ld, $ve_ld - $vs_ld));
                        $i = $ve_ld;
                        next;
                    }
                }
                # `$#{$ref}` — braced form of last-index-of-deref. Common
                # in interpolations like "size: $#{$aref}". Same target
                # as `$#$ref`, just with explicit braces around the inner
                # expression.
                if ($nc2 eq "{" && $i + 3 < $len) {
                    # Skip leading whitespace inside braces.
                    my int $bi = $i + 3;
                    while ($bi < $len) {
                        my str $bc = substr($raw, $bi, 1);
                        if ($bc eq " " || $bc eq "\t") { $bi = $bi + 1; }
                        else { last; }
                    }
                    if ($bi < $len && substr($raw, $bi, 1) eq "\$") {
                        my int $vs_ld2 = $bi + 1;
                        my int $ve_ld2 = $vs_ld2;
                        while ($ve_ld2 < $len) {
                            my str $vc_ld2 = substr($raw, $ve_ld2, 1);
                            if (($vc_ld2 ge "a" && $vc_ld2 le "z") || ($vc_ld2 ge "A" && $vc_ld2 le "Z") || ($vc_ld2 ge "0" && $vc_ld2 le "9") || $vc_ld2 eq "_") {
                                $ve_ld2++;
                            } else { last; }
                        }
                        # Skip trailing whitespace then expect `}`.
                        my int $bj = $ve_ld2;
                        while ($bj < $len) {
                            my str $bc2 = substr($raw, $bj, 1);
                            if ($bc2 eq " " || $bc2 eq "\t") { $bj = $bj + 1; }
                            else { last; }
                        }
                        if ($bj < $len && substr($raw, $bj, 1) eq "}" && $ve_ld2 > $vs_ld2) {
                            if (length($buf) > 0) { push(@parts, "S:" . $buf); $buf = ""; }
                            push(@parts, "LD:" . substr($raw, $vs_ld2, $ve_ld2 - $vs_ld2));
                            $i = $bj + 1;
                            next;
                        }
                    }
                }
            }
            # ${var} form
            if ($nc eq "{") {
                if (length($buf) > 0) { push(@parts, "S:" . $buf); $buf = ""; }
                $i = $i + 2;
                # Skip leading whitespace inside `${...}` — `${ \$x }` should
                # behave the same as `${\$x}` (Perl ignores spaces here).
                while ($i < $len) {
                    my str $__sc = substr($raw, $i, 1);
                    if ($__sc eq " " || $__sc eq "\t" || $__sc eq "\n") { $i = $i + 1; }
                    else { last; }
                }
                my str $vname = "";
                # `${\EXPR}` is the Perl idiom for inline expression
                # interpolation: take a scalar ref to EXPR, deref it. We
                # emit it as a literal eval that interpolates EXPR's
                # stringified value. Without this, `${\foo()}` inside qq{}
                # silently expands to nothing — Sub::Quote's eval-template
                # builder relies on it heavily and qsub/quote_sub returned
                # broken closures under perla.
                if ($i < $len && substr($raw, $i, 1) eq "\\") {
                    $i = $i + 1;  # consume backslash
                    my str $expr_buf = "";
                    my int $depth = 1;
                    while ($i < $len && $depth > 0) {
                        my str $cc = substr($raw, $i, 1);
                        if ($cc eq "{") { $depth = $depth + 1; }
                        elsif ($cc eq "}") {
                            $depth = $depth - 1;
                            if ($depth == 0) { last; }
                        }
                        $expr_buf = $expr_buf . $cc;
                        $i = $i + 1;
                    }
                    if ($i < $len) { $i = $i + 1; }  # consume }
                    push(@parts, "X:" . $expr_buf);
                    next;
                }
                # Balanced brace collection: `${h{a}}` should capture
                # `h{a}` as the inner expression, not `h{a` (which used
                # to be the result because the first `}` terminated the
                # loop). Track depth of nested `{...}`.
                my int $__sb_depth = 1;
                while ($i < $len && $__sb_depth > 0) {
                    my str $__sbc = substr($raw, $i, 1);
                    if ($__sbc eq "{") { $__sb_depth = $__sb_depth + 1; }
                    elsif ($__sbc eq "}") {
                        $__sb_depth = $__sb_depth - 1;
                        if ($__sb_depth == 0) { last; }
                    }
                    $vname = $vname . $__sbc;
                    $i = $i + 1;
                }
                if ($i < $len) { $i = $i + 1; }
                # `${NAME{KEY}}` — scalar interp of `$NAME{KEY}`. Without
                # this branch we left vname as the bare ident and the
                # `{KEY}` part landed in the literal text. Perl idiom
                # used in many ${h{a}} interpolations. Skip when vname
                # starts with `$` — that's a deref form (${$h{a}}) and
                # the deref-with-subscript path below handles it.
                my int $__sb_open = index($vname, "{");
                if ($__sb_open >= 0 && substr($vname, length($vname) - 1, 1) eq "}"
                    && substr($vname, 0, 1) ne "$") {
                    my str $__sb_n = substr($vname, 0, $__sb_open);
                    my str $__sb_k = substr($vname, $__sb_open + 1, length($vname) - $__sb_open - 2);
                    # Quoted keys: use HQ: for literal treatment. The OUTER
                    # perla lexer preserves `\"` as 2-byte `\"` in DQSTRING
                    # contents, so a key like \"a-b\" actually arrives here
                    # as 8 bytes (`\\` `"` `a` `-` `b` `\\` `"`). Recognize
                    # both `\"..\"` and `"..."` and `'...'` forms.
                    my int $__sb_is_squoted = 0;
                    my int $__sb_is_dquoted = 0;
                    my str $__sb_inner = $__sb_k;
                    if (length($__sb_k) >= 4
                        && substr($__sb_k, 0, 2) eq "\\\"" && substr($__sb_k, length($__sb_k) - 2, 2) eq "\\\"") {
                        $__sb_is_dquoted = 1;
                        $__sb_inner = substr($__sb_k, 2, length($__sb_k) - 4);
                    } elsif (length($__sb_k) >= 2) {
                        if (substr($__sb_k, 0, 1) eq "'" && substr($__sb_k, length($__sb_k) - 1, 1) eq "'") {
                            $__sb_is_squoted = 1;
                            $__sb_inner = substr($__sb_k, 1, length($__sb_k) - 2);
                        } elsif (substr($__sb_k, 0, 1) eq "\"" && substr($__sb_k, length($__sb_k) - 1, 1) eq "\"") {
                            $__sb_is_dquoted = 1;
                            $__sb_inner = substr($__sb_k, 1, length($__sb_k) - 2);
                        }
                    }
                    if ($__sb_is_squoted == 1) {
                        push(@parts, "HQ:" . $__sb_n . ":" . $__sb_inner);
                    } elsif ($__sb_is_dquoted == 1 && index($__sb_inner, "\$") < 0) {
                        # Double-quoted, no interp — process Perl DQ escapes
                        # (\n → newline, etc.) before emitting as HQ:.
                        push(@parts, "HQ:" . $__sb_n . ":" . process_perl_dq_escapes($__sb_inner));
                    } elsif ($__sb_is_dquoted == 1) {
                        # Double-quoted key with embedded $var. Strip the
                        # outer backslash-quotes if present so the H:
                        # receiver's lex+parse sees a clean `"k$i"` DQSTRING
                        # — without this, the backslashes leaked into the
                        # parser as a BACKSLASH (N_REF) token followed by
                        # a string that consumed the closing `\"`.
                        push(@parts, "H:" . $__sb_n . ":\"" . $__sb_inner . "\"");
                    } else {
                        push(@parts, "H:" . $__sb_n . ":" . $__sb_k);
                    }
                    next;
                }
                # `${NAME[IDX]}` — same idea for arrays. R: is the
                # array-element-by-name encoding. Same `$`-prefix skip.
                my int $__sb_open_a = index($vname, "[");
                if ($__sb_open_a >= 0 && substr($vname, length($vname) - 1, 1) eq "]"
                    && substr($vname, 0, 1) ne "$") {
                    my str $__sb_an = substr($vname, 0, $__sb_open_a);
                    my str $__sb_ai = substr($vname, $__sb_open_a + 1, length($vname) - $__sb_open_a - 2);
                    push(@parts, "R:" . $__sb_an . ":" . $__sb_ai);
                    next;
                }
                # `${1}` .. `${9}` is the same as $1..$9 — regex capture
                # vars accessed in braced form. perla_capture_var is what
                # the bare `$N` form already routes to.
                if (length($vname) == 1) {
                    my str $first = substr($vname, 0, 1);
                    if ($first ge "1" && $first le "9") {
                        push(@parts, "C:" . $vname);
                        next;
                    }
                }
                # `${$NAME}[idx]` / `${$NAME}{key}` — scalar-deref-then-subscript.
                # Equivalent to `$NAME->[idx]` / `$NAME->{key}`. Without this,
                # `"x=${$ar}[1]"` emitted V:"$ar" + literal "[1]".
                if (length($vname) >= 2 && substr($vname, 0, 1) eq "$") {
                    my str $deref_name = substr($vname, 1, length($vname) - 1);
                    # Complex inner expr like `${$h{a}}[0]`: deref_name is
                    # `h{a}` (not a simple name). Fall through to the
                    # full-eval X: path. Otherwise the Z:A/Z:H decoding
                    # below would mis-treat the complex name as a bare
                    # variable.
                    my int $deref_simple = 1;
                    my int $dni0 = 0;
                    while ($dni0 < length($deref_name)) {
                        my str $dc0 = substr($deref_name, $dni0, 1);
                        if (!(($dc0 ge "a" && $dc0 le "z") || ($dc0 ge "A" && $dc0 le "Z") || ($dc0 ge "0" && $dc0 le "9") || $dc0 eq "_")) {
                            $deref_simple = 0; last;
                        }
                        $dni0 = $dni0 + 1;
                    }
                    if ($deref_simple == 1 && $i < $len) {
                        my str $tc = substr($raw, $i, 1);
                        if ($tc eq "[") {
                            my int $ks = $i + 1;
                            my int $ke = $ks;
                            $ke = scan_balanced($raw, $ke, "[", "]");
                            if ($ke < $len) {
                                # A further subscript chain (`${$ar}[0]->{b}[1]`)
                                # must be carried too — switch to the X: eval
                                # path with the full deref expression. Plain
                                # single-subscript keeps the lighter Z: encoding.
                                my array @__ch = interp_scan_chain($raw, $ke + 1, $len);
                                if (length($__ch[0]) > 0) {
                                    push(@parts, "X:" . "($" . $deref_name . ")->[" . substr($raw, $ks, $ke - $ks) . "]" . $__ch[0]);
                                    $i = $__ch[1];
                                } else {
                                    push(@parts, "Z:A" . chr(1) . $deref_name . chr(1) . substr($raw, $ks, $ke - $ks));
                                    $i = $ke + 1;
                                }
                                next;
                            }
                        } elsif ($tc eq "{") {
                            my int $ks = $i + 1;
                            my int $ke = $ks;
                            $ke = scan_balanced($raw, $ke, "{", "}");
                            if ($ke < $len) {
                                my array @__ch = interp_scan_chain($raw, $ke + 1, $len);
                                if (length($__ch[0]) > 0) {
                                    push(@parts, "X:" . "($" . $deref_name . ")->{" . substr($raw, $ks, $ke - $ks) . "}" . $__ch[0]);
                                    $i = $__ch[1];
                                } else {
                                    push(@parts, "Z:H" . chr(1) . $deref_name . chr(1) . strip_quoted_key(substr($raw, $ks, $ke - $ks)));
                                    $i = $ke + 1;
                                }
                                next;
                            }
                        }
                    }
                    # Complex inner expr followed by subscript:
                    # `${$h{a}}[0]` — collect the full `${...}[SUB]` text
                    # and emit it as an X: (runtime-eval) interp part so
                    # the regular parser handles the arrow-style access.
                    if ($deref_simple == 0 && $i < $len) {
                        my str $tc = substr($raw, $i, 1);
                        if ($tc eq "[" || $tc eq "{") {
                            my str $close_ch = ($tc eq "[") ? "]" : "}";
                            my str $open_ch = $tc;
                            my int $sub_start = $i + 1;
                            my int $sub_end = scan_balanced($raw, $sub_start, $open_ch, $close_ch);
                            if ($sub_end < $len) {
                                my str $sub_text = substr($raw, $sub_start, $sub_end - $sub_start);
                                # Emit `(VNAME)->[SUB]` or `->{SUB}`, then carry
                                # any further subscript chain (`->{b}->[1]`).
                                my str $arrow_op = ($tc eq "[") ? "->[" : "->{";
                                my str $expr_text = "(" . $vname . ")" . $arrow_op . $sub_text . $close_ch;
                                my array @__ch = interp_scan_chain($raw, $sub_end + 1, $len);
                                $expr_text = $expr_text . $__ch[0];
                                push(@parts, "X:" . $expr_text);
                                $i = $__ch[1];
                                next;
                            }
                        }
                    }
                    # Bare `${$NAME}` (no trailing subscript) is scalar-deref.
                    # Equivalent to `$$NAME`. Without this, perla emitted
                    # `V:$NAME` which mangled to a v__dollar_<name> identifier
                    # — read a never-initialized file-scope slot and printed
                    # empty. Same DS: encoding used by the bare-`$$NAME` form
                    # at line 1466.
                    my int $deref_ok = 1;
                    my int $dni = 0;
                    while ($dni < length($deref_name)) {
                        my str $dc = substr($deref_name, $dni, 1);
                        if (!(($dc ge "a" && $dc le "z") || ($dc ge "A" && $dc le "Z") || ($dc ge "0" && $dc le "9") || $dc eq "_")) {
                            $deref_ok = 0; last;
                        }
                        $dni = $dni + 1;
                    }
                    if ($deref_ok == 1 && length($deref_name) > 0) {
                        push(@parts, "DS:" . $deref_name);
                        next;
                    }
                    # Complex inner expr (`${$refs[3]}`, `${$h{k}}`, etc.)
                    # — emit as X: (full runtime-eval) so the deref-and-
                    # access expression is handled by the regular parser.
                    # Without this we fell through to V:"$NAME" which
                    # mangled to a bogus identifier.
                    push(@parts, "X:" . "\${" . $vname . "}");
                    next;
                }
                if ($qm == 1) { push(@parts, "QV:" . $vname); } else { push(@parts, "V:" . $vname); }
                next;
            }
            # `$$NAME[idx]` / `$$NAME{key}` — scalar-deref-then-subscript shorthand.
            # Equivalent to `${$NAME}[idx]` and `$NAME->[idx]`. Perl parses
            # `$$ar[1]` as `${$ar}[1]` (deref then subscript) — without this,
            # the leading `$` emitted literally and `$ar` looked up the wrong
            # slot. Also handles `$$$NAME` / `$$$$NAME` etc. (N-level deref):
            # the extra `$`s are encoded into the DS: payload as a `$`-prefix
            # per extra deref level.
            if ($nc eq "$" && $i + 2 < $len) {
                # Count consecutive `$`s starting at $i+1.
                my int $dollar_run = 1;
                while ($i + 1 + $dollar_run < $len && substr($raw, $i + 1 + $dollar_run, 1) eq "$") {
                    $dollar_run++;
                }
                my int $after_dollars = $i + 1 + $dollar_run;
                my str $nc2 = "";
                if ($after_dollars < $len) { $nc2 = substr($raw, $after_dollars, 1); }
                if (($nc2 ge "a" && $nc2 le "z") || ($nc2 ge "A" && $nc2 le "Z") || $nc2 eq "_") {
                    my int $vs2 = $after_dollars;
                    my int $ve2 = $vs2;
                    while ($ve2 < $len) {
                        my str $vc2 = substr($raw, $ve2, 1);
                        if (($vc2 ge "a" && $vc2 le "z") || ($vc2 ge "A" && $vc2 le "Z") || ($vc2 ge "0" && $vc2 le "9") || $vc2 eq "_") {
                            $ve2++;
                        } else { last; }
                    }
                    if ($ve2 <= $len) {
                        my str $deref_name2 = substr($raw, $vs2, $ve2 - $vs2);
                        # Prefix `$` per extra deref level beyond 1.
                        my str $extra_prefix = "";
                        my int $pi = 1;
                        while ($pi < $dollar_run) { $extra_prefix = $extra_prefix . "$"; $pi++; }
                        my str $tc2 = "";
                        if ($ve2 < $len) { $tc2 = substr($raw, $ve2, 1); }
                        if ($tc2 eq "[" && $dollar_run == 1) {
                            my int $ks = $ve2 + 1;
                            my int $ke = $ks;
                            $ke = scan_balanced($raw, $ke, "[", "]");
                            if ($ke < $len) {
                                if (length($buf) > 0) { push(@parts, "S:" . $buf); $buf = ""; }
                                # Carry a further subscript chain (`$$ar[0]->{b}[1]`)
                                # via the X: eval path; plain single subscript
                                # keeps the lighter Z: encoding.
                                my array @__ch = interp_scan_chain($raw, $ke + 1, $len);
                                if (length($__ch[0]) > 0) {
                                    push(@parts, "X:" . "($" . $deref_name2 . ")->[" . substr($raw, $ks, $ke - $ks) . "]" . $__ch[0]);
                                    $i = $__ch[1];
                                } else {
                                    push(@parts, "Z:A" . chr(1) . $deref_name2 . chr(1) . substr($raw, $ks, $ke - $ks));
                                    $i = $ke + 1;
                                }
                                next;
                            }
                        } elsif ($tc2 eq "{" && $dollar_run == 1) {
                            my int $ks = $ve2 + 1;
                            my int $ke = $ks;
                            $ke = scan_balanced($raw, $ke, "{", "}");
                            if ($ke < $len) {
                                if (length($buf) > 0) { push(@parts, "S:" . $buf); $buf = ""; }
                                my array @__ch = interp_scan_chain($raw, $ke + 1, $len);
                                if (length($__ch[0]) > 0) {
                                    push(@parts, "X:" . "($" . $deref_name2 . ")->{" . substr($raw, $ks, $ke - $ks) . "}" . $__ch[0]);
                                    $i = $__ch[1];
                                } else {
                                    push(@parts, "Z:H" . chr(1) . $deref_name2 . chr(1) . strip_quoted_key(substr($raw, $ks, $ke - $ks)));
                                    $i = $ke + 1;
                                }
                                next;
                            }
                        } else {
                            # `$$NAME` or `$$$NAME` etc., no subscript —
                            # bare N-level scalar deref. Encode extra `$`s
                            # into the DS: payload so the emitter wraps
                            # extra deref steps.
                            if (length($buf) > 0) { push(@parts, "S:" . $buf); $buf = ""; }
                            push(@parts, "DS:" . $extra_prefix . $deref_name2);
                            $i = $ve2;
                            next;
                        }
                    }
                }
            }
            # $1-$9 capture variables
            if ($nc ge "1" && $nc le "9") {
                if (length($buf) > 0) { push(@parts, "S:" . $buf); $buf = ""; }
                push(@parts, "C:" . $nc);
                $i = $i + 2;
                next;
            }
            # `$^X` — caret special variables ($^O, $^W, etc.). In Perla,
            # these become C variables named `v__caret_X`. Encode as
            # "V:^X" — the V: emitter maps "^X" back to v__caret_X.
            # Without this, `"$^O"` in interpolation emitted literal text.
            if ($nc eq "^" && $i + 2 < $len) {
                my str $cc = substr($raw, $i + 2, 1);
                if ($cc ge "A" && $cc le "Z") {
                    if (length($buf) > 0) { push(@parts, "S:" . $buf); $buf = ""; }
                    push(@parts, "V:^" . $cc);
                    $i = $i + 3;
                    next;
                }
            }
            # Special scalars: $@ (eval error), $! (errno string), $/ (input
            # record sep), $\ (output record sep), $, (output field sep), $|
            # (autoflush), $; (subscript sep), $" (list sep), $& $` $' $+
            # (match vars), $0 (program name). Without this branch, `"$@"`
            # in a double-quoted string emits literal "$@" instead of the
            # eval error value — Perla's Test::* output uses this heavily.
            # Bare `$$` (process ID) when followed by a non-ident, non-`{`,
            # non-`[` character. `$$NAME` and `$$ref->{...}` still take the
            # scalar-deref path below. Without this, `"/tmp/foo_$$.txt"`
            # left `$$` as literal text instead of expanding to the PID.
            if ($nc eq "\$" && $i + 2 < $len) {
                my str $nnc = substr($raw, $i + 2, 1);
                if (!(($nnc ge "a" && $nnc le "z") || ($nnc ge "A" && $nnc le "Z") || $nnc eq "_" || $nnc eq "{" || $nnc eq "[")) {
                    if (length($buf) > 0) { push(@parts, "S:" . $buf); $buf = ""; }
                    push(@parts, "V:\$");
                    $i = $i + 2;
                    next;
                }
            } elsif ($nc eq "\$" && $i + 2 >= $len) {
                # `$$` at end of string.
                if (length($buf) > 0) { push(@parts, "S:" . $buf); $buf = ""; }
                push(@parts, "V:\$");
                $i = $i + 2;
                next;
            }
            if ($nc eq "@" || $nc eq "!" || $nc eq "/" || $nc eq "\\" ||
                $nc eq "," || $nc eq ";" || $nc eq "\"" || $nc eq "|" ||
                $nc eq "&" || $nc eq "`" || $nc eq "'" || $nc eq "+" ||
                $nc eq "-" ||
                $nc eq "0" || $nc eq "?" || $nc eq "." ||
                $nc eq "<" || $nc eq ">" || $nc eq "(" || $nc eq ")" ||
                $nc eq "~" || $nc eq "=" || $nc eq "%") {
                # `$+{KEY}` — named-capture hash access (`%+`). Emit a
                # dedicated "N:KEY" part so the emitter routes through
                # strada_named_captures(). Without this, `"$+{name}"`
                # interp emitted just the value of $+ followed by literal
                # `{name}` text.
                if ($nc eq "+" && $i + 2 < $len && substr($raw, $i + 2, 1) eq "{") {
                    my int $nks = $i + 3;
                    my int $nke = $nks;
                    $nke = scan_balanced($raw, $nke, "{", "}");
                    if ($nke < $len) {
                        if (length($buf) > 0) { push(@parts, "S:" . $buf); $buf = ""; }
                        push(@parts, "N:" . strip_quoted_key(substr($raw, $nks, $nke - $nks)));
                        $i = $nke + 1;
                        next;
                    }
                }
                # `$+[N]` / `$-[N]` — regex match-offset arrays. Without
                # this, the interp emitted just the value of $+ / $- and
                # left `[N]` as literal text in the output.
                if (($nc eq "+" || $nc eq "-") && $i + 2 < $len && substr($raw, $i + 2, 1) eq "[") {
                    my int $aks = $i + 3;
                    my int $ake = $aks;
                    $ake = scan_balanced($raw, $ake, "[", "]");
                    if ($ake < $len) {
                        if (length($buf) > 0) { push(@parts, "S:" . $buf); $buf = ""; }
                        my str $aidx = substr($raw, $aks, $ake - $aks);
                        # Encode as "MO:+:IDX" / "MO:-:IDX" (Match Offset).
                        push(@parts, "MO:" . $nc . ":" . $aidx);
                        $i = $ake + 1;
                        next;
                    }
                }
                # `$@->{KEY}` / `$@->[N]` (and chained derefs like
                # `$@->{a}->{b}`, `$@->{a}->[0]`) — arrow deref of a
                # special scalar. Common when $@ holds a hashref or
                # blessed object from `die {...}` or `die $obj`. Without
                # this, the interp emitted the stringified value of $@
                # followed by literal `->{...}` text.
                if ($i + 3 < $len && substr($raw, $i + 2, 2) eq "->"
                    && ($i + 4 < $len)
                    && (substr($raw, $i + 4, 1) eq "{" || substr($raw, $i + 4, 1) eq "[")) {
                    # Walk a chain of `->{key}` and `->[N]` steps.
                    my array @sp_chain = ();
                    my int $scan = $i + 2;
                    while ($scan + 1 < $len && substr($raw, $scan, 2) eq "->"
                           && ($scan + 2 < $len)
                           && (substr($raw, $scan + 2, 1) eq "{" || substr($raw, $scan + 2, 1) eq "[")) {
                        my str $br = substr($raw, $scan + 2, 1);
                        my int $ks = $scan + 3;
                        my int $ke = $ks;
                        if ($br eq "{") {
                            $ke = scan_balanced($raw, $ke, "{", "}");
                            if ($ke >= $len) { last; }
                            push(@sp_chain, "h:" . strip_quoted_key(substr($raw, $ks, $ke - $ks)));
                        } else {
                            $ke = scan_balanced($raw, $ke, "[", "]");
                            if ($ke >= $len) { last; }
                            push(@sp_chain, "a:" . substr($raw, $ks, $ke - $ks));
                        }
                        $scan = $ke + 1;
                    }
                    if (scalar(@sp_chain) > 0) {
                        if (length($buf) > 0) { push(@parts, "S:" . $buf); $buf = ""; }
                        # Encode: ZP:NC<SOH>step1<STX>step2<STX>...
                        my str $zp = "ZP:" . $nc . chr(1);
                        my int $cj = 0;
                        while ($cj < scalar(@sp_chain)) {
                            if ($cj > 0) { $zp = $zp . chr(2); }
                            $zp = $zp . $sp_chain[$cj];
                            $cj++;
                        }
                        push(@parts, $zp);
                        $i = $scan;
                        next;
                    }
                }
                if (length($buf) > 0) { push(@parts, "S:" . $buf); $buf = ""; }
                push(@parts, "V:" . $nc);
                $i = $i + 2;
                next;
            }
            # Accept `:` as a start char too — handles `$::name`
            # (shorthand for `$main::name`). The var-name scanner below
            # treats `::var` as the name; we then prefix with "main".
            # Without this, `"$::var"` left `$::var` as literal text.
            my int $is_var_start = (($nc ge "a" && $nc le "z") || ($nc ge "A" && $nc le "Z") || $nc eq "_");
            if (!$is_var_start && $nc eq ":" && $i + 2 < $len && substr($raw, $i + 2, 1) eq ":"
                && $i + 3 < $len) {
                my str $nnc = substr($raw, $i + 3, 1);
                if (($nnc ge "a" && $nnc le "z") || ($nnc ge "A" && $nnc le "Z") || $nnc eq "_") {
                    $is_var_start = 1;
                }
            }
            if ($is_var_start) {
                # Flush buffer
                if (length($buf) > 0) {
                    push(@parts, "S:" . $buf);
                    $buf = "";
                }
                # Read variable name. Accept `::` as part of the name so
                # `"$HTTP::URI_CLASS"` resolves the HTTP::URI_CLASS
                # package global. Without this, the scanner stopped at the
                # first `:`, leaving `::URI_CLASS` as literal text —
                # LWP / HTTP::Message's `require "$HTTP::URI_CLASS"` then
                # tried to `require ::URI_CLASS` and died with
                # `Can't locate /URI_CLASS.pm in @INC`.
                my int $vs = $i + 1;
                my int $ve = $vs;
                while ($ve < $len) {
                    my str $vc = substr($raw, $ve, 1);
                    if (($vc ge "a" && $vc le "z") || ($vc ge "A" && $vc le "Z") || ($vc ge "0" && $vc le "9") || $vc eq "_") {
                        $ve++;
                    } elsif ($vc eq ":" && $ve + 1 < $len && substr($raw, $ve + 1, 1) eq ":"
                             && $ve + 2 < $len) {
                        # `::` is part of the name only if a valid ident
                        # char follows (avoid swallowing a trailing `::`
                        # that's just punctuation at the end of a word).
                        my str $vn = substr($raw, $ve + 2, 1);
                        if (($vn ge "a" && $vn le "z") || ($vn ge "A" && $vn le "Z") || $vn eq "_") {
                            $ve = $ve + 2;
                        } else { last; }
                    } else { last; }
                }
                my str $vname = substr($raw, $vs, $ve - $vs);
                # `$::name` in interp is Perl shorthand for `$main::name`.
                # Without prefixing, the V: emitter reads literal "::name"
                # which doesn't resolve to any variable.
                if (length($vname) > 2 && substr($vname, 0, 2) eq "::") {
                    $vname = "main" . $vname;
                }
                # First access (with or without `->`) plus any chained
                # subscripts that follow (autoderef in Perl). Examples:
                #   $h{a}{b}     — hash %h slot a, then deref to slot b
                #   $r->{a}{b}   — scalar $r as hashref, deref a then b
                #   $a[0]->[1]   — array @a slot 0 (arrayref), deref slot 1
                # The initial step encodes whether we read via the % / @ sigil
                # (h:/a:) or via scalar deref (H:/A:). All subsequent steps
                # are scalar derefs (h:/a:).
                my str $first_kind = "";  # "h", "a", "H" or "A"
                my str $first_key = "";
                my int $first_consumed_to = $ve;
                if ($ve + 2 < $len && substr($raw, $ve, 2) eq "->") {
                    my str $ac = substr($raw, $ve + 2, 1);
                    if ($ac eq "{") {
                        my int $ks = $ve + 3;
                        my int $ke = $ks;
                        $ke = scan_balanced($raw, $ke, "{", "}");
                        if ($ke < $len) {
                            $first_kind = "H";
                            $first_key = strip_quoted_key(substr($raw, $ks, $ke - $ks));
                            $first_consumed_to = $ke + 1;
                        }
                    } elsif ($ac eq "[") {
                        my int $ks = $ve + 3;
                        my int $ke = $ks;
                        $ke = scan_balanced($raw, $ke, "[", "]");
                        if ($ke < $len) {
                            $first_kind = "A";
                            $first_key = substr($raw, $ks, $ke - $ks);
                            $first_consumed_to = $ke + 1;
                        }
                    }
                }
                if ($first_kind eq "" && $ve < $len) {
                    my str $ac = substr($raw, $ve, 1);
                    if ($ac eq "{") {
                        my int $ks = $ve + 1;
                        my int $ke = $ks;
                        $ke = scan_balanced($raw, $ke, "{", "}");
                        if ($ke < $len) {
                            my str $__raw_k = substr($raw, $ks, $ke - $ks);
                            # Multi-key compound subscript (`$h{'x','y'}`,
                            # `$h{$a,$b}`) — detect a top-level comma and
                            # force the 'h' kind so the inline-parse path
                            # (which now rewrites top-level commas into the
                            # `$;`-join form) handles it. Without this, a
                            # quoted first piece like `'x','y'` was mis-read
                            # as ONE single-quoted key `x','y`.
                            my int $__rk_tlc = 0;
                            {
                                my int $__rkd = 0;
                                my int $__rkq = 0;
                                my int $__rki = 0;
                                while ($__rki < length($__raw_k)) {
                                    my str $__rkc = substr($__raw_k, $__rki, 1);
                                    if ($__rkq == 1) { if ($__rkc eq "'") { $__rkq = 0; } }
                                    elsif ($__rkq == 2) { if ($__rkc eq "\"") { $__rkq = 0; } }
                                    elsif ($__rkc eq "'") { $__rkq = 1; }
                                    elsif ($__rkc eq "\"") { $__rkq = 2; }
                                    elsif ($__rkc eq "(" || $__rkc eq "[" || $__rkc eq "{") { $__rkd = $__rkd + 1; }
                                    elsif ($__rkc eq ")" || $__rkc eq "]" || $__rkc eq "}") { $__rkd = $__rkd - 1; }
                                    elsif ($__rkc eq "," && $__rkd == 0) { $__rk_tlc = 1; }
                                    $__rki = $__rki + 1;
                                }
                            }
                            if ($__rk_tlc == 1) {
                                # Compound multi-key: hand the raw key
                                # (commas intact) to the 'h' inline-parse
                                # path, which rewrites top-level commas
                                # into the `$;`-join form. The outer lexer
                                # preserves double quotes as `\"`; normalize
                                # back to plain `"` so the inline parser
                                # lexes `"p","q"` as two strings rather than
                                # ref-of-string garbage (`\"p\"`).
                                my str $__rk_norm = "";
                                my int $__rni = 0;
                                while ($__rni < length($__raw_k)) {
                                    if ($__rni + 1 < length($__raw_k)
                                        && substr($__raw_k, $__rni, 1) eq "\\"
                                        && substr($__raw_k, $__rni + 1, 1) eq "\"") {
                                        $__rk_norm = $__rk_norm . "\"";
                                        $__rni = $__rni + 2;
                                    } else {
                                        $__rk_norm = $__rk_norm . substr($__raw_k, $__rni, 1);
                                        $__rni = $__rni + 1;
                                    }
                                }
                                $first_kind = "h";
                                $first_key = $__rk_norm;
                            } else {
                            # Quoted keys → 'hq' literal. Recognizes
                            # 'foo', "foo", and \"foo\" (the last form
                            # is the OUTER lexer's preserved-escape shape).
                            # Double-quoted with embedded `$var` falls
                            # through to 'h' for parser interpolation.
                            my int $__sqk = 0;
                            my int $__dqk = 0;
                            my str $__inner_k = $__raw_k;
                            if (length($__raw_k) >= 4
                                && substr($__raw_k, 0, 2) eq "\\\"" && substr($__raw_k, length($__raw_k) - 2, 2) eq "\\\"") {
                                $__dqk = 1;
                                $__inner_k = substr($__raw_k, 2, length($__raw_k) - 4);
                            } elsif (length($__raw_k) >= 2) {
                                if (substr($__raw_k, 0, 1) eq "'" && substr($__raw_k, length($__raw_k) - 1, 1) eq "'") {
                                    $__sqk = 1;
                                    $__inner_k = substr($__raw_k, 1, length($__raw_k) - 2);
                                } elsif (substr($__raw_k, 0, 1) eq "\"" && substr($__raw_k, length($__raw_k) - 1, 1) eq "\"") {
                                    $__dqk = 1;
                                    $__inner_k = substr($__raw_k, 1, length($__raw_k) - 2);
                                }
                            }
                            if ($__sqk == 1) {
                                $first_kind = "hq";
                                $first_key = $__inner_k;
                            } elsif ($__dqk == 1 && index($__inner_k, "\$") < 0) {
                                # Double-quoted, no interp — process Perl DQ
                                # escapes (\n → newline, etc.) so the lookup
                                # key matches Perl's behavior.
                                $first_kind = "hq";
                                $first_key = process_perl_dq_escapes($__inner_k);
                            } elsif ($__dqk == 1) {
                                # Re-emit with clean `"..."` quotes for the
                                # parser (avoid backslash-quote tokenization
                                # issue).
                                $first_kind = "h";
                                $first_key = "\"" . $__inner_k . "\"";
                            } else {
                                $first_kind = "h";
                                $first_key = $__raw_k;
                            }
                            }
                            $first_consumed_to = $ke + 1;
                        }
                    } elsif ($ac eq "[") {
                        my int $ks = $ve + 1;
                        my int $ke = $ks;
                        $ke = scan_balanced($raw, $ke, "[", "]");
                        if ($ke < $len) {
                            $first_kind = "a";
                            $first_key = substr($raw, $ks, $ke - $ks);
                            $first_consumed_to = $ke + 1;
                        }
                    }
                }
                if ($first_kind eq "") {
                    if ($qm == 1) { push(@parts, "QV:" . $vname); } else { push(@parts, "V:" . $vname); }
                    $i = $ve;
                    next;
                }
                # Look ahead for more chained subscripts. Accept either bare
                # or `->{`/`->[` form between steps; the leading `->` is
                # optional once we're already in a chain.
                my array @chain_steps = ();
                my int $cp = $first_consumed_to;
                while ($cp < $len) {
                    my int $cp_after_arrow = $cp;
                    if ($cp + 1 < $len && substr($raw, $cp, 2) eq "->") {
                        $cp_after_arrow = $cp + 2;
                    }
                    if ($cp_after_arrow < $len && substr($raw, $cp_after_arrow, 1) eq "{") {
                        my int $ks = $cp_after_arrow + 1;
                        my int $ke = $ks;
                        $ke = scan_balanced($raw, $ke, "{", "}");
                        if ($ke < $len) {
                            push(@chain_steps, "h:" . strip_quoted_key(substr($raw, $ks, $ke - $ks)));
                            $cp = $ke + 1;
                            next;
                        }
                        last;
                    } elsif ($cp_after_arrow < $len && substr($raw, $cp_after_arrow, 1) eq "[") {
                        my int $ks = $cp_after_arrow + 1;
                        my int $ke = $ks;
                        $ke = scan_balanced($raw, $ke, "[", "]");
                        if ($ke < $len) {
                            push(@chain_steps, "a:" . substr($raw, $ks, $ke - $ks));
                            $cp = $ke + 1;
                            next;
                        }
                        last;
                    }
                    last;
                }
                if (scalar(@chain_steps) == 0) {
                    if ($first_kind eq "H") { push(@parts, "D:" . $vname . ":" . $first_key); }
                    elsif ($first_kind eq "A") { push(@parts, "R:" . $vname . ":" . $first_key); }
                    elsif ($first_kind eq "h") { push(@parts, "H:" . $vname . ":" . $first_key); }
                    elsif ($first_kind eq "hq") { push(@parts, "HQ:" . $vname . ":" . $first_key); }
                    elsif ($first_kind eq "a") { push(@parts, "A:" . $vname . ":" . $first_key); }
                    $i = $first_consumed_to;
                    next;
                }
                # Encode the full chain. Strada string literals don't decode
                # `\xNN` escapes, so we use chr(1) / chr(2) to get real bytes.
                my str $sep_field = chr(1);
                my str $sep_step  = chr(2);
                my str $z = "Z:" . $first_kind . $sep_field . $vname . $sep_field . $first_key;
                my int $sj = 0;
                while ($sj < scalar(@chain_steps)) {
                    $z = $z . $sep_step . $chain_steps[$sj];
                    $sj++;
                }
                push(@parts, $z);
                $i = $cp;
                next;
            }
        }

        # @array interpolation: "@array" joins with space
        # Only interpolate when @ is not preceded by a word char (avoid emails like user@example)
        if ($ch eq "@" && $i + 1 < $len) {
            my str $nc2 = substr($raw, $i + 1, 1);
            my int $prev_is_word = 0;
            if ($i > 0) {
                my str $prev = substr($raw, $i - 1, 1);
                if (($prev ge "a" && $prev le "z") || ($prev ge "A" && $prev le "Z") || ($prev ge "0" && $prev le "9") || $prev eq "_") {
                    $prev_is_word = 1;
                }
            }
            # `@{[ EXPR ]}` is Perl's idiom for inline list-context expression
            # interpolation: bare `[ EXPR ]` is an arrayref, `@{...}` derefs
            # the ref to a list, list-in-string joins with $". Reuse the
            # existing X:-style runtime eval so EXPR runs through perla's
            # eval STRING — same path as `${\EXPR}`. Without this, DBIC's
            # `"Your storage subclass @{[ ref $self ]} provides ..."` lost
            # the class name (it stayed literal in the message), and its
            # source_bind_attributes-deprecation throw_exception emitted a
            # message that began with `Your storage subclass @{[ ref` —
            # which DBIx::Class::Carp's __find_caller couldn't categorize so
            # the bizowie BZ:6 throw came out empty.
            if ($prev_is_word == 0 && $nc2 eq "{" && $i + 2 < $len && substr($raw, $i + 2, 1) eq "[") {
                if (length($buf) > 0) { push(@parts, "S:" . $buf); $buf = ""; }
                my int $j = $i + 3;  # past `@{[`
                my str $expr_buf = "";
                my int $depth = 1;
                while ($j < $len && $depth > 0) {
                    my str $cc = substr($raw, $j, 1);
                    if ($cc eq "[") { $depth = $depth + 1; }
                    elsif ($cc eq "]") {
                        $depth = $depth - 1;
                        if ($depth == 0) { last; }
                    }
                    $expr_buf = $expr_buf . $cc;
                    $j = $j + 1;
                }
                if ($j < $len) { $j = $j + 1; }  # consume `]`
                if ($j < $len && substr($raw, $j, 1) eq "}") { $j = $j + 1; }  # consume `}`
                # Wrap as `[EXPR]` so eval returns an arrayref; then X:
                # handler derefs and joins with $". Without the wrap, the
                # eval evaluates EXPR in scalar context and returns just
                # the last value of a comma-separated list.
                push(@parts, "X:" . "[" . $expr_buf . "]");
                $i = $j;
                next;
            }
            # `@+` and `@-` — regex match-end / match-start position arrays.
            # Without this, the parser fell through and left `@+` as
            # literal text in the result.
            if ($prev_is_word == 0 && ($nc2 eq "+" || $nc2 eq "-")) {
                if (length($buf) > 0) { push(@parts, "S:" . $buf); $buf = ""; }
                push(@parts, "@MA:" . $nc2);
                $i = $i + 2;
                next;
            }
            if ($prev_is_word == 0 && (($nc2 ge "a" && $nc2 le "z") || ($nc2 ge "A" && $nc2 le "Z") || $nc2 eq "_")) {
                if (length($buf) > 0) { push(@parts, "S:" . $buf); $buf = ""; }
                my int $vs = $i + 1;
                my int $ve = $vs;
                while ($ve < $len) {
                    my str $vc = substr($raw, $ve, 1);
                    if (($vc ge "a" && $vc le "z") || ($vc ge "A" && $vc le "Z") || ($vc ge "0" && $vc le "9") || $vc eq "_") {
                        $ve++;
                    } elsif ($vc eq ":" && $ve + 1 < $len && substr($raw, $ve + 1, 1) eq ":") {
                        # Package-qualified array name: `@Foo::Bar::ARR`.
                        # Consume `::` plus the next identifier segment.
                        # Without this the parser captured only "Foo" and
                        # the rest landed as literal text in the result —
                        # `"@Eval::Closure::EXPORT"` came out as
                        # `"::Closure::EXPORT"` (Foo dropped as undef array,
                        # rest treated as a string literal).
                        my str $vc2 = $ve + 2 < $len ? substr($raw, $ve + 2, 1) : "";
                        if (($vc2 ge "a" && $vc2 le "z") || ($vc2 ge "A" && $vc2 le "Z") || $vc2 eq "_") {
                            $ve = $ve + 2;
                        } else { last; }
                    } else { last; }
                }
                # `@NAME[INDICES]` array slice in interp.
                if ($ve < $len && substr($raw, $ve, 1) eq "[") {
                    # Find matching `]` honoring nesting.
                    my int $sis = $ve + 1;
                    my int $sie = $sis;
                    my int $sdepth = 1;
                    while ($sie < $len && $sdepth > 0) {
                        my str $sic = substr($raw, $sie, 1);
                        if ($sic eq "[") { $sdepth++; }
                        elsif ($sic eq "]") {
                            $sdepth--;
                            if ($sdepth == 0) { last; }
                        }
                        $sie++;
                    }
                    if ($sie < $len) {
                        if (length($buf) > 0) { push(@parts, "S:" . $buf); $buf = ""; }
                        my str $aname = substr($raw, $vs, $ve - $vs);
                        my str $aidx = substr($raw, $sis, $sie - $sis);
                        push(@parts, "ASLI:" . $aname . chr(1) . $aidx);
                        $i = $sie + 1;
                        next;
                    }
                }
                # `@NAME{KEYS}` hash slice in interp.
                if ($ve < $len && substr($raw, $ve, 1) eq "{") {
                    my int $sks = $ve + 1;
                    my int $ske = $sks;
                    my int $skdepth = 1;
                    while ($ske < $len && $skdepth > 0) {
                        my str $skc = substr($raw, $ske, 1);
                        if ($skc eq "{") { $skdepth++; }
                        elsif ($skc eq "}") {
                            $skdepth--;
                            if ($skdepth == 0) { last; }
                        }
                        $ske++;
                    }
                    if ($ske < $len) {
                        if (length($buf) > 0) { push(@parts, "S:" . $buf); $buf = ""; }
                        my str $hname = substr($raw, $vs, $ve - $vs);
                        my str $hkeys = substr($raw, $sks, $ske - $sks);
                        push(@parts, "HSLI:" . $hname . chr(1) . $hkeys);
                        $i = $ske + 1;
                        next;
                    }
                }
                push(@parts, "@:" . substr($raw, $vs, $ve - $vs));
                $i = $ve;
                next;
            }
            # `@$NAME` — scalar-deref array form. perla previously left
            # this as literal text in the interpolation output. Encode as
            # "@D:NAME" and emit a runtime deref+join at the part site.
            if ($prev_is_word == 0 && $nc2 eq "$" && $i + 2 < $len) {
                my str $nc3 = substr($raw, $i + 2, 1);
                if (($nc3 ge "a" && $nc3 le "z") || ($nc3 ge "A" && $nc3 le "Z") || $nc3 eq "_") {
                    if (length($buf) > 0) { push(@parts, "S:" . $buf); $buf = ""; }
                    my int $vs_d = $i + 2;
                    my int $ve_d = $vs_d;
                    while ($ve_d < $len) {
                        my str $vc_d = substr($raw, $ve_d, 1);
                        if (($vc_d ge "a" && $vc_d le "z") || ($vc_d ge "A" && $vc_d le "Z") || ($vc_d ge "0" && $vc_d le "9") || $vc_d eq "_") {
                            $ve_d++;
                        } else { last; }
                    }
                    push(@parts, "@D:" . substr($raw, $vs_d, $ve_d - $vs_d));
                    $i = $ve_d;
                    next;
                }
            }
            # `@{EXPR}` — generic braced-deref form. Whatever EXPR is
            # (chain like `$h->{x}[0]{y}`, or just `$ref`), evaluate it
            # and deref as an array. Without a general handler, the
            # specific-shape branches below missed multi-step chains and
            # whitespace variants, leaving the source text literal in the
            # output. We try the specific shapes first (cheap) and fall
            # back to the inline-compile path when none match.
            if ($prev_is_word == 0 && $nc2 eq "{" && $i + 2 < $len && substr($raw, $i + 2, 1) eq "$") {
                my int $vs_b = $i + 3;
                my int $ve_b = $vs_b;
                while ($ve_b < $len) {
                    my str $vc_b = substr($raw, $ve_b, 1);
                    if (($vc_b ge "a" && $vc_b le "z") || ($vc_b ge "A" && $vc_b le "Z") || ($vc_b ge "0" && $vc_b le "9") || $vc_b eq "_") {
                        $ve_b++;
                    } else { last; }
                }
                if ($ve_b > $vs_b && $ve_b < $len) {
                    my str $after = substr($raw, $ve_b, 1);
                    if ($after eq "}") {
                        # `@{$NAME}` — simple scalar deref, possibly followed
                        # by `[idx,...]` (array slice) or `{key,...}` (hash slice).
                        my int $cls_pos = $ve_b + 1;
                        if ($cls_pos < $len) {
                            my str $sl = substr($raw, $cls_pos, 1);
                            if ($sl eq "[" || $sl eq "{") {
                                my str $sl_closer;
                                if ($sl eq "[") { $sl_closer = "]"; } else { $sl_closer = "}"; }
                                my int $sks = $cls_pos + 1;
                                my int $ske = $sks;
                                while ($ske < $len && substr($raw, $ske, 1) ne $sl_closer) { $ske++; }
                                if ($ske < $len) {
                                    if (length($buf) > 0) { push(@parts, "S:" . $buf); $buf = ""; }
                                    my str $stag;
                                    if ($sl eq "[") { $stag = "@SAR:"; } else { $stag = "@SHR:"; }
                                    push(@parts, $stag . substr($raw, $vs_b, $ve_b - $vs_b) . chr(1) . substr($raw, $sks, $ske - $sks));
                                    $i = $ske + 1;
                                    next;
                                }
                            }
                        }
                        if (length($buf) > 0) { push(@parts, "S:" . $buf); $buf = ""; }
                        push(@parts, "@D:" . substr($raw, $vs_b, $ve_b - $vs_b));
                        $i = $ve_b + 1;
                        next;
                    } elsif ($after eq "{" || $after eq "[") {
                        # `@{$NAME{KEY}}` / `@{$NAME[IDX]}` — fetch first, deref
                        my str $closer;
                        if ($after eq "{") { $closer = "}"; } else { $closer = "]"; }
                        my int $ks = $ve_b + 1;
                        my int $ke = $ks;
                        while ($ke < $len && substr($raw, $ke, 1) ne $closer) { $ke++; }
                        if ($ke < $len && $ke + 1 < $len && substr($raw, $ke + 1, 1) eq "}") {
                            if (length($buf) > 0) { push(@parts, "S:" . $buf); $buf = ""; }
                            my str $vname_inner = substr($raw, $vs_b, $ve_b - $vs_b);
                            my str $key_inner = strip_quoted_key(substr($raw, $ks, $ke - $ks));
                            # Encode as "@HD:" (hash-elem-deref) or "@AD:" (array-elem-deref)
                            my str $tag;
                            if ($after eq "{") { $tag = "@HD:"; } else { $tag = "@AD:"; }
                            push(@parts, $tag . $vname_inner . chr(1) . $key_inner);
                            $i = $ke + 2;  # past closer and outer `}`
                            next;
                        }
                    } elsif ($after eq "-" && $ve_b + 1 < $len && substr($raw, $ve_b + 1, 1) eq ">") {
                        # `@{$NAME->{KEY}}` / `@{$NAME->[IDX]}` — arrow-fetch then deref
                        my str $tk = $ve_b + 2 < $len ? substr($raw, $ve_b + 2, 1) : "";
                        if ($tk eq "{" || $tk eq "[") {
                            my str $closer;
                            if ($tk eq "{") { $closer = "}"; } else { $closer = "]"; }
                            my int $ks = $ve_b + 3;
                            my int $ke = $ks;
                            while ($ke < $len && substr($raw, $ke, 1) ne $closer) { $ke++; }
                            if ($ke < $len && $ke + 1 < $len && substr($raw, $ke + 1, 1) eq "}") {
                                if (length($buf) > 0) { push(@parts, "S:" . $buf); $buf = ""; }
                                my str $vname_inner = substr($raw, $vs_b, $ve_b - $vs_b);
                                my str $key_inner = strip_quoted_key(substr($raw, $ks, $ke - $ks));
                                my str $tag;
                                if ($tk eq "{") { $tag = "@RHD:"; } else { $tag = "@RAD:"; }
                                push(@parts, $tag . $vname_inner . chr(1) . $key_inner);
                                $i = $ke + 2;
                                next;
                            }
                        }
                    }
                }
            }
            # Generic `@{EXPR}` fallback: scan to matching `}`, inline-compile
            # EXPR as a Perl expression, then deref+join at the emit site.
            # Catches multi-step chains (`@{$d->{x}[0]{y}}`) and any
            # whitespace variants (`@{ \$ref }`).
            if ($prev_is_word == 0 && $nc2 eq "{") {
                my int $bs = $i + 2;
                my int $be = $bs;
                my int $bd = 1;
                while ($be < $len && $bd > 0) {
                    my str $bc = substr($raw, $be, 1);
                    if ($bc eq "{") { $bd++; }
                    elsif ($bc eq "}") {
                        $bd--;
                        if ($bd == 0) { last; }
                    }
                    $be++;
                }
                if ($be < $len) {
                    my str $expr_inner = substr($raw, $bs, $be - $bs);
                    # Strip whitespace edges so trivial `@{ \$r }` parses.
                    my int $xs2 = 0;
                    my int $xe2 = length($expr_inner);
                    while ($xs2 < $xe2 && (substr($expr_inner, $xs2, 1) eq " " || substr($expr_inner, $xs2, 1) eq "\t" || substr($expr_inner, $xs2, 1) eq "\n")) { $xs2++; }
                    while ($xe2 > $xs2 && (substr($expr_inner, $xe2 - 1, 1) eq " " || substr($expr_inner, $xe2 - 1, 1) eq "\t" || substr($expr_inner, $xe2 - 1, 1) eq "\n")) { $xe2--; }
                    $expr_inner = substr($expr_inner, $xs2, $xe2 - $xs2);
                    if (length($expr_inner) > 0) {
                        if (length($buf) > 0) { push(@parts, "S:" . $buf); $buf = ""; }
                        push(@parts, "ADRX:" . $expr_inner);
                        $i = $be + 1;
                        next;
                    }
                }
            }
        }

        # Regular char — escape for C string. In `\Q...\E` quotemeta
        # region, prepend a runtime backslash for non-alnum/_ chars so
        # the emitted string includes the quotemeta escape (matches
        # Perl's quotemeta semantics on literal characters).
        # In `\U...\E` / `\L...\E` case-modification region, ASCII
        # letters get folded. \u / \l fold just the next char.
        my str $eff_ch = $ch;
        my str $eff_case = $case_mode;
        if (length($case_pending) > 0) {
            $eff_case = $case_pending;
            $case_pending = "";
        }
        if (length($eff_case) > 0) {
            my int $cv = char_at($ch, 0);
            if ($eff_case eq "U" && $cv >= 97 && $cv <= 122) {
                $eff_ch = chr($cv - 32);
            } elsif ($eff_case eq "L" && $cv >= 65 && $cv <= 90) {
                $eff_ch = chr($cv + 32);
            }
        }
        if ($eff_ch eq "\"") {
            $buf = $buf . "\\\"";
        } elsif ($eff_ch eq "\n") {
            $buf = $buf . "\\n";
        } elsif ($eff_ch eq "\t") {
            $buf = $buf . "\\t";
        } elsif ($eff_ch eq "\r") {
            $buf = $buf . "\\r";
        } else {
            if ($qm == 1) {
                # Check if alnum or underscore — if not, prepend literal `\`.
                my int $alnum = 0;
                if (($eff_ch ge "a" && $eff_ch le "z") || ($eff_ch ge "A" && $eff_ch le "Z")
                    || ($eff_ch ge "0" && $eff_ch le "9") || $eff_ch eq "_") {
                    $alnum = 1;
                }
                if ($alnum == 0) {
                    $buf = $buf . "\\\\";  # one literal backslash in runtime
                }
            }
            $buf = $buf . $eff_ch;
        }
        $i++;
    }
    if (length($buf) > 0) {
        push(@parts, "S:" . $buf);
    }

    # Slow path when `\U`/`\L`/`\u`/`\l`/`\E` markers were pushed:
    # filter them out and wrap each remaining variable part with
    # strada_uc/strada_lc. Literal S: parts already have their case
    # applied at scan time (no wrapping needed). Without this, only
    # `"\Uhello\E"` worked — `"\U$name\E"` left $name unfolded.
    my int $has_case_markers = 0;
    my int $cm_i = 0;
    while ($cm_i < scalar(@parts)) {
        my str $cmp = $parts[$cm_i];
        if (substr($cmp, 0, 3) eq "_CU" || substr($cmp, 0, 3) eq "_CL"
            || substr($cmp, 0, 3) eq "_CE" || substr($cmp, 0, 4) eq "_C1U"
            || substr($cmp, 0, 4) eq "_C1L") {
            $has_case_markers = 1; last;
        }
        $cm_i = $cm_i + 1;
    }
    if ($has_case_markers == 1) {
        emit_parts_with_case_wrap($cg, \@parts);
        return;
    }

    # Generate code
    if (scalar(@parts) == 0) {
        Perla::CodeGen::emit($cg, "strada_new_str(\"\")");
        return;
    }
    if (scalar(@parts) == 1) {
        my str $p = $parts[0];
        if (substr($p, 0, 3) eq "QV:") {
            emit_interp_part($cg, $p);
            return;
        }
        if (substr($p, 0, 2) eq "S:") {
            # `use utf8` mirror — see the earlier S: emit for rationale.
            # ALSO emit the UTF-8 variant when the raw source contained
            # `\x{HEX}` / `\N{U+HEX}` / `\xHH` (>= 0x100) escapes that
            # expanded to multi-byte UTF-8 bytes ($has_high_escape). perl's
            # behavior: such escapes always produce a SVf_UTF8 string,
            # `use utf8` notwithstanding. Without this, Encode::encode and
            # other codepoint-aware ops see raw bytes instead of code points.
            my str $__sf_payload = substr($p, 2, length($p) - 2);
            my int $__sf_utf8 = 0;
            if (defined($cg->{"use_utf8"}) && $cg->{"use_utf8"} == 1) { $__sf_utf8 = 1; }
            if ($has_high_escape == 1) { $__sf_utf8 = 1; }
            if ($__sf_utf8 == 1) {
                Perla::CodeGen::emit($cg, "PERLA_NEW_STR_LIT_UTF8(\"" . $__sf_payload . "\")");
            } else {
                Perla::CodeGen::emit($cg, "PERLA_NEW_STR_LIT(\"" . $__sf_payload . "\")");
            }
        } elsif (substr($p, 0, 2) eq "@:") {
            my str $aname = substr($p, 2, length($p) - 2);
            # `@_` reads perla_at_ (the args array global), not v__a
            # (file-scope `_` array). Without this, `my $s = "@_"` and
            # similar interp uses read empty inside a sub even though
            # @_ is populated. Also honor $" (perla_lse) instead of
            # hardcoded " " — `local $" = ","; "@arr"` was joining
            # with space.
            my str $acname = ($aname eq "_") ? "perla_at_" : Perla::CodeGen::c_var_a($aname);
            Perla::CodeGen::emit($cg, "({ const char *__lse = (perla_lse && !STRADA_IS_TAGGED_INT(perla_lse) && perla_lse->type == STRADA_STR && perla_lse->value.pv) ? perla_lse->value.pv : \" \"; ");
            Perla::CodeGen::emit($cg, "char *__js = strada_join(__lse, strada_deref_array(" . $acname . ")); StradaValue *__jr = strada_new_str(__js); free(__js); __jr; })");
        } elsif (substr($p, 0, 2) eq "C:") {
            Perla::CodeGen::emit($cg, "strada_capture_var(" . substr($p, 2, length($p) - 2) . ")");
        } elsif (substr($p, 0, 2) eq "N:") {
            emit_interp_part($cg, $p);
        } elsif (substr($p, 0, 3) eq "MO:") {
            emit_interp_part($cg, $p);
        } elsif (substr($p, 0, 2) eq "H:" || substr($p, 0, 2) eq "D:"
                 || substr($p, 0, 2) eq "R:" || substr($p, 0, 2) eq "A:"
                 || substr($p, 0, 2) eq "Z:" || substr($p, 0, 3) eq "HQ:"
                 || substr($p, 0, 3) eq "ZP:") {
            # R: = scalar-deref array element ($ref->[N])
            # A: = sigil array element ($var[N])
            # Z: = chained subscript ($h{a}{b}, $r->{a}[0], etc.)
            # HQ: = quoted-key hash element ($h{'a-b'}) — literal key.
            # Without these in the single-part dispatch, `my $s = "\$r->[0]"`
            # fell through to the bare-var branch, c_var'd the encoded
            # name (`R:r:0` → `v_r_colon_0`), and read an undeclared C
            # static instead of doing the actual array fetch.
            emit_interp_part($cg, $p);
        } elsif (substr($p, 0, 3) eq "@D:" || substr($p, 0, 3) eq "DS:" || substr($p, 0, 3) eq "LH:" || substr($p, 0, 3) eq "LD:") {
            emit_interp_part($cg, $p);
        } elsif (substr($p, 0, 4) eq "@HD:" || substr($p, 0, 4) eq "@AD:" || substr($p, 0, 4) eq "@MA:") {
            emit_interp_part($cg, $p);
        } elsif (substr($p, 0, 5) eq "@RHD:" || substr($p, 0, 5) eq "@RAD:" ||
                 substr($p, 0, 5) eq "@SAR:" || substr($p, 0, 5) eq "@SHR:" ||
                 substr($p, 0, 5) eq "ASLI:" || substr($p, 0, 5) eq "HSLI:" ||
                 substr($p, 0, 5) eq "ADRX:") {
            emit_interp_part($cg, $p);
        } elsif (substr($p, 0, 2) eq "X:") {
            # `@{[EXPR]}` / `${\EXPR}` as the entire interp string. Without
            # this fall-through to the var branch treated the literal
            # body (e.g., "[ 'a', 'b', 'c' ]") as a scalar variable name
            # and emitted a v_<mangled> read instead of evaluating the
            # expression.
            emit_interp_part($cg, $p);
        } else {
            my str $vn = substr($p, 2, length($p) - 2);
            if ($vn eq "AUTOLOAD") { Perla::CodeGen::emit($cg, "perla_get_autoload_var()"); }
            elsif ($vn eq "@") { Perla::CodeGen::emit($cg, "perla_eval_error"); }
            elsif ($vn eq "!") { Perla::CodeGen::emit($cg, "strada_new_str(errno ? strerror(errno) : \"\")"); }
            elsif ($vn eq "0") { Perla::CodeGen::emit($cg, "(perla_dollar_zero ? ({ strada_incref(perla_dollar_zero); perla_dollar_zero; }) : strada_new_str(\"perla\"))"); }
        # \$ARGV — current filename during bare-diamond reads (set by
        # perla_readline_argv). Match N_SCALAR_VAR rule: read
        # perla_current_argv, fall back to undef when no diamond fired.
        elsif ($vn eq "ARGV") { Perla::CodeGen::emit($cg, "(perla_current_argv ? ({ strada_incref(perla_current_argv); perla_current_argv; }) : strada_new_undef())"); }
            elsif ($vn eq "?") { Perla::CodeGen::emit($cg, "STRADA_MAKE_TAGGED_INT((int64_t)perla_dollar_question)"); }
        elsif ($vn eq ".") { Perla::CodeGen::emit($cg, "STRADA_MAKE_TAGGED_INT((int64_t)perla_dollar_dot)"); }
        elsif ($vn eq "\$") { Perla::CodeGen::emit($cg, "STRADA_MAKE_TAGGED_INT((int64_t)getpid())"); }
            elsif ($vn eq "&") { Perla::CodeGen::emit($cg, "strada_capture_var(0)"); }
            elsif ($vn eq "`") { Perla::CodeGen::emit($cg, "strada_prematch()"); }
            elsif ($vn eq "'") { Perla::CodeGen::emit($cg, "strada_postmatch()"); }
            elsif ($vn eq "+") { Perla::CodeGen::emit($cg, "strada_last_paren_match()"); }
            elsif (length($vn) == 1 && ($vn eq "/" || $vn eq "\\" || $vn eq "," || $vn eq ";" || $vn eq "\"" || $vn eq "|" || $vn eq "+")) {
                # Use globals directly for IO specials so local{} is honored.
                # Mirrors the primary single-part path.
                if ($vn eq "\\") { Perla::CodeGen::emit($cg, "perla_ors"); }
                elsif ($vn eq "/") { Perla::CodeGen::emit($cg, "perla_irs"); }
                elsif ($vn eq ",") { Perla::CodeGen::emit($cg, "perla_ofs"); }
                elsif ($vn eq "\"") { Perla::CodeGen::emit($cg, "perla_lse"); }
                elsif ($vn eq "|") {
                    Perla::CodeGen::emit($cg, "STRADA_MAKE_TAGGED_INT((int64_t)(__perla_autoflush ? 1 : 0))");
                }
                else {
                    my str $esc_vn2 = $vn;
                    if ($esc_vn2 eq "\"") { $esc_vn2 = "\\\""; }
                    Perla::CodeGen::emit($cg, "perla_special_get(\"" . $esc_vn2 . "\")");
                }
            }
            elsif (length($vn) == 1 && ($vn eq "<" || $vn eq ">" || $vn eq "(" || $vn eq ")")) {
                # $</$>/$(/$) — UID/GID specials (mirrors primary path).
                if ($vn eq "<") {
                    Perla::CodeGen::emit($cg, "STRADA_MAKE_TAGGED_INT((int64_t)getuid())");
                } elsif ($vn eq ">") {
                    Perla::CodeGen::emit($cg, "STRADA_MAKE_TAGGED_INT((int64_t)geteuid())");
                } elsif ($vn eq "(") {
                    Perla::CodeGen::emit($cg, "STRADA_MAKE_TAGGED_INT((int64_t)getgid())");
                } else {
                    Perla::CodeGen::emit($cg, "STRADA_MAKE_TAGGED_INT((int64_t)getegid())");
                }
            }
            else {
                # "$var" must produce a STRING, applying any `""` overload
                # when $var is a blessed ref. Without this, `my $s = "$url"`
                # left $s as the blessed URI:: ref, and downstream code
                # (Data::Dumper, hash storage, JSON encoding) saw a ref
                # instead of the URI text. Stringification of a non-ref
                # str/int via strada_to_str is fast (just strdups).
                # `"$_"` must read perla_dollar_underscore (the global the
                # foreach/map/grep block updates), not v__ (file-scope $_).
                # Without this, `map { "$_" } @arr` returned empty strings.
                if ($vn ne "_") { Perla::CodeGen::_strict_check_var($cg, "\$", $vn, 0); }
                my str $sv_src = ($vn eq "_") ? "perla_dollar_underscore" : Perla::CodeGen::c_var($vn);
                # A REF stringifies (applies any `""` overload). A
                # FILEHANDLE does too — File::Temp blesses its handle and
                # overloads `""` to return the temp path; without this,
                # `my $name = "$fh"` passed the filehandle through as-is
                # instead of producing the path string.
                Perla::CodeGen::emit($cg, "({ StradaValue *__sv1 = " . $sv_src . "; ");
                Perla::CodeGen::emit($cg, "(__sv1 && !STRADA_IS_TAGGED_INT(__sv1) && (__sv1->type == STRADA_REF || __sv1->type == STRADA_FILEHANDLE)) ");
                Perla::CodeGen::emit($cg, "? ({ char *__ss1 = strada_to_str(__sv1); StradaValue *__sr1 = strada_new_str_take(__ss1); __sr1; }) ");
                Perla::CodeGen::emit($cg, ": __sv1; })");
            }
        }
        return;
    }

    # Multiple parts — sequential concat with cleanup (prevents intermediate leaks)
    Perla::CodeGen::emit($cg, "({ StradaValue *__ic = ");
    emit_interp_part($cg, $parts[0]);
    Perla::CodeGen::emit($cg, "; ");
    # If the seed part is a borrowed reference (V:/R:/A:), we need to incref
    # it into __ic. Otherwise, the first concat iteration's `strada_decref(__io)`
    # would drop a refcount we never gained, eventually freeing the backing
    # variable out from under its other uses. Example: interpolating the same
    # lexical `$class` twice in a sub with `my $class = ...; print "$class ..."; my $k = "$class::X";`
    # would free $class mid-sub, producing garbage on the next print.
    my str $p0prefix = substr($parts[0], 0, 2);
    if ($p0prefix eq "V:" || $p0prefix eq "R:" || $p0prefix eq "A:") {
        Perla::CodeGen::emit($cg, "strada_incref(__ic); ");
    }
    my int $pi = 1;
    while ($pi < scalar(@parts)) {
        my str $pp = $parts[$pi];
        # Check if this part is a temporary (needs decref) or borrowed (variable)
        my int $is_temp = 0;
        if (substr($pp, 0, 2) eq "S:" || substr($pp, 0, 2) eq "H:" || substr($pp, 0, 2) eq "D:" ||
            substr($pp, 0, 2) eq "@:" || substr($pp, 0, 2) eq "C:" ||
            substr($pp, 0, 2) eq "Z:" || substr($pp, 0, 2) eq "X:" ||
            substr($pp, 0, 2) eq "N:" || substr($pp, 0, 3) eq "MO:" ||
            substr($pp, 0, 3) eq "HQ:" || substr($pp, 0, 3) eq "ZP:" ||
            substr($pp, 0, 3) eq "@D:" ||
            substr($pp, 0, 3) eq "DS:" || substr($pp, 0, 3) eq "LH:" || substr($pp, 0, 3) eq "LD:" ||
            substr($pp, 0, 4) eq "@HD:" || substr($pp, 0, 4) eq "@AD:" ||
            substr($pp, 0, 5) eq "@RHD:" || substr($pp, 0, 5) eq "@RAD:" ||
            substr($pp, 0, 5) eq "@SAR:" || substr($pp, 0, 5) eq "@SHR:" ||
            substr($pp, 0, 5) eq "ASLI:" || substr($pp, 0, 5) eq "HSLI:" ||
            substr($pp, 0, 5) eq "ADRX:") {
            $is_temp = 1;
        }
        if ($is_temp == 1) {
            Perla::CodeGen::emit($cg, "{ StradaValue *__ir = ");
            emit_interp_part($cg, $pp);
            Perla::CodeGen::emit($cg, "; StradaValue *__io = __ic; __ic = strada_concat_sv(__ic, __ir); strada_decref(__io); strada_decref(__ir); } ");
        } else {
            Perla::CodeGen::emit($cg, "{ StradaValue *__io = __ic; __ic = strada_concat_sv(__ic, ");
            emit_interp_part($cg, $pp);
            Perla::CodeGen::emit($cg, "); strada_decref(__io); } ");
        }
        $pi++;
    }
    # Concat chain done. If the raw source had any high-codepoint escape
    # (`\x{HEX}` >= 0x80 / `\N{U+HEX}` / `\xHH` >= 0x100), tag the result
    # SV as UTF-8 so codepoint-aware ops (Encode, length, regex /u, etc.)
    # treat the multi-byte sequences as a single codepoint per perl
    # semantics. strada_concat_sv preserves the LHS flag, so for purely-
    # high-escape inputs this is a no-op; necessary when the LHS slot was
    # a non-utf8 variable but later parts include `\x{NNN}`.
    if ($has_high_escape == 1) {
        Perla::CodeGen::emit($cg, "strada_set_utf8_flag(__ic, 1); ");
    }
    Perla::CodeGen::emit($cg, "__ic; })");
}
func has_dollar_digit(str $s) int {
    my int $i = 0;
    my int $len = length($s);
    while ($i < $len - 1) {
        if (substr($s, $i, 1) eq "\\" && $i + 1 < $len) {
            $i = $i + 2;
            next;
        }
        if (substr($s, $i, 1) eq "$") {
            my str $next = substr($s, $i + 1, 1);
            if ($next ge "1" && $next le "9") { return 1; }
        }
        $i = $i + 1;
    }
    return 0;
}

## Like _has_perl_var, but for s/// replacement strings: \`\$+{NAME}\` is
## treated as a PCRE2 backref (not a real interpolation), so a string
## consisting only of those + literals comes back with has_var=0 and is
## passed straight to PCRE2.
# Detect replacement forms that need full Perl evaluation per match.
# A bare `$var` or PCRE2-style `$1`/`$2` can be handled by building the
# replacement string once and letting PCRE2 substitute backrefs. But
# `$hash{$1}` / `$arr[$1]` / `$ref->{key}` need the inner subscript
# (often containing a capture variable) evaluated AT EACH MATCH against
# the current capture state. The non-/e codegen path materializes the
# replacement once before the regex runs, so capture-driven subscripts
# silently read stale values.
#
# Restriction: only force /e when the ENTIRE trimmed replacement is
# itself an expression (parseable as Perl code). If the replacement
# is mostly literal text with embedded \`\$h{\$1}\` (e.g.,
# \`[\$1=\$lookup{\$1}]\`), /e would parse the literal characters as
# Perl source — turning \`[…]\` into an anon-array constructor and
# the \`=\` into an assignment to the readonly capture variable. Leave
# string-template replacements on the non-/e path; eat the
# \`v_hash + "{" + v_1 + "}"\` wrong output rather than emit invalid C.
func repl_needs_eval(str $s) int {
    my int $i = 0;
    my int $len = length($s);
    my int $found_access = 0;
    while ($i < $len - 1) {
        my str $c = substr($s, $i, 1);
        if ($c eq "\\" && $i + 1 < $len) { $i = $i + 2; next; }
        if ($c eq "$" || $c eq "@") {
            # Skip the sigil.
            my int $j = $i + 1;
            if ($j < $len && substr($s, $j, 1) eq "{") {
                # `${\ EXPR}` and `@{[ EXPR ]}` are Perl idioms for
                # inline expression interpolation — force /e codegen
                # so the expression is evaluated rather than emitted
                # literally. Without this, `s/(\w+)/${\ uc($1)}/g`
                # produced "{ uc()}" in the output.
                my int $jp = $j + 1;
                # Skip leading whitespace inside the braces.
                while ($jp < $len) {
                    my str $wc = substr($s, $jp, 1);
                    if ($wc eq " " || $wc eq "\t") { $jp = $jp + 1; } else { last; }
                }
                if ($jp < $len) {
                    my str $first = substr($s, $jp, 1);
                    if (($c eq "$" && $first eq "\\") ||
                        ($c eq "@" && $first eq "[")) {
                        return 1;
                    }
                }
                # `${...}` braced — could be `${name}` or `${name}{KEY}`.
                # Scan past matching `}` then check for `{`/`[`/`->`.
                my int $depth = 1;
                $j = $j + 1;
                while ($j < $len && $depth > 0) {
                    my str $bc = substr($s, $j, 1);
                    if ($bc eq "{") { $depth = $depth + 1; }
                    elsif ($bc eq "}") { $depth = $depth - 1; if ($depth == 0) { last; } }
                    $j = $j + 1;
                }
                if ($j < $len) { $j = $j + 1; }
            } else {
                # Consume identifier (and ::-qualified package parts).
                while ($j < $len) {
                    my str $vc = substr($s, $j, 1);
                    if (($vc ge "a" && $vc le "z") || ($vc ge "A" && $vc le "Z") || ($vc ge "0" && $vc le "9") || $vc eq "_") {
                        $j = $j + 1;
                    } elsif ($vc eq ":" && $j + 1 < $len && substr($s, $j + 1, 1) eq ":") {
                        $j = $j + 2;
                    } else { last; }
                }
            }
            # After consuming the var, peek for `{`, `[`, or `->`.
            if ($j < $len) {
                my str $after = substr($s, $j, 1);
                if ($after eq "{" || $after eq "[") { $found_access = 1; $i = $j; next; }
                if ($after eq "-" && $j + 1 < $len && substr($s, $j + 1, 1) eq ">") {
                    # `->` is only a real method/element access if it's
                    # followed by `[`, `{`, or a bareword identifier (the
                    # method name). When followed by `$`, `@`, `%`
                    # (another sigil) or anything else, `->` is literal
                    # string content — `s/(\w+)=(\d+)/[$1->$2]/g`
                    # produces `[$1->$2]` as a template, with $1/$2
                    # interpolated, not a method call on $1.
                    if ($j + 2 < $len) {
                        my str $ma = substr($s, $j + 2, 1);
                        if ($ma eq "[" || $ma eq "{"
                            || ($ma ge "a" && $ma le "z")
                            || ($ma ge "A" && $ma le "Z")
                            || $ma eq "_") {
                            $found_access = 1; $i = $j; next;
                        }
                    }
                    # Else fall through to plain interpolation.
                }
            }
            $i = $j;
            next;
        }
        $i = $i + 1;
    }
    if ($found_access == 0) { return 0; }
    # We saw at least one `$name{...}`/`$name[...]`/`$name->...` form.
    # Only force /e when the replacement is parseable as Perl code.
    # Heuristic: any literal `=` that's not a fat-arrow `=>`, or any
    # literal `;`, suggests this is a string template or multi-statement
    # blob, not a single expression. /e would mis-parse `[$1=…]` as
    # `[(\$1 = …)]` (assignment to readonly \$1). Skip /e force when
    # we see those.
    my int $k = 0;
    while ($k < $len) {
        my str $ch = substr($s, $k, 1);
        if ($ch eq "\\" && $k + 1 < $len) { $k = $k + 2; next; }
        if ($ch eq ";") { return 0; }
        if ($ch eq "=") {
            if ($k + 1 < $len && substr($s, $k + 1, 1) eq ">") {
                $k = $k + 2; next;  # `=>` is fine
            }
            return 0;
        }
        $k = $k + 1;
    }
    return 1;
}

func has_perl_var_repl(str $s) int {
    my int $i = 0;
    my int $len = length($s);
    while ($i < $len - 1) {
        if (substr($s, $i, 1) eq "\\" && $i + 1 < $len) { $i = $i + 2; next; }
        if (substr($s, $i, 1) eq "$") {
            my str $next = substr($s, $i + 1, 1);
            # \`\$+{NAME}\` — named-capture backref, NOT a var to interp.
            if ($next eq "+" && $i + 2 < $len && substr($s, $i + 2, 1) eq "{") {
                # skip to matching `}`
                my int $k = scan_balanced($s, $i + 3, "{", "}");
                $i = $k + 1;
                next;
            }
            if (($next ge "a" && $next le "z") || ($next ge "A" && $next le "Z") || $next eq "_") { return 1; }
            if ($next eq "{") {
                # `${digits}` is Perl's braced numeric backref (== $N).
                # PCRE2 handles `$N` natively, so don't interp these as
                # variables — let the runtime preprocess strip the braces
                # and pass `$N` to PCRE2. Detect by scanning to closing
                # `}`; all-digit interior → backref, not a var ref.
                my int $bk = $i + 2;
                my int $only_digits = 0;
                while ($bk < $len) {
                    my str $bc = substr($s, $bk, 1);
                    if ($bc ge "0" && $bc le "9") {
                        $only_digits = 1;
                        $bk = $bk + 1;
                    } elsif ($bc eq "}") { last; }
                    else { $only_digits = 0; last; }
                }
                if ($only_digits == 1 && $bk < $len && substr($s, $bk, 1) eq "}") {
                    $i = $bk + 1;
                    next;
                }
                return 1;
            }
            if ($next eq "@" || $next eq "!" || $next eq "/" || $next eq "\\" ||
                $next eq "," || $next eq ";" || $next eq "\"" || $next eq "&" ||
                $next eq "`" || $next eq "'" || $next eq "+" || $next eq "0" ||
                $next eq "|" || $next eq ".") {
                return 1;
            }
        }
        if (substr($s, $i, 1) eq "@") {
            my str $next = substr($s, $i + 1, 1);
            if (($next ge "a" && $next le "z") || ($next ge "A" && $next le "Z") || $next eq "_" || $next eq "{") {
                return 1;
            }
        }
        $i = $i + 1;
    }
    return 0;
}
# Generate a C expression for an interpolated pattern string containing $var
# Returns a StradaValue* that is the concatenated result
func gen_interp_c_str(scalar $cg, str $s) void {
    # Collect parts: alternating literals and variable names
    my array @parts = ();
    my array @types = ();
    my int $len = length($s);
    my int $i = 0;
    my str $buf = "";

    while ($i < $len) {
        my str $ch = substr($s, $i, 1);
        # `\$` and `\@` escape the sigil — pass both chars through as
        # literal so the result reaches PCRE2 (or the destination) with
        # the backslash intact. Without this, regex patterns like
        # `s/\$bar/X/` interpolated $bar as a variable instead of
        # matching the literal `$bar` substring.
        if ($ch eq "\\" && $i + 1 < $len) {
            my str $nx = substr($s, $i + 1, 1);
            if ($nx eq "\$" || $nx eq "@") {
                $buf = $buf . $ch . $nx;
                $i = $i + 2;
                next;
            }
        }
        if ($ch eq "$" && $i + 1 < $len) {
            # Peek-ahead: only treat `$` as variable interpolation when
            # followed by `{`, alphanumeric, or `_`. For `$|`, `$)`, `$+`,
            # `$,`, etc., emit `$` as a literal. Otherwise the `$` would
            # be consumed and lost — corrupting regex patterns like
            # `(?=...|$)` (the YAML loader's _parse_inline_simple anchor
            # check) into `(?=...|)` which matches empty everywhere and
            # breaks parsing. Memory: project_perla_dollar_alt_in_string
            # documented the same fix for the OTHER interp path; this one
            # was missed.
            my str $nxt = substr($s, $i + 1, 1);
            my int $is_ident_start = 0;
            if ($nxt eq "{") { $is_ident_start = 1; }
            elsif (($nxt ge "a" && $nxt le "z") || ($nxt ge "A" && $nxt le "Z") || $nxt eq "_") { $is_ident_start = 1; }
            elsif ($nxt ge "0" && $nxt le "9") { $is_ident_start = 1; }
            if ($is_ident_start == 0) {
                $buf = $buf . $ch;
                $i = $i + 1;
                next;
            }
            if (length($buf) > 0) {
                push(@parts, $buf);
                push(@types, "str");
                $buf = "";
            }
            $i = $i + 1;
            my str $vname = "";
            # Braced form: ${name}. Skip the `{`, read the name, skip the `}`.
            # Without this, `s/^${pref}-/X/` left vname empty and the
            # leading `{pref}` chars were emitted as a literal — same
            # bug bites regex pattern interpolation through this same path.
            my int $braced = 0;
            if ($i < $len && substr($s, $i, 1) eq "{") {
                $braced = 1;
                $i = $i + 1;
            }
            while ($i < $len) {
                my str $vc = substr($s, $i, 1);
                if (($vc ge "a" && $vc le "z") || ($vc ge "A" && $vc le "Z") || ($vc ge "0" && $vc le "9") || $vc eq "_") {
                    $vname = $vname . $vc;
                    $i = $i + 1;
                } elsif ($vc eq ":" && $i + 1 < $len && substr($s, $i + 1, 1) eq ":") {
                    # `::` is part of the name only if followed by an ident
                    # char. `$Pkg::var` resolves the package-qualified name;
                    # `$URI::scheme_re` is one var, not `$URI` + literal
                    # "::scheme_re". Without this, URI::_generic's
                    # `$$self =~ m,...$URI::scheme_re...,os` matched bogus
                    # text — host parsing failed, host() returned empty.
                    if ($i + 2 < $len) {
                        my str $vc2 = substr($s, $i + 2, 1);
                        if (($vc2 ge "a" && $vc2 le "z") || ($vc2 ge "A" && $vc2 le "Z") || $vc2 eq "_") {
                            $vname = $vname . "::";
                            $i = $i + 2;
                        } else { last; }
                    } else { last; }
                } else { last; }
            }
            # Close the brace if we opened one. Subscript access via the
            # braced form (`${name}[N]`, `${name}{K}`) is rare; the
            # natural form for that is `$name[N]` / `$name{K}` (no braces).
            # Keep this case as a simple "emit variable" — same behavior
            # as Perl's interpolator for the braced form.
            if ($braced == 1 && $i < $len && substr($s, $i, 1) eq "}") {
                $i = $i + 1;
            }
            if (length($vname) > 0 && $braced == 1) {
                push(@parts, $vname);
                push(@types, "var");
            } elsif (length($vname) > 0) {
                # Check for subscript access: `$arr[N]`, `$arr->[N]`,
                # `$h{K}`, `$h->{K}`. Without this, `s/$arr[0]/X/` saw
                # the pattern as `<value of $arr> . "[0]"` (literal `[0]`
                # appended) so the regex never matched anything. Common
                # idiom: iterating a list of compiled regexes to apply
                # serial substitutions.
                # Recognize the explicit arrow form first so `$arr->[N]`
                # doesn't get split at `->`.
                my int $consumed_arrow = 0;
                my int $is_deref = 0;
                if ($i + 1 < $len && substr($s, $i, 2) eq "->") {
                    my str $after_arrow = substr($s, $i + 2, 1);
                    if ($after_arrow eq "[" || $after_arrow eq "{") {
                        $consumed_arrow = 1;
                        $is_deref = 1;
                        $i = $i + 2;
                    }
                }
                if ($i < $len && substr($s, $i, 1) eq "[") {
                    # Array subscript: numeric, $var, or simple expression
                    my int $ks = $i + 1;
                    my int $ke = $ks;
                    my int $depth = 1;
                    while ($ke < $len && $depth > 0) {
                        my str $kc = substr($s, $ke, 1);
                        if ($kc eq "[") { $depth = $depth + 1; }
                        elsif ($kc eq "]") { $depth = $depth - 1; if ($depth == 0) { last; } }
                        $ke = $ke + 1;
                    }
                    if ($ke < $len) {
                        my str $idx_raw = substr($s, $ks, $ke - $ks);
                        push(@parts, "AE:" . ($is_deref ? "D:" : "S:") . $vname . ":" . $idx_raw);
                        push(@types, "expr");
                        $i = $ke + 1;
                    } else {
                        push(@parts, $vname);
                        push(@types, "var");
                    }
                } elsif ($i < $len && substr($s, $i, 1) eq "{") {
                    # Hash subscript
                    my int $ks = $i + 1;
                    my int $ke = $ks;
                    my int $depth = 1;
                    while ($ke < $len && $depth > 0) {
                        my str $kc = substr($s, $ke, 1);
                        if ($kc eq "{") { $depth = $depth + 1; }
                        elsif ($kc eq "}") { $depth = $depth - 1; if ($depth == 0) { last; } }
                        $ke = $ke + 1;
                    }
                    if ($ke < $len) {
                        my str $key_raw = substr($s, $ks, $ke - $ks);
                        push(@parts, "HE:" . ($is_deref ? "D:" : "S:") . $vname . ":" . $key_raw);
                        push(@types, "expr");
                        $i = $ke + 1;
                    } else {
                        push(@parts, $vname);
                        push(@types, "var");
                    }
                } else {
                    push(@parts, $vname);
                    push(@types, "var");
                }
            }
        } else {
            $buf = $buf . $ch;
            $i = $i + 1;
        }
    }
    if (length($buf) > 0) { push(@parts, $buf); push(@types, "str"); }

    # Generate concat chain
    my int $count = scalar(@parts);
    if ($count == 0) {
        Perla::CodeGen::emit($cg, "strada_new_str(\"\")");
        return;
    }
    if ($count == 1) {
        if ($types[0] eq "var") { emit_interpc_var($cg, $parts[0]); }
        elsif ($types[0] eq "expr") { emit_interpc_expr($cg, $parts[0]); }
        else { Perla::CodeGen::emit($cg, "strada_new_str(\"" . Perla::CodeGen::Escape::escape_c_str($parts[0]) . "\")"); }
        return;
    }
    # Multiple parts — build concat chain
    Perla::CodeGen::emit($cg, "({ StradaValue *__ip = ");
    if ($types[0] eq "var") { emit_interpc_var($cg, $parts[0]); }
    elsif ($types[0] eq "expr") { emit_interpc_expr($cg, $parts[0]); }
    else { Perla::CodeGen::emit($cg, "strada_new_str(\"" . Perla::CodeGen::Escape::escape_c_str($parts[0]) . "\")"); }
    Perla::CodeGen::emit($cg, "; ");
    my int $pi = 1;
    while ($pi < $count) {
        Perla::CodeGen::emit($cg, "__ip = strada_concat_sv(__ip, ");
        if ($types[$pi] eq "var") { emit_interpc_var($cg, $parts[$pi]); }
        elsif ($types[$pi] eq "expr") { emit_interpc_expr($cg, $parts[$pi]); }
        else { Perla::CodeGen::emit($cg, "strada_new_str(\"" . Perla::CodeGen::Escape::escape_c_str($parts[$pi]) . "\")"); }
        Perla::CodeGen::emit($cg, "); ");
        $pi = $pi + 1;
    }
    Perla::CodeGen::emit($cg, "__ip; })");
}

# Emit a subscript expression (AE: or HE: prefix) inside regex pattern
# interpolation. Supports the four sigil-promoted forms:
#   AE:S:NAME:IDX   $NAME[IDX]   — array @NAME element (sigil)
#   AE:D:NAME:IDX   $NAME->[IDX] — scalar $NAME as arrayref, deref
#   HE:S:NAME:KEY   $NAME{KEY}   — hash %NAME element (sigil)
#   HE:D:NAME:KEY   $NAME->{KEY} — scalar $NAME as hashref, deref
func emit_interpc_expr(scalar $cg, str $part) void {
    my str $kind = substr($part, 0, 2);
    my str $rest = substr($part, 3, length($part) - 3);
    my str $deref = substr($rest, 0, 1);
    my int $sep_after_deref = index($rest, ":");
    my str $sub_rest = substr($rest, $sep_after_deref + 1, length($rest) - $sep_after_deref - 1);
    my int $sep_after_name = index($sub_rest, ":");
    my str $vname = substr($sub_rest, 0, $sep_after_name);
    my str $idx_raw = substr($sub_rest, $sep_after_name + 1, length($sub_rest) - $sep_after_name - 1);
    if ($kind eq "AE") {
        # Array element: deref source to get the array
        my str $src = "";
        if ($deref eq "D") {
            # $NAME->[IDX] — NAME is a scalar holding an arrayref
            $src = ($vname eq "_") ? "perla_dollar_underscore" : Perla::CodeGen::c_var($vname);
        } else {
            # $NAME[IDX] — NAME is the array @NAME (or @_ for $_[N])
            $src = ($vname eq "_") ? "perla_at_" : Perla::CodeGen::c_var_a($vname);
        }
        # Index may be a number, $var, or expression. Plain digits are
        # the common case; for variables / arrows fall back to a string-
        # to-int conversion via the interp result (recursing into
        # gen_interp_c_str is overkill for the typical [\$i] case, just
        # handle the simple `$NAME` index form).
        my int $is_num = 1;
        if (length($idx_raw) == 0) { $is_num = 0; }
        my int $ii = 0;
        while ($ii < length($idx_raw)) {
            my str $ic = substr($idx_raw, $ii, 1);
            if (!(($ic ge "0" && $ic le "9") || ($ii == 0 && $ic eq "-"))) { $is_num = 0; last; }
            $ii = $ii + 1;
        }
        if ($is_num == 1) {
            Perla::CodeGen::emit($cg, "({ StradaArray *__iea = strada_deref_array(" . $src . "); int __iei = " . $idx_raw . "; if (__iei < 0 && __iea) __iei += strada_array_length(__iea); StradaValue *__iev = strada_array_get(__iea, __iei); __iev; })");
        } elsif (length($idx_raw) > 0 && substr($idx_raw, 0, 1) eq "$") {
            my str $idx_var = substr($idx_raw, 1, length($idx_raw) - 1);
            my str $idx_c = ($idx_var eq "_") ? "perla_dollar_underscore" : Perla::CodeGen::c_var($idx_var);
            Perla::CodeGen::emit($cg, "({ StradaArray *__iea = strada_deref_array(" . $src . "); int __iei = (int)strada_to_int(" . $idx_c . "); if (__iei < 0 && __iea) __iei += strada_array_length(__iea); StradaValue *__iev = strada_array_get(__iea, __iei); __iev; })");
        } else {
            # Fallback — emit literal 0
            Perla::CodeGen::emit($cg, "strada_array_get(strada_deref_array(" . $src . "), 0)");
        }
    } else {
        # HE — hash element
        my str $src = "";
        if ($deref eq "D") {
            $src = ($vname eq "_") ? "perla_dollar_underscore" : Perla::CodeGen::c_var($vname);
        } else {
            $src = ($vname eq "_") ? "perla_dollar_underscore" : Perla::CodeGen::c_var_h($vname);
        }
        my str $key = $idx_raw;
        # Strip surrounding quotes if present
        if (length($key) >= 2 && (substr($key, 0, 1) eq "'" || substr($key, 0, 1) eq "\"")
            && substr($key, length($key) - 1, 1) eq substr($key, 0, 1)) {
            $key = substr($key, 1, length($key) - 2);
        }
        if (length($key) > 0 && substr($key, 0, 1) eq "$") {
            my str $kvar = substr($key, 1, length($key) - 1);
            my str $kvar_c = ($kvar eq "_") ? "perla_dollar_underscore" : Perla::CodeGen::c_var($kvar);
            Perla::CodeGen::emit($cg, "({ char *__hek = strada_to_str(" . $kvar_c . "); StradaValue *__hev = strada_hv_fetch_owned(" . $src . ", __hek); free(__hek); __hev; })");
        } else {
            Perla::CodeGen::emit($cg, "strada_hv_fetch_owned(" . $src . ", \"" . Perla::CodeGen::Escape::escape_c_str($key) . "\")");
        }
    }
}

# Emit a $var reference in regex pattern interpolation. Handles
# package-qualified names like $URI::scheme_re via perla_scalar_get.
func emit_interpc_var(scalar $cg, str $vn) void {
    if (index($vn, "::") > 0) {
        # Split at LAST `::` — package-qualified scalar
        my int $li = -1;
        my int $si = 0;
        while ($si < length($vn) - 1) {
            if (substr($vn, $si, 2) eq "::") { $li = $si; }
            $si++;
        }
        my str $vpkg = substr($vn, 0, $li);
        my str $vleaf = substr($vn, $li + 2, length($vn) - $li - 2);
        Perla::CodeGen::emit($cg, "perla_scalar_get(\"" . $vpkg . "\", \"" . $vleaf . "\")");
    } else {
        Perla::CodeGen::_strict_check_var($cg, "\$", $vn, 0);
        # Same predicate-divergence workaround as the V: handler above.
        my str $__cv_v = Perla::CodeGen::c_var($vn);
        Perla::CodeGen::emit($cg, $__cv_v);
    }
}
