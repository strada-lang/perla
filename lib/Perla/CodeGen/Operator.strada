                    Perla::CodeGen::emit($cg, "{ char *__sstr_s = strada_to_str(" . $sstr_cvar . "); ");
                    Perla::CodeGen::emit($cg, "strada_substr_assign(&");
                    Perla::CodeGen::gen_expr($cg, $sstr_args->[0]);
                    Perla::CodeGen::emit($cg, ", (int64_t)strada_to_int(");
                    Perla::CodeGen::gen_expr($cg, $sstr_args->[1]);
                    Perla::CodeGen::emit($cg, "), ");
                    if (scalar(@{$sstr_args}) >= 3) {
                        Perla::CodeGen::emit($cg, "(int64_t)strada_to_int(");
                        Perla::CodeGen::gen_expr($cg, $sstr_args->[2]);
                        Perla::CodeGen::emit($cg, ")");
                    } else {
                        Perla::CodeGen::emit($cg, "(int64_t)999999");
                    }
                    Perla::CodeGen::emit($cg, ", __sstr_s); free(__sstr_s); } ");
                }
                Perla::CodeGen::emit($cg, "if (" . $sstr_cvar . ") strada_decref(" . $sstr_cvar . "); ");
                Perla::CodeGen::emit($cg, "__sstr_r; })");
                return;
            }
            # tr/from/to/flags — transliteration. Perl semantics:
            #   tr/abc/xyz/  : a→x, b→y, c→z. Counts replacements.
            #   tr/abc//     : count matches; do NOT replace (still counts).
            #   tr/abc//d    : delete matched chars from result.
            #   tr/abc/xy/   : a→x, b→y, c→y (last char of `to` repeated).
            #   tr/abc/xy/d  : a→x, b→y, c→DELETED.
            # Previous codegen ignored /d and didn't count when `to` was empty.
            my str $from = Perla::CodeGen::Escape::escape_c_str(Perla::CodeGen::Escape::expand_tr_charset($right->{"from"}));
            my str $to = Perla::CodeGen::Escape::escape_c_str(Perla::CodeGen::Escape::expand_tr_charset($right->{"to"}));
            my str $tr_flags = "";
            if (defined($right->{"flags"})) { $tr_flags = "" . $right->{"flags"}; }
            my int $tr_del = 0;
            my int $tr_c = 0;
            my int $tr_s = 0;
            my int $tr_r = 0;
            if (index($tr_flags, "d") >= 0) { $tr_del = 1; }
            if (index($tr_flags, "c") >= 0) { $tr_c = 1; }
            if (index($tr_flags, "s") >= 0) { $tr_s = 1; }
            if (index($tr_flags, "r") >= 0) { $tr_r = 1; }
            # Capture LHS SV so we can branch on SVf_UTF8 — char-oriented
            # tr/// needs to decode codepoints, not bytes (otherwise
            # tr/é/X/ replaces both bytes of é with X, doubling the
            # count and corrupting the result). Use a ternary stmt-expr
            # for the branch so the outer expression yields a value
            # whichever path runs.
            Perla::CodeGen::emit($cg, "({ StradaValue *__tr_lhs = ");
            Perla::CodeGen::gen_expr($cg, $node->{"left"});
            Perla::CodeGen::emit($cg, "; int __tr_is_utf8 = (__tr_lhs && !STRADA_IS_TAGGED_INT(__tr_lhs) && __tr_lhs->type == STRADA_STR && STRADA_STR_IS_UTF8(__tr_lhs)); ");
            Perla::CodeGen::emit($cg, "const char *__from = \"" . $from . "\"; const char *__to = \"" . $to . "\"; size_t __fl_ = strlen(__from); size_t __tl_ = strlen(__to); (void)__fl_; (void)__tl_; ");
            Perla::CodeGen::emit($cg, "__tr_is_utf8 ? ({ ");
            Perla::CodeGen::emit($cg, "char *__s_u = strada_to_str(__tr_lhs); size_t __sl_u = strlen(__s_u); int __cnt_u = 0; ");
            Perla::CodeGen::emit($cg, "char *__r_u = strada_tr_utf8(__s_u, __sl_u, __from, __to, " . $tr_del . ", " . $tr_c . ", " . $tr_s . ", &__cnt_u); ");
            if ($tr_r == 1) {
                Perla::CodeGen::emit($cg, "StradaValue *__nv_u = strada_new_str_like(__r_u, __tr_lhs); free(__r_u); free(__s_u); __nv_u; }) : ({ ");
            } else {
                Perla::CodeGen::emit($cg, "StradaValue *__nv_u = strada_new_str_like(__r_u, __tr_lhs); ");
                Perla::CodeGen::Subst::emit_subst_writeback($cg, $node->{"left"}, "__nv_u");
                Perla::CodeGen::emit($cg, " free(__r_u); free(__s_u); STRADA_MAKE_TAGGED_INT(__cnt_u); }) : ({ ");
            }
            # Fallthrough byte-oriented path (original).
            Perla::CodeGen::emit($cg, "char *__s = strada_to_str(__tr_lhs); ");
            Perla::CodeGen::emit($cg, "size_t __sl = strlen(__s); char *__r = malloc(__sl + 1); size_t __ri = 0; int __cnt = 0; ");
            Perla::CodeGen::emit($cg, "size_t __fl = __fl_; size_t __tl = __tl_; ");
            Perla::CodeGen::emit($cg, "int __last_was_xlated = 0; (void)__last_was_xlated; char __last_xlated = 0; (void)__last_xlated; ");
            Perla::CodeGen::emit($cg, "for (size_t __ti = 0; __ti < __sl; __ti++) { char *__fp = memchr(__from, __s[__ti], __fl); ");
            # /c flips the matched-vs-unmatched logic. Build:
            #   bool matched = /c ? (__fp == NULL) : (__fp != NULL)
            if ($tr_c == 1) {
                Perla::CodeGen::emit($cg, "if (!__fp) { __cnt++; ");
            } else {
                Perla::CodeGen::emit($cg, "if (__fp) { __cnt++; ");
            }
            Perla::CodeGen::emit($cg, "  char __xl;  int __is_xl = 1; ");
            if ($tr_c == 1) {
                # complement: matched chars are not in `from`. Map to LAST char
                # of `to` (or delete with /d).
                if ($tr_del == 1) {
                    Perla::CodeGen::emit($cg, "  __is_xl = 0; ");
                } else {
                    Perla::CodeGen::emit($cg, "  __xl = __tl > 0 ? __to[__tl - 1] : __s[__ti]; ");
                }
            } else {
                Perla::CodeGen::emit($cg, "  ptrdiff_t __idx = __fp - __from; ");
                Perla::CodeGen::emit($cg, "  if (__tl == 0) { ");
                if ($tr_del == 1) {
                    Perla::CodeGen::emit($cg, "    __is_xl = 0; ");
                } else {
                    Perla::CodeGen::emit($cg, "    __xl = __s[__ti]; ");
                }
                Perla::CodeGen::emit($cg, "  } else if ((size_t)__idx < __tl) { __xl = __to[__idx]; ");
                Perla::CodeGen::emit($cg, "  } else { ");
                if ($tr_del == 1) {
                    Perla::CodeGen::emit($cg, "    __is_xl = 0; ");
                } else {
                    Perla::CodeGen::emit($cg, "    __xl = __to[__tl - 1]; ");
                }
                Perla::CodeGen::emit($cg, "  } ");
            }
            if ($tr_s == 1) {
                # squeeze: skip consecutive identical translated chars
                Perla::CodeGen::emit($cg, "  if (__is_xl) { if (!(__last_was_xlated && __last_xlated == __xl)) { __r[__ri++] = __xl; __last_xlated = __xl; } __last_was_xlated = 1; } else { __last_was_xlated = 0; } ");
            } else {
                Perla::CodeGen::emit($cg, "  if (__is_xl) __r[__ri++] = __xl; ");
                Perla::CodeGen::emit($cg, "  __last_was_xlated = 0; ");
            }
            Perla::CodeGen::emit($cg, "} else { __r[__ri++] = __s[__ti]; __last_was_xlated = 0; } } __r[__ri] = 0; ");
            if ($tr_r == 1) {
                # /r — return the modified string, leave source untouched.
                Perla::CodeGen::emit($cg, "StradaValue *__nv = strada_new_str(__r); free(__r); free(__s); __nv; }); })");
            } else {
                Perla::CodeGen::emit($cg, "{ StradaValue *__nv = strada_new_str(__r); ");
                Perla::CodeGen::Subst::emit_subst_writeback($cg, $node->{"left"}, "__nv");
                Perla::CodeGen::emit($cg, "} free(__r); free(__s); STRADA_MAKE_TAGGED_INT(__cnt); }); })");
            }
        } else {
            # `$str =~ $pat_or_qr` — RHS is a variable or expression
            # holding either a plain string pattern or a qr// stringified
            # as `(?FLAGS:PATTERN)`. PCRE accepts the embedded-flag form
            # natively, so passing the whole string as pattern works.
            Perla::CodeGen::emit($cg, "({ char *__rs = strada_to_str(");
            Perla::CodeGen::gen_expr($cg, $node->{"left"});
            Perla::CodeGen::emit($cg, "); char *__rp = strada_to_str(");
            Perla::CodeGen::gen_expr($cg, $right);
            Perla::CodeGen::emit($cg, "); int __rm = strada_regex_match_with_capture(__rs, __rp, \"\"); free(__rs); free(__rp); STRADA_MAKE_TAGGED_INT(__rm); })");
        }
        if (defined($cg->{"_subst_hoist_wrap"}) && $cg->{"_subst_hoist_wrap"} == 1) { Perla::CodeGen::emit($cg, ")"); $cg->{"_subst_hoist_wrap"} = 0; }
        return;
    }
    if ($op eq "!~") {
        my scalar $right = $node->{"right"};
        if (defined($right) && $right->{"type"} == Perla::AST::N_REGEX()) {
            my str $pat = Perla::CodeGen::Escape::escape_c_str($right->{"pattern"});
            my str $flags = "";
            if (defined($right->{"flags"})) { $flags = $right->{"flags"}; }
            # Interpolate $var in pattern. URI::implementor's
            # `$scheme !~ /\A$scheme_re\z/o` was emitting the literal
            # "\A$scheme_re\z" as pattern — so EVERY scheme failed the
            # match and URI->new returned URI::_generic instead of
            # URI::https.
            my int $not_pat_has_var = Perla::CodeGen::has_perl_var($pat);
            Perla::CodeGen::emit($cg, "({ char *__rs = strada_to_str(");
            Perla::CodeGen::gen_expr($cg, $node->{"left"});
            if ($not_pat_has_var == 1) {
                Perla::CodeGen::emit($cg, "); char *__pat = strada_to_str(");
                Perla::CodeGen::Interp::gen_interp_c_str($cg, $right->{"pattern"});
                Perla::CodeGen::emit($cg, "); int __rm = !strada_regex_match_with_capture(__rs, __pat, \"" . $flags . "\"); free(__pat); free(__rs); STRADA_MAKE_TAGGED_INT(__rm); })");
            } else {
                Perla::CodeGen::emit($cg, "); int __rm = !strada_regex_match_with_capture(__rs, \"" . $pat . "\", \"" . $flags . "\"); free(__rs); STRADA_MAKE_TAGGED_INT(__rm); })");
            }
        } else {
            Perla::CodeGen::emit($cg, "({ char *__rs = strada_to_str(");
            Perla::CodeGen::gen_expr($cg, $node->{"left"});
            Perla::CodeGen::emit($cg, "); char *__rp = strada_to_str(");
            Perla::CodeGen::gen_expr($cg, $right);
            Perla::CodeGen::emit($cg, "); int __rm = !strada_regex_match_with_capture(__rs, __rp, \"\"); free(__rs); free(__rp); STRADA_MAKE_TAGGED_INT(__rm); })");
        }
        return;
    }

    # Fallback
    Perla::CodeGen::emit($cg, "strada_new_undef() /* TODO: binop " . $op . " */");
}

# --- Unary operations ---
func _gen_unop(scalar $cg, scalar $node) void {
    my str $op = $node->{"op"};

    # File test operators
    if ($op eq "-e" || $op eq "-f" || $op eq "-d" || $op eq "-r" || $op eq "-w" || $op eq "-x" || $op eq "-s" || $op eq "-z" || $op eq "-l" || $op eq "-T" || $op eq "-B" || $op eq "-t" || $op eq "-p" || $op eq "-S" || $op eq "-b" || $op eq "-c" || $op eq "-u" || $op eq "-g" || $op eq "-k" || $op eq "-o" || $op eq "-O" || $op eq "-R" || $op eq "-W" || $op eq "-X" || $op eq "-M" || $op eq "-A" || $op eq "-C") {
        # `-X _` reuses the previous stat. Detect bareword `_` operand
        # (parsed as N_CALL with name="_" and no args) and route through a
        # cached path. YAML::Tiny's `-e $f; -f _; -r _` idiom needs this:
        # without it, `-f _` checked a literal file named "_" which doesn't
        # exist, and YAML::Tiny falsely reported any real file as a directory.
        my int $is_stat_cache = 0;
        my scalar $op_arg = $node->{"operand"};
        if (defined($op_arg) && $op_arg->{"type"} == Perla::AST::N_CALL()
            && defined($op_arg->{"name"}) && $op_arg->{"name"} eq "_") {
            $is_stat_cache = 1;
        }
        if ($op eq "-e") {
            if ($is_stat_cache == 1) {
                Perla::CodeGen::emit($cg, "STRADA_MAKE_TAGGED_INT(perla_last_stat_path[0] ? strada_file_exists(perla_last_stat_path) : 0)");
            } else {
                Perla::CodeGen::emit($cg, "({ char *__fp = strada_to_str(");
                Perla::CodeGen::gen_expr($cg, $node->{"operand"});
                Perla::CodeGen::emit($cg, "); perla_remember_stat_path(__fp); StradaValue *__fr = STRADA_MAKE_TAGGED_INT(strada_file_exists(__fp)); free(__fp); __fr; })");
            }
        } elsif ($op eq "-f") {
            if ($is_stat_cache == 1) {
                Perla::CodeGen::emit($cg, "({ StradaValue *__fp = strada_new_str(perla_last_stat_path); StradaValue *__fr = strada_is_file(__fp); strada_decref(__fp); __fr; })");
            } else {
                Perla::CodeGen::emit($cg, "strada_is_file(");
                Perla::CodeGen::gen_expr($cg, $node->{"operand"});
                Perla::CodeGen::emit($cg, ")");
            }
        } elsif ($op eq "-d") {
            if ($is_stat_cache == 1) {
                Perla::CodeGen::emit($cg, "({ StradaValue *__fp = strada_new_str(perla_last_stat_path); StradaValue *__fr = strada_is_dir(__fp); strada_decref(__fp); __fr; })");
            } else {
                Perla::CodeGen::emit($cg, "strada_is_dir(");
                Perla::CodeGen::gen_expr($cg, $node->{"operand"});
                Perla::CodeGen::emit($cg, ")");
            }
        } elsif ($op eq "-s") {
            # Return size in bytes (or undef if file doesn't exist). The
            # `-e` fallthrough below made `-s $f` return 1/0, which broke
            # the common `read($fh, $buf, -s $f)` idiom for slurping a
            # file by its size — read(…, …, 1) returned one byte.
            if ($is_stat_cache == 1) {
                Perla::CodeGen::emit($cg, "({ struct stat __fs; StradaValue *__fr; if (perla_last_stat_path[0] && stat(perla_last_stat_path, &__fs) == 0) __fr = STRADA_MAKE_TAGGED_INT((int64_t)__fs.st_size); else __fr = strada_new_undef(); __fr; })");
            } else {
                Perla::CodeGen::emit($cg, "({ char *__fp = strada_to_str(");
                Perla::CodeGen::gen_expr($cg, $node->{"operand"});
                Perla::CodeGen::emit($cg, "); perla_remember_stat_path(__fp); struct stat __fs; StradaValue *__fr; if (stat(__fp, &__fs) == 0) __fr = STRADA_MAKE_TAGGED_INT((int64_t)__fs.st_size); else __fr = strada_new_undef(); free(__fp); __fr; })");
            }
        } elsif ($op eq "-z") {
            if ($is_stat_cache == 1) {
                Perla::CodeGen::emit($cg, "({ struct stat __fs; StradaValue *__fr; if (perla_last_stat_path[0] && stat(perla_last_stat_path, &__fs) == 0) __fr = STRADA_MAKE_TAGGED_INT(__fs.st_size == 0 ? 1 : 0); else __fr = strada_new_undef(); __fr; })");
            } else {
                Perla::CodeGen::emit($cg, "({ char *__fp = strada_to_str(");
                Perla::CodeGen::gen_expr($cg, $node->{"operand"});
                Perla::CodeGen::emit($cg, "); perla_remember_stat_path(__fp); struct stat __fs; StradaValue *__fr; if (stat(__fp, &__fs) == 0) __fr = STRADA_MAKE_TAGGED_INT(__fs.st_size == 0 ? 1 : 0); else __fr = strada_new_undef(); free(__fp); __fr; })");
            }
        } elsif ($op eq "-T" || $op eq "-B") {
            my str $fn = $op eq "-T" ? "strada_file_is_text" : "strada_file_is_binary";
            if ($is_stat_cache == 1) {
                Perla::CodeGen::emit($cg, "({ StradaValue *__fp = strada_new_str(perla_last_stat_path); perla_remember_stat_path(perla_last_stat_path); StradaValue *__fr = " . $fn . "(__fp); strada_decref(__fp); __fr; })");
            } else {
                Perla::CodeGen::emit($cg, $fn . "(");
                Perla::CodeGen::gen_expr($cg, $node->{"operand"});
                Perla::CodeGen::emit($cg, ")");
            }
        } elsif ($op eq "-l") {
            # Symlink test — uses lstat to avoid following.
            if ($is_stat_cache == 1) {
                Perla::CodeGen::emit($cg, "({ struct stat __fs; StradaValue *__fr; if (perla_last_stat_path[0] && lstat(perla_last_stat_path, &__fs) == 0 && S_ISLNK(__fs.st_mode)) __fr = STRADA_MAKE_TAGGED_INT(1); else __fr = STRADA_MAKE_TAGGED_INT(0); __fr; })");
            } else {
                Perla::CodeGen::emit($cg, "({ char *__fp = strada_to_str(");
                Perla::CodeGen::gen_expr($cg, $node->{"operand"});
                Perla::CodeGen::emit($cg, "); perla_remember_stat_path(__fp); struct stat __fs; StradaValue *__fr; if (lstat(__fp, &__fs) == 0 && S_ISLNK(__fs.st_mode)) __fr = STRADA_MAKE_TAGGED_INT(1); else __fr = STRADA_MAKE_TAGGED_INT(0); free(__fp); __fr; })");
            }
        } elsif ($op eq "-r" || $op eq "-w" || $op eq "-x") {
            # Use access(2) with appropriate mode flag.
            my str $mode = "R_OK";
            if ($op eq "-w") { $mode = "W_OK"; }
            elsif ($op eq "-x") { $mode = "X_OK"; }
            if ($is_stat_cache == 1) {
                Perla::CodeGen::emit($cg, "STRADA_MAKE_TAGGED_INT(perla_last_stat_path[0] ? (access(perla_last_stat_path, " . $mode . ") == 0 ? 1 : 0) : 0)");
            } else {
                Perla::CodeGen::emit($cg, "({ char *__fp = strada_to_str(");
                Perla::CodeGen::gen_expr($cg, $node->{"operand"});
                Perla::CodeGen::emit($cg, "); perla_remember_stat_path(__fp); StradaValue *__fr = STRADA_MAKE_TAGGED_INT(access(__fp, " . $mode . ") == 0 ? 1 : 0); free(__fp); __fr; })");
            }
        } elsif ($op eq "-t") {
            # -t FH: is filehandle a tty? Test fileno via isatty(3).
            Perla::CodeGen::emit($cg, "({ StradaValue *__tv = ");
            Perla::CodeGen::gen_expr($cg, $node->{"operand"});
            Perla::CodeGen::emit($cg, "; int __tfd = -1; ");
            Perla::CodeGen::emit($cg, "if (__tv && !STRADA_IS_TAGGED_INT(__tv) && __tv->type == STRADA_FILEHANDLE && __tv->value.fh) { __tfd = fileno(__tv->value.fh); } else if (__tv) { __tfd = (int)strada_to_int(__tv); } ");
            # Perl returns empty string for false (not 0), so use STR not int
            Perla::CodeGen::emit($cg, "StradaValue *__tr = (__tfd >= 0 && isatty(__tfd)) ? STRADA_MAKE_TAGGED_INT(1) : strada_new_str(\"\"); __tr; })");
        } elsif ($op eq "-p" || $op eq "-S" || $op eq "-b" || $op eq "-c") {
            # -p (FIFO), -S (socket), -b (block dev), -c (char dev)
            my str $macro = "S_ISFIFO";
            if    ($op eq "-S") { $macro = "S_ISSOCK"; }
            elsif ($op eq "-b") { $macro = "S_ISBLK"; }
            elsif ($op eq "-c") { $macro = "S_ISCHR"; }
            Perla::CodeGen::emit($cg, "({ char *__fp = strada_to_str(");
            Perla::CodeGen::gen_expr($cg, $node->{"operand"});
            Perla::CodeGen::emit($cg, "); perla_remember_stat_path(__fp); struct stat __fs; ");
            Perla::CodeGen::emit($cg, "StradaValue *__fr = (stat(__fp, &__fs) == 0 && " . $macro . "(__fs.st_mode)) ? STRADA_MAKE_TAGGED_INT(1) : strada_new_str(\"\"); free(__fp); __fr; })");
        } elsif ($op eq "-u" || $op eq "-g" || $op eq "-k") {
            # -u (setuid), -g (setgid), -k (sticky)
            my str $bit = "S_ISUID";
            if    ($op eq "-g") { $bit = "S_ISGID"; }
            elsif ($op eq "-k") { $bit = "S_ISVTX"; }
            Perla::CodeGen::emit($cg, "({ char *__fp = strada_to_str(");
            Perla::CodeGen::gen_expr($cg, $node->{"operand"});
            Perla::CodeGen::emit($cg, "); perla_remember_stat_path(__fp); struct stat __fs; ");
            Perla::CodeGen::emit($cg, "StradaValue *__fr = (stat(__fp, &__fs) == 0 && (__fs.st_mode & " . $bit . ")) ? STRADA_MAKE_TAGGED_INT(1) : strada_new_str(\"\"); free(__fp); __fr; })");
        } elsif ($op eq "-o" || $op eq "-O") {
            # -o (owned by effective uid), -O (owned by real uid)
            my str $uidfn = $op eq "-O" ? "getuid()" : "geteuid()";
            Perla::CodeGen::emit($cg, "({ char *__fp = strada_to_str(");
            Perla::CodeGen::gen_expr($cg, $node->{"operand"});
            Perla::CodeGen::emit($cg, "); perla_remember_stat_path(__fp); struct stat __fs; ");
            Perla::CodeGen::emit($cg, "StradaValue *__fr = (stat(__fp, &__fs) == 0 && __fs.st_uid == " . $uidfn . ") ? STRADA_MAKE_TAGGED_INT(1) : strada_new_str(\"\"); free(__fp); __fr; })");
        } elsif ($op eq "-R" || $op eq "-W" || $op eq "-X") {
            # Real-uid versions of -r/-w/-x. Use access(2) with AT_EACCESS
            # turned off — i.e. access() (not faccessat with effective).
            my str $accmode = "R_OK";
            if    ($op eq "-W") { $accmode = "W_OK"; }
            elsif ($op eq "-X") { $accmode = "X_OK"; }
            Perla::CodeGen::emit($cg, "({ char *__fp = strada_to_str(");
            Perla::CodeGen::gen_expr($cg, $node->{"operand"});
            Perla::CodeGen::emit($cg, "); StradaValue *__fr = (access(__fp, " . $accmode . ") == 0) ? STRADA_MAKE_TAGGED_INT(1) : strada_new_str(\"\"); free(__fp); __fr; })");
        } elsif ($op eq "-M" || $op eq "-A" || $op eq "-C") {
            # File age in days from script start time. -M = mtime,
            # -A = atime, -C = ctime. Returns (now - file_time) / 86400.0
            # in days as a num. Returns undef if stat fails.
            my str $field = "st_mtime";
            if    ($op eq "-A") { $field = "st_atime"; }
            elsif ($op eq "-C") { $field = "st_ctime"; }
            Perla::CodeGen::emit($cg, "({ char *__fp = strada_to_str(");
            Perla::CodeGen::gen_expr($cg, $node->{"operand"});
            Perla::CodeGen::emit($cg, "); perla_remember_stat_path(__fp); struct stat __fs; ");
            Perla::CodeGen::emit($cg, "StradaValue *__fr; if (stat(__fp, &__fs) == 0) { double __age = (double)(time(NULL) - __fs." . $field . ") / 86400.0; __fr = strada_new_num(__age); } else { __fr = strada_new_undef(); } free(__fp); __fr; })");
        } else {
            # Fallthrough: existence
            if ($is_stat_cache == 1) {
                Perla::CodeGen::emit($cg, "STRADA_MAKE_TAGGED_INT(perla_last_stat_path[0] ? strada_file_exists(perla_last_stat_path) : 0)");
            } else {
                Perla::CodeGen::emit($cg, "({ char *__fp = strada_to_str(");
                Perla::CodeGen::gen_expr($cg, $node->{"operand"});
                Perla::CodeGen::emit($cg, "); StradaValue *__fr = STRADA_MAKE_TAGGED_INT(strada_file_exists(__fp)); free(__fp); __fr; })");
            }
        }
        return;
    }

    if ($op eq "-") {
        # `-9223372036854775808` (i64 min) — the positive literal is
        # exactly INT64_MAX+1, which overflows i64 and the codegen
        # promotes it to NUM. Unary-minus-of-NUM then loses
        # integer precision (stringifies as -9.22e+18). Detect the
