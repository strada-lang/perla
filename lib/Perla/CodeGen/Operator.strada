            Perla::CodeGen::gen_expr($cg, $node->{"operand"}->{"ref"});
            Perla::CodeGen::emit($cg, "; StradaValue *__ret = NULL; ");
            Perla::CodeGen::emit($cg, "if (__dref && !STRADA_IS_TAGGED_INT(__dref) && __dref->type == STRADA_REF) { ");
            Perla::CodeGen::emit($cg, "  if (strada_is_slot_ref(__dref)) { ");
            Perla::CodeGen::emit($cg, "    StradaValue **__slot = (StradaValue**)__dref->value.ptr; ");
            Perla::CodeGen::emit($cg, "    StradaValue *__nv = perla_increment(*__slot); ");
            Perla::CodeGen::emit($cg, "    if (*__slot) strada_decref(*__slot); *__slot = __nv; ");
            Perla::CodeGen::emit($cg, "    strada_incref(__nv); __ret = __nv; ");
            Perla::CodeGen::emit($cg, "  } else if (__dref->value.rv) { ");
            Perla::CodeGen::emit($cg, "    StradaValue *__tgt = __dref->value.rv; ");
            Perla::CodeGen::emit($cg, "    StradaValue *__nv = perla_increment(__tgt); ");
            Perla::CodeGen::emit($cg, "    strada_overwrite_in_place(__tgt, __nv); strada_decref(__nv); ");
            Perla::CodeGen::emit($cg, "    strada_incref(__tgt); __ret = __tgt; ");
            Perla::CodeGen::emit($cg, "  } ");
            Perla::CodeGen::emit($cg, "} ");
            Perla::CodeGen::emit($cg, "if (!__ret) __ret = strada_new_undef(); __ret; })");
        } else {
            if (Perla::CodeGen::_is_pkg_qualified_scalar($node->{"operand"}) == 1) {
                Perla::CodeGen::_emit_pkg_scalar_inc_prefix($cg, $node->{"operand"}, "+");
            } else if (Perla::CodeGen::_is_our_unqual_scalar($cg, $node->{"operand"}) == 1) {
                # Wrap in a statement-expression so we can sync after.
                Perla::CodeGen::emit($cg, "({ ");
                Perla::CodeGen::gen_expr($cg, $node->{"operand"});
                Perla::CodeGen::emit($cg, " = perla_increment(");
                Perla::CodeGen::gen_expr($cg, $node->{"operand"});
                Perla::CodeGen::emit($cg, ")");
                Perla::CodeGen::_emit_our_sync($cg, $node->{"operand"});
                Perla::CodeGen::emit($cg, "; ");
                Perla::CodeGen::gen_expr($cg, $node->{"operand"});
                Perla::CodeGen::emit($cg, "; })");
            } else {
                # Use perla_increment for magic string-or-number inc.
                # Tied-scalar dispatch (see postfix ++ for rationale):
                # ++tied fetches → increments → stores → returns new.
                Perla::CodeGen::emit($cg, "({ StradaValue *__tg = ");
                Perla::CodeGen::gen_expr($cg, $node->{"operand"});
                Perla::CodeGen::emit($cg, "; StradaValue *__r; ");
                Perla::CodeGen::emit($cg, "if (__builtin_expect(__tg && !STRADA_IS_TAGGED_INT(__tg) && __tg->meta && __tg->meta->is_tied, 0)) { ");
                Perla::CodeGen::emit($cg, "  StradaValue *__fold = strada_tied_scalar_fetch(__tg); ");
                Perla::CodeGen::emit($cg, "  StradaValue *__inc = perla_increment(__fold); ");
                Perla::CodeGen::emit($cg, "  strada_tied_scalar_store(__tg, __inc); ");
                Perla::CodeGen::emit($cg, "  strada_decref(__fold); __r = __inc; ");
                Perla::CodeGen::emit($cg, "} else { ");
                Perla::CodeGen::gen_expr($cg, $node->{"operand"});
                Perla::CodeGen::emit($cg, " = perla_increment(__tg); __r = ");
                Perla::CodeGen::gen_expr($cg, $node->{"operand"});
                Perla::CodeGen::emit($cg, "; } __r; })");
            }
        }
        return;
    }
    # Prefix --
    if ($op eq "--" && defined($node->{"prefix"}) && $node->{"prefix"} == 1) {
        my int $op_type = $node->{"operand"}->{"type"};
        if ($op_type == Perla::AST::N_ARROW_HASH() || $op_type == Perla::AST::N_HASH_ELEM()) {
            Perla::CodeGen::Assign::_gen_hash_compound_assign($cg, $node->{"operand"}, "-", Perla::AST::node_with(Perla::AST::N_INT_LIT(), "value", "1"));
        } elsif ($op_type == Perla::AST::N_ARRAY_ELEM() || $op_type == Perla::AST::N_ARROW_ARRAY()) {
            # --$arr[i] or --$ref->[i]: read-modify-write via array_set.
            Perla::CodeGen::emit($cg, "({ StradaArray *__pi_av = strada_deref_array(");
            my scalar $prd_an = ($op_type == Perla::AST::N_ARRAY_ELEM()) ? $node->{"operand"}->{"array"} : $node->{"operand"}->{"object"};
            my int $prd_is_arrow = 0;
            if (defined($node->{"operand"}->{"is_explicit_arrow"}) && $node->{"operand"}->{"is_explicit_arrow"} == 1) { $prd_is_arrow = 1; }
            if ($prd_is_arrow == 0
                && defined($prd_an) && $prd_an->{"type"} == Perla::AST::N_SCALAR_VAR()
                && defined($prd_an->{"name"}) && $prd_an->{"name"} eq "_") {
                Perla::CodeGen::emit($cg, "perla_at_");
            } elsif ($prd_is_arrow == 0
                && defined($prd_an) && $prd_an->{"type"} == Perla::AST::N_SCALAR_VAR()
                && defined($prd_an->{"name"}) && index($prd_an->{"name"}, "::") > 0) {
                my array @prdpn = Perla::CodeGen::_split_pkg_qual_name($prd_an);
                Perla::CodeGen::emit($cg, "perla_array_get(\"" . $prdpn[0] . "\", \"" . $prdpn[1] . "\")");
            } else {
                Perla::CodeGen::gen_expr($cg, $prd_an);
            }
            Perla::CodeGen::emit($cg, "); int __pi_idx = (int)strada_to_int(");
            Perla::CodeGen::gen_expr($cg, $node->{"operand"}->{"index"});
            Perla::CodeGen::emit($cg, "); if (__pi_idx < 0 && __pi_av) __pi_idx += strada_array_length(__pi_av); ");
            Perla::CodeGen::emit($cg, "StradaValue *__pi_new = STRADA_MAKE_TAGGED_INT(strada_to_int(strada_array_get(__pi_av, __pi_idx)) - 1); ");
            Perla::CodeGen::emit($cg, "strada_array_set(__pi_av, __pi_idx, __pi_new); __pi_new; })");
        } elsif ($op_type == Perla::AST::N_DEREF_SCALAR()) {
            # --${EXPR} — decrement and return the NEW value.
            Perla::CodeGen::emit($cg, "({ StradaValue *__dref = ");
            Perla::CodeGen::gen_expr($cg, $node->{"operand"}->{"ref"});
            Perla::CodeGen::emit($cg, "; StradaValue *__ret = NULL; ");
            Perla::CodeGen::emit($cg, "if (__dref && !STRADA_IS_TAGGED_INT(__dref) && __dref->type == STRADA_REF) { ");
            Perla::CodeGen::emit($cg, "  if (strada_is_slot_ref(__dref)) { ");
            Perla::CodeGen::emit($cg, "    StradaValue **__slot = (StradaValue**)__dref->value.ptr; ");
            Perla::CodeGen::emit($cg, "    StradaValue *__nv = STRADA_MAKE_TAGGED_INT(strada_to_int(*__slot) - 1); ");
            Perla::CodeGen::emit($cg, "    if (*__slot) strada_decref(*__slot); *__slot = __nv; ");
            Perla::CodeGen::emit($cg, "    strada_incref(__nv); __ret = __nv; ");
            Perla::CodeGen::emit($cg, "  } else if (__dref->value.rv) { ");
            Perla::CodeGen::emit($cg, "    StradaValue *__tgt = __dref->value.rv; ");
            Perla::CodeGen::emit($cg, "    StradaValue *__nv = STRADA_MAKE_TAGGED_INT(strada_to_int(__tgt) - 1); ");
            Perla::CodeGen::emit($cg, "    strada_overwrite_in_place(__tgt, __nv); strada_decref(__nv); ");
            Perla::CodeGen::emit($cg, "    strada_incref(__tgt); __ret = __tgt; ");
            Perla::CodeGen::emit($cg, "  } ");
            Perla::CodeGen::emit($cg, "} ");
            Perla::CodeGen::emit($cg, "if (!__ret) __ret = strada_new_undef(); __ret; })");
        } else {
            if (Perla::CodeGen::_is_pkg_qualified_scalar($node->{"operand"}) == 1) {
                Perla::CodeGen::_emit_pkg_scalar_inc_prefix($cg, $node->{"operand"}, "-");
            } else if (Perla::CodeGen::_is_our_unqual_scalar($cg, $node->{"operand"}) == 1) {
                # Use perla_decrement so blessed-ref `--` overload fires.
                # Without this, `--$obj` collapsed to
                # `$obj = STRADA_MAKE_TAGGED_INT(0 - 1)` = -1, clobbering
                # the blessed ref with a plain int.
                Perla::CodeGen::emit($cg, "({ ");
                Perla::CodeGen::gen_expr($cg, $node->{"operand"});
                Perla::CodeGen::emit($cg, " = perla_decrement(");
                Perla::CodeGen::gen_expr($cg, $node->{"operand"});
                Perla::CodeGen::emit($cg, ")");
                Perla::CodeGen::_emit_our_sync($cg, $node->{"operand"});
                Perla::CodeGen::emit($cg, "; ");
                Perla::CodeGen::gen_expr($cg, $node->{"operand"});
                Perla::CodeGen::emit($cg, "; })");
            } else {
                # See comment above re: perla_decrement.
                # Tied-scalar dispatch (see postfix ++ for rationale).
                Perla::CodeGen::emit($cg, "({ StradaValue *__tg = ");
                Perla::CodeGen::gen_expr($cg, $node->{"operand"});
                Perla::CodeGen::emit($cg, "; StradaValue *__r; ");
                Perla::CodeGen::emit($cg, "if (__builtin_expect(__tg && !STRADA_IS_TAGGED_INT(__tg) && __tg->meta && __tg->meta->is_tied, 0)) { ");
                Perla::CodeGen::emit($cg, "  StradaValue *__fold = strada_tied_scalar_fetch(__tg); ");
                Perla::CodeGen::emit($cg, "  StradaValue *__dec = perla_decrement(__fold); ");
                Perla::CodeGen::emit($cg, "  strada_tied_scalar_store(__tg, __dec); ");
                Perla::CodeGen::emit($cg, "  strada_decref(__fold); __r = __dec; ");
                Perla::CodeGen::emit($cg, "} else { ");
                Perla::CodeGen::gen_expr($cg, $node->{"operand"});
                Perla::CodeGen::emit($cg, " = perla_decrement(__tg); __r = ");
                Perla::CodeGen::gen_expr($cg, $node->{"operand"});
                Perla::CodeGen::emit($cg, "; } __r; })");
            }
        }
        return;
    }
    # Unary `+EXPR` — Perl uses this to disambiguate parsing (e.g. inside
    # a hash subscript: `$h->{+shift}` is `$h->{shift}` not the literal key
    # "shift"). Semantically a no-op in scalar context — just evaluate the
    # operand and pass through.
    if ($op eq "+") {
        Perla::CodeGen::gen_expr($cg, $node->{"operand"});
        return;
    }
    Perla::CodeGen::emit($cg, "strada_new_undef() /* TODO: unop " . $op . " */");
}
