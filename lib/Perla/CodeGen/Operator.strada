# Perla::CodeGen::Operator - Binary/unary operator code generation.
#
# Extracted from CodeGen.strada. Owns _gen_binop (all of Perl's binary
# operators: arithmetic, string, comparison, logical, bitwise, range, etc.)
# and _gen_unop (unary !, -, ~, \, defined, etc.).
#
# Calls back into the main Perla::CodeGen via body-less `extern func` decls
# (can't `use` it: cycle). Uses sibling Perla::CodeGen::Assign for the
# hash compound-assign helpers it shares.

use Perla::AST;
use Perla::Lexer;
use Perla::Parser;
use Perla::CodeGen::Escape;
use Perla::CodeGen::Eval;
use Perla::CodeGen::Interp;
use Perla::CodeGen::Predicate;
use Perla::CodeGen::Subst;
use Perla::CodeGen::Assign;

package Perla::CodeGen::Operator;

# Forward decls for Perla::CodeGen helpers we call inline.
extern func Perla::CodeGen::_emit_our_sync(scalar $cg, scalar $node) void;
extern func Perla::CodeGen::_emit_pkg_scalar_inc_postfix(scalar $cg, scalar $node, str $sign) void;
extern func Perla::CodeGen::_emit_pkg_scalar_inc_prefix(scalar $cg, scalar $node, str $sign) void;
extern func Perla::CodeGen::_gen_expr_scalar(scalar $cg, scalar $node) void;
extern func Perla::CodeGen::_is_our_unqual_scalar(scalar $cg, scalar $node) int;
extern func Perla::CodeGen::_is_pkg_qualified_scalar(scalar $node) int;
extern func Perla::CodeGen::_node_is_int(scalar $cg, scalar $node) int;
extern func Perla::CodeGen::_split_pkg_qual_name(scalar $node) array;
extern func Perla::CodeGen::c_var(str $name) str;
extern func Perla::CodeGen::emit(scalar $cg, str $s) void;
extern func Perla::CodeGen::expr_is_borrowed(scalar $node) int;
extern func Perla::CodeGen::gen_expr(scalar $cg, scalar $node) void;
extern func Perla::CodeGen::gen_stmt(scalar $cg, scalar $node) void;
extern func Perla::CodeGen::has_perl_var(str $s) int;

# --- Binary operations ---
func _gen_binop(scalar $cg, scalar $node) void {
    my str $op = $node->{"op"};

    # `use bigint` — route integer arithmetic and numeric comparisons through
    # the arbitrary-precision runtime. The int64 fast path inside
    # perla_bigint_binop keeps small values as tagged ints (so loop counters /
    # indices stay cheap); only results exceeding int64 carry as decimal-string
    # bignums. Division/modulo are not yet arbitrary-precision (fall through).
    if (defined($cg->{"use_bigint"}) && $cg->{"use_bigint"} == 1
        && ($op eq "+" || $op eq "-" || $op eq "*" || $op eq "**"
            || $op eq "/" || $op eq "%"
            || $op eq "<=>" || $op eq "==" || $op eq "!="
            || $op eq "<" || $op eq ">" || $op eq "<=" || $op eq ">=")) {
        my int $bi_l = Perla::CodeGen::expr_is_borrowed($node->{"left"});
        my int $bi_r = Perla::CodeGen::expr_is_borrowed($node->{"right"});
        Perla::CodeGen::emit($cg, "({ StradaValue *__bil = ");
        Perla::CodeGen::_gen_expr_scalar($cg, $node->{"left"});
        Perla::CodeGen::emit($cg, "; StradaValue *__bir = ");
        Perla::CodeGen::_gen_expr_scalar($cg, $node->{"right"});
        Perla::CodeGen::emit($cg, "; StradaValue *__bires = perla_bigint_binop(\"" . $op . "\", __bil, __bir); ");
        if ($bi_l == 0) { Perla::CodeGen::emit($cg, "if (__bil) strada_decref(__bil); "); }
        if ($bi_r == 0) { Perla::CodeGen::emit($cg, "if (__bir) strada_decref(__bir); "); }
        Perla::CodeGen::emit($cg, "__bires; })");
        return;
    }

    # Smartmatch — dispatch to runtime helper. Handles the common cases
    # (scalar in array, scalar in hash, undef test, code ref, regex,
    # fallback eq); see runtime/perla_stash.c perla_smartmatch.
    #
    # Force list context around the RHS so `@a` / `%h` evaluate to the
    # underlying container, not the scalar-context count/key-count —
    # perla_smartmatch dispatches on the rhs->type tag and a scalar
    # count would never match the ARRAY / HASH branches.
    if ($op eq "~~") {
        my int $sm_l_borrowed = Perla::CodeGen::expr_is_borrowed($node->{"left"});
        my int $sm_r_borrowed = Perla::CodeGen::expr_is_borrowed($node->{"right"});
        Perla::CodeGen::emit($cg, "({ StradaValue *__sml = ");
        Perla::CodeGen::_gen_expr_scalar($cg, $node->{"left"});
        Perla::CodeGen::emit($cg, "; int __sm_sav_wl = __perla_want_list; __perla_want_list = 1; ");
        Perla::CodeGen::emit($cg, "StradaValue *__smr = ");
        Perla::CodeGen::gen_expr($cg, $node->{"right"});
        Perla::CodeGen::emit($cg, "; __perla_want_list = __sm_sav_wl; ");
        Perla::CodeGen::emit($cg, "StradaValue *__smres = perla_smartmatch(__sml, __smr); ");
        if ($sm_l_borrowed == 0) { Perla::CodeGen::emit($cg, "if (__sml) strada_decref(__sml); "); }
        if ($sm_r_borrowed == 0) { Perla::CodeGen::emit($cg, "if (__smr) strada_decref(__smr); "); }
        Perla::CodeGen::emit($cg, "__smres; })");
        return;
    }

    # String concat
    if ($op eq ".") {
        # Flatten concat chains: a . b . c → sequential concats with cleanup
        # Collect all parts of the chain
        my scalar $parts = [];
        my scalar $cur = $node;
        while (defined($cur) && $cur->{"type"} == Perla::AST::N_BINOP() && $cur->{"op"} eq ".") {
            unshift(@{$parts}, $cur->{"right"});
            $cur = $cur->{"left"};
        }
        unshift(@{$parts}, $cur);  # leftmost part

        # Perl's `.` is a scalar operator: both operands must evaluate
        # in scalar context regardless of the surrounding expression's
        # context. Without forcing want_list=0 around the operand
        # codegen, calls like `caller` and array-returning sigils
        # inherit the outer (list) context and return arrays — the
        # subsequent strada_concat_sv then coerces the array to its
        # length-count, e.g. `caller . '::'` evaluates as `6 . '::'`
        # giving "6::" instead of "Pkg::". Surfaced via YAML::Mo's
        # `my($P,%e,%o) = caller.'::';` in `use YAML::Mo` which left
        # the importer's @ISA empty and `has` accessor not installed.
        Perla::CodeGen::emit($cg, "({ int __cc_sav_wl = __perla_want_list; __perla_want_list = 0; StradaValue *__cc_rv = ");

        if (scalar(@{$parts}) <= 2) {
            # Simple 2-part concat — no chain cleanup needed
            my scalar $left = $parts->[0];
            my int $left_type = $left->{"type"};
            # Don't use the cstr_sv fast path if:
            # - the interp string contains a `$N` capture var
            #   (`"$1" . "x"` needs perla_capture_var substitution, but
            #   the fast path emits the literal `$1` bytes)
            # - RHS is an array or hash var (strada_concat_cstr_sv
            #   doesn't have STRADA_ARRAY/HASH branches; it would emit
            #   empty for `"" . @a`. strada_concat_sv handles both.)
            my int $right_type = $parts->[1]->{"type"};
            my int $rhs_is_container = ($right_type == Perla::AST::N_ARRAY_VAR()
                                       || $right_type == Perla::AST::N_HASH_VAR()
                                       || $right_type == Perla::AST::N_DEREF_ARRAY()
                                       || $right_type == Perla::AST::N_DEREF_HASH());
            if ($rhs_is_container == 0 && defined($left) && ($left_type == Perla::AST::N_STR_LIT() || ($left_type == Perla::AST::N_INTERP_STR() && Perla::CodeGen::has_perl_var($left->{"value"}) == 0 && Perla::CodeGen::Interp::has_dollar_digit($left->{"value"}) == 0 && index($left->{"value"}, "\\") < 0))) {
                my str $lit = Perla::CodeGen::Escape::escape_c_str($left->{"value"});
                Perla::CodeGen::emit($cg, "strada_concat_cstr_sv(\"" . $lit . "\", sizeof(\"" . $lit . "\") - 1, ");
                Perla::CodeGen::gen_expr($cg, $parts->[1]);
                Perla::CodeGen::emit($cg, ")");
            } else {
                # `.` overload dispatch: if either operand is a blessed
                # ref with `use overload '.'`, that wins over default
                # string concat. Without this, `$obj . "x"` stringified
                # $obj (via '""' overload or default) and concatenated
                # instead of calling the user's '.' sub.
                Perla::CodeGen::emit($cg, "({ StradaValue *__dcl = ");
                Perla::CodeGen::gen_expr($cg, $left);
                Perla::CodeGen::emit($cg, "; StradaValue *__dcr = ");
                Perla::CodeGen::gen_expr($cg, $parts->[1]);
                Perla::CodeGen::emit($cg, "; StradaValue *__dcov = NULL; ");
                Perla::CodeGen::emit($cg, "if ((__dcl && !STRADA_IS_TAGGED_INT(__dcl) && __dcl->type == STRADA_REF) || ");
                Perla::CodeGen::emit($cg, "    (__dcr && !STRADA_IS_TAGGED_INT(__dcr) && __dcr->type == STRADA_REF)) { ");
                Perla::CodeGen::emit($cg, "  __dcov = perla_overload_binary(__dcl, __dcr, \".\"); } ");
                Perla::CodeGen::emit($cg, "__dcov ? __dcov : strada_concat_sv(__dcl, __dcr); })");
            }
        } else {
            # Chain of 3+ parts — emit sequential concats with intermediate cleanup
            Perla::CodeGen::emit($cg, "({ StradaValue *__cc = ");
            # First pair
            my scalar $p0 = $parts->[0];
            my int $p0_type = $p0->{"type"};
            # Emit first pair — capture RHS if it's a temp.
            # The decref MUST be conditional on RHS actually being a temp; if
            # parts[1] is a borrowed scalar var (SCALAR_VAR / ARRAY_VAR), an
            # unconditional `strada_decref(__cc_r)` will drop the variable's
            # storage. Visible site: `"prefix: " . "$cr" . " suffix"` where
            # `$cr` is a coderef from `Pkg->can(...)` — after the warn the
            # var was emptied so the subsequent `$cr->()` call did nothing.
            # Use the same r_is_temp predicate the loop below uses, but
            # ALSO recognize that a single-variable INTERP_STR (e.g. `"$cr"`)
            # routes through `_gen_interp_c_str`'s scalar(@parts)==1 path
            # which emits the variable directly — that result is borrowed,
            # not a temp.
            my scalar $p1 = $parts->[1];
            my int $p1_type = $p1->{"type"};
            my int $p1_is_single_var_interp = 0;
            if ($p1_type == Perla::AST::N_INTERP_STR() && Perla::CodeGen::Predicate::is_single_var_interp($p1->{"value"}) == 1) {
                $p1_is_single_var_interp = 1;
            }
            my int $p1_is_temp = ($p1_type == Perla::AST::N_STR_LIT() || $p1_type == Perla::AST::N_INT_LIT() ||
                ($p1_type == Perla::AST::N_INTERP_STR() && $p1_is_single_var_interp == 0) || $p1_type == Perla::AST::N_BINOP() ||
                $p1_type == Perla::AST::N_HASH_ELEM() || $p1_type == Perla::AST::N_ARROW_HASH() ||
                $p1_type == Perla::AST::N_CALL());
            Perla::CodeGen::emit($cg, "({ StradaValue *__cc_r = ");
            Perla::CodeGen::gen_expr($cg, $parts->[1]);
            Perla::CodeGen::emit($cg, "; StradaValue *__cc_tmp = ");
            # Same guard as the 2-part path: cstr_sv fast path doesn't
            # handle array/hash RHS, fall back to general concat_sv.
            my int $p1_is_container = ($p1_type == Perla::AST::N_ARRAY_VAR()
                                      || $p1_type == Perla::AST::N_HASH_VAR()
                                      || $p1_type == Perla::AST::N_DEREF_ARRAY()
                                      || $p1_type == Perla::AST::N_DEREF_HASH());
            if ($p1_is_container == 0 && defined($p0) && ($p0_type == Perla::AST::N_STR_LIT() || ($p0_type == Perla::AST::N_INTERP_STR() && Perla::CodeGen::has_perl_var($p0->{"value"}) == 0 && Perla::CodeGen::Interp::has_dollar_digit($p0->{"value"}) == 0 && index($p0->{"value"}, "\\") < 0))) {
                my str $lit = Perla::CodeGen::Escape::escape_c_str($p0->{"value"});
                Perla::CodeGen::emit($cg, "strada_concat_cstr_sv(\"" . $lit . "\", sizeof(\"" . $lit . "\") - 1, __cc_r)");
            } else {
                Perla::CodeGen::emit($cg, "strada_concat_sv(");
                Perla::CodeGen::gen_expr($cg, $p0);
                Perla::CodeGen::emit($cg, ", __cc_r)");
            }
            if ($p1_is_temp == 1) {
                Perla::CodeGen::emit($cg, "; strada_decref(__cc_r); __cc_tmp; })");
            } else {
                Perla::CodeGen::emit($cg, "; __cc_tmp; })");
            }
            Perla::CodeGen::emit($cg, "; ");
            # Remaining parts: chain concat with cleanup of old AND RHS
            Perla::CodeGen::emit($cg, "StradaValue *__cc_old; ");
            my int $ci = 2;
            while ($ci < scalar(@{$parts})) {
                my scalar $rpart = $parts->[$ci];
                my int $r_type = $rpart->{"type"};
                # Only decref right operand if it's a temporary (newly created value).
                # Single-var INTERP_STR (e.g. `"$x"`) emits the variable directly
                # and is borrowed — see _is_single_var_interp.
                my int $r_is_single_var_interp = 0;
                if ($r_type == Perla::AST::N_INTERP_STR() && Perla::CodeGen::Predicate::is_single_var_interp($rpart->{"value"}) == 1) {
                    $r_is_single_var_interp = 1;
                }
                my int $r_is_temp = ($r_type == Perla::AST::N_STR_LIT() || $r_type == Perla::AST::N_INT_LIT() ||
                    ($r_type == Perla::AST::N_INTERP_STR() && $r_is_single_var_interp == 0) || $r_type == Perla::AST::N_BINOP() ||
                    $r_type == Perla::AST::N_HASH_ELEM() || $r_type == Perla::AST::N_ARROW_HASH() ||
                    $r_type == Perla::AST::N_CALL());
                Perla::CodeGen::emit($cg, "__cc_old = __cc; ");
                if ($r_is_temp == 1) {
                    Perla::CodeGen::emit($cg, "{ StradaValue *__cc_r2 = ");
                    Perla::CodeGen::gen_expr($cg, $rpart);
                    Perla::CodeGen::emit($cg, "; __cc = strada_concat_sv(__cc, __cc_r2); strada_decref(__cc_r2); } ");
                } else {
                    Perla::CodeGen::emit($cg, "__cc = strada_concat_sv(__cc, ");
                    Perla::CodeGen::gen_expr($cg, $rpart);
                    Perla::CodeGen::emit($cg, "); ");
                }
                Perla::CodeGen::emit($cg, "strada_decref(__cc_old); ");
                $ci++;
            }
            Perla::CodeGen::emit($cg, "__cc; })");
        }
        Perla::CodeGen::emit($cg, "; __perla_want_list = __cc_sav_wl; __cc_rv; })");
        return;
    }

    # Numeric ops — use _gen_expr_scalar for @array → count in numeric context
    if ($op eq "+" || $op eq "-" || $op eq "*") {
        # __builtin name for overflow check
        my str $op_builtin = "add";
        if ($op eq "-") { $op_builtin = "sub"; }
        elsif ($op eq "*") { $op_builtin = "mul"; }
        # On a TRUE int64 overflow, perl promotes to a UV (not NV) when the
        # mathematical result is a non-negative integer <= UINT64_MAX —
        # `9223372036854775807 + 9223372036854775807` is 18446744073709551614,
        # a UV, not 1.84e19. Two's-complement add/sub already give the exact
        # low-64 bits, which equal the true value when it fits [0,UV_MAX];
        # mul needs a uint64 overflow re-check. Otherwise fall back to NV.
        my str $uv_ovf;
        if ($op eq "+") {
            $uv_ovf = "(__opl >= 0 && __opr >= 0) ? strada_new_uint((uint64_t)__opl + (uint64_t)__opr) : strada_new_num((double)__opl + (double)__opr)";
        } elsif ($op eq "-") {
            $uv_ovf = "(__opl >= 0 && __opr < 0) ? strada_new_uint((uint64_t)__opl - (uint64_t)__opr) : strada_new_num((double)__opl - (double)__opr)";
        } else {
            $uv_ovf = "({ uint64_t __um; (__opl >= 0 && __opr >= 0 && !__builtin_mul_overflow((uint64_t)__opl, (uint64_t)__opr, &__um)) ? strada_new_uint(__um) : strada_new_num((double)__opl * (double)__opr); })";
        }
        if (Perla::CodeGen::_node_is_int($cg, $node->{"left"}) == 1 && Perla::CodeGen::_node_is_int($cg, $node->{"right"}) == 1) {
            # Int-typed operands: still need overflow check (perl auto-
            # promotes to float/UV on overflow). `12345678901 * 9876543210`
            # fits in int64 individually but the product overflows.
            # A result that overflows the tagged range but NOT int64 is an
            # exact heap int (strada_new_int), not a lossy double.
            # Capture the operand SVs so owned heap-int operands are
            # released. Tagged ints are immortal (decref is a no-op), but an
            # integer literal beyond 2^62 (e.g. INT64_MAX) is a HEAP int —
            # `strada_to_int(<gen_expr>)` directly would leak it. The result
            # is always independent (tagged / fresh uint / num / new_int), so
            # decref'ing the operands afterward is safe.
            Perla::CodeGen::emit($cg, "({ StradaValue *__iol = ");
            Perla::CodeGen::_gen_expr_scalar($cg, $node->{"left"});
            Perla::CodeGen::emit($cg, "; StradaValue *__ior = ");
            Perla::CodeGen::_gen_expr_scalar($cg, $node->{"right"});
            Perla::CodeGen::emit($cg, "; int64_t __opl = strada_to_int(__iol); int64_t __opr = strada_to_int(__ior); ");
            Perla::CodeGen::emit($cg, "int64_t __opres; int __ovf = __builtin_" . $op_builtin . "_overflow(__opl, __opr, &__opres); ");
            Perla::CodeGen::emit($cg, "StradaValue *__ires = __ovf ? (" . $uv_ovf . ") ");
            Perla::CodeGen::emit($cg, " : ((__opres > STRADA_TAGGED_INT_MAX || __opres < STRADA_TAGGED_INT_MIN) ? strada_new_int(__opres) : STRADA_MAKE_TAGGED_INT(__opres)); ");
            if (Perla::CodeGen::expr_is_borrowed($node->{"left"}) == 0) {
                Perla::CodeGen::emit($cg, "if (__iol) strada_decref(__iol); ");
            }
            if (Perla::CodeGen::expr_is_borrowed($node->{"right"}) == 0) {
                Perla::CodeGen::emit($cg, "if (__ior) strada_decref(__ior); ");
            }
            Perla::CodeGen::emit($cg, "__ires; })");
        } else {
            # Runtime check: if either operand is a blessed ref with an
            # overload registered for this op, dispatch through
            # `perla_overload_binary`. Otherwise fall through to
            # tagged-int / numeric arithmetic. Without this,
            # `$v1 + $v2` on blessed Vec objects added their addresses
            # as numbers instead of running the user's `use overload '+'`.
            my int $al_borrowed = Perla::CodeGen::expr_is_borrowed($node->{"left"});
            my int $ar_borrowed = Perla::CodeGen::expr_is_borrowed($node->{"right"});
            Perla::CodeGen::emit($cg, "({ StradaValue *__al = ");
            Perla::CodeGen::_gen_expr_scalar($cg, $node->{"left"});
            Perla::CodeGen::emit($cg, "; StradaValue *__ar = ");
            Perla::CodeGen::_gen_expr_scalar($cg, $node->{"right"});
            Perla::CodeGen::emit($cg, "; StradaValue *__abr = NULL; StradaValue *__ares; ");
            # FAST PATH: two tagged integers — the overwhelmingly common case
            # (loop counters, indices, fib-style int arithmetic). Skips the
            # REF/overload check and the two non-inlined strada_sv_is_uint
            # calls, and reads operands via the STRADA_TAGGED_INT_VAL shift
            # instead of strada_to_int. Identical overflow/range/tag semantics
            # to the general signed-int branch below; tagged ints are immortal
            # so no operand decref is needed. (fib35: most of the 0.45s vs a
            # 0.04s hand-written tagged-int floor was this per-op overhead.)
            Perla::CodeGen::emit($cg, "if (STRADA_IS_TAGGED_INT(__al) && STRADA_IS_TAGGED_INT(__ar)) { ");
            Perla::CodeGen::emit($cg, "  int64_t __opl = STRADA_TAGGED_INT_VAL(__al); int64_t __opr = STRADA_TAGGED_INT_VAL(__ar); int64_t __opres; ");
            Perla::CodeGen::emit($cg, "  __ares = __builtin_" . $op_builtin . "_overflow(__opl, __opr, &__opres) ? (" . $uv_ovf . ") ");
            Perla::CodeGen::emit($cg, "          : ((__opres > STRADA_TAGGED_INT_MAX || __opres < STRADA_TAGGED_INT_MIN) ? strada_new_int(__opres) : STRADA_MAKE_TAGGED_INT(__opres)); ");
            Perla::CodeGen::emit($cg, "} else { ");
            Perla::CodeGen::emit($cg, "if (((__al && !STRADA_IS_TAGGED_INT(__al) && __al->type == STRADA_REF) || ");
            Perla::CodeGen::emit($cg, "     (__ar && !STRADA_IS_TAGGED_INT(__ar) && __ar->type == STRADA_REF))) { ");
            Perla::CodeGen::emit($cg, "  __abr = perla_overload_binary(__al, __ar, \"" . $op . "\"); } ");
            # Tagged-int fast-path with overflow detection. Perl auto-
            # promotes to float when integer arithmetic overflows; perla
            # used to silently wrap. __builtin_*_overflow returns true
            # on overflow without UB; on overflow OR out-of-tagged-int-
            # range, promote to a float via strada_new_num.
            Perla::CodeGen::emit($cg, "if (__abr) { __ares = __abr; } ");
            # UV-aware path FIRST: when either operand is an unsigned-64 (UV)
            # heap int, do the arithmetic in uint64 so `$uv - 1`, `~0 - 5`,
            # `$near_uvmax + n` stay exact unsigned integers instead of
            # numifying to a lossy double. Overflow past UINT64_MAX falls
            # back to NV (matching Perl). strada_new_uint demotes results
            # <= INT64_MAX back to a plain int. Checked before the signed
            # integer branch so a UV operand isn't read as a signed bit
            # pattern.
            Perla::CodeGen::emit($cg, "else if (strada_sv_is_uint(__al) || strada_sv_is_uint(__ar)) { ");
            Perla::CodeGen::emit($cg, "  uint64_t __ua = strada_to_uint64(__al); uint64_t __ub = strada_to_uint64(__ar); uint64_t __ur; ");
            Perla::CodeGen::emit($cg, "  __ares = __builtin_" . $op_builtin . "_overflow(__ua, __ub, &__ur) ");
            Perla::CodeGen::emit($cg, "          ? strada_new_num((double)__ua " . $op . " (double)__ub) ");
            Perla::CodeGen::emit($cg, "          : strada_new_uint(__ur); ");
            # Both operands integer-valued (tagged OR signed heap int64).
            # Read via strada_to_int (handles both). True int64 overflow
            # promotes to UV when the result is non-negative & fits uint64;
            # a result out of tagged range but within int64 is an exact heap
            # int. Covers `$a + $b` where both hold INT64_MAX-range values.
            Perla::CodeGen::emit($cg, "} else if ((STRADA_IS_TAGGED_INT(__al) || (__al && !STRADA_IS_TAGGED_INT(__al) && __al->type == STRADA_INT)) && (STRADA_IS_TAGGED_INT(__ar) || (__ar && !STRADA_IS_TAGGED_INT(__ar) && __ar->type == STRADA_INT))) { ");
            Perla::CodeGen::emit($cg, "  int64_t __opl = strada_to_int(__al); int64_t __opr = strada_to_int(__ar); int64_t __opres; ");
            Perla::CodeGen::emit($cg, "  int __ovf = __builtin_" . $op_builtin . "_overflow(__opl, __opr, &__opres); ");
            Perla::CodeGen::emit($cg, "  __ares = __ovf ? (" . $uv_ovf . ") ");
            Perla::CodeGen::emit($cg, "          : ((__opres > STRADA_TAGGED_INT_MAX || __opres < STRADA_TAGGED_INT_MIN) ? strada_new_int(__opres) : STRADA_MAKE_TAGGED_INT(__opres)); ");
            # `use warnings` numeric-category emission: warn when a
            # non-numeric string operand is converted to number here.
            # Mirrors perl's "Argument %s isn't numeric in addition (+)"
            # (and the matching subtraction/multiplication variants).
            # The two perla_warn_non_numeric calls go inside the same
            # else branch as the strada_to_num conversion, so the
            # check only fires on the non-tagged-int path that actually
            # runs the numeric coercion.
            my str $__warn_op_long = "addition (+)";
            if ($op eq "-") { $__warn_op_long = "subtraction (-)"; }
            elsif ($op eq "*") { $__warn_op_long = "multiplication (*)"; }
            my int $__warn_line = 0;
            if (defined($node->{"line"})) { $__warn_line = $node->{"line"} + 0; }
            # Fall back to operand's line — BINOP nodes don't always
            # carry their own line attribute; the leftmost operand's
            # line is close enough for the warning location.
            if ($__warn_line == 0 && defined($node->{"left"})
                && defined($node->{"left"}->{"line"})) {
                $__warn_line = $node->{"left"}->{"line"} + 0;
            }
            if ($__warn_line == 0 && defined($node->{"right"})
                && defined($node->{"right"}->{"line"})) {
                $__warn_line = $node->{"right"}->{"line"} + 0;
            }
            my str $__warn_file = "" . $cg->{"filename"};
            if (length($__warn_file) == 0) { $__warn_file = "-"; }
            my str $__warn_file_esc = Perla::CodeGen::Escape::escape_c_str($__warn_file);
            Perla::CodeGen::emit($cg, "} else { ");
            Perla::CodeGen::emit($cg, "  perla_warn_non_numeric(__al, \"" . $__warn_op_long . "\", \"" . $__warn_file_esc . "\", " . $__warn_line . "); ");
            Perla::CodeGen::emit($cg, "  perla_warn_non_numeric(__ar, \"" . $__warn_op_long . "\", \"" . $__warn_file_esc . "\", " . $__warn_line . "); ");
            Perla::CodeGen::emit($cg, "  __ares = strada_new_num(strada_to_num(__al) " . $op . " strada_to_num(__ar)); } ");
            # Decref owned operands. Without this, `$i * 1.5` leaks the
            # fresh-allocated 1.5 num each iter.
            if ($al_borrowed == 0) {
                Perla::CodeGen::emit($cg, "if (__al) strada_decref(__al); ");
            }
            if ($ar_borrowed == 0) {
                Perla::CodeGen::emit($cg, "if (__ar) strada_decref(__ar); ");
            }
            Perla::CodeGen::emit($cg, "} ");  # close the `else` of the tagged-int fast path
            Perla::CodeGen::emit($cg, "__ares; })");
        }
        return;
    }
    if ($op eq "/") {
        my int $use_int = 0;
        if (defined($cg->{"use_integer"}) && $cg->{"use_integer"} == 1) { $use_int = 1; }
        # Runtime overload dispatch for blessed refs with `/` overloaded;
        # falls back to native int- or float-division otherwise.
        my int $dl_borrowed = Perla::CodeGen::expr_is_borrowed($node->{"left"});
        my int $dr_borrowed = Perla::CodeGen::expr_is_borrowed($node->{"right"});
        Perla::CodeGen::emit($cg, "({ StradaValue *__dlv = ");
        Perla::CodeGen::_gen_expr_scalar($cg, $node->{"left"});
        Perla::CodeGen::emit($cg, "; StradaValue *__drv = ");
        Perla::CodeGen::_gen_expr_scalar($cg, $node->{"right"});
        Perla::CodeGen::emit($cg, "; StradaValue *__dbr = NULL; ");
        Perla::CodeGen::emit($cg, "if (((__dlv && !STRADA_IS_TAGGED_INT(__dlv) && __dlv->type == STRADA_REF) || ");
        Perla::CodeGen::emit($cg, "     (__drv && !STRADA_IS_TAGGED_INT(__drv) && __drv->type == STRADA_REF))) { ");
        Perla::CodeGen::emit($cg, "  __dbr = perla_overload_binary(__dlv, __drv, \"/\"); } ");
        Perla::CodeGen::emit($cg, "StradaValue *__dres; if (__dbr) { __dres = __dbr; } else { ");
        if ($use_int == 1) {
            # `use integer` — truncating integer division.
            Perla::CodeGen::emit($cg, "  int64_t __dl = strada_to_int(__dlv); int64_t __dr = strada_to_int(__drv); ");
            Perla::CodeGen::emit($cg, "  if (__dr == 0) strada_die(\"%s\", \"Illegal division by zero\"); ");
            Perla::CodeGen::emit($cg, "  __dres = STRADA_MAKE_TAGGED_INT(__dr == 0 ? 0 : __dl / __dr); ");
        } else {
            Perla::CodeGen::emit($cg, "  double __dl = strada_to_num(__dlv); double __dr = strada_to_num(__drv); ");
            Perla::CodeGen::emit($cg, "  if (__dr == 0.0) strada_die(\"%s\", \"Illegal division by zero\"); ");
            Perla::CodeGen::emit($cg, "  __dres = strada_new_num(__dr == 0.0 ? 0.0 : __dl / __dr); ");
        }
        Perla::CodeGen::emit($cg, "} ");
        if ($dl_borrowed == 0) {
            Perla::CodeGen::emit($cg, "if (__dlv) strada_decref(__dlv); ");
        }
        if ($dr_borrowed == 0) {
            Perla::CodeGen::emit($cg, "if (__drv) strada_decref(__drv); ");
        }
        Perla::CodeGen::emit($cg, "__dres; })");
        return;
    }
    # Modulo — Perl's `%` follows the sign of the right operand
    # (mathematical modulo), unlike C's `%` which follows the sign of
    # the left operand. Compute `a - b * floor(a/b)` to match Perl.
    if ($op eq "%") {
        # Runtime overload dispatch for blessed refs with `%` overloaded;
        # otherwise integer modulo with Perl-style sign rules. Use a
        # result var so the statement-expression yields a value
        # (an if-else statement doesn't).
        Perla::CodeGen::emit($cg, "({ StradaValue *__mlv = ");
        Perla::CodeGen::_gen_expr_scalar($cg, $node->{"left"});
        Perla::CodeGen::emit($cg, "; StradaValue *__mrv = ");
        Perla::CodeGen::_gen_expr_scalar($cg, $node->{"right"});
        Perla::CodeGen::emit($cg, "; StradaValue *__mbr = NULL; ");
        Perla::CodeGen::emit($cg, "if (((__mlv && !STRADA_IS_TAGGED_INT(__mlv) && __mlv->type == STRADA_REF) || ");
        Perla::CodeGen::emit($cg, "     (__mrv && !STRADA_IS_TAGGED_INT(__mrv) && __mrv->type == STRADA_REF))) { ");
        Perla::CodeGen::emit($cg, "  __mbr = perla_overload_binary(__mlv, __mrv, \"%\"); } ");
        Perla::CodeGen::emit($cg, "StradaValue *__mres; ");
        Perla::CodeGen::emit($cg, "if (__mbr) { __mres = __mbr; } ");
        # UV-aware modulo: a UV operand must use UNSIGNED modulo, else its
        # bit pattern is read as a negative signed value
        # (`18446744073709551615 % 10` gave 9 instead of 5).
        Perla::CodeGen::emit($cg, "else if (strada_sv_is_uint(__mlv) || strada_sv_is_uint(__mrv)) { ");
        Perla::CodeGen::emit($cg, "  uint64_t __mul = strada_to_uint64(__mlv); uint64_t __mur = strada_to_uint64(__mrv); ");
        Perla::CodeGen::emit($cg, "  if (__mur == 0) strada_die(\"%s\", \"Illegal modulus zero\"); ");
        Perla::CodeGen::emit($cg, "  __mres = strada_new_uint(__mul % __mur); } ");
        Perla::CodeGen::emit($cg, "else { ");
        Perla::CodeGen::emit($cg, "  int64_t __ml = strada_to_int(__mlv); int64_t __mr = strada_to_int(__mrv); ");
        Perla::CodeGen::emit($cg, "  if (__mr == 0) strada_die(\"%s\", \"Illegal modulus zero\"); ");
        Perla::CodeGen::emit($cg, "  int64_t __mm = (__mr == 0) ? 0 : (__ml % __mr); ");
        Perla::CodeGen::emit($cg, "  if (__mm != 0 && ((__mm < 0) != (__mr < 0))) __mm += __mr; ");
        Perla::CodeGen::emit($cg, "  __mres = STRADA_MAKE_TAGGED_INT(__mm); } ");
        # Release owned operand temps (e.g. UV literals / arithmetic
        # results, which are heap-allocated). Tagged ints are immortal so
        # the old code never leaked, but a heap UV operand did. __mres is
        # always an independent value (overload result / fresh uint / tagged
        # int), so decref'ing the operands here is safe.
        if (Perla::CodeGen::expr_is_borrowed($node->{"left"}) == 0) {
            Perla::CodeGen::emit($cg, "if (__mlv) strada_decref(__mlv); ");
        }
        if (Perla::CodeGen::expr_is_borrowed($node->{"right"}) == 0) {
            Perla::CodeGen::emit($cg, "if (__mrv) strada_decref(__mrv); ");
        }
        Perla::CodeGen::emit($cg, "__mres; })");
        return;
    }

    # Bitwise operators (& | ^ << >>). All also dispatch the matching
    # `use overload` slot on blessed refs, with native integer ops as
    # the fallback.
    if ($op eq "&" || $op eq "|" || $op eq "^" || $op eq "<<" || $op eq ">>") {
        # Perl's >> and << operate on UVs (unsigned), so `-256 >> 2`
        # yields a large positive number, not -64. Cast both operands
        # to uint64_t for shifts to match Perl's default behavior (no
        # `use integer` pragma support — but signed shift on negatives
        # is implementation-defined anyway). For shifts whose result
        # exceeds the tagged-int range (2^62-1), allocate a heap int —
        # `-1 >> 1` = 0x7FFFFFFFFFFFFFFF in u64 and the tag shift would
        # overflow to -1 if we stuffed it into a tagged int.
        if ($op eq "<<" || $op eq ">>") {
            Perla::CodeGen::emit($cg, "({ StradaValue *__shl = ");
            Perla::CodeGen::gen_expr($cg, $node->{"left"});
            Perla::CodeGen::emit($cg, "; StradaValue *__shr = ");
            Perla::CodeGen::gen_expr($cg, $node->{"right"});
            Perla::CodeGen::emit($cg, "; StradaValue *__shbr = NULL; ");
            Perla::CodeGen::emit($cg, "if (((__shl && !STRADA_IS_TAGGED_INT(__shl) && __shl->type == STRADA_REF) || ");
            Perla::CodeGen::emit($cg, "     (__shr && !STRADA_IS_TAGGED_INT(__shr) && __shr->type == STRADA_REF))) { ");
            Perla::CodeGen::emit($cg, "  __shbr = perla_overload_binary(__shl, __shr, \"" . $op . "\"); } ");
            Perla::CodeGen::emit($cg, "__shbr ? __shbr : ({ uint64_t __sh = (uint64_t)strada_to_int(__shl) " . $op . " (uint64_t)strada_to_int(__shr); ");
            Perla::CodeGen::emit($cg, "(__sh > (uint64_t)STRADA_TAGGED_INT_MAX) ? strada_new_int((int64_t)__sh) : STRADA_MAKE_TAGGED_INT((int64_t)__sh); }); })");
            return;
        }
        Perla::CodeGen::emit($cg, "({ StradaValue *__bwl = ");
        Perla::CodeGen::gen_expr($cg, $node->{"left"});
        Perla::CodeGen::emit($cg, "; StradaValue *__bwr = ");
        Perla::CodeGen::gen_expr($cg, $node->{"right"});
        Perla::CodeGen::emit($cg, "; StradaValue *__bwbr = NULL; ");
        Perla::CodeGen::emit($cg, "if (((__bwl && !STRADA_IS_TAGGED_INT(__bwl) && __bwl->type == STRADA_REF) || ");
        Perla::CodeGen::emit($cg, "     (__bwr && !STRADA_IS_TAGGED_INT(__bwr) && __bwr->type == STRADA_REF))) { ");
        Perla::CodeGen::emit($cg, "  __bwbr = perla_overload_binary(__bwl, __bwr, \"" . $op . "\"); } ");
        # When both operands are STRADA_STR, Perl does byte-wise. Without
        # this branch, `"abc" | "ABC"` became `strada_to_int("abc") | ...`
        # which is 0|0 = 0.
        my str $strfn = "";
        if ($op eq "|") { $strfn = "perla_str_or"; }
        elsif ($op eq "&") { $strfn = "perla_str_and"; }
        elsif ($op eq "^") { $strfn = "perla_str_xor"; }
        if (length($strfn) > 0) {
            Perla::CodeGen::emit($cg, "if (!__bwbr && __bwl && !STRADA_IS_TAGGED_INT(__bwl) && __bwl->type == STRADA_STR && ");
            Perla::CodeGen::emit($cg, "    __bwr && !STRADA_IS_TAGGED_INT(__bwr) && __bwr->type == STRADA_STR) { ");
            Perla::CodeGen::emit($cg, "  __bwbr = " . $strfn . "(__bwl, __bwr); } ");
        }
        Perla::CodeGen::emit($cg, "__bwbr ? __bwbr : STRADA_MAKE_TAGGED_INT(strada_to_int(__bwl) " . $op . " strada_to_int(__bwr)); })");
        return;
    }

    # Exponentiation — runtime overload dispatch when either operand
    # is a blessed ref with `**` overloaded; otherwise pow().
    if ($op eq "**") {
        Perla::CodeGen::emit($cg, "({ StradaValue *__pl = ");
        Perla::CodeGen::_gen_expr_scalar($cg, $node->{"left"});
        Perla::CodeGen::emit($cg, "; StradaValue *__pr = ");
        Perla::CodeGen::_gen_expr_scalar($cg, $node->{"right"});
        Perla::CodeGen::emit($cg, "; StradaValue *__pbr = NULL; ");
        Perla::CodeGen::emit($cg, "if (((__pl && !STRADA_IS_TAGGED_INT(__pl) && __pl->type == STRADA_REF) || ");
        Perla::CodeGen::emit($cg, "     (__pr && !STRADA_IS_TAGGED_INT(__pr) && __pr->type == STRADA_REF))) { ");
        Perla::CodeGen::emit($cg, "  __pbr = perla_overload_binary(__pl, __pr, \"**\"); } ");
        Perla::CodeGen::emit($cg, "__pbr ? __pbr : strada_new_num(pow(strada_to_num(__pl), strada_to_num(__pr))); })");
        return;
    }

    # Numeric comparisons
    if ($op eq "==" || $op eq "!=" || $op eq "<" || $op eq ">" || $op eq "<=" || $op eq ">=") {
        # Perl: comparison ops yield "1" (true) or "" (defined empty,
        # false). Was returning tagged 0/1, so `print "'\$x'"` for a
        # false comparison emitted "'0'" instead of "''". The empty
        # vs "0" distinction matters for string-equality tests like
        # `if (\$result eq "")`.
        if (Perla::CodeGen::Predicate::expr_is_int($node->{"left"}) == 1 && Perla::CodeGen::Predicate::expr_is_int($node->{"right"}) == 1) {
            Perla::CodeGen::emit($cg, "((strada_to_int(");
            Perla::CodeGen::_gen_expr_scalar($cg, $node->{"left"});
            Perla::CodeGen::emit($cg, ") " . $op . " strada_to_int(");
            Perla::CodeGen::_gen_expr_scalar($cg, $node->{"right"});
            Perla::CodeGen::emit($cg, ")) ? STRADA_MAKE_TAGGED_INT(1) : strada_new_str(\"\"))");
        } else {
            # Overload dispatch: when either operand is a blessed ref
            # with the matching comparison overload registered, call it.
            # Without this, `$n1 == $n2` on Num objects compared the
            # ref addresses (always unequal) instead of running the
            # user's `use overload '==' => …`.
            my int $cl_borrowed = Perla::CodeGen::expr_is_borrowed($node->{"left"});
            my int $cr_borrowed = Perla::CodeGen::expr_is_borrowed($node->{"right"});
            Perla::CodeGen::emit($cg, "({ StradaValue *__cl = ");
            Perla::CodeGen::_gen_expr_scalar($cg, $node->{"left"});
            Perla::CodeGen::emit($cg, "; StradaValue *__cr = ");
            Perla::CodeGen::_gen_expr_scalar($cg, $node->{"right"});
            Perla::CodeGen::emit($cg, "; StradaValue *__cbr = NULL; ");
            Perla::CodeGen::emit($cg, "if (((__cl && !STRADA_IS_TAGGED_INT(__cl) && __cl->type == STRADA_REF) || ");
            Perla::CodeGen::emit($cg, "     (__cr && !STRADA_IS_TAGGED_INT(__cr) && __cr->type == STRADA_REF))) { ");
            Perla::CodeGen::emit($cg, "  __cbr = perla_overload_binary(__cl, __cr, \"" . $op . "\"); } ");
            Perla::CodeGen::emit($cg, "StradaValue *__cres = __cbr ? (strada_to_bool(__cbr) ? STRADA_MAKE_TAGGED_INT(1) : strada_new_str(\"\")) : ");
            Perla::CodeGen::emit($cg, "((strada_to_num(__cl) " . $op . " strada_to_num(__cr)) ? STRADA_MAKE_TAGGED_INT(1) : strada_new_str(\"\")); ");
            # Decref owned operand temps so `$i == -1` doesn't leak the
            # fresh strada_new_num(-1) once per call.
            if ($cl_borrowed == 0) {
                Perla::CodeGen::emit($cg, "if (__cl) strada_decref(__cl); ");
            }
            if ($cr_borrowed == 0) {
                Perla::CodeGen::emit($cg, "if (__cr) strada_decref(__cr); ");
            }
            Perla::CodeGen::emit($cg, "__cres; })");
        }
        return;
    }

    # Spaceship
    if ($op eq "<=>") {
        Perla::CodeGen::emit($cg, "({ StradaValue *__sl = ");
        Perla::CodeGen::gen_expr($cg, $node->{"left"});
        Perla::CodeGen::emit($cg, "; StradaValue *__sr = ");
        Perla::CodeGen::gen_expr($cg, $node->{"right"});
        Perla::CodeGen::emit($cg, "; StradaValue *__sbr = NULL; ");
        Perla::CodeGen::emit($cg, "if (((__sl && !STRADA_IS_TAGGED_INT(__sl) && __sl->type == STRADA_REF) || ");
        Perla::CodeGen::emit($cg, "     (__sr && !STRADA_IS_TAGGED_INT(__sr) && __sr->type == STRADA_REF))) { ");
        Perla::CodeGen::emit($cg, "  __sbr = perla_overload_binary(__sl, __sr, \"<=>\"); } ");
        Perla::CodeGen::emit($cg, "__sbr ? __sbr : ({ double __l = strada_to_num(__sl); double __r = strada_to_num(__sr); ");
        Perla::CodeGen::emit($cg, "STRADA_MAKE_TAGGED_INT(__l < __r ? -1 : __l > __r ? 1 : 0); }); })");
        return;
    }

    # String spaceship (cmp)
    if ($op eq "cmp") {
        Perla::CodeGen::emit($cg, "({ char *__l = strada_to_str(");
        Perla::CodeGen::gen_expr($cg, $node->{"left"});
        Perla::CodeGen::emit($cg, "); char *__r = strada_to_str(");
        Perla::CodeGen::gen_expr($cg, $node->{"right"});
        Perla::CodeGen::emit($cg, "); int __cmp = strcmp(__l, __r); StradaValue *__res = STRADA_MAKE_TAGGED_INT(__cmp < 0 ? -1 : __cmp > 0 ? 1 : 0); free(__l); free(__r); __res; })");
        return;
    }

    # String comparisons (general expression form).
    if ($op eq "eq" || $op eq "ne" || $op eq "lt" || $op eq "gt" || $op eq "le" || $op eq "ge") {
        # Perl-bool result: "1" for true, "" for false.
        # Scalar context for operands — see the if-cond fast path above
        # for why (reverse $s in eq operand must reverse the string).
        # Overload dispatch for blessed refs: `use overload 'eq' => sub
        # {...}` should fire before the default strcmp. Without this,
        # strada_to_str on the blessed ref returned a generic "P=HASH(...)"
        # stringification and the user's 'eq' override never ran. Falls
        # back to 'cmp' (and ultimately strcmp) when 'eq' isn't defined.
        Perla::CodeGen::emit($cg, "({ int __sav_wl_seq = __perla_want_list; __perla_want_list = 0; ");
        Perla::CodeGen::emit($cg, "StradaValue *__sl = ");
        Perla::CodeGen::gen_expr($cg, $node->{"left"});
        Perla::CodeGen::emit($cg, "; StradaValue *__sr = ");
        Perla::CodeGen::gen_expr($cg, $node->{"right"});
        Perla::CodeGen::emit($cg, "; __perla_want_list = __sav_wl_seq; ");
        Perla::CodeGen::emit($cg, "StradaValue *__sovr = NULL; ");
        Perla::CodeGen::emit($cg, "if ((__sl && !STRADA_IS_TAGGED_INT(__sl) && __sl->type == STRADA_REF) || ");
        Perla::CodeGen::emit($cg, "    (__sr && !STRADA_IS_TAGGED_INT(__sr) && __sr->type == STRADA_REF)) { ");
        Perla::CodeGen::emit($cg, "  __sovr = perla_overload_binary(__sl, __sr, \"" . $op . "\"); } ");
        Perla::CodeGen::emit($cg, "StradaValue *__res; ");
        Perla::CodeGen::emit($cg, "if (__sovr) { __res = perla_to_bool(__sovr) ? STRADA_MAKE_TAGGED_INT(1) : strada_new_str(\"\"); strada_decref(__sovr); } ");
        Perla::CodeGen::emit($cg, "else { char *__l = strada_to_str(__sl); char *__r = strada_to_str(__sr); int __cmp = strcmp(__l, __r); ");
        if ($op eq "eq") { Perla::CodeGen::emit($cg, "__res = (__cmp == 0) ? STRADA_MAKE_TAGGED_INT(1) : strada_new_str(\"\");"); }
        elsif ($op eq "ne") { Perla::CodeGen::emit($cg, "__res = (__cmp != 0) ? STRADA_MAKE_TAGGED_INT(1) : strada_new_str(\"\");"); }
        elsif ($op eq "lt") { Perla::CodeGen::emit($cg, "__res = (__cmp < 0) ? STRADA_MAKE_TAGGED_INT(1) : strada_new_str(\"\");"); }
        elsif ($op eq "gt") { Perla::CodeGen::emit($cg, "__res = (__cmp > 0) ? STRADA_MAKE_TAGGED_INT(1) : strada_new_str(\"\");"); }
        elsif ($op eq "le") { Perla::CodeGen::emit($cg, "__res = (__cmp <= 0) ? STRADA_MAKE_TAGGED_INT(1) : strada_new_str(\"\");"); }
        elsif ($op eq "ge") { Perla::CodeGen::emit($cg, "__res = (__cmp >= 0) ? STRADA_MAKE_TAGGED_INT(1) : strada_new_str(\"\");"); }
        Perla::CodeGen::emit($cg, " free(__l); free(__r); } __res; })");
        return;
    }

    # Logical
    if ($op eq "&&" || $op eq "and") {
        # Symmetric to the `or next`/`or last` handling below: when the
        # RHS is a control-flow statement, _gen_expr emits nothing and
        # the short-circuit becomes a no-op. `EXPR and last;` is the
        # typical "break on success" idiom.
        my scalar $rhs_a = $node->{"right"};
        # `EXPR && return VAL` is Perl's positive short-circuit return —
        # mirrors the `||`/`return` branch below. Class::C3::Componentised's
        # `eval {...} && return 1` got compiled as a ternary that produced
        # 1 but never actually returned, so load_optional_class fell through
        # to throw_exception even when the eval succeeded. Symptom: every
        # successful DBIC driver-class load still threw an empty exception.
        if (defined($rhs_a) && $rhs_a->{"type"} == Perla::AST::N_RETURN()) {
            Perla::CodeGen::emit($cg, "({ StradaValue *__l = ");
            Perla::CodeGen::gen_expr($cg, $node->{"left"});
            Perla::CodeGen::emit($cg, "; if (perla_to_bool(__l)) { if (__perla_local_chain != __perla_local_chain_mark) { perla_local_chain_restore_to(__perla_local_chain, __perla_local_chain_mark); __perla_local_chain = __perla_local_chain_mark; } perla_call_pop(); return ");
            if (defined($rhs_a->{"value"})) {
                Perla::CodeGen::gen_expr($cg, $rhs_a->{"value"});
            } else {
                Perla::CodeGen::emit($cg, "strada_new_undef()");
            }
            Perla::CodeGen::emit($cg, "; } __l; })");
            return;
        }
        if (defined($rhs_a) && ($rhs_a->{"type"} == Perla::AST::N_NEXT() ||
                                $rhs_a->{"type"} == Perla::AST::N_LAST() ||
                                $rhs_a->{"type"} == Perla::AST::N_REDO())) {
            my int $rt_a = $rhs_a->{"type"};
            my str $cf_a = "continue";
            if ($rt_a == Perla::AST::N_LAST()) { $cf_a = "break"; }
            my str $label_a = "" . $rhs_a->{"label"};
            if (length($label_a) > 0) {
                my str $ul_a = $cg->{"label_map"}->{$label_a};
                if (length($ul_a) > 0) {
                    if ($rt_a == Perla::AST::N_NEXT()) { $cf_a = "goto __perla_next_" . $ul_a; }
                    elsif ($rt_a == Perla::AST::N_LAST()) { $cf_a = "goto __perla_last_" . $ul_a; }
                    elsif ($rt_a == Perla::AST::N_REDO()) { $cf_a = "goto __perla_redo_" . $ul_a; }
                }
            }
            Perla::CodeGen::emit($cg, "({ StradaValue *__l = ");
            Perla::CodeGen::gen_expr($cg, $node->{"left"});
            Perla::CodeGen::emit($cg, "; if (perla_to_bool(__l)) { " . $cf_a . "; } __l; })");
            return;
        }
        # Incref __l when returning the LHS so consumers that decref the
        # result don't free a borrowed variable.
        Perla::CodeGen::emit($cg, "({ StradaValue *__l = ");
        Perla::CodeGen::gen_expr($cg, $node->{"left"});
        Perla::CodeGen::emit($cg, "; perla_to_bool(__l) ? (");
        Perla::CodeGen::gen_expr($cg, $node->{"right"});
        Perla::CodeGen::emit($cg, ") : (strada_incref(__l), __l); })");
        return;
    }
    if ($op eq "||" || $op eq "or") {
        # Check if RHS is a return statement — generate actual C return
        my scalar $rhs = $node->{"right"};
        if (defined($rhs) && $rhs->{"type"} == Perla::AST::N_RETURN()) {
            Perla::CodeGen::emit($cg, "({ StradaValue *__l = ");
            Perla::CodeGen::gen_expr($cg, $node->{"left"});
            Perla::CodeGen::emit($cg, "; if (!perla_to_bool(__l)) { if (__perla_local_chain != __perla_local_chain_mark) { perla_local_chain_restore_to(__perla_local_chain, __perla_local_chain_mark); __perla_local_chain = __perla_local_chain_mark; } perla_call_pop(); return ");
            if (defined($rhs->{"value"})) {
                Perla::CodeGen::gen_expr($cg, $rhs->{"value"});
            } else {
                Perla::CodeGen::emit($cg, "strada_new_undef()");
            }
            Perla::CodeGen::emit($cg, "; } __l; })");
            return;
        }
        # `EXPR or next/last/redo` — RHS is a control-flow statement, not
        # an expression. Without this branch, _gen_expr on N_NEXT emits
        # nothing useful inside the ternary, so the "or next" silently
        # becomes "or 0" and the loop body keeps executing past the
        # short-circuit. Idiomatic Perl uses this constantly:
        #   eval { ... } or next;        # Clone::Choose backend loop
        #   $fn or next;                  # skip-on-empty
        if (defined($rhs) && ($rhs->{"type"} == Perla::AST::N_NEXT() ||
                              $rhs->{"type"} == Perla::AST::N_LAST() ||
                              $rhs->{"type"} == Perla::AST::N_REDO())) {
            my int $rt = $rhs->{"type"};
            my str $cf = "continue";
            if ($rt == Perla::AST::N_LAST()) { $cf = "break"; }
            # REDO has no direct C equivalent and labelled forms need a
            # goto; for a plain unlabelled `redo` we approximate with
            # `continue` (skip rest of body) — close enough that the
            # control flow doesn't run past the short-circuit. A proper
            # redo would need a goto into the top of the loop body.
            my str $label = "" . $rhs->{"label"};
            if (length($label) > 0) {
                my str $ul = $cg->{"label_map"}->{$label};
                if (length($ul) > 0) {
                    if ($rt == Perla::AST::N_NEXT()) { $cf = "goto __perla_next_" . $ul; }
                    elsif ($rt == Perla::AST::N_LAST()) { $cf = "goto __perla_last_" . $ul; }
                    elsif ($rt == Perla::AST::N_REDO()) { $cf = "goto __perla_redo_" . $ul; }
                }
            }
            Perla::CodeGen::emit($cg, "({ StradaValue *__l = ");
            Perla::CodeGen::gen_expr($cg, $node->{"left"});
            Perla::CodeGen::emit($cg, "; if (!perla_to_bool(__l)) { " . $cf . "; } __l; })");
            return;
        }
        # Incref __l when returning the LHS so consumers that decref the
        # result don't free a borrowed variable.
        Perla::CodeGen::emit($cg, "({ StradaValue *__l = ");
        Perla::CodeGen::gen_expr($cg, $node->{"left"});
        Perla::CodeGen::emit($cg, "; perla_to_bool(__l) ? (strada_incref(__l), __l) : (");
        Perla::CodeGen::gen_expr($cg, $node->{"right"});
        Perla::CodeGen::emit($cg, "); })");
        return;
    }
    if ($op eq "xor") {
        # Perl's `xor` is a low-precedence logical xor: boolean-of-left !=
        # boolean-of-right. Result is 1 or empty-string (not the operand
        # values, unlike || / &&). Both sides are always evaluated.
        Perla::CodeGen::emit($cg, "({ int __lx = perla_to_bool(");
        Perla::CodeGen::gen_expr($cg, $node->{"left"});
        Perla::CodeGen::emit($cg, "); int __rx = perla_to_bool(");
        Perla::CodeGen::gen_expr($cg, $node->{"right"});
        Perla::CodeGen::emit($cg, "); (__lx != __rx) ? STRADA_MAKE_TAGGED_INT(1) : strada_new_str(\"\"); })");
        return;
    }
    if ($op eq "//") {
        # `//` (defined-or) is a binary scalar op. Evaluate LHS in
        # scalar context — otherwise `eval { die } // "default"` in
        # list context returns an empty array from eval, which
        # `strada_defined_bool` says IS defined, and the fallback
        # is never reached. Save/restore __perla_want_list around LHS.
        my scalar $rhs = $node->{"right"};
        if (defined($rhs) && $rhs->{"type"} == Perla::AST::N_RETURN()) {
            Perla::CodeGen::emit($cg, "({ int __sav_wl_dor = __perla_want_list; __perla_want_list = 0; StradaValue *__l = ");
            Perla::CodeGen::gen_expr($cg, $node->{"left"});
            Perla::CodeGen::emit($cg, "; __perla_want_list = __sav_wl_dor; if (!strada_defined_bool(__l)) { if (__perla_local_chain != __perla_local_chain_mark) { perla_local_chain_restore_to(__perla_local_chain, __perla_local_chain_mark); __perla_local_chain = __perla_local_chain_mark; } perla_call_pop(); return ");
            if (defined($rhs->{"value"})) {
                Perla::CodeGen::gen_expr($cg, $rhs->{"value"});
            } else {
                Perla::CodeGen::emit($cg, "strada_new_undef()");
            }
            Perla::CodeGen::emit($cg, "; } __l; })");
            return;
        }
        # Incref __l when returning the LHS so consumers (e.g. concat)
        # that decref the result don't free a borrowed variable.
        Perla::CodeGen::emit($cg, "({ int __sav_wl_dor = __perla_want_list; __perla_want_list = 0; StradaValue *__l = ");
        Perla::CodeGen::gen_expr($cg, $node->{"left"});
        Perla::CodeGen::emit($cg, "; __perla_want_list = __sav_wl_dor; strada_defined_bool(__l) ? (strada_incref(__l), __l) : (");
        Perla::CodeGen::gen_expr($cg, $node->{"right"});
        Perla::CodeGen::emit($cg, "); })");
        return;
    }

    # String repeat
    if ($op eq "x") {
        # `(LIST) x N` in list context returns the flat list repeated N
        # times. In scalar context, returns the string-concatenation
        # repeated. perla's parser produces N_ANON_ARRAY for `(...)` —
        # in list context with such an LHS, emit list-repeat semantics.
        # Otherwise fall back to string-repeat.
        my int $lhs_is_anon = 0;
        if (defined($node->{"left"}) && $node->{"left"}->{"type"} == Perla::AST::N_ANON_ARRAY()) {
            my int $is_ref = 0;
            if (defined($node->{"left"}->{"is_ref"})) { $is_ref = $node->{"left"}->{"is_ref"}; }
            # `[...] x N` (ref form) is a ref, not a list — string-repeat
            # the stringified ref. Only `(...)` (non-ref) should list-repeat.
            if ($is_ref == 0) { $lhs_is_anon = 1; }
        }
        if ($lhs_is_anon == 1) {
            # Evaluate the LHS with the SURROUNDING want_list context.
            # In list context, `(LIST) x N` is the flat list repeated;
            # in scalar context, `(SCALAR) x N` is string repetition of
            # the scalar's stringification. Previously this path forced
            # want_list=1 on the LHS — that meant in scalar context the
            # ANON_ARRAY came back as a STRADA_ARRAY and then got
            # stringified as "ARRAY(0x..)" rather than the scalar value
            # inside. `(1 ? "a" : "b") x 3` produced
            # "ARRAY(0x..)ARRAY(0x..)ARRAY(0x..)" instead of "aaa".
            Perla::CodeGen::emit($cg, "({ StradaValue *__lhs = ");
            Perla::CodeGen::gen_expr($cg, $node->{"left"});
            Perla::CodeGen::emit($cg, "; int __n = (int)strada_to_num(");
            Perla::CodeGen::gen_expr($cg, $node->{"right"});
            Perla::CodeGen::emit($cg, "); StradaValue *__xr; ");
            Perla::CodeGen::emit($cg, "if (__perla_want_list && __lhs && !STRADA_IS_TAGGED_INT(__lhs) && __lhs->type == STRADA_ARRAY) { ");
            Perla::CodeGen::emit($cg, "  __xr = strada_new_array(); StradaArray *__xdst = strada_deref_array(__xr); ");
            Perla::CodeGen::emit($cg, "  StradaArray *__xsrc = strada_deref_array(__lhs); ");
            Perla::CodeGen::emit($cg, "  if (__xsrc) for (int __xi = 0; __xi < __n; __xi++) { ");
            Perla::CodeGen::emit($cg, "    for (int __xj = 0; __xj < (int)strada_array_length(__xsrc); __xj++) { ");
            Perla::CodeGen::emit($cg, "      StradaValue *__xe = strada_array_get(__xsrc, __xj); if (__xe) strada_incref(__xe); strada_array_push(__xdst, __xe); } } ");
            Perla::CodeGen::emit($cg, "  strada_decref(__lhs); ");
            Perla::CodeGen::emit($cg, "} else { ");
            Perla::CodeGen::emit($cg, "  char *__s = strada_to_str(__lhs); int __sl = (int)strlen(__s); ");
            Perla::CodeGen::emit($cg, "  if (__n < 0) __n = 0; ");
            Perla::CodeGen::emit($cg, "  char *__buf = malloc((size_t)__sl * (size_t)__n + 1); __buf[0] = 0; ");
            Perla::CodeGen::emit($cg, "  for(int __i=0; __i<__n; __i++) memcpy(__buf + __i*__sl, __s, __sl); __buf[__sl*__n]=0; ");
            Perla::CodeGen::emit($cg, "  __xr = strada_new_str(__buf); free(__buf); free(__s); strada_decref(__lhs); ");
            Perla::CodeGen::emit($cg, "} __xr; })");
            return;
        }
        # Negative or zero repeat count is a no-op (empty string). Without
        # the clamp, `malloc(__sl * __n + 1)` with __n=-3 produced a huge
        # size_t (negative→wrap) and `__buf[0] = 0` segfaulted.
        # Overload dispatch first: `$obj x N` with `use overload "x"`
        # gets the user sub. Without this, the LHS stringified to its
        # default form and got repeated as a string instead of the
        # user's overload behavior.
        my int $__xl_borrowed = Perla::CodeGen::expr_is_borrowed($node->{"left"});
        my int $__xr_borrowed = Perla::CodeGen::expr_is_borrowed($node->{"right"});
        Perla::CodeGen::emit($cg, "({ StradaValue *__xl = ");
        Perla::CodeGen::gen_expr($cg, $node->{"left"});
        Perla::CodeGen::emit($cg, "; StradaValue *__xr_rhs = ");
        Perla::CodeGen::gen_expr($cg, $node->{"right"});
        Perla::CodeGen::emit($cg, "; StradaValue *__xrov = NULL; ");
        Perla::CodeGen::emit($cg, "if (__xl && !STRADA_IS_TAGGED_INT(__xl) && __xl->type == STRADA_REF) { ");
        Perla::CodeGen::emit($cg, "  __xrov = perla_overload_binary(__xl, __xr_rhs, \"x\"); } ");
        Perla::CodeGen::emit($cg, "StradaValue *__xrf; ");
        Perla::CodeGen::emit($cg, "if (__xrov) { __xrf = __xrov; } ");
        Perla::CodeGen::emit($cg, "else { ");
        # Route through strada_string_repeat which preserves embedded NULs
        # (binary payloads). The previous inline path used strlen() and
        # silently produced "" for strings containing \x00.
        Perla::CodeGen::emit($cg, "  __xrf = strada_string_repeat(__xl, (int64_t)strada_to_num(__xr_rhs)); ");
        Perla::CodeGen::emit($cg, "} ");
        # Drop the LHS / RHS temps if they were owned (literals, refs,
        # calls, etc.). Borrowed forms (variables) keep their backing
        # alive through their owning slot, so we must not decref.
        # Without this, every `"ab" x N` leaked the "ab" literal once
        # per iter — visible in t/leaks/string_x_repeat.pl.
        if ($__xl_borrowed == 0) {
            Perla::CodeGen::emit($cg, "if (__xl) strada_decref(__xl); ");
        }
        if ($__xr_borrowed == 0) {
            Perla::CodeGen::emit($cg, "if (__xr_rhs) strada_decref(__xr_rhs); ");
        }
        Perla::CodeGen::emit($cg, "__xrf; })");
        return;
    }

    # Regex match or substitution: $str =~ /pattern/ or $str =~ s/pat/repl/
    if ($op eq "=~") {
        my scalar $right = $node->{"right"};
        # For mutating RHS (s///, tr///), the codegen evaluates `left` multiple
        # times — once to read the current value, once to decref, once to
        # assign. When `left` is itself a side-effecting construct like
        # `(my $x = $src)` (N_MY) or `($x = $src)` (N_ASSIGN), re-evaluating
        # it would re-declare or re-assign on every call and produce non-lvalue
        # C like `(v_x = v_src) = __nv`. Hoist such side-effecting LHS forms
        # to a prelude statement and rewrite `left` to the plain scalar-var
        # node for downstream use.
        my int $_mutating_rhs = 0;
        if (defined($right) && ($right->{"type"} == Perla::AST::N_SUBST() || $right->{"type"} == Perla::AST::N_TR())) {
            $_mutating_rhs = 1;
        }
        if ($_mutating_rhs == 1 && defined($node->{"left"})) {
            my int $lt = $node->{"left"}->{"type"};
            my str $hoist_vname = "";
            if ($lt == Perla::AST::N_MY()) {
                my scalar $mn = $node->{"left"};
                my scalar $mv = $mn->{"var"};
                if (!defined($mv) && defined($mn->{"vars"}) && scalar(@{$mn->{"vars"}}) > 0) {
                    my scalar $mv0 = $mn->{"vars"}->[0];
                    if (defined($mv0->{"var"})) { $mv = $mv0->{"var"}; }
                }
                if (defined($mv) && length("" . $mv->{"value"}) > 0) { $hoist_vname = $mv->{"value"}; }
            } elsif ($lt == Perla::AST::N_ASSIGN() && defined($node->{"left"}->{"op"}) && $node->{"left"}->{"op"} eq "=") {
                my scalar $at = $node->{"left"}->{"target"};
                if (defined($at) && $at->{"type"} == Perla::AST::N_SCALAR_VAR()) {
                    $hoist_vname = "" . $at->{"name"};
                }
            }
            if (length($hoist_vname) > 0) {
                my str $hcvar = Perla::CodeGen::c_var($hoist_vname);
                if (!defined($cg->{"declared_vars"})) { $cg->{"declared_vars"} = {}; }
                $cg->{"declared_vars"}->{$hcvar} = 1;
                # Inline the hoist as a leading comma-expression so the
                # binop yields ONE expression value (the s/// result).
                # Without the leading `(` + trailing `)` wrap, the hoist
                # emitted standalone statements that ran BEFORE the s/// —
                # and in a map body capture context, `__mr = body` then
                # took the hoist's value (the my-init assignment) instead
                # of the s/// substitution result.
                Perla::CodeGen::emit($cg, "(");
                Perla::CodeGen::gen_expr($cg, $node->{"left"});
                Perla::CodeGen::emit($cg, ", (" . $hcvar . " ? (strada_incref(" . $hcvar . "), 0) : 0), ");
                my scalar $sv_node = Perla::AST::node(Perla::AST::N_SCALAR_VAR());
                $sv_node->{"name"} = $hoist_vname;
                $node->{"left"} = $sv_node;
                $cg->{"_subst_hoist_wrap"} = 1;
            } else {
                $cg->{"_subst_hoist_wrap"} = 0;
            }
        } else {
            $cg->{"_subst_hoist_wrap"} = 0;
        }
        if (defined($right) && $right->{"type"} == Perla::AST::N_REGEX()) {
            my str $raw_pat = $right->{"pattern"};
            # Embedded code blocks `(?{ CODE })` — perl runs CODE during
            # matching (with $1.. set). PCRE2 has no equivalent, so we
            # strip the blocks from the pattern and run their code AFTER
            # a successful match, with the captures in place. This is
            # exact for the overwhelmingly common single-shot use
            # (`/(\d+)(?{ $n = $1 })/`); it diverges only for patterns
            # that fire the block multiple times via backtracking, which
            # is rare. The strip+post-run is fully contained here and
            # only activates when `(?{` is present, so normal regexes
            # are untouched. Multiple blocks run in order, joined by `;`.
            my str $emb_code = "";
            if (index($raw_pat, "(?{") >= 0) {
                my str $emb_stripped = "";
                my int $epi = 0;
                my int $eplen = length($raw_pat);
                while ($epi < $eplen) {
                    if ($epi + 2 < $eplen && substr($raw_pat, $epi, 3) eq "(?{") {
                        # Balance-match braces from just after `(?{`.
                        my int $edepth = 1;
                        my int $ej = $epi + 3;
                        my int $ecode_start = $ej;
                        while ($ej < $eplen && $edepth > 0) {
                            my str $ec = substr($raw_pat, $ej, 1);
                            if ($ec eq "{") { $edepth = $edepth + 1; }
                            elsif ($ec eq "}") { $edepth = $edepth - 1; }
                            if ($edepth == 0) { last; }
                            $ej = $ej + 1;
                        }
                        my str $ecode = substr($raw_pat, $ecode_start, $ej - $ecode_start);
                        if (length($emb_code) > 0) { $emb_code = $emb_code . "; "; }
                        $emb_code = $emb_code . $ecode;
                        # Skip the closing `}` and an optional `)`.
                        my int $eafter = $ej + 1;
                        if ($eafter < $eplen && substr($raw_pat, $eafter, 1) eq ")") {
                            $eafter = $eafter + 1;
                        }
                        $epi = $eafter;
                    } else {
                        $emb_stripped = $emb_stripped . substr($raw_pat, $epi, 1);
                        $epi = $epi + 1;
                    }
                }
                $raw_pat = $emb_stripped;
            }
            my str $pat = Perla::CodeGen::Escape::escape_c_str($raw_pat);
            my str $flags = "";
            if (defined($right->{"flags"})) { $flags = $right->{"flags"}; }
            my int $is_global = 0;
            if (index($flags, "g") >= 0) { $is_global = 1; }
            # Open the embedded-code wrapper: capture the match result so
            # we can run the stripped (?{ }) code on success.
            if (length($emb_code) > 0) {
                Perla::CodeGen::emit($cg, "({ StradaValue *__emb_mr = (");
            }
            # Detect `$var` interpolation in the pattern (including inside
            # `[...]` character classes) and build the runtime pattern
            # via _gen_interp_c_str. Without this, URI's
            # `s*([^$uric\#])*...*ego` had `[^$uric]` emitted literally
            # as `[^$uric\#]` — matched every char except `$`/`u`/`r`/...,
            # and URI->new escaped every char of every URL.
            my int $pat_has_var = Perla::CodeGen::has_perl_var($raw_pat);
            # The subject __rsv is gen_expr'd as an owned temp when the left
            # operand is not a borrowed lvalue (e.g. an interpolated string or
            # a call result). It is freed at the very end of each branch —
            # after any /g meta (pos) store, which reads __rsv. Borrowed
            # subjects (a bare variable) must NOT be decref'd.
            my str $rsv_free = (Perla::CodeGen::expr_is_borrowed($node->{"left"}) == 0) ? "strada_decref(__rsv); " : "";
            if ($is_global == 1 && defined($cg->{"regex_g_pos_var"}) && length($cg->{"regex_g_pos_var"}) > 0) {
                # /g with position tracking (inside while loop)
                # Capture SV first so subject_len override sees binary-safe length.
                # The left operand of =~ is always scalar context — even
                # when the surrounding statement is list context. Force
                # __perla_want_list = 0 around the gen_expr so calls
                # like `unpack(...) =~ /pat/g` evaluate unpack in scalar
                # context (returning a single string) instead of getting
                # the array form whose stringification is "ARRAY(0x...)".
                Perla::CodeGen::emit($cg, "({ int __sav_wl_rxl = __perla_want_list; __perla_want_list = 0; StradaValue *__rsv = ");
                Perla::CodeGen::gen_expr($cg, $node->{"left"});
                Perla::CodeGen::emit($cg, "; __perla_want_list = __sav_wl_rxl; strada_regex_set_subject_for_sv(__rsv); char *__rs = strada_to_str(__rsv); ");
                # /gc preserves pos on loop exit (for tokenizer patterns
                # that probe with \G then back-track). Mirror the local
                # pos var into the SV's meta on each successful match so
                # the final pos is visible after the loop via pos().
                my int $loop_has_c = 0;
                if (index($flags, "c") >= 0) { $loop_has_c = 1; }
                if ($pat_has_var == 1) {
                    Perla::CodeGen::emit($cg, "char *__pat = strada_to_str(");
                    Perla::CodeGen::Interp::gen_interp_c_str($cg, $raw_pat);
                    Perla::CodeGen::emit($cg, "); int __rm = strada_regex_match_global(__rs, __pat, \"" . $flags . "\", &" . $cg->{"regex_g_pos_var"} . "); free(__pat); ");
                } else {
                    Perla::CodeGen::emit($cg, "int __rm = strada_regex_match_global(__rs, \"" . $pat . "\", \"" . $flags . "\", &" . $cg->{"regex_g_pos_var"} . "); ");
                }
                if ($loop_has_c == 1) {
                    Perla::CodeGen::emit($cg, "if (__rm && __rsv && !STRADA_IS_TAGGED_INT(__rsv)) { StradaMetadata *__rwm = strada_ensure_meta(__rsv); if (__rwm) __rwm->regex_pos = (int32_t)" . $cg->{"regex_g_pos_var"} . "; } ");
                }
                Perla::CodeGen::emit($cg, "free(__rs); strada_regex_clear_subject_len(); " . $rsv_free . "STRADA_MAKE_TAGGED_INT(__rm); })");
            } elsif ($is_global == 1) {
                # /g outside a while loop. Two contexts to handle:
                #   - Scalar: track pos on the SV's meta so pos($var) and
                #     subsequent /g iterations resume from the right
                #     offset (matches perl). Pos stored in
                #     meta->regex_pos with -1 = unset / failed-match-reset.
                #   - List: return all matches' captures concatenated
                #     via strada_regex_match_list. (List-context /g
                #     consumes all matches at once; per-SV pos isn't
                #     meaningful since the iteration is done in one
                #     call.)
                # The left operand of =~ is always scalar context — even
                # when the surrounding statement is list context. Force
                # __perla_want_list = 0 around the gen_expr so calls
                # like `unpack(...) =~ /pat/g` evaluate unpack in scalar
                # context (returning a single string) instead of getting
                # the array form whose stringification is "ARRAY(0x...)".
                Perla::CodeGen::emit($cg, "({ int __sav_wl_rxl = __perla_want_list; __perla_want_list = 0; StradaValue *__rsv = ");
                Perla::CodeGen::gen_expr($cg, $node->{"left"});
                Perla::CodeGen::emit($cg, "; __perla_want_list = __sav_wl_rxl; strada_regex_set_subject_for_sv(__rsv); char *__rs = strada_to_str(__rsv); ");
                Perla::CodeGen::emit($cg, "StradaValue *__rmv; ");
                Perla::CodeGen::emit($cg, "if (__perla_want_list) { ");
                if ($pat_has_var == 1) {
                    Perla::CodeGen::emit($cg, "char *__pat = strada_to_str(");
                    Perla::CodeGen::Interp::gen_interp_c_str($cg, $raw_pat);
                    Perla::CodeGen::emit($cg, "); __rmv = strada_regex_match_list(__rs, __pat, \"" . $flags . "\"); free(__pat); ");
                } else {
                    Perla::CodeGen::emit($cg, "__rmv = strada_regex_match_list(__rs, \"" . $pat . "\", \"" . $flags . "\"); ");
                }
                Perla::CodeGen::emit($cg, "} else { ");
                Perla::CodeGen::emit($cg, "StradaMetadata *__rmeta = strada_ensure_meta(__rsv); ");
                # strada_regex_match_global takes size_t* — declare as size_t to
                # avoid 32/64-bit truncation that loses the pos on platforms
                # where int is 32-bit and size_t is 64-bit.
                Perla::CodeGen::emit($cg, "size_t __rpos = (__rmeta && __rmeta->regex_pos >= 0) ? (size_t)__rmeta->regex_pos : 0; ");
                if ($pat_has_var == 1) {
                    Perla::CodeGen::emit($cg, "char *__pat = strada_to_str(");
                    Perla::CodeGen::Interp::gen_interp_c_str($cg, $raw_pat);
                    Perla::CodeGen::emit($cg, "); int __rm = strada_regex_match_global(__rs, __pat, \"" . $flags . "\", &__rpos); free(__pat); ");
                } else {
                    Perla::CodeGen::emit($cg, "int __rm = strada_regex_match_global(__rs, \"" . $pat . "\", \"" . $flags . "\", &__rpos); ");
                }
                # On match, store new pos. On no-match: /c preserves pos
                # (perl semantics — used for tokenizers that backtrack via
                # \G); plain /g resets to -1.
                my int $has_c_flag = 0;
                if (index($flags, "c") >= 0) { $has_c_flag = 1; }
                if ($has_c_flag == 1) {
                    Perla::CodeGen::emit($cg, "if (__rmeta && __rm) __rmeta->regex_pos = (int32_t)__rpos; ");
                } else {
