            # — filehandle DUP, not a fopen of a path. The third arg is
            # an existing filehandle SV, not a filename. Capture it as
            # an SV up-front; if the mode is a dup form, hand it to
            # perla_open_dup (dup+fdopen the underlying fd). Otherwise
            # fall through to the normal fopen path, where stringifying
            # the FH SV is harmless. IPC::Open3 and stderr→stdout redirect
            # patterns need this to work.
            Perla::CodeGen::emit($cg, "({ " . $fh_decl . "char *__pm = strada_to_str(");
            Perla::CodeGen::gen_expr($cg, $args->[1]);
            Perla::CodeGen::emit($cg, "); StradaValue *__src_fh_sv = ");
            Perla::CodeGen::gen_expr($cg, $args->[2]);
            Perla::CodeGen::emit($cg, "; char *__fn = (__pm && strchr(__pm, '&')) ? NULL : strada_to_str(__src_fh_sv); char *__cm = __pm; ");
            Perla::CodeGen::emit($cg, "if (strcmp(__pm, \"<\") == 0) __cm = \"r\"; ");
            Perla::CodeGen::emit($cg, "else if (strcmp(__pm, \">\") == 0) __cm = \"w\"; ");
            Perla::CodeGen::emit($cg, "else if (strcmp(__pm, \">>\") == 0) __cm = \"a\"; ");
