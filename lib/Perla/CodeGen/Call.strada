            Perla::CodeGen::emit($cg, "size_t __wn = __we->value.av->size; for (size_t __wj = 0; __wj < __wn; __wj++) { ");
            Perla::CodeGen::emit($cg, "StradaValue *__wel = strada_array_get(__we->value.av, __wj); ");
            Perla::CodeGen::emit($cg, "char *__ws = strada_to_str(__wel); size_t __wl = __ws ? strlen(__ws) : 0; ");
            Perla::CodeGen::emit($cg, "if (__wl > 0) { if (__wblen + __wl + 1 > __wbcap) { __wbcap = (__wblen + __wl + 1) * 2; __wbuf = realloc(__wbuf, __wbcap); } memcpy(__wbuf + __wblen, __ws, __wl); __wblen += __wl; __wnl = (__ws[__wl-1] == '\\n'); } ");
            Perla::CodeGen::emit($cg, "free(__ws); } ");
            Perla::CodeGen::emit($cg, "} else { char *__ws = strada_to_str(__we); size_t __wl = __ws ? strlen(__ws) : 0; ");
            Perla::CodeGen::emit($cg, "if (__wl > 0) { if (__wblen + __wl + 1 > __wbcap) { __wbcap = (__wblen + __wl + 1) * 2; __wbuf = realloc(__wbuf, __wbcap); } memcpy(__wbuf + __wblen, __ws, __wl); __wblen += __wl; __wnl = (__ws[__wl-1] == '\\n'); } ");
