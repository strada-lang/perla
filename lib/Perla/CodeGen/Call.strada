    # sort
    if ($name eq "sort") {
        if ($argc == 1) {
            Perla::CodeGen::emit($cg, "strada_sort(");
            Perla::CodeGen::gen_expr($cg, $args->[0]);
            Perla::CodeGen::emit($cg, ")");
        } elsif ($argc > 1) {
