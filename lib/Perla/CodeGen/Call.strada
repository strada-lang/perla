                Perla::CodeGen::emit($cg, "{ StradaValue *__sfe = ");
                Perla::CodeGen::gen_expr($cg, $args->[$sfi]);
                Perla::CodeGen::emit($cg, "; if (__sfe && !STRADA_IS_TAGGED_INT(__sfe) && __sfe->type == STRADA_ARRAY) { StradaArray *__sfx = __sfe->value.av; if (__sfx) for (size_t __sfj = 0; __sfj < __sfx->size; __sfj++) { StradaValue *__sfk = __sfx->elements[__sfx->head + __sfj]; if (__sfk) strada_incref(__sfk); strada_array_push(__sav, __sfk); } } else { if (__sfe) strada_incref(__sfe); strada_array_push(__sav, __sfe); } } ");
                $sfi++;
            }
            Perla::CodeGen::emit($cg, "__perla_want_list = __sav_wl_sft; ");
            Perla::CodeGen::emit($cg, "int __sfn_args = (int)__sav->size; ");
            Perla::CodeGen::emit($cg, "if (__sfn_args >= 1) __sftm.tm_sec  = (int)strada_to_int(strada_array_get(__sav, 0)); ");
            Perla::CodeGen::emit($cg, "if (__sfn_args >= 2) __sftm.tm_min  = (int)strada_to_int(strada_array_get(__sav, 1)); ");
            Perla::CodeGen::emit($cg, "if (__sfn_args >= 3) __sftm.tm_hour = (int)strada_to_int(strada_array_get(__sav, 2)); ");
            Perla::CodeGen::emit($cg, "if (__sfn_args >= 4) __sftm.tm_mday = (int)strada_to_int(strada_array_get(__sav, 3)); ");
            Perla::CodeGen::emit($cg, "if (__sfn_args >= 5) __sftm.tm_mon  = (int)strada_to_int(strada_array_get(__sav, 4)); ");
            Perla::CodeGen::emit($cg, "if (__sfn_args >= 6) __sftm.tm_year = (int)strada_to_int(strada_array_get(__sav, 5)); ");
            Perla::CodeGen::emit($cg, "if (__sfn_args >= 7) __sftm.tm_wday = (int)strada_to_int(strada_array_get(__sav, 6)); ");
            Perla::CodeGen::emit($cg, "if (__sfn_args >= 8) __sftm.tm_yday = (int)strada_to_int(strada_array_get(__sav, 7)); ");
            Perla::CodeGen::emit($cg, "__sftm.tm_isdst = __sfn_args >= 9 ? (int)strada_to_int(strada_array_get(__sav, 8)) : -1; ");
            # Perl's POSIX::strftime runs the tm through mini_mktime — a
            # timezone-free calendar normalizer that ALWAYS recomputes
            # tm_wday/tm_yday from year/mon/mday (ignoring any supplied
            # wday/yday) and normalizes out-of-range fields (mday=32 -> next
            # month). Mirror it with timegm (UTC, no TZ/DST hour shifts) so
            # %A/%a/%w/%j and overflowed dates match Perl rather than trusting
            # the input wday (which defaulted to 0 = Sunday).
            Perla::CodeGen::emit($cg, "{ int __sf_isdst = __sftm.tm_isdst; struct tm __sftmp = __sftm; if (timegm(&__sftmp) != (time_t)-1) { __sftmp.tm_isdst = __sf_isdst; __sftm = __sftmp; } } ");
            Perla::CodeGen::emit($cg, "size_t __sflen = strftime(__sfb, sizeof(__sfb), __sff, &__sftm); ");
            Perla::CodeGen::emit($cg, "free(__sff); strada_decref(__sfa); strada_new_str_len(__sfb, __sflen); })");
            return;
        }
        Perla::CodeGen::emit($cg, "strada_new_str(\"\")");
        return;
    }
    # getpid
    if ($name eq "getpid") {
        Perla::CodeGen::emit($cg, "STRADA_MAKE_TAGGED_INT((int64_t)getpid())");
        return;
    }
    # getppid — parent process ID.
    if ($name eq "getppid") {
        Perla::CodeGen::emit($cg, "STRADA_MAKE_TAGGED_INT((int64_t)getppid())");
        return;
    }
    # getpwuid(N) / getpwnam(NAME) — Perl semantics:
    #   list context: 9 elems (name, passwd, uid, gid, quota, comment,
    #                          gcos, dir, shell)
    #   scalar context: just the name
    # Dispatches to perla_getpwuid_list / perla_getpwnam_list which
    # return a list-shaped array, vs perla_getpwuid_name (scalar form).
    if (($name eq "getpwuid" || $name eq "getpwnam") && $argc > 0) {
        my str $fn = $name;
        Perla::CodeGen::emit($cg, "(__perla_want_list ? ");
        Perla::CodeGen::emit($cg, "perla_" . $fn . "_list(");
        Perla::CodeGen::gen_expr($cg, $args->[0]);
        Perla::CodeGen::emit($cg, ") : perla_" . $fn . "_name(");
        Perla::CodeGen::gen_expr($cg, $args->[0]);
        Perla::CodeGen::emit($cg, "))");
        return;
    }
    # getpgrp — process group ID.
    if ($name eq "getpgrp") {
        Perla::CodeGen::emit($cg, "STRADA_MAKE_TAGGED_INT((int64_t)getpgrp())");
        return;
    }
    # rand/srand
    #
    # Perl's `randfunc` on Debian-family perl5 is `Perl_drand48` —
    # libc's drand48 family. Using `rand()/RAND_MAX` (LCG with a
    # different state) produces a sequence that diverges immediately
    # from perl's after the same srand. Wire to drand48()/srand48()
    # so `srand(42); rand(); rand()` round-trips bit-for-bit with
    # perl (verified against the libc impl on Debian 13.x perl 5.38).
    if ($name eq "rand") {
        Perla::CodeGen::emit($cg, "strada_new_num(drand48() * strada_to_num(");
        if ($argc > 0) { Perla::CodeGen::gen_expr($cg, $args->[0]); }
        else { Perla::CodeGen::emit($cg, "STRADA_MAKE_TAGGED_INT(1)"); }
        Perla::CodeGen::emit($cg, "))");
        return;
    }
    if ($name eq "srand") {
        Perla::CodeGen::emit($cg, "({ srand48((long)strada_to_int(");
        if ($argc > 0) { Perla::CodeGen::gen_expr($cg, $args->[0]); }
        else { Perla::CodeGen::emit($cg, "STRADA_MAKE_TAGGED_INT((int64_t)time(NULL))"); }
        Perla::CodeGen::emit($cg, ")); strada_new_undef(); })");
        return;
    }
    # die with list args
    if ($name eq "die" && $argc > 1) {
        Perla::CodeGen::emit($cg, "({ StradaValue *__dv = strada_new_str(\"\"); ");
        my int $di = 0;
        while ($di < $argc) {
            Perla::CodeGen::emit($cg, "__dv = strada_concat_sv(__dv, ");
            Perla::CodeGen::gen_expr($cg, $args->[$di]);
            Perla::CodeGen::emit($cg, "); ");
            $di++;
        }
        Perla::CodeGen::emit($cg, "if (perla_eval_error) strada_decref(perla_eval_error); ");
        # Transfer __dv ownership to perla_eval_error — see comment at
        # the simple-die path ~12937. Old `incref(perla_eval_error)` left
        # an extra ref that died with the longjmp'd local pointer.
        Perla::CodeGen::emit($cg, "perla_eval_error = __dv; ");
        Perla::CodeGen::emit($cg, "char *__dm = strada_to_str(__dv); strada_die(\"%s\", __dm); free(__dm); strada_new_undef(); })");
        return;
    }
    # lc/uc/length/chomp with no args → default to $_
    if ($name eq "lc" && $argc == 0) {
        Perla::CodeGen::emit($cg, "({ char *__s = strada_to_str(perla_dollar_underscore ? perla_dollar_underscore : strada_new_str(\"\")); char *__r = strada_lc(__s); StradaValue *__rv = strada_new_str(__r); free(__r); free(__s); __rv; })");
        return;
    }
    if ($name eq "uc" && $argc == 0) {
        Perla::CodeGen::emit($cg, "({ char *__s = strada_to_str(perla_dollar_underscore ? perla_dollar_underscore : strada_new_str(\"\")); char *__r = strada_uc(__s); StradaValue *__rv = strada_new_str(__r); free(__r); free(__s); __rv; })");
        return;
    }
    if ($name eq "length" && $argc == 0) {
        Perla::CodeGen::emit($cg, "({ char *__s = strada_to_str(perla_dollar_underscore ? perla_dollar_underscore : strada_new_str(\"\")); int64_t __len = (int64_t)strlen(__s); free(__s); STRADA_MAKE_TAGGED_INT(__len); })");
        return;
    }

    # eval "string" — runtime string eval via compile + dlopen.
    # Pass the calling sub's @_ so eval'd code's $_[N] sees the caller's
    # args (Sub::Quote relies on this — `_clean_eval(\$code, \%captures)`
    # needs the eval body to read `$_[1] = \%captures`).
    # In-scope `my $x` scalars are captured via perla_eval_string_with_lexicals
    # when present; see _emit_eval_string_with_caps.
    if ($name eq "eval") {
        if ($argc > 0) {
            my scalar $fake_node = {};
            $fake_node->{"expr"} = $args->[0];
            Perla::CodeGen::Eval::emit_eval_string_with_caps($cg, $fake_node, 1);
        } else {
            Perla::CodeGen::emit($cg, "strada_new_undef()");
        }
        return;
    }

    # Code reference call: $ref->(args)
    # Delegate to perla_call_code which already handles every callable
    # shape: closures (bare and ref-wrapped), CPOINTERs (with the
    # XSUB/non-XSUB calling-convention split), and STRADA_STR holding
    # a perla_sub_* symbol name (dlsym lookup). The previous inline
    # switch missed the STR case, so any value coming out of
    # `Class->can("method")` (which returns the SLOT_CODE value) was
    # uninvokable when the method was a perla-source-compiled sub.
    if ($name eq "__coderef__" && defined($node->{"coderef"})) {
        # `&\$sub` (no parens) — pass the caller's perla_at_ through, just
        # like the bare-&IDENT form does. Without this, the no-parens
        # form called with an empty arg list, breaking wrappers that rely
        # on perl's "pass @_ unchanged" semantics.
        my int $cr_pass = 0;
        if (defined($node->{"pass_caller_args"}) && $node->{"pass_caller_args"} == 1) { $cr_pass = 1; }
        if ($cr_pass == 1) {
            Perla::CodeGen::emit($cg, "({ StradaValue *__cr = ");
            Perla::CodeGen::gen_expr($cg, $node->{"coderef"});
            Perla::CodeGen::emit($cg, "; StradaValue *__cov = (__cr && !STRADA_IS_TAGGED_INT(__cr) && __cr->type == STRADA_REF) ? perla_overload_deref(__cr, \"&{}\") : NULL; if (__cov) __cr = __cov; ");
            Perla::CodeGen::emit($cg, "StradaValue *__crr = perla_call_code(__cr, perla_at_); __crr; })");
            return;
        }
        Perla::CodeGen::emit($cg, "({ StradaValue *__cr = ");
        Perla::CodeGen::gen_expr($cg, $node->{"coderef"});
        Perla::CodeGen::emit($cg, "; StradaValue *__cov = (__cr && !STRADA_IS_TAGGED_INT(__cr) && __cr->type == STRADA_REF) ? perla_overload_deref(__cr, \"&{}\") : NULL; if (__cov) __cr = __cov; ");
        Perla::CodeGen::emit($cg, "StradaValue *__ca = strada_new_array(); StradaArray *__av = strada_deref_array(__ca); ");
        _gen_push_args($cg, $args, $argc);
        Perla::CodeGen::emit($cg, "StradaValue *__crr = perla_call_code(__cr, __ca); strada_decref(__ca); __crr; })");
        return;
    }

    # User-defined function call — resolve qualified name
    my str $qname = _resolve_sub($cg, $name);
    if (length($qname) > 0) {
        my str $fname = Perla::CodeGen::sub_cname_q($qname);
        # `&sub` (no args, no parens) — pass the caller's @_ THROUGH so
        # the callee sees and can shift/pop it. Hash::Merge's `_get_obj`
        # depends on this.
        my int $is_amp_pass = 0;
        if (defined($node->{"pass_caller_args"}) && $node->{"pass_caller_args"} == 1) { $is_amp_pass = 1; }
        if ($is_amp_pass == 1) {
            Perla::CodeGen::emit($cg, $fname . "(perla_at_)");
            return;
        }
        # Split qname into pkg + short for the stash-override check.
        # Glob assignment (`*Pkg::sub = sub {...}`) replaces the CODE
        # slot with a non-STRADA_STR value; the original perla_code_set
        # registered it as STRADA_STR("perla_sub_Pkg_sub"). At each
        # call site, peek the slot — if it's been overridden (non-STR),
        # route through perla_call_code; otherwise fall through to the
        # direct C call. Without this, glob replacement was silently
        # ignored (Devel::Mock-style patterns, around-overrides at
        # runtime, etc.).
        my int $__qn_li = -1;
        my int $__qn_si = 0;
        while ($__qn_si < length($qname) - 1) {
            if (substr($qname, $__qn_si, 2) eq "::") { $__qn_li = $__qn_si; }
            $__qn_si = $__qn_si + 1;
        }
        my str $__qn_pkg = "main";
        my str $__qn_short = $qname;
        if ($__qn_li > 0) {
            $__qn_pkg = substr($qname, 0, $__qn_li);
            $__qn_short = substr($qname, $__qn_li + 2, length($qname) - $__qn_li - 2);
        }
        # Try direct-arg call if sub has known params and args are simple scalars
        my scalar $pinfo = $cg->{"sub_params"}->{$qname};
        if (defined($pinfo) && $pinfo->{"arity"} == $argc && Perla::CodeGen::Predicate::args_are_simple($args, $argc) == 1) {
            # Wrap in statement expression to capture and decref temp args.
            # Borrowed args (plain variables) are NOT decref'd at the call
            # site — they belong to the caller. Without this guard,
            # `modify($t)` would decref v_t after the call and corrupt
            # subsequent uses of $t. Hash/array element access returns
            # OWNED via strada_hv_fetch_owned, so those DO need decref.
            Perla::CodeGen::emit($cg, "({ ");
            my int $ai = 0;
            while ($ai < $argc) {
                Perla::CodeGen::emit($cg, "StradaValue *__da" . $ai . " = ");
                Perla::CodeGen::gen_expr($cg, $args->[$ai]);
                Perla::CodeGen::emit($cg, "; ");
                $ai++;
            }
            Perla::CodeGen::emit($cg, "StradaValue *__dr = " . $fname . "__direct(");
            $ai = 0;
            while ($ai < $argc) {
                if ($ai > 0) { Perla::CodeGen::emit($cg, ", "); }
                Perla::CodeGen::emit($cg, "__da" . $ai);
                $ai++;
            }
            # Trailing perla_args_full — NULL signals __direct to build
            # perla_at_ from the named params (the prior behavior).
            if ($argc > 0) { Perla::CodeGen::emit($cg, ", "); }
            Perla::CodeGen::emit($cg, "NULL");
            Perla::CodeGen::emit($cg, "); ");
            $ai = 0;
            while ($ai < $argc) {
                my int $da_t = $args->[$ai]->{"type"};
                my int $da_borrowed = 0;
                if ($da_t == Perla::AST::N_SCALAR_VAR() ||
                    $da_t == Perla::AST::N_ARRAY_VAR() ||
                    $da_t == Perla::AST::N_HASH_VAR()) {
                    $da_borrowed = 1;
                }
                if ($da_borrowed == 0) {
                    Perla::CodeGen::emit($cg, "strada_decref(__da" . $ai . "); ");
                }
                $ai++;
            }
            Perla::CodeGen::emit($cg, "__dr; })");
        } elsif ($argc == 0) {
            Perla::CodeGen::emit($cg, "({ static StradaValue *__ovr_c = NULL; static long __ovr_g = -1; if (__ovr_g != perla_code_override_gen) { __ovr_c = perla_code_get(\"" . $__qn_pkg . "\", \"" . $__qn_short . "\"); __ovr_g = perla_code_override_gen; } StradaValue *__ovr = __ovr_c; ");
            Perla::CodeGen::emit($cg, "(__ovr && !STRADA_IS_TAGGED_INT(__ovr) && __ovr->type != STRADA_STR) ");
            Perla::CodeGen::emit($cg, "  ? ({ StradaValue *__oa = strada_new_array(); StradaValue *__or = perla_call_code(__ovr, __oa); strada_decref(__oa); __or; }) ");
            Perla::CodeGen::emit($cg, "  : " . $fname . "(NULL); })");
        } else {
            Perla::CodeGen::emit($cg, "({ StradaValue *__a = strada_new_array(); StradaArray *__av = strada_deref_array(__a); ");
            _gen_push_args($cg, $args, $argc);
            # Snapshot @_'s head before the call so writeback can detect
            # whether the callee shifted/popped. shift/pop move head/tail
            # of perla_at_ (== __av), and the post-call __av[0] read would
            # otherwise return the original second arg — which then gets
            # written back to the caller's first variable, smashing it
            # (`my $f = shift; my @captured = @_; return sub { … }` did
            # this in curry()-style closures: every closure beyond the
            # first one corrupted v_add because writeback wrote the
            # curried value back over the coderef).
            Perla::CodeGen::emit($cg, "size_t __a_head_before = __av ? __av->head : 0; size_t __a_size_before = __av ? __av->size : 0; ");
            # Stash override check (see argc==0 branch comment). Cached by
            # the global override generation so the common (no runtime
            # monkey-patch) path skips the per-call stash hash lookup.
            Perla::CodeGen::emit($cg, "static StradaValue *__cv_c = NULL; static long __cv_g = -1; if (__cv_g != perla_code_override_gen) { __cv_c = perla_code_get(\"" . $__qn_pkg . "\", \"" . $__qn_short . "\"); __cv_g = perla_code_override_gen; } StradaValue *__cv_ovr = __cv_c; ");
            Perla::CodeGen::emit($cg, "StradaValue *__fr = (__cv_ovr && !STRADA_IS_TAGGED_INT(__cv_ovr) && __cv_ovr->type != STRADA_STR) ");
            Perla::CodeGen::emit($cg, "  ? perla_call_code(__cv_ovr, __a) ");
            Perla::CodeGen::emit($cg, "  : " . $fname . "(__a); ");
            # Perl @_ aliasing: when caller passes a plain scalar
            # variable, the callee's $_[N] is an alias to it. We
            # approximate this by copying back @_'s element N to the
            # caller's variable after the call. Required for idioms
            # like `_strip_trailing_sep($dirname)` which uses
            # `$_[0] =~ s|/$||`. Only direct N_SCALAR_VAR args are
            # written back; expressions / literals are not. Vars
            # are matched by AST position, not by aliasing — close
            # enough for the common case.
            my int $wb_ai = 0;
            while ($wb_ai < $argc) {
                my scalar $wb_arg = $args->[$wb_ai];
                if (defined($wb_arg) && $wb_arg->{"type"} == Perla::AST::N_SCALAR_VAR()
                    && defined($wb_arg->{"name"}) && length($wb_arg->{"name"}) > 0
                    && index($wb_arg->{"name"}, "::") < 0
                    && $wb_arg->{"name"} ne "_" && $wb_arg->{"name"} ne "@") {
                    # Skip read-only specials ($1-$9, $&, etc.)
                    my str $wb_name = $wb_arg->{"name"};
                    my int $wb_is_ro = 0;
                    if (length($wb_name) == 1) {
                        my int $wb_c0 = char_at($wb_name, 0);
                        if ($wb_c0 >= 49 && $wb_c0 <= 57) { $wb_is_ro = 1; }
                        if ($wb_name eq "&" || $wb_name eq "`" || $wb_name eq "'" || $wb_name eq "+") { $wb_is_ro = 1; }
                    }
                    if ($wb_is_ro == 0) {
                        my str $wb_cv = Perla::CodeGen::c_var($wb_name);
                        # Only write back if @_ wasn't shifted/popped (head
                        # unchanged, size still at least the index). A shift
                        # moves head forward, so __av[N] then reads a
                        # different element than the caller's original arg N
                        # — and the resulting writeback would mutate the
                        # caller's var to the curried/leftover element.
                        Perla::CodeGen::emit($cg, "if (__av && __av->head == __a_head_before && __av->size > " . $wb_ai . ") { ");
                        Perla::CodeGen::emit($cg, "StradaValue *__wb" . $wb_ai . " = strada_array_get(__av, " . $wb_ai . "); ");
                        Perla::CodeGen::emit($cg, "if (__wb" . $wb_ai . " != " . $wb_cv . ") { ");
                        Perla::CodeGen::emit($cg, "if (__wb" . $wb_ai . ") strada_incref(__wb" . $wb_ai . "); ");
                        Perla::CodeGen::emit($cg, "strada_decref(" . $wb_cv . "); " . $wb_cv . " = __wb" . $wb_ai . "; } } ");
                    }
                }
                # `inc($arr[0])` / `inc($h{k})` — @_[N] aliases the array
                # element / hash entry. Write back via strada_array_set
                # / strada_hash_set if @_ wasn't shifted. Both `$arr[i]`
                # (no-arrow) and `$ref->[i]` parse to N_ARROW_ARRAY in
                # perla — same node, the `is_explicit_arrow` flag
                # distinguishes. For writeback both forms work the same.
                elsif (defined($wb_arg) && $wb_arg->{"type"} == Perla::AST::N_ARROW_ARRAY()) {
                    Perla::CodeGen::emit($cg, "if (__av && __av->head == __a_head_before && __av->size > " . $wb_ai . ") { ");
                    Perla::CodeGen::emit($cg, "StradaValue *__wb" . $wb_ai . " = strada_array_get(__av, " . $wb_ai . "); ");
                    Perla::CodeGen::emit($cg, "StradaArray *__wba" . $wb_ai . " = strada_deref_array(");
                    Perla::CodeGen::gen_expr($cg, $wb_arg->{"object"});
                    Perla::CodeGen::emit($cg, "); int64_t __wbi" . $wb_ai . " = strada_to_int(");
                    Perla::CodeGen::gen_expr($cg, $wb_arg->{"index"});
                    Perla::CodeGen::emit($cg, "); if (__wba" . $wb_ai . " && __wb" . $wb_ai . ") { ");
                    Perla::CodeGen::emit($cg, "strada_array_set(__wba" . $wb_ai . ", (int)__wbi" . $wb_ai . ", __wb" . $wb_ai . "); } } ");
                }
                elsif (defined($wb_arg) && $wb_arg->{"type"} == Perla::AST::N_ARROW_HASH()) {
                    Perla::CodeGen::emit($cg, "if (__av && __av->head == __a_head_before && __av->size > " . $wb_ai . ") { ");
                    Perla::CodeGen::emit($cg, "StradaValue *__wb" . $wb_ai . " = strada_array_get(__av, " . $wb_ai . "); ");
                    Perla::CodeGen::emit($cg, "StradaHash *__wbh" . $wb_ai . " = strada_deref_hash(");
                    Perla::CodeGen::gen_expr($cg, $wb_arg->{"object"});
                    Perla::CodeGen::emit($cg, "); char *__wbk" . $wb_ai . " = strada_to_str(");
                    Perla::CodeGen::gen_expr($cg, $wb_arg->{"key"});
                    Perla::CodeGen::emit($cg, "); if (__wbh" . $wb_ai . " && __wb" . $wb_ai . ") { ");
                    Perla::CodeGen::emit($cg, "strada_hash_set(__wbh" . $wb_ai . ", __wbk" . $wb_ai . ", __wb" . $wb_ai . "); } ");
                    Perla::CodeGen::emit($cg, "free(__wbk" . $wb_ai . "); } ");
                }
                $wb_ai++;
            }
            Perla::CodeGen::emit($cg, "strada_incref(__fr); strada_decref(__a); __fr; })");
        }
        return;
    }

    # Check if it's an our (global) variable used as a bareword. ONLY for
    # scalar ones — bareword `ISA` is a string "ISA", not `@ISA`, even when
    # `our @ISA` is declared elsewhere. Perl's bareword rules never promote
    # a bareword to an array/hash deref. Without this narrowing,
    # YAML::Node's `our @ISA = qw(…)` leaks "ISA" into the shared
    # our_vars table and YAML::Mo's `$P.ISA` in sub_2 emits `v_ISA`
    # (@ISA of main) instead of the string "ISA", so @{$P.ISA}=… writes
    # to the wrong place.
    if ($argc == 0 && defined($cg->{"our_vars"}->{$name})
        && $cg->{"our_vars"}->{$name} eq "SCALAR_VAR") {
        Perla::CodeGen::emit($cg, Perla::CodeGen::c_var($name));
        return;
    }

    # Strada core:: and math:: namespace calls — emit direct runtime calls
    if (index($name, "::") >= 0) {
        my int $dc = index($name, "::");
        my str $ns = substr($name, 0, $dc);
        my str $fn = substr($name, $dc + 2, length($name) - $dc - 2);

        if ($ns eq "core" || $ns eq "sys") {
            # core::func() → strada_func(args)
            Perla::CodeGen::emit($cg, "strada_" . $fn . "(");
            _gen_call_args_inline($cg, $args, $argc);
            Perla::CodeGen::emit($cg, ")");
            return;
        }
        if ($ns eq "math") {
            # math::func() → strada function or C math function
            if ($fn eq "sqrt" || $fn eq "sin" || $fn eq "cos" || $fn eq "tan" ||
                $fn eq "log" || $fn eq "exp" || $fn eq "abs" || $fn eq "floor" ||
                $fn eq "ceil" || $fn eq "pow" || $fn eq "atan2" || $fn eq "fmod") {
                Perla::CodeGen::emit($cg, "strada_new_num(" . $fn . "(");
                if ($argc > 0) {
                    Perla::CodeGen::emit($cg, "strada_to_num(");
                    Perla::CodeGen::gen_expr($cg, $args->[0]);
                    Perla::CodeGen::emit($cg, ")");
                    my int $mai = 1;
                    while ($mai < $argc) {
                        Perla::CodeGen::emit($cg, ", strada_to_num(");
                        Perla::CodeGen::gen_expr($cg, $args->[$mai]);
                        Perla::CodeGen::emit($cg, ")");
                        $mai++;
                    }
                }
                Perla::CodeGen::emit($cg, "))");
                return;
            }
        }
    }

    # Unknown function — dispatch through stash at runtime (supports XS, dynamic loading)
    if (index($name, "::") >= 0) {
        # Find LAST :: for correct package::name split
        my int $dc = -1;
        my int $dci = 0;
        while ($dci < length($name) - 1) {
            if (substr($name, $dci, 2) eq "::") { $dc = $dci; }
            $dci++;
        }
        my str $call_pkg = substr($name, 0, $dc);
        my str $call_fn = substr($name, $dc + 2, length($name) - $dc - 2);
        # For 0-arg calls to a package-qualified bareword (e.g.
        # `Object::new` used as a string in `*{$M.Object::new}`), fall
        # back to the stringified bareword name when the sub isn't
        # defined. This matches Perl's no-strict-subs semantics and is
        # what YAML::Mo's Mo::Inline blob relies on:
        #   *{$M . Object::new} = sub {...};
        # Only applies to package-qualified barewords to keep the
        # unqualified case unchanged (no-arg builtin calls etc.).
        if ($argc == 0) {
            my int $has_parens = 0;
            if (defined($node->{"has_parens"}) && $node->{"has_parens"} == 1) { $has_parens = 1; }
            Perla::CodeGen::emit($cg, "({ StradaValue *__xs_fn_name = perla_code_get(\"" . $call_pkg . "\", \"" . $call_fn . "\"); ");
            # Pkg's perla_mod_init may not have run yet (a top-level call into a
            # `use`d dependency whose init hasn't fired in the cascade) — lazy-run
            # it and retry before failing. Fixes Moose::Exporter::_make_exporter
            # dying "Undefined subroutine &Sub::Exporter::build_exporter".
            Perla::CodeGen::emit($cg, "if (!__xs_fn_name) { perla_ensure_mod_init(\"" . $call_pkg . "\"); __xs_fn_name = perla_code_get(\"" . $call_pkg . "\", \"" . $call_fn . "\"); } ");
            Perla::CodeGen::emit($cg, "StradaValue *__xs_result; ");
            Perla::CodeGen::emit($cg, "if (__xs_fn_name) { StradaValue *__xs_args = strada_new_array(); __xs_result = perla_call_code(__xs_fn_name, __xs_args); strada_decref(__xs_args); } ");
            # When the call had explicit parens (`Foo::bar()`), it's a
            # function-call syntax — try AUTOLOAD as a final fallback
            # before returning undef. Matches Perl's function-call
            # dispatch semantics. Without parens (`Foo::bar` as a
            # bareword), fall back to the stringified name — needed by
            # YAML::Mo's `*{$M . Object::new} = sub {...}` idiom.
            if ($has_parens == 1) {
                # Die when sub doesn't exist (matches Perl). Without this
                # the call silently returned undef and eval STRING
                # couldn't set $@.
                Perla::CodeGen::emit($cg, "else { PerlGlob *__al_g = perla_autoload_resolve(\"" . $call_pkg . "\"); ");
                Perla::CodeGen::emit($cg, "  if (__al_g && __al_g->slots[PERLA_SLOT_CODE]) { ");
                Perla::CodeGen::emit($cg, "    perla_set_autoload_var(\"" . $call_pkg . "::" . $call_fn . "\"); ");
                Perla::CodeGen::emit($cg, "    StradaValue *__xs_args = strada_new_array(); ");
                Perla::CodeGen::emit($cg, "    __xs_result = perla_call_code(__al_g->slots[PERLA_SLOT_CODE], __xs_args); ");
                Perla::CodeGen::emit($cg, "    strada_decref(__xs_args); ");
                Perla::CodeGen::emit($cg, "  } else { strada_die(\"Undefined subroutine &" . $call_pkg . "::" . $call_fn . " called\"); __xs_result = strada_new_undef(); } } ");
            } else {
                Perla::CodeGen::emit($cg, "else { __xs_result = strada_new_str(\"" . $call_pkg . "::" . $call_fn . "\"); } ");
            }
            Perla::CodeGen::emit($cg, "__xs_result; })");
        } else {
            # When the sub isn't found, try AUTOLOAD as a final fallback:
            # set `$AUTOLOAD = "pkg::name"`, then call the package's
            # AUTOLOAD sub if it has one. Matches Perl's function-call
            # dispatch semantics (method calls already AUTOLOAD via
            # perla_method_resolve).
            Perla::CodeGen::emit($cg, "({ StradaValue *__xs_fn_name = perla_code_get(\"" . $call_pkg . "\", \"" . $call_fn . "\"); ");
            # Lazy-init Pkg on a miss then retry (see no-args path above).
            Perla::CodeGen::emit($cg, "if (!__xs_fn_name) { perla_ensure_mod_init(\"" . $call_pkg . "\"); __xs_fn_name = perla_code_get(\"" . $call_pkg . "\", \"" . $call_fn . "\"); } ");
            Perla::CodeGen::emit($cg, "StradaValue *__xs_args = strada_new_array(); StradaArray *__av = strada_deref_array(__xs_args); ");
            _gen_push_args($cg, $args, $argc);
            Perla::CodeGen::emit($cg, "StradaValue *__xs_result; ");
            Perla::CodeGen::emit($cg, "if (__xs_fn_name) { __xs_result = perla_call_code(__xs_fn_name, __xs_args); strada_decref(__xs_args); } ");
            Perla::CodeGen::emit($cg, "else { PerlGlob *__al_g = perla_autoload_resolve(\"" . $call_pkg . "\"); ");
            Perla::CodeGen::emit($cg, "  if (__al_g && __al_g->slots[PERLA_SLOT_CODE]) { ");
            Perla::CodeGen::emit($cg, "    perla_set_autoload_var(\"" . $call_pkg . "::" . $call_fn . "\"); ");
            Perla::CodeGen::emit($cg, "    __xs_result = perla_call_code(__al_g->slots[PERLA_SLOT_CODE], __xs_args); strada_decref(__xs_args); ");
            # Die when sub doesn't exist (matches Perl). Decref args first
            # since strada_die longjmps past anything after it.
            Perla::CodeGen::emit($cg, "  } else { strada_decref(__xs_args); strada_die(\"Undefined subroutine &" . $call_pkg . "::" . $call_fn . " called\"); __xs_result = strada_new_undef(); } } ");
            Perla::CodeGen::emit($cg, "__xs_result; })");
        }
    } else {
        # Unqualified unknown function: try current package stash, then main::.
        # 0-arg form applies the no-strict-subs bareword-as-string fallback
        # — Perl stringifies `BAREWORD` to "BAREWORD" when no such sub
        # exists. Mo::Inline-style modules rely on this to build symbol
        # names dynamically: `*{$M.import}=sub{...}` needs `import` to
        # stringify, not return undef.
        #
        # When the name is NOT in $cg->{"subs"} (no visible `sub NAME {}` in
        # the file), Perl's compile-time resolution has already decided this
        # is a bareword. Doing a runtime code_get lookup is wrong: sibling
        # code can install a sub by that name via `*{$M.NAME}=sub{...}`
        # before this expression is evaluated, and the lookup would then
        # accidentally CALL the installed sub during load — triggering
        # sub_2 in Mo::Inline before the user's `use YAML::Mo` fires, and
        # polluting the module's own stash with extends/has/@ISA entries.
        # Emit the string directly and skip the runtime lookup entirely.
        my str $try_pkg = $cg->{"pkg"};
        my int $has_parens_u = 0;
        if (defined($node->{"has_parens"}) && $node->{"has_parens"} == 1) { $has_parens_u = 1; }
        if ($argc == 0) {
            # With explicit parens (`NAME()`), this is a function-call syntax —
            # look up the sub at runtime. Without parens, treat as bareword
            # string (no-strict-subs Mo::Inline pattern). This matters for
            # `${\ greet()}` and `@{[greet()]}` interpolation idioms where
            # eval STRING compiles the inner expression as a fresh unit and
            # has no static knowledge of `greet`.
            if ($has_parens_u == 1) {
                Perla::CodeGen::emit($cg, "({ StradaValue *__xs_fn_name = perla_code_get(\"" . $try_pkg . "\", \"" . $name . "\"); ");
                Perla::CodeGen::emit($cg, "if (!__xs_fn_name) __xs_fn_name = perla_code_get(\"main\", \"" . $name . "\"); ");
                Perla::CodeGen::emit($cg, "if (!__xs_fn_name) __xs_fn_name = perla_code_get_walking(\"" . $name . "\"); ");
                Perla::CodeGen::emit($cg, "StradaValue *__xs_args = strada_new_array(); ");
                # Die with Perl's standard "Undefined subroutine" message
                # when the bareword resolves to no sub at runtime. Without
                # this, calls to non-existent subs silently returned undef
                # and (worse) eval STRING couldn't set $@ for the standard
                # `eval "no_such_func()"; print $@` introspection idiom.
                Perla::CodeGen::emit($cg, "StradaValue *__xs_result; ");
                Perla::CodeGen::emit($cg, "if (__xs_fn_name) { __xs_result = perla_call_code(__xs_fn_name, __xs_args); } ");
                Perla::CodeGen::emit($cg, "else { strada_decref(__xs_args); strada_die(\"Undefined subroutine &" . $try_pkg . "::" . $name . " called\"); __xs_result = strada_new_undef(); } ");
                Perla::CodeGen::emit($cg, "if (__xs_fn_name) strada_decref(__xs_args); __xs_result; })");
            } else {
                # Bareword without parens: if a sub of this name is known
                # via any stash, call it (covers `use POSIX qw(INT_MAX);
                # print INT_MAX` style — constants exported as 0-arg subs).
                # Otherwise fall back to a string literal (no-strict-subs
                # bareword string idiom). Walking respects load order so
                # explicitly-used modules win over init-time stubs.
                #
                # strict 'subs': under `use strict;`, the string-fallback
                # is a compile error in real Perl. We emit a runtime
                # check: if the lookup fails, die with the Perl-style
                # message rather than silently substituting the bareword
                # as a string. Compile-time `_resolve_sub` would false-
                # positive on imports loaded at runtime (`use POSIX qw(X)`
                # registers X via perla_code_set in the package init —
                # not visible to $cg->{"subs"} until runtime), so we
                # defer to runtime where the stash IS populated.
                my int $__bw_strict_subs = 0;
                if (defined($cg->{"strict_subs"}) && $cg->{"strict_subs"} == 1) {
                    $__bw_strict_subs = 1;
                }
                # Special filehandle barewords are valid filehandle
                # references even when not bound as subs — they're
                # built into the runtime. Without this, code like
                # `select(STDOUT)` died under strict 'subs' because
                # STDOUT isn't a registered sub. STDIN/STDOUT/STDERR
                # specifically resolve to runtime filehandle wrappers
                # via strada_new_filehandle(stdout) at the call site.
                if ($name eq "STDIN" || $name eq "STDOUT" || $name eq "STDERR"
                    || $name eq "ARGV" || $name eq "DATA") {
                    my str $__fh_stream = "stdout";
                    if ($name eq "STDIN")  { $__fh_stream = "stdin"; }
                    if ($name eq "STDERR") { $__fh_stream = "stderr"; }
                    if ($name eq "STDIN" || $name eq "STDOUT" || $name eq "STDERR") {
                        # Build an on-the-fly STRADA_FILEHANDLE wrapper.
                        # The libc stream isn't closed by strada's decref
                        # because we clear value.fh before decref.
                        Perla::CodeGen::emit($cg, "({ StradaValue *__fh = strada_new_filehandle(" . $__fh_stream . "); __fh; })");
                    } else {
                        # ARGV/DATA — fall through to runtime bareword string
                        Perla::CodeGen::emit($cg, "strada_new_str(\"" . $name . "\")");
                    }
                    return;
                }
                Perla::CodeGen::emit($cg, "({ StradaValue *__bw_fn = perla_code_get(\"" . $try_pkg . "\", \"" . $name . "\"); ");
                Perla::CodeGen::emit($cg, "if (!__bw_fn) __bw_fn = perla_code_get(\"main\", \"" . $name . "\"); ");
                Perla::CodeGen::emit($cg, "if (!__bw_fn) __bw_fn = perla_code_get_walking(\"" . $name . "\"); ");
                Perla::CodeGen::emit($cg, "StradaValue *__bw_v; ");
                Perla::CodeGen::emit($cg, "if (__bw_fn) { StradaValue *__bw_args = strada_new_array(); __bw_v = perla_call_code(__bw_fn, __bw_args); strada_decref(__bw_args); } ");
                if ($__bw_strict_subs == 1) {
                    Perla::CodeGen::emit($cg, "else { strada_die(\"Bareword \\\"" . $name . "\\\" not allowed while \\\"strict subs\\\" in use\"); __bw_v = strada_new_undef(); } ");
                } else {
                    Perla::CodeGen::emit($cg, "else { __bw_v = strada_new_str(\"" . $name . "\"); } ");
                }
                Perla::CodeGen::emit($cg, "__bw_v; })");
            }
        } else {
            Perla::CodeGen::emit($cg, "({ StradaValue *__xs_fn_name = perla_code_get(\"" . $try_pkg . "\", \"" . $name . "\"); ");
            Perla::CodeGen::emit($cg, "if (!__xs_fn_name) __xs_fn_name = perla_code_get(\"main\", \"" . $name . "\"); ");
            Perla::CodeGen::emit($cg, "if (!__xs_fn_name) __xs_fn_name = perla_code_get_walking(\"" . $name . "\"); ");
            Perla::CodeGen::emit($cg, "StradaValue *__xs_args = strada_new_array(); StradaArray *__av = strada_deref_array(__xs_args); ");
            _gen_push_args($cg, $args, $argc);
            Perla::CodeGen::emit($cg, "StradaValue *__xs_result = __xs_fn_name ? perla_call_code(__xs_fn_name, __xs_args) : strada_new_undef(); ");
            Perla::CodeGen::emit($cg, "strada_decref(__xs_args); __xs_result; })");
        }
    }
}

# Emit a slot-store of `__fh` into the open()/sysopen() first-arg target.
# Used for `open($h{k}, ...)`, `open($a[i], ...)`, `open($h->{k}, ...)`,
# `open($a->[i], ...)` and similar Perl-style out-parameter forms where
# the first arg is a hash/array slot rather than a scalar variable.
# Plain `Perla::CodeGen::gen_expr($fh_arg) = __fh` emits invalid C (`strada_hv_fetch_owned(...) = __fh`).
# __fh is an owned ref (refcount 1); strada_hash_set_take / strada_array_set take ownership.
func _emit_open_slot_store(scalar $cg, scalar $fh_arg) void {
    my int $tt = $fh_arg->{"type"};
    if ($tt == Perla::AST::N_HASH_ELEM()) {
        Perla::CodeGen::emit($cg, "{ char *__osk = strada_to_str(");
        Perla::CodeGen::gen_expr($cg, $fh_arg->{"key"});
        Perla::CodeGen::emit($cg, "); StradaValue *__osh = ");
        Perla::CodeGen::gen_expr($cg, $fh_arg->{"hash"});
        Perla::CodeGen::emit($cg, "; if (__osh && !STRADA_IS_TAGGED_INT(__osh) && __osh->type == STRADA_HASH) strada_hash_set_take(__osh->value.hv, __osk, __fh); else strada_decref(__fh); free(__osk); }");
        return;
    }
    if ($tt == Perla::AST::N_ARROW_HASH()) {
        Perla::CodeGen::emit($cg, "{ char *__osk = strada_to_str(");
        Perla::CodeGen::gen_expr($cg, $fh_arg->{"key"});
        Perla::CodeGen::emit($cg, "); StradaValue *__osr = ");
        Perla::CodeGen::gen_expr($cg, $fh_arg->{"object"});
        Perla::CodeGen::emit($cg, "; StradaValue *__osh = (__osr && !STRADA_IS_TAGGED_INT(__osr) && __osr->type == STRADA_REF) ? __osr->value.rv : __osr; if (__osh && !STRADA_IS_TAGGED_INT(__osh) && __osh->type == STRADA_HASH) strada_hash_set_take(__osh->value.hv, __osk, __fh); else strada_decref(__fh); free(__osk); }");
        return;
    }
    if ($tt == Perla::AST::N_ARRAY_ELEM()) {
        Perla::CodeGen::emit($cg, "{ StradaArray *__osa = strada_deref_array(");
        Perla::CodeGen::gen_expr($cg, $fh_arg->{"array"});
        Perla::CodeGen::emit($cg, "); int __osi = (int)strada_to_int(");
        Perla::CodeGen::gen_expr($cg, $fh_arg->{"index"});
        Perla::CodeGen::emit($cg, "); if (__osa) { if (__osi < 0) __osi += strada_array_length(__osa); strada_array_set(__osa, __osi, __fh); strada_decref(__fh); } else strada_decref(__fh); }");
        return;
    }
    if ($tt == Perla::AST::N_ARROW_ARRAY()) {
        Perla::CodeGen::emit($cg, "{ StradaArray *__osa = strada_deref_array(");
        Perla::CodeGen::gen_expr($cg, $fh_arg->{"object"});
        Perla::CodeGen::emit($cg, "); int __osi = (int)strada_to_int(");
        Perla::CodeGen::gen_expr($cg, $fh_arg->{"index"});
        Perla::CodeGen::emit($cg, "); if (__osa) { strada_array_set(__osa, __osi, __fh); strada_decref(__fh); } else strada_decref(__fh); }");
        return;
    }
    # Fallback: scalar-var / unsupported lvalue — try plain assignment.
    Perla::CodeGen::gen_expr($cg, $fh_arg);
    Perla::CodeGen::emit($cg, " = __fh; ");
}

# Resolve a function name to its qualified name, or "" if not found
func _resolve_sub(scalar $cg, str $name) str {
    my scalar $subs = $cg->{"subs"};
    # Check if already qualified (contains ::)
    if (index($name, "::") >= 0) {
        if (defined($subs->{$name})) {
            return $name;
        }
        return "";
    }
    # Try current package
    my str $qname = $cg->{"pkg"} . "::" . $name;
    if (defined($subs->{$qname})) {
        return $qname;
    }
    # Try main::
    my str $main_q = "main::" . $name;
    if (defined($subs->{$main_q})) {
        return $main_q;
    }
    return "";
}

# --- Method call ---
# --- Push args to __av, with hash/array flattening ---
# Generate inline comma-separated args (for direct C function calls)
func _gen_call_args_inline(scalar $cg, scalar $args, int $argc) void {
    my int $ai = 0;
    while ($ai < $argc) {
        if ($ai > 0) { Perla::CodeGen::emit($cg, ", "); }
        Perla::CodeGen::gen_expr($cg, $args->[$ai]);
        $ai++;
    }
}

# Push a single scalar call-argument onto the __av args array with the
# correct ownership transfer. strada_array_push INCREFS its value, so an
# OWNED temp (string/number literal, a \ref, a call/hash-access result, a
# capture var) pushed that way is left at refcount 1 after the args array is
# decref'd at the end of the call — one leaked ref per argument, and for a
# \%hash / \@array ref that orphaned ref pins the whole container alive. Use
# strada_array_push_take for owned temps (the args array assumes their single
# ref) and the increfing strada_array_push only for BORROWED operands (plain
# $var, $arr[i], derefs) which keep their own ref.
func _gen_push_arg_scalar(scalar $cg, scalar $arg) void {
    if (Perla::CodeGen::expr_is_borrowed($arg) == 1) {
        Perla::CodeGen::emit($cg, "strada_array_push(__av, ");
        Perla::CodeGen::gen_expr($cg, $arg);
        Perla::CodeGen::emit($cg, "); ");
    } else {
        Perla::CodeGen::emit($cg, "strada_array_push_take(__av, ");
        Perla::CodeGen::gen_expr($cg, $arg);
        Perla::CodeGen::emit($cg, "); ");
    }
}

func _gen_push_args(scalar $cg, scalar $args, int $argc) void {
    my int $ai = 0;
    while ($ai < $argc) {
        my scalar $arg = $args->[$ai];
        if ($arg->{"type"} == Perla::AST::N_HASH_VAR() || $arg->{"type"} == Perla::AST::N_DEREF_HASH()) {
            # Flatten hash (or %{$ref} dereference) into key-value pairs.
            # `%$ref` was previously falling through to the default branch
            # and getting pushed as one STRADA_HASH element, so DBIC's
            # `columns => { count => { count => '*' } }` followed by
            # SQLMaker's `%{ $columns->{count} }` iteration came out empty
            # and `_count_rs` produced `SELECT me., COUNT( * ) FROM ...`
            # — a malformed query that fetched no rows, hence the bizowie
            # BZ:6 plateau.
            #
            # Force list context around the hash expression so it
            # actually yields the hash (in list ctx) instead of the
            # bucket-count tag-int (in scalar ctx). Without this,
            # `my $err = validate(%$href)` saw __perla_want_list=0
            # (carried in from the outer scalar `my $err = …`), so
            # `%$href` collapsed to STRADA_MAKE_TAGGED_INT(num_entries)
            # — strada_deref_hash on a tagged int is NULL, the for-
            # loop pushed nothing, and validate got 0 args.
            Perla::CodeGen::emit($cg, "{ int __sav_wl_pa = __perla_want_list; __perla_want_list = 1; StradaValue *__hv = ");
            Perla::CodeGen::gen_expr($cg, $arg);
            Perla::CodeGen::emit($cg, "; __perla_want_list = __sav_wl_pa; StradaHash *__hh = strada_deref_hash(__hv); ");
            Perla::CodeGen::emit($cg, "if (__hh) { StradaArray *__hka = strada_hash_keys(__hh); ");
            Perla::CodeGen::emit($cg, "for (int __hi = 0; __hi < (int)__hka->size; __hi++) { ");
            Perla::CodeGen::emit($cg, "StradaValue *__key = __hka->elements[__hi]; ");
            Perla::CodeGen::emit($cg, "strada_array_push(__av, __key); ");
            Perla::CodeGen::emit($cg, "char *__ks = strada_to_str(__key); strada_array_push_take(__av, strada_hv_fetch_owned(__hv, __ks)); free(__ks); ");
            Perla::CodeGen::emit($cg, "} strada_free_array(__hka); } } ");
        } elsif ($arg->{"type"} == Perla::AST::N_ARRAY_VAR() || $arg->{"type"} == Perla::AST::N_DEREF_ARRAY()
                 || $arg->{"type"} == Perla::AST::N_ARRAY_SLICE() || $arg->{"type"} == Perla::AST::N_HASH_SLICE()
                 || $arg->{"type"} == Perla::AST::N_RANGE()) {
            # Flatten array elements (both @arr and @{$ref}) and slices/
            # ranges. Without N_RANGE here, `count(1..5)` passes a single
            # arrayref so @_ has size 1 in the callee.
            # Force list context around the slice/range expression —
            # array slices in scalar context collapse to the last
            # element (`@a[0..5]` inside `my $r = mktime(@a[0..5])`
            # returned just the 6th element). When passed as args to a
            # multi-arg builtin, we always want the full list.
            Perla::CodeGen::emit($cg, "{ int __sav_wl_pa = __perla_want_list; __perla_want_list = 1; StradaValue *__fav = ");
            Perla::CodeGen::gen_expr($cg, $arg);
            Perla::CodeGen::emit($cg, "; __perla_want_list = __sav_wl_pa; StradaArray *__fa = strada_deref_array(__fav); ");
            Perla::CodeGen::emit($cg, "if (__fa) for (int __fi = 0; __fi < (int)strada_array_length(__fa); __fi++) ");
            Perla::CodeGen::emit($cg, "strada_array_push(__av, strada_array_get(__fa, __fi)); } ");
        } elsif ($arg->{"type"} == Perla::AST::N_QWORD()) {
            # qw(a b c) in a call's arg list — flatten into individual
            # string args, not pushed as one array. Without this,
            # `$obj->load_components(qw/Row PK/)` passes a single
            # array ref as the sole arg; `load_components` in
            # perla_stash.c then stringifies it as "ARRAY(0x...)" and
            # the downstream require fails on a bogus path. Mirrors
            # the existing N_ANON_ARRAY flatten just below.
            my scalar $elems = $arg->{"elems"};
            my int $ei = 0;
            while ($ei < scalar(@{$elems})) {
                _gen_push_arg_scalar($cg, $elems->[$ei]);
                $ei++;
            }
        } elsif ($arg->{"type"} == Perla::AST::N_ANON_ARRAY() && defined($arg->{"elems"}) && $arg->{"is_ref"} != 1) {
            # Flatten parenthesized list (a, b, c) into individual args
            # But NOT [...] array ref constructors (is_ref=1)
            my scalar $elems = $arg->{"elems"};
            my int $ei = 0;
            while ($ei < scalar(@{$elems})) {
                my scalar $elem = $elems->[$ei];
                if (defined($elem) && $elem->{"type"} == Perla::AST::N_CALL() && !defined($elem->{"coderef"})) {
                    # Function call - may return array to flatten.
                    # Matches the pattern at line ~5256; needs the same
                    # strada_decref(__fcr) to avoid leaking one ref per
                    # call in flatten-call-inside-list contexts.
                    Perla::CodeGen::emit($cg, "{ StradaValue *__fcr = ");
                    Perla::CodeGen::gen_expr($cg, $elem);
                    Perla::CodeGen::emit($cg, "; if (__fcr && !STRADA_IS_TAGGED_INT(__fcr) && __fcr->type == STRADA_ARRAY) { ");
                    Perla::CodeGen::emit($cg, "StradaArray *__fca = strada_deref_array(__fcr); ");
                    Perla::CodeGen::emit($cg, "if (__fca) for (int __fci=0; __fci<(int)strada_array_length(__fca); __fci++) ");
                    Perla::CodeGen::emit($cg, "strada_array_push(__av, strada_array_get(__fca, __fci)); ");
                    Perla::CodeGen::emit($cg, "} else { strada_array_push(__av, __fcr); } strada_decref(__fcr); } ");
                } else {
                    _gen_push_arg_scalar($cg, $elem);
                }
                $ei++;
            }
        } elsif ($arg->{"type"} == Perla::AST::N_CALL() && defined($arg->{"name"}) && ($arg->{"name"} eq "_definition_context" || $arg->{"name"} eq "Class::MOP::_definition_context")) {
            # Special: _definition_context returns (key => value) that must be flattened
            Perla::CodeGen::emit($cg, "strada_array_push_take(__av, strada_new_str(\"definition_context\")); ");
            Perla::CodeGen::emit($cg, "{ StradaValue *__dch = strada_new_hash(); ");
            Perla::CodeGen::emit($cg, "strada_hv_store(__dch, \"package\", strada_new_str(\"" . $cg->{"pkg"} . "\")); ");
            Perla::CodeGen::emit($cg, "strada_hv_store(__dch, \"file\", strada_new_str(\"" . $cg->{"filename"} . "\")); ");
            Perla::CodeGen::emit($cg, "strada_hv_store(__dch, \"line\", STRADA_MAKE_TAGGED_INT(0)); ");
            Perla::CodeGen::emit($cg, "strada_array_push_take(__av, strada_new_ref(__dch, '%')); } ");
        } elsif (($arg->{"type"} == Perla::AST::N_CALL() && !defined($arg->{"coderef"}))
                 || $arg->{"type"} == Perla::AST::N_METHOD()
                 || $arg->{"type"} == Perla::AST::N_BINOP()
                 || $arg->{"type"} == Perla::AST::N_TERNARY()) {
            # Function/method/binop call result: may return array (list
            # context), flatten at runtime. Set `__perla_want_list = 1`
            # around the call so a callee that does `return (a,b,c)`
            # returns the full list, not the scalar-context last element.
            # N_METHOD missing here used to make `$obj->fn($obj->returns_list)`
            # pass only the LAST element of returns_list — broke DBIC's
            # `$self->_execute($self->_select_args(@_))` so _execute saw
            # ($self, ARRAY_REF, ...) instead of ($self, 'select', $ident, ...).
            # N_BINOP/N_TERNARY: `||`, `//`, `?:` can yield the empty list
            # `()` (which is a 0-length array StradaValue); without this
            # branch it was pushed as one empty-array element instead of
            # zero elements.
            # __fca is a temporary holding the call's return value (refcount 1);
            # strada_array_push bumps either __fca or its elements by +1,
            # giving __av its ref. Without the trailing decref, __fca's
            # original ref is never released - leak per call.
            Perla::CodeGen::emit($cg, "{ int __sav_wl = __perla_want_list; __perla_want_list = 1; StradaValue *__fca = ");
            Perla::CodeGen::gen_expr($cg, $arg);
            Perla::CodeGen::emit($cg, "; __perla_want_list = __sav_wl; if (__fca && !STRADA_IS_TAGGED_INT(__fca) && __fca->type == STRADA_ARRAY) { ");
            Perla::CodeGen::emit($cg, "StradaArray *__fcav = strada_deref_array(__fca); ");
            Perla::CodeGen::emit($cg, "if (__fcav) for (int __fci = 0; __fci < (int)strada_array_length(__fcav); __fci++) ");
            Perla::CodeGen::emit($cg, "strada_array_push(__av, strada_array_get(__fcav, __fci)); ");
            Perla::CodeGen::emit($cg, "} else { strada_array_push(__av, __fca); } strada_decref(__fca); } ");
        } elsif ($arg->{"type"} == Perla::AST::N_MAP()
                 || $arg->{"type"} == Perla::AST::N_GREP()
                 || $arg->{"type"} == Perla::AST::N_SORT()) {
            # map/grep/sort always return a list — flatten the resulting
            # array into the call args. Without this, code like
            #   _load_components( map { ... } grep { ... } @_ )
            # passes a single arrayref to _load_components, which then
            # tries to require ARRAY(0x...) — fatal in DBIx::Class load.
            # Push __perla_want_list = 1 around the evaluation so the
            # map/grep/sort returns the list (not the scalar count when
            # the surrounding context is scalar, e.g. `my $s = sum(map ...)`).
            Perla::CodeGen::emit($cg, "{ int __sav_wl_mc = __perla_want_list; __perla_want_list = 1; StradaValue *__mca = ");
            Perla::CodeGen::gen_expr($cg, $arg);
            Perla::CodeGen::emit($cg, "; __perla_want_list = __sav_wl_mc; ");
            Perla::CodeGen::emit($cg, "if (__mca && !STRADA_IS_TAGGED_INT(__mca) && __mca->type == STRADA_ARRAY) { ");
            Perla::CodeGen::emit($cg, "StradaArray *__mcav = strada_deref_array(__mca); ");
            Perla::CodeGen::emit($cg, "if (__mcav) for (int __mci = 0; __mci < (int)strada_array_length(__mcav); __mci++) ");
            Perla::CodeGen::emit($cg, "strada_array_push(__av, strada_array_get(__mcav, __mci)); ");
            Perla::CodeGen::emit($cg, "} else { strada_array_push(__av, __mca); } strada_decref(__mca); } ");
        } else {
            _gen_push_arg_scalar($cg, $arg);
        }
        $ai++;
    }
}
