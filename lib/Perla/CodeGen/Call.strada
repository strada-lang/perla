                # Force list context for the same reason as N_DEREF_ARRAY.
                Perla::CodeGen::emit($cg, "({ int __sav_wl_sh = __perla_want_list; __perla_want_list = 1; ");
                Perla::CodeGen::emit($cg, "StradaValue *__sh = ");
                Perla::CodeGen::gen_expr($cg, $arg);
                Perla::CodeGen::emit($cg, "; __perla_want_list = __sav_wl_sh; ");
                Perla::CodeGen::emit($cg, "StradaValue *__sh_t = (__sh && !STRADA_IS_TAGGED_INT(__sh) && __sh->meta && __sh->meta->is_tied) ? strada_tied_hash_scalar(__sh) : NULL; ");
                Perla::CodeGen::emit($cg, "StradaValue *__sh_r; if (__sh_t) { __sh_r = __sh_t; } else { StradaHash *__shv = strada_deref_hash(__sh); __sh_r = STRADA_MAKE_TAGGED_INT((int64_t)(__shv ? __shv->num_entries : 0)); } __sh_r; })");
            } else {
                # Dynamic: evaluate in scalar context, branch on type.
                Perla::CodeGen::emit($cg, "({ int __sav_wl = __perla_want_list; __perla_want_list = 0; StradaValue *__sv = ");
                Perla::CodeGen::gen_expr($cg, $arg);
                Perla::CodeGen::emit($cg, "; __perla_want_list = __sav_wl; ");
                Perla::CodeGen::emit($cg, "StradaValue *__sr; ");
                Perla::CodeGen::emit($cg, "if (__sv && !STRADA_IS_TAGGED_INT(__sv) && __sv->type == STRADA_ARRAY) { ");
                Perla::CodeGen::emit($cg, "  __sr = STRADA_MAKE_TAGGED_INT((int64_t)strada_array_length(strada_deref_array(__sv))); ");
                Perla::CodeGen::emit($cg, "  strada_decref(__sv); ");
                Perla::CodeGen::emit($cg, "} else if (__sv && !STRADA_IS_TAGGED_INT(__sv) && __sv->type == STRADA_HASH) { ");
                Perla::CodeGen::emit($cg, "  StradaHash *__shv = strada_deref_hash(__sv); ");
                Perla::CodeGen::emit($cg, "  __sr = STRADA_MAKE_TAGGED_INT((int64_t)(__shv ? __shv->num_entries : 0)); ");
                Perla::CodeGen::emit($cg, "  strada_decref(__sv); ");
