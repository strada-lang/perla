    # sysopen($fh, $path, $flags [, $perms]) — POSIX open(2) flags, not
    # the mode-string form of `open()`. File::Temp + many CPAN modules
    # depend on this for O_CREAT|O_EXCL retry-on-race idioms. Routes
    # through perla_sysopen() which does open(2)+fdopen and returns a
    # FILEHANDLE on success, undef on failure.
    if ($name eq "sysopen" && $argc >= 3) {
        my scalar $fh_arg = $args->[0];
        my str $fh_var = "";
        my str $fh_bareword = "";
        if (defined($fh_arg) && $fh_arg->{"type"} == Perla::AST::N_SCALAR_VAR()) {
            $fh_var = Perla::CodeGen::c_var($fh_arg->{"name"});
        } elsif (defined($fh_arg) && $fh_arg->{"type"} == Perla::AST::N_MY()) {
            if (defined($fh_arg->{"var"})) {
                $fh_var = Perla::CodeGen::c_var($fh_arg->{"var"}->{"value"});
                Perla::CodeGen::_my_prefix($cg, $fh_arg->{"var"}->{"value"});
            }
        } elsif (defined($fh_arg) && $fh_arg->{"type"} == Perla::AST::N_CALL()) {
            my scalar $fhargs = $fh_arg->{"args"};
            my int $acount = 0;
            if (defined($fhargs)) { $acount = scalar(@{$fhargs}); }
            if ($acount == 0 && defined($fh_arg->{"name"})) {
                $fh_bareword = $fh_arg->{"name"};
            }
        }
        Perla::CodeGen::emit($cg, "({ StradaValue *__sop_path = ");
        Perla::CodeGen::gen_expr($cg, $args->[1]);
        Perla::CodeGen::emit($cg, "; int64_t __sop_flags = (int64_t)strada_to_int(");
        Perla::CodeGen::gen_expr($cg, $args->[2]);
        Perla::CodeGen::emit($cg, "); int64_t __sop_perms = ");
        if ($argc >= 4) {
            Perla::CodeGen::emit($cg, "(int64_t)strada_to_int(");
            Perla::CodeGen::gen_expr($cg, $args->[3]);
