        Perla::CodeGen::emit($cg, "    const char *__df = (perla_call_depth > 0) ? (perla_call_stack[perla_call_depth - 1].file ?: \"-\") : \"-\"; ");
        Perla::CodeGen::emit($cg, "    char __dbuf[1024]; snprintf(__dbuf, sizeof(__dbuf), \"%s at %s line " . $die_line . ".\\n\", __dv->value.pv, __df); ");
        Perla::CodeGen::emit($cg, "    strada_decref(__dv); __dv = strada_new_str(__dbuf); ");
