        } else {
            $class_is_lit = 1;
            $class_lit = $cg->{"pkg"};
        }
        if ($class_is_lit == 1) {
            Perla::CodeGen::emit($cg, "({ char *__bp = strdup(\"" . $class_lit . "\"); StradaValue *__br = perla_bless(");
            Perla::CodeGen::gen_expr($cg, $args->[0]);
