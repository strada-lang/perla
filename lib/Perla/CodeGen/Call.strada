        Perla::CodeGen::emit($cg, "  StradaValue *__da = strada_new_array(); strada_incref(__dv); strada_array_push(strada_deref_array(__da), __dv); ");
        Perla::CodeGen::emit($cg, "  /* prevent recursion: clear handler during call */ StradaValue *__dhs = strada_hash_get(v_SIG->value.hv, \"__DIE__\"); if (__dhs) strada_incref(__dhs); strada_hash_delete(v_SIG->value.hv, \"__DIE__\"); ");
        Perla::CodeGen::emit($cg, "  StradaValue *__dr = perla_call_code(__dh, __da); if (__dr) strada_decref(__dr); strada_decref(__da); ");
        Perla::CodeGen::emit($cg, "  if (__dhs) { strada_hash_set_take(v_SIG->value.hv, \"__DIE__\", __dhs); } ");
