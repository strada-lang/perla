            Perla::CodeGen::emit($cg, "if (__wh && !STRADA_IS_TAGGED_INT(__wh) && __wh->type == STRADA_CLOSURE) { ");
            Perla::CodeGen::emit($cg, "  StradaValue *__wa = strada_new_array(); strada_array_push(strada_deref_array(__wa), strada_new_str(\"Warning: something's wrong\\n\")); ");
