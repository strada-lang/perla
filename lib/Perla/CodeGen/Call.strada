            Perla::CodeGen::emit($cg, "strada_sort(__sa); })");
        }
        return;
    }

    # reverse — no-args form defaults to $_ (Perl semantics for the
    # scalar variant: `scalar reverse` reverses $_).
    if ($name eq "reverse") {
        # `reverse LIST` is context-sensitive: in list context returns the
        # reversed list; in scalar context joins-and-reverses-the-string.
        # perla_reverse_ctx checks __perla_want_list and dispatches.
        # Perl's `reverse` with no args defaults to $_ in scalar context
        # ONLY — in list context bare `reverse` is the empty list.
        # Arg eval imposes LIST context: reverse always wants a list as
        # input; the outer scalar/list context only affects what the
        # function RETURNS. Without this, `scalar(reverse sub_returning_list())`
        # ran the sub in scalar context (returning just the last value)
        # so reverse only saw (3) instead of (1,2,3).
