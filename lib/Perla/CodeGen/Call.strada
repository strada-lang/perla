# Perla::CodeGen::Call - Function/sub call code generation.
#
# Extracted from CodeGen.strada. Owns _gen_call (the N_CALL handler and all
# the builtin/user-sub dispatch within it) plus the argument-marshalling
# helpers (_gen_push_args, _gen_push_arg_scalar, _gen_call_args_inline),
# subroutine name resolution (_resolve_sub), and the open()-slot store helper
# (_emit_open_slot_store).
#
# Cross-module calls back into the main Perla::CodeGen (emit, gen_expr,
# c_var*, op_capture*, etc.) use body-less `extern func` decls below; we
# can't `use Perla::CodeGen` because CodeGen.strada `use`s us (cycle).

use Perla::AST;
use Perla::Lexer;
use Perla::Parser;
use Perla::CodeGen::Escape;
use Perla::CodeGen::Eval;
use Perla::CodeGen::Predicate;
use Perla::CodeGen::Subst;
use Perla::CodeGen::Interp;

package Perla::CodeGen::Call;

# Forward decls for Perla::CodeGen helpers we call inline.
extern func Perla::CodeGen::emit(scalar $cg, str $s) void;
extern func Perla::CodeGen::gen_expr(scalar $cg, scalar $node) void;
extern func Perla::CodeGen::c_var(str $name) str;
extern func Perla::CodeGen::c_var_a(str $name) str;
extern func Perla::CodeGen::c_var_h(str $name) str;
extern func Perla::CodeGen::c_var_for_vtype(str $vtype, str $name) str;
extern func Perla::CodeGen::safe_ident(str $name) str;
extern func Perla::CodeGen::sub_cname_q(str $qname) str;
extern func Perla::CodeGen::has_perl_var(str $s) int;
extern func Perla::CodeGen::expr_is_borrowed(scalar $node) int;
extern func Perla::CodeGen::_my_prefix(scalar $cg, str $vname) str;
extern func Perla::CodeGen::_split_pkg_qual_name(scalar $node) array;
extern func Perla::CodeGen::_gen_autoviv_hash(scalar $cg, scalar $node) void;
extern func Perla::CodeGen::_gen_autoviv_outer_hash(scalar $cg, scalar $node, int $hash_context) void;
extern func Perla::CodeGen::op_capture(scalar $cg, scalar $rec, str $cvar, scalar $node, int $scalar_ctx) void;
extern func Perla::CodeGen::op_capture_c(scalar $cg, scalar $rec, str $cvar, str $cexpr) void;
extern func Perla::CodeGen::op_release(scalar $cg, scalar $rec) void;
extern func Perla::CodeGen::_perla_has_mangle_collision(str $name) int;

func _gen_call(scalar $cg, scalar $node) void {
    my str $name = $node->{"name"};
    my scalar $args = $node->{"args"};
    my int $argc = scalar(@{$args});

    # `goto(EXPR)` in EXPRESSION context (e.g. a ternary branch like
    # `COND ? goto($cref) : ...`). The statement parser turns a top-level goto
    # into N_GOTO_SUB; in expression position it parses as a call to "goto".
    # Perl's `goto &CODE` tail-calls CODE with the current @_ — mid-expression
    # we can't do a true frame swap, so model the observable result: call the
    # coderef with @_ and yield its return value. Real-world: Type::Tiny /
    # Types::TypeTiny inline-check subs do
    # `( $AvoidCallbacks or not $xsubname ) ? goto($inlined) : qq/.../` — without
    # this the goto branch yielded undef and Type::Tiny croaked "Inlining type
    # constraint check ... returned undef".
    if ($name eq "goto" && $argc == 1) {
        Perla::CodeGen::emit($cg, "perla_call_code(");
        Perla::CodeGen::gen_expr($cg, $args->[0]);
        Perla::CodeGen::emit($cg, ", perla_at_)");
        return;
    }

    # `CORE::name` — Perl's explicit-builtin form. Used by packages that
    # override built-in names (`sub push {...}` then `CORE::push @a, ...`).
    # Strip the prefix and reuse the unqualified handler so it routes
    # through perla's built-in inline codegen (push / pop / scalar /
    # length / uc / ...). Without this, `CORE::push` looked up the
    # "CORE" package in the stash, missed, and silently returned undef.
    if (length($name) > 6 && substr($name, 0, 6) eq "CORE::") {
        $name = substr($name, 6, length($name) - 6);
        $node->{"name"} = $name;
    }

    # Prototype-driven auto-reference. `sub takes_array (\@)` declares that
    # the caller's array arg should be promoted to a ref at the call site
    # — Perl's `\@`, `\%`, `\$`, `\&` proto chars. Without this, calls
    # like `takes_array(@arr)` flattened @arr to its elements and the
    # callee's `shift` got the first element rather than a ref.
    if (defined($cg->{"sub_protos"}) && $argc > 0) {
        my str $__proto_qn = "";
        if (index($name, "::") >= 0) {
            if (defined($cg->{"sub_protos"}->{$name})) { $__proto_qn = $name; }
        } else {
            my str $__cand = $cg->{"pkg"} . "::" . $name;
            if (defined($cg->{"sub_protos"}->{$__cand})) {
                $__proto_qn = $__cand;
            } elsif (defined($cg->{"sub_protos"}->{"main::" . $name})) {
                $__proto_qn = "main::" . $name;
            }
        }
        if (length($__proto_qn) > 0) {
            my str $__proto = "" . $cg->{"sub_protos"}->{$__proto_qn};
            if (length($__proto) > 0) {
                # Walk the proto char-by-char, building per-arg specs.
                # `\X` (X in @%$&*) means: take ref of arg N. Other chars
                # consume one arg slot without modifying it. `;` is the
                # required/optional separator (skip). `@` and `%` are
                # slurpy (consume remaining args, no per-arg rewrite).
                my int $__pi = 0;
                my int $__plen = length($__proto);
                my int $__slot = 0;
                while ($__pi < $__plen && $__slot < $argc) {
                    my str $__pc = substr($__proto, $__pi, 1);
                    if ($__pc eq ";") { $__pi = $__pi + 1; }
                    elsif ($__pc eq "\\") {
                        if ($__pi + 1 < $__plen) {
                            my str $__pnx = substr($__proto, $__pi + 1, 1);
                            if ($__pnx eq "@" || $__pnx eq "%" ||
                                $__pnx eq "\$" || $__pnx eq "&") {
                                my scalar $__orig = $args->[$__slot];
                                my scalar $__refn = Perla::AST::node(Perla::AST::N_REF());
                                $__refn->{"operand"} = $__orig;
                                $args->[$__slot] = $__refn;
                            }
                            $__pi = $__pi + 2;
                        } else { $__pi = $__pi + 1; }
                        $__slot = $__slot + 1;
                    }
                    elsif ($__pc eq "@" || $__pc eq "%") { last; }
                    elsif ($__pc eq "\$") {
                        # `$` proto slot: scalar context. If the arg is
                        # an N_ARRAY_VAR / N_HASH_VAR / N_ARRAY_SLICE
                        # the call site otherwise passes flattened
                        # elements; wrap in scalar(...) so the callee
                        # gets the count / single value.
                        my scalar $__sarg = $args->[$__slot];
                        my int $__sat = $__sarg->{"type"};
                        if ($__sat == Perla::AST::N_ARRAY_VAR() ||
                            $__sat == Perla::AST::N_HASH_VAR() ||
                            $__sat == Perla::AST::N_ARRAY_SLICE() ||
                            $__sat == Perla::AST::N_HASH_SLICE()) {
                            my scalar $__scn = Perla::AST::node(Perla::AST::N_CALL());
                            $__scn->{"name"} = "scalar";
                            my array @__sca = ($__sarg);
                            $__scn->{"args"} = \@__sca;
                            $args->[$__slot] = $__scn;
                        }
                        $__pi = $__pi + 1;
                        $__slot = $__slot + 1;
                    }
                    else {
                        $__pi = $__pi + 1;
                        $__slot = $__slot + 1;
                    }
                }
            }
        }
    }

    # tie %HASH, 'Class', HASHREF — Perl's tie semantics (FETCH/STORE
    # dispatch) aren't implemented; for the ubiquitous Config.pm-style
    # pattern `tie %H, 'Class', { ... }` we just copy the data hash into
    # %H so subsequent $H{key} lookups work without needing a real tie.
    # This matches real Perl's observable behavior for this specific
    # pattern: Config::FETCH returns $self->{key}, i.e. the passed-in
    # hash's values.
    if ($name eq "tie" && $argc >= 2) {
        my scalar $target = $args->[0];
        # Track whether the target came from an inline `my` declaration so
        # the scalar branch below can force-fresh-storage. Without this,
        # repeated `tie my $x, …` inside a for-loop body all share the same
        # C local v_x, so iter-N's tied state overwrites iter-(N-1)'s and
        # any references taken earlier in the loop end up aliased.
        my int $__tie_is_my = 0;
        # Inline `tie my $x, 'Class'` — peel the my-decl back to its var
        # so the scalar/array/hash branches below match. Mirrors how
        # pipe(my $rfh) etc. handle the inline-my form. The N_MY's var
        # is what we actually want to tie; the declaration itself was
        # registered in declared_vars by the call-args parser.
        if (defined($target) && $target->{"type"} == Perla::AST::N_MY()
            && defined($target->{"var"})) {
            $__tie_is_my = 1;
            my scalar $__tie_inner_var = $target->{"var"};
            my str $__tie_inner_t = "" . $__tie_inner_var->{"type"};
            if (length($__tie_inner_t) == 0) { $__tie_inner_t = "SCALAR_VAR"; }
            # Build a synthetic SCALAR_VAR / ARRAY_VAR / HASH_VAR node
            # to feed the branches below.
            my scalar $__tie_synth = Perla::AST::node(Perla::AST::N_SCALAR_VAR());
            if ($__tie_inner_t eq "ARRAY_VAR") {
                $__tie_synth = Perla::AST::node(Perla::AST::N_ARRAY_VAR());
            } elsif ($__tie_inner_t eq "HASH_VAR") {
                $__tie_synth = Perla::AST::node(Perla::AST::N_HASH_VAR());
            }
            $__tie_synth->{"name"} = $__tie_inner_var->{"value"};
            # Register in declared_vars so strict 'vars' sees the
            # declaration on subsequent reads.
            my str $__tie_cn = Perla::CodeGen::c_var_for_vtype($__tie_inner_t, $__tie_inner_var->{"value"});
            if (defined($cg->{"declared_vars"})) {
                $cg->{"declared_vars"}->{$__tie_cn} = 1;
            }
            $target = $__tie_synth;
        }
        # Scalar tie: `tie $x, 'Class', @args` → strada_tie_scalar(v_x, "Class", argc, args...)
        # Reads through the tied scalar dispatch FETCH via the to_int/str/num/bool
        # checks in strada_runtime.c; writes still go to v_x storage (STORE
        # dispatch is a separate codegen change).
        if (defined($target) && $target->{"type"} == Perla::AST::N_SCALAR_VAR()) {
            my scalar $class_arg = $args->[1];
            # Ensure v_x is materialized as a StradaValue before tying. For
            # the inline-my form (`tie my $x, …`), force fresh storage —
            # each lexical introduction should get its own SV. Without
            # forcing fresh, `for my $i (…) { tie my $x, …; push @refs,
            # \$x; }` would tie iter-N's "tied state" onto the same v_x
            # as iter-(N-1), so refs captured in earlier iters resolve to
            # the LAST iter's tied state. For the non-my form (`tie $x,
            # …`), $x already exists with its declaration's storage —
            # keep the existing slot and only init when NULL.
            my str $svname = "v_" . Perla::CodeGen::safe_ident($target->{"name"});
            if ($__tie_is_my == 1) {
                Perla::CodeGen::emit($cg, "({ if (" . $svname . ") strada_decref(" . $svname . "); " . $svname . " = strada_new_undef(); ");
            } else {
                Perla::CodeGen::emit($cg, "({ if (!" . $svname . ") " . $svname . " = strada_new_undef(); ");
            }
            Perla::CodeGen::emit($cg, "char *__tie_cls = strada_to_str(");
            Perla::CodeGen::gen_expr($cg, $class_arg);
            Perla::CodeGen::emit($cg, "); ");
            # Build extra-args list (everything after class name).
            my int $extra = $argc - 2;
            Perla::CodeGen::emit($cg, "StradaValue *__tie_obj = perla_tie_scalar(" . $svname . ", __tie_cls, " . $extra);
            my int $ai = 2;
            while ($ai < $argc) {
                Perla::CodeGen::emit($cg, ", ");
                Perla::CodeGen::gen_expr($cg, $args->[$ai]);
                $ai = $ai + 1;
            }
            Perla::CodeGen::emit($cg, "); free(__tie_cls); __tie_obj; })");
            return;
        }
        # NOTE: a previous "Config.pm shortcut" path used to copy the
        # passed-in hashref into the target hash and skip TIEHASH/STORE.
        # That broke real-tie semantics — `tie %h, 'Class', \%data` where
        # Class defines TIEHASH/STORE never fired the user's callbacks,
        # so STORE side-effects (validation, logging) and STORE-die
        # propagation through eval were silently dropped. Removed; real
        # tie via strada_tie_hash works for both the data-init and the
        # callback-driven patterns.

        # Generic hash tie: `tie %h, 'Class', @args` calls Class->TIEHASH(@args)
        # and attaches the result to v_h's meta. Subsequent $h{k} ops dispatch
        # FETCH/STORE/EXISTS/DELETE via the strada_hv_* tied checks.
        if (defined($target) && $target->{"type"} == Perla::AST::N_HASH_VAR()) {
            my scalar $class_arg_h = $args->[1];
            my str $hvname = "v_" . Perla::CodeGen::safe_ident($target->{"name"});
            Perla::CodeGen::emit($cg, "({ if (!" . $hvname . ") " . $hvname . " = strada_new_hash(); ");
            Perla::CodeGen::emit($cg, "char *__tie_cls = strada_to_str(");
            Perla::CodeGen::gen_expr($cg, $class_arg_h);
            Perla::CodeGen::emit($cg, "); ");
            my int $extra_h = $argc - 2;
            Perla::CodeGen::emit($cg, "StradaValue *__tie_obj = strada_tie_hash(" . $hvname . ", __tie_cls, " . $extra_h);
            my int $ai_h = 2;
            while ($ai_h < $argc) {
                Perla::CodeGen::emit($cg, ", ");
                Perla::CodeGen::gen_expr($cg, $args->[$ai_h]);
                $ai_h = $ai_h + 1;
            }
            Perla::CodeGen::emit($cg, "); free(__tie_cls); __tie_obj; })");
            return;
        }

        # Glob tie: `tie *FH, 'Class', @args` — calls Class->TIEHANDLE(@args)
        # and stores the resulting blessed object in FH's glob IO slot.
        # Diamond `<FH>`, `print FH …`, `close FH`, and `tied(*FH)` then
        # check the IO slot at runtime and dispatch through the blessed
        # object when set.
        if (defined($target) && $target->{"type"} == Perla::AST::N_GLOB_ACCESS()) {
            my str $gname = "" . $target->{"name"};
            my scalar $class_arg_g = $args->[1];
            Perla::CodeGen::emit($cg, "({ char *__tie_cls = strada_to_str(");
            Perla::CodeGen::gen_expr($cg, $class_arg_g);
            Perla::CodeGen::emit($cg, "); StradaValue *__tie_args = strada_new_array(); StradaArray *__tav = strada_deref_array(__tie_args); ");
            Perla::CodeGen::emit($cg, "{ StradaValue *__cn_e = strada_new_str(__tie_cls); strada_array_push_take(__tav, __cn_e); } ");
            my int $ai_g = 2;
            while ($ai_g < $argc) {
                Perla::CodeGen::emit($cg, "{ StradaValue *__tav_e = ");
                Perla::CodeGen::gen_expr($cg, $args->[$ai_g]);
                Perla::CodeGen::emit($cg, "; if (__tav_e) strada_incref(__tav_e); strada_array_push_take(__tav, __tav_e); } ");
                $ai_g = $ai_g + 1;
            }
            Perla::CodeGen::emit($cg, "StradaValue *__tie_obj = perla_tie_handle(\"" . $cg->{"pkg"} . "\", \"" . $gname . "\", __tie_cls, __tie_args); ");
            Perla::CodeGen::emit($cg, "strada_decref(__tie_args); free(__tie_cls); __tie_obj; })");
            return;
        }

        # Generic array tie: `tie @a, 'Class', @args`.
        if (defined($target) && $target->{"type"} == Perla::AST::N_ARRAY_VAR()) {
            my scalar $class_arg_a = $args->[1];
            my str $avname = "v_" . Perla::CodeGen::safe_ident($target->{"name"});
            Perla::CodeGen::emit($cg, "({ if (!" . $avname . ") " . $avname . " = strada_new_array(); ");
            Perla::CodeGen::emit($cg, "char *__tie_cls = strada_to_str(");
            Perla::CodeGen::gen_expr($cg, $class_arg_a);
            Perla::CodeGen::emit($cg, "); ");
            my int $extra_a = $argc - 2;
            Perla::CodeGen::emit($cg, "StradaValue *__tie_obj = strada_tie_array(" . $avname . ", __tie_cls, " . $extra_a);
            my int $ai_a = 2;
            while ($ai_a < $argc) {
                Perla::CodeGen::emit($cg, ", ");
                Perla::CodeGen::gen_expr($cg, $args->[$ai_a]);
                $ai_a = $ai_a + 1;
            }
            Perla::CodeGen::emit($cg, "); free(__tie_cls); __tie_obj; })");
            return;
        }
    }

    # tied $scalar / tied %hash / tied @array — return the tied object,
    # or undef if untied. The tie state lives on meta->tied_obj; just
    # route to strada_tied(). Without this, `tied` fell through to
    # perla_code_get looking for a sub.
    # IO::Compress::* / IO::Uncompress::* one-shot functions (native, libz/
    # libbz2). `VERB $src => $dst` — $src/$dst each a scalar-ref (\$buf,
    # in-memory) or a filename string. Trailing options (Level => ...) are
    # accepted and ignored. Returns 1 on success, "" (false) on failure.
    # gzip/gunzip (gzip), deflate/inflate (zlib), rawdeflate/rawinflate (raw),
    # bzip2/bunzip2 (bzip2). The bare verb or the fully-qualified name matches;
    # argc>=2 disambiguates from unrelated 0/1-arg subs (e.g. DBIC deflate).
    my str $cz_fn = "";
    if ($name eq "gzip" || $name eq "IO::Compress::Gzip::gzip") { $cz_fn = "perla_io_gzip"; }
    elsif ($name eq "gunzip" || $name eq "IO::Uncompress::Gunzip::gunzip") { $cz_fn = "perla_io_gunzip"; }
    elsif ($name eq "deflate" || $name eq "IO::Compress::Deflate::deflate") { $cz_fn = "perla_io_deflate"; }
    elsif ($name eq "inflate" || $name eq "IO::Uncompress::Inflate::inflate") { $cz_fn = "perla_io_inflate"; }
    elsif ($name eq "rawdeflate" || $name eq "IO::Compress::RawDeflate::rawdeflate") { $cz_fn = "perla_io_rawdeflate"; }
    elsif ($name eq "rawinflate" || $name eq "IO::Uncompress::RawInflate::rawinflate") { $cz_fn = "perla_io_rawinflate"; }
    elsif ($name eq "bzip2" || $name eq "IO::Compress::Bzip2::bzip2") { $cz_fn = "perla_io_bzip2"; }
    elsif ($name eq "bunzip2" || $name eq "IO::Uncompress::Bunzip2::bunzip2") { $cz_fn = "perla_io_bunzip2"; }
    if (length($cz_fn) > 0 && $argc >= 2) {
        Perla::CodeGen::emit($cg, "({ StradaValue *__cz_s = ");
        Perla::CodeGen::gen_expr($cg, $args->[0]);
        Perla::CodeGen::emit($cg, "; StradaValue *__cz_d = ");
        Perla::CodeGen::gen_expr($cg, $args->[1]);
        Perla::CodeGen::emit($cg, "; StradaValue *__cz_r = " . $cz_fn . "(__cz_s, __cz_d); ");
        if (Perla::CodeGen::expr_is_borrowed($args->[0]) == 0) { Perla::CodeGen::emit($cg, "strada_decref(__cz_s); "); }
        if (Perla::CodeGen::expr_is_borrowed($args->[1]) == 0) { Perla::CodeGen::emit($cg, "strada_decref(__cz_d); "); }
        Perla::CodeGen::emit($cg, "__cz_r; })");
        return;
    }

    if ($name eq "tied" && $argc == 1) {
        my scalar $tgt = $args->[0];
        if (defined($tgt)) {
            my int $tt = $tgt->{"type"};
            if ($tt == Perla::AST::N_SCALAR_VAR() ||
                $tt == Perla::AST::N_HASH_VAR() ||
                $tt == Perla::AST::N_ARRAY_VAR()) {
                Perla::CodeGen::emit($cg, "strada_tied(" . "v_" . Perla::CodeGen::safe_ident($tgt->{"name"}) . ")");
                return;
            }
            # tied(*FH) — read the tied handle object from the glob's
            # IO slot. Returns undef when *FH was never tied.
            if ($tt == Perla::AST::N_GLOB_ACCESS()) {
                Perla::CodeGen::emit($cg, "perla_tied_handle_get(\"" . $cg->{"pkg"} . "\", \"" . $tgt->{"name"} . "\")");
                return;
            }
        }
    }

    # untie $scalar / untie %hash / untie @array — clear tied state.
    if ($name eq "untie" && $argc == 1) {
        my scalar $utgt = $args->[0];
        if (defined($utgt)) {
            my int $utt = $utgt->{"type"};
            if ($utt == Perla::AST::N_SCALAR_VAR() ||
                $utt == Perla::AST::N_HASH_VAR() ||
                $utt == Perla::AST::N_ARRAY_VAR()) {
                # The "untie attempted while N inner references still exist"
                # warning is wired up in perla_stash.c (perla_warn_untie_with_refs)
                # but not emitted here yet — strada's refcount on the tied
                # object includes spurious leaks from `$_[0]->{...}` and
                # `my (...) = @_;` access paths (each leak +1 to refcount),
                # so the count we'd report is consistently higher than
                # perl's. Until those access leaks are plugged, suppress
                # the warning entirely to avoid false positives.
                Perla::CodeGen::emit($cg, "({ strada_untie(" . "v_" . Perla::CodeGen::safe_ident($utgt->{"name"}) . "); STRADA_MAKE_TAGGED_INT(1); })");
                return;
            }
        }
    }

    # select(FH) — set default output filehandle. Without this handler
    # \`select(\$fh); print "text";\` fell through to perla_code_get
    # looking for a user sub named "select" (none exists) and the
    # redirect was silently ignored. select() with no args returns the
    # current default.
    if ($name eq "select") {
        if ($argc == 0) {
            Perla::CodeGen::emit($cg, "strada_select_get()");
        } else {
            # Bareword-FH form (`select(STDOUT)`, `select(MYFH)`) gets
            # the handle name forwarded to perla_set_selected_handle
            # so per-handle $~ / $^ assignments under the new select
            # land on the right slot. The scalar form (`select($fh)`)
            # falls back to strada_select only — we can't recover the
            # name from the SV deterministically.
            my scalar $sa = $args->[0];
            my int $is_bareword = 0;
            my str $bw_name = "";
            if (defined($sa) && $sa->{"type"} == Perla::AST::N_CALL()
                && defined($sa->{"name"})) {
                my scalar $sargs = $sa->{"args"};
                my int $sac = 0;
                if (defined($sargs)) { $sac = scalar(@{$sargs}); }
                if ($sac == 0) {
                    my str $cand = "" . $sa->{"name"};
                    my int $sn = length($cand);
                    my int $sni = 0;
                    my int $allcaps = 1;
                    while ($sni < $sn) {
                        my str $sc = substr($cand, $sni, 1);
                        if (!(($sc ge "A" && $sc le "Z") || ($sc ge "0" && $sc le "9") || $sc eq "_")) {
                            $allcaps = 0; last;
                        }
                        $sni = $sni + 1;
                    }
                    if ($allcaps == 1 && $sn > 0) {
                        $is_bareword = 1;
                        $bw_name = $cand;
                    }
                }
            }
            if ($is_bareword == 1) {
                Perla::CodeGen::emit($cg, "({ perla_set_selected_handle(\"" . $bw_name . "\"); strada_select(");
                Perla::CodeGen::gen_expr($cg, $args->[0]);
                Perla::CodeGen::emit($cg, "); })");
            } else {
                Perla::CodeGen::emit($cg, "strada_select(");
                Perla::CodeGen::gen_expr($cg, $args->[0]);
                Perla::CodeGen::emit($cg, ")");
            }
        }
        return;
    }

    # print/say — with optional filehandle: print $fh "text" or print("text")
    if ($name eq "print" || $name eq "say") {
        my int $is_say = 0;
        if ($name eq "say") { $is_say = 1; }
        if ($argc == 0) {
            # `print;` / `say;` — no args, defaults to $_. strada_print returns
            # void; wrap so the expression yields STRADA_MAKE_TAGGED_INT(1) (Perl's
            # print returns 1 on success). Bare wrap (just the call) confuses the
