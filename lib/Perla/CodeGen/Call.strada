        Perla::CodeGen::emit($cg, "} else if (__dv && (STRADA_IS_TAGGED_INT(__dv) || ");
        Perla::CodeGen::emit($cg, "          (!STRADA_IS_TAGGED_INT(__dv) && __dv->type != STRADA_REF && __dv->type != STRADA_UNDEF && __dv->type != STRADA_CLOSURE && __dv->type != STRADA_CPOINTER && __dv->type != STRADA_REGEX))) { ");
