            # EXPR is a string with optional mode prefix (`<name`, `>name`,
            # `>>name`, `+<name`, or bare `name` = read). Assigns the
            # opened handle to FH the same way as the 3-arg form.
            # Legacy code still uses `open(CF, $file);` for config slurps.
            my scalar $fh_arg = $args->[0];
            my str $fh_var = "";
            my str $fh_decl = "";
            my str $fh_bareword = "";
            if (defined($fh_arg) && $fh_arg->{"type"} == Perla::AST::N_SCALAR_VAR()) {
                $fh_var = Perla::CodeGen::c_var($fh_arg->{"name"});
            } elsif (defined($fh_arg) && $fh_arg->{"type"} == Perla::AST::N_MY()) {
                # `open(my $fh, EXPR)` — same trap as the 3-arg form: an
                # inner `StradaValue *v_fh = NULL;` inside the statement-
                # expression shadows the outer auto-declared static, so
                # `print $fh ...; close $fh;` after the open hit the
                # NULL outer. Just call _my_prefix to register the var
                # for the file-scope auto-decl pass and assign into the
                # outer static, leaving $fh_decl empty.
                if (defined($fh_arg->{"var"})) {
                    $fh_var = Perla::CodeGen::c_var($fh_arg->{"var"}->{"value"});
                    Perla::CodeGen::_my_prefix($cg, $fh_arg->{"var"}->{"value"});
                }
            } elsif (defined($fh_arg) && $fh_arg->{"type"} == Perla::AST::N_CALL()) {
                my scalar $fhargs = $fh_arg->{"args"};
                my int $acount = 0;
                if (defined($fhargs)) { $acount = scalar(@{$fhargs}); }
                if ($acount == 0 && defined($fh_arg->{"name"})) {
                    $fh_bareword = $fh_arg->{"name"};
                }
            }
            Perla::CodeGen::emit($cg, "({ " . $fh_decl . "char *__fn_raw = strada_to_str(");
            Perla::CodeGen::gen_expr($cg, $args->[1]);
            Perla::CodeGen::emit($cg, "); char *__fn = __fn_raw; const char *__cm = \"r\"; int __is_pipe = 0; const char *__pipe_mode = \"r\"; ");
            Perla::CodeGen::emit($cg, "while (*__fn == ' ' || *__fn == '\\t') __fn++; ");
            # Detect Perl 2-arg pipe forms: trailing `|` means "read from
            # this command's stdout"; leading `|` means "write to this
            # command's stdin". The pipe char + whitespace is stripped
            # so strada_popen receives a clean command string.
            Perla::CodeGen::emit($cg, "{ size_t __fl = strlen(__fn); ");
            Perla::CodeGen::emit($cg, "  if (__fl > 0 && __fn[__fl-1] == '|') { __is_pipe = 1; __pipe_mode = \"r\"; __fn[__fl-1] = '\\0'; __fl--; ");
            Perla::CodeGen::emit($cg, "    while (__fl > 0 && (__fn[__fl-1] == ' ' || __fn[__fl-1] == '\\t')) { __fn[__fl-1] = '\\0'; __fl--; } } ");
            Perla::CodeGen::emit($cg, "  else if (__fn[0] == '|') { __is_pipe = 1; __pipe_mode = \"w\"; __fn++; while (*__fn == ' ' || *__fn == '\\t') __fn++; } ");
            Perla::CodeGen::emit($cg, "} ");
            Perla::CodeGen::emit($cg, "if (!__is_pipe) { ");
            Perla::CodeGen::emit($cg, "  if (__fn[0] == '>' && __fn[1] == '>') { __cm = \"a\"; __fn += 2; } ");
            Perla::CodeGen::emit($cg, "  else if (__fn[0] == '>') { __cm = \"w\"; __fn += 1; } ");
            Perla::CodeGen::emit($cg, "  else if (__fn[0] == '<') { __cm = \"r\"; __fn += 1; } ");
            Perla::CodeGen::emit($cg, "  else if (__fn[0] == '+' && __fn[1] == '<') { __cm = \"r+\"; __fn += 2; } ");
            Perla::CodeGen::emit($cg, "  else if (__fn[0] == '+' && __fn[1] == '>') { __cm = \"w+\"; __fn += 2; } ");
            Perla::CodeGen::emit($cg, "  while (*__fn == ' ' || *__fn == '\\t') __fn++; ");
            Perla::CodeGen::emit($cg, "} ");
            Perla::CodeGen::emit($cg, "StradaValue *__fh; ");
            Perla::CodeGen::emit($cg, "if (__is_pipe) { StradaValue *__pc = strada_new_str(__fn); StradaValue *__pm = strada_new_str(__pipe_mode); __fh = strada_popen(__pc, __pm); strada_decref(__pc); strada_decref(__pm); } ");
            Perla::CodeGen::emit($cg, "else { __fh = strada_open(__fn, __cm); } ");
            if (length($fh_var) > 0) {
                Perla::CodeGen::emit($cg, $fh_var . " = __fh; ");
            } elsif (length($fh_bareword) > 0) {
                Perla::CodeGen::emit($cg, "perla_scalar_set(\"" . $cg->{"pkg"} . "\", \"" . $fh_bareword . "\", __fh); ");
            } else {
                _emit_open_slot_store($cg, $fh_arg);
            }
            # Same as 3-arg form: undef-on-failure means \`__fh != NULL\`
            # is wrong; check filehandle type + non-NULL FILE*.
            Perla::CodeGen::emit($cg, "int __op_ok = (__fh && !STRADA_IS_TAGGED_INT(__fh) && __fh->type == STRADA_FILEHANDLE && __fh->value.fh != NULL); ");
            Perla::CodeGen::emit($cg, "free(__fn_raw); STRADA_MAKE_TAGGED_INT(__op_ok); })");
