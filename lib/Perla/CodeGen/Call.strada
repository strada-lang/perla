        } elsif ($argc == 1) {
            Perla::CodeGen::emit($cg, "({ int __sav_wl_rv = __perla_want_list; __perla_want_list = 1; StradaValue *__rva = ");
            Perla::CodeGen::gen_expr($cg, $args->[0]);
            Perla::CodeGen::emit($cg, "; __perla_want_list = __sav_wl_rv; perla_reverse_ctx(__rva); })");
        } elsif ($argc > 1) {
            Perla::CodeGen::emit($cg, "({ int __sav_wl_rv = __perla_want_list; __perla_want_list = 1; StradaValue *__ra = strada_new_array(); StradaArray *__rav = strada_deref_array(__ra); ");
            my int $ri = 0;
            while ($ri < $argc) {
                Perla::CodeGen::emit($cg, "strada_array_push(__rav, ");
                Perla::CodeGen::gen_expr($cg, $args->[$ri]);
                Perla::CodeGen::emit($cg, "); ");
                $ri++;
