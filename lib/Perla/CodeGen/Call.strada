                    my str $eon = $eo->{"name"};
                    my int $eoli = -1;
                    my int $eosi = 0;
                    while ($eosi < length($eon) - 1) {
                        if (substr($eon, $eosi, 2) eq "::") { $eoli = $eosi; }
                        $eosi++;
                    }
                    my str $eopkg = substr($eon, 0, $eoli);
                    my str $eoshort = substr($eon, $eoli + 2, length($eon) - $eoli - 2);
                    Perla::CodeGen::emit($cg, "perla_hash_get(\"" . $eopkg . "\", \"" . $eoshort . "\")");
                } elsif ($eo_arrow == 0 && defined($eo) && $eo->{"type"} == Perla::AST::N_SCALAR_VAR()
                    && defined($eo->{"name"}) && length($eo->{"name"}) > 0
                    && index($eo->{"name"}, "::") < 0 && $eo->{"name"} ne "_") {
                    # Imported-from-module hashes (e.g. \`use Config; exists $Config{X}\`)
                    # — v_X is NULL because no `our %X` was declared; the
                    # hash lives in the X:: stash. Mirror the read-path
                    # fallback to perla_hash_get.
                    Perla::CodeGen::emit($cg, Perla::CodeGen::c_var_h($eo->{"name"}));
                    $eo_stash_fallback = 1;
                    $eo_stash_name = $eo->{"name"};
                } else {
                    Perla::CodeGen::gen_expr($cg, $eo);
                }
                if ($eo_stash_fallback == 1) {
                    # Same tied-SV guard as N_HASH_ELEM path above.
                    Perla::CodeGen::emit($cg, "; if ((!__eh || (!STRADA_IS_TAGGED_INT(__eh) && __eh->type == STRADA_HASH && __eh->value.hv && __eh->value.hv->num_entries == 0)) && (!__eh || STRADA_IS_TAGGED_INT(__eh) || !__eh->meta || !__eh->meta->is_tied)) { StradaValue *__ehsv = perla_hash_get(\"" . $eo_stash_name . "\", \"" . $eo_stash_name . "\"); if (__ehsv) __eh = __ehsv; }");
                }
                Perla::CodeGen::emit($cg, "; char *__k = strada_to_str(");
                Perla::CodeGen::gen_expr($cg, $arg->{"key"});
                Perla::CodeGen::emit($cg, "); int __e = strada_hv_exists(__eh, __k); free(__k); __e ? STRADA_MAKE_TAGGED_INT(1) : strada_new_str(\"\"); })");
            } elsif ($arg->{"type"} == Perla::AST::N_ARROW_ARRAY() || $arg->{"type"} == Perla::AST::N_ARRAY_ELEM()) {
                # `exists $h{a}[0]` or `exists $arr[5]` — true iff the slot
                # is in bounds AND has not been tombstoned by a prior
                # `delete $arr[N]`. Tied-aware: dispatch EXISTS on the
                # tied object when SV is tied.
                Perla::CodeGen::emit($cg, "({ StradaValue *__ea_sv = ");
                if ($arg->{"type"} == Perla::AST::N_ARRAY_ELEM()) {
                    Perla::CodeGen::gen_expr($cg, $arg->{"array"});
                } else {
                    Perla::CodeGen::gen_expr($cg, $arg->{"object"});
                }
                Perla::CodeGen::emit($cg, "; int64_t __ea_i = strada_to_int(");
                Perla::CodeGen::gen_expr($cg, $arg->{"index"});
                Perla::CodeGen::emit($cg, "); int __ea_e = strada_av_exists_sv(__ea_sv, __ea_i); __ea_e ? STRADA_MAKE_TAGGED_INT(1) : strada_new_str(\"\"); })");
            } else {
                Perla::CodeGen::emit($cg, "STRADA_MAKE_TAGGED_INT(0)");
            }
        }
        return;
    }

    # delete — Perl returns the deleted value (or undef if it didn't exist).
    # Was hardcoding `strada_new_undef()` so callers like `delete $attrs->{-result_source}`
    # always saw undef, which broke DBIC's `Row::new` (couldn't recover the source).
    if ($name eq "delete") {
        if ($argc > 0) {
            my scalar $arg = $args->[0];
            if ($arg->{"type"} == Perla::AST::N_HASH_ELEM()) {
                # `delete $ENV{KEY}` also calls unsetenv so child processes
                # don't see the deleted key in their env.
                my int $is_env_del = 0;
                my scalar $del_hash = $arg->{"hash"};
                if (defined($del_hash) && $del_hash->{"type"} == Perla::AST::N_SCALAR_VAR()
                    && defined($del_hash->{"name"}) && $del_hash->{"name"} eq "ENV") {
                    $is_env_del = 1;
                }
                Perla::CodeGen::emit($cg, "({ StradaValue *__dh = ");
                if (defined($del_hash) && $del_hash->{"type"} == Perla::AST::N_SCALAR_VAR()
                    && defined($del_hash->{"name"}) && index($del_hash->{"name"}, "::") > 0) {
                    my array @dhpn = Perla::CodeGen::_split_pkg_qual_name($del_hash);
                    Perla::CodeGen::emit($cg, "perla_hash_get(\"" . $dhpn[0] . "\", \"" . $dhpn[1] . "\")");
                } else {
                    Perla::CodeGen::gen_expr($cg, $arg->{"hash"});
                }
                Perla::CodeGen::emit($cg, "; char *__k = strada_to_str(");
                Perla::CodeGen::gen_expr($cg, $arg->{"key"});
                # Tie-aware: hv_fetch_owned and hv_delete dispatch
                # FETCH/DELETE on tied hashes.
                Perla::CodeGen::emit($cg, "); StradaValue *__dv = strada_hv_fetch_owned(__dh, __k); ");
                Perla::CodeGen::emit($cg, "strada_hv_delete(__dh, __k); ");
                if ($is_env_del == 1) {
                    Perla::CodeGen::emit($cg, "unsetenv(__k); ");
                }
                Perla::CodeGen::emit($cg, "free(__k); ");
                Perla::CodeGen::emit($cg, "__dv ? __dv : strada_new_undef(); })");
            } elsif ($arg->{"type"} == Perla::AST::N_ARROW_HASH()) {
                my int $is_env_del_ah = 0;
                my scalar $del_obj = $arg->{"object"};
                if (defined($del_obj) && $del_obj->{"type"} == Perla::AST::N_SCALAR_VAR()
                    && defined($del_obj->{"name"}) && $del_obj->{"name"} eq "ENV") {
                    $is_env_del_ah = 1;
                }
                Perla::CodeGen::emit($cg, "({ StradaValue *__dh = ");
                # `delete $Pkg::H{k}` — route to HASH slot of stash glob.
                # Only when no explicit arrow (`$P::h{k}`, not `$P::h->{k}`)
                # so explicit arrow falls through to Perla::CodeGen::gen_expr (which derefs
                # the SCALAR slot holding a hashref).
                my int $do_is_arrow = 0;
                if (defined($arg->{"is_explicit_arrow"}) && $arg->{"is_explicit_arrow"} == 1) { $do_is_arrow = 1; }
                if ($do_is_arrow == 0 && defined($del_obj)
                    && $del_obj->{"type"} == Perla::AST::N_SCALAR_VAR()
                    && defined($del_obj->{"name"}) && index($del_obj->{"name"}, "::") > 0) {
                    my array @dopn = Perla::CodeGen::_split_pkg_qual_name($del_obj);
                    Perla::CodeGen::emit($cg, "perla_hash_get(\"" . $dopn[0] . "\", \"" . $dopn[1] . "\")");
                } else {
                    Perla::CodeGen::gen_expr($cg, $arg->{"object"});
                }
                Perla::CodeGen::emit($cg, "; char *__k = strada_to_str(");
                Perla::CodeGen::gen_expr($cg, $arg->{"key"});
                # Tie-aware (see N_HASH_ELEM branch above).
                Perla::CodeGen::emit($cg, "); StradaValue *__dv = strada_hv_fetch_owned(__dh, __k); ");
                Perla::CodeGen::emit($cg, "strada_hv_delete(__dh, __k); ");
                if ($is_env_del_ah == 1) {
                    Perla::CodeGen::emit($cg, "unsetenv(__k); ");
                }
                Perla::CodeGen::emit($cg, "free(__k); ");
                Perla::CodeGen::emit($cg, "__dv ? __dv : strada_new_undef(); })");
            } elsif ($arg->{"type"} == Perla::AST::N_HASH_SLICE()) {
                # delete @h{keys} — delete multiple keys, return their
                # values as a list. Without this branch, the call fell
                # through to "unhandled arg type".
                Perla::CodeGen::emit($cg, "({ StradaValue *__dh = ");
                my scalar $hs_hash = $arg->{"hash"};
                if (ref($hs_hash) eq "HASH") {
                    Perla::CodeGen::gen_expr($cg, $hs_hash);
                } else {
                    Perla::CodeGen::emit($cg, Perla::CodeGen::c_var_h("" . $hs_hash));
                }
                Perla::CodeGen::emit($cg, "; StradaHash *__dhv = strada_deref_hash(__dh); ");
                Perla::CodeGen::emit($cg, "StradaValue *__dr = strada_new_array(); StradaArray *__drv = strada_deref_array(__dr); ");
                # Build flat keys array — may be a list of expressions or a single qw/anon-array
                Perla::CodeGen::emit($cg, "StradaValue *__dks = strada_new_array(); StradaArray *__dkv = strada_deref_array(__dks); ");
                my scalar $hs_keys = $arg->{"keys_list"};
                my int $hs_n = scalar(@{$hs_keys});
                my int $hs_i = 0;
                while ($hs_i < $hs_n) {
                    my scalar $hs_k = $hs_keys->[$hs_i];
                    my int $hs_kt = $hs_k->{"type"};
                    if ($hs_kt == Perla::AST::N_QWORD() || ($hs_kt == Perla::AST::N_ANON_ARRAY() && $hs_k->{"is_ref"} != 1)) {
                        my scalar $hs_elems = $hs_k->{"elems"};
                        my int $hs_ei = 0;
                        while ($hs_ei < scalar(@{$hs_elems})) {
                            Perla::CodeGen::emit($cg, "strada_array_push(__dkv, ");
                            Perla::CodeGen::gen_expr($cg, $hs_elems->[$hs_ei]);
                            Perla::CodeGen::emit($cg, "); ");
                            $hs_ei++;
                        }
                    } elsif ($hs_kt == Perla::AST::N_ARRAY_VAR()
                          || $hs_kt == Perla::AST::N_DEREF_ARRAY()
                          || $hs_kt == Perla::AST::N_RANGE()
                          || $hs_kt == Perla::AST::N_ARRAY_SLICE()) {
                        # Array variable / range / slice — splat at runtime.
                        # Without this, `delete @h{@keys}` pushed the whole
                        # array as ONE element and the loop did
                        # `strada_to_str(array)` getting a stringified
                        # array that matched no hash key.
                        Perla::CodeGen::emit($cg, "{ StradaArray *__hs_av = strada_deref_array(");
                        Perla::CodeGen::gen_expr($cg, $hs_k);
                        Perla::CodeGen::emit($cg, "); if (__hs_av) for (size_t __hs_ai = 0; __hs_ai < __hs_av->size; __hs_ai++) { strada_array_push(__dkv, __hs_av->elements[__hs_av->head + __hs_ai]); } } ");
                    } else {
                        Perla::CodeGen::emit($cg, "strada_array_push(__dkv, ");
                        Perla::CodeGen::gen_expr($cg, $hs_k);
                        Perla::CodeGen::emit($cg, "); ");
                    }
                    $hs_i++;
                }
                # For each key, fetch its value then delete from hash.
                Perla::CodeGen::emit($cg, "if (__dhv && __dkv) { for (size_t __dki = 0; __dki < __dkv->size; __dki++) { ");
                Perla::CodeGen::emit($cg, "  StradaValue *__dkk = __dkv->elements[__dkv->head + __dki]; ");
                Perla::CodeGen::emit($cg, "  char *__dks_str = strada_to_str(__dkk); ");
                Perla::CodeGen::emit($cg, "  StradaValue *__dv = strada_hash_get(__dhv, __dks_str); ");
                Perla::CodeGen::emit($cg, "  if (__dv) strada_incref(__dv); else __dv = strada_new_undef(); ");
                Perla::CodeGen::emit($cg, "  strada_array_push_take(__drv, __dv); ");
                Perla::CodeGen::emit($cg, "  strada_hash_delete(__dhv, __dks_str); free(__dks_str); ");
                Perla::CodeGen::emit($cg, "} } strada_decref(__dks); __dr; })");
            } elsif ($arg->{"type"} == Perla::AST::N_ARRAY_ELEM() || $arg->{"type"} == Perla::AST::N_ARROW_ARRAY()) {
                # delete $arr[N] / delete $ref->[N] — use the runtime helper
                # so the slot becomes a real tombstone (so exists() returns
                # false afterwards) and the array shrinks on trailing
                # delete, matching Perl semantics. Tied-aware: dispatch
                # DELETE on the tied object when SV is tied.
                Perla::CodeGen::emit($cg, "({ StradaValue *__dae_sv = ");
                if ($arg->{"type"} == Perla::AST::N_ARRAY_ELEM()) {
                    my scalar $ae_arr = $arg->{"array"};
                    if (defined($ae_arr) && ref($ae_arr) eq "HASH") {
                        Perla::CodeGen::gen_expr($cg, $ae_arr);
                    } else {
                        Perla::CodeGen::emit($cg, Perla::CodeGen::c_var_a("" . $arg->{"array"}));
                    }
                } else {
                    Perla::CodeGen::gen_expr($cg, $arg->{"object"});
                }
                Perla::CodeGen::emit($cg, "; int64_t __dae_i = strada_to_int(");
                Perla::CodeGen::gen_expr($cg, $arg->{"index"});
                # Fetch the value BEFORE deleting so we can return it.
                # Perl's `delete $arr[N]` returns the deleted element
                # (or undef when the slot is already empty). Previously
                # the codegen unconditionally returned undef even on a
                # populated slot.
                Perla::CodeGen::emit($cg, "); StradaValue *__dae_old = NULL; ");
                Perla::CodeGen::emit($cg, "if (__dae_sv && !STRADA_IS_TAGGED_INT(__dae_sv) && __dae_sv->meta && __dae_sv->meta->is_tied) { ");
                Perla::CodeGen::emit($cg, "  __dae_old = strada_tied_array_fetch(__dae_sv, __dae_i); ");
                Perla::CodeGen::emit($cg, "  strada_tied_array_delete(__dae_sv, __dae_i); ");
                Perla::CodeGen::emit($cg, "} else { ");
                Perla::CodeGen::emit($cg, "  StradaArray *__dae_av = strada_deref_array(__dae_sv); ");
                Perla::CodeGen::emit($cg, "  if (__dae_av) { int64_t __dae_eff = __dae_i; if (__dae_eff < 0) __dae_eff += (int64_t)__dae_av->size; ");
                Perla::CodeGen::emit($cg, "    if (__dae_eff >= 0 && (size_t)__dae_eff < __dae_av->size) { __dae_old = __dae_av->elements[__dae_av->head + __dae_eff]; if (__dae_old) strada_incref(__dae_old); } } ");
                Perla::CodeGen::emit($cg, "  strada_array_delete_idx(__dae_av, __dae_i); ");
                Perla::CodeGen::emit($cg, "} ");
                Perla::CodeGen::emit($cg, "__dae_old ? __dae_old : strada_new_undef(); })");
            } elsif ($arg->{"type"} == Perla::AST::N_ARRAY_SLICE()) {
                # delete @arr[1,3] — slice delete: return list of deleted values,
                # leave undef in each slot
                Perla::CodeGen::emit($cg, "({ StradaValue *__das_a = ");
                my scalar $as_arr = $arg->{"array"};
                if (defined($as_arr) && ref($as_arr) eq "HASH") {
                    Perla::CodeGen::gen_expr($cg, $as_arr);
                } else {
                    Perla::CodeGen::emit($cg, Perla::CodeGen::c_var_a("" . $arg->{"array"}));
                }
                Perla::CodeGen::emit($cg, "; StradaArray *__das_av = strada_deref_array(__das_a); ");
                Perla::CodeGen::emit($cg, "StradaValue *__das_r = strada_new_array(); StradaArray *__das_rv = strada_deref_array(__das_r); ");
                Perla::CodeGen::emit($cg, "StradaValue *__das_ks = strada_new_array(); StradaArray *__das_kv = strada_deref_array(__das_ks); ");
                my scalar $as_keys = $arg->{"keys_list"};
                if (!defined($as_keys)) { $as_keys = $arg->{"indices"}; }
                if (defined($as_keys)) {
                    my int $as_n = scalar(@{$as_keys});
                    my int $as_i = 0;
                    while ($as_i < $as_n) {
                        my scalar $as_k = $as_keys->[$as_i];
                        my int $as_kt = $as_k->{"type"};
                        if ($as_kt == Perla::AST::N_QWORD() || ($as_kt == Perla::AST::N_ANON_ARRAY() && $as_k->{"is_ref"} != 1) || $as_kt == Perla::AST::N_RANGE()) {
                            my scalar $as_elems = $as_k->{"elems"};
                            if (!defined($as_elems) && $as_kt == Perla::AST::N_RANGE()) {
                                # range — expand at runtime
                                Perla::CodeGen::emit($cg, "{ int64_t __dr_a = strada_to_int(");
                                Perla::CodeGen::gen_expr($cg, $as_k->{"from"});
                                Perla::CodeGen::emit($cg, "); int64_t __dr_b = strada_to_int(");
                                Perla::CodeGen::gen_expr($cg, $as_k->{"to"});
                                Perla::CodeGen::emit($cg, "); for (int64_t __dr_i = __dr_a; __dr_i <= __dr_b; __dr_i++) strada_array_push_take(__das_kv, STRADA_MAKE_TAGGED_INT(__dr_i)); } ");
                            } elsif (defined($as_elems)) {
                                my int $as_ei = 0;
                                while ($as_ei < scalar(@{$as_elems})) {
                                    Perla::CodeGen::emit($cg, "strada_array_push(__das_kv, ");
                                    Perla::CodeGen::gen_expr($cg, $as_elems->[$as_ei]);
                                    Perla::CodeGen::emit($cg, "); ");
                                    $as_ei++;
                                }
                            }
                        } else {
                            Perla::CodeGen::emit($cg, "strada_array_push(__das_kv, ");
                            Perla::CodeGen::gen_expr($cg, $as_k);
                            Perla::CodeGen::emit($cg, "); ");
                        }
                        $as_i++;
                    }
                }
                Perla::CodeGen::emit($cg, "if (__das_av && __das_kv) { for (size_t __di = 0; __di < __das_kv->size; __di++) { ");
                Perla::CodeGen::emit($cg, "  int64_t __dki = strada_to_int(__das_kv->elements[__das_kv->head + __di]); ");
                Perla::CodeGen::emit($cg, "  StradaValue *__dv = strada_array_delete_idx(__das_av, __dki); ");
                Perla::CodeGen::emit($cg, "  strada_array_push_take(__das_rv, __dv); ");
                Perla::CodeGen::emit($cg, "} } strada_decref(__das_ks); __das_r; })");
            } else {
                Perla::CodeGen::emit($cg, "/* delete: unhandled arg type " . $arg->{"type"} . " */ strada_new_undef()");
            }
        }
        return;
    }

    # chomp — in-place, modifies the variable
    if ($name eq "chomp") {
        # Multi-arg form: `chomp(\$a, \$b, \$c)` chomps each in place.
        # All-scalar-var fast path — emit a per-arg chomp inline.
        if ($argc > 1) {
            my int $ch_all_simple = 1;
            my int $chk = 0;
            while ($chk < $argc) {
                if ($args->[$chk]->{"type"} != Perla::AST::N_SCALAR_VAR()) {
                    $ch_all_simple = 0;
                    last;
                }
                $chk++;
            }
            if ($ch_all_simple == 1) {
                Perla::CodeGen::emit($cg, "({ ");
                my int $chi = 0;
                while ($chi < $argc) {
                    my str $chvname = $args->[$chi]->{"name"};
                    my str $chcvar = ($chvname eq "_") ? "perla_dollar_underscore" : Perla::CodeGen::c_var($chvname);
                    Perla::CodeGen::emit($cg, "if (" . $chcvar . ") { ");
                    Perla::CodeGen::emit($cg, "char *__chs_" . $chi . " = strada_to_str(" . $chcvar . "); ");
                    Perla::CodeGen::emit($cg, "char *__chc_" . $chi . " = perla_chomp_irs(__chs_" . $chi . "); ");
                    # Preserve SVf_UTF8 from the source SV.
                    Perla::CodeGen::emit($cg, "StradaValue *__chnv_" . $chi . " = strada_new_str_like(__chc_" . $chi . ", " . $chcvar . "); ");
                    Perla::CodeGen::emit($cg, "strada_decref(" . $chcvar . "); " . $chcvar . " = __chnv_" . $chi . "; ");
                    Perla::CodeGen::emit($cg, "free(__chs_" . $chi . "); free(__chc_" . $chi . "); } ");
                    $chi++;
                }
                Perla::CodeGen::emit($cg, "STRADA_MAKE_TAGGED_INT(" . $argc . "); })");
                return;
            }
            # Mixed types: chomp just the first arg via the existing single-
            # arg path (matches the prior behavior so nothing regresses).
        }
        if ($argc > 0) {
            # If arg is itself a side-effecting lvalue (my $x = …, $x = …),
            # hoist to a prelude and rewrite to the underlying scalar var so
            # we don't re-evaluate it on the mutating assign (same pattern
            # as s/// and tr///).
            my int $at0 = $args->[0]->{"type"};
            my str $ch_vname = "";
            if ($at0 == Perla::AST::N_MY()) {
                my scalar $mn = $args->[0];
                my scalar $mv = $mn->{"var"};
                if (!defined($mv) && defined($mn->{"vars"}) && scalar(@{$mn->{"vars"}}) > 0) {
                    my scalar $mv0 = $mn->{"vars"}->[0];
                    if (defined($mv0->{"var"})) { $mv = $mv0->{"var"}; }
                }
                # Only hoist as scalar when the my-decl is itself a scalar.
                # `chomp(my @ml = split ...)` would otherwise read @ml as a
                # scalar string and overwrite v_ml with the chomped result,
                # so @ml ended up empty when later iterated.
                if (defined($mv) && length("" . $mv->{"value"}) > 0
                    && defined($mv->{"type"})
                    && "" . $mv->{"type"} ne "ARRAY_VAR"
                    && "" . $mv->{"type"} ne "HASH_VAR") {
                    $ch_vname = $mv->{"value"};
                }
            } elsif ($at0 == Perla::AST::N_ASSIGN() && defined($args->[0]->{"op"}) && $args->[0]->{"op"} eq "=") {
                my scalar $at = $args->[0]->{"target"};
                if (defined($at) && $at->{"type"} == Perla::AST::N_SCALAR_VAR()) {
                    $ch_vname = "" . $at->{"name"};
                }
            }
            # Element-style chomp on $_[N], $arr[N], $hash{k}, $ref->{k}, etc.
            # Route through _emit_subst_writeback so the chomped value is
            # written back into the array/hash slot.
            my int $ch_is_elem = 0;
            if ($at0 == Perla::AST::N_ARRAY_ELEM()
                || $at0 == Perla::AST::N_ARROW_ARRAY()
                || $at0 == Perla::AST::N_HASH_ELEM()
                || $at0 == Perla::AST::N_ARROW_HASH()
                || $at0 == Perla::AST::N_DEREF_SCALAR()) {
                $ch_is_elem = 1;
            }
            if ($ch_is_elem == 1) {
                # chomp on array element: emit the fetch + writeback
                # inline rather than going through emit_subst_writeback
                # (which was crashing perla compile-time on the array
                # branch — root cause not yet diagnosed, but the inline
                # pattern below avoids the bad codepath entirely).
                # Hash element still goes through the writeback helper.
                if (($at0 == Perla::AST::N_ARRAY_ELEM() || $at0 == Perla::AST::N_ARROW_ARRAY())
                    && defined($args->[0]->{"index"})) {
                    my scalar $ce_arr = $args->[0];
                    my scalar $ce_array_obj = ($at0 == Perla::AST::N_ARRAY_ELEM())
                        ? $ce_arr->{"array"} : $ce_arr->{"object"};
                    my int $ce_is_arrow = 0;
                    if ($at0 == Perla::AST::N_ARROW_ARRAY()
                        && defined($ce_arr->{"is_explicit_arrow"})
                        && $ce_arr->{"is_explicit_arrow"} == 1) {
                        $ce_is_arrow = 1;
                    }
                    Perla::CodeGen::emit($cg, "({ StradaArray *__ce_av = strada_deref_array(");
                    if ($ce_is_arrow == 0 && defined($ce_array_obj)
                        && $ce_array_obj->{"type"} == Perla::AST::N_SCALAR_VAR()
                        && $ce_array_obj->{"name"} eq "_") {
                        Perla::CodeGen::emit($cg, "perla_at_");
                    } elsif ($ce_is_arrow == 0 && defined($ce_array_obj)
                             && $ce_array_obj->{"type"} == Perla::AST::N_SCALAR_VAR()
                             && index($ce_array_obj->{"name"}, "::") < 0) {
                        Perla::CodeGen::emit($cg, Perla::CodeGen::c_var_a($ce_array_obj->{"name"}));
                    } else {
                        Perla::CodeGen::gen_expr($cg, $ce_array_obj);
                    }
                    Perla::CodeGen::emit($cg, "); int __ce_idx = (int)strada_to_int(");
                    Perla::CodeGen::gen_expr($cg, $ce_arr->{"index"});
                    Perla::CodeGen::emit($cg, "); if (__ce_idx < 0 && __ce_av) __ce_idx += strada_array_length(__ce_av); ");
                    Perla::CodeGen::emit($cg, "StradaValue *__ce_old = __ce_av ? strada_array_get(__ce_av, __ce_idx) : NULL; ");
                    Perla::CodeGen::emit($cg, "char *__s = strada_to_str(__ce_old); size_t __sl_pre = __s ? strlen(__s) : 0; ");
                    Perla::CodeGen::emit($cg, "char *__c = perla_chomp_irs(__s); size_t __sl_post = __c ? strlen(__c) : 0; ");
                    Perla::CodeGen::emit($cg, "StradaValue *__nv = strada_new_str_like(__c, __ce_old); ");
                    Perla::CodeGen::emit($cg, "if (__ce_av) strada_array_set(__ce_av, __ce_idx, __nv); else strada_decref(__nv); ");
                    Perla::CodeGen::emit($cg, "free(__s); free(__c); STRADA_MAKE_TAGGED_INT((int64_t)(__sl_pre - __sl_post)); })");
                    return;
                }
                Perla::CodeGen::emit($cg, "({ StradaValue *__ch_in = ");
                Perla::CodeGen::gen_expr($cg, $args->[0]);
                Perla::CodeGen::emit($cg, "; char *__s = strada_to_str(__ch_in); size_t __sl_pre = __s ? strlen(__s) : 0; ");
                Perla::CodeGen::emit($cg, "char *__c = perla_chomp_irs(__s); size_t __sl_post = __c ? strlen(__c) : 0; ");
                Perla::CodeGen::emit($cg, "StradaValue *__nv = strada_new_str_like(__c, __ch_in); ");
                Perla::CodeGen::Subst::emit_subst_writeback($cg, $args->[0], "__nv");
                Perla::CodeGen::emit($cg, " free(__s); free(__c); STRADA_MAKE_TAGGED_INT((int64_t)(__sl_pre - __sl_post)); })");
                return;
            }
            # Only chomp targets we can assign back to (plain scalar var, or
            # hoist-able scalar assign/my). Complex targets (e.g. chomp(@lines
             # = <STDIN>) which chomps per-element) fall back to a TODO that
             # still type-checks.
            my int $ch_ok = 0;
            if ($at0 == Perla::AST::N_SCALAR_VAR()) { $ch_ok = 1; }
            if (length($ch_vname) > 0) { $ch_ok = 1; }
            if ($ch_ok == 1) {
                Perla::CodeGen::emit($cg, "({ ");
                if (length($ch_vname) > 0) {
                    my str $cvar_ch = Perla::CodeGen::c_var($ch_vname);
                    if (!defined($cg->{"declared_vars"})) { $cg->{"declared_vars"} = {}; }
                    $cg->{"declared_vars"}->{$cvar_ch} = 1;
                    Perla::CodeGen::gen_expr($cg, $args->[0]); Perla::CodeGen::emit($cg, "; ");
                    Perla::CodeGen::emit($cg, "if (" . $cvar_ch . ") strada_incref(" . $cvar_ch . "); ");
                    my scalar $sv_node = Perla::AST::node(Perla::AST::N_SCALAR_VAR());
                    $sv_node->{"name"} = $ch_vname;
                    $args->[0] = $sv_node;
                }
                # `chomp($@)` — $@ reads as a lazy-init statement expression
                # `({ if (!perla_eval_error)…; perla_eval_error; })`, which is
                # NOT a C lvalue, so the standard `<read> = <chomped>` assign
                # fails to compile ("lvalue required"). Write the global
                # directly instead. Real-world: Types::TypeTiny chomps $@ in an
                # error-formatting path, which blocked Type::Library.pm.o (and
                # thus DBIx::Class / Type::Tiny) from compiling at all.
                my int $ch_is_at = 0;
                if (defined($args->[0]) && $args->[0]->{"type"} == Perla::AST::N_SCALAR_VAR()
                    && defined($args->[0]->{"name"}) && $args->[0]->{"name"} eq "@") {
                    $ch_is_at = 1;
                }
                Perla::CodeGen::emit($cg, "StradaValue *__ch_in = ");
                Perla::CodeGen::gen_expr($cg, $args->[0]);
                Perla::CodeGen::emit($cg, "; char *__s = strada_to_str(__ch_in); size_t __sl_pre = __s ? strlen(__s) : 0; char *__c = perla_chomp_irs(__s); size_t __sl_post = __c ? strlen(__c) : 0; ");
                if ($ch_is_at == 1) {
                    Perla::CodeGen::emit($cg, "{ StradaValue *__ch_nv = strada_new_str_like(__c, __ch_in); if (perla_eval_error) strada_decref(perla_eval_error); perla_eval_error = __ch_nv; } ");
                    Perla::CodeGen::emit($cg, "free(__s); free(__c); STRADA_MAKE_TAGGED_INT((int64_t)(__sl_pre - __sl_post)); })");
                } else {
                    Perla::CodeGen::gen_expr($cg, $args->[0]);
                    Perla::CodeGen::emit($cg, " = strada_new_str_like(__c, __ch_in); free(__s); free(__c); STRADA_MAKE_TAGGED_INT((int64_t)(__sl_pre - __sl_post)); })");
                }
            } else {
                # Array-style: chomp(@arr) chomps each element in place.
                # Evaluate the arg to produce the array (whether `@arr` alone
                # or `@arr = <FH>`), then loop over it and rewrite each
                # element to its chomped value.
                Perla::CodeGen::emit($cg, "({ StradaValue *__ch_av_sv = ");
                Perla::CodeGen::gen_expr($cg, $args->[0]);
                Perla::CodeGen::emit($cg, "; StradaArray *__ch_av = strada_deref_array(__ch_av_sv); ");
                Perla::CodeGen::emit($cg, "int __ch_cnt = 0; ");
                Perla::CodeGen::emit($cg, "if (__ch_av) { for (size_t __ch_i = 0; __ch_i < __ch_av->size; __ch_i++) { ");
                Perla::CodeGen::emit($cg, "StradaValue *__ch_el = __ch_av->elements[__ch_av->head + __ch_i]; ");
                Perla::CodeGen::emit($cg, "if (!__ch_el) continue; char *__ch_s = strada_to_str(__ch_el); ");
                Perla::CodeGen::emit($cg, "size_t __ch_sl = __ch_s ? strlen(__ch_s) : 0; ");
                # Route through perla_chomp_irs so chomp respects $/ (notably
                # the slurp-mode no-op when $/ is undef).
                Perla::CodeGen::emit($cg, "char *__ch_c = perla_chomp_irs(__ch_s); size_t __ch_new_sl = __ch_c ? strlen(__ch_c) : 0; ");
                Perla::CodeGen::emit($cg, "if (__ch_new_sl < __ch_sl) { __ch_cnt += (int)(__ch_sl - __ch_new_sl); ");
                Perla::CodeGen::emit($cg, "StradaValue *__ch_nv = strada_new_str_like(__ch_c, __ch_el); ");
                Perla::CodeGen::emit($cg, "strada_array_set(__ch_av, __ch_i, __ch_nv); } free(__ch_s); free(__ch_c); } } ");
                Perla::CodeGen::emit($cg, "STRADA_MAKE_TAGGED_INT(__ch_cnt); })");
            }
        } else {
            # chomp with no args: default to $_
            Perla::CodeGen::emit($cg, "({ StradaValue *__ch_in = perla_dollar_underscore ? perla_dollar_underscore : strada_new_str(\"\"); ");
            Perla::CodeGen::emit($cg, "char *__s = strada_to_str(__ch_in); ");
            Perla::CodeGen::emit($cg, "size_t __sl_pre = __s ? strlen(__s) : 0; ");
            Perla::CodeGen::emit($cg, "char *__c = perla_chomp_irs(__s); size_t __sl_post = __c ? strlen(__c) : 0; ");
            Perla::CodeGen::emit($cg, "StradaValue *__ch_nv = strada_new_str_like(__c, __ch_in); ");
            Perla::CodeGen::emit($cg, "if (perla_dollar_underscore) strada_decref(perla_dollar_underscore); ");
            Perla::CodeGen::emit($cg, "perla_dollar_underscore = __ch_nv; free(__s); free(__c); STRADA_MAKE_TAGGED_INT((int64_t)(__sl_pre - __sl_post)); })");
        }
        return;
    }

    # length — must use the binary-safe stored length, not strlen,
    # so `length(chr(0))` returns 1 and embedded NULs in strings
    # are counted correctly.
    if ($name eq "length") {
        # Perl: length(undef) returns undef, not 0. Other args return
        # the character length. Scalar context on arg — without it,
        # `length(returns_list())` in print args got the stringification
        # of an empty STRADA_ARRAY ("array(0x...)" → length 21) instead
        # of length of last value.
        # Tied scalars: dispatch FETCH before length check — without
        # this, `length($tied_x)` sees the placeholder STRADA_UNDEF
        # type on the tied SV and returns undef. Match perl: FETCH
        # first, then measure the result.
        Perla::CodeGen::emit($cg, "({ int __sav_wl_len = __perla_want_list; __perla_want_list = 0; StradaValue *__lv = ");
        if ($argc > 0) { Perla::CodeGen::gen_expr($cg, $args->[0]); }
        else { Perla::CodeGen::emit($cg, "perla_dollar_underscore ? perla_dollar_underscore : strada_new_str(\"\")"); }
        Perla::CodeGen::emit($cg, "; __perla_want_list = __sav_wl_len; ");
        Perla::CodeGen::emit($cg, "StradaValue *__lv_f = NULL; ");
        Perla::CodeGen::emit($cg, "if (__lv && !STRADA_IS_TAGGED_INT(__lv) && __lv->meta && __lv->meta->is_tied && __lv->meta->tied_obj) { __lv_f = strada_tied_scalar_fetch(__lv); __lv = __lv_f; } ");
        # `use bytes` switches length() to byte count regardless of
        # SVf_UTF8 flag — emit STRADA_STR_BYTELEN instead of the char-
        # counting strada_str_len. Outside `use bytes`, the runtime
        # strada_str_len counts codepoints when the flag is set, bytes
        # otherwise (matches Perl).
        my int $__len_bytes = 0;
        if (defined($cg->{"use_bytes"}) && $cg->{"use_bytes"} == 1) { $__len_bytes = 1; }
        if ($__len_bytes == 1) {
            Perla::CodeGen::emit($cg, "StradaValue *__lr = (!__lv || (!STRADA_IS_TAGGED_INT(__lv) && __lv->type == STRADA_UNDEF)) ? strada_new_undef() : STRADA_MAKE_TAGGED_INT((int64_t)((__lv && !STRADA_IS_TAGGED_INT(__lv) && __lv->type == STRADA_STR) ? (STRADA_STR_BYTELEN(__lv) ? STRADA_STR_BYTELEN(__lv) : (__lv->value.pv ? strlen(__lv->value.pv) : 0)) : strada_str_len(__lv))); ");
        } else {
            Perla::CodeGen::emit($cg, "StradaValue *__lr = (!__lv || (!STRADA_IS_TAGGED_INT(__lv) && __lv->type == STRADA_UNDEF)) ? strada_new_undef() : STRADA_MAKE_TAGGED_INT((int64_t)strada_str_len(__lv)); ");
        }
        Perla::CodeGen::emit($cg, "if (__lv_f) strada_decref(__lv_f); __lr; })");
        return;
    }

    # pos — current /g match position. Only meaningful inside a
    # `while (\$s =~ /pat/g)` loop, where the surrounding codegen has
    # set regex_g_pos_var to the local size_t var tracking the position.
    # Outside that context, return undef (matches Perl).
    if ($name eq "pos") {
        if (defined($cg->{"regex_g_pos_var"}) && length($cg->{"regex_g_pos_var"}) > 0) {
            Perla::CodeGen::emit($cg, "STRADA_MAKE_TAGGED_INT((int64_t)" . $cg->{"regex_g_pos_var"} . ")");
        } elsif ($argc >= 1) {
            # pos($sv) reads sv->meta->regex_pos (set by /g matches).
            # Returns undef if unset or no meta.
            Perla::CodeGen::emit($cg, "({ StradaValue *__pv = ");
            Perla::CodeGen::gen_expr($cg, $args->[0]);
            Perla::CodeGen::emit($cg, "; StradaValue *__pr; if (__pv && !STRADA_IS_TAGGED_INT(__pv) && __pv->meta && __pv->meta->regex_pos >= 0) { __pr = STRADA_MAKE_TAGGED_INT((int64_t)__pv->meta->regex_pos); } else { __pr = strada_new_undef(); } __pr; })");
        } else {
            Perla::CodeGen::emit($cg, "strada_new_undef()");
        }
        return;
    }

    # substr
    if ($name eq "substr") {
        if ($argc == 4) {
            # 4-arg substr: substr(\$str, off, len, REPL) replaces the
            # substring with REPL AND returns the original substring.
            # Was falling through to 3-arg (no replacement) and silently
            # dropping REPL.
            # 4-arg substr through a DEREF target (`substr($$yaml,0,1,'')`,
            # YAML::PP::Lexer): gen_expr of $$x is a statement-expression,
            # not an lvalue — taking &(...) of it failed to compile. Deref
            # the REF once and write back through its rv slot.
            if (defined($args->[0]) && ref($args->[0]) eq "HASH"
                && $args->[0]->{"type"} == Perla::AST::N_DEREF_SCALAR()
                && defined($args->[0]->{"ref"})) {
                Perla::CodeGen::emit($cg, "({ StradaValue *__sub_tref = ");
                Perla::CodeGen::gen_expr($cg, $args->[0]->{"ref"});
                Perla::CodeGen::emit($cg, "; StradaValue *__sub_old = strada_new_str(\"\"); ");
                Perla::CodeGen::emit($cg, "if (__sub_tref && !STRADA_IS_TAGGED_INT(__sub_tref) && __sub_tref->type == STRADA_REF && __sub_tref->value.rv) { ");
                Perla::CodeGen::emit($cg, "  strada_decref(__sub_old); ");
                Perla::CodeGen::emit($cg, "  __sub_old = strada_substr(__sub_tref->value.rv, (int)strada_to_num(");
                Perla::CodeGen::gen_expr($cg, $args->[1]);
                Perla::CodeGen::emit($cg, "), (int)strada_to_num(");
                Perla::CodeGen::gen_expr($cg, $args->[2]);
                Perla::CodeGen::emit($cg, ")); ");
                Perla::CodeGen::emit($cg, "  char *__sub_repl = strada_to_str(");
                Perla::CodeGen::gen_expr($cg, $args->[3]);
                Perla::CodeGen::emit($cg, "); ");
                Perla::CodeGen::emit($cg, "  strada_substr_assign(&(__sub_tref->value.rv), (int64_t)strada_to_num(");
                Perla::CodeGen::gen_expr($cg, $args->[1]);
                Perla::CodeGen::emit($cg, "), (int64_t)strada_to_num(");
                Perla::CodeGen::gen_expr($cg, $args->[2]);
                Perla::CodeGen::emit($cg, "), __sub_repl); free(__sub_repl); ");
                Perla::CodeGen::emit($cg, "} __sub_old; })");
                return;
            }
            Perla::CodeGen::emit($cg, "({ ");
            Perla::CodeGen::emit($cg, "StradaValue *__sub_old = strada_substr(");
            Perla::CodeGen::gen_expr($cg, $args->[0]);
            Perla::CodeGen::emit($cg, ", (int)strada_to_num(");
            Perla::CodeGen::gen_expr($cg, $args->[1]);
            Perla::CodeGen::emit($cg, "), (int)strada_to_num(");
            Perla::CodeGen::gen_expr($cg, $args->[2]);
            Perla::CodeGen::emit($cg, ")); ");
            Perla::CodeGen::emit($cg, "char *__sub_repl = strada_to_str(");
            Perla::CodeGen::gen_expr($cg, $args->[3]);
            Perla::CodeGen::emit($cg, "); ");
            Perla::CodeGen::emit($cg, "strada_substr_assign(&(");
            Perla::CodeGen::gen_expr($cg, $args->[0]);
            Perla::CodeGen::emit($cg, "), (int64_t)strada_to_num(");
            Perla::CodeGen::gen_expr($cg, $args->[1]);
            Perla::CodeGen::emit($cg, "), (int64_t)strada_to_num(");
            Perla::CodeGen::gen_expr($cg, $args->[2]);
            Perla::CodeGen::emit($cg, "), __sub_repl); free(__sub_repl); __sub_old; })");
            return;
        }
        if ($argc >= 3) {
            Perla::CodeGen::emit($cg, "strada_substr(");
            Perla::CodeGen::gen_expr($cg, $args->[0]);
            Perla::CodeGen::emit($cg, ", (int)strada_to_num(");
            Perla::CodeGen::gen_expr($cg, $args->[1]);
            Perla::CodeGen::emit($cg, "), (int)strada_to_num(");
            Perla::CodeGen::gen_expr($cg, $args->[2]);
            Perla::CodeGen::emit($cg, "))");
        } elsif ($argc >= 2) {
            # substr with just offset — to end of string. Route through
            # strada_substr (char-oriented for UTF-8 strings, byte-
            # oriented for raw); pass INT64_MAX as the length sentinel
            # so the runtime clamps to end. The previous inline emit
            # used byte offsets unconditionally, breaking
            # `use utf8; substr($s, 6)` on a multibyte string.
            Perla::CodeGen::emit($cg, "strada_substr(");
            Perla::CodeGen::gen_expr($cg, $args->[0]);
            Perla::CodeGen::emit($cg, ", (int64_t)strada_to_num(");
            Perla::CodeGen::gen_expr($cg, $args->[1]);
            Perla::CodeGen::emit($cg, "), INT64_MAX)");
        }
        return;
    }

    # join
    if ($name eq "join") {
        if ($argc == 1) {
            # join(SEP) with no list — emit empty string. Perl returns "".
            # Template::Context has `join(', ')` in a debug chain.
            Perla::CodeGen::emit($cg, "strada_new_str(\"\")");
            return;
        }
        if ($argc == 0) {
            Perla::CodeGen::emit($cg, "strada_new_str(\"\")");
            return;
        }
        if ($argc >= 2) {
            # Keep sep as StradaValue* so embedded NULs (e.g. join("\x00", ...))
            # are preserved — strada_to_str followed by strlen would truncate.
            my int $sep_borrowed = Perla::CodeGen::expr_is_borrowed($args->[0]);
            Perla::CodeGen::emit($cg, "({ StradaValue *__sep_sv = (");
            Perla::CodeGen::gen_expr($cg, $args->[0]);
            if ($argc == 2) {
                # join(",", @array) — single arg. If the arg is an array
                # (STRADA_ARRAY), join its elements. If it's a hash, flatten
                # to (k,v,k,v,...). Otherwise treat as a single-element list
                # — `join(",", "x")` should return "x", not "" (which
                # strada_deref_array on a scalar would produce by returning
                # NULL).
                # Force list context for the second arg so chains like
                # `join(",", map {...} sort {...} keys %h)` propagate
                # list context to keys (which otherwise returns count).
                Perla::CodeGen::emit($cg, "); int __sav_wl_jn = __perla_want_list; __perla_want_list = 1; StradaValue *__jv = ");
                Perla::CodeGen::gen_expr($cg, $args->[1]);
                Perla::CodeGen::emit($cg, "; __perla_want_list = __sav_wl_jn");
                Perla::CodeGen::emit($cg, "; StradaArray *__jav = strada_deref_array(__jv); ");
                Perla::CodeGen::emit($cg, "StradaValue *__jfb = NULL; ");
                Perla::CodeGen::emit($cg, "if (!__jav && __jv && !STRADA_IS_TAGGED_INT(__jv) && __jv->type == STRADA_HASH && __jv->value.hv) { ");
                Perla::CodeGen::emit($cg, "  __jfb = strada_new_array(); StradaArray *__hf_av = strada_deref_array(__jfb); ");
                Perla::CodeGen::emit($cg, "  StradaArray *__hf_keys = strada_hash_keys(__jv->value.hv); ");
                Perla::CodeGen::emit($cg, "  if (__hf_keys) { for (size_t __hf_i = 0; __hf_i < __hf_keys->size; __hf_i++) { ");
                Perla::CodeGen::emit($cg, "    StradaValue *__hf_k = __hf_keys->elements[__hf_keys->head + __hf_i]; ");
                Perla::CodeGen::emit($cg, "    char *__hf_ks = strada_to_str(__hf_k); ");
                Perla::CodeGen::emit($cg, "    StradaValue *__hf_v = strada_hash_get(__jv->value.hv, __hf_ks); ");
                Perla::CodeGen::emit($cg, "    free(__hf_ks); ");
                Perla::CodeGen::emit($cg, "    if (__hf_k) strada_incref(__hf_k); strada_array_push(__hf_av, __hf_k); ");
                Perla::CodeGen::emit($cg, "    if (__hf_v) strada_incref(__hf_v); strada_array_push(__hf_av, __hf_v); ");
                Perla::CodeGen::emit($cg, "  } strada_free_array(__hf_keys); } __jav = __hf_av; ");
                Perla::CodeGen::emit($cg, "} else if (!__jav && __jv) { __jfb = strada_new_array(); strada_array_push(strada_deref_array(__jfb), __jv); __jav = strada_deref_array(__jfb); } ");
                my int $jv_borrowed = Perla::CodeGen::expr_is_borrowed($args->[1]);
                Perla::CodeGen::emit($cg, "StradaValue *__jr = strada_join_sv(__sep_sv, __jav); ");
                Perla::CodeGen::emit($cg, "if (__jfb) strada_decref(__jfb); ");
                # Decref the SEP and LIST temps when they were owned exprs.
                # Without this, `join("|", LIST)` leaked the "|" literal
                # plus the LIST array container once per call.
                if ($sep_borrowed == 0) {
                    Perla::CodeGen::emit($cg, "if (__sep_sv) strada_decref(__sep_sv); ");
                }
                if ($jv_borrowed == 0) {
                    Perla::CodeGen::emit($cg, "if (__jv) strada_decref(__jv); ");
                }
                Perla::CodeGen::emit($cg, "__jr; })");
            } else {
                # join(",", "a", @b, "c", @d) — mixed scalars and arrays.
                # Each array argument must FLATTEN into the joined list (Perl
                # list-context semantics) — without flatten, perla's
                # `join('', $prefix, @msg)` produced just $prefix because
                # @msg got pushed as one ARRAY element and join()'s
                # stringification yielded "" for it. DBIx::Class::Carp's
                # `join('', $calling, @_)` was the visible casualty:
                # `{UNKNOWN}: <real message>` collapsed to `{UNKNOWN}: `,
                # the bizowie BZ:6 plateau's empty diagnostics.
                Perla::CodeGen::emit($cg, "); StradaValue *__ja = strada_new_array(); StradaArray *__jav = strada_deref_array(__ja); ");
                my int $ji = 1;
                while ($ji < $argc) {
                    my int $j_at = $args->[$ji]->{"type"};
                    my int $j_is_call = ($j_at == Perla::AST::N_CALL()
                                         || $j_at == Perla::AST::N_METHOD()) ? 1 : 0;
                    # Force list context for sub/method calls so
                    # `return (...)` produces an array, not just the
                    # last element. Without this, `join("-", mk(), "x")`
                    # where mk returns ("a","b") collapsed to "b-x"
                    # because mk() inherited the outer scalar context.
                    if ($j_is_call == 1) {
                        Perla::CodeGen::emit($cg, "{ int __j_sav_wl = __perla_want_list; __perla_want_list = 1; StradaValue *__jve = ");
                        Perla::CodeGen::gen_expr($cg, $args->[$ji]);
                        Perla::CodeGen::emit($cg, "; __perla_want_list = __j_sav_wl; ");
                    } else {
                        Perla::CodeGen::emit($cg, "{ StradaValue *__jve = ");
                        Perla::CodeGen::gen_expr($cg, $args->[$ji]);
                        Perla::CodeGen::emit($cg, "; ");
                    }
                    Perla::CodeGen::emit($cg, "if (__jve && !STRADA_IS_TAGGED_INT(__jve) && __jve->type == STRADA_ARRAY) { ");
                    Perla::CodeGen::emit($cg, "StradaArray *__jvea = strada_deref_array(__jve); if (__jvea) { for (size_t __jvi = 0; __jvi < __jvea->size; __jvi++) { ");
                    Perla::CodeGen::emit($cg, "StradaValue *__jvel = __jvea->elements[__jvea->head + __jvi]; if (__jvel) strada_incref(__jvel); strada_array_push(__jav, __jvel); } } ");
                    Perla::CodeGen::emit($cg, "} else { strada_array_push(__jav, __jve); } } ");
                    $ji++;
                }
                Perla::CodeGen::emit($cg, "StradaValue *__jr = strada_join_sv(__sep_sv, __jav); ");
                if ($sep_borrowed == 0) {
                    Perla::CodeGen::emit($cg, "if (__sep_sv) strada_decref(__sep_sv); ");
                }
                Perla::CodeGen::emit($cg, "strada_decref(__ja); __jr; })");
            }
        }
        return;
    }

    # split
    if ($name eq "split") {
        # `split` with no args = `split " ", $_` (whitespace split on $_).
        # Without this, perla treated `split` as a bareword and returned
        # empty for `split` in `map { split }` etc.
        if ($argc == 0) {
            # No-arg split: arm subject_len from $_ so NUL bytes in the
            # subject don't truncate the regex/string split below.
            Perla::CodeGen::emit($cg, "({ char *__sp = strdup(\"\\\\s+\"); ");
            Perla::CodeGen::emit($cg, "StradaValue *__ssv = perla_dollar_underscore ? perla_dollar_underscore : strada_new_str(\"\"); ");
