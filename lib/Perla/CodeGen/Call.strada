            # Argument evaluation order: Perl evaluates the BLOCK (1st
            # arg) before the class expression (2nd arg). This matters
            # for the idiomatic constructor `bless { @_[1..\$#_] }, shift`
            # where shift mutates @_ — the slice must see the pre-shift
            # @_, which only happens if we eval arg[0] first.
            Perla::CodeGen::emit($cg, "({ StradaValue *__bref = ");
            Perla::CodeGen::gen_expr($cg, $args->[0]);
            Perla::CodeGen::emit($cg, "; StradaValue *__bsv = ");
            Perla::CodeGen::gen_expr($cg, $args->[1]);
            Perla::CodeGen::emit($cg, "; strada_incref(__bsv); char *__bp = perla_class_name(__bsv); StradaValue *__br = perla_bless(__bref, __bp); strada_decref(__bsv); free(__bp); __br; })");
        }
