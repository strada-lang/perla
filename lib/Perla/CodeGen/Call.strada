                        || $aat == Perla::AST::N_ARRAY_SLICE()
                        || $aat == Perla::AST::N_HASH_SLICE()
                        || $aat == Perla::AST::N_RANGE()
                        || $aat == Perla::AST::N_CALL()
                        || $aat == Perla::AST::N_METHOD()
                        || $aat == Perla::AST::N_GREP()
                        || $aat == Perla::AST::N_MAP()
                        || $aat == Perla::AST::N_SORT()
                        || $aat == Perla::AST::N_QWORD()) {
                        Perla::CodeGen::emit($cg, "{ StradaValue *__sp_fv = ");
                        Perla::CodeGen::gen_expr($cg, $args->[$si]);
                        Perla::CodeGen::emit($cg, "; if (__sp_fv && !STRADA_IS_TAGGED_INT(__sp_fv) && __sp_fv->type == STRADA_ARRAY) { ");
                        Perla::CodeGen::emit($cg, "  StradaArray *__sp_fa = __sp_fv->value.av; size_t __sp_fa_sz = __sp_fa ? __sp_fa->size : 0; size_t __sp_fa_hd = __sp_fa ? __sp_fa->head : 0; ");
                        Perla::CodeGen::emit($cg, "  for (size_t __sp_fi = 0; __sp_fi < __sp_fa_sz; __sp_fi++) strada_array_push(__sp_av, __sp_fa->elements[__sp_fa_hd + __sp_fi]); ");
                        Perla::CodeGen::emit($cg, "} else { strada_array_push(__sp_av, __sp_fv); } } ");
                    } else {
                        Perla::CodeGen::emit($cg, "strada_array_push(__sp_av, ");
                        Perla::CodeGen::gen_expr($cg, $args->[$si]);
                        Perla::CodeGen::emit($cg, "); ");
                    }
                    $si++;
                }
                Perla::CodeGen::emit($cg, "__perla_want_list = __sp_sav_wl; ");
                Perla::CodeGen::emit($cg, "StradaValue *__sp_r = strada_sprintf_sv_arr(__sp_fmt, __sp_arr); strada_decref(__sp_arr); __sp_r; })");
                return;
            }
            my int $nargs = $argc - 1;
            # Evaluate arguments left-to-right via temporary captures so
            # side effects fire in Perl order. Calling
            # `strada_sprintf_sv(fmt, n, a, b, c, …)` directly hands the
            # args to a varargs C function whose evaluation order is
            # unspecified — and gcc/clang typically evaluate right-to-left.
            # Track each arg's borrowed/owned status so we can decref the
            # owned temps after the call; without this the fmt string
            # literal and any computed args leak once per call.
            my int $sp_fmt_borrowed = Perla::CodeGen::expr_is_borrowed($args->[0]);
            Perla::CodeGen::emit($cg, "({ ");
            Perla::CodeGen::emit($cg, "StradaValue *__sp_fmt = ");
            Perla::CodeGen::gen_expr($cg, $args->[0]);
            Perla::CodeGen::emit($cg, "; ");
            my int $si = 1;
            while ($si < $argc) {
                Perla::CodeGen::emit($cg, "StradaValue *__sp_a" . $si . " = ");
                Perla::CodeGen::gen_expr($cg, $args->[$si]);
                Perla::CodeGen::emit($cg, "; ");
                $si++;
            }
            Perla::CodeGen::emit($cg, "StradaValue *__sp_r = strada_sprintf_sv(__sp_fmt, " . $nargs);
            $si = 1;
            while ($si < $argc) {
                Perla::CodeGen::emit($cg, ", __sp_a" . $si);
                $si++;
            }
            Perla::CodeGen::emit($cg, "); ");
            # Decref owned temps. Borrowed (variables, array elems) are
            # held alive by their slot — never decref those.
            if ($sp_fmt_borrowed == 0) {
                Perla::CodeGen::emit($cg, "if (__sp_fmt) strada_decref(__sp_fmt); ");
            }
            $si = 1;
            while ($si < $argc) {
                if (Perla::CodeGen::expr_is_borrowed($args->[$si]) == 0) {
                    Perla::CodeGen::emit($cg, "if (__sp_a" . $si . ") strada_decref(__sp_a" . $si . "); ");
                }
                $si++;
            }
            Perla::CodeGen::emit($cg, "__sp_r; })");
        }
        return;
    }

    # pack(FMT, LIST) → strada_pack(fmt_cstr, args_array). Without
    # dispatch, perla emitted `perla_code_get("main", "pack")` which
    # returns NULL → undef → broke binary I/O entirely.
    # vec(EXPR, OFFSET, BITS) — bit-vector accessor (rvalue form).
    # Lvalue form `vec($v, off, bits) = val` is handled in the N_ASSIGN
    # codegen which detects the vec(...) target and emits strada_vec_set
    # instead. Without that, `vec($v, 0, 8) = 65` would try to assign
    # to the result of vec() which is not an lvalue.
    if ($name eq "vec") {
        if ($argc == 3) {
            Perla::CodeGen::emit($cg, "STRADA_MAKE_TAGGED_INT(strada_vec_get(");
            Perla::CodeGen::gen_expr($cg, $args->[0]);
            Perla::CodeGen::emit($cg, ", strada_to_int(");
            Perla::CodeGen::gen_expr($cg, $args->[1]);
            Perla::CodeGen::emit($cg, "), (int)strada_to_int(");
            Perla::CodeGen::gen_expr($cg, $args->[2]);
            Perla::CodeGen::emit($cg, ")))");
            return;
        }
        Perla::CodeGen::emit($cg, "STRADA_MAKE_TAGGED_INT(0)");
        return;
    }
    if ($name eq "pack") {
        if ($argc >= 1) {
            Perla::CodeGen::emit($cg, "({ char *__fmt = strada_to_str(");
            Perla::CodeGen::gen_expr($cg, $args->[0]);
            Perla::CodeGen::emit($cg, "); StradaValue *__pa = strada_new_array(); ");
            my int $pi2 = 1;
            while ($pi2 < $argc) {
                my scalar $parg = $args->[$pi2];
                # pack(TEMPLATE, LIST) — every value arg is list context, and
                # list results flatten. Evaluate each arg with want_list=1
                # (so a bare range `1..5`, or reverse/map/grep/keys/values/a
                # list-returning call, yields its full list rather than the
                # scalar-context value — e.g. the flip-flop op for `1..5`),
                # then flatten if it came back as an array.
                Perla::CodeGen::emit($cg, "{ StradaValue *__pkv = ({ int __pk_swl = __perla_want_list; __perla_want_list = 1; StradaValue *__pk_rv = ");
                Perla::CodeGen::gen_expr($cg, $parg);
                Perla::CodeGen::emit($cg, "; __perla_want_list = __pk_swl; __pk_rv; }); if (__pkv && !STRADA_IS_TAGGED_INT(__pkv) && __pkv->type == STRADA_ARRAY) { ");
                Perla::CodeGen::emit($cg, "StradaArray *__pka = __pkv->value.av; ");
                Perla::CodeGen::emit($cg, "for (size_t __pki = 0; __pki < __pka->size; __pki++) strada_array_push(strada_deref_array(__pa), __pka->elements[__pka->head + __pki]); ");
                # A hash in list context flattens to its key/value pairs.
                Perla::CodeGen::emit($cg, "} else if (__pkv && !STRADA_IS_TAGGED_INT(__pkv) && __pkv->type == STRADA_HASH) { ");
                Perla::CodeGen::emit($cg, "StradaArray *__pkk = strada_hash_keys(__pkv->value.hv); ");
                Perla::CodeGen::emit($cg, "if (__pkk) { for (size_t __pki = 0; __pki < __pkk->size; __pki++) { ");
                Perla::CodeGen::emit($cg, "StradaValue *__pkey = __pkk->elements[__pkk->head + __pki]; char *__pks = strada_to_str(__pkey); ");
                Perla::CodeGen::emit($cg, "strada_array_push(strada_deref_array(__pa), __pkey); ");
                Perla::CodeGen::emit($cg, "strada_array_push(strada_deref_array(__pa), strada_hash_get(__pkv->value.hv, __pks ? __pks : \"\")); ");
                Perla::CodeGen::emit($cg, "if (__pks) free(__pks); } strada_free_array(__pkk); } ");
                Perla::CodeGen::emit($cg, "} else { strada_array_push(strada_deref_array(__pa), __pkv); } } ");
                $pi2++;
            }
            Perla::CodeGen::emit($cg, "StradaValue *__pr = strada_pack(__fmt, __pa); free(__fmt); strada_decref(__pa); __pr; })");
        }
        return;
    }

    if ($name eq "unpack") {
        if ($argc >= 2) {
            # Perl's unpack in scalar context returns only the FIRST
            # element of the result list (not the count). `my $hex =
            # unpack("H*", "AB")` returns "4142", not 1. perla used to
            # collapse to the array's `last element` count (1 here) via
            # the generic scalar-context array → length conversion.
            Perla::CodeGen::emit($cg, "({ char *__fmt = strada_to_str(");
            Perla::CodeGen::gen_expr($cg, $args->[0]);
            Perla::CodeGen::emit($cg, "); StradaValue *__dv = ");
            Perla::CodeGen::gen_expr($cg, $args->[1]);
            Perla::CodeGen::emit($cg, "; StradaValue *__pr = strada_unpack(__fmt, __dv); free(__fmt); ");
            Perla::CodeGen::emit($cg, "if (__perla_want_list != 1 && __pr && !STRADA_IS_TAGGED_INT(__pr) && __pr->type == STRADA_ARRAY) { ");
            Perla::CodeGen::emit($cg, "  StradaArray *__pra = __pr->value.av; ");
            Perla::CodeGen::emit($cg, "  StradaValue *__first = (__pra && __pra->size > 0) ? __pra->elements[__pra->head] : NULL; ");
            Perla::CodeGen::emit($cg, "  if (__first) strada_incref(__first); ");
            Perla::CodeGen::emit($cg, "  strada_decref(__pr); ");
            Perla::CodeGen::emit($cg, "  __pr = __first ? __first : strada_new_undef(); ");
            Perla::CodeGen::emit($cg, "} __pr; })");
        }
        return;
    }

    # printf — sprintf + print. perla previously routed `printf` through
    # perla_code_get("main", "printf") which returns NULL → silent no-op.
    if ($name eq "printf") {
        # printf STDERR / STDOUT "fmt", args — bareword filehandle.
        # Non-stdio barewords (FH, LOG, etc.) look up via package stash.
        if (defined($node->{"fh_bareword"})) {
            my str $fhb = $node->{"fh_bareword"};
            my int $is_stdio = 0;
            my str $stream = "stdout";
            if ($fhb eq "STDOUT") { $is_stdio = 1; }
            elsif ($fhb eq "STDERR") { $stream = "stderr"; $is_stdio = 1; }
            elsif ($fhb eq "STDIN") { $stream = "stdin"; $is_stdio = 1; }
            if ($is_stdio == 1) {
                if ($argc >= 1) {
                    my int $pfn = $argc - 1;
                    Perla::CodeGen::emit($cg, "({ StradaValue *__pfr = strada_sprintf_sv(");
                    Perla::CodeGen::gen_expr($cg, $args->[0]);
                    Perla::CodeGen::emit($cg, ", " . $pfn);
                    my int $pi = 1;
                    while ($pi < $argc) {
                        Perla::CodeGen::emit($cg, ", ");
                        Perla::CodeGen::gen_expr($cg, $args->[$pi]);
                        $pi++;
                    }
                    Perla::CodeGen::emit($cg, "); char *__pfs = strada_to_str(__pfr); fputs(__pfs, " . $stream . "); free(__pfs); strada_decref(__pfr); STRADA_MAKE_TAGGED_INT(1); })");
                } else {
                    Perla::CodeGen::emit($cg, "STRADA_MAKE_TAGGED_INT(1)");
                }
                return;
            }
            # Non-stdio: dispatch tied-FH PRINTF first (mirrors the print
            # path at ~16557). If tied, hand the (fmt, args) tuple to
            # perla_tied_handle_printf which prefers PRINTF, else formats
            # and falls back to PRINT. Otherwise: stash lookup +
            # strada_print_fh with the formatted string.
            if ($argc >= 1) {
                Perla::CodeGen::emit($cg, "({ StradaValue *__pth_bw = perla_tied_handle_for_name(\"" . $cg->{"pkg"} . "\", \"" . $fhb . "\"); ");
                Perla::CodeGen::emit($cg, "__pth_bw ? ({ StradaValue *__pth_args = strada_new_array(); StradaArray *__pth_av = strada_deref_array(__pth_args); ");
                my int $pi3 = 0;
                while ($pi3 < $argc) {
                    Perla::CodeGen::emit($cg, "{ StradaValue *__pth_a = ");
                    Perla::CodeGen::gen_expr($cg, $args->[$pi3]);
                    Perla::CodeGen::emit($cg, "; if (__pth_a) strada_incref(__pth_a); strada_array_push_take(__pth_av, __pth_a); } ");
                    $pi3 = $pi3 + 1;
                }
                Perla::CodeGen::emit($cg, "StradaValue *__pth_r = perla_tied_handle_printf(\"" . $cg->{"pkg"} . "\", \"" . $fhb . "\", __pth_args); strada_decref(__pth_args); __pth_r; }) : ");
                my int $pfn2 = $argc - 1;
                Perla::CodeGen::emit($cg, "({ StradaValue *__pfr = strada_sprintf_sv(");
                Perla::CodeGen::gen_expr($cg, $args->[0]);
                Perla::CodeGen::emit($cg, ", " . $pfn2);
                my int $pi2 = 1;
                while ($pi2 < $argc) {
                    Perla::CodeGen::emit($cg, ", ");
                    Perla::CodeGen::gen_expr($cg, $args->[$pi2]);
                    $pi2++;
                }
                Perla::CodeGen::emit($cg, "); StradaValue *__pfh = perla_scalar_get(\"" . $cg->{"pkg"} . "\", \"" . $fhb . "\"); strada_print_fh(__pfr, __pfh); strada_decref(__pfr); STRADA_MAKE_TAGGED_INT(1); }); })");
            } else {
                Perla::CodeGen::emit($cg, "STRADA_MAKE_TAGGED_INT(1)");
            }
            return;
        }
        # printf $fh "fmt", args — scalar var filehandle.
        if (defined($node->{"fh"})) {
            if ($argc >= 1) {
                my int $pfn = $argc - 1;
                Perla::CodeGen::emit($cg, "({ StradaValue *__pfr = strada_sprintf_sv(");
                Perla::CodeGen::gen_expr($cg, $args->[0]);
                Perla::CodeGen::emit($cg, ", " . $pfn);
                my int $pi = 1;
                while ($pi < $argc) {
                    Perla::CodeGen::emit($cg, ", ");
                    Perla::CodeGen::gen_expr($cg, $args->[$pi]);
                    $pi++;
                }
                Perla::CodeGen::emit($cg, "); strada_print_fh(__pfr, ");
                Perla::CodeGen::gen_expr($cg, $node->{"fh"});
                Perla::CodeGen::emit($cg, "); strada_decref(__pfr); STRADA_MAKE_TAGGED_INT(1); })");
            } else {
                Perla::CodeGen::emit($cg, "STRADA_MAKE_TAGGED_INT(1)");
            }
            return;
        }
        if ($argc >= 1) {
            my int $pf_nargs = $argc - 1;
            Perla::CodeGen::emit($cg, "({ StradaValue *__pfr = strada_sprintf_sv(");
            Perla::CodeGen::gen_expr($cg, $args->[0]);
            Perla::CodeGen::emit($cg, ", " . $pf_nargs);
            my int $pfi = 1;
            while ($pfi < $argc) {
                Perla::CodeGen::emit($cg, ", ");
                Perla::CodeGen::gen_expr($cg, $args->[$pfi]);
                $pfi++;
            }
            Perla::CodeGen::emit($cg, "); strada_print(__pfr); strada_decref(__pfr); STRADA_MAKE_TAGGED_INT(1); })");
        } else {
            Perla::CodeGen::emit($cg, "STRADA_MAKE_TAGGED_INT(1)");
        }
        return;
    }

    # chop — removes last char, returns it
    if ($name eq "chop") {
        # No-args form defaults to chop $_. Without this, `chop` was a
        # no-op when used in a `for ($var) { chop }` loop. Mirror chomp.
        if ($argc == 0) {
            Perla::CodeGen::emit($cg, "({ char *__s = strada_to_str(perla_dollar_underscore ? perla_dollar_underscore : strada_new_str(\"\")); ");
            Perla::CodeGen::emit($cg, "char *__c = strada_chop(__s); ");
            Perla::CodeGen::emit($cg, "StradaValue *__nv = strada_new_str_charflag(__c, __s); ");
            Perla::CodeGen::emit($cg, "if (perla_dollar_underscore) strada_decref(perla_dollar_underscore); perla_dollar_underscore = __nv; strada_incref(__nv); ");
            Perla::CodeGen::emit($cg, "StradaValue *__r = strada_new_str_charflag(__s + strlen(__c), __s); free(__s); free(__c); __r; })");
            return;
        }
        if ($argc > 0) {
            my scalar $chop_arg = $args->[0];
            my int $chop_argt = $chop_arg->{"type"};
            # `chop @arr` / `chop %hash` — chop each element in place
            # and return the last char chopped. Walk the underlying
            # StradaArray/StradaHash and chop each str entry, replacing
            # with the chopped string.
            if ($chop_argt == Perla::AST::N_ARRAY_VAR()) {
                my str $aname = $chop_arg->{"name"};
                my str $av_c = ($aname eq "_") ? "perla_at_" : Perla::CodeGen::c_var_a($aname);
                Perla::CodeGen::emit($cg, "({ StradaArray *__cha = strada_deref_array(" . $av_c . "); ");
                Perla::CodeGen::emit($cg, "StradaValue *__chr = strada_new_str(\"\"); ");
                Perla::CodeGen::emit($cg, "if (__cha) { for (size_t __chi = 0; __chi < __cha->size; __chi++) { ");
                Perla::CodeGen::emit($cg, "  StradaValue *__che = __cha->elements[__cha->head + __chi]; ");
                Perla::CodeGen::emit($cg, "  char *__chs = strada_to_str(__che); char *__chc = strada_chop(__chs); ");
                Perla::CodeGen::emit($cg, "  StradaValue *__chn = strada_new_str_charflag(__chc, __chs); ");
                Perla::CodeGen::emit($cg, "  strada_decref(__che); __cha->elements[__cha->head + __chi] = __chn; ");
                Perla::CodeGen::emit($cg, "  strada_decref(__chr); __chr = strada_new_str_charflag(__chs + strlen(__chc), __chs); ");
                Perla::CodeGen::emit($cg, "  free(__chs); free(__chc); ");
                Perla::CodeGen::emit($cg, "} } __chr; })");
                return;
            }
            # When the arg is a non-lvalue target (array elem, hash elem,
            # deref, etc.), the old `<expr> = strada_new_str(...)` pattern
            # produces an invalid C lvalue. Route the writeback through
            # `_emit_subst_writeback` for those cases.
            if ($chop_argt == Perla::AST::N_ARRAY_ELEM()
                || $chop_argt == Perla::AST::N_ARROW_ARRAY()
                || $chop_argt == Perla::AST::N_HASH_ELEM()
                || $chop_argt == Perla::AST::N_ARROW_HASH()
                || $chop_argt == Perla::AST::N_DEREF_SCALAR()) {
                Perla::CodeGen::emit($cg, "({ char *__s = strada_to_str(");
                Perla::CodeGen::gen_expr($cg, $chop_arg);
                Perla::CodeGen::emit($cg, "); char *__c = strada_chop(__s); StradaValue *__nv = strada_new_str_charflag(__c, __s); ");
                Perla::CodeGen::Subst::emit_subst_writeback($cg, $chop_arg, "__nv");
                Perla::CodeGen::emit($cg, " StradaValue *__r = strada_new_str_charflag(__s + strlen(__c), __s); free(__s); free(__c); __r; })");
            } else {
                Perla::CodeGen::emit($cg, "({ char *__s = strada_to_str(");
                Perla::CodeGen::gen_expr($cg, $chop_arg);
                Perla::CodeGen::emit($cg, "); char *__c = strada_chop(__s); ");
                Perla::CodeGen::gen_expr($cg, $chop_arg);
                Perla::CodeGen::emit($cg, " = strada_new_str_charflag(__c, __s); StradaValue *__r = strada_new_str_charflag(__s + strlen(__c), __s); free(__s); free(__c); __r; })");
            }
        }
        return;
    }

    # chr/ord
    if ($name eq "chr") {
        # Route through `strada_chr_sv` which UTF-8-encodes codepoints
        # >= 256 (Perl semantics). The previous inline path truncated
        # `(char)0x100` to 0x00 → `chr(0x100)` produced "\x00" instead
        # of the 2-byte UTF-8 sequence "\xc4\x80". `strada_chr_sv` also
        # handles `chr(0)` (returns a 1-byte NUL string, not "").
        # No-args form defaults to $_ — common idiom in
        # `map { chr } @ords`. Without this, perla called with 0
        # and got a space/null for every entry.
        Perla::CodeGen::emit($cg, "strada_chr_sv((int)strada_to_num(");
        if ($argc > 0) { Perla::CodeGen::gen_expr($cg, $args->[0]); }
        else { Perla::CodeGen::emit($cg, "perla_dollar_underscore"); }
        Perla::CodeGen::emit($cg, "))");
        return;
    }
    if ($name eq "ord") {
        # `ord` with no args defaults to $_ — common idiom in
        # `map { ord } split //, $str`. Without this, perla called
        # ord with NULL and got 0 for every char.
        #
        # Use `strada_ord` (UTF-8 aware) rather than reading a raw byte.
        # `ord(chr(0x100))` should round-trip to 256, but reading
        # `__s[0]` only sees the multi-byte leader byte (0xc4) for the
        # 2-byte UTF-8 sequence.
        # Scalar context on arg.
        Perla::CodeGen::emit($cg, "({ int __sav_wl_ord = __perla_want_list; __perla_want_list = 0; char *__s = strada_to_str(");
        if ($argc > 0) {
            Perla::CodeGen::gen_expr($cg, $args->[0]);
        } else {
            Perla::CodeGen::emit($cg, "(perla_dollar_underscore ? perla_dollar_underscore : strada_new_str(\"\"))");
        }
        Perla::CodeGen::emit($cg, "); __perla_want_list = __sav_wl_ord; StradaValue *__r = STRADA_MAKE_TAGGED_INT((int64_t)strada_ord(__s)); free(__s); __r; })");
        return;
    }

    # sprintf
    if ($name eq "sprintf") {
        # Simple: just do string concat for now
        Perla::CodeGen::emit($cg, "strada_new_str(\"TODO_sprintf\")");
        return;
    }

    # scalar
    if ($name eq "scalar") {
        if ($argc > 0) {
            # `scalar EXPR` enforces scalar context. Result depends on the
            # expression's type:
            #   - array (@arr)       → length
            #   - hash (%hash)       → "K/N" stat string (Perl); we return N
            #   - anything else      → the value itself (scalar pass-through)
            # Old behavior always returned strada_array_length, so
            # `scalar test()` where test returns a SCALAR or ARRAY-REF
            # got the count of an empty/wrong array. DBIC's
            # `scalar $self->_resolve_condition(...)` was returning
            # `count` instead of the function's `\@res` arrayref, so
            # the JOIN clause emitted `ON 0` instead of the real
            # condition.
            #
            # Set `__perla_want_list = 0` around the inner expression so
            # the callee picks its scalar-return branch.
            #
            # `scalar (a, b, c)` — when the parser splits the
            # parenthesized list into N args, treat it as Perl's
            # comma-operator-in-scalar-context: evaluate all and
            # return the last. Discard earlier args (run them for
            # side effects, drop their values).
            if ($argc > 1) {
                Perla::CodeGen::emit($cg, "({ ");
                my int $sxi = 0;
                while ($sxi < $argc - 1) {
                    Perla::CodeGen::emit($cg, "({ StradaValue *__sx = ");
                    Perla::CodeGen::gen_expr($cg, $args->[$sxi]);
                    Perla::CodeGen::emit($cg, "; if (__sx) strada_decref(__sx); }); ");
                    $sxi++;
                }
                Perla::CodeGen::gen_expr($cg, $args->[$argc - 1]);
                Perla::CodeGen::emit($cg, "; })");
                return;
            }
            my scalar $arg = $args->[0];
            my int $at = $arg->{"type"};
            if ($at == Perla::AST::N_ARRAY_VAR() || $at == Perla::AST::N_DEREF_ARRAY()) {
                # Static: definitely an array — length. Force list context
                # on the inner deref so N_DEREF_ARRAY's scalar short-circuit
                # (added in bdbf367d) doesn't reduce the deref to an int
                # before we can ask for the length.
                # Tied-aware: dispatch FETCHSIZE if the SV is tied.
                Perla::CodeGen::emit($cg, "({ int __sav_wl_sc = __perla_want_list; __perla_want_list = 1; ");
                Perla::CodeGen::emit($cg, "StradaValue *__sca = ");
                Perla::CodeGen::gen_expr($cg, $arg);
                Perla::CodeGen::emit($cg, "; __perla_want_list = __sav_wl_sc; ");
                Perla::CodeGen::emit($cg, "int64_t __scl = strada_av_fetchsize_sv(__sca); ");
                Perla::CodeGen::emit($cg, "STRADA_MAKE_TAGGED_INT(__scl); })");
