    if ($name eq "defined") {
        # Perl: `defined &SUB` checks whether SUB is defined in the
        # package stash WITHOUT calling it. The parser turns `&SUB` into
        # an N_CALL with pass_caller_args=1 which would otherwise call
        # the sub and check the return value. Detect the pattern and
        # route to a stash lookup instead. Required for Class::Load and
        # similar `defined &Pkg::method` checks.
        if ($argc > 0) {
            my scalar $arg0 = $args->[0];
            if (defined($arg0) && $arg0->{"type"} == Perla::AST::N_CALL()
                && defined($arg0->{"pass_caller_args"}) && $arg0->{"pass_caller_args"} == 1
                && defined($arg0->{"name"}) && length($arg0->{"name"}) > 0
                && $arg0->{"name"} ne "__coderef__") {
                my str $sn = $arg0->{"name"};
                my int $sep = -1;
                my int $si = length($sn) - 1;
                while ($si > 0) {
                    if (substr($sn, $si - 1, 2) eq "::") { $sep = $si - 1; last; }
                    $si--;
                }
                my str $spkg = ($sep >= 0) ? substr($sn, 0, $sep) : $cg->{"pkg"};
                my str $sshort = ($sep >= 0) ? substr($sn, $sep + 2, length($sn) - $sep - 2) : $sn;
                Perla::CodeGen::emit($cg, "(perla_code_get(\"" . $spkg . "\", \"" . $sshort . "\") ? STRADA_MAKE_TAGGED_INT(1) : strada_new_str(\"\"))");
                return;
            }
            # `defined &{EXPR}` — dynamic sub-by-name lookup. Parser
            # wraps as N_CALL with name="__coderef__" and coderef =
            # N_GLOB_ACCESS{is_code_deref=1, expr=EXPR}. Evaluate the
            # expr to a string at runtime, split on `::`, look up.
            # Also matches `defined &$var` where coderef is N_SCALAR_VAR
            # holding a name string — Memoize and similar introspect
            # via this pattern. Without this branch, the call falls
            # through to the default codegen which actually CALLS the
            # sub and checks its return — recursive subs that return
            # undef on entry then look "undefined" via this path.
            # Only the AMPERSAND introspection form — `defined &$f` / `defined
            # &{$ref}` (no parens) — is a stash lookup. The parser marks those
            # with pass_caller_args=1. A real coderef CALL — `$f->($x)` (arrow)
            # or `&$f($x)` (parens) — has no pass_caller_args and must be
            # EVALUATED then checked for definedness. Without this guard,
            # `defined($f->($x))` was compiled as `defined &$f`: it stringified
            # the closure and did perla_code_get on the (garbage) name, so it
            # never called $f and reported undef — broke Data::OptList's
            # `defined($_->($value))` (Sub::Exporter → Moose::Util load).
            if (defined($arg0) && $arg0->{"type"} == Perla::AST::N_CALL()
                && defined($arg0->{"name"}) && $arg0->{"name"} eq "__coderef__"
                && defined($arg0->{"coderef"})
                && defined($arg0->{"pass_caller_args"}) && $arg0->{"pass_caller_args"} == 1) {
                my scalar $cref = $arg0->{"coderef"};
                my int $is_stringy = 0;
                my scalar $name_expr = undef;
                if (defined($cref->{"type"}) && $cref->{"type"} == Perla::AST::N_GLOB_ACCESS()
                    && defined($cref->{"is_code_deref"}) && $cref->{"is_code_deref"} == 1
                    && defined($cref->{"expr"})) {
                    $is_stringy = 1;
                    $name_expr = $cref->{"expr"};
                } elsif (defined($cref->{"type"}) && $cref->{"type"} == Perla::AST::N_SCALAR_VAR()) {
                    $is_stringy = 1;
                    $name_expr = $cref;
                }
                if ($is_stringy == 1) {
                    Perla::CodeGen::emit($cg, "({ StradaValue *__dv = ");
                    Perla::CodeGen::gen_expr($cg, $name_expr);
                    Perla::CodeGen::emit($cg, "; StradaValue *__dr; ");
                    # A real CODE ref (`\\&sub`, `\\&{name}`, or a coderef held
                    # in $var) is itself a defined sub — `defined &$f` must be
                    # true without stringifying it to "CODE(0x..)" and failing
                    # the by-name stash lookup. Only a STRING operand (`&{"P::n"}`
                    # / a $var holding a name) is a by-name probe. This fixes
                    # Moose::Exporter::_sub_from_package (`\\&{P::n}; defined &$sub`)
                    # which mis-reported every TypeConstraints sugar sub (type,
                    # subtype, as, where, coerce, ...) as undefined.
                    # A reference to a COMPILED named sub is a STRADA_CPOINTER
                    # (raw C function pointer); a reference to an anon/closure
                    # sub is a STRADA_CLOSURE — either, bare or wrapped in a
                    # (possibly slot-) REF, means a defined code ref.
                    Perla::CodeGen::emit($cg, "int __discode = 0; if (__dv && !STRADA_IS_TAGGED_INT(__dv)) { if (__dv->type == STRADA_CLOSURE || __dv->type == STRADA_CPOINTER) __discode = 1; else if (__dv->type == STRADA_REF) { StradaValue *__drr = strada_is_slot_ref(__dv) ? (((StradaValue**)__dv->value.ptr) ? *((StradaValue**)__dv->value.ptr) : (StradaValue*)NULL) : __dv->value.rv; if (__drr && !STRADA_IS_TAGGED_INT(__drr) && (__drr->type == STRADA_CLOSURE || __drr->type == STRADA_CPOINTER)) __discode = 1; } } ");
                    Perla::CodeGen::emit($cg, "if (__discode) { __dr = STRADA_MAKE_TAGGED_INT(1); } ");
                    Perla::CodeGen::emit($cg, "else { char *__dn = strada_to_str(__dv); if (!__dn || !__dn[0]) { __dr = strada_new_str(\"\"); } ");
                    Perla::CodeGen::emit($cg, "else { const char *__dsep = NULL; for (const char *__dp = __dn; *__dp; __dp++) { if (__dp[0]==':' && __dp[1]==':') __dsep = __dp; } ");
                    Perla::CodeGen::emit($cg, "  StradaValue *__dfn; ");
                    Perla::CodeGen::emit($cg, "  if (__dsep) { size_t __dpl = (size_t)(__dsep - __dn); char __dpkg[256]; if (__dpl >= sizeof(__dpkg)) __dpl = sizeof(__dpkg)-1; memcpy(__dpkg, __dn, __dpl); __dpkg[__dpl] = 0; __dfn = perla_code_get(__dpkg, __dsep + 2); } ");
                    Perla::CodeGen::emit($cg, "  else { __dfn = perla_code_get(\"" . $cg->{"pkg"} . "\", __dn); if (!__dfn) __dfn = perla_code_get(\"main\", __dn); } ");
                    Perla::CodeGen::emit($cg, "  __dr = __dfn ? STRADA_MAKE_TAGGED_INT(1) : strada_new_str(\"\"); } ");
                    Perla::CodeGen::emit($cg, "free(__dn); } __dr; })");
                    return;
                }
            }
        }
        # Perl: defined returns 1 for true, "" (empty string) for false.
        # defined() imposes scalar context on its arg — `defined sub()`
        # where sub does `return;` must give 0 (undef in scalar) even
        # when the surrounding expression is list context (e.g. inside
        # print args). Without saving/restoring __perla_want_list,
        # sub() ran in list context and returned strada_new_array()
        # (empty array) → strada_defined_bool(array) returned true.
        Perla::CodeGen::emit($cg, "({ int __sav_wl_def = __perla_want_list; __perla_want_list = 0; ");
        Perla::CodeGen::emit($cg, "StradaValue *__def_v = ");
        if ($argc > 0) { Perla::CodeGen::gen_expr($cg, $args->[0]); }
        else { Perla::CodeGen::emit($cg, "perla_dollar_underscore ? perla_dollar_underscore : strada_new_undef()"); }
        Perla::CodeGen::emit($cg, "; __perla_want_list = __sav_wl_def; ");
        Perla::CodeGen::emit($cg, "strada_defined_bool(__def_v) ? STRADA_MAKE_TAGGED_INT(1) : strada_new_str(\"\"); })");
        return;
    }

    # ref — returns Perl-compatible type string. ref imposes scalar
    # context on its arg; without `__perla_want_list = 0` save+restore,
    # `ref(returns_undef())` in print args ran in list context and got
    # an empty STRADA_ARRAY → reported "ARRAY" instead of "".
    if ($name eq "ref") {
        Perla::CodeGen::emit($cg, "({ int __sav_wl_ref = __perla_want_list; __perla_want_list = 0; ");
        Perla::CodeGen::emit($cg, "StradaValue *__rv = ");
        if ($argc > 0) { Perla::CodeGen::gen_expr($cg, $args->[0]); }
        else { Perla::CodeGen::emit($cg, "perla_dollar_underscore"); }
        Perla::CodeGen::emit($cg, "; __perla_want_list = __sav_wl_ref; const char *__rt = \"\"; ");
        Perla::CodeGen::emit($cg, "if (!__rv || STRADA_IS_TAGGED_INT(__rv)) __rt = \"\"; ");
        Perla::CodeGen::emit($cg, "else if (__rv->type == STRADA_REF && __rv->value.rv) { ");
        # For slot refs (perla's `\\$var` flavor that points at the C var
        # slot), follow the slot to read the actual referent. Without
        # this, ref() saw the slot address cast to StradaValue* and
        # always reported "SCALAR" — `ref(\\$arrayref)` returned SCALAR
        # instead of Perl's "REF".
        Perla::CodeGen::emit($cg, "  StradaValue *__rr; ");
        Perla::CodeGen::emit($cg, "  if (strada_is_slot_ref(__rv)) { StradaValue **__rs = (StradaValue**)__rv->value.ptr; __rr = __rs ? *__rs : NULL; } ");
        Perla::CodeGen::emit($cg, "  else { __rr = __rv->value.rv; } ");
        Perla::CodeGen::emit($cg, "  const char *__bp = (__rv->meta && __rv->meta->blessed_package) ? __rv->meta->blessed_package : NULL; ");
        Perla::CodeGen::emit($cg, "  if (__bp) __rt = __bp; ");
        Perla::CodeGen::emit($cg, "  else if (!__rr) __rt = \"SCALAR\"; ");
        Perla::CodeGen::emit($cg, "  else if (STRADA_IS_TAGGED_INT(__rr) || __rr->type == STRADA_INT || __rr->type == STRADA_NUM || __rr->type == STRADA_STR || __rr->type == STRADA_UNDEF) __rt = \"SCALAR\"; ");
        Perla::CodeGen::emit($cg, "  else if (__rr->type == STRADA_HASH) __rt = \"HASH\"; ");
        Perla::CodeGen::emit($cg, "  else if (__rr->type == STRADA_ARRAY) __rt = \"ARRAY\"; ");
        Perla::CodeGen::emit($cg, "  else if (__rr->type == STRADA_CLOSURE) __rt = \"CODE\"; ");
        Perla::CodeGen::emit($cg, "  else if (__rr->type == STRADA_REF) __rt = \"REF\"; ");
        Perla::CodeGen::emit($cg, "  else __rt = \"SCALAR\"; } ");
        Perla::CodeGen::emit($cg, "else if (__rv->type == STRADA_HASH) { ");
        Perla::CodeGen::emit($cg, "  const char *__bp = (__rv->meta && __rv->meta->blessed_package) ? __rv->meta->blessed_package : NULL; ");
        Perla::CodeGen::emit($cg, "  __rt = __bp ? __bp : \"HASH\"; } ");
        Perla::CodeGen::emit($cg, "else if (__rv->type == STRADA_ARRAY) { ");
        Perla::CodeGen::emit($cg, "  const char *__bp = (__rv->meta && __rv->meta->blessed_package) ? __rv->meta->blessed_package : NULL; ");
        Perla::CodeGen::emit($cg, "  __rt = __bp ? __bp : \"ARRAY\"; } ");
        Perla::CodeGen::emit($cg, "else if (__rv->type == STRADA_CLOSURE || __rv->type == STRADA_CPOINTER) { ");
        Perla::CodeGen::emit($cg, "  const char *__bp = (__rv->meta && __rv->meta->blessed_package) ? __rv->meta->blessed_package : NULL; ");
        Perla::CodeGen::emit($cg, "  __rt = __bp ? __bp : \"CODE\"; } ");
        # Non-ref types (STRADA_STR/INT/NUM) can carry blessed_package
        # too — used by qr// to mark its returned string as 'Regexp' so
        # `ref(qr/.../) eq "Regexp"` matches Perl's behavior. DBIC's
        # _Util::sigwarn_silencer relies on that check.
        Perla::CodeGen::emit($cg, "else if (__rv->meta && __rv->meta->blessed_package) __rt = __rv->meta->blessed_package; ");
        Perla::CodeGen::emit($cg, "else __rt = \"\"; ");
        Perla::CodeGen::emit($cg, "strada_new_str(__rt); })");
        return;
    }

    # shift
    if ($name eq "shift") {
        if ($argc > 0) {
            # Tied-aware: dispatch SHIFT on tied SV, else raw shift.
            # Force list-context around the arg so a DEREF_ARRAY in
            # scalar context isn't collapsed to its length.
            Perla::CodeGen::emit($cg, "({ int __sav_wl_sh = __perla_want_list; __perla_want_list = 1; StradaValue *__sh_sv = ");
            Perla::CodeGen::gen_expr($cg, $args->[0]);
            Perla::CodeGen::emit($cg, "; __perla_want_list = __sav_wl_sh; (__sh_sv && !STRADA_IS_TAGGED_INT(__sh_sv) && __sh_sv->meta && __sh_sv->meta->is_tied) ? strada_tied_array_shift(__sh_sv) : strada_array_shift(strada_deref_array(__sh_sv)); })");
        } else {
            # Bare shift = shift(@_) — @_ is never tied; raw call.
            Perla::CodeGen::emit($cg, "strada_array_shift(strada_deref_array(perla_at_))");
        }
        return;
    }

    # pop
    if ($name eq "pop") {
        if ($argc > 0) {
            # Tied-aware: dispatch POP on tied SV, else raw pop.
            # Force list-context (see shift).
            Perla::CodeGen::emit($cg, "({ int __sav_wl_po = __perla_want_list; __perla_want_list = 1; StradaValue *__po_sv = ");
            Perla::CodeGen::gen_expr($cg, $args->[0]);
            Perla::CodeGen::emit($cg, "; __perla_want_list = __sav_wl_po; (__po_sv && !STRADA_IS_TAGGED_INT(__po_sv) && __po_sv->meta && __po_sv->meta->is_tied) ? strada_tied_array_pop(__po_sv) : strada_array_pop(strada_deref_array(__po_sv)); })");
        } else {
            Perla::CodeGen::emit($cg, "strada_array_pop(strada_deref_array(perla_at_))");
        }
        return;
    }

    # push
    if ($name eq "push") {
        # Fast path: `push @arr, simple_val_1, ..., simple_val_N` where
        # every value-arg is a scalar (no array/hash flattening) and the
        # destination is a non-tied lexical array. Skip the __tp_args
        # wrapper array — emit one strada_array_push_take per arg
        # directly into the destination array. Tied-dispatch still
        # handled via a runtime meta check; the fast path applies only
        # when the meta indicates no tie.
        #
        # Win: bench_data's tight `push(@arr, $i*$i)` loop is the
        # canonical case — 50k iterations × (alloc args array + free)
        # collapses to 50k direct pushes.
        if ($argc >= 2 && defined($args->[0])
            && $args->[0]->{"type"} == Perla::AST::N_ARRAY_VAR()
            && defined($args->[0]->{"name"})
            && index($args->[0]->{"name"}, "::") < 0
            && $args->[0]->{"name"} ne "_") {
            my str $__tp_name = $args->[0]->{"name"};
            my str $__tp_cvar = Perla::CodeGen::c_var_a($__tp_name);
            # Detect "all simple value args" — every arg is something
            # that produces a single scalar (no array flatten, no
            # range, no anon-list, no call returning a list).
            my int $all_simple = 1;
            my int $__tspi = 1;
            while ($__tspi < $argc) {
                my int $tt = $args->[$__tspi]->{"type"};
                if ($tt == Perla::AST::N_ARRAY_VAR()
                    || $tt == Perla::AST::N_DEREF_ARRAY()
                    || $tt == Perla::AST::N_RANGE()
                    || $tt == Perla::AST::N_CALL()
                    || $tt == Perla::AST::N_METHOD()
                    || $tt == Perla::AST::N_ANON_ARRAY()
                    || $tt == Perla::AST::N_HASH_VAR()
                    || $tt == Perla::AST::N_DEREF_HASH()
                    || $tt == Perla::AST::N_ARRAY_SLICE()
                    || $tt == Perla::AST::N_HASH_SLICE()
                    || $tt == Perla::AST::N_MAP()
                    || $tt == Perla::AST::N_GREP()
                    || $tt == Perla::AST::N_SORT()) {
                    $all_simple = 0;
                    last;
                }
                $__tspi = $__tspi + 1;
            }
            if ($all_simple == 1) {
                # Inline N pushes: one stmt-expr that ends in the new
                # length. Tied-check at top; if untied (the hot case),
                # push each arg directly into the dest array.
                #
                # Evaluate arg expressions ONCE up front into __tp_v_N
                # locals — calling gen_expr twice on the same node
                # (once for the tied branch, once for the untied) is
                # only correct for pure expressions; anon-sub-as-expr
                # mutates the node (assigns a synthesized name) and
                # the second call falls into a fallback emit. Compute
                # once, dispatch by tied flag.
                Perla::CodeGen::emit($cg, "({ StradaValue *__tp_sv = " . $__tp_cvar . "; ");
                my int $sp_i = 1;
                while ($sp_i < $argc) {
                    Perla::CodeGen::emit($cg, "StradaValue *__tp_v_" . $sp_i . " = ");
                    Perla::CodeGen::gen_expr($cg, $args->[$sp_i]);
                    Perla::CodeGen::emit($cg, "; ");
                    $sp_i = $sp_i + 1;
                }
                Perla::CodeGen::emit($cg, "int64_t __tp_n; ");
                Perla::CodeGen::emit($cg, "if (__builtin_expect(__tp_sv && !STRADA_IS_TAGGED_INT(__tp_sv) && __tp_sv->meta && __tp_sv->meta->is_tied, 0)) { ");
                # Slow tied path — build args array, dispatch PUSH.
                Perla::CodeGen::emit($cg, "  StradaValue *__tp_args = strada_new_array(); StradaArray *__tp_av = strada_deref_array(__tp_args); ");
                $sp_i = 1;
                while ($sp_i < $argc) {
                    Perla::CodeGen::emit($cg, "  if (__tp_v_" . $sp_i . ") strada_incref(__tp_v_" . $sp_i . "); strada_array_push_take(__tp_av, __tp_v_" . $sp_i . "); ");
                    $sp_i = $sp_i + 1;
                }
                Perla::CodeGen::emit($cg, "  __tp_n = strada_tied_array_push(__tp_sv, __tp_args); ");
                Perla::CodeGen::emit($cg, "  strada_decref(__tp_args); ");
                Perla::CodeGen::emit($cg, "} else { ");
                # Fast path — direct push into the deref'd array.
                Perla::CodeGen::emit($cg, "  StradaArray *__tp_dav = strada_deref_array(__tp_sv); ");
                $sp_i = 1;
                while ($sp_i < $argc) {
                    Perla::CodeGen::emit($cg, "  if (__tp_v_" . $sp_i . ") strada_incref(__tp_v_" . $sp_i . "); strada_array_push_take(__tp_dav, __tp_v_" . $sp_i . "); ");
                    $sp_i = $sp_i + 1;
                }
                Perla::CodeGen::emit($cg, "  __tp_n = (int64_t)strada_array_length(__tp_dav); ");
                Perla::CodeGen::emit($cg, "} ");
                # Release the locals: owned expressions need decref to
                # balance gen_expr's +1; borrowed exprs are referenced
                # only via __tp_v_N here and need decref to balance the
                # push's incref. Either way: decref every __tp_v_N once.
                # (For borrowed exprs whose gen_expr didn't incref, the
                # push's incref + this decref are a wash.)
                $sp_i = 1;
                while ($sp_i < $argc) {
                    # Only decref owned exprs — borrowed exprs would underflow.
                    if (Perla::CodeGen::expr_is_borrowed($args->[$sp_i]) == 0) {
                        Perla::CodeGen::emit($cg, "if (__tp_v_" . $sp_i . ") strada_decref(__tp_v_" . $sp_i . "); ");
                    }
                    $sp_i = $sp_i + 1;
                }
                Perla::CodeGen::emit($cg, "STRADA_MAKE_TAGGED_INT(__tp_n); })");
                return;
            }
            # Statement-expression that ends in a tagged-int (the result
            # length). Build args array once; if tied, dispatch PUSH;
            # else push each element into the raw StradaArray.
            Perla::CodeGen::emit($cg, "({ StradaValue *__tp_sv = " . $__tp_cvar . "; ");
            Perla::CodeGen::emit($cg, "StradaValue *__tp_args = strada_new_array(); StradaArray *__tp_av = strada_deref_array(__tp_args); ");
            my int $__tpi = 1;
            while ($__tpi < $argc) {
                my scalar $__tp_arg = $args->[$__tpi];
                my int $__tp_at = $__tp_arg->{"type"};
                # `push @arr, (L1, L2, ...)` — the parens parse to a
                # non-ref N_ANON_ARRAY; perl semantics flatten it as
                # `push @arr, L1, L2, …`. Without this, the general path
                # gen_expr'd the ANON_ARRAY in (effectively scalar) push-arg
                # context and pushed its last element (or worse, an empty
                # placeholder when want_list was -1). Now we walk the elems
                # in-place and push each as its own item.
                if ($__tp_at == Perla::AST::N_ANON_ARRAY()
                    && (!defined($__tp_arg->{"is_ref"}) || $__tp_arg->{"is_ref"} == 0)
                    && defined($__tp_arg->{"elems"})) {
                    my scalar $__tp_elems = $__tp_arg->{"elems"};
                    my int $__tp_ne = scalar(@{$__tp_elems});
                    my int $__tp_ei = 0;
                    while ($__tp_ei < $__tp_ne) {
                        my scalar $__tp_el = $__tp_elems->[$__tp_ei];
                        my int $__tp_el_t = $__tp_el->{"type"};
                        # Inner element may itself need list-context for
                        # array/range/call expansion.
                        my int $__tp_el_is_call = ($__tp_el_t == Perla::AST::N_CALL()
                                                  || $__tp_el_t == Perla::AST::N_METHOD()) ? 1 : 0;
                        if ($__tp_el_t == Perla::AST::N_ARRAY_VAR()
                            || $__tp_el_t == Perla::AST::N_DEREF_ARRAY()
                            || $__tp_el_t == Perla::AST::N_RANGE()
                            || $__tp_el_is_call == 1) {
                            my int $__tp_el_owned = ($__tp_el_t == Perla::AST::N_RANGE()
                                                    || $__tp_el_is_call == 1) ? 1 : 0;
                            if ($__tp_el_is_call == 1) {
                                Perla::CodeGen::emit($cg, "{ int __tp_sav_wl = __perla_want_list; __perla_want_list = 1; StradaValue *__tp_v = ");
                                Perla::CodeGen::gen_expr($cg, $__tp_el);
                                Perla::CodeGen::emit($cg, "; __perla_want_list = __tp_sav_wl; ");
                            } else {
                                Perla::CodeGen::emit($cg, "{ StradaValue *__tp_v = ");
                                Perla::CodeGen::gen_expr($cg, $__tp_el);
                                Perla::CodeGen::emit($cg, "; ");
                            }
                            Perla::CodeGen::emit($cg, "if (__tp_v && !STRADA_IS_TAGGED_INT(__tp_v) && __tp_v->type == STRADA_ARRAY) { StradaArray *__tp_va = strada_deref_array(__tp_v); for (size_t __tpfi = 0; __tpfi < __tp_va->size; __tpfi++) { StradaValue *__tpe = __tp_va->elements[__tp_va->head + __tpfi]; if (__tpe) strada_incref(__tpe); strada_array_push_take(__tp_av, __tpe); } } else if (__tp_v) { strada_incref(__tp_v); strada_array_push_take(__tp_av, __tp_v); } ");
                            if ($__tp_el_owned == 1) {
                                Perla::CodeGen::emit($cg, "if (__tp_v) strada_decref(__tp_v); ");
                            }
                            Perla::CodeGen::emit($cg, "} ");
                        } else {
                            Perla::CodeGen::emit($cg, "{ StradaValue *__tp_v = ");
                            Perla::CodeGen::gen_expr($cg, $__tp_el);
                            Perla::CodeGen::emit($cg, "; if (__tp_v) strada_incref(__tp_v); strada_array_push_take(__tp_av, __tp_v); } ");
                        }
                        $__tp_ei = $__tp_ei + 1;
                    }
                    $__tpi = $__tpi + 1;
                    next;
                }
                # Force list context around sub/method calls so their
                # `return (a, b, c)` produces an array. Without this,
                # `push @arr, sub_returning_list()` saw the call in
                # whatever the outer context was (often scalar) and
                # the call returned just its last element.
                my int $__tp_is_call = ($__tp_at == Perla::AST::N_CALL()
                                       || $__tp_at == Perla::AST::N_METHOD()) ? 1 : 0;
                if ($__tp_at == Perla::AST::N_ARRAY_VAR()
                    || $__tp_at == Perla::AST::N_DEREF_ARRAY()
                    || $__tp_at == Perla::AST::N_RANGE()
                    || $__tp_is_call == 1) {
                    # ARRAY_VAR and DEREF_ARRAY produce borrowed pointers
                    # — the source still owns them. Decreffing __tp_v at
                    # loop end frees the source's container. RANGE and
                    # CALL produce owned values, must decref.
