            Perla::CodeGen::emit($cg, "__perla_want_list = __sav_wl_rv; perla_reverse_ctx(__ra); })");
        }
        return;
    }

    # bless
    if ($name eq "bless") {
        # Optimize: if class name is a string literal, use strdup directly
        my int $class_is_lit = 0;
        my str $class_lit = "";
        if ($argc > 1) {
            my scalar $carg = $args->[1];
            if (defined($carg) && $carg->{"type"} == Perla::AST::N_STR_LIT()) {
                $class_is_lit = 1;
                $class_lit = Perla::CodeGen::Escape::escape_c_str($carg->{"value"});
