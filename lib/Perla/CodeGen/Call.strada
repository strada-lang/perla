            # the command, not a filename. Dispatch to popen via
            # strada_popen so `open(my \$fh, "-|", "echo hi")` works.
            # Multi-arg form `open(my \$fh, "-|", "echo", "hi", "world")` —
            # Perl's exec-list semantics, no shell. We approximate by
            # concatenating arg2..argN with spaces and going through popen
            # anyway. Good enough for the common case (echo, basic argv)
            # but a true exec-list (fork+execvp) would be more correct for
            # args containing shell metacharacters.
            Perla::CodeGen::emit($cg, "StradaValue *__fh; ");
            Perla::CodeGen::emit($cg, "if (strcmp(__pm, \"-|\") == 0 || strcmp(__pm, \"|-\") == 0) { ");
            if ($argc > 3) {
                Perla::CodeGen::emit($cg, "  StradaValue *__cmd_sv = strada_new_str(__fn); ");
                my int $eai = 3;
                while ($eai < $argc) {
                    Perla::CodeGen::emit($cg, "  { StradaValue *__ea_p = strada_new_str(\" \"); ");
                    Perla::CodeGen::emit($cg, "    StradaValue *__ea_v = ");
                    Perla::CodeGen::gen_expr($cg, $args->[$eai]);
                    Perla::CodeGen::emit($cg, "; StradaValue *__ea_t1 = strada_concat_sv(__cmd_sv, __ea_p); strada_decref(__cmd_sv); strada_decref(__ea_p); ");
                    Perla::CodeGen::emit($cg, "    __cmd_sv = strada_concat_sv(__ea_t1, __ea_v); strada_decref(__ea_t1); strada_decref(__ea_v); } ");
                    $eai = $eai + 1;
                }
                Perla::CodeGen::emit($cg, "  StradaValue *__mode_sv = strada_new_str(strcmp(__pm, \"-|\") == 0 ? \"r\" : \"w\"); ");
                Perla::CodeGen::emit($cg, "  __fh = strada_popen(__cmd_sv, __mode_sv); ");
                Perla::CodeGen::emit($cg, "  strada_decref(__cmd_sv); strada_decref(__mode_sv); ");
            } else {
                Perla::CodeGen::emit($cg, "  StradaValue *__cmd_sv = strada_new_str(__fn); ");
                Perla::CodeGen::emit($cg, "  StradaValue *__mode_sv = strada_new_str(strcmp(__pm, \"-|\") == 0 ? \"r\" : \"w\"); ");
                Perla::CodeGen::emit($cg, "  __fh = strada_popen(__cmd_sv, __mode_sv); ");
                Perla::CodeGen::emit($cg, "  strada_decref(__cmd_sv); strada_decref(__mode_sv); ");
            }
            Perla::CodeGen::emit($cg, "} else if (__pm && strchr(__pm, '&')) { extern StradaValue *perla_open_dup(StradaValue *, const char *); __fh = perla_open_dup(__src_fh_sv, __pm); } ");
            Perla::CodeGen::emit($cg, "else { __fh = strada_open(__fn, __cm); } ");
            if (length($fh_var) > 0) {
                Perla::CodeGen::emit($cg, $fh_var . " = __fh; ");
            } elsif (length($fh_bareword) > 0) {
                Perla::CodeGen::emit($cg, "perla_scalar_set(\"" . $cg->{"pkg"} . "\", \"" . $fh_bareword . "\", __fh); ");
            } else {
                _emit_open_slot_store($cg, $fh_arg);
            }
            # strada_open returns strada_new_undef() (non-NULL but type
            # STRADA_UNDEF) on failure — checking \`__fh != NULL\` would
            # treat that as success. The correct check is "is it a
            # filehandle with a non-NULL FILE*". On failure, errno is
            # already set by fopen; preserve it for \$! to read.
            Perla::CodeGen::emit($cg, "int __op_ok = (__fh && !STRADA_IS_TAGGED_INT(__fh) && __fh->type == STRADA_FILEHANDLE && __fh->value.fh != NULL); ");
            Perla::CodeGen::emit($cg, "if (__fn) free(__fn); free(__pm); STRADA_MAKE_TAGGED_INT(__op_ok); })");
        } elsif ($argc >= 2) {
