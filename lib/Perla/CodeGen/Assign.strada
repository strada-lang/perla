                Perla::CodeGen::gen_expr($cg, $node->{"value"});
                Perla::CodeGen::emit($cg, "; strada_hv_store(");
            } else {
                Perla::CodeGen::emit($cg, "({ char *__k = strada_to_str(");
                if (defined($tkey)) {
                    Perla::CodeGen::gen_expr($cg, $tkey);
                } else {
                    Perla::CodeGen::emit($cg, "perla_dollar_underscore");
                }
                Perla::CodeGen::emit($cg, "); StradaValue *__hv_val = ");
                Perla::CodeGen::gen_expr($cg, $node->{"value"});
                Perla::CodeGen::emit($cg, "; strada_hv_store(");
            }
            if ($inner_type == Perla::AST::N_HASH_ELEM() || $inner_type == Perla::AST::N_ARROW_HASH()) {
                Perla::CodeGen::_gen_autoviv_hash($cg, $inner_obj);
            } elsif ($inner_type == Perla::AST::N_ARRAY_ELEM() || $inner_type == Perla::AST::N_ARROW_ARRAY()) {
