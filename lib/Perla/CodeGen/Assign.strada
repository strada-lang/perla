        }
        # Array-deref assignment: @{$ref} = LIST
        # Covers both the normal case (real array ref — replace contents) and
        # the symbolic-ref form `@{"Pkg::ISA"} = qw(Parent...)` used by
        # dynamic `import` subs (e.g. Drogo::Dispatch::import). The runtime
        # helper decides based on whether $ref is a string or a real ref.
        # `%{$ref} = (k => v, ...)` — hash deref LHS. Previously this
        # had no handler — the assignment silently evaluated the RHS
        # and dropped it. Now routes through perla_deref_hash_assign
        # which handles both real hashrefs and symbolic (package-
        # qualified) refs.
        if ($target_type == Perla::AST::N_DEREF_HASH()) {
            my int $__lh_strict = 0;
            if (defined($cg->{"strict_refs"}) && $cg->{"strict_refs"} == 1) {
                $__lh_strict = 1;
            }
            Perla::CodeGen::emit($cg, "({ StradaValue *__dh_ref = ");
            Perla::CodeGen::gen_expr($cg, $target->{"ref"});
            Perla::CodeGen::emit($cg, "; int __sav_wl_dh = __perla_want_list; __perla_want_list = 1; StradaValue *__dh_val = ");
            Perla::CodeGen::gen_expr($cg, $node->{"value"});
            Perla::CodeGen::emit($cg, "; __perla_want_list = __sav_wl_dh; ");
            if ($__lh_strict == 1) {
                Perla::CodeGen::emit($cg, "if (__dh_ref && !STRADA_IS_TAGGED_INT(__dh_ref) && __dh_ref->type == STRADA_STR && __dh_ref->value.pv && !strstr(__dh_ref->value.pv, \"::\")) { char __sm[512]; snprintf(__sm, sizeof(__sm), \"Can't use string (\\\"%s\\\") as a HASH ref while \\\"strict refs\\\" in use\", __dh_ref->value.pv); strada_die(__sm); } ");
            }
