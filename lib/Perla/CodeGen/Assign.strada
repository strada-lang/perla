                    # (or doesn't exist as an arrayref), spring it into being
                    # so the subsequent `[i]{key}` chain has a place to land.
                    Perla::CodeGen::_gen_autoviv_array_value($cg, $arr_node);
                }
                Perla::CodeGen::emit($cg, "); int __aih_p = (int)strada_to_int(");
                Perla::CodeGen::gen_expr($cg, $inner_obj->{"index"});
                Perla::CodeGen::emit($cg, "); if (__aih_p < 0 && __avh_p) __aih_p += strada_array_length(__avh_p); ");
                Perla::CodeGen::emit($cg, "StradaValue *__slh_p = __avh_p ? strada_array_get(__avh_p, __aih_p) : NULL; ");
                Perla::CodeGen::emit($cg, "if (!__slh_p || STRADA_IS_TAGGED_INT(__slh_p) || __slh_p->type != STRADA_REF || !__slh_p->value.rv || __slh_p->value.rv->type != STRADA_HASH) { ");
                Perla::CodeGen::emit($cg, "  StradaValue *__nrh = strada_new_ref_take(strada_new_hash(), '%'); ");
                Perla::CodeGen::emit($cg, "  if (__avh_p) strada_array_set(__avh_p, __aih_p, __nrh); ");
                Perla::CodeGen::emit($cg, "  __slh_p = __nrh; ");
                Perla::CodeGen::emit($cg, "} __slh_p; })");
            } elsif ($inner_type == Perla::AST::N_SCALAR_VAR()
                && defined($inner_obj->{"name"}) && length($inner_obj->{"name"}) > 0
                && index($inner_obj->{"name"}, "::") > 0) {
                # `$Pkg::H{k} = X` — write to the HASH slot of the stash
                # glob, mirroring the read path's stash-routing. Without
                # this we fell through to gen_expr which emits
                # perla_scalar_get (SCALAR slot) and the write silently
                # missed the package's actual %H.
                my str $hwn = $inner_obj->{"name"};
                my int $hwli = -1;
                my int $hwsi = 0;
                while ($hwsi < length($hwn) - 1) {
                    if (substr($hwn, $hwsi, 2) eq "::") { $hwli = $hwsi; }
                    $hwsi = $hwsi + 1;
