        Perla::CodeGen::emit($cg, "char *__rep_b = malloc(__rep_tl + 1); for (int64_t __rep_i = 0; __rep_i < __rep_n; __rep_i++) memcpy(__rep_b + __rep_i * __rep_sl, __rep_s, __rep_sl); __rep_b[__rep_tl] = 0; ");
