            Perla::CodeGen::emit($cg, " = ");
            Perla::CodeGen::gen_scalar_ctx_expr($cg, $node->{"value"});
            Perla::CodeGen::emit($cg, "; } ");
            Perla::CodeGen::gen_expr($cg, $node->{"target"});
            Perla::CodeGen::emit($cg, "; })");
        } elsif ($target_type == Perla::AST::N_DEREF_SCALAR()) {
            # `${EXPR} //= V` — scalar deref lvalue (symbolic / ref / slot).
            # Read current; if undef, route the assignment through the plain
            # `=` deref-scalar path. Mirrors the ||= deref-scalar case.
            my scalar $da_synth = { "op" => "=", "target" => $target, "value" => $node->{"value"} };
            Perla::CodeGen::emit($cg, "({ StradaValue *__l = ");
            Perla::CodeGen::gen_expr($cg, $target);
            Perla::CodeGen::emit($cg, "; if (!strada_defined_bool(__l)) { __l = ");
            _gen_assign($cg, $da_synth);
            Perla::CodeGen::emit($cg, "; } __l; })");
        } else {
            # Non-lvalue target (e.g. //= on a call result, anon hash, etc.).
            # Real Perl raises a compile-time error for these. At runtime we
            # die with a clear message so the author knows to fix the source.
            Perla::CodeGen::emit($cg, "({ strada_die(\"%s\", \"Can't modify non-lvalue in //= assignment\"); strada_new_undef(); })");
        }
        return;
    }
    # ||= : assign if falsy
    if ($op eq "||=") {
        # `$@ ||= V` — the N_SCALAR_VAR{name="@"} read path emits a lazy-init
        # statement expression `({ if (!perla_eval_error) ... perla_eval_error; })`
        # which is not a C lvalue, so the standard simple-lvalue compound-assign
        # produced `(STMT-EXPR) = V` and failed to compile (DBI.pm uses this
        # idiom in install_method). Use the global directly for the assignment.
        if ($target_type == Perla::AST::N_SCALAR_VAR()
            && defined($target->{"name"}) && $target->{"name"} eq "@") {
            Perla::CodeGen::emit($cg, "({ if (!perla_eval_error) { perla_eval_error = strada_new_str(\"\"); strada_incref(perla_eval_error); } ");
            Perla::CodeGen::emit($cg, "if (!perla_to_bool(perla_eval_error)) { ");
            Perla::CodeGen::emit($cg, "if (perla_eval_error) strada_decref(perla_eval_error); perla_eval_error = ");
            Perla::CodeGen::gen_scalar_ctx_expr($cg, $node->{"value"});
            Perla::CodeGen::emit($cg, "; } perla_eval_error; })");
            return;
        }
        if ($target_type == Perla::AST::N_HASH_ELEM() || $target_type == Perla::AST::N_ARROW_HASH()) {
            _gen_hash_compound_assign($cg, $target, "||", $node->{"value"});
        } elsif ($target_type == Perla::AST::N_ARRAY_ELEM() || $target_type == Perla::AST::N_ARROW_ARRAY()) {
            # $a[i] ||= v  /  $ref->[i] ||= v — fetch current, assign only
            # when falsy, yield new value. Used by YAML::Loader:
            # `$self->offset->[$self->level] ||= 0`.
            Perla::CodeGen::emit($cg, "({ StradaArray *__la_av = strada_deref_array(");
            if ($target_type == Perla::AST::N_ARRAY_ELEM()) {
                Perla::CodeGen::gen_expr($cg, $target->{"array"});
            } else {
                Perla::CodeGen::gen_expr($cg, $target->{"object"});
            }
            Perla::CodeGen::emit($cg, "); int __la_idx = (int)strada_to_int(");
            Perla::CodeGen::gen_expr($cg, $target->{"index"});
            Perla::CodeGen::emit($cg, "); if (__la_idx < 0 && __la_av) __la_idx += strada_array_length(__la_av); ");
            Perla::CodeGen::emit($cg, "StradaValue *__la_cur = __la_av ? strada_array_get(__la_av, __la_idx) : strada_new_undef(); ");
            Perla::CodeGen::emit($cg, "StradaValue *__la_r; if (perla_to_bool(__la_cur)) { __la_r = __la_cur; } else { __la_r = ");
            Perla::CodeGen::gen_scalar_ctx_expr($cg, $node->{"value"});
            Perla::CodeGen::emit($cg, "; if (__la_av) strada_array_set(__la_av, __la_idx, __la_r); } __la_r; })");
        } elsif (Perla::CodeGen::_is_pkg_qualified_scalar($target) == 1) {
            # `$Pkg::Name ||= V` — same lvalue issue as //= above.
            my array @pn = Perla::CodeGen::_split_pkg_qual_name($target);
            my str $pkg = $pn[0];
            my str $name = $pn[1];
            Perla::CodeGen::emit($cg, "({ StradaValue *__l = perla_scalar_get(\"" . $pkg . "\", \"" . $name . "\"); ");
            Perla::CodeGen::emit($cg, "if (!perla_to_bool(__l)) { perla_scalar_set(\"" . $pkg . "\", \"" . $name . "\", ");
            Perla::CodeGen::gen_scalar_ctx_expr($cg, $node->{"value"});
            Perla::CodeGen::emit($cg, "); __l = perla_scalar_get(\"" . $pkg . "\", \"" . $name . "\"); } __l; })");
        } elsif (Perla::CodeGen::Predicate::is_simple_lvalue($target_type) == 1) {
            Perla::CodeGen::emit($cg, "({ StradaValue *__l = ");
            Perla::CodeGen::gen_expr($cg, $target);
            Perla::CodeGen::emit($cg, "; if (!perla_to_bool(__l)) { ");
            Perla::CodeGen::gen_expr($cg, $target);
            Perla::CodeGen::emit($cg, " = ");
            Perla::CodeGen::gen_scalar_ctx_expr($cg, $node->{"value"});
            Perla::CodeGen::emit($cg, "; } ");
            Perla::CodeGen::gen_expr($cg, $target);
            Perla::CodeGen::emit($cg, "; })");
        } elsif ($target_type == Perla::AST::N_DEREF_SCALAR()) {
            # `${EXPR} ||= V` — scalar deref (symbolic `${"Pkg::X"}`, `$$ref`,
            # slot ref) as an lvalue. Read the current value; if falsy, route
            # the assignment through the plain `=` deref-scalar path (which
            # handles symbolic-name / ref / slot-ref writes). Real-world:
            # Type::Library::meta's `${"$_[0]::META"} ||= bless {}, $_[0]`.
            my scalar $oa_synth = { "op" => "=", "target" => $target, "value" => $node->{"value"} };
            Perla::CodeGen::emit($cg, "({ StradaValue *__l = ");
            Perla::CodeGen::gen_expr($cg, $target);
            Perla::CodeGen::emit($cg, "; if (!perla_to_bool(__l)) { __l = ");
            _gen_assign($cg, $oa_synth);
            Perla::CodeGen::emit($cg, "; } __l; })");
        } else {
            Perla::CodeGen::emit($cg, "({ strada_die(\"%s\", \"Can't modify non-lvalue in ||= assignment\"); strada_new_undef(); })");
        }
        return;
    }
    # &&= : assign if truthy
    if ($op eq "&&=") {
        if (Perla::CodeGen::_is_pkg_qualified_scalar($target) == 1) {
            # `$Pkg::Name &&= V` — same lvalue issue as //= / ||= above.
            my array @pn = Perla::CodeGen::_split_pkg_qual_name($target);
            my str $pkg = $pn[0];
            my str $name = $pn[1];
            Perla::CodeGen::emit($cg, "({ StradaValue *__l = perla_scalar_get(\"" . $pkg . "\", \"" . $name . "\"); ");
            Perla::CodeGen::emit($cg, "if (perla_to_bool(__l)) { perla_scalar_set(\"" . $pkg . "\", \"" . $name . "\", ");
            Perla::CodeGen::gen_scalar_ctx_expr($cg, $node->{"value"});
            Perla::CodeGen::emit($cg, "); __l = perla_scalar_get(\"" . $pkg . "\", \"" . $name . "\"); } __l; })");
            return;
        }
        Perla::CodeGen::emit($cg, "({ StradaValue *__l = ");
        Perla::CodeGen::gen_expr($cg, $target);
        Perla::CodeGen::emit($cg, "; if (perla_to_bool(__l)) { ");
        Perla::CodeGen::gen_expr($cg, $target);
        Perla::CodeGen::emit($cg, " = ");
        Perla::CodeGen::gen_scalar_ctx_expr($cg, $node->{"value"});
        Perla::CodeGen::emit($cg, "; } ");
        Perla::CodeGen::gen_expr($cg, $target);
        Perla::CodeGen::emit($cg, "; })");
        return;
    }
    # Fallback: plain assignment
    Perla::CodeGen::gen_expr($cg, $target);
    Perla::CodeGen::emit($cg, " = ");
    Perla::CodeGen::gen_expr($cg, $node->{"value"});
}

# --- Scalar-deref compound assignment: $$ref OP= val / ${expr} OP= val ---
func _gen_deref_scalar_compound_assign(scalar $cg, scalar $target, str $op, scalar $value) void {
    Perla::CodeGen::emit($cg, "({ StradaValue *__dc_ref = ");
    Perla::CodeGen::gen_expr($cg, $target->{"ref"});
    # Read the current target: for slot refs (e.g. \$arr[i]) the target
    # is *(StradaValue **)value.ptr; for heap refs it's value.rv. The
    # old code always read value.rv, which for slot refs is value.ptr
    # cast to a pointer — a corrupt StradaValue address that segfaulted
    # on the first deref. perla_scalar_deref_assign already handles both
    # ref types for the write side.
    Perla::CodeGen::emit($cg, "; StradaValue *__dc_cur; ");
    Perla::CodeGen::emit($cg, "if (__dc_ref && !STRADA_IS_TAGGED_INT(__dc_ref) && __dc_ref->type == STRADA_REF) { ");
    Perla::CodeGen::emit($cg, "  if (strada_is_slot_ref(__dc_ref)) { ");
    Perla::CodeGen::emit($cg, "    StradaValue **__dc_slot = (StradaValue**)__dc_ref->value.ptr; ");
    Perla::CodeGen::emit($cg, "    __dc_cur = (__dc_slot && *__dc_slot) ? *__dc_slot : strada_undef_static(); ");
    Perla::CodeGen::emit($cg, "  } else { __dc_cur = __dc_ref->value.rv ? __dc_ref->value.rv : strada_undef_static(); } ");
    Perla::CodeGen::emit($cg, "} else { __dc_cur = strada_undef_static(); } ");
    Perla::CodeGen::emit($cg, "StradaValue *__dc_rhs = ");
    Perla::CodeGen::gen_expr($cg, $value);
    Perla::CodeGen::emit($cg, "; StradaValue *__dc_new = ");
    if ($op eq "+") {
        Perla::CodeGen::emit($cg, "strada_new_num(strada_to_num(__dc_cur) + strada_to_num(__dc_rhs))");
    } elsif ($op eq "-") {
        Perla::CodeGen::emit($cg, "strada_new_num(strada_to_num(__dc_cur) - strada_to_num(__dc_rhs))");
    } elsif ($op eq "*") {
        Perla::CodeGen::emit($cg, "strada_new_num(strada_to_num(__dc_cur) * strada_to_num(__dc_rhs))");
    } elsif ($op eq "/") {
        Perla::CodeGen::emit($cg, "strada_new_num(strada_to_num(__dc_cur) / strada_to_num(__dc_rhs))");
    } elsif ($op eq "%") {
        Perla::CodeGen::emit($cg, "STRADA_MAKE_TAGGED_INT(strada_to_int(__dc_cur) % strada_to_int(__dc_rhs))");
    } elsif ($op eq "**") {
        Perla::CodeGen::emit($cg, "strada_new_num(pow(strada_to_num(__dc_cur), strada_to_num(__dc_rhs)))");
    } else {
        Perla::CodeGen::emit($cg, "strada_concat_sv(__dc_cur, __dc_rhs)");
    }
    Perla::CodeGen::emit($cg, "; perla_scalar_deref_assign(__dc_ref, __dc_new); ");
    # Release the owned RHS temp (the op only read it). __dc_new is left as the
    # yielded value; perla_scalar_deref_assign's incref behaviour differs
    # between slot-refs (increfs) and heap-refs (copies in place), so it is not
    # uniformly safe to drop a create-ref here — `$$ref OP=` is rare and
    # expr_is_borrowed reports it borrowed (consumers over-incref at worst).
    if (Perla::CodeGen::expr_is_borrowed($value) == 0) { Perla::CodeGen::emit($cg, "if (__dc_rhs) strada_decref(__dc_rhs); "); }
    Perla::CodeGen::emit($cg, "__dc_new; })");
}

# --- Array-element compound assignment: $arr[i] OP= val / $ref->[i] OP= val ---
func _gen_array_compound_assign(scalar $cg, scalar $target, str $op, scalar $value) void {
    my int $tt = $target->{"type"};
    Perla::CodeGen::emit($cg, "({ StradaArray *__ca_av = strada_deref_array(");
    # Sigil-array form (`$arr[i] op= V`) accesses @arr. With name collision
    # `c_var_a` handles the v_NAME → v_NAME__a remapping; plain gen_expr
    # of N_SCALAR_VAR returns v_NAME (the scalar). Mirrors the explicit
    # branch in the `+=` codegen above. Without this, `$sum[0] -= V` etc.
    # silently updated the wrong variable's deref.
    my scalar $ca_arr_node = ($tt == Perla::AST::N_ARRAY_ELEM()) ? $target->{"array"} : $target->{"object"};
    my int $ca_is_arrow = 0;
    if (defined($target->{"is_explicit_arrow"}) && $target->{"is_explicit_arrow"} == 1) { $ca_is_arrow = 1; }
    if ($ca_is_arrow == 0
        && defined($ca_arr_node) && $ca_arr_node->{"type"} == Perla::AST::N_SCALAR_VAR()
        && defined($ca_arr_node->{"name"}) && $ca_arr_node->{"name"} eq "_") {
        Perla::CodeGen::emit($cg, "perla_at_");
    } elsif ($ca_is_arrow == 0
        && defined($ca_arr_node) && $ca_arr_node->{"type"} == Perla::AST::N_SCALAR_VAR()
        && defined($ca_arr_node->{"name"}) && index($ca_arr_node->{"name"}, "::") > 0) {
        # $Pkg::arr[i] OP= V — fetch the ARRAY slot of the stash glob.
        my array @capn = Perla::CodeGen::_split_pkg_qual_name($ca_arr_node);
        Perla::CodeGen::emit($cg, "perla_array_get(\"" . $capn[0] . "\", \"" . $capn[1] . "\")");
    } elsif ($ca_is_arrow == 0
        && defined($ca_arr_node) && $ca_arr_node->{"type"} == Perla::AST::N_SCALAR_VAR()
        && defined($ca_arr_node->{"name"}) && length($ca_arr_node->{"name"}) > 0
        && index($ca_arr_node->{"name"}, "::") < 0) {
        Perla::CodeGen::emit($cg, Perla::CodeGen::c_var_a($ca_arr_node->{"name"}));
    } else {
        Perla::CodeGen::gen_expr($cg, $ca_arr_node);
    }
    Perla::CodeGen::emit($cg, "); int __ca_idx = (int)strada_to_int(");
    Perla::CodeGen::gen_expr($cg, $target->{"index"});
    Perla::CodeGen::emit($cg, "); if (__ca_idx < 0 && __ca_av) __ca_idx += strada_array_length(__ca_av); ");
    Perla::CodeGen::emit($cg, "StradaValue *__ca_cur = strada_array_get(__ca_av, __ca_idx); ");
    # //= / ||= — short-circuit: only evaluate RHS and store back when the
    # current value fails the defined / truthy check. Without this branch,
    # `$cache[$i] //= EXPR` fell through to the standard "Can't modify
    # non-lvalue" path because `Perla::CodeGen::gen_expr(target) = …` doesn't produce a
    # C lvalue for array elements.
    if ($op eq "//" || $op eq "||") {
        my str $tcond = "perla_to_bool";
        if ($op eq "//") { $tcond = "strada_defined_bool"; }
        Perla::CodeGen::emit($cg, "StradaValue *__ca_new = " . $tcond . "(__ca_cur) ? __ca_cur : ");
        Perla::CodeGen::gen_scalar_ctx_expr($cg, $value);
        Perla::CodeGen::emit($cg, "; if (__ca_new != __ca_cur) { strada_array_set(__ca_av, __ca_idx, __ca_new); } __ca_new; })");
        return;
    }
    Perla::CodeGen::emit($cg, "StradaValue *__ca_rhs = ");
    Perla::CodeGen::gen_scalar_ctx_expr($cg, $value);
    Perla::CodeGen::emit($cg, "; StradaValue *__ca_new = ");
    if ($op eq "+") {
        Perla::CodeGen::emit($cg, "strada_new_num(strada_to_num(__ca_cur) + strada_to_num(__ca_rhs))");
    } elsif ($op eq "-") {
        Perla::CodeGen::emit($cg, "strada_new_num(strada_to_num(__ca_cur) - strada_to_num(__ca_rhs))");
    } elsif ($op eq "*") {
        Perla::CodeGen::emit($cg, "strada_new_num(strada_to_num(__ca_cur) * strada_to_num(__ca_rhs))");
    } elsif ($op eq "/") {
        Perla::CodeGen::emit($cg, "strada_new_num(strada_to_num(__ca_cur) / strada_to_num(__ca_rhs))");
    } elsif ($op eq "%") {
        Perla::CodeGen::emit($cg, "STRADA_MAKE_TAGGED_INT(strada_to_int(__ca_cur) % strada_to_int(__ca_rhs))");
    } elsif ($op eq "**") {
        Perla::CodeGen::emit($cg, "strada_new_num(pow(strada_to_num(__ca_cur), strada_to_num(__ca_rhs)))");
    } else {
        Perla::CodeGen::emit($cg, "strada_concat_sv(__ca_cur, __ca_rhs)");
    }
    Perla::CodeGen::emit($cg, "; strada_array_set(__ca_av, __ca_idx, __ca_new); ");
    # Release the owned RHS temp (the op only read it) — it was previously
    # emitted inline and leaked every iteration. __ca_new is yielded OWNED
    # (rc=2: the create-ref + strada_array_set's incref); consumers take the
    # create-ref and the void-statement emitter decrefs it. __ca_cur came from
    # strada_array_get (borrowed) and was consumed by the op above.
    if (Perla::CodeGen::expr_is_borrowed($value) == 0) { Perla::CodeGen::emit($cg, "if (__ca_rhs) strada_decref(__ca_rhs); "); }
    Perla::CodeGen::emit($cg, "__ca_new; })");
}

# --- Function call ---
# --- Hash compound assignment: $h{k} += val ---
# Postfix $h{k}++ / $h{k}-- — return OLD value, then increment/decrement in
# place. `$op` is "+" or "-". Perl's postfix semantics: `$seen{$n}++`
# returns 0 the first time and 1 the second, which is critical for
# idioms like `die "dup" if $seen{$k}++`. Earlier we routed this through
# `_gen_hash_compound_assign` which returns the NEW value — so the dup
# check fired on the very first increment.
func _gen_hash_postfix_inc_dec(scalar $cg, scalar $target, str $op) void {
    my int $tt = $target->{"type"};
    my scalar $hash_expr = undef;
    my scalar $key_expr = undef;
    my int $hash_ctx = 0;
    if ($tt == Perla::AST::N_HASH_ELEM()) {
        $hash_expr = $target->{"hash"};
        $key_expr = $target->{"key"};
        $hash_ctx = 1;
    } elsif ($tt == Perla::AST::N_ARROW_HASH()) {
        $hash_expr = $target->{"object"};
        $key_expr = $target->{"key"};
        # `$h{k}` (no arrow) parses as N_ARROW_HASH without is_explicit_arrow.
        if (!defined($target->{"is_explicit_arrow"}) || $target->{"is_explicit_arrow"} != 1) {
            $hash_ctx = 1;
        }
    }
    my int $key_is_lit = 0;
    if (defined($key_expr) && $key_expr->{"type"} == Perla::AST::N_STR_LIT()) { $key_is_lit = 1; }
    # Single-probe lvalue RMW: ++/-- never resize beyond the existing slot, and
    # __nv is an immortal tagged int, so the slot pointer stays valid. Postfix
    # returns the OLD value, so we transfer the slot's ownership of the old
    # value into the return (no incref) rather than fetch_owned's extra ref.
    # strada_hv_fetch_lvalue_sv* returns NULL for tied/non-hash → fallback
    # branch keeps fetch/store so tie FETCH/STORE magic still fires.
    if ($key_is_lit == 1) {
        my str $lit_key = Perla::CodeGen::Escape::escape_c_str($key_expr->{"value"});
        Perla::CodeGen::emit($cg, "({ StradaValue *__ch = ");
        Perla::CodeGen::_gen_autoviv_outer_hash($cg, $hash_expr, $hash_ctx);
        Perla::CodeGen::emit($cg, "; StradaValue **__slot = strada_hv_fetch_lvalue_sv(__ch, \"" . $lit_key . "\", 1); StradaValue *__cv; ");
        Perla::CodeGen::emit($cg, "if (__slot) { __cv = *__slot; *__slot = STRADA_MAKE_TAGGED_INT(strada_to_int(__cv) " . $op . " 1); } ");
        Perla::CodeGen::emit($cg, "else { __cv = strada_hv_fetch_owned(__ch, \"" . $lit_key . "\"); strada_hv_store(__ch, \"" . $lit_key . "\", STRADA_MAKE_TAGGED_INT(strada_to_int(__cv) " . $op . " 1)); } ");
        # perl's postfix ++/-- numifies an undef old value to 0 in the result.
        Perla::CodeGen::emit($cg, "((__cv && !STRADA_IS_TAGGED_INT(__cv) && __cv->type == STRADA_UNDEF) ? (strada_decref(__cv), STRADA_MAKE_TAGGED_INT(0)) : __cv); })");
    } else {
        # When the key expr is an owned temp (e.g. a string-literal key that
        # parses to a non-N_STR_LIT node), __ck_sv must be freed — the borrowed
        # case (a bare scalar var, the common path) skips the decref entirely.
        my int $key_owned = 0;
        if (Perla::CodeGen::expr_is_borrowed($key_expr) == 0) { $key_owned = 1; }
        Perla::CodeGen::emit($cg, "({ StradaValue *__ck_sv = ");
        Perla::CodeGen::gen_expr($cg, $key_expr);
        Perla::CodeGen::emit($cg, "; StradaValue *__ch = ");
        Perla::CodeGen::_gen_autoviv_outer_hash($cg, $hash_expr, $hash_ctx);
        Perla::CodeGen::emit($cg, "; StradaValue **__slot = strada_hv_fetch_lvalue_sv_key(__ch, __ck_sv, 1); StradaValue *__cv; ");
        Perla::CodeGen::emit($cg, "if (__slot) { __cv = *__slot; *__slot = STRADA_MAKE_TAGGED_INT(strada_to_int(__cv) " . $op . " 1); } ");
        Perla::CodeGen::emit($cg, "else { __cv = strada_hv_fetch_owned_sv(__ch, __ck_sv); strada_hv_store_sv(__ch, __ck_sv, STRADA_MAKE_TAGGED_INT(strada_to_int(__cv) " . $op . " 1)); } ");
        # perl's postfix ++/-- numifies an undef old value to 0 in the result.
        Perla::CodeGen::emit($cg, "StradaValue *__res = (__cv && !STRADA_IS_TAGGED_INT(__cv) && __cv->type == STRADA_UNDEF) ? (strada_decref(__cv), STRADA_MAKE_TAGGED_INT(0)) : __cv; ");
        if ($key_owned == 1) { Perla::CodeGen::emit($cg, "strada_decref(__ck_sv); "); }
        Perla::CodeGen::emit($cg, "__res; })");
    }
}

# Emit `StradaValue *__nv = <op of __cv and the RHS>;` for hash/array-element
# compound assigns. For the non-short-circuit ops the owned RHS temp is
# captured into __hrhs and released after use (it was previously emitted
# inline and leaked). The short-circuit //=/||= must evaluate the RHS lazily,
# so they keep it inline (and only allocate when the branch is taken). __cv
# (the current owned value) must already be in scope.
func _emit_hash_cmpd_nv(scalar $cg, str $op, scalar $value) void {
    if ($op eq "//") {
        Perla::CodeGen::emit($cg, "StradaValue *__nv = strada_defined_bool(__cv) ? __cv : ");
        Perla::CodeGen::gen_scalar_ctx_expr($cg, $value);
        Perla::CodeGen::emit($cg, "; ");
        return;
    }
    if ($op eq "||") {
        Perla::CodeGen::emit($cg, "StradaValue *__nv = perla_to_bool(__cv) ? __cv : ");
        Perla::CodeGen::gen_scalar_ctx_expr($cg, $value);
        Perla::CodeGen::emit($cg, "; ");
        return;
    }
    Perla::CodeGen::emit($cg, "StradaValue *__hrhs = ");
    Perla::CodeGen::gen_scalar_ctx_expr($cg, $value);
    Perla::CodeGen::emit($cg, "; StradaValue *__nv = ");
    if ($op eq ".") {
        Perla::CodeGen::emit($cg, "strada_concat_sv(__cv, __hrhs)");
    } elsif ($op eq "%") {
        Perla::CodeGen::emit($cg, "STRADA_MAKE_TAGGED_INT(strada_to_int(__cv) % strada_to_int(__hrhs))");
    } elsif ($op eq "**") {
        Perla::CodeGen::emit($cg, "strada_new_num(pow(strada_to_num(__cv), strada_to_num(__hrhs)))");
    } elsif ($op eq "|" || $op eq "&" || $op eq "^" || $op eq "<<" || $op eq ">>") {
        Perla::CodeGen::emit($cg, "STRADA_MAKE_TAGGED_INT(strada_to_int(__cv) " . $op . " strada_to_int(__hrhs))");
    } else {
        if (Perla::CodeGen::Predicate::expr_is_int($value) == 1) {
            Perla::CodeGen::emit($cg, "STRADA_MAKE_TAGGED_INT(strada_to_int(__cv) " . $op . " strada_to_int(__hrhs))");
        } else {
            Perla::CodeGen::emit($cg, "strada_new_num(strada_to_num(__cv) " . $op . " strada_to_num(__hrhs))");
        }
    }
    Perla::CodeGen::emit($cg, "; ");
    if (Perla::CodeGen::expr_is_borrowed($value) == 0) {
        Perla::CodeGen::emit($cg, "if (__hrhs) strada_decref(__hrhs); ");
    }
}

func _gen_hash_compound_assign(scalar $cg, scalar $target, str $op, scalar $value) void {
    my int $tt = $target->{"type"};
    my scalar $hash_expr = undef;
    my scalar $key_expr = undef;
    my int $hash_ctx = 0;
    if ($tt == Perla::AST::N_HASH_ELEM()) {
        $hash_expr = $target->{"hash"};
        $key_expr = $target->{"key"};
        $hash_ctx = 1;
    } elsif ($tt == Perla::AST::N_ARROW_HASH()) {
        $hash_expr = $target->{"object"};
        $key_expr = $target->{"key"};
        if (!defined($target->{"is_explicit_arrow"}) || $target->{"is_explicit_arrow"} != 1) {
            $hash_ctx = 1;
        }
    }
    my int $key_is_lit = 0;
    if (defined($key_expr) && $key_expr->{"type"} == Perla::AST::N_STR_LIT()) { $key_is_lit = 1; }
    # A side-effect-free RHS cannot resize/mutate the hash mid-statement, so the
    # value-slot pointer stays valid across the read-modify-write — enabling the
    # single-probe lvalue path (vs fetch+store's two probes + two re-hashes).
    my int $rhs_safe = 0;
    if (defined($value)) {
        my int $vt = $value->{"type"};
        if ($vt == Perla::AST::N_INT_LIT() || $vt == Perla::AST::N_NUM_LIT()
            || $vt == Perla::AST::N_STR_LIT() || $vt == Perla::AST::N_SCALAR_VAR()) {
            $rhs_safe = 1;
        }
    }
    if ($key_is_lit == 1) {
        my str $lit_key = Perla::CodeGen::Escape::escape_c_str($key_expr->{"value"});
        if ($rhs_safe == 1) {
            Perla::CodeGen::emit($cg, "({ StradaValue *__ch = ");
            Perla::CodeGen::_gen_autoviv_outer_hash($cg, $hash_expr, $hash_ctx);
            Perla::CodeGen::emit($cg, "; StradaValue **__slot = strada_hv_fetch_lvalue_sv(__ch, \"" . $lit_key . "\", 1); StradaValue *__cv = __slot ? *__slot : strada_hv_fetch_owned(__ch, \"" . $lit_key . "\"); ");
            _emit_hash_cmpd_nv($cg, $op, $value);
            Perla::CodeGen::emit($cg, "if (__slot) { *__slot = __nv; strada_incref(__nv); if (__cv && __cv != __nv) strada_decref(__cv); } else { strada_hv_store(__ch, \"" . $lit_key . "\", __nv); if (__cv && __cv != __nv) strada_decref(__cv); } __nv; })");
        } else {
            Perla::CodeGen::emit($cg, "({ StradaValue *__ch = ");
            Perla::CodeGen::_gen_autoviv_outer_hash($cg, $hash_expr, $hash_ctx);
            Perla::CodeGen::emit($cg, "; StradaValue *__cv = strada_hv_fetch_owned(__ch, \"" . $lit_key . "\"); ");
            _emit_hash_cmpd_nv($cg, $op, $value);
            # __nv is yielded OWNED (rc=2 for non-short-circuit: the create-ref +
            # strada_hv_store's incref); consumers take the create-ref and the
            # void-statement emitter decrefs it. _emit_hash_cmpd_nv already released
            # the owned RHS temp (previously emitted inline and leaked).
            # CRITICAL: store BEFORE decref'ing __cv, and only decref when __cv is
            # NOT the yielded value. For `||=`/`//=` short-circuit KEEP (__nv==__cv)
            # the old unconditional `strada_decref(__cv)` dropped the fetch_owned
            # ref, leaving the kept element BORROWED (rc=1, hash-owned) — but the
            # compound result is contracted OWNED, so a void/return consumer
            # decref'd it to 0 and FREED a live hash value (slot recycled → wrong
            # code). Mirror the lvalue path's `if (__cv && __cv != __nv)` guard.
            # (For non-short-circuit ops __nv is always a fresh value != __cv, so
            # the guard is always true and behavior is unchanged.)
            Perla::CodeGen::emit($cg, "strada_hv_store(__ch, \"" . $lit_key . "\", __nv); if (__cv && __cv != __nv) strada_decref(__cv); __nv; })");
        }
    } else {
        # Fast path: when the key is a borrowed scalar var, use the _sv
        # variants for fetch + store — sv_key_extract pulls the pv from
        # an existing StradaString without strdup, saving a per-iter
        # malloc/free pair. Falls back to the strada_to_str path for
        # arbitrary key expressions.
        my int $key_simple = 0;
        if (defined($key_expr) && $key_expr->{"type"} == Perla::AST::N_SCALAR_VAR()
            && defined($key_expr->{"name"}) && index($key_expr->{"name"}, "::") < 0) {
            $key_simple = 1;
        }
        # Single-probe lvalue fast path (rhs_safe computed above): the slot
        # pointer stays valid across the read-modify-write — one probe instead
        # of fetch+store's two. strada_hv_fetch_lvalue_sv* returns NULL for
        # tied/non-hash sv; the ternary then falls back so tie magic still fires.
        if ($rhs_safe == 1 && $key_simple == 1) {
            # single-probe + no-strdup: reuse the key scalar's pv directly
            Perla::CodeGen::emit($cg, "({ StradaValue *__ck_sv = ");
            Perla::CodeGen::gen_expr($cg, $key_expr);
            Perla::CodeGen::emit($cg, "; StradaValue *__ch = ");
            Perla::CodeGen::_gen_autoviv_outer_hash($cg, $hash_expr, $hash_ctx);
            Perla::CodeGen::emit($cg, "; StradaValue **__slot = strada_hv_fetch_lvalue_sv_key(__ch, __ck_sv, 1); StradaValue *__cv = __slot ? *__slot : strada_hv_fetch_owned_sv(__ch, __ck_sv); ");
            _emit_hash_cmpd_nv($cg, $op, $value);
            Perla::CodeGen::emit($cg, "if (__slot) { *__slot = __nv; strada_incref(__nv); if (__cv && __cv != __nv) strada_decref(__cv); } else { strada_hv_store_sv(__ch, __ck_sv, __nv); if (__cv && __cv != __nv) strada_decref(__cv); } __nv; })");
        } elsif ($rhs_safe == 1) {
            Perla::CodeGen::emit($cg, "({ char *__ck = strada_to_str(");
            Perla::CodeGen::gen_expr($cg, $key_expr);
            Perla::CodeGen::emit($cg, "); StradaValue *__ch = ");
            Perla::CodeGen::_gen_autoviv_outer_hash($cg, $hash_expr, $hash_ctx);
            Perla::CodeGen::emit($cg, "; StradaValue **__slot = strada_hv_fetch_lvalue_sv(__ch, __ck, 1); StradaValue *__cv = __slot ? *__slot : strada_hv_fetch_owned(__ch, __ck); ");
            _emit_hash_cmpd_nv($cg, $op, $value);
            Perla::CodeGen::emit($cg, "if (__slot) { *__slot = __nv; strada_incref(__nv); if (__cv && __cv != __nv) strada_decref(__cv); } else { strada_hv_store(__ch, __ck, __nv); if (__cv && __cv != __nv) strada_decref(__cv); } free(__ck); __nv; })");
        } else {
            if ($key_simple == 1) {
                Perla::CodeGen::emit($cg, "({ StradaValue *__ck_sv = ");
                Perla::CodeGen::gen_expr($cg, $key_expr);
                Perla::CodeGen::emit($cg, "; StradaValue *__ch = ");
                Perla::CodeGen::_gen_autoviv_outer_hash($cg, $hash_expr, $hash_ctx);
                Perla::CodeGen::emit($cg, "; StradaValue *__cv = strada_hv_fetch_owned_sv(__ch, __ck_sv); ");
            } else {
                Perla::CodeGen::emit($cg, "({ char *__ck = strada_to_str(");
                Perla::CodeGen::gen_expr($cg, $key_expr);
                Perla::CodeGen::emit($cg, "); StradaValue *__ch = ");
                Perla::CodeGen::_gen_autoviv_outer_hash($cg, $hash_expr, $hash_ctx);
                Perla::CodeGen::emit($cg, "; StradaValue *__cv = strada_hv_fetch_owned(__ch, __ck); ");
            }
            _emit_hash_cmpd_nv($cg, $op, $value);
            # __nv yielded OWNED (see literal-key path); _emit_hash_cmpd_nv already
            # released the owned RHS temp.
            # Store before the conditional decref (see literal-key path): for the
            # `||=`/`//=` KEEP case (__nv==__cv) the old unconditional decref left
            # the kept element borrowed → void/return consumer freed a live value.
            if ($key_simple == 1) {
                Perla::CodeGen::emit($cg, "strada_hv_store_sv(__ch, __ck_sv, __nv); if (__cv && __cv != __nv) strada_decref(__cv); __nv; })");
            } else {
                Perla::CodeGen::emit($cg, "strada_hv_store(__ch, __ck, __nv); if (__cv && __cv != __nv) strada_decref(__cv); free(__ck); __nv; })");
            }
        }
    }
}
