                }
                Perla::CodeGen::_gen_autoviv_array_value($cg, $aa_arr_node);
                Perla::CodeGen::emit($cg, "); int __ai_p = (int)strada_to_int(");
                Perla::CodeGen::gen_expr($cg, $aa_obj->{"index"});
                Perla::CodeGen::emit($cg, "); if (__ai_p < 0 && __av_p) __ai_p += strada_array_length(__av_p); ");
                Perla::CodeGen::emit($cg, "StradaValue *__sl_p = __av_p ? strada_array_get(__av_p, __ai_p) : NULL; ");
                Perla::CodeGen::emit($cg, "if (!__sl_p || STRADA_IS_TAGGED_INT(__sl_p) || __sl_p->type != STRADA_REF || !__sl_p->value.rv || __sl_p->value.rv->type != STRADA_ARRAY) { ");
                Perla::CodeGen::emit($cg, "  StradaValue *__nr = strada_new_ref_take(strada_new_array(), '@'); ");
                Perla::CodeGen::emit($cg, "  if (__av_p) strada_array_set(__av_p, __ai_p, __nr); ");
                Perla::CodeGen::emit($cg, "  __sl_p = __nr; ");
                Perla::CodeGen::emit($cg, "} StradaArray *__aa_av = strada_deref_array(__sl_p); ");
                Perla::CodeGen::emit($cg, "int __aa_idx = (int)strada_to_num(");
                Perla::CodeGen::gen_expr($cg, $target->{"index"});
                Perla::CodeGen::emit($cg, "); StradaValue *__aa_val = ");
                Perla::CodeGen::gen_expr($cg, $node->{"value"});
                Perla::CodeGen::emit($cg, "; strada_array_set(__aa_av, __aa_idx, __aa_val); __aa_val; })");
                return;
            }
            if ($aa_obj_t == Perla::AST::N_HASH_ELEM() || $aa_obj_t == Perla::AST::N_ARROW_HASH()) {
                # `\$h{k}[i] = X` — inner is hash elem; autoviv hash slot
                # to arrayref.
                #
                # The container chain UP TO the leaf key also needs autoviv:
                # `my $d; $d->{x}[0] = "alice"` would otherwise compile to
                # __hv_p = NULL → __hh_p = NULL → `if (__hh_p) strada_hash_set_take`
                # silently skipped → arrayref never linked back to $d.
                # Route the outer object through `_gen_autoviv_hash` when it's
                # itself a hash access (which autovivs each step to {}), and
                # emit a scalar-autoviv snippet when it's a plain scalar var.
                Perla::CodeGen::emit($cg, "({ StradaValue *__hv_p = ");
                my scalar $aa_outer = NULL;
                if ($aa_obj_t == Perla::AST::N_HASH_ELEM()) {
                    $aa_outer = $aa_obj->{"hash"};
                } else {
                    $aa_outer = $aa_obj->{"object"};
                }
                my int $aa_outer_t = $aa_outer->{"type"};
                if ($aa_outer_t == Perla::AST::N_HASH_ELEM()
                    || $aa_outer_t == Perla::AST::N_ARROW_HASH()) {
                    Perla::CodeGen::_gen_autoviv_hash($cg, $aa_outer);
                } elsif ($aa_outer_t == Perla::AST::N_SCALAR_VAR()
                    && defined($aa_outer->{"name"})
                    && length($aa_outer->{"name"}) > 0
                    && index($aa_outer->{"name"}, "::") < 0
                    && $aa_outer->{"name"} ne "_") {
                    my str $aa_outer_vc = Perla::CodeGen::c_var($aa_outer->{"name"});
                    Perla::CodeGen::emit($cg, "({ if (!" . $aa_outer_vc . " || (!STRADA_IS_TAGGED_INT(" . $aa_outer_vc . ") && " . $aa_outer_vc . "->type == STRADA_UNDEF)) { ");
                    Perla::CodeGen::emit($cg, "  if (" . $aa_outer_vc . ") strada_decref(" . $aa_outer_vc . "); ");
                    Perla::CodeGen::emit($cg, "  " . $aa_outer_vc . " = strada_new_ref_take(strada_new_hash(), '%'); ");
                    Perla::CodeGen::emit($cg, "} " . $aa_outer_vc . "; })");
                } else {
                    Perla::CodeGen::gen_expr($cg, $aa_outer);
                }
                Perla::CodeGen::emit($cg, "; char *__hk_p = strada_to_str(");
                Perla::CodeGen::gen_expr($cg, $aa_obj->{"key"});
                Perla::CodeGen::emit($cg, "); StradaHash *__hh_p = strada_deref_hash(__hv_p); ");
                Perla::CodeGen::emit($cg, "StradaValue *__sl_p = __hh_p ? strada_hash_get(__hh_p, __hk_p) : NULL; ");
                Perla::CodeGen::emit($cg, "if (!__sl_p || STRADA_IS_TAGGED_INT(__sl_p) || __sl_p->type != STRADA_REF || !__sl_p->value.rv || __sl_p->value.rv->type != STRADA_ARRAY) { ");
                Perla::CodeGen::emit($cg, "  StradaValue *__nr = strada_new_ref_take(strada_new_array(), '@'); ");
                Perla::CodeGen::emit($cg, "  if (__hh_p) strada_hash_set_take(__hh_p, __hk_p, __nr); ");
                Perla::CodeGen::emit($cg, "  __sl_p = __nr; ");
                Perla::CodeGen::emit($cg, "} StradaArray *__aa_av = strada_deref_array(__sl_p); ");
                Perla::CodeGen::emit($cg, "int __aa_idx = (int)strada_to_num(");
                Perla::CodeGen::gen_expr($cg, $target->{"index"});
                Perla::CodeGen::emit($cg, "); StradaValue *__aa_val = ");
                Perla::CodeGen::gen_expr($cg, $node->{"value"});
