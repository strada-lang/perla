                # match Perl's "autovivification triggered by undef
                # only" semantics. Don't clobber existing strings, ints,
                # or other refs — those would be runtime errors in
                # strict Perl, but the user might use them as symbolic
                # refs (`${"Pkg::Name"}->{key}`).
                Perla::CodeGen::emit($cg, "({ if (!" . $vc . " || STRADA_IS_TAGGED_INT(" . $vc . ") ? 0 : (" . $vc . "->type == STRADA_UNDEF)) { ");
                Perla::CodeGen::emit($cg, "  StradaValue *__nh = strada_new_ref_take(strada_new_hash(), '%'); ");
                Perla::CodeGen::emit($cg, "  if (" . $vc . ") strada_decref(" . $vc . "); ");
                Perla::CodeGen::emit($cg, "  " . $vc . " = __nh; ");
                Perla::CodeGen::emit($cg, "} else if (!" . $vc . ") { ");
                Perla::CodeGen::emit($cg, "  " . $vc . " = strada_new_ref_take(strada_new_hash(), '%'); ");
                Perla::CodeGen::emit($cg, "} " . $vc . "; })");
            } else {
                Perla::CodeGen::gen_expr($cg, $inner_obj);
            }
            Perla::CodeGen::emit($cg, ", __k, __hv_val); free(__k); ");
            if ($is_env_assign_ah == 1) {
                Perla::CodeGen::emit($cg, "{ char *__envk = strada_to_str(");
                Perla::CodeGen::gen_expr($cg, $tkey);
                Perla::CodeGen::emit($cg, "); char *__envv = strada_to_str(__hv_val); ");
                Perla::CodeGen::emit($cg, "if (__envk && __envv) setenv(__envk, __envv, 1); ");
                Perla::CodeGen::emit($cg, "if (__envk) free(__envk); if (__envv) free(__envv); } ");
            }
            if ($is_sig_assign_ah == 1) {
                Perla::CodeGen::emit($cg, "{ char *__sigk = strada_to_str(");
                Perla::CodeGen::gen_expr($cg, $tkey);
                Perla::CodeGen::emit($cg, "); if (__sigk) { perla_install_signal(__sigk, __hv_val); free(__sigk); } } ");
            }
            Perla::CodeGen::emit($cg, "__hv_val; })");
