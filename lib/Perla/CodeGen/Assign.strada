                Perla::CodeGen::gen_expr($cg, $inner_hash);
            }
            Perla::CodeGen::emit($cg, ", __k, __hv_val); free(__k); ");
            if ($is_env_assign == 1) {
                Perla::CodeGen::emit($cg, "{ char *__envk = strada_to_str(");
                Perla::CodeGen::gen_expr($cg, $target->{"key"});
                Perla::CodeGen::emit($cg, "); char *__envv = strada_to_str(__hv_val); ");
                Perla::CodeGen::emit($cg, "if (__envk && __envv) setenv(__envk, __envv, 1); ");
                Perla::CodeGen::emit($cg, "if (__envk) free(__envk); if (__envv) free(__envv); } ");
            }
            if ($is_sig_assign == 1) {
                Perla::CodeGen::emit($cg, "{ char *__sigk = strada_to_str(");
                Perla::CodeGen::gen_expr($cg, $target->{"key"});
                Perla::CodeGen::emit($cg, "); if (__sigk) { perla_install_signal(__sigk, __hv_val); free(__sigk); } } ");
            }
            Perla::CodeGen::emit($cg, "__hv_val; })");
            return;
        }
        # Arrow hash assignment: $ref->{key} = val
        if ($target_type == Perla::AST::N_ARROW_HASH()) {

            my scalar $inner_obj = $target->{"object"};
            my int $inner_type = $inner_obj->{"type"};
            my scalar $tkey = $target->{"key"};
            # `$ENV{K} = V` (parses as N_ARROW_HASH on the $ENV scalar)
            # must also call setenv() so child processes (qx, system,
            # exec, popen) inherit the new value. Without this, Perl-
            # style "set var then shell out" patterns saw the parent's
            # hash mutated but the shell child still got the pre-change
            # env.
            my int $is_env_assign_ah = 0;
            if ($inner_type == Perla::AST::N_SCALAR_VAR()
                && defined($inner_obj->{"name"}) && $inner_obj->{"name"} eq "ENV") {
