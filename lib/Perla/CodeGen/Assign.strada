            # is what perla's parser actually uses for `$h{k}`). Without
            # the hook here, only the v_SIG hash got the coderef and no
            # real C signal handler was installed — `kill 'USR1', $$`
            # then killed the process with default action. Mirror the
            # N_HASH_ELEM branch.
            my int $is_sig_assign_ah = 0;
            if ($inner_type == Perla::AST::N_SCALAR_VAR()
                && defined($inner_obj->{"name"}) && $inner_obj->{"name"} eq "SIG") {
                $is_sig_assign_ah = 1;
            }

            # Perl's `$r->{k} = $v` evaluates to $v — capture RHS in a temp
            # and yield it from the statement expression. Returning NULL
            # here made Mo-style accessors silently return undef from
            # `$_[0]{$n} = $g->(@_)`.
            # Check for string literal or bareword key — emit directly.
            # For N_INTERP_STR (double-quoted) the raw value still has
            # Perl escape sequences like `\n` (backslash-n) — those must
            # be converted to actual C escapes so the runtime sees the
            # intended byte sequence. _escape_perl_dq_for_c does that;
            # _escape_c_str alone just doubles every backslash, leaving
            # `$h{"a\nb"}` with a 4-char key "a\nb" instead of "a\nb"
            # (3 bytes with a real newline).
            if (defined($tkey) && $tkey->{"type"} == Perla::AST::N_STR_LIT()) {
                Perla::CodeGen::emit($cg, "({ char *__k = strdup(\"" . Perla::CodeGen::Escape::escape_c_str($tkey->{"value"}) . "\"); StradaValue *__hv_val = ");
                Perla::CodeGen::gen_expr($cg, $node->{"value"});
                Perla::CodeGen::emit($cg, "; strada_hv_store(");
            } elsif (defined($tkey) && $tkey->{"type"} == Perla::AST::N_INTERP_STR() && Perla::CodeGen::has_perl_var($tkey->{"value"}) == 0) {
                Perla::CodeGen::emit($cg, "({ char *__k = strdup(\"" . Perla::CodeGen::Escape::perl_interp_literal_to_c($tkey->{"value"}) . "\"); StradaValue *__hv_val = ");
                Perla::CodeGen::gen_expr($cg, $node->{"value"});
                Perla::CodeGen::emit($cg, "; strada_hv_store(");
            } elsif (defined($tkey) && $tkey->{"type"} == Perla::AST::N_CALL() && defined($tkey->{"name"}) && length($tkey->{"name"}) > 0 && (!defined($tkey->{"args"}) || scalar(@{$tkey->{"args"}}) == 0)) {
                # Zero-arg bareword as key only — `{lc($conf)}` must call lc()
