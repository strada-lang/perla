# Perla::CodeGen::Assign - Assignment & compound-assignment code generation.
#
# Extracted from CodeGen.strada. Owns _gen_assign (scalar/list/slice/deref
# assignment) and the compound-assignment helpers (+=, .=, ||=, //=, and
# ++/-- on hash/array/deref lvalues).
#
# Calls back into the main Perla::CodeGen via body-less `extern func` decls
# (can't `use` it: cycle). _gen_binop lives in the sibling
# Perla::CodeGen::Operator module; we reach it via an `extern func` decl
# rather than `use` to avoid an Operator<->Assign use-cycle.

use Perla::AST;
use Perla::Lexer;
use Perla::Parser;
use Perla::CodeGen::Escape;
use Perla::CodeGen::Predicate;
use Perla::CodeGen::Subst;

package Perla::CodeGen::Assign;

extern func Perla::CodeGen::Operator::_gen_binop(scalar $cg, scalar $node) void;
extern func Perla::CodeGen::_perla_has_mangle_collision(str $name) int;

# Forward decls for Perla::CodeGen helpers we call inline.
extern func Perla::CodeGen::_emit_our_sync(scalar $cg, scalar $node) void;
extern func Perla::CodeGen::_emit_pkg_scalar_compound(scalar $cg, scalar $node, str $op, scalar $value) void;
extern func Perla::CodeGen::_gen_autoviv_array_value(scalar $cg, scalar $node) void;
extern func Perla::CodeGen::_gen_autoviv_hash(scalar $cg, scalar $node) void;
extern func Perla::CodeGen::_gen_autoviv_outer_hash(scalar $cg, scalar $node, int $hash_context) void;
extern func Perla::CodeGen::_is_our_unqual_scalar(scalar $cg, scalar $node) int;
extern func Perla::CodeGen::_is_pkg_qualified_scalar(scalar $node) int;
extern func Perla::CodeGen::_split_pkg_qual_name(scalar $node) array;
extern func Perla::CodeGen::_strict_check_var(scalar $cg, str $sigil, str $name, int $line) void;
extern func Perla::CodeGen::c_var(str $name) str;
extern func Perla::CodeGen::c_var_a(str $name) str;
extern func Perla::CodeGen::c_var_h(str $name) str;
extern func Perla::CodeGen::emit(scalar $cg, str $s) void;
extern func Perla::CodeGen::expr_is_borrowed(scalar $node) int;
extern func Perla::CodeGen::gen_expr(scalar $cg, scalar $node) void;
extern func Perla::CodeGen::gen_scalar_ctx_expr(scalar $cg, scalar $expr) void;
extern func Perla::CodeGen::has_perl_var(str $s) int;
extern func Perla::CodeGen::ind(scalar $cg) void;

# --- Assignment ---
func _gen_assign(scalar $cg, scalar $node) void {
    my str $op = $node->{"op"};
    my scalar $target = $node->{"target"};
    my int $target_type = $target->{"type"};

    # `use bigint` — desugar arithmetic compound assignment `$x OP= $y` into
    # `$x = $x OP $y` so it flows through the arbitrary-precision binop hook in
    # Perla::CodeGen::Operator::_gen_binop (which the per-operator compound paths below don't use). Covers
    # the factorial idiom `$f *= $_`. (Re-evaluates the target expression; only
    # matters for targets with side effects, which are rare under use bigint.)
    if (defined($cg->{"use_bigint"}) && $cg->{"use_bigint"} == 1
        && ($op eq "+=" || $op eq "-=" || $op eq "*=" || $op eq "**="
            || $op eq "/=" || $op eq "%=")) {
        my str $bi_base = substr($op, 0, length($op) - 1);
        my scalar $bi_bin = Perla::AST::node(Perla::AST::N_BINOP());
        $bi_bin->{"op"} = $bi_base;
        $bi_bin->{"left"} = $target;
        $bi_bin->{"right"} = $node->{"value"};
        my scalar $bi_asn = Perla::AST::node(Perla::AST::N_ASSIGN());
        $bi_asn->{"op"} = "=";
        $bi_asn->{"target"} = $target;
        $bi_asn->{"value"} = $bi_bin;
        _gen_assign($cg, $bi_asn);
        return;
    }

    # `$1 = X` / `$& = X` — regex capture variables are read-only in Perl.
    # gen_expr emits `strada_capture_var(N)` (a function call, not lvalue)
    # so the standard assignment path fails to compile. Emit a runtime
    # die so the user sees a meaningful error (matching Perl behavior:
    # "Modification of a read-only value attempted") instead of a gcc
    # error. Common surfaced via `s///e` replacements that incidentally
    # produce expressions like `$1=@{[expr]}`.
    if ($target_type == Perla::AST::N_SCALAR_VAR()
        && defined($target->{"name"})) {
        my str $__ro_name = $target->{"name"};
        if ((length($__ro_name) == 1 && $__ro_name ge "1" && $__ro_name le "9")
            || $__ro_name eq "&") {
            Perla::CodeGen::emit($cg, "({ ");
            Perla::CodeGen::gen_expr($cg, $node->{"value"});
            Perla::CodeGen::emit($cg, "; strada_die(\"%s\", \"Modification of a read-only value attempted\"); strada_new_undef(); })");
            return;
        }
    }

    # `$#arr = N` — truncate or extend @arr so its last index becomes N.
    # `$#arr` is parsed as N_SPECIAL_VAR with value "#NAME". The rvalue
    # form returns the current last index; the lvalue form mutates the
    # array's size.
    if ($op eq "=" && $target_type == Perla::AST::N_SPECIAL_VAR()
        && defined($target->{"value"}) && substr($target->{"value"}, 0, 1) eq "#") {
        my str $lia_name = substr($target->{"value"}, 1, length($target->{"value"}) - 1);
        my str $lia_cvar = Perla::CodeGen::c_var_a($lia_name);
        if ($lia_name eq "_") { $lia_cvar = "perla_at_"; }
        Perla::CodeGen::emit($cg, "({ int __new_last = (int)strada_to_int(");
        Perla::CodeGen::gen_expr($cg, $node->{"value"});
        Perla::CodeGen::emit($cg, "); StradaArray *__lav = strada_deref_array(" . $lia_cvar . "); ");
        Perla::CodeGen::emit($cg, "if (__lav) { ");
        Perla::CodeGen::emit($cg, "int __new_sz = __new_last + 1; if (__new_sz < 0) __new_sz = 0; ");
        # Shrink: decref removed elements and reduce size.
        Perla::CodeGen::emit($cg, "while ((int)__lav->size > __new_sz) { StradaValue *__re = __lav->elements[__lav->head + __lav->size - 1]; if (__re) strada_decref(__re); __lav->size--; } ");
        # Extend: pad with undef.
        Perla::CodeGen::emit($cg, "while ((int)__lav->size < __new_sz) { strada_array_push(__lav, strada_new_undef()); } ");
        Perla::CodeGen::emit($cg, "} STRADA_MAKE_TAGGED_INT((int64_t)__new_last); })");
        return;
    }

    # `$0 = "name"` — assign to the program-name special. Its read-path
    # emits a NULL-check ternary which is not a C lvalue, so handle the
    # assignment directly against the underlying global.
    if ($op eq "=" && $target_type == Perla::AST::N_SCALAR_VAR()
        && defined($target->{"name"}) && $target->{"name"} eq "0") {
        Perla::CodeGen::emit($cg, "({ StradaValue *__d0v = ");
        Perla::CodeGen::gen_expr($cg, $node->{"value"});
        Perla::CodeGen::emit($cg, "; if (perla_dollar_zero) strada_decref(perla_dollar_zero); perla_dollar_zero = __d0v; if (perla_dollar_zero) strada_incref(perla_dollar_zero); perla_dollar_zero; })");
        return;
    }

    # `$? = N` — assign to the child-exit-status special. Read-path
    # wraps perla_dollar_question in STRADA_MAKE_TAGGED_INT(...) which
    # isn't an lvalue. Write directly to the underlying int.
    if ($op eq "=" && $target_type == Perla::AST::N_SCALAR_VAR()
        && defined($target->{"name"}) && $target->{"name"} eq "?") {
        Perla::CodeGen::emit($cg, "({ int64_t __dqv = strada_to_int(");
        Perla::CodeGen::gen_expr($cg, $node->{"value"});
        Perla::CodeGen::emit($cg, "); perla_dollar_question = (int)__dqv; STRADA_MAKE_TAGGED_INT(__dqv); })");
        return;
    }

    # List-destructure assignment: `(A, B, C) = RHS`. RHS is evaluated
    # once in list context; each lvalue receives the corresponding
    # element (or undef when the list is shorter). An ARRAY_VAR in the
    # lvalue list slurps remaining elements; a HASH_VAR collects
    # remaining pairs. Used by e.g. `($h->{x}, $h->{y}) = split ...`
    # (YAML::Loader) and `my ($a, $b) = @list` (the N_MY path has its
    # own handler, this is the non-my form).
    if ($op eq "=" && $target_type == Perla::AST::N_ANON_ARRAY() && defined($target->{"elems"})) {
        my scalar $lhs_elems = $target->{"elems"};
        my int $nlhs = scalar(@{$lhs_elems});
        Perla::CodeGen::emit($cg, "({ int __sav_wl_ld = __perla_want_list; __perla_want_list = 1; StradaValue *__ld_rhs = ");
        Perla::CodeGen::gen_expr($cg, $node->{"value"});
        Perla::CodeGen::emit($cg, "; __perla_want_list = __sav_wl_ld; StradaArray *__ld_av = strada_deref_array(__ld_rhs); ");
        Perla::CodeGen::emit($cg, "StradaValue *__ld_fb = NULL; ");
        # `(...) = %h` — flatten hash to (k,v,k,v,...).
        Perla::CodeGen::emit($cg, "if (!__ld_av && __ld_rhs && !STRADA_IS_TAGGED_INT(__ld_rhs) && __ld_rhs->type == STRADA_HASH && __ld_rhs->value.hv) { ");
        Perla::CodeGen::emit($cg, "  __ld_fb = strada_new_array(); StradaArray *__ldhf_av = strada_deref_array(__ld_fb); ");
        Perla::CodeGen::emit($cg, "  StradaArray *__ldhf_keys = strada_hash_keys(__ld_rhs->value.hv); ");
        Perla::CodeGen::emit($cg, "  if (__ldhf_keys) { for (size_t __ldhf_i = 0; __ldhf_i < __ldhf_keys->size; __ldhf_i++) { ");
        Perla::CodeGen::emit($cg, "    StradaValue *__ldhf_k = __ldhf_keys->elements[__ldhf_keys->head + __ldhf_i]; ");
        Perla::CodeGen::emit($cg, "    char *__ldhf_ks = strada_to_str(__ldhf_k); ");
        Perla::CodeGen::emit($cg, "    StradaValue *__ldhf_v = strada_hash_get(__ld_rhs->value.hv, __ldhf_ks); ");
        Perla::CodeGen::emit($cg, "    free(__ldhf_ks); ");
        Perla::CodeGen::emit($cg, "    if (__ldhf_k) strada_incref(__ldhf_k); strada_array_push(__ldhf_av, __ldhf_k); ");
        Perla::CodeGen::emit($cg, "    if (__ldhf_v) strada_incref(__ldhf_v); strada_array_push(__ldhf_av, __ldhf_v); ");
        Perla::CodeGen::emit($cg, "  } strada_free_array(__ldhf_keys); } __ld_av = __ldhf_av; ");
        Perla::CodeGen::emit($cg, "} else if (!__ld_av && __ld_rhs) { __ld_fb = strada_new_array(); strada_array_push(strada_deref_array(__ld_fb), __ld_rhs); __ld_av = strada_deref_array(__ld_fb); } ");
        Perla::CodeGen::emit($cg, "int __ld_len = __ld_av ? strada_array_length(__ld_av) : 0; ");
        my int $li = 0;
        while ($li < $nlhs) {
            my scalar $lelem = $lhs_elems->[$li];
            my int $ltype = $lelem->{"type"};
            if ($ltype == Perla::AST::N_ARRAY_VAR()) {
                # Slurp remainder into array.
                Perla::CodeGen::emit($cg, "{ StradaArray *__slurp_av = strada_deref_array(" . Perla::CodeGen::c_var_a($lelem->{"name"}) . "); ");
                Perla::CodeGen::emit($cg, "if (__slurp_av) { while (__slurp_av->size > 0) { StradaValue *__old = __slurp_av->elements[__slurp_av->head + __slurp_av->size - 1]; __slurp_av->size--; if (__old) strada_decref(__old); } ");
                Perla::CodeGen::emit($cg, "for (int __ri = " . $li . "; __ri < __ld_len; __ri++) { StradaValue *__e = strada_array_get(__ld_av, __ri); if (__e) strada_incref(__e); strada_array_push(__slurp_av, __e); } } } ");
                $li = $nlhs;
            } elsif ($ltype == Perla::AST::N_DEREF_ARRAY()) {
                # `(SCALAR, @$ref) = LIST` — slurp remainder into the array
                # ref'd by SCALAR (autoviv if undef). Used by DBIC's
                # `($sql, @$bind) = $self->sql_maker->$op(...)` and similar.
                # Without this the fallback emits the deref expression as
                # the LHS of `=`, which gcc rejects ("lvalue required").
                my scalar $ref_node = $lelem->{"ref"};
                if (defined($ref_node) && $ref_node->{"type"} == Perla::AST::N_SCALAR_VAR()) {
                    my str $rvc = Perla::CodeGen::c_var($ref_node->{"name"});
                    Perla::CodeGen::emit($cg, "{ StradaValue *__sr = " . $rvc . "; ");
                    Perla::CodeGen::emit($cg, "if (!__sr || STRADA_IS_TAGGED_INT(__sr) || __sr->type != STRADA_REF || !__sr->value.rv || __sr->value.rv->type != STRADA_ARRAY) { ");
                    Perla::CodeGen::emit($cg, "  StradaValue *__newref = strada_new_ref_take(strada_new_array(), '@'); ");
                    Perla::CodeGen::emit($cg, "  if (" . $rvc . ") strada_decref(" . $rvc . "); ");
                    Perla::CodeGen::emit($cg, "  " . $rvc . " = __newref; __sr = __newref; ");
                    Perla::CodeGen::emit($cg, "} StradaArray *__slurp_da = strada_deref_array(__sr); ");
                    Perla::CodeGen::emit($cg, "if (__slurp_da) { while (__slurp_da->size > 0) { StradaValue *__o = __slurp_da->elements[__slurp_da->head + __slurp_da->size - 1]; __slurp_da->size--; if (__o) strada_decref(__o); } ");
                    Perla::CodeGen::emit($cg, "for (int __ri = " . $li . "; __ri < __ld_len; __ri++) { StradaValue *__e = strada_array_get(__ld_av, __ri); if (__e) strada_incref(__e); strada_array_push(__slurp_da, __e); } } } ");
                } else {
                    # Generic case: evaluate the ref expression, deref, slurp.
                    # No autoviv for complex lvalues — caller is responsible.
                    Perla::CodeGen::emit($cg, "{ StradaArray *__slurp_da = strada_deref_array(");
                    Perla::CodeGen::gen_expr($cg, $ref_node);
                    Perla::CodeGen::emit($cg, "); if (__slurp_da) { while (__slurp_da->size > 0) { StradaValue *__o = __slurp_da->elements[__slurp_da->head + __slurp_da->size - 1]; __slurp_da->size--; if (__o) strada_decref(__o); } ");
                    Perla::CodeGen::emit($cg, "for (int __ri = " . $li . "; __ri < __ld_len; __ri++) { StradaValue *__e = strada_array_get(__ld_av, __ri); if (__e) strada_incref(__e); strada_array_push(__slurp_da, __e); } } } ");
                }
                $li = $nlhs;
            } elsif ($ltype == Perla::AST::N_HASH_VAR()) {
                # Slurp remainder into hash as key/value pairs.
                Perla::CodeGen::emit($cg, "{ StradaHash *__slurp_hv = strada_deref_hash(" . Perla::CodeGen::c_var_h($lelem->{"name"}) . "); ");
                Perla::CodeGen::emit($cg, "if (__slurp_hv) { for (int __ri = " . $li . "; __ri + 1 < __ld_len; __ri += 2) { ");
                Perla::CodeGen::emit($cg, "char *__hk = strada_to_str(strada_array_get(__ld_av, __ri)); strada_hash_set(__slurp_hv, __hk, strada_array_get(__ld_av, __ri + 1)); free(__hk); } } } ");
                $li = $nlhs;
            } elsif ($ltype == Perla::AST::N_UNDEF()) {
                # `(undef, $x) = LIST` — discard this slot, advance index.
                $li++;
            } else {
                # `my $x` (and the other sigils) appearing inline as a list
                # element — common idiom: `($attrs->{k}, my $new_order) = ...`.
                # Without this branch, the fallback _gen_expr emits the
                # auto-init pattern `(v_new_order = strada_new_undef())`,
                # which we then suffix with ` = __ld_v` — invalid C
                # ("lvalue required as left operand of assignment").
                # Treat as a plain scalar/array/hash assignment and rely on
                # the file-scope auto-decl post-pass to declare the var.
                # The N_MY node carries the var(s) under either ->{"var"}
                # (single, e.g. `my $x`) or ->{"vars"} (plural, e.g.
                # `my ($a, $b)`); both shapes can land here.
                if ($ltype == Perla::AST::N_MY()) {
                    my scalar $myvar = undef;
                    if (defined($lelem->{"var"})) {
                        $myvar = $lelem->{"var"};
                    } elsif (defined($lelem->{"vars"}) && scalar(@{$lelem->{"vars"}}) == 1) {
                        $myvar = $lelem->{"vars"}->[0];
                    }
                    if (defined($myvar)) {
                        my str $myvtype = "" . $myvar->{"type"};
                        my str $myvname = $myvar->{"value"};
                        if (length($myvtype) == 0) { $myvtype = "SCALAR_VAR"; }
                    if ($myvtype eq "SCALAR_VAR") {
                        $lelem = Perla::AST::node_with(Perla::AST::N_SCALAR_VAR(), "name", $myvname);
                        $ltype = Perla::AST::N_SCALAR_VAR();
                    } elsif ($myvtype eq "ARRAY_VAR") {
                        $lelem = Perla::AST::node_with(Perla::AST::N_ARRAY_VAR(), "name", $myvname);
                        $ltype = Perla::AST::N_ARRAY_VAR();
                        # Re-dispatch: array slurp behaves like the top-level branch.
                        # Easiest is just to re-enter the loop iteration, but we
                        # already consumed the index, so inline the slurp here.
                        Perla::CodeGen::emit($cg, "{ StradaArray *__slurp_av = strada_deref_array(" . Perla::CodeGen::c_var_a($myvname) . " ? " . Perla::CodeGen::c_var_a($myvname) . " : (" . Perla::CodeGen::c_var_a($myvname) . " = strada_new_array())); ");
                        Perla::CodeGen::emit($cg, "if (__slurp_av) { while (__slurp_av->size > 0) { StradaValue *__old = __slurp_av->elements[__slurp_av->head + __slurp_av->size - 1]; __slurp_av->size--; if (__old) strada_decref(__old); } ");
                        Perla::CodeGen::emit($cg, "for (int __ri = " . $li . "; __ri < __ld_len; __ri++) { StradaValue *__e = strada_array_get(__ld_av, __ri); if (__e) strada_incref(__e); strada_array_push(__slurp_av, __e); } } } ");
                        $li = $nlhs;
                        next;
                    }
                    # HASH_VAR slurp would mirror ARRAY_VAR; left out for now —
                    # add when an actual case appears. Falls through to the
                    # generic SCALAR_VAR path otherwise.
                    }
                }
                # Scalar lvalue at position $li. Assign from __ld_av[$li] or undef.
                my scalar $vnode = Perla::AST::node(Perla::AST::N_ASSIGN());
                $vnode->{"op"} = "=";
                $vnode->{"target"} = $lelem;
                # Wrap the get in a dummy AST node we can feed to _gen_expr.
                # Simpler: inline emit the get.
                Perla::CodeGen::emit($cg, "({ StradaValue *__ld_v = (" . $li . " < __ld_len) ? strada_array_get(__ld_av, " . $li . ") : strada_new_undef(); ");
                # Emit assignment target = __ld_v as statement expression.
                # We synthesize a small assignment by re-using the existing codegen paths for each lvalue kind.
                if ($ltype == Perla::AST::N_SCALAR_VAR()) {
                    Perla::CodeGen::emit($cg, Perla::CodeGen::c_var($lelem->{"name"}) . " = __ld_v; ");
                } elsif ($ltype == Perla::AST::N_ARROW_HASH()) {
                    # $ref->{key} = __ld_v
                    Perla::CodeGen::emit($cg, "{ char *__ahk; ");
                    my scalar $key_n = $lelem->{"key"};
                    if (defined($key_n) && ($key_n->{"type"} == Perla::AST::N_STR_LIT() || ($key_n->{"type"} == Perla::AST::N_INTERP_STR() && Perla::CodeGen::has_perl_var($key_n->{"value"}) == 0))) {
                        Perla::CodeGen::emit($cg, "__ahk = strdup(\"" . Perla::CodeGen::Escape::escape_c_str($key_n->{"value"}) . "\"); ");
                    } elsif (defined($key_n) && $key_n->{"type"} == Perla::AST::N_CALL() && defined($key_n->{"name"}) && length($key_n->{"name"}) > 0) {
                        Perla::CodeGen::emit($cg, "__ahk = strdup(\"" . Perla::CodeGen::Escape::escape_c_str($key_n->{"name"}) . "\"); ");
                    } else {
                        Perla::CodeGen::emit($cg, "__ahk = strada_to_str(");
                        if (defined($key_n)) { Perla::CodeGen::gen_expr($cg, $key_n); } else { Perla::CodeGen::emit($cg, "perla_dollar_underscore"); }
                        Perla::CodeGen::emit($cg, "); ");
                    }
                    Perla::CodeGen::emit($cg, "strada_hv_store(");
                    Perla::CodeGen::gen_expr($cg, $lelem->{"object"});
                    Perla::CodeGen::emit($cg, ", __ahk, __ld_v); free(__ahk); }");
                } elsif ($ltype == Perla::AST::N_HASH_ELEM()) {
                    Perla::CodeGen::emit($cg, "{ char *__ahk = strada_to_str(");
                    Perla::CodeGen::gen_expr($cg, $lelem->{"key"});
                    Perla::CodeGen::emit($cg, "); strada_hv_store(");
                    Perla::CodeGen::gen_expr($cg, $lelem->{"hash"});
                    Perla::CodeGen::emit($cg, ", __ahk, __ld_v); free(__ahk); }");
                } elsif ($ltype == Perla::AST::N_ARROW_ARRAY()) {
                    Perla::CodeGen::emit($cg, "{ StradaArray *__aav = strada_deref_array(");
                    Perla::CodeGen::gen_expr($cg, $lelem->{"object"});
                    Perla::CodeGen::emit($cg, "); int __aai = (int)strada_to_int(");
                    Perla::CodeGen::gen_expr($cg, $lelem->{"index"});
                    Perla::CodeGen::emit($cg, "); strada_array_set(__aav, __aai, __ld_v); }");
                } elsif ($ltype == Perla::AST::N_ARRAY_ELEM()) {
                    Perla::CodeGen::emit($cg, "{ StradaArray *__aav = strada_deref_array(");
                    Perla::CodeGen::gen_expr($cg, $lelem->{"array"});
                    Perla::CodeGen::emit($cg, "); int __aai = (int)strada_to_int(");
                    Perla::CodeGen::gen_expr($cg, $lelem->{"index"});
                    Perla::CodeGen::emit($cg, "); if (__aai < 0 && __aav) __aai += strada_array_length(__aav); strada_array_set(__aav, __aai, __ld_v); }");
                } elsif ($ltype == Perla::AST::N_DEREF_SCALAR()) {
                    # `($$a, $$b) = (X, Y)` — list-assign through scalar
                    # derefs. The fallback `Perla::CodeGen::gen_expr(lelem) = __ld_v` would
                    # emit `({ __dsv; }) = ...` (statement-expression rvalue
                    # — not a lvalue). Route through strada_deref_set so the
                    # write reaches the slot (for slot refs) or
                    # strada_overwrite_in_place (for heap refs).
                    Perla::CodeGen::emit($cg, "{ StradaValue *__dsref = ");
                    Perla::CodeGen::gen_expr($cg, $lelem->{"ref"});
                    Perla::CodeGen::emit($cg, "; if (__dsref && !STRADA_IS_TAGGED_INT(__dsref) && __dsref->type == STRADA_REF) { ");
                    Perla::CodeGen::emit($cg, "  if (strada_is_slot_ref(__dsref)) { strada_deref_set(__dsref, __ld_v); } ");
                    Perla::CodeGen::emit($cg, "  else if (__dsref->value.rv) { strada_overwrite_in_place(__dsref->value.rv, __ld_v); } ");
                    Perla::CodeGen::emit($cg, "} }");
                } elsif ($ltype == Perla::AST::N_GLOB_ACCESS()) {
                    # `(*$ga, *$gb) = (\1, \2)` / `local (*A, *B) = @_` —
                    # typeglob targets in a list assignment
                    # (List::MoreUtils::pairwise and the DBIC Relationship
                    # helpers localise *a/*b exactly this way). The fallback
                    # below would emit the rvalue glob-fetch
                    # statement-expression and assign to it — invalid C
                    # ("lvalue required as left operand of assignment").
                    # Route through the same runtime assigns the scalar
                    # `*{EXPR} = value` / `*Name = value` forms use.
                    my scalar $lgexpr = $lelem->{"expr"};
                    if (defined($lgexpr)) {
                        Perla::CodeGen::emit($cg, "{ StradaValue *__gan = ");
                        Perla::CodeGen::gen_expr($cg, $lgexpr);
                        Perla::CodeGen::emit($cg, "; perla_glob_assign_dynamic_pkg(__gan, __ld_v, \"" . $cg->{"pkg"} . "\"); }");
                    } else {
                        my str $lgname = "" . $lelem->{"name"};
                        my int $lgsep = -1;
                        my int $lgi = length($lgname) - 1;
                        while ($lgi >= 0) {
                            if ($lgi > 0 && substr($lgname, $lgi - 1, 2) eq "::") { $lgsep = $lgi - 1; last; }
                            $lgi--;
                        }
                        my str $lgpkg = $cg->{"pkg"};
                        my str $lgshort = $lgname;
                        if ($lgsep >= 0) {
                            $lgpkg = substr($lgname, 0, $lgsep);
                            $lgshort = substr($lgname, $lgsep + 2, length($lgname) - $lgsep - 2);
                        }
                        Perla::CodeGen::emit($cg, "perla_glob_assign(perla_glob_get_or_create(perla_stash_get_or_create(\""
                            . Perla::CodeGen::Escape::escape_c_str($lgpkg) . "\"), \""
                            . Perla::CodeGen::Escape::escape_c_str($lgshort) . "\"), __ld_v); ");
                    }
                } else {
                    # Fallback: try plain assignment (may fail for unsupported lvalues).
                    Perla::CodeGen::gen_expr($cg, $lelem);
                    Perla::CodeGen::emit($cg, " = __ld_v; ");
                }
                Perla::CodeGen::emit($cg, " __ld_v; }); ");
                $li++;
            }
        }
        # In scalar context, list assignment evaluates to the number of
        # elements on the RHS (Perl semantics for `(A,B,C) = LIST` and the
        # `()= LIST` idiom: `my $n = () = LIST` is the classic count-the-list
        # idiom). The list (`__ld_rhs`) is what propagates in list context.
        Perla::CodeGen::emit($cg, "(__perla_want_list ? __ld_rhs : STRADA_MAKE_TAGGED_INT(__ld_len)); })");
        return;
    }

    # Ternary-target lvalue: (cond ? A : B) OP= RHS → dispatch to A or B.
    # Perl lets you write `($cond ? $a : $b) = $x` and its `||=` / `//=`
    # cousins, but C has no ternary-as-lvalue. Rewrite at codegen time into
    # a branching statement expression that delegates to the existing
    # per-op codegen on the selected side.
    if ($target_type == Perla::AST::N_TERNARY()) {
        my scalar $then_node = Perla::AST::node(Perla::AST::N_ASSIGN());
        $then_node->{"op"} = $op;
        $then_node->{"target"} = $target->{"then"};
        $then_node->{"value"} = $node->{"value"};
        my scalar $else_node = Perla::AST::node(Perla::AST::N_ASSIGN());
        $else_node->{"op"} = $op;
        $else_node->{"target"} = $target->{"else"};
        $else_node->{"value"} = $node->{"value"};
        Perla::CodeGen::emit($cg, "({ StradaValue *__tr; if (perla_to_bool(");
        Perla::CodeGen::gen_expr($cg, $target->{"cond"});
        Perla::CodeGen::emit($cg, ")) { __tr = ");
        _gen_assign($cg, $then_node);
        Perla::CodeGen::emit($cg, "; } else { __tr = ");
        _gen_assign($cg, $else_node);
        Perla::CodeGen::emit($cg, "; } __tr; })");
        return;
    }

    if ($op eq "=") {
        # @ISA = qw(Parent1 Parent2) — as a standalone assignment (not part
        # of `our @ISA = ...` which _gen_our already handles). Many modules
        # do `our (@ISA, @EXPORT); @ISA = qw(Exporter);` as two statements;
        # without this path we'd only set v_ISA and skip the stash ISA push.
        if ($target_type == Perla::AST::N_ARRAY_VAR() && defined($target->{"name"}) && $target->{"name"} eq "ISA") {
            my str $isa_pkg = $cg->{"pkg"};
            my scalar $iv = $node->{"value"};
            if (defined($iv) && ($iv->{"type"} == Perla::AST::N_ANON_ARRAY() || $iv->{"type"} == Perla::AST::N_QWORD())) {
                my scalar $ie = $iv->{"elems"};
                my int $ii = 0;
                while ($ii < scalar(@{$ie})) {
                    my scalar $iel = $ie->[$ii];
                    if ($iel->{"type"} == Perla::AST::N_STR_LIT() || $iel->{"type"} == Perla::AST::N_INTERP_STR()) {
                        Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "perla_isa_push(\"" . $isa_pkg . "\", \"" . $iel->{"value"} . "\");\n");
                    }
                    $ii++;
                }
                Perla::CodeGen::emit($cg, "(StradaValue*)NULL");
                return;
            }
            if (defined($iv) && ($iv->{"type"} == Perla::AST::N_STR_LIT() || $iv->{"type"} == Perla::AST::N_INTERP_STR())) {
                Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "perla_isa_push(\"" . $isa_pkg . "\", \"" . $iv->{"value"} . "\");\n");
                Perla::CodeGen::emit($cg, "(StradaValue*)NULL");
                return;
            }
            # Fall through to normal array assignment for complex RHS
        }
        # *Foo::bar = \&func or *{expr} = \&func — typeglob assignment
        if ($target_type == Perla::AST::N_GLOB_ACCESS()) {
            my scalar $gexpr = $target->{"expr"};
            if (defined($gexpr)) {
                # Dynamic: *{EXPR} = value
                Perla::CodeGen::emit($cg, "({ StradaValue *__gv = ");
                Perla::CodeGen::gen_expr($cg, $node->{"value"});
                Perla::CodeGen::emit($cg, "; StradaValue *__gn = ");
                Perla::CodeGen::gen_expr($cg, $gexpr);
                Perla::CodeGen::emit($cg, "; perla_glob_assign_dynamic_pkg(__gn, __gv, \"" . $cg->{"pkg"} . "\"); __gv; })");
                return;
            }
            my str $gname = $target->{"name"};
            # Split into pkg::name
            my int $sep = -1;
            my int $gi = length($gname) - 1;
            while ($gi >= 0) {
                if ($gi > 0 && substr($gname, $gi - 1, 2) eq "::") { $sep = $gi - 1; last; }
                $gi--;
            }
            my str $gpkg = $cg->{"pkg"};
            my str $gshort = $gname;
            if ($sep >= 0) {
                $gpkg = substr($gname, 0, $sep);
                $gshort = substr($gname, $sep + 2, length($gname) - $sep - 2);
            }
            # `*dst = *src` — typeglob alias. The RHS gen_expr for
            # N_GLOB_ACCESS returns only the CODE slot, so a plain
            # perla_glob_assign would copy only the code (losing scalar /
            # array / hash slots). Detect a static N_GLOB_ACCESS RHS and
            # emit perla_glob_alias to copy ALL slots. Perl idiom: alias
            # one symbol-table entry to another (see Exporter's `import`,
            # Sub::Install, and Perl 5's `*foo = *bar` pattern). Without
            # this, `$foo` reads via the alias return undef.
            my scalar $vnode = $node->{"value"};
            if (defined($vnode) && $vnode->{"type"} == Perla::AST::N_GLOB_ACCESS()
                && !defined($vnode->{"expr"}) && defined($vnode->{"name"})) {
                my str $srcname = $vnode->{"name"};
                my int $ssep = -1;
                my int $sgi = length($srcname) - 1;
                while ($sgi >= 0) {
                    if ($sgi > 0 && substr($srcname, $sgi - 1, 2) eq "::") { $ssep = $sgi - 1; last; }
                    $sgi--;
                }
                my str $spkg = $cg->{"pkg"};
                my str $sshort = $srcname;
                if ($ssep >= 0) {
                    $spkg = substr($srcname, 0, $ssep);
                    $sshort = substr($srcname, $ssep + 2, length($srcname) - $ssep - 2);
                }
                # Also mirror the source's C-static slots into the dest's
                # so unqualified reads of $dst/@dst/%dst (via v_dst, etc.)
                # see the aliased value. perla_glob_alias only copies the
                # stash slots; reads compile to `v_dst`, not a stash lookup.
                # Tied together they emulate Perl's "the symbol is now an
                # alias" semantic for both stash-qualified and unqualified
                # access paths.
                # STDIN/STDOUT/STDERR have no C-static mirror symbol (only an
                # extern decl), so syncing v_dst = v_STDOUT would reference an
                # undefined symbol and fail to link. perla_glob_alias copies
                # the source glob's slots (including IO) at the stash level,
                # which is what bareword `print DST ...` resolves through, so
                # skip the unqualified-mirror sync for these.
                my int $src_is_std = 0;
                if ($sshort eq "STDOUT" || $sshort eq "STDIN" || $sshort eq "STDERR") { $src_is_std = 1; }
                Perla::CodeGen::emit($cg, "({ perla_glob_alias(\"" . $gpkg . "\", \"" . $gshort . "\", \"" . $spkg . "\", \"" . $sshort . "\"); ");
                if ($src_is_std == 0) {
                    my str $dst_cvar_s = Perla::CodeGen::c_var($gshort);
                    my str $dst_cvar_a = Perla::CodeGen::c_var_a($gshort);
                    my str $dst_cvar_h = Perla::CodeGen::c_var_h($gshort);
                    my str $src_cvar_s = Perla::CodeGen::c_var($sshort);
                    my str $src_cvar_a = Perla::CodeGen::c_var_a($sshort);
                    my str $src_cvar_h = Perla::CodeGen::c_var_h($sshort);
                    Perla::CodeGen::emit($cg, "if (" . $dst_cvar_s . " != " . $src_cvar_s . ") { if (" . $dst_cvar_s . ") strada_decref(" . $dst_cvar_s . "); " . $dst_cvar_s . " = " . $src_cvar_s . "; if (" . $dst_cvar_s . ") strada_incref(" . $dst_cvar_s . "); } ");
                    Perla::CodeGen::emit($cg, "if (" . $dst_cvar_a . " != " . $src_cvar_a . ") { if (" . $dst_cvar_a . ") strada_decref(" . $dst_cvar_a . "); " . $dst_cvar_a . " = " . $src_cvar_a . "; if (" . $dst_cvar_a . ") strada_incref(" . $dst_cvar_a . "); } ");
                    Perla::CodeGen::emit($cg, "if (" . $dst_cvar_h . " != " . $src_cvar_h . ") { if (" . $dst_cvar_h . ") strada_decref(" . $dst_cvar_h . "); " . $dst_cvar_h . " = " . $src_cvar_h . "; if (" . $dst_cvar_h . ") strada_incref(" . $dst_cvar_h . "); } ");
                }
                # Aliasing from a standard handle: perla represents bareword
                # filehandles in the glob's SCALAR slot (open(FH,...) stores via
                # perla_scalar_set and `print FH ...` reads via perla_scalar_get),
                # so point DST's scalar slot at the libc stream. STDOUT/STDIN/
                # STDERR have no v_ mirror, hence the dedicated handling here.
                if ($src_is_std == 1) {
                    my str $stdstream = "stdout";
                    if ($sshort eq "STDIN") { $stdstream = "stdin"; }
                    if ($sshort eq "STDERR") { $stdstream = "stderr"; }
                    Perla::CodeGen::emit($cg, "perla_scalar_set(\"" . $gpkg . "\", \"" . $gshort . "\", strada_new_filehandle(" . $stdstream . ")); ");
                }
                Perla::CodeGen::emit($cg, "strada_new_undef(); })");
                return;
            }
            # `*Dst = \$ourvar` — taking a ref to an unqualified package
            # (our / file-scope) scalar. The default gen_expr for `\$var`
            # emits `strada_slot_ref_create(&v_var)`, pointing at the C-static
            # backing cell, NOT a glob slot. perla_glob_assign back-casts the
            # slot address to a PerlGlob* (slot_addr - offsetof(slots) ...);
            # for a static cell that recovers garbage and crashes in the
            # aliased_by realloc. Package scalars mirror every write into
            # their stash glob's SCALAR slot, so emit a slot ref to THAT glob
            # slot instead — perla_glob_assign then gets a valid glob, the
            # aliased_by registration is correct, and writes to $var fan out
            # to the aliased target. Real-world: FindBin::init's
            # `*Dir = \$Bin; *RealDir = \$RealBin;` (list-`our` vars).
            my scalar $gav = $node->{"value"};
            if (defined($gav) && $gav->{"type"} == Perla::AST::N_REF()
                && defined($gav->{"operand"})
                && $gav->{"operand"}->{"type"} == Perla::AST::N_SCALAR_VAR()
                && defined($gav->{"operand"}->{"name"})
                && index($gav->{"operand"}->{"name"}, "::") < 0) {
                my str $gavn = $gav->{"operand"}->{"name"};
                my int $gav_pkgvar = 0;
                if (defined($cg->{"our_vars"}) && exists($cg->{"our_vars"}->{$gavn})) { $gav_pkgvar = 1; }
                if (defined($cg->{"file_scope_vars"}) && exists($cg->{"file_scope_vars"}->{$gavn})) { $gav_pkgvar = 1; }
                if ($gav_pkgvar == 1) {
                    Perla::CodeGen::emit($cg, "({ StradaValue *__gv = strada_slot_ref_create(&perla_glob_get_or_create(perla_stash_get_or_create(\"" . $cg->{"pkg"} . "\"), \"" . $gavn . "\")->slots[PERLA_SLOT_SCALAR]); ");
                    Perla::CodeGen::emit($cg, "PerlGlob *__glob = perla_glob_get_or_create(perla_stash_get_or_create(\"" . $gpkg . "\"), \"" . $gshort . "\"); ");
                    Perla::CodeGen::emit($cg, "perla_glob_assign(__glob, __gv); __gv; })");
                    return;
                }
            }
            Perla::CodeGen::emit($cg, "({ StradaValue *__gv = ");
            Perla::CodeGen::gen_expr($cg, $node->{"value"});
            Perla::CodeGen::emit($cg, "; PerlGlob *__glob = perla_glob_get_or_create(perla_stash_get_or_create(\"" . $gpkg . "\"), \"" . $gshort . "\"); ");
            Perla::CodeGen::emit($cg, "perla_glob_assign(__glob, __gv); __gv; })");
            return;
        }
        # $$ref = value — write through scalar reference, or set the
        # named package scalar when the target is a STRING (symbolic
        # ref: `${"Pkg::NAME"} = $v`). Without the STR branch
        # Class::Accessor::Grouped's set_inherited would silently
        # store nothing, so DBIC class-data accessors install but
        # never persist their values.
        if ($target_type == Perla::AST::N_DEREF_SCALAR()) {
            # `${*$fh} = X` — store X in the filehandle glob's SCALAR
            # slot (on its meta). File::Temp->new does `${*$fh} = $path`.
            # Detect the glob-access-with-expr inner and route to the
            # per-filehandle slot setter.
            my scalar $__asref = $target->{"ref"};
            if (defined($__asref) && $__asref->{"type"} == Perla::AST::N_GLOB_ACCESS()
                && defined($__asref->{"expr"})) {
                Perla::CodeGen::emit($cg, "perla_fh_slot_set(");
                Perla::CodeGen::gen_expr($cg, $__asref->{"expr"});
                Perla::CodeGen::emit($cg, ", ");
                Perla::CodeGen::gen_expr($cg, $node->{"value"});
                Perla::CodeGen::emit($cg, ")");
                return;
            }
            # `$$ref = X` writes through the reference into the underlying
            # scalar's storage. Previously we replaced the ref's `rv`
            # pointer, which left the original variable's slot untouched
            # (so `$val` still saw the old value). Now we overwrite the
            # target StradaValue in place via strada_overwrite_in_place,
            # so all aliases — `$val`, `$$ref`, `\$val`, etc. — see the
            # new value.
            Perla::CodeGen::emit($cg, "({ StradaValue *__dref = ");
            Perla::CodeGen::gen_expr($cg, $target->{"ref"});
            Perla::CodeGen::emit($cg, "; StradaValue *__nv = ");
            Perla::CodeGen::gen_expr($cg, $node->{"value"});
            # Slot refs (created by `\\$var` for scalar locals or
            # \\$Pkg::var stash slots) store the address of the
            # variable's StradaValue* slot. Writing through them
            # updates the underlying C variable directly — required
            # for `$$r = X` to also update `$var` itself (Perl
            # aliasing). Use perla_scalar_deref_assign which handles
            # both slot refs AND stash-slot-→-local mirror sync (so
            # \\$Pkg::var writes propagate into pkg's compiled subs).
            Perla::CodeGen::emit($cg, "; if (__dref && !STRADA_IS_TAGGED_INT(__dref) && __dref->type == STRADA_REF && strada_is_slot_ref(__dref)) { ");
            Perla::CodeGen::emit($cg, "perla_scalar_deref_assign(__dref, __nv); } ");
            Perla::CodeGen::emit($cg, "else if (__dref && !STRADA_IS_TAGGED_INT(__dref) && __dref->type == STRADA_REF && __dref->value.rv && __dref->value.rv->meta && __dref->value.rv->meta->is_tied) { ");
            Perla::CodeGen::emit($cg, "strada_tied_scalar_store(__dref->value.rv, __nv); } ");
            Perla::CodeGen::emit($cg, "else if (__dref && !STRADA_IS_TAGGED_INT(__dref) && __dref->type == STRADA_REF && __dref->value.rv) { ");
            Perla::CodeGen::emit($cg, "strada_overwrite_in_place(__dref->value.rv, __nv); } ");
            Perla::CodeGen::emit($cg, "else if (__dref && !STRADA_IS_TAGGED_INT(__dref) && __dref->type == STRADA_STR && __dref->value.pv) { ");
            if (defined($cg->{"strict_refs"}) && $cg->{"strict_refs"} == 1) {
                Perla::CodeGen::emit($cg, "if (strstr(__dref->value.pv, \"::\")) { strada_incref(__nv); perla_scalar_set_via_qname(__dref->value.pv, __nv); } else { char __sm[512]; snprintf(__sm, sizeof(__sm), \"Can't use string (\\\"%s\\\") as a SCALAR ref while \\\"strict refs\\\" in use\", __dref->value.pv); strada_die(__sm); } ");
            } else {
                Perla::CodeGen::emit($cg, "strada_incref(__nv); perla_scalar_set_via_qname(__dref->value.pv, __nv); ");
            }
            Perla::CodeGen::emit($cg, "} __nv; })");
            return;
        }
        # Assignment to special variables
        if ($target_type == Perla::AST::N_SCALAR_VAR()) {
            my str $svname = $target->{"name"};
            # strict 'vars' — check the assignment LHS too, not just reads.
            # Without this, `use strict; $foo = 3;` only errored on a later
            # READ of $foo; writes silently auto-registered the name as
            # IMPLICIT_GLOBAL. Match Perl's behavior of erroring on the
            # first appearance — read or write — of an undeclared name.
            Perla::CodeGen::_strict_check_var($cg, "\$", $svname, $target->{"line"} + 0);
            if ($svname eq "/" || $svname eq "\\" || $svname eq "," || $svname eq "\""
                || $svname eq "~" || $svname eq "^" || $svname eq "="
                || $svname eq "%" || $svname eq "^A") {
                my str $cvar = "perla_irs";
                if ($svname eq "\\") { $cvar = "perla_ors"; }
                if ($svname eq ",") { $cvar = "perla_ofs"; }
                if ($svname eq "\"") { $cvar = "perla_lse"; }
                if ($svname eq "~") { $cvar = "perla_dollar_tilde"; }
                if ($svname eq "^") { $cvar = "perla_dollar_caret"; }
                if ($svname eq "=") { $cvar = "perla_dollar_equals"; }
                if ($svname eq "%") { $cvar = "perla_dollar_percent"; }
                if ($svname eq "^A") { $cvar = "perla_dollar_caret_A"; }
                # Per-handle $~ / $^ : also mirror into the currently-
                # selected handle's PerlaFmtPageState slot so a
                # `select(FH); $~ = "X"; ...` pattern carries the
                # override to FH even after a later select() swap.
                my str $perhandle_setter = "";
                if ($svname eq "~") { $perhandle_setter = "perla_format_set_selected_fmt_name"; }
                if ($svname eq "^") { $perhandle_setter = "perla_format_set_selected_top_name"; }
                Perla::CodeGen::emit($cg, "({ StradaValue *__nv = ");
                Perla::CodeGen::gen_expr($cg, $node->{"value"});
                Perla::CodeGen::emit($cg, "; strada_incref(__nv); if (" . $cvar . ") strada_decref(" . $cvar . "); " . $cvar . " = __nv; ");
                if (length($perhandle_setter) > 0) {
                    Perla::CodeGen::emit($cg, "{ char *__phs = strada_to_str(__nv); " . $perhandle_setter . "(__phs ? __phs : \"\"); if (__phs) free(__phs); } ");
                }
                Perla::CodeGen::emit($cg, "__nv; })");
                return;
            }
            if ($svname eq "|") {
                Perla::CodeGen::emit($cg, "({ __perla_autoflush = (int)strada_to_int(");
                Perla::CodeGen::gen_expr($cg, $node->{"value"});
                Perla::CodeGen::emit($cg, "); if (__perla_autoflush) setvbuf(stdout, NULL, 2 /* _IONBF */, 0); ");
                Perla::CodeGen::emit($cg, "STRADA_MAKE_TAGGED_INT((int64_t)__perla_autoflush); })");
                return;
            }
            # $! = N — set errno (Perl accepts numeric or string; we take the
            # integer form). Otherwise `$! = strerror(errno) = VAL` would
            # emit a non-lvalue assignment to the read-side expression.
            if ($svname eq "!") {
                Perla::CodeGen::emit($cg, "({ StradaValue *__nv = ");
                Perla::CodeGen::gen_expr($cg, $node->{"value"});
                Perla::CodeGen::emit($cg, "; errno = (int)strada_to_int(__nv); __nv; })");
                return;
            }
            # $. = N — input line number. Read path emits
            # STRADA_MAKE_TAGGED_INT((int64_t)perla_dollar_dot) which
            # isn't a C lvalue, so write must go through the int
            # storage directly.
            if ($svname eq ".") {
                Perla::CodeGen::emit($cg, "({ int64_t __nv = strada_to_int(");
                Perla::CodeGen::gen_expr($cg, $node->{"value"});
                Perla::CodeGen::emit($cg, "); perla_dollar_dot = (int)__nv; STRADA_MAKE_TAGGED_INT(__nv); })");
                return;
            }
            # $1, $2, ..., $9 — regex capture vars. Read-only in Perl;
            # assignment raises "Modification of a read-only value".
            # Without this branch, gen_expr emits `strada_capture_var(N)`
            # (a function call rvalue) which gcc rejects with "lvalue
            # required". Emit a runtime die instead so callers see the
            # same kind of failure Perl would.
            if (length($svname) == 1 && $svname ge "1" && $svname le "9") {
                Perla::CodeGen::emit($cg, "({ ");
                Perla::CodeGen::gen_expr($cg, $node->{"value"});
                Perla::CodeGen::emit($cg, "; strada_die(\"%s\", \"Modification of a read-only value attempted\"); strada_new_undef(); })");
                return;
            }
            # $& — same read-only constraint as $1-$9.
            if ($svname eq "&") {
                Perla::CodeGen::emit($cg, "({ ");
                Perla::CodeGen::gen_expr($cg, $node->{"value"});
                Perla::CodeGen::emit($cg, "; strada_die(\"%s\", \"Modification of a read-only value attempted\"); strada_new_undef(); })");
                return;
            }
        }
        # substr($s, offset, len) = value — in-place string modification.
        # If the target string is a plain scalar variable, `&v_x` works as the
        # StradaValue** that strada_substr_assign needs. For hash/array
        # accesses (or any non-lvalue expression), the naive codegen would
        # take the address of a statement-expression and fail at the C level.
        # For those, fetch into a temp, mutate it, and store back.
        # pos($sv) = N — set the SV's regex pos so the next /g match
        # resumes from offset N. Without this, `pos($s) = 0` was a
        # no-op and code like `while (pos($s) < length($s)) { ... }`
        # patterns couldn't manually steer the iterator.
        if ($target_type == Perla::AST::N_CALL() && $target->{"name"} eq "pos") {
            my scalar $pos_args = $target->{"args"};
            if (defined($pos_args) && scalar(@{$pos_args}) >= 1) {
                Perla::CodeGen::emit($cg, "({ StradaValue *__pos_sv = ");
                Perla::CodeGen::gen_expr($cg, $pos_args->[0]);
                Perla::CodeGen::emit($cg, "; StradaValue *__pos_v = ");
                Perla::CodeGen::gen_expr($cg, $node->{"value"});
                Perla::CodeGen::emit($cg, "; if (__pos_sv && !STRADA_IS_TAGGED_INT(__pos_sv)) { ");
                Perla::CodeGen::emit($cg, "StradaMetadata *__pos_meta = strada_ensure_meta(__pos_sv); ");
                # undef → reset to -1; defined → set to int value.
                Perla::CodeGen::emit($cg, "if (!__pos_v || (!STRADA_IS_TAGGED_INT(__pos_v) && __pos_v->type == STRADA_UNDEF)) { ");
                Perla::CodeGen::emit($cg, "  if (__pos_meta) __pos_meta->regex_pos = -1; ");
                Perla::CodeGen::emit($cg, "} else if (__pos_meta) { __pos_meta->regex_pos = (int32_t)strada_to_int(__pos_v); } ");
                Perla::CodeGen::emit($cg, "} __pos_v; })");
                return;
            }
