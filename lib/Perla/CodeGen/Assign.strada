            } elsif ($inner_type == Perla::AST::N_SCALAR_VAR()
                && (!defined($target->{"is_explicit_arrow"}) || $target->{"is_explicit_arrow"} != 1)
                && defined($inner_obj->{"name"}) && length($inner_obj->{"name"}) > 0
                && index($inner_obj->{"name"}, "::") < 0 && $inner_obj->{"name"} ne "_"
                && Perla::CodeGen::_perla_has_mangle_collision($inner_obj->{"name"})) {
                # Only the sigil-hash form `$X{key}` routes to v_X__h. The
                # arrow form `$X->{key}` is a scalar holding a hashref —
                # use v_X (the scalar). Without this guard, `$s->{k} = v`
                # in a sub silently wrote to the unrelated v_s__h when an
                # outer scope's `@s` triggered the name-collision mangling.
                Perla::CodeGen::emit($cg, Perla::CodeGen::c_var_h($inner_obj->{"name"}));
            } elsif ($inner_type == Perla::AST::N_SCALAR_VAR()
                && defined($inner_obj->{"name"}) && $inner_obj->{"name"} eq "INC") {
                # `$INC{Mod} = ...` writes the loaded-modules hash slot
                # (v_INC__h, backed by g_INC_hash) not the @INC paths
