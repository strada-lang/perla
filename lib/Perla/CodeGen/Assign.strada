        Perla::CodeGen::emit($cg, "; StradaValue *__ovr = NULL; ");
        Perla::CodeGen::emit($cg, "if (__tg && !STRADA_IS_TAGGED_INT(__tg) && __tg->type == STRADA_REF) { ");
        Perla::CodeGen::emit($cg, "  __ovr = perla_overload_binary(__tg, __rv, \"%=\"); ");
        Perla::CodeGen::emit($cg, "  if (!__ovr) __ovr = perla_overload_binary(__tg, __rv, \"%\"); } ");
