            # Without forcing want_list=1, list-returning expressions like
            # grep/map saw scalar context and collapsed to a count.
            Perla::CodeGen::emit($cg, "; int __sav_wl_da = __perla_want_list; __perla_want_list = 1; StradaValue *__da_val = ");
            Perla::CodeGen::gen_expr($cg, $node->{"value"});
            Perla::CodeGen::emit($cg, "; __perla_want_list = __sav_wl_da; ");
            if ($__la_strict == 1) {
                # strict 'refs': symbolic-ref assignment dies. perla_deref_
                # array_assign falls back to symbolic handling for strings,
                # which under strict refs is exactly the error case.
                Perla::CodeGen::emit($cg, "if (__da_ref && !STRADA_IS_TAGGED_INT(__da_ref) && __da_ref->type == STRADA_STR && __da_ref->value.pv && !strstr(__da_ref->value.pv, \"::\")) { char __sm[512]; snprintf(__sm, sizeof(__sm), \"Can't use string (\\\"%s\\\") as an ARRAY ref while \\\"strict refs\\\" in use\", __da_ref->value.pv); strada_die(__sm); } ");
            }
            Perla::CodeGen::emit($cg, "perla_deref_array_assign(__da_ref, __da_val); __da_val; })");
            return;
        }
        # Arrow array assignment: $ref->[idx] = val
        # When the inner object is itself an array/hash access (chained
        # form like \$a[0][1] = X or \$h{k}[0] = X), autovivify the inner
        # slot to an arrayref before the deref. Without this, the deref
        # of an undef slot returns NULL and the strada_array_set is a
        # no-op.
        if ($target_type == Perla::AST::N_ARROW_ARRAY()) {
            my scalar $aa_obj = $target->{"object"};
