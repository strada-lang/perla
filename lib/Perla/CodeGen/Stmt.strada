    }
    if ($type == Perla::AST::N_PRECOMPILED_MOD()) {
        my str $init_func = $node->{"init_func"};
        my str $o_path = $node->{"o_path"};
        my str $so_path = defined($node->{"so_path"}) ? $node->{"so_path"} : ($o_path . ".so");
        my str $mod = $node->{"module"};
        my int $use_shared = defined($node->{"use_shared"}) ? $node->{"use_shared"} : 0;

        if ($use_shared == 1) {
            # --shared mode: dlopen the .pm.so at program startup and
            # invoke its init func via dlsym. Skips static linking of
            # the sibling .pm.o — smaller binary, dynamic loading.
            Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "/* precompiled (shared): " . $mod . " (" . $so_path . ") */\n");
            Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "{ void *__h = dlopen(\"" . Perla::CodeGen::Escape::escape_c_str($so_path) . "\", RTLD_NOW | RTLD_GLOBAL); ");
            Perla::CodeGen::emit($cg, "if (__h) { void (*__init)(void) = (void(*)(void))dlsym(__h, \"" . $init_func . "\"); if (__init) __init(); } ");
            Perla::CodeGen::emit($cg, "else if (perla_debug_mode()) fprintf(stderr, \"[shared] dlopen failed for %s: %s\\n\", \"" . Perla::CodeGen::Escape::escape_c_str($so_path) . "\", dlerror()); }\n");
            # Do NOT push $o_path to precompiled_objects — the .pm.so
            # is self-contained at runtime.
            return;
        }

        Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "/* precompiled: " . $mod . " (" . $o_path . ") */\n");

        if ($cg->{"module_mode"} == 1) {
            # Inside a module compilation: use dlsym to resolve the dependency init
            # at runtime, so we don't need link-time resolution between .o files.
            # If dlsym returns NULL (symbol not in the main binary because the
            # module graph wasn't statically linked — e.g. when this .pm.o is
            # loaded via runtime require under a `perla` binary rather than a
            # compiled-exe main program), fall back to perla_require_module so
            # the dependency still gets loaded. Without the fallback,
            # e.g. Drogo::Dispatch's init can't reach Drogo::Dispatcher, which
            # means e.g. Drogo::Dispatcher::r is never registered and
            # consuming apps fail at runtime with a missing method.
            Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "{ void (*__dep_init)(void) = (void(*)(void))dlsym(RTLD_DEFAULT, \"" . $init_func . "\"); ");
            Perla::CodeGen::emit($cg, "if (__dep_init) { __dep_init(); } ");
            Perla::CodeGen::emit($cg, "else { StradaValue *__m = strada_new_str(\"" . $mod . "\"); StradaValue *__r = perla_require_module(__m); if (__r) strada_decref(__r); strada_decref(__m); } }\n");
        } else {
            # Main program: direct call (will be resolved by linking the .o)
            Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, $init_func . "();\n");
            # Track extern declaration needed
            if (!defined($cg->{"precompiled_externs"})) {
                $cg->{"precompiled_externs"} = [];
