        #   return @arr;        in scalar = scalar(@arr) (size)
        # Without this, my $s = func() always saw the whole array, which
        # broke YAML::Load's scalar-context semantics.
        my int $reduce_last = 0;   # AST is a list literal — take last element
        my int $reduce_size = 0;   # AST is an @array — take size
        if (defined($node->{"value"})) {
            my int $vt = $node->{"value"}->{"type"};
            if ($vt == Perla::AST::N_ANON_ARRAY()) {
                my int $isref = 0;
                if (defined($node->{"value"}->{"is_ref"})) {
                    $isref = $node->{"value"}->{"is_ref"};
                }
                if ($isref == 0) { $reduce_last = 1; }
            } elsif ($vt == Perla::AST::N_ARRAY_VAR()) {
                $reduce_size = 1;
            }
        }
        # caller() line propagation for `return EXPR` where EXPR is a
        # call/method — set perla_pending_call_line so the callee's
        # perla_call_push records the call-site line for caller(0).
        if (defined($node->{"value"})) {
            my int $__rv_type = $node->{"value"}->{"type"};
            if ($__rv_type == Perla::AST::N_CALL() || $__rv_type == Perla::AST::N_METHOD()) {
                my int $__rv_line = $node->{"value"}->{"line"} + 0;
                if ($__rv_line > 0) {
                    Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "perla_pending_call_line = " . $__rv_line . ";\n");
                }
            }
        }
        # If we have local vars, eval return expr, restore locals, then return
        if (defined($cg->{"local_vars"}) && scalar(keys(%{$cg->{"local_vars"}})) > 0) {
            # Restore caller's wantarray context before evaluating EXPR.
            # Perl: `return EXPR` evaluates EXPR in the caller's context, but
            # perla's intermediate code in the function body may have left
            # __perla_want_list mutated (e.g., a save/restore that's outdated).
            # Without resetting, chained method calls (e.g. `return $self->method(...)`)
            # see the WRONG context. Concrete failure: YAML::Loader::_parse's
            # `return wantarray ? @docs : $docs[-1]` picks list branch in
            # bizowie's deep call chain, returning an arrayref instead of last doc.
            Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "__perla_want_list = __perla_caller_want_list;\n");
            # Skip the return-value incref when the return EXPR is already
            # owned (literal, call result, anon constructor, etc.). The
            # incref is only needed for borrowed reads (variables, array
            # elements) where param/local cleanup below would otherwise
            # decref the value to 0 before the caller sees it. Matches
            # strada's return_needs_incref pattern; without this every
            # chained method call doubled the result's refcount.
            my int $__rv_needs_incref = 1;
            if (defined($node->{"value"})) {
                $__rv_needs_incref = Perla::CodeGen::expr_is_borrowed($node->{"value"});
                # `return bless $self, $class`: bless is transparent
                # (rc+0), so the returned ref shares the refcount of its
                # first arg. If that arg is a borrowed value (variable
                # whose scope-cleanup decref is about to fire), the
                # caller's copy will be freed underneath them. Mirror
                # the arg's borrowed-ness to bless itself. If the bless
                # arg is a fresh literal / anon constructor (rc=1 owned),
                # leave $__rv_needs_incref at 0 — adding incref here
                # would leak a permanent ref past DESTROY-at-scope-exit.
                if ($__rv_needs_incref == 0
                    && $node->{"value"}->{"type"} == Perla::AST::N_CALL()
                    && defined($node->{"value"}->{"name"})
                    && ($node->{"value"}->{"name"} eq "bless"
                        || $node->{"value"}->{"name"} eq "CORE::bless")) {
                    my scalar $__rv_bless_args = $node->{"value"}->{"args"};
                    if (defined($__rv_bless_args)
                        && scalar(@{$__rv_bless_args}) >= 1
                        && Perla::CodeGen::expr_is_borrowed($__rv_bless_args->[0]) == 1) {
                        $__rv_needs_incref = 1;
                    }
                }
            } else {
                $__rv_needs_incref = 0;
            }
            Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "{ StradaValue *__ret_val = ");
            if (defined($node->{"value"})) {
                Perla::CodeGen::gen_expr($cg, $node->{"value"});
            } else {
                # `return;` context-sensitive — see other branch.
                Perla::CodeGen::emit($cg, "(__perla_caller_want_list ? strada_new_array() : strada_new_undef())");
            }
            Perla::CodeGen::emit($cg, ";\n");
            # Incref BEFORE the scalar-conversion checks. When the return
            # value is a borrowed variable (e.g. `return @list` where
            # @list is a file-scope my), the conversion's
            # `strada_decref(__ret_val); __ret_val = TAGGED_INT(size)`
            # would drop the variable's refcount to 0 and free it. The
            # caller's count was correct but the file-scope @list was
            # destroyed — subsequent calls returned a dangling pointer.
            # With the incref moved up, the conversion's decref balances
            # the extra ref instead of consuming the variable's last
            # one.
            if ($__rv_needs_incref == 1) {
                Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "if (__ret_val) strada_incref(__ret_val);\n");
            }
            if ($reduce_last == 1) {
                Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "if (!__perla_caller_want_list && __ret_val && !STRADA_IS_TAGGED_INT(__ret_val) && __ret_val->type == STRADA_ARRAY) { StradaArray *__rrav = strada_deref_array(__ret_val); StradaValue *__rrlast = (__rrav && __rrav->size > 0) ? __rrav->elements[__rrav->head + __rrav->size - 1] : strada_new_undef(); strada_incref(__rrlast); strada_decref(__ret_val); __ret_val = __rrlast; }\n");
            } elsif ($reduce_size == 1) {
                Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "if (!__perla_caller_want_list && __ret_val && !STRADA_IS_TAGGED_INT(__ret_val) && __ret_val->type == STRADA_ARRAY) { StradaArray *__rrav = strada_deref_array(__ret_val); int64_t __rrsz = __rrav ? (int64_t)__rrav->size : 0; strada_decref(__ret_val); __ret_val = STRADA_MAKE_TAGGED_INT(__rrsz); }\n");
            }
