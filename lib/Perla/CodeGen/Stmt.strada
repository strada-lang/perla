                    # "my X masks earlier declaration" check sees both first
                    # and subsequent decls in the same scope. Result string
                    # is "" if the C var was already declared (decref+reassign
                    # path) and "StradaValue *" otherwise (fresh declaration).
                    my str $__mpr_init = Perla::CodeGen::_my_prefix_vt($cg, $vtype, $vname);
                    if (length($__mpr_init) == 0) {
                        # Variable already declared (e.g. inside a loop) — decref old and reassign
