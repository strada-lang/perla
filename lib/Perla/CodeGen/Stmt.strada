                    # perla_overload_import can find the right caller
                    # package even when call_stack is empty (module init
                    # context). Already routed correctly for Exporter via
                    # exporter_import; doing the same here is uniform.
                    #
                    # Also temporarily reset perla_call_depth to 0 across
                    # the dispatch. The .pm.so init runs without pushing
                    # its own frame, so the "current top" of the stack
                    # belongs to whatever subroutine triggered the
                    # dlopen → init chain — `caller()` inside import
                    # would return that subroutine's package instead of
                    # the consuming module's. Forcing depth=0 makes
                    # perla_caller(0) fall through to perla_use_caller_pkg
                    # (which we set to the consuming pkg), which matches
                    # Perl's `caller` semantics for `use Module`.
                    Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "extern const char *perla_use_caller_pkg;\n");
                    Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "extern int perla_call_depth;\n");
                    Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "const char *__sav_ucp = perla_use_caller_pkg;\n");
                    Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "int __sav_cd = perla_call_depth;\n");
                    # Forcing perla_call_depth=0 (below) makes the import's own
                    # perla_call_push calls (e.g. Sub::Exporter's
                    # default_installer chain) OVERWRITE the existing call-stack
                    # slots — including THIS module's own (init) frame. Restoring
                    # only the depth afterwards leaves those slots holding the
                    # import's stale frames, so a later `caller()` in this
                    # module's top-level code reads the wrong package (e.g.
                    # "Sub::Exporter" instead of the consuming module). Snapshot
                    # the soon-to-be-clobbered slots [0,__sav_cd) and restore
                    # their contents after the dispatch.
                    Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "PerlaCallFrame __sav_cf[256]; int __sav_nf = (__sav_cd < 256) ? __sav_cd : 256;\n");
                    Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "for (int __cfi = 0; __cfi < __sav_nf; __cfi++) __sav_cf[__cfi] = perla_call_stack[__cfi];\n");
                    Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "perla_use_caller_pkg = \"" . $cg->{"pkg"} . "\";\n");
                    Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "perla_call_depth = 0;\n");
                    Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "StradaValue *__ir = NULL;\n");
                    Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "if (perla_can(\"" . $mod . "\", \"import\")) {\n");
                    $cg->{"indent"} = $cg->{"indent"} + 1;
                    if ($cg->{"module_mode"} == 1) {
                        # In module_mode: wrap the import dispatch in eval.
                        # A CPAN module's import can die on conditions perla
                        # doesn't fully emulate (e.g. Sub::Exporter::Progressive
                        # croaks during DBIx::Class::ResultSource init). Without
                        # this guard the die propagates out of the .pm.so init
                        # function and the rest of init (including
                        # mk_group_accessors that installs class accessors)
                        # never runs.
                        Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "{ int __use_sav_wl = __perla_want_list; jmp_buf *__use_jb = STRADA_TRY_PUSH(); if (__use_jb && setjmp(*__use_jb) == 0) { __ir = perla_method_dispatch(__icls, \"import\", __ia); STRADA_TRY_POP(); } else { STRADA_TRY_POP(); __perla_want_list = __use_sav_wl; if (getenv(\"PERLA_TRACE_USE_DIE\")) fprintf(stderr, \"[use-import-die] " . $cg->{"pkg"} . " caught\\n\"); } }\n");
                    } else {
                        Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "__ir = perla_method_dispatch(__icls, \"import\", __ia);\n");
                    }
                    $cg->{"indent"} = $cg->{"indent"} - 1;
                    # No `import` of its own: promote the requested names
                    # from the module's own stash into the caller (covers
                    # native builtin shims with no Exporter wiring).
                    Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "} else {\n");
                    $cg->{"indent"} = $cg->{"indent"} + 1;
                    Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "extern StradaValue *perla_exporter_import_pub(StradaValue*);\n");
                    Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "__ir = perla_exporter_import_pub(__ia);\n");
                    $cg->{"indent"} = $cg->{"indent"} - 1;
                    Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "}\n");
                    Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "perla_call_depth = __sav_cd;\n");
                    Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "for (int __cfi2 = 0; __cfi2 < __sav_nf; __cfi2++) perla_call_stack[__cfi2] = __sav_cf[__cfi2];\n");
                    Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "perla_use_caller_pkg = __sav_ucp;\n");
                    Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "if (__ir) strada_decref(__ir);\n");
                    Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "strada_decref(__icls);\n");
                    Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "strada_decref(__ia);\n");
                    $cg->{"indent"} = $cg->{"indent"} - 1;
                    Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "}\n");
                }
            }
            # Sub::Quote — after the real Sub::Quote.pm.so has run its
            # init (which registers a buggy `quotify` whose ternary
            # classifier returns 'undef()' for non-undef strings under
            # perla), re-register `quotify` with our native impl. The
            # native version is registered in perla_init too but gets
            # overwritten when Sub::Quote.pm.so loads.
