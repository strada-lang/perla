                Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, Perla::CodeGen::c_var_for_vtype($lvt, $lv[$li]) . " = __local_save_" . Perla::CodeGen::safe_ident($lv[$li]) . ";\n");
