                            # Perl lets you interleave %hash with other lvalues:
                            # `my ($P, %e, %o) = LIST` binds %e to the remainder
                            # and leaves later hashes/arrays empty. Without this,
                            # Mo::Inline's `my ($P,%e,%o) = caller.'::';` would
                            # leave %e as undef so `\%e` then derefs nothing.
                            Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "{ StradaHash *__rhv = strada_deref_hash(" . Perla::CodeGen::c_var_h($dname) . ");\n");
                            Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "  for (int __ri = " . $di . "; __ri + 1 < __dlen; __ri += 2) {\n");
                            Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "    char *__rhk = strada_to_str(strada_array_get(__da, __ri));\n");
                            Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "    strada_hash_set(__rhv, __rhk, strada_array_get(__da, __ri + 1));\n");
                            Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "    free(__rhk);\n");
                            Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "  } }\n");
                            $di = $nv;  # done
                        } else {
                            Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, Perla::CodeGen::c_var($dname) . " = (" . $di . " < __dlen ? strada_array_get(__da, " . $di . ") : strada_new_undef());\n");
