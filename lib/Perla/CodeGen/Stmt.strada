                        # URI::_server's `use URI::Escape qw(uri_unescape);` needs
                        # URI::Escape loaded before the import-dispatch check, or
                        # uri_unescape never makes it into URI::_server's stash
                        # and `$u->host` returns undef (LWP/URI HTTP/HTTPS chain
                        # all blocked on this).
                        if ($mod eq "URI::Escape") { $needs_load = 1; }
                        if ($needs_load == 1) {
                            Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "if (!perla_can(\"" . $mod . "\", \"import\")) { ");
                            Perla::CodeGen::emit($cg, "StradaValue *__urm = strada_new_str(\"" . $mod . "\"); ");
                            Perla::CodeGen::emit($cg, "StradaValue *__urr = perla_require_module(__urm); ");
                            Perla::CodeGen::emit($cg, "if (__urr) strada_decref(__urr); strada_decref(__urm); }\n");
                        }
                    }
                    # Sub::Quote — re-register native quotify BEFORE the
                    # import dispatch runs, so when Sub::Quote's import
                    # copies `quotify` into the caller's stash, it copies
                    # OUR native impl instead of Sub::Quote's broken one.
                    if ($mod eq "Sub::Quote") {
                        Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "{ extern StradaValue *perla_sub_quote_quotify(StradaValue*); ");
                        Perla::CodeGen::emit($cg, "perla_code_set(\"Sub::Quote\", \"quotify\", strada_cpointer_new((void*)perla_sub_quote_quotify)); }\n");
                    }
