            # Use a labeled goto (set by the eval-block wrapper) so `last`/
            # `next` inside the eval still target the enclosing loop. `break`
            # would otherwise be caught by the do-while(0) and never reach
            # the outer loop. Fall back to `break` only when no label set —
            # try/catch and the older expression-form eval still use that.
            my str $ev_label = "";
            if (defined($cg->{"eval_block_return_label"})) { $ev_label = "" . $cg->{"eval_block_return_label"}; }
            my str $exit_stmt = length($ev_label) > 0 ? ("goto " . $ev_label . ";") : "break;";
            Perla::CodeGen::ind($cg);
            if (defined($node->{"value"})) {
                Perla::CodeGen::emit($cg, "{ " . $resv . " = ");
                Perla::CodeGen::gen_expr($cg, $node->{"value"});
                Perla::CodeGen::emit($cg, "; if (" . $resv . ") strada_incref(" . $resv . "); " . $exit_stmt . " }\n");
            } else {
                Perla::CodeGen::emit($cg, "{ " . $resv . " = NULL; " . $exit_stmt . " }\n");
            }
            return;
        }
        # Skip return at module init level (leaked sub body)
        if ($cg->{"in_sub"} != 1) {
