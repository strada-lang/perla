# Perla::CodeGen::Stmt - Statement & control-flow code generation.
#
# Extracted from CodeGen.strada. Owns gen_stmt (the statement dispatcher)
# and the control-flow constructs: my/state declarations, blocks, if/elsif,
# while/until, foreach, and C-style for, plus their helpers (loop-var
# hoisting, int-var inference, block shadow-name handling, capture-return
# variants used by do-block expression context).
#
# gen_expr and the small shared helpers stay in the main Perla::CodeGen;
# reached here via body-less `extern func` decls (can't `use` it: cycle).
# Sibling modules that need gen_stmt / gen_block_stmts / _compute_int_vars /
# gen_if_capture_return / _node_is_int (Eval, Operator, Subs) reach them via
# `extern func Perla::CodeGen::Stmt::...` decls rather than `use` (avoids a
# use-cycle).

use Perla::AST;
use Perla::Lexer;
use Perla::Parser;
use Perla::CodeGen::Escape;
use Perla::CodeGen::Eval;
use Perla::CodeGen::Predicate;
use Perla::CodeGen::Subs;
use Perla::CodeGen::Method;

package Perla::CodeGen::Stmt;

# Forward decls for Perla::CodeGen helpers we call inline.
extern func Perla::CodeGen::_gen_cond(scalar $cg, scalar $node) void;
extern func Perla::CodeGen::_gen_map_block(scalar $cg, scalar $block) void;
extern func Perla::CodeGen::_gen_our(scalar $cg, scalar $node) void;
extern func Perla::CodeGen::_is_file_scope(scalar $cg, str $vname) int;
extern func Perla::CodeGen::_my_prefix_vt(scalar $cg, str $vtype, str $vname) str;
extern func Perla::CodeGen::_sub_in_node_references_var(scalar $node, str $vname) int;
extern func Perla::CodeGen::c_var(str $name) str;
extern func Perla::CodeGen::c_var_a(str $name) str;
extern func Perla::CodeGen::c_var_for_vtype(str $vtype, str $name) str;
extern func Perla::CodeGen::c_var_h(str $name) str;
extern func Perla::CodeGen::emit(scalar $cg, str $s) void;
extern func Perla::CodeGen::expr_is_borrowed(scalar $node) int;
extern func Perla::CodeGen::gen_expr(scalar $cg, scalar $node) void;
extern func Perla::CodeGen::gen_expr_safe(scalar $cg, scalar $node) void;
extern func Perla::CodeGen::ind(scalar $cg) void;
extern func Perla::CodeGen::safe_ident(str $name) str;

# --- Statement generation ---
func gen_stmt(scalar $cg, scalar $node) void {
    my int $type = $node->{"type"};

    # Statement-context pre-declaration for an inline `my` buried in a
    # list-destructure assignment LHS: `($h->{k}, my $x) = LIST;`. _gen_assign
    # rewrites the inline N_MY to a plain scalar/array/hash assignment but never
    # emits the C declaration or registers the var, so a later reference trips
    # strict 'vars' and the C variable is undeclared. At file scope the static
    # file_scope_vars pass covers this; inside a sub we emit the local decl here
    # (statement context — safe to prepend declarations). Surfaced by DBIC
    # ResultSet: `($attrs->{group_by}, my $new_order) = $source->storage->...`.
    if ($type == Perla::AST::N_ASSIGN() && defined($node->{"op"}) && $node->{"op"} eq "="
        && defined($node->{"target"}) && $node->{"target"}->{"type"} == Perla::AST::N_ANON_ARRAY()
        && defined($node->{"target"}->{"elems"})
        && (!defined($cg->{"in_main"}) || $cg->{"in_main"} != 1)) {
        my scalar $__lae = $node->{"target"}->{"elems"};
        my int $__lai = 0;
        while ($__lai < scalar(@{$__lae})) {
            my scalar $__lael = $__lae->[$__lai];
            if (defined($__lael) && $__lael->{"type"} == Perla::AST::N_MY()) {
                my array @__lavars = ();
                if (defined($__lael->{"vars"})) { @__lavars = @{$__lael->{"vars"}}; }
                elsif (defined($__lael->{"var"})) { push(@__lavars, $__lael->{"var"}); }
                my int $__lavi = 0;
                while ($__lavi < scalar(@__lavars)) {
                    my scalar $__lav = $__lavars[$__lavi];
                    my str $__lavt = "" . $__lav->{"type"};
                    if (length($__lavt) == 0) { $__lavt = "SCALAR_VAR"; }
                    my str $__lavcn = Perla::CodeGen::c_var_for_vtype($__lavt, $__lav->{"value"});
                    if (!defined($cg->{"declared_vars"}->{$__lavcn})) {
                        my str $__lavinit = "NULL";
                        if ($__lavt eq "ARRAY_VAR") { $__lavinit = "strada_new_array()"; }
                        elsif ($__lavt eq "HASH_VAR") { $__lavinit = "strada_new_hash()"; }
                        Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "StradaValue *" . $__lavcn . " = " . $__lavinit . ";\n");
                        $cg->{"declared_vars"}->{$__lavcn} = 1;
                    }
                    $__lavi = $__lavi + 1;
                }
            }
            $__lai = $__lai + 1;
        }
    }

    # Labeled bare block: LABEL: { ... }
    # Emits a C block with goto targets at both ends, so `last LABEL` jumps
    # out and `redo LABEL` restarts the block. Without a label this case
    # would normally fall through to the expression form (`({ ... })`),
    # which doesn't permit break/goto.
    if ($type == Perla::AST::N_BLOCK() && defined($node->{"label"})) {
        my str $user_label = "" . $node->{"label"};
        $cg->{"label_count"} = $cg->{"label_count"} + 1;
        my str $ll = $user_label . "_" . $cg->{"label_count"};
        my scalar $saved_lm = $cg->{"label_map"};
        if (!defined($saved_lm)) { $saved_lm = {}; $cg->{"label_map"} = $saved_lm; }
        my str $prev_mapped = "" . $saved_lm->{$user_label};
        $saved_lm->{$user_label} = $ll;
        Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "__perla_redo_" . $ll . ": ;\n");
        Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "do {\n");
        $cg->{"indent"} = $cg->{"indent"} + 1;
        gen_block_stmts($cg, $node);
        $cg->{"indent"} = $cg->{"indent"} - 1;
        Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "} while (0);\n");
        Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "__perla_end_" . $ll . ": ;\n");
        # Test::More SKIP: { skip "msg", 2 if cond; ... } — perla
        # emulates `last SKIP` (the Perl idiom inside skip) by having
        # skip() set a thread-local "in skip" flag that suppresses
        # subsequent ok/is/like. Reset the flag at block exit so
        # tests after the SKIP block run normally.
        if ($user_label eq "SKIP") {
            Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "{ extern __thread int perla_tm_in_skip_block; perla_tm_in_skip_block = 0; }\n");
        }
        # Restore label map entry
        if (length($prev_mapped) > 0) { $saved_lm->{$user_label} = $prev_mapped; }
        return;
    }

    # Unlabeled bare `{ ... }` at statement level. In Perl this is a
    # loop-once construct — `redo` re-enters, `last`/`next` exit.
    # Emit goto labels around `do { ... } while (0)` and set
    # cg->{redo_label} so the inner N_REDO codegen can target them.
    # Common in Carp.pm:long_error_loc, namespace::clean's
    # accessor-builders, and many CPAN modules using bare blocks for
    # restartable lookups.
    if ($type == Perla::AST::N_BLOCK()) {
        $cg->{"label_count"} = $cg->{"label_count"} + 1;
        my str $ll = "bare_" . $cg->{"label_count"};
        my str $prev_redo = "" . $cg->{"redo_label"};
        my str $prev_in_loop = "" . $cg->{"in_loop"};
        $cg->{"redo_label"} = "__perla_redo_" . $ll;
        $cg->{"in_loop"} = 1;
        # Save lexical-pragma flags so `use integer;` inside the block
        # doesn't leak past its closing brace. Perl pragmas are lexically
        # scoped via $^H; we mirror that by save/restore around blocks.
        my int $bb_save_use_integer = 0;
        if (defined($cg->{"use_integer"})) { $bb_save_use_integer = $cg->{"use_integer"}; }
        my int $bb_save_use_utf8 = 0;
        if (defined($cg->{"use_utf8"})) { $bb_save_use_utf8 = $cg->{"use_utf8"}; }
        my int $bb_save_use_bytes = 0;
        if (defined($cg->{"use_bytes"})) { $bb_save_use_bytes = $cg->{"use_bytes"}; }
        # Snapshot local-vars for block-scoped `local $g` restoration.
        # Only track keys with an ACTIVE local (value != "__restored__").
        # An earlier block may have left "\\" marked as __restored__ —
        # treating that as a saved key would suppress the restore for a
        # NEW `local $\` declared inside this block.
        my scalar $bb_saved_locals = {};
        if (defined($cg->{"local_vars"})) {
            my array @bb_keys_b = keys($cg->{"local_vars"});
            my int $bb_ki = 0;
            while ($bb_ki < scalar(@bb_keys_b)) {
                my str $bb_v = "" . $cg->{"local_vars"}->{$bb_keys_b[$bb_ki]};
                if ($bb_v ne "__restored__") {
                    $bb_saved_locals->{$bb_keys_b[$bb_ki]} = 1;
                }
                $bb_ki++;
            }
        }
        # Lexical-shadow save/restore: a top-level `my $x` in this block that
        # SHADOWS an outer in-scope lexical of the same C slot (sub param or
        # sub-local) reuses v_x via `decref(v_x); v_x=new` — with no save the
        # block permanently clobbers the outer var. (`sub f{ my($x)=@_;
        # { my $x={%$x}; $x->{c}=3 } return [keys %$x] }` returned [a b c],
        # not [a b].) Most block my-vars are renamed to __blk slots by Collect
        # and don't collide; a same-name shadow that escapes renaming lands
        # here. Save the outer pointer (incref to compensate for the body's
        # reassignment-decref), let the body run — its RHS self-reference
        # `{%$x}` still reads the intact outer slot — then at block exit decref
        # the shadow and restore the outer. Saved BEFORE the redo label so the
        # save runs once; $ll in the save-var name avoids sibling collisions.
        my array @__bb_shadows = _block_shadow_cnames($cg, $node);
        my int $__bsv_i = 0;
        while ($__bsv_i < scalar(@__bb_shadows)) {
            my str $__bsv_cn = $__bb_shadows[$__bsv_i];
            Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "StradaValue *__shadowsav_" . $ll . "_" . $__bsv_cn . " = " . $__bsv_cn . "; if (" . $__bsv_cn . ") strada_incref(" . $__bsv_cn . ");\n");
            $__bsv_i = $__bsv_i + 1;
        }
        Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "__perla_redo_" . $ll . ": ;\n");
        # Capture local-chain head so `local $h{k} = v` inside this block
        # restores at block exit (Perl `local` is dynamic-block-scoped).
        Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "void *__bb_local_mark_" . $ll . " = __perla_local_chain;\n");
        # Collect renamed (__blk<N> suffixed) my-decls so we can decref
        # them at block exit. The Collect pass renames every `my X` in
        # the block to a unique synthetic name; decref'ing here drops
        # the refcount of any blessed obj held by the lexical, firing
        # DESTROY at block exit (Perl semantics).
        #
        # SKIP this for blocks that contain `sub` definitions — closure-
        # style `{ my $i = 0; sub next { $i++ } }` relies on the sub
        # body's references to the renamed slot continuing to work
        # AFTER the block closes. Decref'ing at exit would make the
        # sub's reads return undef. Without subs inside, the renamed
        # var is genuinely block-local and safe to decref.
        my array @__bb_blk_vars = ();
        # Walk top-level my-decls in the block and collect their renamed
        # (__blk<N> suffixed) names — these are the block-private lexicals
        # whose decref-at-block-exit fires DESTROY for blessed values, etc.
        #
        # Per-var capture filter: an enclosing closure may have captured
        # one of our block-local slots via &v_X, and decref+NULL'ing the
        # slot at block exit would corrupt the closure. We used to skip
        # ALL cleanup when ANY sub appeared in the block, but that left
        # plenty of unreferenced vars pinned past their scope — including
        # blessed objects whose DESTROY then only fired at process exit.
        # Instead we now check each var individually via
        # _sub_in_node_references_var; if no sub in the block references
        # that specific var, we can safely decref+NULL it at block exit.
        # Surface that motivated this: `{ package X; sub DESTROY {...};
        # my $o = bless {}, "X"; }` — DESTROY never refers to $o, so $o
        # should decref at block close and fire DESTROY there (matches
        # perl). Conversely `{ my $i = 0; sub next { $i++ } }` keeps the
        # original behaviour because `next` references $i.
        if (defined($node->{"stmts"})) {
            my scalar $__bb_stmts = $node->{"stmts"};
            my int $__bb_si = 0;
            while ($__bb_si < scalar(@{$__bb_stmts})) {
                my scalar $__bb_ss = $__bb_stmts->[$__bb_si];
                if (defined($__bb_ss) && $__bb_ss->{"type"} == Perla::AST::N_MY()) {
                    if (defined($__bb_ss->{"var"})) {
                        my str $__bb_vn = $__bb_ss->{"var"}->{"value"};
                        my str $__bb_vt = "" . $__bb_ss->{"var"}->{"type"};
                        if (length($__bb_vt) == 0) { $__bb_vt = "SCALAR_VAR"; }
                        if (($__bb_vt eq "SCALAR_VAR" || $__bb_vt eq "ARRAY_VAR" || $__bb_vt eq "HASH_VAR")
                            && index($__bb_vn, "__blk") >= 0
                            && Perla::CodeGen::_sub_in_node_references_var($node->{"stmts"}, $__bb_vn) == 0) {
                            push(@__bb_blk_vars, Perla::CodeGen::c_var($__bb_vn));
                        }
                    }
                    if (defined($__bb_ss->{"vars"})) {
                        my int $__bb_dvi = 0;
                        while ($__bb_dvi < scalar(@{$__bb_ss->{"vars"}})) {
                            my scalar $__bb_dv = $__bb_ss->{"vars"}->[$__bb_dvi];
                            my str $__bb_dvn = $__bb_dv->{"value"};
                            my str $__bb_dvt = "" . $__bb_dv->{"type"};
                            if (length($__bb_dvt) == 0) { $__bb_dvt = "SCALAR_VAR"; }
                            if (($__bb_dvt eq "SCALAR_VAR" || $__bb_dvt eq "ARRAY_VAR" || $__bb_dvt eq "HASH_VAR")
                                && index($__bb_dvn, "__blk") >= 0
                                && Perla::CodeGen::_sub_in_node_references_var($node->{"stmts"}, $__bb_dvn) == 0) {
                                push(@__bb_blk_vars, Perla::CodeGen::c_var($__bb_dvn));
                            }
                            $__bb_dvi = $__bb_dvi + 1;
                        }
                    }
                }
                $__bb_si = $__bb_si + 1;
            }
        }
        Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "do {\n");
        $cg->{"indent"} = $cg->{"indent"} + 1;
        gen_block_stmts($cg, $node);
        # Restore any `local $g` saves created inside this block.
        if (defined($cg->{"local_vars"})) {
            my array @bb_keys_a = keys($cg->{"local_vars"});
            my int $bb_kj = 0;
            while ($bb_kj < scalar(@bb_keys_a)) {
                my str $bb_kn = $bb_keys_a[$bb_kj];
                if (!defined($bb_saved_locals->{$bb_kn})) {
                    my str $bb_kvt = "" . $cg->{"local_vars"}->{$bb_kn};
                    if (length($bb_kvt) == 0 || $bb_kvt eq "1" || $bb_kvt eq "__restored__") { $bb_kvt = "SCALAR_VAR"; }
                    Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, Perla::CodeGen::c_var_for_vtype($bb_kvt, $bb_kn) . " = __local_save_" . Perla::CodeGen::safe_ident($bb_kn) . ";\n");
                    # Mirror special $/, $\, $, into perla_irs/_ors/_ofs.
                    if ($bb_kn eq "/") { Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "perla_irs = __local_save_" . Perla::CodeGen::safe_ident($bb_kn) . ";\n"); }
                    elsif ($bb_kn eq "\\") { Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "perla_ors = __local_save_" . Perla::CodeGen::safe_ident($bb_kn) . ";\n"); }
                    elsif ($bb_kn eq ",") { Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "perla_ofs = __local_save_" . Perla::CodeGen::safe_ident($bb_kn) . ";\n"); }
                    elsif ($bb_kn eq "\"") { Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "perla_lse = __local_save_" . Perla::CodeGen::safe_ident($bb_kn) . ";\n"); }
                    $cg->{"local_vars"}->{$bb_kn} = "__restored__";
                }
                $bb_kj++;
            }
        }
        $cg->{"indent"} = $cg->{"indent"} - 1;
        Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "} while (0);\n");
        Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "__perla_end_" . $ll . ": ;\n");
        # Unwind hash-element locals pushed inside the block.
        Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "if (__perla_local_chain != __bb_local_mark_" . $ll . ") { perla_local_chain_restore_to(__perla_local_chain, __bb_local_mark_" . $ll . "); __perla_local_chain = __bb_local_mark_" . $ll . "; }\n");
        # Decref block-private my-lexicals so blessed objs fire DESTROY
        # at block exit (Perl semantics for `{ my $o = Obj->new; }`).
        # Iterate in REVERSE declaration order: Perl destroys lexicals at
        # scope exit LIFO, so `{ my $a=Obj->new(1); my $b=Obj->new(2); }`
        # fires DESTROY(2) before DESTROY(1).
        my int $__bb_di = scalar(@__bb_blk_vars) - 1;
        while ($__bb_di >= 0) {
            my str $__bb_dv = $__bb_blk_vars[$__bb_di];
            Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "if (" . $__bb_dv . ") { strada_decref(" . $__bb_dv . "); " . $__bb_dv . " = NULL; }\n");
            $__bb_di = $__bb_di - 1;
        }
        # Restore lexical shadows (reverse declaration order). decref whatever
        # the body left in the slot (the shadow value), then point the slot
        # back at the saved outer pointer (its refcount was pre-incref'd, and
        # the body's reassignment-decref consumed exactly that incref).
        my int $__bsr_i = scalar(@__bb_shadows) - 1;
        while ($__bsr_i >= 0) {
            my str $__bsr_cn = $__bb_shadows[$__bsr_i];
            Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "if (" . $__bsr_cn . " != __shadowsav_" . $ll . "_" . $__bsr_cn . ") { if (" . $__bsr_cn . ") strada_decref(" . $__bsr_cn . "); } " . $__bsr_cn . " = __shadowsav_" . $ll . "_" . $__bsr_cn . ";\n");
            $__bsr_i = $__bsr_i - 1;
        }
        $cg->{"redo_label"} = $prev_redo;
        $cg->{"in_loop"} = $prev_in_loop;
        # Restore lexical pragmas (use integer/utf8/bytes) at block exit.
        $cg->{"use_integer"} = $bb_save_use_integer;
        $cg->{"use_utf8"} = $bb_save_use_utf8;
        $cg->{"use_bytes"} = $bb_save_use_bytes;
        return;
    }

    if ($type == Perla::AST::N_MY()) {
        _gen_my($cg, $node);
        return;
    }
    if ($type == Perla::AST::N_STATE()) {
        _gen_state($cg, $node);
        return;
    }
    if ($type == Perla::AST::N_LOCAL()) {
        # local $var = expr — save old value, set new
        # For our variables, save the old value and set the new one.
        # Restoration happens at function exit OR eval BLOCK exit via the
        # local-chain. For scalar vars we also push to chain so eval-block
        # die-unwind can restore (the static __local_save_* slot only fires
        # at sub exit, not at eval block exit).
        #
        # `local (\$a, \$b) = (5, 10)` — list-form. Each var gets pushed
        # on the local-chain individually; the RHS is evaluated once
        # (list context) and elements distributed. Without this branch,
        # the list form silently did nothing because the codegen only
        # checked for `var` (single) or `target` (lvalue) — never `vars`.
        if (defined($node->{"vars"}) && !defined($node->{"var"})) {
            my scalar $vars = $node->{"vars"};
            my int $vn = scalar(@{$vars});
            if (defined($node->{"init"})) {
                Perla::CodeGen::emit($cg, "{ int __sav_wl_lloc = __perla_want_list; __perla_want_list = 1; StradaValue *__lloc_rhs = ");
                Perla::CodeGen::gen_expr($cg, $node->{"init"});
                Perla::CodeGen::emit($cg, "; __perla_want_list = __sav_wl_lloc; StradaArray *__lloc_av = strada_deref_array(__lloc_rhs); ");
                my int $li = 0;
                while ($li < $vn) {
                    my scalar $vt = $vars->[$li];
                    my str $vn1 = $vt->{"value"};
                    my str $vtype = "" . $vt->{"type"};
                    if (length($vtype) == 0) { $vtype = "SCALAR_VAR"; }
                    if ($vtype eq "SCALAR_VAR") {
                        my str $lcv1 = Perla::CodeGen::c_var($vn1);
                        Perla::CodeGen::emit($cg, "__perla_local_chain = perla_local_push_scalar_slot(__perla_local_chain, &" . $lcv1 . ", ");
                        Perla::CodeGen::emit($cg, "(__lloc_av && " . $li . " < (int)__lloc_av->size) ? ({ StradaValue *__lv = __lloc_av->elements[__lloc_av->head + " . $li . "]; if (__lv) strada_incref(__lv); __lv ? __lv : strada_new_undef(); }) : strada_new_undef()");
                        Perla::CodeGen::emit($cg, "); ");
                    }
                    $li = $li + 1;
                }
                Perla::CodeGen::emit($cg, "if (__lloc_rhs) strada_decref(__lloc_rhs); }\n");
            } else {
                my int $li = 0;
                while ($li < $vn) {
                    my scalar $vt = $vars->[$li];
                    my str $vn1 = $vt->{"value"};
                    my str $vtype = "" . $vt->{"type"};
                    if (length($vtype) == 0) { $vtype = "SCALAR_VAR"; }
                    if ($vtype eq "SCALAR_VAR") {
                        my str $lcv1 = Perla::CodeGen::c_var($vn1);
                        Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "__perla_local_chain = perla_local_push_scalar_slot(__perla_local_chain, &" . $lcv1 . ", strada_new_undef());\n");
                    }
                    $li = $li + 1;
                }
            }
            return;
        }
        if (defined($node->{"var"})) {
            my str $vname = $node->{"var"}->{"value"};
            my str $lvtype = "" . $node->{"var"}->{"type"};
            if (length($lvtype) == 0) { $lvtype = "SCALAR_VAR"; }
            my str $safe_vname = Perla::CodeGen::safe_ident($vname);
            my str $lcv = Perla::CodeGen::c_var_for_vtype($lvtype, $vname);
            # `local $/` must mirror into perla_irs (the IRS the I/O
            # routines actually read). Otherwise the slurp idiom
            # `do { local $/; <\$fh> }` modifies v__slash_ but not
            # perla_irs, and the read still uses "\n".
            # Scalar-only special globals — only apply when the local is
            # on the scalar sigil. `local @_` (array) must NOT alias into
            # perla_dollar_underscore (which is the $_ scalar storage).
            my str $mirror_global = "";
            if ($lvtype eq "SCALAR_VAR") {
                if ($vname eq "/") { $mirror_global = "perla_irs"; }
                elsif ($vname eq "\\") { $mirror_global = "perla_ors"; }
                elsif ($vname eq ",") { $mirror_global = "perla_ofs"; }
                elsif ($vname eq "\"") { $mirror_global = "perla_lse"; }
                # Format-control special vars — mirrored so the
                # write runtime can consult them at write-time.
                elsif ($vname eq "~") { $mirror_global = "perla_dollar_tilde"; }
                elsif ($vname eq "=") { $mirror_global = "perla_dollar_equals"; }
                # `local $_` — the canonical $_ storage is
                # perla_dollar_underscore (used by loops, map, grep, sort,
                # bare-scalar interp, etc.). v__ is the legacy mirror.
                # Localize the canonical and mirror to v__ so any code still
