            push(@{$cg->{"precompiled_externs"}}, "extern void " . $init_func . "(void);");
        }

        # Track the .o file for linking (both module and main program modes)
        if (!defined($cg->{"precompiled_objects"})) {
            $cg->{"precompiled_objects"} = [];
        }
        push(@{$cg->{"precompiled_objects"}}, $o_path);
        return;
    }
    if ($type == Perla::AST::N_IF() || $type == Perla::AST::N_UNLESS()) {
        _gen_if($cg, $node);
        return;
    }
    if ($type == Perla::AST::N_WHILE() || $type == Perla::AST::N_UNTIL()) {
        _gen_while($cg, $node);
        return;
    }
    if ($type == Perla::AST::N_FOREACH()) {
        _gen_foreach($cg, $node);
        return;
    }
    if ($type == Perla::AST::N_DO_WHILE()) {
        # Mark `in_loop` while generating the body so unlabeled
        # `last`/`next` inside emit `break;`/`continue;` and target the
        # C do-while. Real Perl errors out — "Can't 'last' outside a
        # loop block" — but perla previously fell to the warn-and-noop
        # branch and looped forever (the condition stayed truthy and the
        # warning-only `last` left the body running). Treating do-while
        # as a loop is a useful deviation from Perl and matches the
        # user's clear intent of breaking out.
        my int $__old_in_loop_dw = 0;
        if (defined($cg->{"in_loop"})) { $__old_in_loop_dw = $cg->{"in_loop"}; }
        $cg->{"in_loop"} = 1;
        # Detect body's top-level `my X` decls that shadow file-scope
        # vars; emit save before body, restore after. Mirror of the
        # eval-block / do-block / if-my fixes.
        my array @__dw_shadowed = ();
        if (defined($node->{"body"}) && defined($node->{"body"}->{"stmts"})) {
            my scalar $__dw_bstmts = $node->{"body"}->{"stmts"};
            my int $__dw_bsi = 0;
            while ($__dw_bsi < scalar(@{$__dw_bstmts})) {
                my scalar $__dw_bs = $__dw_bstmts->[$__dw_bsi];
                if (defined($__dw_bs) && $__dw_bs->{"type"} == Perla::AST::N_MY()) {
                    if (defined($__dw_bs->{"var"})) {
                        my str $__dw_vn = $__dw_bs->{"var"}->{"value"};
                        if (Perla::CodeGen::_is_file_scope($cg, $__dw_vn) == 1) {
                            my str $__dw_vt = "" . $__dw_bs->{"var"}->{"type"};
                            if (length($__dw_vt) == 0) { $__dw_vt = "SCALAR_VAR"; }
                            push(@__dw_shadowed, Perla::CodeGen::c_var_for_vtype($__dw_vt, $__dw_vn));
                        }
                    }
                    if (defined($__dw_bs->{"vars"})) {
                        my int $__dw_dvi = 0;
                        while ($__dw_dvi < scalar(@{$__dw_bs->{"vars"}})) {
                            my scalar $__dw_dv = $__dw_bs->{"vars"}->[$__dw_dvi];
                            my str $__dw_dvn = $__dw_dv->{"value"};
                            if (Perla::CodeGen::_is_file_scope($cg, $__dw_dvn) == 1) {
                                my str $__dw_dvt = "" . $__dw_dv->{"type"};
                                if (length($__dw_dvt) == 0) { $__dw_dvt = "SCALAR_VAR"; }
                                push(@__dw_shadowed, Perla::CodeGen::c_var_for_vtype($__dw_dvt, $__dw_dvn));
                            }
                            $__dw_dvi = $__dw_dvi + 1;
                        }
                    }
                }
                $__dw_bsi = $__dw_bsi + 1;
            }
        }
        if (scalar(@__dw_shadowed) > 0) {
            Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "{\n");
            $cg->{"indent"} = $cg->{"indent"} + 1;
            my int $__dw_shi = 0;
            while ($__dw_shi < scalar(@__dw_shadowed)) {
                my str $__dw_shc = $__dw_shadowed[$__dw_shi];
                Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "StradaValue *__dw_sav_" . $__dw_shc . " = " . $__dw_shc . "; " . $__dw_shc . " = NULL;\n");
                $__dw_shi = $__dw_shi + 1;
            }
        }
        Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "do {\n");
        $cg->{"indent"} = $cg->{"indent"} + 1;
        gen_block_stmts($cg, $node->{"body"});
        $cg->{"indent"} = $cg->{"indent"} - 1;
        Perla::CodeGen::ind($cg);
        if (defined($node->{"negate"}) && $node->{"negate"} == 1) {
            Perla::CodeGen::emit($cg, "} while (!(");
            Perla::CodeGen::_gen_cond($cg, $node->{"cond"});
            Perla::CodeGen::emit($cg, "));\n");
        } else {
            Perla::CodeGen::emit($cg, "} while (");
            Perla::CodeGen::_gen_cond($cg, $node->{"cond"});
            Perla::CodeGen::emit($cg, ");\n");
        }
        # Close do-while shadow wrap (mirror of the open above).
        if (scalar(@__dw_shadowed) > 0) {
            my int $__dw_rsi = 0;
            while ($__dw_rsi < scalar(@__dw_shadowed)) {
                my str $__dw_rsc = $__dw_shadowed[$__dw_rsi];
                Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "if (" . $__dw_rsc . ") strada_decref(" . $__dw_rsc . "); " . $__dw_rsc . " = __dw_sav_" . $__dw_rsc . ";\n");
                $__dw_rsi = $__dw_rsi + 1;
            }
            $cg->{"indent"} = $cg->{"indent"} - 1;
            Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "}\n");
        }
        $cg->{"in_loop"} = $__old_in_loop_dw;
        return;
    }
    if ($type == Perla::AST::N_FOR_C()) {
        _gen_for_c($cg, $node);
        return;
    }
    if ($type == Perla::AST::N_GOTO_LABEL()) {
        # `goto LABEL` — bareword label jump. Emit a C goto to the
        # synthesized C label that N_LABEL_STMT introduces. C goto
        # has function-local scope only; perl's goto across-sub jumps
        # aren't supported (rare and a hack even in perl).
        my str $lbl = "" . $node->{"label"};
        Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "goto __perla_label_" . Perla::CodeGen::safe_ident($lbl) . ";\n");
        return;
    }
    if ($type == Perla::AST::N_LABEL_STMT()) {
        # Free-standing `LABEL:` — emit as a C label followed by a
        # no-op statement (C requires a statement after a label).
        my str $lbl2 = "" . $node->{"label"};
        Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "__perla_label_" . Perla::CodeGen::safe_ident($lbl2) . ": (void)0;\n");
        return;
    }
    if ($type == Perla::AST::N_FORMAT()) {
        # format NAME = ... . — register the format body with the
        # runtime so `write [HANDLE]` can interpret it. Picture
        # interpretation happens at write-time.
        #
        # Lexical bridge: file-scope `my $x` references in value lines
        # can't be reached by the runtime (which uses perla_scalar_get
        # → stash lookup). To bridge them, we (1) scan value lines for
        # `$IDENT` references, (2) rewrite each lexical reference to a
        # mangled name (`$__perla_lex_NAME`), (3) emit a static sync
        # function that copies the C-side `v_NAME` into the stash under
        # the mangled name before each write, and (4) register that
        # sync function with the runtime so it fires on every write
        # (including $~-overridden formats with the same name).
        my str $fnm = "" . $node->{"name"};
        my str $fbody = "" . $node->{"body"};
        # Collect both file/block-scope lex refs (handled by the
        # static sync helper) AND sub-local lex refs (handled by
        # inline sync emitted at the write call-site).
        my array @fmt_lex_refs = Perla::CodeGen::Method::_collect_format_lex_refs($cg, $fbody);
        my array @fmt_sub_lex_refs = Perla::CodeGen::Method::_collect_format_sub_lex_refs($cg, $fbody);
        my array @fmt_all_refs = (@fmt_lex_refs);
        my int $sri = 0;
        while ($sri < scalar(@fmt_sub_lex_refs)) {
            push(@fmt_all_refs, $fmt_sub_lex_refs[$sri]);
            $sri = $sri + 1;
        }
        my str $rewritten = Perla::CodeGen::Method::_rewrite_format_body_for_lex($fbody, \@fmt_all_refs);
        my str $fbody_esc = Perla::CodeGen::Escape::escape_c_str($rewritten);
        my int $nrefs = scalar(@fmt_lex_refs);
        my int $nsub_refs = scalar(@fmt_sub_lex_refs);
        # Sub-local refs need inline sync at every write site (the
        # vars are on the C stack; can't be `extern`'d from a file-
        # scope helper). Record the ref list keyed by format name.
        if ($nsub_refs > 0) {
            if (!defined($cg->{"format_sub_lex_refs"})) { $cg->{"format_sub_lex_refs"} = {}; }
            $cg->{"format_sub_lex_refs"}->{$fnm} = \@fmt_sub_lex_refs;
        }
        if ($nrefs > 0) {
            my str $sync_name = "__perla_fmt_sync_" . Perla::CodeGen::safe_ident($fnm);
            # Emit the static sync function. Hoist into a deferred buffer
            # so the static-def appears at file scope (not inside main()).
            if (!defined($cg->{"format_sync_defs"})) {
                $cg->{"format_sync_defs"} = "";
            }
            $cg->{"format_sync_defs"} = $cg->{"format_sync_defs"}
                . "static void " . $sync_name . "(void) {\n";
            my int $li = 0;
            while ($li < $nrefs) {
                my str $lname = "" . $fmt_lex_refs[$li];
                my str $cvar = "v_" . Perla::CodeGen::safe_ident($lname);
                $cg->{"format_sync_defs"} = $cg->{"format_sync_defs"}
                    . "    if (" . $cvar . ") perla_scalar_set(\"main\", \"__perla_lex_"
                    . $lname . "\", " . $cvar . ");\n";
                $li = $li + 1;
            }
            $cg->{"format_sync_defs"} = $cg->{"format_sync_defs"} . "}\n";
            Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "perla_register_format(\"" . $fnm . "\", \"" . $fbody_esc . "\");\n");
            Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "perla_register_format_sync(\"" . $fnm . "\", " . $sync_name . ");\n");
        } else {
            Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "perla_register_format(\"" . $fnm . "\", \"" . $fbody_esc . "\");\n");
        }
        return;
    }
    if ($type == Perla::AST::N_WRITE()) {
        my str $whn = "" . $node->{"handle"};
        # Inline sync for sub-local lex refs captured by formats — the
        # file-scope sync helper can't `extern` stack-allocated lexicals,
        # so each write site copies the current scope's `v_NAME` value
        # into the mangled stash slot before the runtime reads it. The
        # name lookup is keyed on the static `write FH` handle name; $~
        # overrides won't pick up the inline-synced values, but the
        # static helper still fires from inside perla_write_format for
        # file-scope refs in that case.
        if (defined($cg->{"format_sub_lex_refs"})
            && defined($cg->{"format_sub_lex_refs"}->{$whn})) {
            my scalar $subrefs = $cg->{"format_sub_lex_refs"}->{$whn};
            my int $sli = 0;
            while ($sli < scalar(@{$subrefs})) {
                my str $lname = "" . $subrefs->[$sli];
                my str $cvar = "v_" . Perla::CodeGen::safe_ident($lname);
                Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "if (" . $cvar . ") perla_scalar_set(\"main\", \"__perla_lex_" . $lname . "\", " . $cvar . ");\n");
                $sli = $sli + 1;
            }
        }
        # `write $fh;` — scalar-var holding a filehandle. Route to the
        # _to_fh variant so the runtime picks up the FH directly
        # without going through stash lookup by name.
        if (defined($node->{"fh_expr"})) {
            Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "perla_write_format_to_fh(");
            Perla::CodeGen::gen_expr($cg, $node->{"fh_expr"});
            Perla::CodeGen::emit($cg, ");\n");
            return;
        }
        Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "perla_write_format(\"" . $whn . "\");\n");
        return;
    }
    if ($type == Perla::AST::N_GOTO_SUB()) {
        # goto &EXPR — tail call that replaces the current call frame so
        # caller() inside EXPR sees the invoker of the current sub, not
        # the sub itself. Emit: pop the current call frame, then call EXPR
        # with the current @_, and return its result. Semantically
        # equivalent to Perl's goto &sub for the common "goto at end of
        # wrapper" idiom. Not a true stack-frame swap, but matches the
        # observable behavior of caller() and the return value.
        Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "{\n");
        $cg->{"indent"} = $cg->{"indent"} + 1;
        Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "StradaValue *__gt_fn = ");
        Perla::CodeGen::gen_expr($cg, $node->{"target"});
        Perla::CodeGen::emit($cg, ";\n");
        # `goto &$name` where $name is a bareword: Perl resolves the
        # name relative to the CURRENT package (i.e., AUTOLOAD's package
        # for the typical install-then-goto pattern). We must look up
        # the sub BEFORE perla_call_pop drops this frame — afterward,
        # `caller_pkg` is the invoker, not us.
        Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "if (__gt_fn && !STRADA_IS_TAGGED_INT(__gt_fn) && __gt_fn->type == STRADA_STR && __gt_fn->value.pv && !strstr(__gt_fn->value.pv, \"::\")) { ");
        Perla::CodeGen::emit($cg, "StradaValue *__gt_resolved = perla_code_get(\"" . $cg->{"pkg"} . "\", __gt_fn->value.pv); ");
        Perla::CodeGen::emit($cg, "if (__gt_resolved && !STRADA_IS_TAGGED_INT(__gt_resolved)) { strada_incref(__gt_resolved); strada_decref(__gt_fn); __gt_fn = __gt_resolved; } }\n");
        Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "if (__perla_local_chain != __perla_local_chain_mark) { perla_local_chain_restore_to(__perla_local_chain, __perla_local_chain_mark); __perla_local_chain = __perla_local_chain_mark; }\n");
        Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "perla_call_pop();  /* goto &: drop current frame so caller() reports invoker */\n");
        Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "StradaValue *__gt_ret = perla_call_code(__gt_fn, perla_at_);\n");
        # Drain ONLY this frame's cleanup entries (those pushed since entry).
        # A bare strada_cleanup_drain() drains the WHOLE stack to 0, which
        # decrefs the CALLER's still-live locals — e.g. `$self` in a method
        # that tail-calls `goto &other` (Path::Tiny::_path -> goto &_pathify
        # over-decref'd the invocant, freeing it out from under the caller).
        Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "strada_cleanup_drain_to(__perla_cleanup_mark);\n");
        Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "return __gt_ret;\n");
        $cg->{"indent"} = $cg->{"indent"} - 1;
        Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "}\n");
        return;
    }
    if ($type == Perla::AST::N_RETURN()) {
        # `return EXPR` inside `eval { ... }` or `try { ... }` returns
        # from that block (setting its value) rather than from the
        # enclosing sub. The wrapper sets eval_block_expr_active=1 and
        # emits a do { ... } while(0) around the body so we can break.
        # The result-var name lives in `eval_block_result_var` (defaults
        # to "__ev_val" for eval, overridden to "__try_result" for try).
        if (defined($cg->{"eval_block_expr_active"}) && $cg->{"eval_block_expr_active"} >= 1) {
            my str $resv = "__ev_val";
            if (defined($cg->{"eval_block_result_var"}) && length("" . $cg->{"eval_block_result_var"}) > 0) {
                $resv = "" . $cg->{"eval_block_result_var"};
