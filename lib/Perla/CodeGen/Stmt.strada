            # `return %h` in scalar context yields keycount (or "k/n"
            # historical form). Without this `my $y = func()` got the
            # full hash StradaValue, printed as ARRAY-stringification.
            Perla::CodeGen::ind($cg); Perla::CodeGen::emit($cg, "if (!__perla_caller_want_list && __ret_val && !STRADA_IS_TAGGED_INT(__ret_val) && __ret_val->type == STRADA_HASH) { StradaHash *__rrhv = strada_deref_hash(__ret_val); int64_t __rrhn = __rrhv ? (int64_t)__rrhv->num_entries : 0; strada_decref(__ret_val); __ret_val = STRADA_MAKE_TAGGED_INT(__rrhn); }\n");
            my array @lv = keys(%{$cg->{"local_vars"}});
