#!/bin/bash
# configure — Perla build configuration (optional)
#
# Perla builds against the SYSTEM-installed Strada by default; the Makefile
# self-locates `strada`/`stradac` on PATH and their installed runtime + PCRE2,
# so running configure is optional. Use it to pin a prefix, point at a Strada
# *source tree*, or generate perla.conf.
#
# Usage: ./configure [options]
#   --prefix=PATH      Installation prefix (default: /usr/local)
#   --strada-dir=PATH  Build against a Strada source/dev tree instead of the
#                      system install (optional)
#   --help             Show this help

PREFIX="/usr/local"
STRADA_DIR=""

for arg in "$@"; do
    case "$arg" in
        --prefix=*)     PREFIX="${arg#--prefix=}" ;;
        --strada-dir=*) STRADA_DIR="${arg#--strada-dir=}" ;;
        --help)
            sed -n '2,13p' "$0" | sed 's/^# \{0,1\}//'
            exit 0
            ;;
        *)
            echo "Unknown option: $arg" >&2
            exit 1
            ;;
    esac
done

echo "Perla configuration"
echo "  Prefix:     $PREFIX"

# --- Locate Strada -----------------------------------------------------------
STRADA_RUNTIME=""
STRADA_VENDOR=""
if [ -n "$STRADA_DIR" ]; then
    STRADA_DIR=$(cd "$STRADA_DIR" 2>/dev/null && pwd) || STRADA_DIR=$(realpath "$STRADA_DIR" 2>/dev/null)
    echo "  Strada:     source tree at $STRADA_DIR"
    if [ ! -f "$STRADA_DIR/stradac" ]; then
        echo "ERROR: Strada compiler not found at $STRADA_DIR/stradac" >&2
        echo "Build Strada first: (cd $STRADA_DIR && make)" >&2
        exit 1
    fi
    if [ ! -f "$STRADA_DIR/runtime/strada_runtime.h" ]; then
        echo "ERROR: Strada runtime header not found under $STRADA_DIR/runtime" >&2
        exit 1
    fi
    STRADA_RUNTIME="$STRADA_DIR/runtime"
    STRADA_VENDOR="$STRADA_DIR/vendor/pcre2"
else
    SB="$(command -v strada 2>/dev/null || true)"
    if [ -z "$SB" ]; then
        echo "ERROR: 'strada' not found on PATH." >&2
        echo "Install Strada, or pass --strada-dir=/path/to/strada-source." >&2
        exit 1
    fi
    STRADA_LIB="$(cd "$(dirname "$SB")/.." && pwd)/lib/strada"
    echo "  Strada:     system ($SB)"
    if [ ! -f "$STRADA_LIB/runtime/strada_runtime.h" ]; then
        echo "ERROR: Strada runtime header not found at $STRADA_LIB/runtime" >&2
        echo "Reinstall Strada so it ships its runtime headers (make install)." >&2
        exit 1
    fi
    STRADA_RUNTIME="$STRADA_LIB/runtime"
    STRADA_VENDOR="$STRADA_LIB/vendor/pcre2"
fi

# --- gcc ---------------------------------------------------------------------
if ! command -v gcc >/dev/null 2>&1; then
    echo "ERROR: gcc not found" >&2
    exit 1
fi
echo "  gcc:        $(gcc --version | head -1)"

# --- PCRE2 -------------------------------------------------------------------
if [ -f "$STRADA_VENDOR/libpcre2-8.a" ]; then
    echo "  PCRE2:      bundled (from Strada)"
elif pkg-config --exists libpcre2-8 2>/dev/null; then
    echo "  PCRE2:      system"
else
    echo "  PCRE2:      not found (regex will use POSIX)"
fi

# --- Write config.mk ---------------------------------------------------------
# Only emit STRADA_DIR when the user pinned a source tree; otherwise the
# Makefile's system-strada default applies.
{
    echo "# Generated by configure — do not edit"
    echo "PREFIX = $PREFIX"
    [ -n "$STRADA_DIR" ] && echo "STRADA_DIR = $STRADA_DIR"
    echo "LIBDIR = $PREFIX/lib/perla"
    echo "BINDIR = $PREFIX/bin"
    echo "ETCDIR = $PREFIX/etc"
    echo "SHAREDIR = $PREFIX/share/perla"
} > config.mk

# --- Generate perla.conf -----------------------------------------------------
{
    echo "# perla.conf — generated by configure"
    echo "lib_path = $PREFIX/lib/perla:$PREFIX/share/perla/lib"
    [ -n "$STRADA_DIR" ] && echo "strada_dir = $STRADA_DIR"
} > perla.conf

echo ""
echo "Configuration written to config.mk and perla.conf"
echo "Run 'make' to build, 'make install' to install"
